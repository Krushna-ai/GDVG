{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/anime/[id]/[slug]",
      "regex": "^/anime/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid",
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/anime/(?<nxtPid>[^/]+?)/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/drama/[id]/[slug]",
      "regex": "^/drama/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid",
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/drama/(?<nxtPid>[^/]+?)/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/movies/[id]/[slug]",
      "regex": "^/movies/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid",
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/movies/(?<nxtPid>[^/]+?)/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/people/[id]/[slug]",
      "regex": "^/people/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid",
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/people/(?<nxtPid>[^/]+?)/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/series/[id]/[slug]",
      "regex": "^/series/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid",
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/series/(?<nxtPid>[^/]+?)/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/account",
      "regex": "^/account(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/account(?:/)?$"
    },
    {
      "page": "/movies",
      "regex": "^/movies(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/movies(?:/)?$"
    },
    {
      "page": "/mylist",
      "regex": "^/mylist(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/mylist(?:/)?$"
    },
    {
      "page": "/people",
      "regex": "^/people(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/people(?:/)?$"
    },
    {
      "page": "/series",
      "regex": "^/series(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/series(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}