10:T40b,{"@context":"https://schema.org","@type":"TVSeries","name":"Journey to the West","description":"Journey to the West is a Hong Kong television series adapted from the classical novel of the same title. Starring Dicky Cheung, Kwong Wah, Wayne Lai and Evergreen Mak, the series was produced by TVB and was first broadcast on TVB Jade in Hong Kong in November 1996. A sequel, Journey to the West II, was broadcast in 1998, but the role of the Monkey King was played by Benny Chan instead, due to contract problems between Dicky Cheung and TVB. Cheung later reprised the role in another television series The Monkey King: Quest for the Sutra, which was broadcast on TVB but not produced by the station.","image":"https://image.tmdb.org/t/p/w500/2jCQdd7HEKCI0lsPrzHdiEUYWNt.jpg","datePublished":"1996-11-18","numberOfEpisodes":72,"countryOfOrigin":"HK","inLanguage":"cn","genre":["Drama","Action & Adventure","Sci-Fi & Fantasy",null,null,null],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.3,"bestRating":10,"ratingCount":14}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"a0add831-8e9a-4313-b2f9-613c046afad1","tmdb_id":13922,"imdb_id":"tt1459024","content_type":"drama","title":"Journey to the West","original_title":"西遊記","overview":"Journey to the West is a Hong Kong television series adapted from the classical novel of the same title. Starring Dicky Cheung, Kwong Wah, Wayne Lai and Evergreen Mak, the series was produced by TVB and was first broadcast on TVB Jade in Hong Kong in November 1996. A sequel, Journey to the West II, was broadcast in 1998, but the role of the Monkey King was played by Benny Chan instead, due to contract problems between Dicky Cheung and TVB. Cheung later reprised the role in another television series The Monkey King: Quest for the Sutra, which was broadcast on TVB but not produced by the station.","poster_path":"/2jCQdd7HEKCI0lsPrzHdiEUYWNt.jpg","bac