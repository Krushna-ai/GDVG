5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Witness to a Prosecution\",\"description\":\"Witness to a Prosecution is a Hong Kong television series produced by TVB. The original broadcast was on the TVB Jade network with 45-minute episodes airing five days a week from 20 December 1999 to 16 January 2000. The drama stars Bobby Au-yeung as the famous historical forensic medical expert Song Ci. Set during the Southern Song Dynasty of Mid-Imperial China, Witness to a Prosecution tells a fictionalised account of Chee's modest beginnings and the events leading to the creation of his book Collected Cases of Injustice Rectified, the world's earliest documentation of forensic science.\",\"image\":\"https://image.tmdb.org/t/p/w500/fbonuuEAxTjoPFXTonuDI4ZAcSr.jpg\",\"datePublished\":\"1999-12-20\",\"numberOfEpisodes\":44,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"cn\",\"genre\":[\"Crime\",null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.4,\"bestRating\":10,\"ratingCount\":10}}"}}],["$","$L10",null,{"initialDrama":{"id":"7c10f48a-88ff-4c02-a53a-06eea815e0e4","tmdb_id":8919,"imdb_id":"tt11799948","content_type":"drama","title":"Witness to a Prosecution","original_title":"洗冤錄","overview":"Witness to a Prosecution is a Hong Kong television series produced by TVB. The original broadcast was on the TVB Jade network with 45-minute episodes airing five days a week from 20 December 1999 to 16 January 2000. The drama stars Bobby Au-yeung as the famous historical forensic medical expert Song Ci. Set during the Southern Song Dynasty of Mid-Imperial China, Witness to a Prosecution tells a fictionalised account of Chee's modest beginnings and the events leading to the creation of his book Collected Cases of Injustice Rectified, the world's earliest documentation of forensic science.","poster_path":"/fbonuuEAxTjoPFXTonuDI4ZAcSr.jpg","backdrop_path