10:T4b4,{"@context":"https://schema.org","@type":"TVSeries","name":"Sinister Beings","description":"Hui Chun-sum is an elite OCTB officer. He is fearless and competent. His boss thinks highly of him, and his colleagues really admire him. But his ultimate dream is to join SDU. Another elite OCTB officer Shum Wai-lik has a shrewd mind and extensive experience. Although the duo have different approaches, but they are like-minded and ideally complement each other. Police suffer heavy casualties as they are ambushed by thugs. To catch the culprit, Chun-sum forgets his dream and stays with OCTB. Moreover, Chun-sum and Wai-lik are faced with successive nasty cases that are tortuous, surreptitious, tricky and baffling. The duo use reverse thinking, psychological game theory and meticulous analysis to decipher the criminals’ thoughts and motives. No crook can escape the long arm of the law!","image":"https://image.tmdb.org/t/p/w500/o8ygqy0d7xrW1Qhpc3Fdaio7Y2d.jpg","datePublished":"2021-05-03","numberOfEpisodes":60,"countryOfOrigin":"HK","inLanguage":"cn","genre":["Crime","Action & Adventure","Drama",null],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.3,"bestRating":10,"ratingCount":3}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"a23940ab-d2bc-4e3e-963c-4278c10d8327","tmdb_id":124727,"imdb_id":"tt14614752","content_type":"drama","title":"Sinister Beings","original_title":"逆天奇案","overview":"Hui Chun-sum is an elite OCTB officer. He is fearless and competent. His boss thinks highly of him, and his colleagues really admire him. But his ultimate dream is to join SDU. Another elite OCTB officer Shum Wai-lik has a shrewd mind and extensive experience. Although the duo have different approaches, but they are like-minded and ideally complement each other. Police suffer heavy casualties as they are ambushed by thugs. To catch the culprit, Chun-sum forgets his dream and stays with OCTB. Moreover, Chun-sum and Wai-lik are faced with successive nasty cases that are tortuous, surreptitious, tricky and baffling. The duo use reverse thinking, psychological game theory and meticulous analysis to decipher the criminals’ thoughts and motives. No crook can escape the long arm of the law!","poster_path":"/o8ygqy0d7xrW1Qhpc3Fdaio7Y2d.jpg","backdrop_path":"/3Xtc2iqCBXoXFmD8GhVdYaIY111.jpg","release_date":null,"first_air_date":"2021-05-03","status":"published","original_language":"cn","origin_country":["HK"],"genres":[{"id":80,"name":"Crime"},{"id":10759,"name":"Action & Adventure"},{"id":18,"name":"Drama"},"drama television series"],"popularity":12.6065,"vote_average":8.3,"vote_count":3,"runtime":null,"number_of_seasons":2,"number_of_episodes":60,"created_at":"2026-01-26T16:51:08.565608+00:00","updated_at":"2026-01-26T16:51:08.565608+00:00","tagline":null,"homepage":"https://programme.tvb.com/drama/sinisterbeings","budget":null,"revenue":null,"production_companies":[],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":null,"in_production":false,"tmdb_status":"Returning Series","content_rating":null,"keywords":[],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/o8ygqy0d7xrW1Qhpc3Fdaio7Y2d.jpg","images":{"logos":[{"width":1799,"height":890,"file_path":"/ubh2ODrlVKIPtpAhyLxukvOPFqt.png","iso_639_1":null,"vote_average":0}],"posters":[{"width":2000,"height":3000,"file_path":"/o8ygqy0d7xrW1Qhpc3Fdaio7Y2d.jpg","iso_639_1":"zh","vote_average":3.334},{"width":500,"height":750,"file_path":"/gAhdCbIyfDgh5MbRyeudsgYfli2.jpg","iso_639_1":"zh","vote_average":0},{"width":1080,"height":1527,"file_path":"/rfU7BY2aXRDwGgY4AO25e4KXMTO.jpg","iso_639_1":"zh","vote_average":0},{"width":660,"height":946,"file_path":"/o0bmD7bvxVDwL