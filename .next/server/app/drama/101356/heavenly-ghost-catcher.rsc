5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Heavenly Ghost Catcher\",\"description\":\"A Singapore co-production with Taiwan TV about the legendary ghost-catcher Zhong Kui, with a star-studded cast comprising Singaporean and Taiwanese drama artistes. The series is divided into 5 main stories: Yang Guifei, Zhong Kui meets Justice Bao, The Secret of the Goblet, Beauty from Jiangshan and Snow in June. Zhong Kui is a widely known legendary figure. He is a ghost catcher in China. He is conferred a title of “Ghost Catching General” and “Yama – King of Hell”. It authorises him to manage all matters of injustice. Zhong Kui helps to redress cases in which the victims die unjustly. The culprits of mischief will surely be punished.\",\"image\":\"https://image.tmdb.org/t/p/w500/cpjE077pzbc95p4bjjmm5ZAA4ow.jpg\",\"datePublished\":\"1994-01-01\",\"numberOfEpisodes\":91,\"countryOfOrigin\":\"SG\",\"inLanguage\":\"zh\",\"genre\":[\"Drama\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5,\"bestRating\":10,\"ratingCount\":1}}"}}],["$","$L10",null,{"initialDrama":{"id":"26f69699-d531-46d6-914c-76a6f9bcfd2a","tmdb_id":96511,"imdb_id":null,"content_type":"drama","title":"Heavenly Ghost Catcher","original_title":"天师钟馗","overview":"A Singapore co-production with Taiwan TV about the legendary ghost-catcher Zhong Kui, with a star-studded cast comprising Singaporean and Taiwanese drama artistes. The series is divided into 5 main stories: Yang Guifei, Zhong Kui meets Justice Bao, The Secret of the Goblet, Beauty from Jiangshan and Snow in June. Zhong Kui is a widely known legendary figure. He is a ghost catcher in China. He is conferred a title of “Ghost Catching General” and “Yama – King of Hell”. It authorises him to manage all matters of injustice. Zhong Kui helps to redress cases in which the victims die unjustly. The culprits of mischief will surely be punished.","poster_path":"/cpjE077pzbc95p4bjjmm5ZAA4ow.jpg","backdrop_path":"/mwOTpvbui9HUZRn3SQcpyFx9H0V.jpg","release_date":null,"first_air_date":"1994-01-01","status":"published","original_language":"zh","origin_country":["SG","TW"],"genres":[{"id":18,"name":"Drama"}],"popularity":6.9457,"vote_average":5,"vote_count":1,"runtime":null,"number_of_seasons":2,"number_of_episodes":91,"created_at":"2026-01-26T16:50:37.696517+00:00","updated_at":"2026-01-26T16:50:37.696517+00:00","tagline":null,"homepage":"https://www.mewatch.sg/show/Heavenly-Ghost-Catcher-28097","budget":null,"revenue":null,"production_companies":[],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":null,"in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/cpjE077pzbc95p4bjjmm5ZAA4ow.jpg","images":{"logos":[],"posters":[{"width":1000,"height":1500,"file_path":"/cpjE077pzbc95p4bjjmm5ZAA4ow.jpg","iso_639_1":null,"vote_average":3.334},{"width":850,"height":1276,"file_path":"/tZBCObsrJ9eQDvGlILmRuxZcXZt.jpg","iso_639_1":null,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/mwOTpvbui9HUZRn3SQcpyFx9H0V.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/7xsh3Q4vbFLy30mqAAxoYhsAiU8.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/qp8VcviXM2mgwHpTKX5AVFZXPpI.jpg","iso_639_1":"zh","vote_average":0},{"width":1920,"height":1080,"file_path":"/45XFiV1DMWi8S0DZ5O9Kc1LgX97.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/ozRg5rI5ZPnm7eCVKrDRRXKiRhx.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T01:31:42.822+00:00","enrichment_cycle":1,"translations":null,