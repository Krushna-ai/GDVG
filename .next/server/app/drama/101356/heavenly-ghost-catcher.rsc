9:{"metadata":[["$","title","0",{"children":"Heavenly Ghost Catcher | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"A Singapore co-production with Taiwan TV about the legendary ghost-catcher Zhong Kui, with a star-studded cast comprising Singaporean and Taiwanese drama artistes. The series is divided into 5 main stories: Yang Guifei, Zhong Kui meets Justice Bao, The Secret of the Goblet, Beauty from Jiangshan and Snow in June. Zhong Kui is a widely known legendary figure. He is a ghost catcher in China. He is conferred a title of “Ghost Catching General” and “Yama – King of Hell”. It authorises him to manage all matters of injustice. Zhong Kui helps to redress cases in which the victims die unjustly. The culprits of mischief will surely be punished."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/drama/101356/heavenly-ghost-catcher"}],["$","meta","5",{"property":"og:title","content":"Heavenly Ghost Catcher"}],["$","meta","6",{"property":"og:description","content":"A Singapore co-production with Taiwan TV about the legendary ghost-catcher Zhong Kui, with a star-studded cast comprising Singaporean and Taiwanese drama artistes. The series is divided into 5 main stories: Yang Guifei, Zhong Kui meets Justice Bao, The Secret of the Goblet, Beauty from Jiangshan and Snow in June. Zhong Kui is a widely known legendary figure. He is a ghost catcher in China. He is conferred a title of “Ghost Catching General” and “Yama – King of Hell”. It authorises him to manage all matters of injustice. Zhong Kui helps to redress cases in which the victims die unjustly. The culprits of mischief will surely be punished."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/drama/101356/heavenly-ghost-catcher"}],["$","meta","8",{"proper