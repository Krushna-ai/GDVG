10:T488,{"@context":"https://schema.org","@type":"TVSeries","name":"Some Day","description":"After taking charge of her deceased husband’s jewelry shop, MING SUM-ON (Lee Sze Kei) makes it a big success with the help of both jewelry designers, MA HO-MAN (Cheng Tse Sing) and his wife CHENG KIU (Teresa Mo). However, KIU falls out with SUM after her divorce with MAN for SUM didn’t tell her that MAN was committing adultery. SUM’s youngest uncle (Lee Sze Chit) tries to mediate between them but it doesn’t work. On top of the dispute with KIU, SUM is also troubled by the Administrative Consultant CHU BO (Lau Tan) who is assigned by her husband’s family and the rebellious step daughter SHEK HO-YEE (Aimee Chan).  With the support of her best friend LAM CHING-LING (Kristal Tin) after the divorce, KIU has transformed from a home-loving housewife into a total workaholic. Consequently, she is promoted as chief designer and achieves great success at work...","image":"https://image.tmdb.org/t/p/w500/k7nlCXYQcn2pweP9VDJ3yjg1Np2.jpg","datePublished":"2010-06-14","numberOfEpisodes":118,"countryOfOrigin":"HK","inLanguage":"cn","genre":["Family","Comedy",null]}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"ab6c03d3-8e63-4ad5-8571-c7f59236b947","tmdb_id":32905,"imdb_id":null,"content_type":"drama","title":"Some Day","original_title":"天天天晴","overview":"After taking charge of her deceased husband’s jewelry shop, MING SUM-ON (Lee Sze Kei) makes it a big success with the help of both jewelry designers, MA HO-MAN (Cheng Tse Sing) and his wife CHENG KIU (Teresa Mo). However, KIU falls out with SUM after her divorce with MAN for SUM didn’t tell her that MAN was committing adultery. SUM’s youngest uncle (Lee Sze Chit) tries to mediate between them but it doesn’t work. On top of the dispute with KIU, SUM is also troubled by the Administrative Consultant CHU BO (Lau Tan) who is assigned by her husband’s family and the rebellious step daughter SHEK HO-YEE (Aimee Chan).  With the support of her best friend LAM CHING-LING (Kristal Tin) after the divorce, KIU has transformed from a home-loving housewife into a total workaholic. Consequently, she is promoted as chief designer and achieves great success at work...","poster_path":"/k7nlCXYQcn2pweP9VDJ3yjg1Np2.jpg","backdrop_path":"/ku5ViaNxgcGh0mkLZd8BP94NfdX.jpg","release_date":null,"first_air_date":"2010-06-14","status":"published","original_language":"cn","origin_country":["HK"],"genres":[{"id":10751,"name":"Family"},{"id":35,"name":"Comedy"},"drama television series"],"popularity":17.008,"vote_average":null,"vote_count":null,"runtime":null,"number_of_seasons":1,"number_of_episodes":118,"created_at":"2026-01-26T16:49:53.073985+00:00","updated_at":"2026-01-26T16:49:53.073985+00:00","tagline":null,"homepage":"https://www.mytvsuper.com/en/programme/someday0001_117115/Some-Day/","budget":null,"revenue":null,"production_companies":[{"id":0,"name":"TVB"}],"production_countries":null,"spoken_languages":[{"name":"Cantonese","iso_639_1":"","english_name":"Cantonese"}],"networks":[],"last_air_date":null,"in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/k7nlCXYQcn2pweP9VDJ3yjg1Np2.jpg","images":{"logos":[],"posters":[{"width":720,"height":1080,"file_path":"/k7nlCXYQcn2pweP9VDJ3yjg1Np2.jpg","iso_639_1":null,"vote_average":3.334},{"width":600,"height":900,"file_path":"/uQuhctS5OvyqlkU60KP4Fmxmyy9.jpg","iso_639_1":null,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/ku5ViaNxgcGh0mkLZd8BP94NfdX.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-22T22:39:20.571+00:00","enrichment_cycle":1,"translations":null