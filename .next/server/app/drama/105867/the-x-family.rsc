5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"The X-Family\",\"description\":\"The X-Family is a Taiwanese drama starring Pauline Lan, Jiro Wang, Danson Tang, Sunnie Huang, Calvin Chen, and Aaron Yan. It is a sequel to 2005 series KO One and was produced by Comic International Productions. The series started filming in June 2006 and wrapped in April 2007. It was broadcast on cable TV Gala Television Variety Show/CH 28 on 8 August 2007 to 23 October 2007.\\n\\nThe prequel KO One was broadcast on 26 November 2005 to 27 May 2006 and a threequel, K.O.3an Guo was broadcast on 28 February 2009 to 27 February 2010, on cable TV Gala Television Variety Show/CH 28.\",\"image\":\"https://image.tmdb.org/t/p/w500/sM0lrIZBgw2ilxqLLgNIE8lHf2I.jpg\",\"datePublished\":\"2007-08-08\",\"numberOfEpisodes\":55,\"countryOfOrigin\":\"TW\",\"inLanguage\":\"zh\",\"genre\":[\"Sci-Fi & Fantasy\",\"Drama\",\"Comedy\",\"Action & Adventure\",\"Family\",null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.7,\"bestRating\":10,\"ratingCount\":6}}"}}],["$","$L10",null,{"initialDrama":{"id":"0841d120-e5dd-42b5-aa95-0dd46cc3b088","tmdb_id":3376,"imdb_id":"tt1848688","content_type":"drama","title":"The X-Family","original_title":"終極一家","overview":"The X-Family is a Taiwanese drama starring Pauline Lan, Jiro Wang, Danson Tang, Sunnie Huang, Calvin Chen, and Aaron Yan. It is a sequel to 2005 series KO One and was produced by Comic International Productions. The series started filming in June 2006 and wrapped in April 2007. It was broadcast on cable TV Gala Television Variety Show/CH 28 on 8 August 2007 to 23 October 2007.\n\nThe prequel KO One was broadcast on 26 November 2005 to 27 May 2006 and a threequel, K.O.3an Guo was broadcast on 28 February 2009 to 27 February 2010, on cable TV Gala Television Variety Show/CH 28.","poster_path":"/sM0lrIZBgw2ilxqLLgNIE8lHf2I.