5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"GoGo Dino\",\"description\":\"There are many different kinds of life form living on planets in the univers. Among them, dinosaurs that are now extict on Earth lives on the planet called M25. The dino-explorers are dispatched in order to let the children of Earth know about the diversity and the beauty of life. The dino-ecplorers are a team of explorers consisting of Dr.Beard, a dinosaur expert who has dedicated his whole life on researching the extinct dinosaurs, and transformable robot dinosaurs. They discover dinosaurs through exploration and help them, and befriend them.\",\"image\":\"https://image.tmdb.org/t/p/w500/vRvhgs48tv7h6Khg3pE3Gi20CUY.jpg\",\"datePublished\":\"2016-01-12\",\"numberOfEpisodes\":260,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"Animation\",\"Kids\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8,\"bestRating\":10,\"ratingCount\":1}}"}}],["$","$L10",null,{"initialDrama":{"id":"79921111-e3d1-4f41-b3cd-d6effbbda0ff","tmdb_id":95112,"imdb_id":null,"content_type":"drama","title":"GoGo Dino","original_title":"고고 다이노","overview":"There are many different kinds of life form living on planets in the univers. Among them, dinosaurs that are now extict on Earth lives on the planet called M25. The dino-explorers are dispatched in order to let the children of Earth know about the diversity and the beauty of life. The dino-ecplorers are a team of explorers consisting of Dr.Beard, a dinosaur expert who has dedicated his whole life on researching the extinct dinosaurs, and transformable robot dinosaurs. They discover dinosaurs through exploration and help them, and befriend them.","poster_path":"/vRvhgs48tv7h6Khg3pE3Gi20CUY.jpg","backdrop_path":"/zbmcpasZZBZhnbx6bkBVR1R4H4M.jpg","release_date":null,"first_air_date":"2016-01-12","status":"published","original_lan