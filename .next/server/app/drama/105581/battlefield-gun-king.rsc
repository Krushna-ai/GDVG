5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Battlefield Gun King\",\"description\":\"During the beginning of year 1945 in the Northeast region, Lu Yinghao returns from military school in the Soviet Union for his father's birthday celebrations at An Tai Hospital. He arrives just in time to witness the atrocities committed by the Japanese army as they slaughter innocents and takeover the hospital. Lu Yinghao plots revenge and crosses paths with Li Ruxue, a female warrior on a mission. Along the way, a bandit named Tong Xiaofeng falls in love at first sight with Lu Yinghao and steals important documents from him. Lu Yinghao strives to retrieve the documents but gets coerced into marrying Xiaofeng. Despite the obstacles, he continues on a path of being to be a hero of the people.\",\"image\":\"https://image.tmdb.org/t/p/w500/hIPD0lMkqg67CdtaaRWOC8N5cB7.jpg\",\"datePublished\":\"2017-07-05\",\"numberOfEpisodes\":40,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Drama\",\"War & Politics\"]}"}}],["$","$L10",null,{"initialDrama":{"id":"1e61a17f-3c9a-4d42-9b40-6eced5385a23","tmdb_id":138429,"imdb_id":null,"content_type":"drama","title":"Battlefield Gun King","original_title":"战地枪王","overview":"During the beginning of year 1945 in the Northeast region, Lu Yinghao returns from military school in the Soviet Union for his father's birthday celebrations at An Tai Hospital. He arrives just in time to witness the atrocities committed by the Japanese army as they slaughter innocents and takeover the hospital. Lu Yinghao plots revenge and crosses paths with Li Ruxue, a female warrior on a mission. Along the way, a bandit named Tong Xiaofeng falls in love at first sight with Lu Yinghao and steals important documents from him. Lu Yinghao strives to retrieve the documents but gets coerced into marrying Xiaofeng. Despite the obstacles, he continues on a path 