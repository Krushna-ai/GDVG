9:{"metadata":[["$","title","0",{"children":"Super Trio Series | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"The Super Trio Series is a Hong Kong variety show produced by TVB. The series debuted in 1995, and remained in production for eighteen years due to its popularity. The show was hosted by Eric Tsang and his two assistants - Jerry Lamb and Chin Kar-lok. The show initially ended its run with the airing of the final episode on July 16, 2005. However, on March 9, 2008, the first episode of the show's spin-off series Super Trio Wonder Trip was aired; its main purpose was to introduce a series of new games that are to be imported from various game shows all over the world and would appear in series 8, Super Trio Supreme."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/drama/104250/super-trio-series"}],["$","meta","5",{"property":"og:title","content":"Super Trio Series"}],["$","meta","6",{"property":"og:description","content":"The Super Trio Series is a Hong Kong variety show produced by TVB. The series debuted in 1995, and remained in production for eighteen years due to its popularity. The show was hosted by Eric Tsang and his two assistants - Jerry Lamb and Chin Kar-lok. The show initially ended its run with the airing of the final episode on July 16, 2005. However, on March 9, 2008, the first episode of the show's spin-off series Super Trio Wonder Trip was aired; its main purpose was to introduce a series of new games that are to be imported from various game shows all over the world and would appear in series 8, Super Trio Supreme."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/drama/104250/super-trio-series"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/Sw4nK2