5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Amazing Saturday\",\"description\":\"A group of hungry celebrities listen to poppin’ tunes, from recent hits to all-time-favorites, to correctly dictate a part of the lyrics.\\n\\nThe songs may sound familiar, but the part they must dictate are unclear to the naked ear, as the lyrics are slurred, muffled by strong beats, etc.\\n\\nIf they get the lyrics right, they get to share exquisite regional dishes. But if they get them wrong, a professional eater gobbles it up instead.\",\"image\":\"https://image.tmdb.org/t/p/w500/nEwybsfZBSPjcZamPpKDTaTI5g.jpg\",\"datePublished\":\"2018-04-07\",\"numberOfEpisodes\":420,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"Comedy\",\"Reality\",null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.6,\"bestRating\":10,\"ratingCount\":10}}"}}],["$","$L10",null,{"initialDrama":{"id":"ff05b117-7b11-49cf-8d24-c14019eccb90","tmdb_id":78648,"imdb_id":"tt10160132","content_type":"drama","title":"Amazing Saturday","original_title":"놀라운 토요일","overview":"A group of hungry celebrities listen to poppin’ tunes, from recent hits to all-time-favorites, to correctly dictate a part of the lyrics.\n\nThe songs may sound familiar, but the part they must dictate are unclear to the naked ear, as the lyrics are slurred, muffled by strong beats, etc.\n\nIf they get the lyrics right, they get to share exquisite regional dishes. But if they get them wrong, a professional eater gobbles it up instead.","poster_path":"/nEwybsfZBSPjcZamPpKDTaTI5g.jpg","backdrop_path":"/pNdUVPm6RwvG9Ycd2cuYpLbM7lk.jpg","release_date":null,"first_air_date":"2018-04-07","status":"published","original_language":"ko","origin_country":["KR"],"genres":[{"id":35,"name":"Comedy"},{"id":10764,"name":"Reality"},"variety show","game show"],"popularity":34.5164,"vote_average":7.6,"vote_count":10,