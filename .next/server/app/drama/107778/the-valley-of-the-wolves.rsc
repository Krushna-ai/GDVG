9:{"metadata":[["$","title","0",{"children":"The Valley of The Wolves | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Valley of the Wolves was a Turkish television drama which broadcast mainly on Show TV and then transferred to Kanal D, then atv for its last season. It was mostly about an agent named Polat Alemdar who leaked into the mafia after his plastic surgery. The scenario has direct and indirect references to the Turkish politics and political history from a viewpoint of an undercover agent. Valley of the Wolves became one of the most successful TV shows in Turkey and produced a successful feature film named Valley of the Wolves: Iraq."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/drama/107778/the-valley-of-the-wolves"}],["$","meta","5",{"property":"og:title","content":"The Valley of The Wolves"}],["$","meta","6",{"property":"og:description","content":"Valley of the Wolves was a Turkish television drama which broadcast mainly on Show TV and then transferred to Kanal D, then atv for its last season. It was mostly about an agent named Polat Alemdar who leaked into the mafia after his plastic surgery. The scenario has direct and indirect references to the Turkish politics and political history from a viewpoint of an undercover agent. Valley of the Wolves became one of the most successful TV shows in Turkey and produced a successful feature film named Valley of the Wolves: Iraq."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/drama/107778/the-valley-of-the-wolves"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/aGi8EuXsf5bbM4O59Uu0pucLcT.jpg"}],["$","meta","9",{"property":"og:type","content":"video.tv_show"}],["$","meta","10",{"name":"twitter:card","content":"summa