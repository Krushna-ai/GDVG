10:T509,{"@context":"https://schema.org","@type":"TVSeries","name":"6 of Us","description":"A story of six siblings—Azize, Cemo, Zeliha, Fidan, Samet, and Balım—who, after suddenly losing their parents, struggle to stay united and survive. The roots of their tragedy trace back to their parents, Bala and Rıfat, whose forbidden love began in a village in Mardin. Rıfat, a teacher, falls in love with Bala, but Yavuz, the wealthy and obsessive son of Mardin’s richest family, kidnaps her. Despite his abuse, Bala escapes with Rıfat, and they build a secluded life in the forest, raising six children in peace. However, Yavuz’s revenge shatters their world when he finds and attacks them. Fleeing to Istanbul, the siblings face the dangers of the city while seeking refuge with “Uncle Aslan,” their father’s trusted friend. The story highlights resilience, as the older siblings are forced to grow up quickly to protect their younger brothers and sisters in the face of overwhelming challenges.","image":"https://image.tmdb.org/t/p/w500/l0g0CAq7VjoKslVE9JZZQFMI9Tt.jpg","datePublished":"2024-11-13","numberOfEpisodes":50,"countryOfOrigin":"TR","inLanguage":"tr","genre":["Drama",null],"aggregateRating":{"@type":"AggregateRating","ratingValue":5.5,"bestRating":10,"ratingCount":2}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"cc7b06e8-163a-4a58-83b3-21f640f9de58","tmdb_id":271548,"imdb_id":"tt33349183","content_type":"drama","title":"6 of Us","original_title":"Sahipsizler","overview":"A story of six siblings—Azize, Cemo, Zeliha, Fidan, Samet, and Balım—who, after suddenly losing their parents, struggle to stay united and survive. The roots of their tragedy trace back to their parents, Bala and Rıfat, whose forbidden love began in a village in Mardin. Rıfat, a teacher, falls in love with Bala, but Yavuz, the wealthy and obsessive son of Mardin’s richest family, kidnaps her. Despite his abuse, Bala escapes with Rıfat, and they build a secluded life in the forest, raising six children in peace. However, Yavuz’s revenge shatters their world when he finds and attacks them. Fleeing to Istanbul, the siblings face the dangers of the city while seeking refuge with “Uncle Aslan,” their father’s trusted friend. The story highlights resilience, as the older siblings are forced to grow up quickly to protect their younger brothers and sisters in the face of overwhelming challenges.","poster_path":"/l0g0CAq7VjoKslVE9JZZQFMI9Tt.jpg","backdrop_path":"/gTPfMUXFIgG6HZeR5hif2fvGzOv.jpg","release_date":null,"first_air_date":"2024-11-13","status":"published","original_language":"tr","origin_country":["TR"],"genres":[{"id":18,"name":"Drama"},"drama film"],"popularity":23.5033,"vote_average":5.5,"vote_count":2,"runtime":120,"number_of_seasons":2,"number_of_episodes":50,"created_at":"2026-01-26T16:51:47.26317+00:00","updated_at":"2026-01-26T16:51:47.26317+00:00","tagline":null,"homepage":"https://www.startv.com.tr/dizi/sahipsizler","budget":null,"revenue":null,"production_companies":[],"production_countries":null,"spoken_languages":[{"name":"Turkish","iso_639_1":"","english_name":"Turkish"}],"networks":[],"last_air_date":null,"in_production":false,"tmdb_status":"Returning Series","content_rating":null,"keywords":[],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"TR","main_poster":"/l0g0CAq7VjoKslVE9JZZQFMI9Tt.jpg","images":{"logos":[],"posters":[{"width":720,"height":1080,"file_path":"/l0g0CAq7VjoKslVE9JZZQFMI9Tt.jpg","iso_639_1":"en","vote_average":3.334},{"width":1344,"height":1920,"file_path":"/k1FZ5cpY9kDaHrVpCFlZTlkcCkP.jpg","iso_639_1":"tr","vote_average":3.334},{"width":680,"height":1000,"file_path":"/ifAZPcHSfmzxfJtyeG8zQjDMpaS.jpg","iso_639_1":"tr","vote_average":1.75},{"width":1