10:T4ed,{"@context":"https://schema.org","@type":"TVSeries","name":"Children of Paradise","description":"Iskender was a feared gangster in the dark alleys of Istanbul, known for his own rough code of honor—until betrayal left him bleeding and stripped of everything he had built. When he opens his eyes in a quiet Aegean town, he finds himself surrounded by warmth he has never known: a caring mother, a blind little sister, a home that feels like it was always his. The townspeople believe he is Kamil, a long-lost son returned; only he knows the truth. But the past never lets go—old enemies, blood feuds, and the ghosts of his choices haunt him still. As he uncovers a shocking secret—that this family is bound to him by blood—Iskender stands at a crossroads. Revenge or redemption? Will he remain the ruthless survivor the streets created, or dare to become the man he was meant to be? This is a story of love, betrayal, and the price of becoming truly human.","image":"https://image.tmdb.org/t/p/w500/b6QGAQBiAWXVPQvc9um8o9Q90jY.jpg","datePublished":"2025-09-15","numberOfEpisodes":15,"countryOfOrigin":"TR","inLanguage":"tr","genre":["Drama","Comedy","Family"],"aggregateRating":{"@type":"AggregateRating","ratingValue":1,"bestRating":10,"ratingCount":1}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"b0f82581-b974-4135-9787-c7c09b8e1e04","tmdb_id":299847,"imdb_id":"tt38516654","content_type":"drama","title":"Children of Paradise","original_title":"Cennetin Çocukları","overview":"Iskender was a feared gangster in the dark alleys of Istanbul, known for his own rough code of honor—until betrayal left him bleeding and stripped of everything he had built. When he opens his eyes in a quiet Aegean town, he finds himself surrounded by warmth he has never known: a caring mother, a blind little sister, a home that feels like it was always his. The townspeople believe he is Kamil, a long-lost son returned; only he knows the truth. But the past never lets go—old enemies, blood feuds, and the ghosts of his choices haunt him still. As he uncovers a shocking secret—that this family is bound to him by blood—Iskender stands at a crossroads. Revenge or redemption? Will he remain the ruthless survivor the streets created, or dare to become the man he was meant to be? This is a story of love, betrayal, and the price of becoming truly human.","poster_path":"/b6QGAQBiAWXVPQvc9um8o9Q90jY.jpg","backdrop_path":"/z6SEDeOcBcVk1oFXg60vm94bcKt.jpg","release_date":null,"first_air_date":"2025-09-15","status":"published","original_language":"tr","origin_country":["TR"],"genres":[{"id":18,"name":"Drama"},{"id":35,"name":"Comedy"},{"id":10751,"name":"Family"}],"popularity":6.0777,"vote_average":1,"vote_count":1,"runtime":null,"number_of_seasons":1,"number_of_episodes":15,"created_at":"2026-01-27T21:42:06.223357+00:00","updated_at":"2026-01-27T21:42:06.223357+00:00","tagline":null,"homepage":"https://www.trt1.com.tr/diziler/cennetin-cocuklari","budget":null,"revenue":null,"production_companies":[],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":null,"in_production":false,"tmdb_status":"Returning Series","content_rating":null,"keywords":[],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"TR","main_poster":"/b6QGAQBiAWXVPQvc9um8o9Q90jY.jpg","images":{"logos":[{"width":2128,"height":579,"file_path":"/u9CL2rYYaw8HkA31Yg8bGYeOScZ.png","iso_639_1":"tr","vote_average":0}],"posters":[{"width":1632,"height":2448,"file_path":"/b6QGAQBiAWXVPQvc9um8o9Q90jY.jpg","iso_639_1":"tr","vote_average":0},{"width":768,"height":1152,"file_path":"/8pQEgQwfdXEoYJ9vxUKysTI2FvQ.jpg","iso_639_1":null,"vote_average":0},{"width":600,"height":900,"file_path":"/3xslVcLnnraEZyYsM35qtPbBefi.