5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Smile Again\",\"description\":\"Raised in America by his mentally handicapped mother Anna, Dong Hae dreams of traveling to Korea to propose to the woman he loves.. After qualifying for a speed skating competition, he smuggles his mother to Korea with him, but his undying devotion to her soon begins causing him problems. Finally reconnecting with his lost love Saewa, Dong Hae finds his affections divided when things don’t work out as he planned in this award-winning daily drama.\",\"image\":\"https://image.tmdb.org/t/p/w500/82NWvQzwtNJJVeNXglKRephUExM.jpg\",\"datePublished\":\"2010-10-04\",\"numberOfEpisodes\":159,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"Drama\",\"Comedy\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.5,\"bestRating\":10,\"ratingCount\":2}}"}}],["$","$L10",null,{"initialDrama":{"id":"b80cae59-c9c8-4d2e-8821-fea85f28eda0","tmdb_id":35351,"imdb_id":"tt6141742","content_type":"drama","title":"Smile Again","original_title":"웃어라 동해야","overview":"Raised in America by his mentally handicapped mother Anna, Dong Hae dreams of traveling to Korea to propose to the woman he loves.. After qualifying for a speed skating competition, he smuggles his mother to Korea with him, but his undying devotion to her soon begins causing him problems. Finally reconnecting with his lost love Saewa, Dong Hae finds his affections divided when things don’t work out as he planned in this award-winning daily drama.","poster_path":"/82NWvQzwtNJJVeNXglKRephUExM.jpg","backdrop_path":"/mMkJF2yx4cva4ciCvUuJKrIF9w2.jpg","release_date":null,"first_air_date":"2010-10-04","status":"published","original_language":"ko","origin_country":["KR"],"genres":[{"id":18,"name":"Drama"},{"id":35,"name":"Comedy"},"drama"],"popularity":10.6446,"vote_average":5.5,"vote_count":2,"runtime":null,"number