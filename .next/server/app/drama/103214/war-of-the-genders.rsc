5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"War of the Genders\",\"description\":\"War of the Genders is a Hong Kong sitcom which aired on TVB Jade from 21 February to 7 July 2000. The series was produced by TVB with Tsui Chong-hong serving as the executive producer. An average of 3.1 million viewers watched the episode finale live, creating the highest rating average below the 2003 Charity Football Competition Real Madrid vs Hong Kong and tied with the 2005 Korean TV drama Dae Jang Geum and the 2008 TVB TV drama Moonlight Resonance.\",\"image\":\"https://image.tmdb.org/t/p/w500/aOnBdZbIhISlYFkvVCp8NLZ9qyL.jpg\",\"datePublished\":\"2000-02-21\",\"numberOfEpisodes\":103,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"cn\",\"genre\":[\"Comedy\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.4,\"bestRating\":10,\"ratingCount\":7}}"}}],["$","$L10",null,{"initialDrama":{"id":"bb63408c-2bba-49ba-83e2-1b1844d70bfb","tmdb_id":6262,"imdb_id":"tt10384720","content_type":"drama","title":"War of the Genders","original_title":"男親女愛","overview":"War of the Genders is a Hong Kong sitcom which aired on TVB Jade from 21 February to 7 July 2000. The series was produced by TVB with Tsui Chong-hong serving as the executive producer. An average of 3.1 million viewers watched the episode finale live, creating the highest rating average below the 2003 Charity Football Competition Real Madrid vs Hong Kong and tied with the 2005 Korean TV drama Dae Jang Geum and the 2008 TVB TV drama Moonlight Resonance.","poster_path":"/aOnBdZbIhISlYFkvVCp8NLZ9qyL.jpg","backdrop_path":"/bTD4rLzW5hH6oPAbNWU9ruQOf.jpg","release_date":null,"first_air_date":"2000-02-21","status":"published","original_language":"cn","origin_country":["HK"],"genres":[{"id":35,"name":"Comedy"},"drama television series"],"popularity":25.2658,"vote_average":8.4,"vote_count":7,"runtime":null,"nu