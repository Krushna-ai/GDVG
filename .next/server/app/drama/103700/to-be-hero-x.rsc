5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"TO BE HERO X\",\"description\":\"In a world full of brilliant heroes, it’s the trust of fans that turns heroes into superheroes. If a hero loses the people’s trust, they lose their special abilities. Trust value is collected, quantified, and used to determine a hero’s ranking, displayed on their wrist. Every two years, the top heroes go to a tournament to fight, determine new trust values, and earn their rankings.\",\"image\":\"https://image.tmdb.org/t/p/w500/7ynNG9lYS9HIR8cYMgawO19VPkg.jpg\",\"datePublished\":\"2025-04-06\",\"numberOfEpisodes\":24,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Animation\",\"Action & Adventure\",\"Sci-Fi & Fantasy\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.776,\"bestRating\":10,\"ratingCount\":98}}"}}],["$","$L10",null,{"initialDrama":{"id":"e2286ee4-6e21-4568-9970-48f1197a827a","tmdb_id":272059,"imdb_id":"tt23139038","content_type":"drama","title":"TO BE HERO X","original_title":"凸变英雄X","overview":"In a world full of brilliant heroes, it’s the trust of fans that turns heroes into superheroes. If a hero loses the people’s trust, they lose their special abilities. Trust value is collected, quantified, and used to determine a hero’s ranking, displayed on their wrist. Every two years, the top heroes go to a tournament to fight, determine new trust values, and earn their rankings.","poster_path":"/7ynNG9lYS9HIR8cYMgawO19VPkg.jpg","backdrop_path":"/4b0oKiGtlwX19b0y6tQQC1ea0o5.jpg","release_date":null,"first_air_date":"2025-04-06","status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":16,"name":"Animation"},{"id":10759,"name":"Action & Adventure"},{"id":10765,"name":"Sci-Fi & Fantasy"},"anime/manga style"],"popularity":13.2023,"vote_average":8.776,"vote_count":98,"runtime":null,"number_of_seasons":2,"nu