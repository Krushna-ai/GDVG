10:T4a6,{"@context":"https://schema.org","@type":"TVSeries","name":"Detective Investigation Files","description":"\"Detective Investigation Files\" revolves around the professional and meticulous investigations carried out by a group of dedicated police officers. As they delve into mysterious deaths with unclear causes, they tirelessly work towards maintaining peace and security for the people. However, their demanding job often comes at the expense of personal happiness.\n\nCheung Dai Yong, a brilliant and astute police officer, has a track record of solving crucial cases. His trusted colleague, Lee Chung Yee, stands by his side, and together they tackle challenging and complex cases. Amidst their work, Dai Yong encounters Ko Jit, a tenacious journalist. Despite their initial conflicts, a deepening connection blossoms between them. However, Ko Jit already has a romantic partner.","image":"https://image.tmdb.org/t/p/w500/wivAFRPJJTvV8nloc2HjcwdeWxh.jpg","datePublished":"1995-03-13","numberOfEpisodes":150,"countryOfOrigin":"HK","inLanguage":"cn","genre":["Mystery","Crime","Drama",null],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.3,"bestRating":10,"ratingCount":9}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"269e7767-bab1-405e-b7df-8d9c091fd9fb","tmdb_id":71971,"imdb_id":"tt1332051","content_type":"drama","title":"Detective Investigation Files","original_title":"刑事偵緝檔案","overview":"\"Detective Investigation Files\" revolves around the professional and meticulous investigations carried out by a group of dedicated police officers. As they delve into mysterious deaths with unclear causes, they tirelessly work towards maintaining peace and security for the people. However, their demanding job often comes at the expense of personal happiness.\n\nCheung Dai Yong, a brilliant and astute police officer, has a track record of solving crucial cases. His trusted colleague, Lee Chung Yee, stands by his side, and together they tackle challenging and complex cases. Amidst their work, Dai Yong encounters Ko Jit, a tenacious journalist. Despite their initial conflicts, a deepening connection blossoms between them. However, Ko Jit already has a romantic partner.","poster_path":"/wivAFRPJJTvV8nloc2HjcwdeWxh.jpg","backdrop_path":"/uWDkmJL0Hg5URfQJmqvXPJzl1TD.jpg","release_date":null,"first_air_date":"1995-03-13","status":"published","original_language":"cn","origin_country":["HK"],"genres":[{"id":9648,"name":"Mystery"},{"id":80,"name":"Crime"},{"id":18,"name":"Drama"},"drama television series"],"popularity":13.6877,"vote_average":8.3,"vote_count":9,"runtime":null,"number_of_seasons":4,"number_of_episodes":150,"created_at":"2026-01-26T16:50:20.29117+00:00","updated_at":"2026-01-26T16:50:20.29117+00:00","tagline":null,"homepage":"https://www.mytvsuper.com/en/programme/detectiveinvestigationfiles0001_116208/Detective-Investigation-Files/","budget":null,"revenue":null,"production_companies":[{"id":0,"name":"TVB"}],"production_countries":null,"spoken_languages":[{"name":"Cantonese","iso_639_1":"","english_name":"Cantonese"}],"networks":[],"last_air_date":null,"in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/wivAFRPJJTvV8nloc2HjcwdeWxh.jpg","images":{"logos":[{"width":819,"height":301,"file_path":"/hj1httBkjAg71xrAv79mhODPrSc.png","iso_639_1":"zh","vote_average":0}],"posters":[{"width":2000,"height":3000,"file_path":"/wivAFRPJJTvV8nloc2HjcwdeWxh.jpg","iso_639_1":"zh","vote_average":3.334},{"width":500,"height":750,"file_path":"/tQFBxrSKhz34p224zCgjHjBmhXy.jpg","iso_639_1":null,"vote_average":2.278},{"width":945,"height":1350,"file_path":"/6WtsF2OCjFtNqu