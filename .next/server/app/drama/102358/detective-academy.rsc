10:T49e,{"@context":"https://schema.org","@type":"TVSeries","name":"Detective Academy","description":"\"Detective College\", as a derivative of the fifth season of \"Who's the Murderer\", is a star reasoning variety show where selected detective assistants launched by Mango TV. The star guests determine the number of advances by rolling the dice on the checkerboard. When the game is triggered, the corresponding game needs to be completed. The first guest to reach the end becomes the current No.1. The program combines the form of team battles and individual battles to inspire the star guests ’IQ and Contest of logical ability. No. 1 selected in the show will appear on the scene of the fifth season of \"Who's the Murderer\". \"Detective College\" consists of Pu Yixing, Zhou Junwei, Tang Jiuzhou, Qi Sijun, Shi Kai, Guo Wentao, Shao Mingming, etc., and premiered on November 3, 2019.","image":"https://image.tmdb.org/t/p/w500/wuUvhZ2WLqX1z0b1NXkapWoov9j.jpg","datePublished":"2019-11-03","numberOfEpisodes":219,"countryOfOrigin":"CN","inLanguage":"zh","genre":["Reality","Mystery"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.333,"bestRating":10,"ratingCount":3}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"f958c00c-93c0-4690-9d23-b51de438beb2","tmdb_id":114473,"imdb_id":null,"content_type":"drama","title":"Detective Academy","original_title":"名侦探学院","overview":"\"Detective College\", as a derivative of the fifth season of \"Who's the Murderer\", is a star reasoning variety show where selected detective assistants launched by Mango TV. The star guests determine the number of advances by rolling the dice on the checkerboard. When the game is triggered, the corresponding game needs to be completed. The first guest to reach the end becomes the current No.1. The program combines the form of team battles and individual battles to inspire the star guests ’IQ and Contest of logical ability. No. 1 selected in the show will appear on the scene of the fifth season of \"Who's the Murderer\". \"Detective College\" consists of Pu Yixing, Zhou Junwei, Tang Jiuzhou, Qi Sijun, Shi Kai, Guo Wentao, Shao Mingming, etc., and premiered on November 3, 2019.","poster_path":"/wuUvhZ2WLqX1z0b1NXkapWoov9j.jpg","backdrop_path":"/hHTfyEC8WWB8XZUkqFNidYDL8MP.jpg","release_date":null,"first_air_date":"2019-11-03","status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":10764,"name":"Reality"},{"id":9648,"name":"Mystery"}],"popularity":24.2646,"vote_average":7.333,"vote_count":3,"runtime":null,"number_of_seasons":9,"number_of_episodes":219,"created_at":"2026-01-26T21:46:36.83919+00:00","updated_at":"2026-01-26T21:46:36.83919+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":null,"in_production":false,"tmdb_status":"Returning Series","content_rating":null,"keywords":[],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/wuUvhZ2WLqX1z0b1NXkapWoov9j.jpg","images":{"logos":[{"width":826,"height":610,"file_path":"/mfTaNYQGIwB0LppEfVnPmT8ympC.png","iso_639_1":"zh","vote_average":3.334},{"width":996,"height":996,"file_path":"/eNVK5HUhBRPRzJykbubz2VwY1lJ.png","iso_639_1":"zh","vote_average":0},{"width":775,"height":661,"file_path":"/lknV2KnGSvgrRHnEWZM91EXKvmZ.png","iso_639_1":"zh","vote_average":0}],"posters":[{"width":1080,"height":1620,"file_path":"/wuUvhZ2WLqX1z0b1NXkapWoov9j.jpg","iso_639_1":"zh","vote_average":3.334},{"width":500,"height":750,"file_path":"/zkiB7hiRpCq14tjVr3EhMN3WLjN.jpg","iso_639_1":"zh","vote_average":0}],"backdrops":[{"width":2160,"height":1212,"file_path":"/hHTfyEC8WWB8XZUkqFNid