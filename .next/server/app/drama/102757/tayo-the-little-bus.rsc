5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Tayo the Little Bus\",\"description\":\"Tayo the Little Bus is a South Korean computer-generated animated television series created by Educational Broadcasting System, Iconix Entertainment, Seoul and Hot Animation which is owned by HiT Entertainment. The Korean-dubbed series began airing on EBS in 2010 and the English-dubbed series aired on Disney Junior in 2012. The latter is also scheduled to air on Disney Channel and Cartoonito in 2013. The narrator of the UK series is Michael Angelis who also narrates the UK series of Thomas & Friends.\",\"image\":\"https://image.tmdb.org/t/p/w500/ieUwI8Y8FhhFNWVOwau0gDoHPnj.jpg\",\"datePublished\":\"2010-08-23\",\"numberOfEpisodes\":182,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"Animation\",\"Kids\",\"Comedy\",\"Family\",null,null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.7,\"bestRating\":10,\"ratingCount\":6}}"}}],["$","$L10",null,{"initialDrama":{"id":"23da0086-fbe5-45a8-96f5-a4e76a056b2f","tmdb_id":45039,"imdb_id":"tt3270208","content_type":"drama","title":"Tayo the Little Bus","original_title":"꼬마버스 타요","overview":"Tayo the Little Bus is a South Korean computer-generated animated television series created by Educational Broadcasting System, Iconix Entertainment, Seoul and Hot Animation which is owned by HiT Entertainment. The Korean-dubbed series began airing on EBS in 2010 and the English-dubbed series aired on Disney Junior in 2012. The latter is also scheduled to air on Disney Channel and Cartoonito in 2013. The narrator of the UK series is Michael Angelis who also narrates the UK series of Thomas & Friends.","poster_path":"/ieUwI8Y8FhhFNWVOwau0gDoHPnj.jpg","backdrop_path":"/fLn6AM7jUpXNrUOoAAJuHXaI9En.jpg","release_date":null,"first_air_date":"2010-08-23","status":"published","original_language":"ko","origin_cou