10:T426,{"@context":"https://schema.org","@type":"TVSeries","name":"Pluto","description":"Ai-oon is the disappointing twin of successful and beloved Ob-oom. They aren't close.\n\nOn Ob-oom's wedding night, she takes Ai-oon aside and makes a request of her. Ob-oon and her husband Paul will be going away for their honeymoon and she'll be leaving something important behind: a lover, May, she hasn't broken up with—and she wants Ai-oon to do it for her.\n\nIn the early morning following the wedding, Ai-oon learns that the newlyweds got into an accident. Paul has passed away and Ob-oom is in a coma. When Ai-oon decides to fullfil her sister's request, she's shocked to learn that May is both blind and a woman. She finds herself unprepared to complete the task.","image":"https://image.tmdb.org/t/p/w500/i4umoWmqGjVIMyAQYLL64lJcLoS.jpg","datePublished":"2024-10-19","numberOfEpisodes":12,"countryOfOrigin":"TH","inLanguage":"th","genre":["Mystery","Drama",null,null],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.342,"bestRating":10,"ratingCount":19}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"2926ecfa-195b-47b5-891d-ab3e0042fd1e","tmdb_id":237330,"imdb_id":"tt29688734","content_type":"drama","title":"Pluto","original_title":"นิทาน ดวงดาว ความรัก","overview":"Ai-oon is the disappointing twin of successful and beloved Ob-oom. They aren't close.\n\nOn Ob-oom's wedding night, she takes Ai-oon aside and makes a request of her. Ob-oon and her husband Paul will be going away for their honeymoon and she'll be leaving something important behind: a lover, May, she hasn't broken up with—and she wants Ai-oon to do it for her.\n\nIn the early morning following the wedding, Ai-oon learns that the newlyweds got into an accident. Paul has passed away and Ob-oom is in a coma. When Ai-oon decides to fullfil her sister's request, she's shocked to learn that May is both blind and a woman. She finds herself unprepared to complete the task.","poster_path":"/i4umoWmqGjVIMyAQYLL64lJcLoS.jpg","backdrop_path":"/f9HEPtPmW22z9dRhWmG9k76P8V.jpg","release_date":null,"first_air_date":"2024-10-19","status":"published","original_language":"th","origin_country":["TH"],"genres":[{"id":9648,"name":"Mystery"},{"id":18,"name":"Drama"},"girls' love","romantic television drama"],"popularity":4.2549,"vote_average":8.342,"vote_count":19,"runtime":null,"number_of_seasons":1,"number_of_episodes":12,"created_at":"2026-01-28T21:53:33.612712+00:00","updated_at":"2026-01-28T21:53:33.612712+00:00","tagline":"Pluto Tales, Stars, Love","homepage":null,"budget":null,"revenue":null,"production_companies":[],"production_countries":null,"spoken_languages":[{"name":"Thai","iso_639_1":"","english_name":"Thai"}],"networks":[],"last_air_date":null,"in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"TH","main_poster":"/apDkL8pCpNw5U7EziC0fJeSZVpH.jpg","images":{"logos":[{"width":581,"height":355,"file_path":"/esBIDwWvSYhdcs7tEz7FZRrIhv4.png","iso_639_1":"th","vote_average":0},{"width":392,"height":411,"file_path":"/3SZtTgkwjMs6Qi5NiKoaJhjYxgq.png","iso_639_1":"th","vote_average":0},{"width":770,"height":628,"file_path":"/8DWN75wNL7ZePoW9sbh8Q5qAhjz.png","iso_639_1":"zh","vote_average":0}],"posters":[{"width":1440,"height":2160,"file_path":"/apDkL8pCpNw5U7EziC0fJeSZVpH.jpg","iso_639_1":"th","vote_average":10},{"width":1440,"height":2160,"file_path":"/i4umoWmqGjVIMyAQYLL64lJcLoS.jpg","iso_639_1":"en","vote_average":3.334},{"width":1642,"height":2464,"file_path":"/7D8692Hi3vCjnYzsbcnwAHOGevO.jpg","iso_639_1":"th","vote_average":2.278},{"width":2000,"height":2800,"file_path":"/xMvsY0QOKMBZVbIB81M721cwOpN.jpg","iso_639_1":"th"