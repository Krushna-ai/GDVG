5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Heart of Greed\",\"description\":\"An abalone that has been passed on for generations. A legacy of a hundred million dollars that everybody wants a share. \\\"Heart of Greed\\\" is a story of a renowned sea-products retailer and a big traditional family, in which there are those who manage to endure to the end, those who consider themselves superior to everyone else, those who love and respect their brothers, those who seek every opportunity to fulfill their ambition, those who stay loyal to their beloved, and those who remain grateful for whatever they get. But when hatred is stirred up among the family, the family will inevitably break down...\",\"image\":\"https://image.tmdb.org/t/p/w500/tJMWiCxC1MP5DoQDL7qy8B3PB2S.jpg\",\"datePublished\":\"2007-04-09\",\"numberOfEpisodes\":120,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"cn\",\"genre\":[\"Drama\",\"Family\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7,\"bestRating\":10,\"ratingCount\":3}}"}}],["$","$L10",null,{"initialDrama":{"id":"a22eda49-c2fb-4abe-941d-e67d5457961d","tmdb_id":5640,"imdb_id":"tt1037955","content_type":"drama","title":"Heart of Greed","original_title":"溏心風暴","overview":"An abalone that has been passed on for generations. A legacy of a hundred million dollars that everybody wants a share. \"Heart of Greed\" is a story of a renowned sea-products retailer and a big traditional family, in which there are those who manage to endure to the end, those who consider themselves superior to everyone else, those who love and respect their brothers, those who seek every opportunity to fulfill their ambition, those who stay loyal to their beloved, and those who remain grateful for whatever they get. But when hatred is stirred up among the family, the family will inevitably break down...","poster_path":"/tJMWiCxC1MP5DoQDL7q