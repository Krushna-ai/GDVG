5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"A Step Into The Past\",\"description\":\"A Step into the Past is a 2001 Hong Kong television series produced by TVB and based on Huang Yi's novel of the same Chinese title. The series tells the story of a 21st-century Hong Kong VIPPU officer who travels back in time to the Warring States period of ancient China. He is involved in a number of important historical events that leads to the first unification of China under the Qin Dynasty. The series' first original broadcast ran from 15 October to 7 December 2001 on the TVB Jade network in Hong Kong.\",\"image\":\"https://image.tmdb.org/t/p/w500/uqTDtAHyUY1X1WHRcjyLGWx6n49.jpg\",\"datePublished\":\"2001-10-15\",\"numberOfEpisodes\":40,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"cn\",\"genre\":[\"Drama\",\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.5,\"bestRating\":10,\"ratingCount\":31}}"}}],["$","$L10",null,{"initialDrama":{"id":"5b3e8c91-c0fa-4329-9377-ffcd95306176","tmdb_id":1375,"imdb_id":"tt0855326","content_type":"drama","title":"A Step Into The Past","original_title":"尋秦記","overview":"A Step into the Past is a 2001 Hong Kong television series produced by TVB and based on Huang Yi's novel of the same Chinese title. The series tells the story of a 21st-century Hong Kong VIPPU officer who travels back in time to the Warring States period of ancient China. He is involved in a number of important historical events that leads to the first unification of China under the Qin Dynasty. The series' first original broadcast ran from 15 October to 7 December 2001 on the TVB Jade network in Hong Kong.","poster_path":"/uqTDtAHyUY1X1WHRcjyLGWx6n49.jpg","backdrop_path":"/5DojFALEJC3qmd8pjVAWRsXzh0U.jpg","release_date":null,"first_air_date":"2001-10-15","status":"published","original_language":"cn","origi