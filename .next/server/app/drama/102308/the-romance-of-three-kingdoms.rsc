5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"The Romance Of Three Kingdoms\",\"description\":\"Adapted from the classical 14th century novel of the same title by Luo Guanzhong, Romance of the Three Kingdoms is part historical, part legend, and part mythical – romanticises and dramatises the lives of feudal lords and their retainers, who tried to replace the dwindling Han dynasty or restore it. The focus is mainly on the three power blocs that emerged from the remnants of the Han dynasty, and would eventually form the three states of Cao Wei, Shu Han, and Eastern Wu.\",\"image\":\"https://image.tmdb.org/t/p/w500/ex6DcbKNim993aFjEasrU1fIMXT.jpg\",\"datePublished\":\"1994-02-10\",\"numberOfEpisodes\":84,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Action & Adventure\",\"War & Politics\",\"Drama\",null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":9.1,\"bestRating\":10,\"ratingCount\":35}}"}}],["$","$L10",null,{"initialDrama":{"id":"1100b8a7-b4cb-42e8-91c8-b59e641c5b2a","tmdb_id":72645,"imdb_id":"tt0108914","content_type":"drama","title":"The Romance Of Three Kingdoms","original_title":"三国演义","overview":"Adapted from the classical 14th century novel of the same title by Luo Guanzhong, Romance of the Three Kingdoms is part historical, part legend, and part mythical – romanticises and dramatises the lives of feudal lords and their retainers, who tried to replace the dwindling Han dynasty or restore it. The focus is mainly on the three power blocs that emerged from the remnants of the Han dynasty, and would eventually form the three states of Cao Wei, Shu Han, and Eastern Wu.","poster_path":"/ex6DcbKNim993aFjEasrU1fIMXT.jpg","backdrop_path":"/63320bMLJrXHDqUHAEx4p0kp2vn.jpg","release_date":null,"first_air_date":"1994-02-10","status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":10759,"n