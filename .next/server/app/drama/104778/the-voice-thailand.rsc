5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"The Voice Thailand\",\"description\":\"A Thai reality television series on the Channel 3 television network. It was premiered on 9 September 2012 on Channel 3. The format is Dutch and the original Dutch version of the programme was broadcast in the Netherlands for the first time in 2010 as The Voice of Holland. The programme was commissioned after a successful first season in the U.S., where the programme aired on NBC domestically and AXN Asia regionally. It is produced by True Music and Toh-Klom Televisions\",\"image\":\"https://image.tmdb.org/t/p/w500/a0MNkvJLAaU5MtQxNcATNECFDN5.jpg\",\"datePublished\":\"2012-09-09\",\"numberOfEpisodes\":124,\"countryOfOrigin\":\"TH\",\"inLanguage\":\"th\",\"genre\":[\"Reality\",null]}"}}],["$","$L10",null,{"initialDrama":{"id":"12649317-99ab-4436-8f97-16e7604c88b8","tmdb_id":50540,"imdb_id":"tt6166216","content_type":"drama","title":"The Voice Thailand","original_title":"เดอะ วอยซ์ เสียงจริงตัวจริง","overview":"A Thai reality television series on the Channel 3 television network. It was premiered on 9 September 2012 on Channel 3. The format is Dutch and the original Dutch version of the programme was broadcast in the Netherlands for the first time in 2010 as The Voice of Holland. The programme was commissioned after a successful first season in the U.S., where the programme aired on NBC domestically and AXN Asia regionally. It is produced by True Music and Toh-Klom Televisions","poster_path":"/a0MNkvJLAaU5MtQxNcATNECFDN5.jpg","backdrop_path":"/zTWYy2ccnfb0nwkCFn7uXIqvViR.jpg","release_date":null,"first_air_date":"2012-09-09","status":"published","original_language":"th","origin_country":["TH"],"genres":[{"id":10764,"name":"Reality"},"reality television"],"popularity":6.2784,"vote_average":null,"vote_count":null,"runtime":null,"number_of_seasons":9,"number_of_episodes":124,