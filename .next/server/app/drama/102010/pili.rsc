5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Pili\",\"description\":\"Pili is a puppet show from Taiwan. It is made by Pili International Multimedia. The TV series started in 1985, and it still continues today. It is one of the most popular TV shows in Taiwan. Pili puppet show is performed by many kinds of puppets, some of them are cool, some are intelligent, and some are funny. Unlike traditional puppet shows, Pili puppet show uses state-of-the-art animation to help present its fighting art. The delicate design of the appearance and characteristics of each puppet has made Pili puppet show a well-known entertainment in Taiwan.\",\"image\":\"https://image.tmdb.org/t/p/w500/sBVfyRYPmKSARRTodsTbwHqgcRA.jpg\",\"datePublished\":\"1988-06-01\",\"numberOfEpisodes\":2958,\"countryOfOrigin\":\"TW\",\"inLanguage\":\"zh\",\"genre\":[\"Action & Adventure\",\"Drama\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.9,\"bestRating\":10,\"ratingCount\":7}}"}}],["$","$L10",null,{"initialDrama":{"id":"cc775a30-a472-45c9-91ed-a65a2d1fae2e","tmdb_id":19530,"imdb_id":null,"content_type":"drama","title":"Pili","original_title":"霹靂布袋戲","overview":"Pili is a puppet show from Taiwan. It is made by Pili International Multimedia. The TV series started in 1985, and it still continues today. It is one of the most popular TV shows in Taiwan. Pili puppet show is performed by many kinds of puppets, some of them are cool, some are intelligent, and some are funny. Unlike traditional puppet shows, Pili puppet show uses state-of-the-art animation to help present its fighting art. The delicate design of the appearance and characteristics of each puppet has made Pili puppet show a well-known entertainment in Taiwan.","poster_path":"/sBVfyRYPmKSARRTodsTbwHqgcRA.jpg","backdrop_path":"/luUTaPpTBM8BjP4wgCLxNIPkx6k.jpg","release_date":null,"first_air_date":"1988-06-01"