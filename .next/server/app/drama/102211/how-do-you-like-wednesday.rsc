10:T57e,{"@context":"https://schema.org","@type":"TVSeries","name":"How do you like Wednesday?","description":"How do you like Wednesday? was a Japanese television variety series that aired on the HTB network in Hokkaidō, Japan, and on other regional television networks in Japan. The program debuted on HTB on October 9, 1996. The series was one of the first local variety programs to be produced on Hokkaido; prior to this series' launch, local variety programs in Hokkaidō were virtually non-existent. The program also had a significant influence on other local programs in other regions in Japan, most notably Kwangaku! in Kansai and Nobunaga in Tokai.\n\nThe series achieved a record 18.6% viewing share on December 8, 1999, the highest share for a late-night program on a local TV station.\n\nProduction of the weekly regular series ended in September 2002, though new limited-run series were produced on average of every 18 months; the latest series was shown on HTB in late 2005, eight episodes in length.\n\nMost of the series have been rerun under the names of Dōdeshō Returns and Suiyō Dōdeshō Classic.","image":"https://image.tmdb.org/t/p/w500/i2MwS6U0XzD8ad6aS3HiTNKz8ov.jpg","datePublished":"1996-10-09","numberOfEpisodes":918,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Comedy",null,null],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.7,"bestRating":10,"ratingCount":3}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"7f6f1214-18a3-428e-a3b9-090fa5b1c311","tmdb_id":13,"imdb_id":null,"content_type":"drama","title":"How do you like Wednesday?","original_title":"水曜どうでしょう","overview":"How do you like Wednesday? was a Japanese television variety series that aired on the HTB network in Hokkaidō, Japan, and on other regional television networks in Japan. The program debuted on HTB on October 9, 1996. The series was one of the first local variety programs to be produced on Hokkaido; prior to this series' launch, local variety programs in Hokkaidō were virtually non-existent. The program also had a significant influence on other local programs in other regions in Japan, most notably Kwangaku! in Kansai and Nobunaga in Tokai.\n\nThe series achieved a record 18.6% viewing share on December 8, 1999, the highest share for a late-night program on a local TV station.\n\nProduction of the weekly regular series ended in September 2002, though new limited-run series were produced on average of every 18 months; the latest series was shown on HTB in late 2005, eight episodes in length.\n\nMost of the series have been rerun under the names of Dōdeshō Returns and Suiyō Dōdeshō Classic.","poster_path":"/i2MwS6U0XzD8ad6aS3HiTNKz8ov.jpg","backdrop_path":"/gZHrgkvmLYxEbchxkwzn6hTMk7i.jpg","release_date":null,"first_air_date":"1996-10-09","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":35,"name":"Comedy"},"travel television show","variety show"],"popularity":38.8509,"vote_average":7.7,"vote_count":3,"runtime":null,"number_of_seasons":4,"number_of_episodes":918,"created_at":"2026-01-26T16:52:00.318149+00:00","updated_at":"2026-01-26T16:52:00.318149+00:00","tagline":null,"homepage":"https://www.htb.co.jp/suidou/","budget":null,"revenue":null,"production_companies":[],"production_countries":null,"spoken_languages":[{"name":"Japanese","iso_639_1":"","english_name":"Japanese"}],"networks":[],"last_air_date":null,"in_production":false,"tmdb_status":"Returning Series","content_rating":null,"keywords":[],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"JP","main_poster":"/i2MwS6U0XzD8ad6aS3HiTNKz8ov.jpg","images":{"logos":[{"width":1273,"height":266,"file_path":"/tWdeGMqUrvvNPuGEbR1YZYMkwL4.png","iso_639_1":null,"vote_average":0