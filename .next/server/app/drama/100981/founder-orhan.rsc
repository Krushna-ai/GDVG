9:{"metadata":[["$","title","0",{"children":"Founder: Orhan | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Kuruluş: Orhan is a Turkish historical drama that follows the life of Orhan Bey, the son of Osman I and the second ruler of the Ottoman Empire. Set in the 14th century, the series portrays Orhan’s transformation from a young warrior into a visionary leader who expands his father's legacy by conquering key Byzantine cities like Bursa and establishing the foundations of a powerful empire. With political intrigue, epic battles, and complex relationships, the show explores Orhan’s rise amidst internal strife and external threats, continuing the legacy of Kuruluş: Osman with a new generation of characters and high-stakes storytelling."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/drama/100981/founder-orhan"}],["$","meta","5",{"property":"og:title","content":"Founder: Orhan"}],["$","meta","6",{"property":"og:description","content":"Kuruluş: Orhan is a Turkish historical drama that follows the life of Orhan Bey, the son of Osman I and the second ruler of the Ottoman Empire. Set in the 14th century, the series portrays Orhan’s transformation from a young warrior into a visionary leader who expands his father's legacy by conquering key Byzantine cities like Bursa and establishing the foundations of a powerful empire. With political intrigue, epic battles, and complex relationships, the show explores Orhan’s rise amidst internal strife and external threats, continuing the legacy of Kuruluş: Osman with a new generation of characters and high-stakes storytelling."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/drama/100981/founder-orhan"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.o