10:T54a,{"@context":"https://schema.org","@type":"TVSeries","name":"D.I.E.","description":"In the police force, \"Death Investigation Extension\" or \"D.I.E.\" was established to accommodate those who have been sent away by their supervisors. As everybody knows, members of the Extension are to investigate unsolved cold cases. Yue Chi-Long (Roger Kwok), who has cracked a large number of difficult cases by extrasensory means, is assigned to the D.I.E. because his superiors find him strange for falling asleep constantly on the job. New appointee Ying Jing-Jing (Sonija Kwok) is a good-looking girl but she takes an uncompromising stand over every case she deals with. Initially unaccepting of a division made of incompetent detectives, she is tricked into staying by her former supervisor, who claims that she was placed there to eventually replace the head and whip the team into shape. Chi-Long proves himself a capable detective but has a laidback attitude. The relationship between Jing-Jing and Chi-Long is deteriorating day by day, but also improving in a way...","image":"https://image.tmdb.org/t/p/w500/l2jlZCCFoLm8u0Qf0dZn4Mx6c3q.jpg","datePublished":"2008-03-17","numberOfEpisodes":50,"countryOfOrigin":"HK","inLanguage":"cn","genre":["Comedy",null,null],"aggregateRating":{"@type":"AggregateRating","ratingValue":6,"bestRating":10,"ratingCount":5}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"c28fcf82-1ff5-4ae6-b4fe-9f53ee055440","tmdb_id":7153,"imdb_id":"tt1517119","content_type":"drama","title":"D.I.E.","original_title":"古靈精探","overview":"In the police force, \"Death Investigation Extension\" or \"D.I.E.\" was established to accommodate those who have been sent away by their supervisors. As everybody knows, members of the Extension are to investigate unsolved cold cases. Yue Chi-Long (Roger Kwok), who has cracked a large number of difficult cases by extrasensory means, is assigned to the D.I.E. because his superiors find him strange for falling asleep constantly on the job. New appointee Ying Jing-Jing (Sonija Kwok) is a good-looking girl but she takes an uncompromising stand over every case she deals with. Initially unaccepting of a division made of incompetent detectives, she is tricked into staying by her former supervisor, who claims that she was placed there to eventually replace the head and whip the team into shape. Chi-Long proves himself a capable detective but has a laidback attitude. The relationship between Jing-Jing and Chi-Long is deteriorating day by day, but also improving in a way...","poster_path":"/l2jlZCCFoLm8u0Qf0dZn4Mx6c3q.jpg","backdrop_path":"/kCo6HgbChKFJj7HhyTBaLQmRuLp.jpg","release_date":null,"first_air_date":"2008-03-17","status":"published","original_language":"cn","origin_country":["HK"],"genres":[{"id":35,"name":"Comedy"},"comedy drama","drama television series"],"popularity":8.3574,"vote_average":6,"vote_count":5,"runtime":null,"number_of_seasons":2,"number_of_episodes":50,"created_at":"2026-01-29T21:50:59.46558+00:00","updated_at":"2026-01-29T21:50:59.46558+00:00","tagline":null,"homepage":"https://www.mytvsuper.com/en/programme/die_102341/D.I.E./","budget":null,"revenue":null,"production_companies":[{"id":0,"name":"TVB"}],"production_countries":null,"spoken_languages":[{"name":"Cantonese","iso_639_1":"","english_name":"Cantonese"}],"networks":[],"last_air_date":null,"in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/l2jlZCCFoLm8u0Qf0dZn4Mx6c3q.jpg","images":{"logos":[{"width":680,"height":358,"file_path":"/cRQBWXnbbUSEwfuUPct2gt3whQE.png","iso_639_1":null,"vote_average":0}],"posters":[{"width":945,"height":1350,"file_p