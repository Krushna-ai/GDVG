5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"The Wonderland of Ten Thousands\",\"description\":\"Ye Xingyu'’s master Yu Huanxian went and left a giant Tianyuan Shenzong. Ye Xingyun became the new leader of the Tianyuan Shenzong. At the same time, he exchanged place with the tenth prince of King Qi, and became a child of a small family, hidden in it, waiting for revenge.  Ye Xingyun embarked on a very dangerous road, but with his own strategy, and Tianyuan Shenzong masters of all the help of experts, vertical and horizontal tactics, strategizing, against the huge Grand Dynasty.\",\"image\":\"https://image.tmdb.org/t/p/w500/9fDLczJzCijwo9M73XkZPzsAull.jpg\",\"datePublished\":\"2018-03-21\",\"numberOfEpisodes\":904,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Animation\",\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":9,\"bestRating\":10,\"ratingCount\":4}}"}}],["$","$L10",null,{"initialDrama":{"id":"8b6a8d41-f81c-4593-9aef-99ad2bab7d3e","tmdb_id":89364,"imdb_id":"tt12923874","content_type":"drama","title":"The Wonderland of Ten Thousands","original_title":"万界仙踪","overview":"Ye Xingyu'’s master Yu Huanxian went and left a giant Tianyuan Shenzong. Ye Xingyun became the new leader of the Tianyuan Shenzong. At the same time, he exchanged place with the tenth prince of King Qi, and became a child of a small family, hidden in it, waiting for revenge.  Ye Xingyun embarked on a very dangerous road, but with his own strategy, and Tianyuan Shenzong masters of all the help of experts, vertical and horizontal tactics, strategizing, against the huge Grand Dynasty.","poster_path":"/9fDLczJzCijwo9M73XkZPzsAull.jpg","backdrop_path":"/3U9dD6wGphCxBGLM1CbhHBiQGil.jpg","release_date":null,"first_air_date":"2018-03-21","status":"published","original_language":"zh","origin_country":["CN"],"genres