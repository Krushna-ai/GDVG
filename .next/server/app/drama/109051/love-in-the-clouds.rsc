9:{"metadata":[["$","title","0",{"children":"Love in the Clouds | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"At the annual Qingyun Conference in the Hexu Six Realms, Ji Bozai, a warrior from the Jixing Abyss with a past as a convict, defeated Ming Yi, the cold warrior goddess who had reigned supreme for seven consecutive years. Overnight, Ji Bozai became the hottest new star in Jixing Abyss. Meanwhile, Ming Yi, hiding her true identity, disguised herself as a dancer to get close to Ji Bozai. Under their carefully crafted personas, the two engaged in a thrilling dance of deception and attraction, fighting for justice and fairness, and ultimately found a deep and moving love."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/drama/109051/love-in-the-clouds"}],["$","meta","5",{"property":"og:title","content":"Love in the Clouds"}],["$","meta","6",{"property":"og:description","content":"At the annual Qingyun Conference in the Hexu Six Realms, Ji Bozai, a warrior from the Jixing Abyss with a past as a convict, defeated Ming Yi, the cold warrior goddess who had reigned supreme for seven consecutive years. Overnight, Ji Bozai became the hottest new star in Jixing Abyss. Meanwhile, Ming Yi, hiding her true identity, disguised herself as a dancer to get close to Ji Bozai. Under their carefully crafted personas, the two engaged in a thrilling dance of deception and attraction, fighting for justice and fairness, and ultimately found a deep and moving love."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/drama/109051/love-in-the-clouds"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/alXAb26apN2tbRM91QjeZ0KzHlj.jpg"}],["$","meta","9",{"property":"og:type","content":"video.tv_show"