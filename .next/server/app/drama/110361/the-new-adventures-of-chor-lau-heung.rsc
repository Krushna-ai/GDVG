9:{"metadata":[["$","title","0",{"children":"The New Adventures of Chor Lau Heung | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Chu Liuxiang is the famous \"Chief of Bandits\" in the jianghu. His qinggong is unmatched and he leaves behind a trail of fragrance everywhere he goes. Once, Chu enters the palace to steal a treasure called the \"Amber Guanyin\", which contains a wooden figurine carved by \"Little Li Flying Dagger\" Li Xunhuan. In the palace, Chu meets Sikong Xing'er, the daughter of master thief Sikong Zhaixing, and her sworn sister Su Rongrong. While escaping from the guards' pursuit, Li Xunhuan dies trying to save Su Rongrong."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/drama/110361/the-new-adventures-of-chor-lau-heung"}],["$","meta","5",{"property":"og:title","content":"The New Adventures of Chor Lau Heung"}],["$","meta","6",{"property":"og:description","content":"Chu Liuxiang is the famous \"Chief of Bandits\" in the jianghu. His qinggong is unmatched and he leaves behind a trail of fragrance everywhere he goes. Once, Chu enters the palace to steal a treasure called the \"Amber Guanyin\", which contains a wooden figurine carved by \"Little Li Flying Dagger\" Li Xunhuan. In the palace, Chu meets Sikong Xing'er, the daughter of master thief Sikong Zhaixing, and her sworn sister Su Rongrong. While escaping from the guards' pursuit, Li Xunhuan dies trying to save Su Rongrong."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/drama/110361/the-new-adventures-of-chor-lau-heung"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/boI24iSYXf4PmqqsViBNJlz6BOL.jpg"}],["$","meta","9",{"property":"og:type","content":"video.tv_show"}],["$","meta","10",{"name":"twitter:c