5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Son Kare\",\"description\":\"After being suspended from duty and only able to work under the supervision of a psychotherapist, Homicide Squad Commissioner Sare Baykal faces the most complicated murder of her career, while her path crosses with fashion photographer Atlas Demiroğlu, who came to the police station because of a film full of mysterious images. The investigation, which begins with a woman's body found in an amusement park, soon opens the doors to a multi-layered puzzle that extends to both Sare and Atlas' pasts. As each new clue draws Sare and Atlas into a dark labyrinth, the boundaries between reality, fantasy, loyalty and betrayal become increasingly blurred.\",\"image\":\"https://image.tmdb.org/t/p/w500/jwVRYnc6IwReY9bURd2svzJezP6.jpg\",\"datePublished\":\"2026-01-16\",\"numberOfEpisodes\":6,\"countryOfOrigin\":\"TR\",\"inLanguage\":\"tr\",\"genre\":[\"Drama\"]}"}}],["$","$L10",null,{"initialDrama":{"id":"f1a3f412-4abf-4746-9c16-054f0db52422","tmdb_id":303453,"imdb_id":"tt36473743","content_type":"drama","title":"Son Kare","original_title":"Son Kare","overview":"After being suspended from duty and only able to work under the supervision of a psychotherapist, Homicide Squad Commissioner Sare Baykal faces the most complicated murder of her career, while her path crosses with fashion photographer Atlas Demiroğlu, who came to the police station because of a film full of mysterious images. The investigation, which begins with a woman's body found in an amusement park, soon opens the doors to a multi-layered puzzle that extends to both Sare and Atlas' pasts. As each new clue draws Sare and Atlas into a dark labyrinth, the boundaries between reality, fantasy, loyalty and betrayal become increasingly blurred.","poster_path":"/jwVRYnc6IwReY9bURd2svzJezP6.jpg","backdrop_path":"/mL36yB4fKDzay0G3vEi2tocn2qb