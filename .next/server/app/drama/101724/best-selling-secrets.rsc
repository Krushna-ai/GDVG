10:T490,{"@context":"https://schema.org","@type":"TVSeries","name":"Best Selling Secrets","description":"Wong Ka-Nam disappeared to the United States, leaving behind her son and husband in Hong Kong. When her husband dies in an airplane accident looking for her, Wong Ka-Nam's son, Luk Chit is taken into the custody of her mother-in-law, Ng Hang. After eighteen long years, Wong Ka-Nam wishes to see her son again and returns to Hong Kong. However, she is met with adamant resistance from her mother-in-law, who views Ka-Nam as bad luck, blaming her for the death of her son. Highly protective of her grandson and fearing that Wong Ka-Nam will attempt to take him away, Ka Nam's mother-in-law does everything in her power to keep mother and son apart. However, Wong Ka-Nam is ironically assisted by her own son, who befriends her and secures her office job in his advertising agency.","image":"https://image.tmdb.org/t/p/w500/hDhUREsTCsYzAxykh2CxpJVFzQf.jpg","datePublished":"2007-03-12","numberOfEpisodes":364,"countryOfOrigin":"HK","inLanguage":"cn","genre":["Comedy",null,null],"aggregateRating":{"@type":"AggregateRating","ratingValue":8,"bestRating":10,"ratingCount":1}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"ec7cee53-da00-47d3-87e1-1bcf1bb31954","tmdb_id":15903,"imdb_id":"tt10111810","content_type":"drama","title":"Best Selling Secrets","original_title":"同事三分親","overview":"Wong Ka-Nam disappeared to the United States, leaving behind her son and husband in Hong Kong. When her husband dies in an airplane accident looking for her, Wong Ka-Nam's son, Luk Chit is taken into the custody of her mother-in-law, Ng Hang. After eighteen long years, Wong Ka-Nam wishes to see her son again and returns to Hong Kong. However, she is met with adamant resistance from her mother-in-law, who views Ka-Nam as bad luck, blaming her for the death of her son. Highly protective of her grandson and fearing that Wong Ka-Nam will attempt to take him away, Ka Nam's mother-in-law does everything in her power to keep mother and son apart. However, Wong Ka-Nam is ironically assisted by her own son, who befriends her and secures her office job in his advertising agency.","poster_path":"/hDhUREsTCsYzAxykh2CxpJVFzQf.jpg","backdrop_path":"/2GPe3jaXM1itSEXoPhGyPJlbZA6.jpg","release_date":null,"first_air_date":"2007-03-12","status":"published","original_language":"cn","origin_country":["HK"],"genres":[{"id":35,"name":"Comedy"},"drama television series","sitcom"],"popularity":50.5164,"vote_average":8,"vote_count":1,"runtime":null,"number_of_seasons":1,"number_of_episodes":364,"created_at":"2026-01-26T16:48:26.477959+00:00","updated_at":"2026-01-26T16:48:26.477959+00:00","tagline":null,"homepage":"https://www.mytvsuper.com/en/programme/bestsellingsecrets0001_116952/Best-Selling-Secrets/","budget":null,"revenue":null,"production_companies":[{"id":0,"name":"TVB"}],"production_countries":null,"spoken_languages":[{"name":"Cantonese","iso_639_1":"","english_name":"Cantonese"}],"networks":[],"last_air_date":null,"in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/hDhUREsTCsYzAxykh2CxpJVFzQf.jpg","images":{"logos":[],"posters":[{"width":800,"height":1200,"file_path":"/hDhUREsTCsYzAxykh2CxpJVFzQf.jpg","iso_639_1":"zh","vote_average":3.334}],"backdrops":[{"width":1920,"height":1080,"file_path":"/2GPe3jaXM1itSEXoPhGyPJlbZA6.jpg","iso_639_1":null,"vote_average":1.75},{"width":2048,"height":1152,"file_path":"/ouNsU1cbia2afzzTV0YVhzheP3u.jpg","iso_639_1":null,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/9i4VvpvpwrZVE6aAC2RHVggtwvs.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"