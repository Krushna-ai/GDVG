10:T4e7,{"@context":"https://schema.org","@type":"TVSeries","name":"HK 80's","description":"This sitcom  series premiered in 1981 and changed its name every year, from \"Hong Kong 81\" to \"Hong Kong 86.\" It was eventually replaced by a new sitcom called \"City Stories.\" A total of 1330 episodes were produced, making it the second-longest-running series in Hong Kong, after \"Come Home Love: Lo and Behold\".\n\nEach episode of this series is inspired by current social issues, with early storylines often satirizing society's flaws. The characters, such as \"Chen Ji,\" \"Mrs. Shun,\" \"Uncle Mao,\" \"Jue Wu Yin,\" \"Miss Su,\" \"A Wei,\" and \"Ah Kang,\" mostly hail from the grassroots, leaving a lasting impression on the audience. For example, \"Mrs. Shun,\" portrayed by Lydia Shum, later became a term to describe uneducated women who follow trends blindly. \"Chen Ji,\" played by Lawrence Ng, is a stockbroker who loves to show off his wealth, and his behavior typified that of many Hong Kongers, becoming a byword for the city's nouveau riche.","image":"https://image.tmdb.org/t/p/w500/6IpuLrhh7XZfIvz0OmFOSJdSORe.jpg","datePublished":"1981-06-08","numberOfEpisodes":1310,"countryOfOrigin":"HK","inLanguage":"cn","genre":["Comedy","Drama","Family"]}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"6bc01255-11c7-4414-ae10-e7a859c4d861","tmdb_id":228091,"imdb_id":null,"content_type":"drama","title":"HK 80's","original_title":"香港八十系列","overview":"This sitcom  series premiered in 1981 and changed its name every year, from \"Hong Kong 81\" to \"Hong Kong 86.\" It was eventually replaced by a new sitcom called \"City Stories.\" A total of 1330 episodes were produced, making it the second-longest-running series in Hong Kong, after \"Come Home Love: Lo and Behold\".\n\nEach episode of this series is inspired by current social issues, with early storylines often satirizing society's flaws. The characters, such as \"Chen Ji,\" \"Mrs. Shun,\" \"Uncle Mao,\" \"Jue Wu Yin,\" \"Miss Su,\" \"A Wei,\" and \"Ah Kang,\" mostly hail from the grassroots, leaving a lasting impression on the audience. For example, \"Mrs. Shun,\" portrayed by Lydia Shum, later became a term to describe uneducated women who follow trends blindly. \"Chen Ji,\" played by Lawrence Ng, is a stockbroker who loves to show off his wealth, and his behavior typified that of many Hong Kongers, becoming a byword for the city's nouveau riche.","poster_path":"/6IpuLrhh7XZfIvz0OmFOSJdSORe.jpg","backdrop_path":"/kmwOP8ep8QZBKxC6gZ6igkR9pLq.jpg","release_date":null,"first_air_date":"1981-06-08","status":"published","original_language":"cn","origin_country":["HK"],"genres":[{"id":35,"name":"Comedy"},{"id":18,"name":"Drama"},{"id":10751,"name":"Family"}],"popularity":107.9803,"vote_average":null,"vote_count":null,"runtime":null,"number_of_seasons":6,"number_of_episodes":1310,"created_at":"2026-01-26T16:47:20.683755+00:00","updated_at":"2026-01-26T16:47:20.683755+00:00","tagline":null,"homepage":"https://www.mytvsuper.com/en/programme/hk81series10001_114038/HK-'81(SERIES-2)/","budget":null,"revenue":null,"production_companies":[],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":null,"in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/6IpuLrhh7XZfIvz0OmFOSJdSORe.jpg","images":{"logos":[],"posters":[{"width":720,"height":1080,"file_path":"/6IpuLrhh7XZfIvz0OmFOSJdSORe.jpg","iso_639_1":null,"vote_average":0},{"width":720,"height":1080,"file_path":"/bq2sJyI8Sn798Y0yaBv3yo9nhVZ.jpg","iso_639_1":null,"vote_average":0},{"width":720,"height":1080,"file_path":"/jZbfRNcJeN9qRncwcNCYwLsuOT1.jpg"