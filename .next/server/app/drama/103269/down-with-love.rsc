5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Down with Love\",\"description\":\"Xiang Yu Ping, a divorce and inheritance lawyer, is seen by others as cold, selfish, and ruthless. He had taken in his brother's orphans and was in need of a nanny. But after he exhausted his supply of nannies, he still couldn't find one who doesn't fall in love with him or gets scared off by the kids. Fed up, Yu Ping asks his secretary, Yang Duo, to find a nanny that meets his requirements. She recommends her younger sister, Yang Guo, for the job; assuring Yu Ping that her tomboyish sister will not fall in love with him by lying that she does not like men at all.\",\"image\":\"https://image.tmdb.org/t/p/w500/9F4vF5dSUJ2OZCg93Kta5vNnHpg.jpg\",\"datePublished\":\"2010-01-31\",\"numberOfEpisodes\":28,\"countryOfOrigin\":\"TW\",\"inLanguage\":\"zh\",\"genre\":[\"Drama\",\"Comedy\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6,\"bestRating\":10,\"ratingCount\":4}}"}}],["$","$L10",null,{"initialDrama":{"id":"84ddfb36-a9d5-4995-9d44-d2ef81fddfe6","tmdb_id":33072,"imdb_id":"tt5852764","content_type":"drama","title":"Down with Love","original_title":"就想賴著你","overview":"Xiang Yu Ping, a divorce and inheritance lawyer, is seen by others as cold, selfish, and ruthless. He had taken in his brother's orphans and was in need of a nanny. But after he exhausted his supply of nannies, he still couldn't find one who doesn't fall in love with him or gets scared off by the kids. Fed up, Yu Ping asks his secretary, Yang Duo, to find a nanny that meets his requirements. She recommends her younger sister, Yang Guo, for the job; assuring Yu Ping that her tomboyish sister will not fall in love with him by lying that she does not like men at all.","poster_path":"/9F4vF5dSUJ2OZCg93Kta5vNnHpg.jpg","backdrop_path":"/eIWNQPVcBbgMw8foERWN72rbhpv.jpg","release_date":null,"first