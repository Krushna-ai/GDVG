5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Chris Tucker\",\"image\":\"https://image.tmdb.org/t/p/w500/k0oLIL0xTgDR6Qn3yCsNuLCJhFT.jpg\",\"description\":\"Christopher Tucker is an American stand-up comedian and actor. He made his debut in 1992 as a stand-up performer on the HBO comedy series Def Comedy Jam, where he frequently appeared on the show during the 1990s. He made his feature film debut in House Party 3 in 1994 and gained greater recognition in Friday the following year. In 1997, he co-starred in the films The Fifth Element and Money Talks, and had a supporting role in Quentin Tarantino's Jackie Brown. Tucker gained international fame in the 2000s for playing Detective James Carter in the Rush Hour film series.\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/549239/chris-tucker\",\"sameAs\":[\"http://www.christucker.com\",\"https://imdb.com/name/nm0000676\"]}"}}],["$","$L10",null,{"person":{"id":"e5724c95-9506-4db4-86b1-fcc5fc70650a","tmdb_id":66,"name":"Chris Tucker","gender":2,"biography":"Christopher Tucker is an American stand-up comedian and actor. He made his debut in 1992 as a stand-up performer on the HBO comedy series Def Comedy Jam, where he frequently appeared on the show during the 1990s. He made his feature film debut in House Party 3 in 1994 and gained greater recognition in Friday the following year. In 1997, he co-starred in the films The Fifth Element and Money Talks, and had a supporting role in Quentin Tarantino's Jackie Brown. Tucker gained international fame in the 2000s for playing Detective James Carter in the Rush Hour film series.","birthday":"1971-08-31","deathday":null,"place_of_birth":"Atlanta, Georgia, USA","profile_path":"/k0oLIL0xTgDR6Qn3yCsNuLCJhFT.jpg","known_for_department":"Acting","popularity":3.8142,"imdb_id":"nm0000676","created_at":"2026-02-24T22:04:41.412993+00:00","updated_at":"2026