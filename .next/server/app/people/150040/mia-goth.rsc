5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Mia Goth\",\"image\":\"https://image.tmdb.org/t/p/w500/371WiQYe2mGlsZj5f7AZHSGgnFV.jpg\",\"description\":\"Mia Gypsy Mello da Silva Goth is a British actress and model. After modelling as a teenager, Goth made her acting debut in the erotic art film Nymphomaniac (2013). She earned recognition with the films A Cure For Wellness (2016), High Life (2018), Suspiria (2018), and Emma (2020). She achieved a career breakthrough by playing Maxine Minx and Pearl in the X film series (2022–2024) which established her as a scream queen. She has since starred in Infinity Pool (2023) and Frankenstein (2025).\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/150040/mia-goth\",\"sameAs\":[\"https://imdb.com/name/nm5301405\"]}"}}],["$","$L10",null,{"person":{"id":"56443df3-f701-4f57-9983-1cd3efc03cdb","tmdb_id":1137824,"name":"Mia Goth","gender":1,"biography":"Mia Gypsy Mello da Silva Goth is a British actress and model. After modelling as a teenager, Goth made her acting debut in the erotic art film Nymphomaniac (2013). She earned recognition with the films A Cure For Wellness (2016), High Life (2018), Suspiria (2018), and Emma (2020). She achieved a career breakthrough by playing Maxine Minx and Pearl in the X film series (2022–2024) which established her as a scream queen. She has since starred in Infinity Pool (2023) and Frankenstein (2025).","birthday":"1993-10-25","deathday":null,"place_of_birth":"Southwark, London, England, UK","profile_path":"/371WiQYe2mGlsZj5f7AZHSGgnFV.jpg","known_for_department":"Acting","popularity":4.1523,"imdb_id":"nm5301405","created_at":"2026-02-08T23:30:10.058312+00:00","updated_at":"2026-02-16T21:14:10.717+00:00","also_known_as":["Mia Gypsy Mello da Silva Goth"],"homepage":null,"adult":false,"wikipedia_url":"https://en.wikipedia.org/wiki/Mia_Goth","bio_source":"wikipedia",