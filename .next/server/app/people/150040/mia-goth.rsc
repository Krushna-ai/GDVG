9:{"metadata":[["$","title","0",{"children":"Mia Goth | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Mia Gypsy Mello da Silva Goth is a British actress and model. After modelling as a teenager, Goth made her acting debut in the erotic art film Nymphomaniac (2013). She earned recognition with the films A Cure For Wellness (2016), High Life (2018), Suspiria (2018), and Emma (2020). She achieved a career breakthrough by playing Maxine Minx and Pearl in the X film series (2022–2024) which established her as a scream queen. She has since starred in Infinity Pool (2023) and Frankenstein (2025)."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/people/150040/mia-goth"}],["$","meta","5",{"property":"og:title","content":"Mia Goth"}],["$","meta","6",{"property":"og:description","content":"Mia Gypsy Mello da Silva Goth is a British actress and model. After modelling as a teenager, Goth made her acting debut in the erotic art film Nymphomaniac (2013). She earned recognition with the films A Cure For Wellness (2016), High Life (2018), Suspiria (2018), and Emma (2020). She achieved a career breakthrough by playing Maxine Minx and Pearl in the X film series (2022–2024) which established her as a scream queen. She has since starred in Infinity Pool (2023) and Frankenstein (2025)."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/people/150040/mia-goth"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w185/371WiQYe2mGlsZj5f7AZHSGgnFV.jpg"}],["$","meta","9",{"property":"og:type","content":"profile"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Mia Goth"}],["$","meta","12",{"name":"twitter:description","content":"Mia