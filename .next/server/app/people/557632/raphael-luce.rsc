10:T45d,{"@context":"https://schema.org","@type":"Person","name":"Raphael Luce","image":"https://image.tmdb.org/t/p/w500/nKiboEmmgxAF7xUNSPYN56ANnak.jpg","description":"Henry Creel, better known as Vecna, One, or Mr. Whatsit, is a fictional character and the main antagonist of the Netflix science fiction horror television series Stranger Things. He is portrayed by Jamie Campbell Bower. The character was introduced in the fourth season as a malevolent being from the Upside Down, a mirroring alternate dimension, that haunts his victims with horrifying visions of their past traumas before killing them in a sadistic, brutal manner. As the fourth season progresses, he is ultimately revealed to be the alpha of the Upside Down and the mastermind behind all of the events that previously terrorized the town of Hawkins, beginning with the disappearance of Will Byers, revealing himself to be a vengeful misanthrope bent on bringing on human extinction, by aiding the Mind Flayer in its goals.","jobTitle":"Acting","url":"https://gdvg-ten.vercel.app/people/557632/raphael-luce","sameAs":["https://imdb.com/name/nm11561207"]}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"person":{"id":"f496d581-9230-4512-9fbd-9a687f823a98","tmdb_id":3119212,"name":"Raphael Luce","gender":2,"biography":"Henry Creel, better known as Vecna, One, or Mr. Whatsit, is a fictional character and the main antagonist of the Netflix science fiction horror television series Stranger Things. He is portrayed by Jamie Campbell Bower. The character was introduced in the fourth season as a malevolent being from the Upside Down, a mirroring alternate dimension, that haunts his victims with horrifying visions of their past traumas before killing them in a sadistic, brutal manner. As the fourth season progresses, he is ultimately revealed to be the alpha of the Upside Down and the mastermind behind all of the events that previously terrorized the town of Hawkins, beginning with the disappearance of Will Byers, revealing himself to be a vengeful misanthrope bent on bringing on human extinction, by aiding the Mind Flayer in its goals.","birthday":"2006-12-29","deathday":null,"place_of_birth":"Burlington, Vermont, USA","profile_path":"/nKiboEmmgxAF7xUNSPYN56ANnak.jpg","known_for_department":"Acting","popularity":3.8529,"imdb_id":"nm11561207","created_at":"2026-02-24T23:19:32.605965+00:00","updated_at":"2026-02-25T22:33:55.153+00:00","also_known_as":[],"homepage":null,"adult":false,"wikipedia_url":"https://en.wikipedia.org/wiki/Vecna_(Stranger_Things)","bio_source":"wikipedia","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-24T23:19:32.605965+00:00","main_profile_photo":"/nKiboEmmgxAF7xUNSPYN56ANnak.jpg","images":{"tagged":[],"profiles":[{"width":2000,"height":3000,"file_path":"/nKiboEmmgxAF7xUNSPYN56ANnak.jpg","aspect_ratio":0.667,"vote_average":3.334},{"width":426,"height":638,"file_path":"/c23LD93Ve2u9buIb0R1BmAzUCYK.jpg","aspect_ratio":0.668,"vote_average":0.166}]},"enriched_at":"2026-02-25T22:33:55.153+00:00","enrichment_cycle":1,"external_ids":null,"social_ids":null,"combined_credits_count":0,"gdvg_id":557632,"native_name":null,"instagram":"raphael_luce","twitter":"TheRaphaelLuce","tiktok":null,"height_cm":null,"wikidata_id":"Q112980968"}}]]
9:{"metadata":[["$","title","0",{"children":"Raphael Luce | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Henry Creel, better known as Vecna, One, or Mr. Whatsit, is a fictional character and the main antagonist of the Netflix science fiction horror television series Stranger Things. He is portrayed by Jamie Campbell Bower. The character was introduced in the fourth season as a malevolent being from the Upside Down, a mirroring alternate dimension, that haunts his victims with horrifying visions of their past traumas before killing them in a sadistic, brutal manner. As the fourth season progresses, he is ultimately revealed to be the alpha of the Upside Down and the mastermind behind all of the events that previously terrorized the town of Hawkins, beginning with the disappearance of Will Byers, revealing himself to be a vengeful misanthrope bent on bringing on human extinction, by aiding the Mind Flayer in its goals."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/people/557632/raphael-luce"}],["$","meta","5",{"property":"og:title","content":"Raphael Luce"}],["$","meta","6",{"property":"og:description","content":"Henry Creel, better known as Vecna, One, or Mr. Whatsit, is a fictional character and the main antagonist of the Netflix science fiction horror television series Stranger Things. He is portrayed by Jamie Campbell Bower. The character was introduced in the fourth season as a malevolent being from the Upside Down, a mirroring alternate dimension, that haunts his victims with horrifying visions of their past traumas before killing them in a sadistic, brutal manner. As the fourth season progresses, he is ultimately revealed to be the alpha of the Upside Down and the mastermind behind all of the events that previously terrorized the town of Hawkins, beginning with the disappearance of Will Byers, revealing himself to be a vengeful misanthrope bent on bringing on human extinction, by aiding the Mind Flayer in its goals."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/people/557632/raphael-luce"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w185/nKiboEmmgxAF7xUNSPYN56ANnak.jpg"}],["$","meta","9",{"property":"og:type","content":"profile"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Raphael Luce"}],["$","meta","12",{"name":"twitter:description","content":"Henry Creel, better known as Vecna, One, or Mr. Whatsit, is a fictional character and the main antagonist of the Netflix science fiction horror television series Stranger Things. He is portrayed by Jamie Campbell Bower. The character was introduced in the fourth season as a malevolent being from the Upside Down, a mirroring alternate dimension, that haunts his victims with horrifying visions of their past traumas before killing them in a sadistic, brutal manner. As the fourth season progresses, he is ultimately revealed to be the alpha of the Upside Down and the mastermind behind all of the events that previously terrorized the town of Hawkins, beginning with the disappearance of Will Byers, revealing himself to be a vengeful misanthrope bent on bringing on human extinction, by aiding the Mind Flayer in its goals."}],"$L12","$L13","$L14"],"error":null,"digest":"$undefined"}
