5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Noomi Rapace\",\"image\":\"https://image.tmdb.org/t/p/w500/zkg9wfbXZi9OqvwW2ku38zNC1Hk.jpg\",\"description\":\"Noomi Rapace is a Swedish actress. She achieved international fame with her portrayal of Lisbeth Salander in the Swedish film adaptations of the Millennium series (2009): The Girl with the Dragon Tattoo, The Girl Who Played with Fire, and The Girl Who Kicked the Hornets' Nest. For her performance in the Millennium series, Rapace won two Nymphe d'Ors, a Guldbagge Award, and a Satellite Award as Best Actress amongst others, and was nominated for a BAFTA Award, an International Emmy Award and a European Film Award. Following the success of the Millennium series, Rapace has gone on to star in American movies.\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/150346/noomi-rapace\",\"sameAs\":[\"https://imdb.com/name/nm0636426\"]}"}}],["$","$L10",null,{"person":{"id":"7ecf2d33-15c2-45c7-b8c3-2638e3f9df8f","tmdb_id":87722,"name":"Noomi Rapace","gender":1,"biography":"Noomi Rapace is a Swedish actress. She achieved international fame with her portrayal of Lisbeth Salander in the Swedish film adaptations of the Millennium series (2009): The Girl with the Dragon Tattoo, The Girl Who Played with Fire, and The Girl Who Kicked the Hornets' Nest. For her performance in the Millennium series, Rapace won two Nymphe d'Ors, a Guldbagge Award, and a Satellite Award as Best Actress amongst others, and was nominated for a BAFTA Award, an International Emmy Award and a European Film Award. Following the success of the Millennium series, Rapace has gone on to star in American movies.","birthday":"1979-12-28","deathday":null,"place_of_birth":"Hudiksvall, Gävleborgs län, Sweden ","profile_path":"/zkg9wfbXZi9OqvwW2ku38zNC1Hk.jpg","known_for_department":"Acting","popularity":5.0647,"imdb_id":"nm0636426","cre