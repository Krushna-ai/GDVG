5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Piper Rubio\",\"image\":\"https://image.tmdb.org/t/p/w500/kIg9VvVBi1H8Bl9B697f2GE9rPo.jpg\",\"description\":\"Five Nights at Freddy's is a 2023 American supernatural horror film based on the video game series created by Scott Cawthon. It was directed by Emma Tammi, and written by Cawthon, Tammi and Seth Cuddeback. The film stars Josh Hutcherson as a troubled security guard who starts a job at an abandoned pizzeria where he discovers its animatronic mascots are possessed by the souls of murdered children who were abducted by a serial killer decades before. The film also stars Elizabeth Lail, Piper Rubio, Mary Stuart Masterson, and Matthew Lillard, who are featured in supporting roles.\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/191646/piper-rubio\",\"sameAs\":[\"https://imdb.com/name/nm10138913\"]}"}}],["$","$L10",null,{"person":{"id":"da1ce59b-40c3-450a-9251-c4199bb5bb8e","tmdb_id":2283930,"name":"Piper Rubio","gender":1,"biography":"Five Nights at Freddy's is a 2023 American supernatural horror film based on the video game series created by Scott Cawthon. It was directed by Emma Tammi, and written by Cawthon, Tammi and Seth Cuddeback. The film stars Josh Hutcherson as a troubled security guard who starts a job at an abandoned pizzeria where he discovers its animatronic mascots are possessed by the souls of murdered children who were abducted by a serial killer decades before. The film also stars Elizabeth Lail, Piper Rubio, Mary Stuart Masterson, and Matthew Lillard, who are featured in supporting roles.","birthday":"2013-09-20","deathday":null,"place_of_birth":"Los Angeles, California, USA","profile_path":"/kIg9VvVBi1H8Bl9B697f2GE9rPo.jpg","known_for_department":"Acting","popularity":5.2341,"imdb_id":"nm10138913","created_at":"2026-02-21T10:32:29.768382+00:00","updated_at":"2026-02-