9:{"metadata":[["$","title","0",{"children":"Piper Rubio | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Five Nights at Freddy's is a 2023 American supernatural horror film based on the video game series created by Scott Cawthon. It was directed by Emma Tammi, and written by Cawthon, Tammi and Seth Cuddeback. The film stars Josh Hutcherson as a troubled security guard who starts a job at an abandoned pizzeria where he discovers its animatronic mascots are possessed by the souls of murdered children who were abducted by a serial killer decades before. The film also stars Elizabeth Lail, Piper Rubio, Mary Stuart Masterson, and Matthew Lillard, who are featured in supporting roles."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/people/191646/piper-rubio"}],["$","meta","5",{"property":"og:title","content":"Piper Rubio"}],["$","meta","6",{"property":"og:description","content":"Five Nights at Freddy's is a 2023 American supernatural horror film based on the video game series created by Scott Cawthon. It was directed by Emma Tammi, and written by Cawthon, Tammi and Seth Cuddeback. The film stars Josh Hutcherson as a troubled security guard who starts a job at an abandoned pizzeria where he discovers its animatronic mascots are possessed by the souls of murdered children who were abducted by a serial killer decades before. The film also stars Elizabeth Lail, Piper Rubio, Mary Stuart Masterson, and Matthew Lillard, who are featured in supporting roles."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/people/191646/piper-rubio"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w185/kIg9VvVBi1H8Bl9B697f2GE9rPo.jpg"}],["$","meta","9",{"property":"og:type","content":"profile"}],["$","meta"