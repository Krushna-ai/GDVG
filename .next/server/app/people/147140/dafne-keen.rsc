5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Dafne Keen\",\"image\":\"https://image.tmdb.org/t/p/w500/g325OIjIHrFr0te8ewPfhKQ2SKj.jpg\",\"description\":\"Dafne Keen Fernández is a Spanish and British actress. Keen made her debut as a child actress on the series The Refugees (2015). Her breakthrough role was as Laura, in the X-Men superhero film Logan (2017) which she reprised for the Marvel Cinematic Universe (MCU) film Deadpool & Wolverine (2024). She also starred as Lyra Belacqua in the television series His Dark Materials (2019–2022) and Jecki Lon in the Star Wars series The Acolyte (2024).\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/147140/dafne-keen\",\"sameAs\":[\"https://imdb.com/name/nm6748436\"]}"}}],["$","$L10",null,{"person":{"id":"f2bab52a-e75f-4db1-a40b-4f73a4f8ac1e","tmdb_id":1464650,"name":"Dafne Keen","gender":1,"biography":"Dafne Keen Fernández is a Spanish and British actress. Keen made her debut as a child actress on the series The Refugees (2015). Her breakthrough role was as Laura, in the X-Men superhero film Logan (2017) which she reprised for the Marvel Cinematic Universe (MCU) film Deadpool & Wolverine (2024). She also starred as Lyra Belacqua in the television series His Dark Materials (2019–2022) and Jecki Lon in the Star Wars series The Acolyte (2024).","birthday":"2005-01-04","deathday":null,"place_of_birth":"Fuenlabrada, Madrid, Spain","profile_path":"/g325OIjIHrFr0te8ewPfhKQ2SKj.jpg","known_for_department":"Acting","popularity":5.0253,"imdb_id":"nm6748436","created_at":"2026-02-08T23:40:38.719277+00:00","updated_at":"2026-02-14T21:15:35.601+00:00","also_known_as":["Daphne Keen Fernández","Dafne Keen Fernández","다프네 킨","达芙妮·基恩","達芙妮·金","Dafne María Keen Fernández","ダフネ・マリア・キーン・フェルナンデス","دافنه کین","دفنه کین"],"homepage":null,"adult":false,"wikipedia_url":"https://en.wikipedia.org/wiki/Dafne_Keen","bi