5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Abigail Spencer\",\"image\":\"https://image.tmdb.org/t/p/w500/uf96FDHVoFMwoiP5He4SPLCmwri.jpg\",\"description\":\"Abigail Leigh Spencer is an American actress, producer and writer. She began her career playing Rebecca Tyree on the ABC daytime television soap opera All My Children (1999–2001) before going on to star in the Lifetime crime drama series, Angela's Eyes (2006). From 2013 to 2016, Spencer starred as Amantha Holden in the SundanceTV drama series Rectify, for which she received a nomination for a Critics' Choice Television Award; she then starred as history professor Lucy Preston in the NBC science-fiction series Timeless. In 2026 she aired in a lead role in the FOX series Best Medicine.\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/144669/abigail-spencer\",\"sameAs\":[\"https://imdb.com/name/nm0817844\"]}"}}],["$","$L10",null,{"person":{"id":"cb76c0eb-baab-4b23-9156-74b496a07618","tmdb_id":123725,"name":"Abigail Spencer","gender":1,"biography":"Abigail Leigh Spencer is an American actress, producer and writer. She began her career playing Rebecca Tyree on the ABC daytime television soap opera All My Children (1999–2001) before going on to star in the Lifetime crime drama series, Angela's Eyes (2006). From 2013 to 2016, Spencer starred as Amantha Holden in the SundanceTV drama series Rectify, for which she received a nomination for a Critics' Choice Television Award; she then starred as history professor Lucy Preston in the NBC science-fiction series Timeless. In 2026 she aired in a lead role in the FOX series Best Medicine.","birthday":"1981-08-04","deathday":null,"place_of_birth":"Gulf Breeze, Florida, USA","profile_path":"/uf96FDHVoFMwoiP5He4SPLCmwri.jpg","known_for_department":"Acting","popularity":4.6042,"imdb_id":"nm0817844","created_at":"2026-02-08T00:56:15.483589+00:00",