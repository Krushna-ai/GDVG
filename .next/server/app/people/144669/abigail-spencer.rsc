9:{"metadata":[["$","title","0",{"children":"Abigail Spencer | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Abigail Leigh Spencer is an American actress, producer and writer. She began her career playing Rebecca Tyree on the ABC daytime television soap opera All My Children (1999–2001) before going on to star in the Lifetime crime drama series, Angela's Eyes (2006). From 2013 to 2016, Spencer starred as Amantha Holden in the SundanceTV drama series Rectify, for which she received a nomination for a Critics' Choice Television Award; she then starred as history professor Lucy Preston in the NBC science-fiction series Timeless. In 2026 she aired in a lead role in the FOX series Best Medicine."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/people/144669/abigail-spencer"}],["$","meta","5",{"property":"og:title","content":"Abigail Spencer"}],["$","meta","6",{"property":"og:description","content":"Abigail Leigh Spencer is an American actress, producer and writer. She began her career playing Rebecca Tyree on the ABC daytime television soap opera All My Children (1999–2001) before going on to star in the Lifetime crime drama series, Angela's Eyes (2006). From 2013 to 2016, Spencer starred as Amantha Holden in the SundanceTV drama series Rectify, for which she received a nomination for a Critics' Choice Television Award; she then starred as history professor Lucy Preston in the NBC science-fiction series Timeless. In 2026 she aired in a lead role in the FOX series Best Medicine."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/people/144669/abigail-spencer"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w185/uf96FDHVoFMwoiP5He4SPLCmwri.jpg"}],["$","meta","9",{"property":"og:type","