5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Sasha Alexander\",\"image\":\"https://image.tmdb.org/t/p/w500/2K3v9aG4JYJtsvZK6MeIhPU7t47.jpg\",\"description\":\"Suzana Drobnjakovic, known professionally as Sasha Alexander, is an American actress. She played Gretchen Witter in Dawson's Creek and has appeared in such films as Yes Man (2008) and He's Just Not That Into You (2009). Alexander played Caitlin Todd for the first two seasons of NCIS (2003–2005). From July 2010 through September 2016, Alexander starred as Maura Isles in the TNT series Rizzoli & Isles, and was a regular in Season 5 and 6 of Shameless in 2015–16.\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/145284/sasha-alexander\",\"sameAs\":[\"https://www.sashaalexander.us/\",\"https://imdb.com/name/nm0018734\"]}"}}],["$","$L10",null,{"person":{"id":"c862e825-5395-4c90-bb44-0907a1885487","tmdb_id":64154,"name":"Sasha Alexander","gender":1,"biography":"Suzana Drobnjakovic, known professionally as Sasha Alexander, is an American actress. She played Gretchen Witter in Dawson's Creek and has appeared in such films as Yes Man (2008) and He's Just Not That Into You (2009). Alexander played Caitlin Todd for the first two seasons of NCIS (2003–2005). From July 2010 through September 2016, Alexander starred as Maura Isles in the TNT series Rizzoli & Isles, and was a regular in Season 5 and 6 of Shameless in 2015–16.","birthday":"1973-05-17","deathday":null,"place_of_birth":" Los Angeles, California, USA","profile_path":"/2K3v9aG4JYJtsvZK6MeIhPU7t47.jpg","known_for_department":"Acting","popularity":5.8653,"imdb_id":"nm0018734","created_at":"2026-02-08T00:27:13.868278+00:00","updated_at":"2026-02-15T21:23:32.108+00:00","also_known_as":["Suzana Drobnjakovic "],"homepage":"https://www.sashaalexander.us/","adult":false,"wikipedia_url":"https://en.wikipedia.org/wiki/Sasha_Alexander","bio_s