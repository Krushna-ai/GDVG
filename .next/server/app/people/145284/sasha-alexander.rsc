9:{"metadata":[["$","title","0",{"children":"Sasha Alexander | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Suzana Drobnjakovic, known professionally as Sasha Alexander, is an American actress. She played Gretchen Witter in Dawson's Creek and has appeared in such films as Yes Man (2008) and He's Just Not That Into You (2009). Alexander played Caitlin Todd for the first two seasons of NCIS (2003–2005). From July 2010 through September 2016, Alexander starred as Maura Isles in the TNT series Rizzoli & Isles, and was a regular in Season 5 and 6 of Shameless in 2015–16."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/people/145284/sasha-alexander"}],["$","meta","5",{"property":"og:title","content":"Sasha Alexander"}],["$","meta","6",{"property":"og:description","content":"Suzana Drobnjakovic, known professionally as Sasha Alexander, is an American actress. She played Gretchen Witter in Dawson's Creek and has appeared in such films as Yes Man (2008) and He's Just Not That Into You (2009). Alexander played Caitlin Todd for the first two seasons of NCIS (2003–2005). From July 2010 through September 2016, Alexander starred as Maura Isles in the TNT series Rizzoli & Isles, and was a regular in Season 5 and 6 of Shameless in 2015–16."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/people/145284/sasha-alexander"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w185/2K3v9aG4JYJtsvZK6MeIhPU7t47.jpg"}],["$","meta","9",{"property":"og:type","content":"profile"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Sasha Alexander"}],["$","meta","12",{"name":"twitter:description","content":"Suzana Drobnjakovic, known professionally as Sasha Alexander, is an American actress. She played Gretchen Witter in Dawson's Creek and has appeared in such films as Yes Man (2008) and He's Just Not That Into You (2009). Alexander played Caitlin Todd for the first two seasons of NCIS (2003–2005). From July 2010 through September 2016, Alexander starred as Maura Isles in the TNT series Rizzoli & Isles, and was a regular in Season 5 and 6 of Shameless in 2015–16."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w185/2K3v9aG4JYJtsvZK6MeIhPU7t47.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
