5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Noah Galvin\",\"image\":\"https://image.tmdb.org/t/p/w500/wKGpfo1BHeNMvFVGVJjGqOgiaMh.jpg\",\"description\":\"Noah Egidi Galvin is an American actor and singer. He portrayed Kenny O'Neal in the ABC sitcom The Real O'Neals and was the second person to perform the title role in the Broadway musical Dear Evan Hansen. He also played Dr. Asher Wolke in the TV series The Good Doctor, originated the role of the Duchess in the off-Broadway musical Alice by Heart, and sang as Brian on the cast recording of the musical adaptation of Goosebumps. For his performance in Theater Camp, Galvin received a nomination for Best Supporting Performance at the 39th Independent Spirit Awards.\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/137676/noah-galvin\",\"sameAs\":[\"https://imdb.com/name/nm5687643\"]}"}}],["$","$L10",null,{"person":{"id":"69a07795-41ec-4aea-92d5-518b03330df5","tmdb_id":1472747,"name":"Noah Galvin","gender":2,"biography":"Noah Egidi Galvin is an American actor and singer. He portrayed Kenny O'Neal in the ABC sitcom The Real O'Neals and was the second person to perform the title role in the Broadway musical Dear Evan Hansen. He also played Dr. Asher Wolke in the TV series The Good Doctor, originated the role of the Duchess in the off-Broadway musical Alice by Heart, and sang as Brian on the cast recording of the musical adaptation of Goosebumps. For his performance in Theater Camp, Galvin received a nomination for Best Supporting Performance at the 39th Independent Spirit Awards.","birthday":"1994-05-06","deathday":null,"place_of_birth":"Katonah, New York, U.S.","profile_path":"/wKGpfo1BHeNMvFVGVJjGqOgiaMh.jpg","known_for_department":"Acting","popularity":3.8026,"imdb_id":"nm5687643","created_at":"2026-01-24T11:48:32.960209+00:00","updated_at":"2026-02-15T21:17:26.043+00:00","also_known_as