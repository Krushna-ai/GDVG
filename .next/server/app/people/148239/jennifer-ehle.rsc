9:{"metadata":[["$","title","0",{"children":"Jennifer Ehle | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Jennifer Anne Ehle is an American and British actress. The daughter of writer John Ehle and English actress Rosemary Harris, Ehle started her career acting on stage in the United Kingdom, with the Edinburgh Festival, the Royal Shakespeare Company, and the National Theatre. She earned a Tony Award for Best Actress in a Play and a nomination for the Laurence Olivier Award for Best Actress in Tom Stoppard's The Real Thing. She reunited with Stoppard acting in his play The Coast of Utopia (2007), earning a Tony Award for Best Featured Actress in a Play. She appeared on Broadway in the J.T. Rogers play Oslo, earning a second Tony nomination for Best Actress."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/people/148239/jennifer-ehle"}],["$","meta","5",{"property":"og:title","content":"Jennifer Ehle"}],["$","meta","6",{"property":"og:description","content":"Jennifer Anne Ehle is an American and British actress. The daughter of writer John Ehle and English actress Rosemary Harris, Ehle started her career acting on stage in the United Kingdom, with the Edinburgh Festival, the Royal Shakespeare Company, and the National Theatre. She earned a Tony Award for Best Actress in a Play and a nomination for the Laurence Olivier Award for Best Actress in Tom Stoppard's The Real Thing. She reunited with Stoppard acting in his play The Coast of Utopia (2007), earning a Tony Award for Best Featured Actress in a Play. She appeared on Broadway in the J.T. Rogers play Oslo, earning a second Tony nomination for Best Actress."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/people/148239/jennifer-ehle"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w185/rmHaDj5xQu3ZPoI5XWgA5BZj3zH.jpg"}],["$","meta","9",{"property":"og:type","content":"profile"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Jennifer Ehle"}],["$","meta","12",{"name":"twitter:description","content":"Jennifer Anne Ehle is an American and British actress. The daughter of writer John Ehle and English actress Rosemary Harris, Ehle started her career acting on stage in the United Kingdom, with the Edinburgh Festival, the Royal Shakespeare Company, and the National Theatre. She earned a Tony Award for Best Actress in a Play and a nomination for the Laurence Olivier Award for Best Actress in Tom Stoppard's The Real Thing. She reunited with Stoppard acting in his play The Coast of Utopia (2007), earning a Tony Award for Best Featured Actress in a Play. She appeared on Broadway in the J.T. Rogers play Oslo, earning a second Tony nomination for Best Actress."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w185/rmHaDj5xQu3ZPoI5XWgA5BZj3zH.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
