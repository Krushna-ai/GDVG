5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Jennifer Ehle\",\"image\":\"https://image.tmdb.org/t/p/w500/rmHaDj5xQu3ZPoI5XWgA5BZj3zH.jpg\",\"description\":\"Jennifer Anne Ehle is an American and British actress. The daughter of writer John Ehle and English actress Rosemary Harris, Ehle started her career acting on stage in the United Kingdom, with the Edinburgh Festival, the Royal Shakespeare Company, and the National Theatre. She earned a Tony Award for Best Actress in a Play and a nomination for the Laurence Olivier Award for Best Actress in Tom Stoppard's The Real Thing. She reunited with Stoppard acting in his play The Coast of Utopia (2007), earning a Tony Award for Best Featured Actress in a Play. She appeared on Broadway in the J.T. Rogers play Oslo, earning a second Tony nomination for Best Actress.\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/148239/jennifer-ehle\",\"sameAs\":[\"https://imdb.com/name/nm0000383\"]}"}}],["$","$L10",null,{"person":{"id":"4dd8969d-a0f2-40c2-bbcf-3a8178966c31","tmdb_id":49971,"name":"Jennifer Ehle","gender":1,"biography":"Jennifer Anne Ehle is an American and British actress. The daughter of writer John Ehle and English actress Rosemary Harris, Ehle started her career acting on stage in the United Kingdom, with the Edinburgh Festival, the Royal Shakespeare Company, and the National Theatre. She earned a Tony Award for Best Actress in a Play and a nomination for the Laurence Olivier Award for Best Actress in Tom Stoppard's The Real Thing. She reunited with Stoppard acting in his play The Coast of Utopia (2007), earning a Tony Award for Best Featured Actress in a Play. She appeared on Broadway in the J.T. Rogers play Oslo, earning a second Tony nomination for Best Actress.","birthday":"1969-12-29","deathday":null,"place_of_birth":"Winston-Salem, North Carolina, USA","profile_path":"/rmHaDj5xQu3ZPoI5XWgA5BZj3zH.jpg","known_for_department":"Acting","popularity":3.9285,"imdb_id":"nm0000383","created_at":"2026-02-08T23:44:26.24921+00:00","updated_at":"2026-02-14T21:58:50.207+00:00","also_known_as":[],"homepage":null,"adult":false,"wikipedia_url":"https://en.wikipedia.org/wiki/Jennifer_Ehle","bio_source":"wikipedia","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-08T23:44:26.24921+00:00","main_profile_photo":"/rmHaDj5xQu3ZPoI5XWgA5BZj3zH.jpg","images":{"tagged":[],"profiles":[{"width":310,"height":464,"file_path":"/rmHaDj5xQu3ZPoI5XWgA5BZj3zH.jpg","aspect_ratio":0.668,"vote_average":6.312},{"width":1005,"height":1508,"file_path":"/kMddVKineLFpxsUoGrb3E6edkOv.jpg","aspect_ratio":0.666,"vote_average":6.312},{"width":1039,"height":1557,"file_path":"/gYhErPD5rKoHRLSF59gXTyDyiAW.jpg","aspect_ratio":0.667,"vote_average":2.278},{"width":352,"height":528,"file_path":"/8MgiyFXT83QBTBEkT5Qwa1rTfP.jpg","aspect_ratio":0.667,"vote_average":0},{"width":364,"height":546,"file_path":"/fEIdrH0qwtthqViQyA28KVI3G4N.jpg","aspect_ratio":0.667,"vote_average":0},{"width":357,"height":535,"file_path":"/9PSpn00abJ9cVYMZurztQSZd5df.jpg","aspect_ratio":0.667,"vote_average":0},{"width":424,"height":636,"file_path":"/9Nmspdc1ehqIAUwb9CmfciWm9OW.jpg","aspect_ratio":0.667,"vote_average":0},{"width":591,"height":886,"file_path":"/802U3rtfsuput7ujONpQgXHgaI3.jpg","aspect_ratio":0.667,"vote_average":0},{"width":1246,"height":1869,"file_path":"/5C7yjDlmfFmHQriHjeF2x4Uluxr.jpg","aspect_ratio":0.667,"vote_average":0},{"width":657,"height":986,"file_path":"/vw6rayh2xodRqWSgsMI6c6pS7r8.jpg","aspect_ratio":0.666,"vote_average":0}]},"enriched_at":"2026-02-14T21:58:50.207+00:00","enrichment_cycle":1,"external_ids":null,"social_ids":null,"combined_credits_count":0,"gdvg_id":148239,"native_name":null,"instagram":null,"twitter":null,"tiktok":null,"height_cm":null,"wikidata_id":null}}]]
