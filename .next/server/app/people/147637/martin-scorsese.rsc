9:{"metadata":[["$","title","0",{"children":"Martin Scorsese | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Martin Charles Scorsese is an American filmmaker. One of the major figures of the New Hollywood era, he is widely considered one of the greatest and most influential directors in the history of cinema. He has received many accolades, including an Academy Award, four BAFTA Awards, three Emmy Awards, a Grammy Award, and three Golden Globe Awards. He has been honored with the AFI Life Achievement Award in 1997, the Film Society of Lincoln Center tribute in 1998, the Kennedy Center Honor in 2007, the Cecil B. DeMille Award in 2010, and the BAFTA Fellowship in 2012. Four of his films have been inducted into the National Film Registry by the Library of Congress as \"culturally, historically or aesthetically significant\"."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/people/147637/martin-scorsese"}],["$","meta","5",{"property":"og:title","content":"Martin Scorsese"}],["$","meta","6",{"property":"og:description","content":"Martin Charles Scorsese is an American filmmaker. One of the major figures of the New Hollywood era, he is widely considered one of the greatest and most influential directors in the history of cinema. He has received many accolades, including an Academy Award, four BAFTA Awards, three Emmy Awards, a Grammy Award, and three Golden Globe Awards. He has been honored with the AFI Life Achievement Award in 1997, the Film Society of Lincoln Center tribute in 1998, the Kennedy Center Honor in 2007, the Cecil B. DeMille Award in 2010, and the BAFTA Fellowship in 2012. Four of his films have been inducted into the National Film Registry by the Library of Congress as \"culturally, historically or aesthetically significant\"