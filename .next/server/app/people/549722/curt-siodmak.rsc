5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Curt Siodmak\",\"image\":\"https://image.tmdb.org/t/p/w500/1g2v8J8vJKziUnmee4JVoBAeRsW.jpg\",\"description\":\"From Wikipedia, the free encyclopedia\\n\\nCurt Siodmak (August 10, 1902 – September 2, 2000) was a novelist and screenwriter. He made a name for himself in Hollywood with horror and science fiction films, most notably The Wolf Man and Donovan's Brain (the latter adapted from his novel of the same name). He was the brother of noir director Robert Siodmak.\\n\\nDescription above from the Wikipedia article Curt Siodmak, licensed under CC-BY-SA, full list of contributors on Wikipedia.\",\"jobTitle\":\"Writing\",\"url\":\"https://gdvg-ten.vercel.app/people/549722/curt-siodmak\",\"sameAs\":[\"https://imdb.com/name/nm0802561\"]}"}}],["$","$L10",null,{"person":{"id":"0f756939-f3bf-4c7b-a76a-7de25ec24cbe","tmdb_id":5028,"name":"Curt Siodmak","gender":2,"biography":"From Wikipedia, the free encyclopedia\n\nCurt Siodmak (August 10, 1902 – September 2, 2000) was a novelist and screenwriter. He made a name for himself in Hollywood with horror and science fiction films, most notably The Wolf Man and Donovan's Brain (the latter adapted from his novel of the same name). He was the brother of noir director Robert Siodmak.\n\nDescription above from the Wikipedia article Curt Siodmak, licensed under CC-BY-SA, full list of contributors on Wikipedia.","birthday":"1902-08-10","deathday":"2000-09-02","place_of_birth":"Dresden, Germany","profile_path":"/1g2v8J8vJKziUnmee4JVoBAeRsW.jpg","known_for_department":"Writing","popularity":6.1017,"imdb_id":"nm0802561","created_at":"2026-02-24T22:08:34.692165+00:00","updated_at":"2026-03-18T23:32:59.352+00:00","also_known_as":["Kurt Siodmak","Curtis Siodmak"],"homepage":null,"adult":false,"wikipedia_url":null,"bio_source":"tmdb","import_batch_id":null,"import_batch_name":null,"importe