5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Abir Chatterjee\",\"image\":\"https://image.tmdb.org/t/p/w500/bXirXzEH2ggdto8QAH4xum8y9E8.jpg\",\"description\":\"Abir Chatterjee is an Indian actor who mainly works in Bengali cinema. He is the son of theatre personalities Phalguni Chatterjee and Rumki Chatterjee. He started his career with Bengali television and made his debut in Bengali cinema in 2009 as a lead with Cross Connection. He is well known for appearing as famous detective Byomkesh Bakshi in a separate movie series. He is one of the highest-paid actors in Indian Bengali cinema along Jeet and Dev.\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/149584/abir-chatterjee\",\"sameAs\":[\"https://imdb.com/name/nm3374672\"]}"}}],["$","$L10",null,{"person":{"id":"7ab3ef51-2937-4999-b2af-baa1fec8dea8","tmdb_id":1143634,"name":"Abir Chatterjee","gender":2,"biography":"Abir Chatterjee is an Indian actor who mainly works in Bengali cinema. He is the son of theatre personalities Phalguni Chatterjee and Rumki Chatterjee. He started his career with Bengali television and made his debut in Bengali cinema in 2009 as a lead with Cross Connection. He is well known for appearing as famous detective Byomkesh Bakshi in a separate movie series. He is one of the highest-paid actors in Indian Bengali cinema along Jeet and Dev.","birthday":"1980-11-18","deathday":null,"place_of_birth":"Kolkata, West Bengal, India","profile_path":"/bXirXzEH2ggdto8QAH4xum8y9E8.jpg","known_for_department":"Acting","popularity":3.7639,"imdb_id":"nm3374672","created_at":"2026-02-13T22:05:22.285079+00:00","updated_at":"2026-02-15T21:58:47.571+00:00","also_known_as":["আবীর চট্টোপাধ্যায়"],"homepage":null,"adult":false,"wikipedia_url":"https://en.wikipedia.org/wiki/Abir_Chatterjee","bio_source":"wikipedia","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02