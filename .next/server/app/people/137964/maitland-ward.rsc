5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Maitland Ward\",\"image\":\"https://image.tmdb.org/t/p/w500/kbi23u4XeYaE00PtWLuX1JQ0Ept.jpg\",\"description\":\"Maitland Ward is an American actress, pornographic film actress and model. She made her acting debut as Jessica Forrester on the CBS soap opera The Bold and the Beautiful (1994–1996). Continuing to appear in film and television through the mid-2000s, she came to further prominence for playing Rachel McGuire on the sixth and seventh seasons of the ABC sitcom Boy Meets World (1998–2000). After retiring from mainstream acting in 2007, Ward began performing in pornographic films in 2019.\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/137964/maitland-ward\",\"sameAs\":[\"https://imdb.com/name/nm0005533\"]}"}}],["$","$L10",null,{"person":{"id":"c22952e4-3523-498d-9375-c7717dc44dfd","tmdb_id":71482,"name":"Maitland Ward","gender":1,"biography":"Maitland Ward is an American actress, pornographic film actress and model. She made her acting debut as Jessica Forrester on the CBS soap opera The Bold and the Beautiful (1994–1996). Continuing to appear in film and television through the mid-2000s, she came to further prominence for playing Rachel McGuire on the sixth and seventh seasons of the ABC sitcom Boy Meets World (1998–2000). After retiring from mainstream acting in 2007, Ward began performing in pornographic films in 2019.","birthday":"1977-02-03","deathday":null,"place_of_birth":"Long Beach, California, USA","profile_path":"/kbi23u4XeYaE00PtWLuX1JQ0Ept.jpg","known_for_department":"Acting","popularity":62.849,"imdb_id":"nm0005533","created_at":"2026-02-08T22:50:40.054021+00:00","updated_at":"2026-02-14T21:08:13.083+00:00","also_known_as":["Maitland Ward Baxter","Ashley Maitland Welkos","Ešlija Meitlenda Velkosa","Meitlenda Vorda Bakstere"],"homepage":null,"adult":true,"wikipedia_url"