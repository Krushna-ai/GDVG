5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Megumi Toda\",\"image\":\"https://image.tmdb.org/t/p/w500/shoI0KHLw4kL0VteI9dCayaXCV9.jpg\",\"description\":\"Megumi Toda  is a Japanese voice actress from Tokyo. She is affiliated with Kenyu Office. She was regular on the Animate Pia Channel, which was broadcast on Nico Nico. Her major roles include Hajime Shinoda in New Game!, Kiitan in Etotama and Yuzu Iizuka in Sakura Trick. As part of the Etotama cast, she sang on the theme song under the group Soruaru BOB on a single called \\\"blue moment\\\" that reached number 49 on the Oricon charts. She also sang the theme songs for New Game! under the group forfolium; the singles \\\"Sakura\\\" and \\\"Now Loading!!\\\" reached numbers 33 and 42 on Oricon. As part of the Idolmaster cast, she sang on one of the singles which reached number 22.\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/146970/megumi-toda\",\"sameAs\":[\"https://kenyu-office.com/todamegumi/\",\"https://imdb.com/name/nm7445268\"]}"}}],["$","$L10",null,{"person":{"id":"fa0fcb52-6ff9-4514-b464-d0827e83b0b9","tmdb_id":1678728,"name":"Megumi Toda","gender":1,"biography":"Megumi Toda  is a Japanese voice actress from Tokyo. She is affiliated with Kenyu Office. She was regular on the Animate Pia Channel, which was broadcast on Nico Nico. Her major roles include Hajime Shinoda in New Game!, Kiitan in Etotama and Yuzu Iizuka in Sakura Trick. As part of the Etotama cast, she sang on the theme song under the group Soruaru BOB on a single called \"blue moment\" that reached number 49 on the Oricon charts. She also sang the theme songs for New Game! under the group forfolium; the singles \"Sakura\" and \"Now Loading!!\" reached numbers 33 and 42 on Oricon. As part of the Idolmaster cast, she sang on one of the singles which reached number 22.","birthday":"1990-12-08","deathday":null,"place_of_birth":"Tokyo, Japan","profile_path":"/shoI0KHLw4kL0VteI9dCayaXCV9.jpg","known_for_department":"Acting","popularity":18.697,"imdb_id":"nm7445268","created_at":"2026-02-07T23:32:51.250822+00:00","updated_at":"2026-02-14T21:08:38.581+00:00","also_known_as":["Ichigoyama Buntarou","苺山文太郎","柳 ひとみ","戸田 めぐみ"],"homepage":"https://kenyu-office.com/todamegumi/","adult":true,"wikipedia_url":"https://en.wikipedia.org/wiki/Megumi_Toda","bio_source":"wikipedia","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T23:32:51.250822+00:00","main_profile_photo":"/shoI0KHLw4kL0VteI9dCayaXCV9.jpg","images":{"tagged":[],"profiles":[{"width":853,"height":1280,"file_path":"/shoI0KHLw4kL0VteI9dCayaXCV9.jpg","aspect_ratio":0.666,"vote_average":3.334},{"width":798,"height":1200,"file_path":"/hGAg88Mpc0VA1K9FV8AYJ881fwP.jpg","aspect_ratio":0.665,"vote_average":0.166}]},"enriched_at":"2026-02-14T21:08:38.581+00:00","enrichment_cycle":1,"external_ids":null,"social_ids":null,"combined_credits_count":0,"gdvg_id":146970,"native_name":null,"instagram":null,"twitter":null,"tiktok":null,"height_cm":null,"wikidata_id":null}}]]
