9:{"metadata":[["$","title","0",{"children":"Gina Carano | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Gina Joy Carano is an American actress and mixed martial artist. She competed in Elite Xtreme Combat and Strikeforce from 2006 to 2009, where she compiled a 7–1 record. Her popularity led to her being called the \"face of women's MMA\", although Carano rejected this title. She and Cris Cyborg were the first women to headline a major MMA event during their 2009 Strikeforce bout. Carano retired from competition after her first professional MMA defeat to Cyborg."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/people/596380/gina-carano"}],["$","meta","5",{"property":"og:title","content":"Gina Carano"}],["$","meta","6",{"property":"og:description","content":"Gina Joy Carano is an American actress and mixed martial artist. She competed in Elite Xtreme Combat and Strikeforce from 2006 to 2009, where she compiled a 7–1 record. Her popularity led to her being called the \"face of women's MMA\", although Carano rejected this title. She and Cris Cyborg were the first women to headline a major MMA event during their 2009 Strikeforce bout. Carano retired from competition after her first professional MMA defeat to Cyborg."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/people/596380/gina-carano"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w185/6K89PVbt3v2N7cqbPyZiO74yuOj.jpg"}],["$","meta","9",{"property":"og:type","content":"profile"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Gina Carano"}],["$","meta","12",{"name":"twitter:description","content":"Gina Joy Carano is an American actress and mixed martial artist. She competed in Elite Xtreme Combat and Strikeforce from 2006 to 2009, where she compiled a 7–1 record. Her popularity led to her being called the \"face of women's MMA\", although Carano rejected this title. She and Cris Cyborg were the first women to headline a major MMA event during their 2009 Strikeforce bout. Carano retired from competition after her first professional MMA defeat to Cyborg."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w185/6K89PVbt3v2N7cqbPyZiO74yuOj.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
