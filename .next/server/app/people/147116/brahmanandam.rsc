5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Brahmanandam\",\"image\":\"https://image.tmdb.org/t/p/w500/zh6nWEIy3l1dsZA9EDuDezq867b.jpg\",\"description\":\"Kanneganti Brahmanandam is an Indian actor and comedian known for his work in Telugu cinema. Recognised as one of India's finest and highest-paid comic actors, he holds the Guinness World Record for the most screen credits for a living actor, having appeared in over 1,000 films. Brahmanandam has received numerous accolades, including six Nandi Awards and two Filmfare Awards, and was honoured with the Padma Shri, India's fourth-highest civilian award, in 2009. He was also awarded an honorary doctorate by Acharya Nagarjuna University.\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/147116/brahmanandam\",\"sameAs\":[\"https://imdb.com/name/nm0103977\"]}"}}],["$","$L10",null,{"person":{"id":"634b51dc-891e-496f-ae64-beb54d1024d4","tmdb_id":113810,"name":"Brahmanandam","gender":2,"biography":"Kanneganti Brahmanandam is an Indian actor and comedian known for his work in Telugu cinema. Recognised as one of India's finest and highest-paid comic actors, he holds the Guinness World Record for the most screen credits for a living actor, having appeared in over 1,000 films. Brahmanandam has received numerous accolades, including six Nandi Awards and two Filmfare Awards, and was honoured with the Padma Shri, India's fourth-highest civilian award, in 2009. He was also awarded an honorary doctorate by Acharya Nagarjuna University.","birthday":"1956-02-01","deathday":null,"place_of_birth":"Sattenapalli, Andhra Pradesh, India","profile_path":"/zh6nWEIy3l1dsZA9EDuDezq867b.jpg","known_for_department":"Acting","popularity":4.5789,"imdb_id":"nm0103977","created_at":"2026-02-08T00:11:16.325932+00:00","updated_at":"2026-02-14T21:14:25.647+00:00","also_known_as":["Bramhanandam","ब्रह्मानन्दम","பிரம்மானந்