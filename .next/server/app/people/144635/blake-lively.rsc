5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Blake Lively\",\"image\":\"https://image.tmdb.org/t/p/w500/rkGVjd6wImtgjOCi0IpeffdEWtb.jpg\",\"description\":\"Blake Ellender Brown, known professionally as Blake Lively, is an American actress. A daughter of actor Ernie Lively, she made her professional debut in his directorial project Sandman (1998). She had her breakthrough role in The Sisterhood of the Traveling Pants (2005) and its 2008 sequel. Lively achieved stardom with her portrayal of Serena van der Woodsen in the CW teen drama television series Gossip Girl (2007–2012). During this period, she also took on supporting roles in the romantic comedies New York, I Love You (2008) and The Private Lives of Pippa Lee (2009), as well as in the thrillers The Town (2010) and Savages (2012).\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/144635/blake-lively\",\"sameAs\":[\"https://imdb.com/name/nm0515116\"]}"}}],["$","$L10",null,{"person":{"id":"2fd1f9c8-44ce-4645-8465-879608f12683","tmdb_id":59175,"name":"Blake Lively","gender":1,"biography":"Blake Ellender Brown, known professionally as Blake Lively, is an American actress. A daughter of actor Ernie Lively, she made her professional debut in his directorial project Sandman (1998). She had her breakthrough role in The Sisterhood of the Traveling Pants (2005) and its 2008 sequel. Lively achieved stardom with her portrayal of Serena van der Woodsen in the CW teen drama television series Gossip Girl (2007–2012). During this period, she also took on supporting roles in the romantic comedies New York, I Love You (2008) and The Private Lives of Pippa Lee (2009), as well as in the thrillers The Town (2010) and Savages (2012).","birthday":"1987-08-25","deathday":null,"place_of_birth":"Los Angeles, California, USA","profile_path":"/rkGVjd6wImtgjOCi0IpeffdEWtb.jpg","known_for_department":"Acting","