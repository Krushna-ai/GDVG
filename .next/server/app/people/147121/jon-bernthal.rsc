5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Jon Bernthal\",\"image\":\"https://image.tmdb.org/t/p/w500/pEDKAsy1zO9dgSeBjohqklOXRUQ.jpg\",\"description\":\"Jonathan Edward Bernthal is an American actor. He came to prominence for portraying Shane Walsh on the AMC horror drama series The Walking Dead, where he was a starring cast member in the first two seasons. Bernthal achieved further recognition as Frank Castle / The Punisher in the Marvel Cinematic Universe, appearing in the second season of Daredevil (2016), the spin-off series The Punisher (2017–2019), and the first season of the revival series Daredevil: Born Again (2025). For his recurring guest role as restaurant owner Michael Berzatto in the series The Bear (2022–present), he won a Primetime Emmy Award and was nominated for two others.\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/147121/jon-bernthal\",\"sameAs\":[\"https://imdb.com/name/nm1256532\"]}"}}],["$","$L10",null,{"person":{"id":"7918c84e-858f-46ae-a8bf-905570c171e7","tmdb_id":19498,"name":"Jon Bernthal","gender":2,"biography":"Jonathan Edward Bernthal is an American actor. He came to prominence for portraying Shane Walsh on the AMC horror drama series The Walking Dead, where he was a starring cast member in the first two seasons. Bernthal achieved further recognition as Frank Castle / The Punisher in the Marvel Cinematic Universe, appearing in the second season of Daredevil (2016), the spin-off series The Punisher (2017–2019), and the first season of the revival series Daredevil: Born Again (2025). For his recurring guest role as restaurant owner Michael Berzatto in the series The Bear (2022–present), he won a Primetime Emmy Award and was nominated for two others.","birthday":"1976-09-20","deathday":null,"place_of_birth":"Washington, D.C., USA","profile_path":"/pEDKAsy1zO9dgSeBjohqklOXRUQ.jpg","known_for_departm