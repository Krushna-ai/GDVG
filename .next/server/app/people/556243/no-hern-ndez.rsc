5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Noé Hernández\",\"image\":\"https://image.tmdb.org/t/p/w500/l3NXUy1x5buKHawSw4xye5JW8pl.jpg\",\"description\":\"Noé Hernández Álvarez is a Mexican actor. Following his studies of Dramatic Arts at the Autonomous University of the State of Mexico, he became a high school teacher and founded an experimental theater group. After relocating to Mexico City he was offered little roles on several films, including Propiedad Ajena and Sin Nombre. His first lead role was Lino Valdez in Miss Bala, gaining popular recognition and earning a nomination for an Ariel Award for Best Actor.\",\"jobTitle\":\"Acting\",\"url\":\"https://gdvg-ten.vercel.app/people/556243/no-hern-ndez\",\"sameAs\":[\"https://imdb.com/name/nm2084963\"]}"}}],["$","$L10",null,{"person":{"id":"646083cc-3043-4e68-a9ad-c5a7a4060f38","tmdb_id":89445,"name":"Noé Hernández","gender":2,"biography":"Noé Hernández Álvarez is a Mexican actor. Following his studies of Dramatic Arts at the Autonomous University of the State of Mexico, he became a high school teacher and founded an experimental theater group. After relocating to Mexico City he was offered little roles on several films, including Propiedad Ajena and Sin Nombre. His first lead role was Lino Valdez in Miss Bala, gaining popular recognition and earning a nomination for an Ariel Award for Best Actor.","birthday":"1969-11-10","deathday":null,"place_of_birth":"Atitalaquía, Hidalgo, México","profile_path":"/l3NXUy1x5buKHawSw4xye5JW8pl.jpg","known_for_department":"Acting","popularity":4.5322,"imdb_id":"nm2084963","created_at":"2026-02-24T23:07:02.816667+00:00","updated_at":"2026-03-07T23:58:14.816+00:00","also_known_as":["Noé Hernández"],"homepage":null,"adult":false,"wikipedia_url":"https://en.wikipedia.org/wiki/No%C3%A9_Hern%C3%A1ndez_(actor)","bio_source":"wikipedia","import_batch_id":null,"import_batch_na