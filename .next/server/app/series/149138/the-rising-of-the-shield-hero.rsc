9:{"metadata":[["$","title","0",{"children":"The Rising of the Shield Hero | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Naofumi Iwatani, an uncharismatic Otaku who spends his days on games and manga, suddenly finds himself summoned to a parallel universe! He discovers he is one of four heroes equipped with legendary weapons and tasked with saving the world from its prophesied destruction. As the Shield Hero, the weakest of the heroes, all is not as it seems. Naofumi is soon alone, penniless, and betrayed. With no one to turn to, and nowhere to run, he is left with only his shield. Now, Naofumi must rise to become the legendary Shield Hero and save the world!<br>\n<br>\n<i>Note:<br>\n- The first episode was pre-aired on December 27th, 2018. Regular broadcast began on January 9th, 2019.<br>\n- The first episode aired with a runtime of ~47 minutes as opposed to the standard 24 minute long episode.</i>"}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/series/149138/the-rising-of-the-shield-hero"}],["$","meta","5",{"property":"og:title","content":"The Rising of the Shield Hero"}],["$","meta","6",{"property":"og:description","content":"Naofumi Iwatani, an uncharismatic Otaku who spends his days on games and manga, suddenly finds himself summoned to a parallel universe! He discovers he is one of four heroes equipped with legendary weapons and tasked with saving the world from its prophesied destruction. As the Shield Hero, the weakest of the heroes, all is not as it seems. Naofumi is soon alone, penniless, and betrayed. With no one to turn to, and nowhere to run, he is left with only his shield. Now, Naofumi must rise to become the legendary Shield Hero and save the world!<br>\n<br>\n<i>Note:<br>\n- The first episode was pre-aired on December 27th, 2018. Regular broadcast began on January 9th, 2019.<br>\n- The first episode aired with a runtime of ~47 minutes as opposed to the standard 24 minute long episode.</i>"}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/series/149138/the-rising-of-the-shield-hero"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx99263-LcazQwdlWzMy.jpg"}],["$","meta","9",{"property":"og:type","content":"video.tv_show"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"The Rising of the Shield Hero"}],["$","meta","12",{"name":"twitter:description","content":"Naofumi Iwatani, an uncharismatic Otaku who spends his days on games and manga, suddenly finds himself summoned to a parallel universe! He discovers he is one of four heroes equipped with legendary weapons and tasked with saving the world from its prophesied destruction. As the Shield Hero, the weakest of the heroes, all is not as it seems. Naofumi is soon alone, penniless, and betrayed. With no one to turn to, and nowhere to run, he is left with only his shield. Now, Naofumi must rise to become the legendary Shield Hero and save the world!<br>\n<br>\n<i>Note:<br>\n- The first episode was pre-aired on December 27th, 2018. Regular broadcast began on January 9th, 2019.<br>\n- The first episode aired with a runtime of ~47 minutes as opposed to the standard 24 minute long episode.</i>"}],"$L12","$L13","$L14"],"error":null,"digest":"$undefined"}
