10:T58d,{"@context":"https://schema.org","@type":"TVSeries","name":"Kaiji - Ultimate Survivor","description":"Itou Kaiji is a bum who steals car emblems and slashes tires on what seems to be a regular basis. This routine changes one day when he is paid a visit by a man in a trench-coat. Once the two get talking, it seems that the visitor (Calling himself Endou) is a debt collector. The reason for his visit is an unpaid loan which Kaiji had previously co-signed for a work-mate (Furuhata Takeshi). The original loan was 300,000 yen and once Takeshi had disappeared, the loan then fell on Kaiji.<br><br>\nKaiji is then told of a way to clear the interest compounded debt (which stood at 3,850,000 yen), which involved getting on a boat with others in his position. Once on the boat the debtors would then have to gamble with loaned money, which would end with a few winning, and others getting into deeper debt and having to work to pay off their debts. After some coercion Kaiji accepts a position on the boat, in order to clear his debt and make a bit of money as well...","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx3002-BExanPfxp888.jpg","datePublished":"2007-10-03","numberOfEpisodes":26,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Psychological","Thriller"],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.2,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"bfb86bf1-75da-439b-a06e-8fc773d5032d","tmdb_id":3002,"imdb_id":null,"content_type":"anime","title":"Kaiji - Ultimate Survivor","original_title":"逆境無頼カイジ Ultimate Survivor","overview":"Itou Kaiji is a bum who steals car emblems and slashes tires on what seems to be a regular basis. This routine changes one day when he is paid a visit by a man in a trench-coat. Once the two get talking, it seems that the visitor (Calling himself Endou) is a debt collector. The reason for his visit is an unpaid loan which Kaiji had previously co-signed for a work-mate (Furuhata Takeshi). The original loan was 300,000 yen and once Takeshi had disappeared, the loan then fell on Kaiji.<br><br>\nKaiji is then told of a way to clear the interest compounded debt (which stood at 3,850,000 yen), which involved getting on a boat with others in his position. Once on the boat the debtors would then have to gamble with loaned money, which would end with a few winning, and others getting into deeper debt and having to work to pay off their debts. After some coercion Kaiji accepts a position on the boat, in order to clear his debt and make a bit of money as well...","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx3002-BExanPfxp888.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/3002-HcG6WRNYf5BC.jpg","release_date":null,"first_air_date":"2007-10-03","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Psychological"},{"id":2,"name":"Thriller"}],"popularity":93778,"vote_average":8.2,"vote_count":null,"runtime":23,"number_of_seasons":null,"number_of_episodes":26,"created_at":"2026-05-02T08:50:33.880226+00:00","updated_at":"2026-05-02T08:50:33.843+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"MADHOUSE"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2008-04-02","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Gambling"},{"id":2,"name":"Survival"},{"id":3,"name":"Primarily Adult Cast"},{"id":4,"name":"Class Struggle"},{"id":5,"name":"Primarily Male Cast"},{"id":6,"name":"Seinen"},{"id":7,"name":"Male Protagonist"},{"id":8,"name":"Death Game"},{"id":9,"name":"Philosophy"},{"id":10,"name":"Crime"},{"id":11,"name":"Card Battle"},{"id":12,"name":"Yakuza"}],"alternative_titles":null,"videos":[],"w