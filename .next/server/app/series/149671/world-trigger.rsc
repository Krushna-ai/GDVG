10:T506,{"@context":"https://schema.org","@type":"TVSeries","name":"World Trigger","description":"One day, a gate to another world suddenly opens in Mikado City. Aliens invincible to Earth’s weapons, called “Neighbors”, start coming over. Earth’s only line of defense is a mysterious group called the “Border” who are armed with weapons called “Triggers”.<br>\n <br>\nFour years later, the city has recovered from initial attacks and citizens of Mikado City have started to get used to the Neighbor’s attacks. Yuma Kuga, a transfer student, and his classmate Osamu Mikumo find themselves fighting a Neighbor that suddenly appears. Osamu, who is actually a Border agent, activates his Trigger but is unable to defeat it. This leaves Yuma to activate his own Trigger and defeat the alien. Yuma reveals that he is not part of Border and is actually a Neighbor who has transferred from the other side.<br>\n<br>\n(Source: Crunchyroll)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20729-DnBXnUxFon1B.png","datePublished":"2014-10-05","numberOfEpisodes":73,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Sci-Fi"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.2,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"0b22b236-096d-460c-8bda-d64ec2418d07","tmdb_id":20729,"imdb_id":null,"content_type":"anime","title":"World Trigger","original_title":"ワールドトリガー","overview":"One day, a gate to another world suddenly opens in Mikado City. Aliens invincible to Earth’s weapons, called “Neighbors”, start coming over. Earth’s only line of defense is a mysterious group called the “Border” who are armed with weapons called “Triggers”.<br>\n <br>\nFour years later, the city has recovered from initial attacks and citizens of Mikado City have started to get used to the Neighbor’s attacks. Yuma Kuga, a transfer student, and his classmate Osamu Mikumo find themselves fighting a Neighbor that suddenly appears. Osamu, who is actually a Border agent, activates his Trigger but is unable to defeat it. This leaves Yuma to activate his own Trigger and defeat the alien. Yuma reveals that he is not part of Border and is actually a Neighbor who has transferred from the other side.<br>\n<br>\n(Source: Crunchyroll)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20729-DnBXnUxFon1B.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/20729-yIc4suclOeOA.jpg","release_date":null,"first_air_date":"2014-10-05","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Sci-Fi"}],"popularity":111873,"vote_average":7.2,"vote_count":null,"runtime":23,"number_of_seasons":null,"number_of_episodes":73,"created_at":"2026-05-02T08:50:04.987241+00:00","updated_at":"2026-05-02T08:50:04.945+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Toei Animation"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2016-04-03","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Aliens"},{"id":2,"name":"Ensemble Cast"},{"id":3,"name":"Shounen"},{"id":4,"name":"Urban Fantasy"},{"id":5,"name":"Swordplay"},{"id":6,"name":"Guns"},{"id":7,"name":"Battle Royale"},{"id":8,"name":"Super Power"},{"id":9,"name":"Augmented Reality"},{"id":10,"name":"Military"},{"id":11,"name":"Primarily Male Cast"},{"id":12,"name":"Primarily Teen Cast"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:50:04.987241+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"re