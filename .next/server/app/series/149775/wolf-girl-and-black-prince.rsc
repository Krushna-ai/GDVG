5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Wolf Girl and Black Prince\",\"description\":\"The story centers around Erika Shinohara, a vain 16-year-old girl who tells her friends about her romantic exploits, but she actually has no boyfriend. She claims that a handsome boy in a candid photo is her boyfriend, but it turns out that boy is a schoolmate named Kyouya Sata. She has no choice but to make him her fake boyfriend. Unfortunately, Sata may look like a sweet person, but he is actually an ultra-black-hearted sadist. Sata takes advantage of Erika's weakness and treats her like his dog.\\n<br><br>\\n(Source: Anime News Network)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20701-8tyJFN3soUm0.jpg\",\"datePublished\":\"2014-10-05\",\"numberOfEpisodes\":12,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Comedy\",\"Romance\",\"Slice of Life\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.6,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"f970d698-ce02-4b7b-9cde-4c6b825e26ae","tmdb_id":20701,"imdb_id":null,"content_type":"anime","title":"Wolf Girl and Black Prince","original_title":"オオカミ少女と黒王子","overview":"The story centers around Erika Shinohara, a vain 16-year-old girl who tells her friends about her romantic exploits, but she actually has no boyfriend. She claims that a handsome boy in a candid photo is her boyfriend, but it turns out that boy is a schoolmate named Kyouya Sata. She has no choice but to make him her fake boyfriend. Unfortunately, Sata may look like a sweet person, but he is actually an ultra-black-hearted sadist. Sata takes advantage of Erika's weakness and treats her like his dog.\n<br><br>\n(Source: Anime News Network)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20701-8tyJFN3soUm0.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/20701-2TCItnY8VkTE.jpg","release_date":null,"first_air_date":"2014-10-05","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Romance"},{"id":3,"name":"Slice of Life"}],"popularity":96911,"vote_average":6.6,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:50:26.27691+00:00","updated_at":"2026-05-02T08:50:26.236+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"TYO Animations"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2014-12-21","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Shoujo"},{"id":2,"name":"Heterosexual"},{"id":3,"name":"Tsundere"},{"id":4,"name":"Female Protagonist"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:50:26.27691+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":23673,"anilist_id":20701},"social_ids":{"mal":"https://myanimelist.net/anime/23673","anilist":"https://anilist.co/anime/20701"},"gdvg_id":149775,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":null,"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikida