5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"The Familiar of Zero: Knight of the Twin Moons\",\"description\":\"This sequel is a continuation of the previous season, not long after the war. Louise and Saito seemingly getting along now since she knows that he had given up his only chance to return to Tokyo for her. The story continues as Louise begins to use Void Magic from a mysterious secret book she had received from her majesty Henrietta, while a new villain has appeared in town causing trouble.\\n<br><br>\\n(Source: Anime News Network)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx1840-AYZXdXUCpqpR.jpg\",\"datePublished\":\"2007-07-09\",\"numberOfEpisodes\":12,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Adventure\",\"Comedy\",\"Ecchi\",\"Fantasy\",\"Romance\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"a26fa38f-0ddf-42e7-8fba-43893ae0b49a","tmdb_id":1840,"imdb_id":null,"content_type":"anime","title":"The Familiar of Zero: Knight of the Twin Moons","original_title":"ゼロの使い魔 ～双月の騎士～","overview":"This sequel is a continuation of the previous season, not long after the war. Louise and Saito seemingly getting along now since she knows that he had given up his only chance to return to Tokyo for her. The story continues as Louise begins to use Void Magic from a mysterious secret book she had received from her majesty Henrietta, while a new villain has appeared in town causing trouble.\n<br><br>\n(Source: Anime News Network)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx1840-AYZXdXUCpqpR.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/1840-dJnYA5qtz0Th.jpg","release_date":null,"first_air_date":"200