9:{"metadata":[["$","title","0",{"children":"Rokka -Braves of the Six Flowers- | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"When the Majin awoke from the depths of darkness, the deity of fate chose six heroes and bequeathed them with the power to save the world. Adlet, a boy who proclaims himself the strongest on Earth, was selected among the Rokka no Yuusha (Heroes of the Six Flowers), and he goes to the rendezvous point — but seven have gathered there. The heroes suspect that someone among the seven is the enemy, and the initial suspicion falls on Adlet.\n<br><br>\n(Source: Anime News Network)"}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/series/149571/rokka-braves-of-the-six-flowers"}],["$","meta","5",{"property":"og:title","content":"Rokka -Braves of the Six Flowers-"}],["$","meta","6",{"property":"og:description","content":"When the Majin awoke from the depths of darkness, the deity of fate chose six heroes and bequeathed them with the power to save the world. Adlet, a boy who proclaims himself the strongest on Earth, was selected among the Rokka no Yuusha (Heroes of the Six Flowers), and he goes to the rendezvous point — but seven have gathered there. The heroes suspect that someone among the seven is the enemy, and the initial suspicion falls on Adlet.\n<br><br>\n(Source: Anime News Network)"}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/series/149571/rokka-braves-of-the-six-flowers"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20955-MeZp4OtwKGl1.jpg"}],["$","meta","9",{"property":"og:type","content":"video.tv_show"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],[