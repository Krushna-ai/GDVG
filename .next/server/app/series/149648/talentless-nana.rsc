10:T43e,{"@context":"https://schema.org","@type":"TVSeries","name":"Talentless Nana","description":"It is the year 20XX. Earth has been assaulted by monsters known as 'the Enemy of Humanity'. In order to deal with this threat, special schools comprised of teenagers with extraordinary abilities were formed. These people, who came to be known as 'the Talented', have abilities that defy the rules of reality. Among these superpowered individuals was an outlier, someone who was sent to one of these schools despite having no innate special abilities whatsoever. This is the story of our protagonist, who attempts to defeat the Enemies of Humanity through the use of intelligence and manipulation.\n","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx117343-NgCLZTaxallv.jpg","datePublished":"2020-10-04","numberOfEpisodes":13,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Horror","Mystery","Psychological","Supernatural","Thriller"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"a3eabf1c-b7ee-49a3-b3e0-11478dbbf1e6","tmdb_id":117343,"imdb_id":null,"content_type":"anime","title":"Talentless Nana","original_title":"無能なナナ","overview":"It is the year 20XX. Earth has been assaulted by monsters known as 'the Enemy of Humanity'. In order to deal with this threat, special schools comprised of teenagers with extraordinary abilities were formed. These people, who came to be known as 'the Talented', have abilities that defy the rules of reality. Among these superpowered individuals was an outlier, someone who was sent to one of these schools despite having no innate special abilities whatsoever. This is the story of our protagonist, who attempts to defeat the Enemies of Humanity through the use of intelligence and manipulation.\n","poster_path"