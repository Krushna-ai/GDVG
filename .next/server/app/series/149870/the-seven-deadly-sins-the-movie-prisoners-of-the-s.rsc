10:T484,{"@context":"https://schema.org","@type":"TVSeries","name":"The Seven Deadly Sins the Movie: Prisoners of the Sky","description":"The Seven Deadly Sins travel to a remote land in search of the phantom ingredient \"sky fish.\" Meliodas and Hawk end up at a \"Sky Palace\" that exists above the clouds, where all the residents have wings. Meliodas is mistaken for a boy who committed a crime and is thrown in prison. Meanwhile, the residents are preparing a ceremony for defense against a ferocious beast that awakens once every 3,000 years. But the Six Knights of Black, a Demon Clan army, arrives and removes the seal on the beast in order to threaten the lives of the residents of Sky Palace. Meliodas and his allies meet the Six Knights of Black in battle.<br>\n<br>\n(Source: Anime News Network)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/nx99540-QnY48c1oifvY.jpg","datePublished":"2018-08-18","numberOfEpisodes":1,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Adventure","Fantasy"],"aggregateRating":{"@type":"AggregateRating","ratingValue":6.9,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"87ee9eb9-4196-4294-bbea-51789df587fe","tmdb_id":99540,"imdb_id":null,"content_type":"anime","title":"The Seven Deadly Sins the Movie: Prisoners of the Sky","original_title":"劇場版 七つの大罪 天空の囚われ人","overview":"The Seven Deadly Sins travel to a remote land in search of the phantom ingredient \"sky fish.\" Meliodas and Hawk end up at a \"Sky Palace\" that exists above the clouds, where all the residents have wings. Meliodas is mistaken for a boy who committed a crime and is thrown in prison. Meanwhile, the residents are preparing a ceremony for defense against a ferocious beast that awakens once every 3,000 years. But the Six Knights of Black, a Demon Clan army, arrives and removes the seal on the beast in order to threaten the lives of the residents of Sky Palace. Meliodas and his allies meet the Six Knights of Black in battle.<br>\n<br>\n(Source: Anime News Network)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/nx99540-QnY48c1oifvY.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/99540-O4ey5WgXrMR8.jpg","release_date":null,"first_air_date":"2018-08-18","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Adventure"},{"id":3,"name":"Fantasy"}],"popularity":86414,"vote_average":6.9,"vote_count":null,"runtime":99,"number_of_seasons":null,"number_of_episodes":1,"created_at":"2026-05-02T08:50:45.855545+00:00","updated_at":"2026-05-02T08:50:45.815+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"A-1 Pictures"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2018-08-18","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Shounen"},{"id":2,"name":"Demons"},{"id":3,"name":"Magic"},{"id":4,"name":"Super Power"},{"id":5,"name":"Male Protagonist"},{"id":6,"name":"Ensemble Cast"},{"id":7,"name":"Fairy"},{"id":8,"name":"Medieval"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:50:45.855545+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":35946,"anilist_id":99540},"social_ids":{"mal":"https://myanimelist.net/anime/35946","anilist":"https://anilist.co/anime/99540"},"gdvg_id":149870,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_