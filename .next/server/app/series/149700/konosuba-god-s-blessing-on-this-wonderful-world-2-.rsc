10:T548,{"@context":"https://schema.org","@type":"TVSeries","name":"KONOSUBA -God's blessing on this wonderful world! 2: God's Blessings on These Wonderful Works of Art!","description":"An unaired episode bundled with the 12th volume of the light novel.<br>\n<br>\nAfter returning from his trip to Arcanretia, Kazuma is living life without a care in the world, thanks to his debts being all paid off by the reward money he earned from eliminating one of the Devil King's generals, Hans. One day, a rookie adventurer named Ran comes up to him in the Guild Hall asking for a handshake. She's apparently become a fan of Kazuma after his consecutive defeat of the Devil King's generals! This puts him in an amazing mood, but it's not long before the Guild receptionist Luna appears, asking him to take on a quest to eliminate a golem. Wanting to look good in front of a fan, Kazuma ends up accepting, and heads towards ancient ruins with Aqua, Megumin, and Darkness in tow.<br>\n<br>\n(Source: Crunchyroll)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/b97996-px2KGexuEZpg.jpg","datePublished":"2017-07-24","numberOfEpisodes":1,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Adventure","Comedy","Fantasy"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.8,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"5ee182f2-8cc6-48a3-ad2c-988f3b07bc1c","tmdb_id":97996,"imdb_id":null,"content_type":"anime","title":"KONOSUBA -God's blessing on this wonderful world! 2: God's Blessings on These Wonderful Works of Art!","original_title":"この素晴らしい世界に祝福を！ 2 この素晴らしい芸術に祝福を!","overview":"An unaired episode bundled with the 12th volume of the light novel.<br>\n<br>\nAfter returning from his trip to Arcanretia, Kazuma is living life without a care in the world, thanks to his debts being all paid off by the reward money he earned from eliminating one of the Devil King's generals, Hans. One day, a rookie adventurer named Ran comes up to him in the Guild Hall asking for a handshake. She's apparently become a fan of Kazuma after his consecutive defeat of the Devil King's generals! This puts him in an amazing mood, but it's not long before the Guild receptionist Luna appears, asking him to take on a quest to eliminate a golem. Wanting to look good in front of a fan, Kazuma ends up accepting, and heads towards ancient ruins with Aqua, Megumin, and Darkness in tow.<br>\n<br>\n(Source: Crunchyroll)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/b97996-px2KGexuEZpg.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/97996-3llIqC8Fv29V.jpg","release_date":null,"first_air_date":"2017-07-24","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Adventure"},{"id":2,"name":"Comedy"},{"id":3,"name":"Fantasy"}],"popularity":106735,"vote_average":7.8,"vote_count":null,"runtime":29,"number_of_seasons":null,"number_of_episodes":1,"created_at":"2026-05-02T08:50:12.236607+00:00","updated_at":"2026-05-02T08:50:12.196+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Studio DEEN"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2017-07-24","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Isekai"},{"id":2,"name":"Satire"},{"id":3,"name":"Parody"},{"id":4,"name":"Afterlife"},{"id":5,"name":"Chuunibyou"},{"id":6,"name":"Swordplay"},{"id":7,"name":"Gods"},{"id":8,"name":"Magic"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:50:12.236607+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"en