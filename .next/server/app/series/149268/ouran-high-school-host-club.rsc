10:T493,{"@context":"https://schema.org","@type":"TVSeries","name":"Ouran High School Host Club","description":"Fujioka Haruhi wins a scholarship to attend Ouran Academy, a school reserved for only the most rich and prestigious. Despite what other students may think of her, she cares little for physical appearances or the fact that she is a commoner.<br><br>\nUnfortunately for Haruhi, her high school days take a sudden turn when she stumbles upon the Host Club, an elite club filled with super rich and beautiful boys who use their specific traits and charms to entertain young ladies. Even worse, Haruhi accidentally breaks an 8-million yen vase in the club. Since she is unable to repay her debt with money, Haruhi finds herself with no choice but to work for the Host Club, becoming a male host herself.","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx853-fiUtW8yohsSF.jpg","datePublished":"2006-04-05","numberOfEpisodes":26,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Comedy","Drama","Romance","Slice of Life"],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.1,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"fdbc7fe8-6b59-4995-9f81-008aa2bbc2a0","tmdb_id":853,"imdb_id":null,"content_type":"anime","title":"Ouran High School Host Club","original_title":"桜蘭高校ホスト部","overview":"Fujioka Haruhi wins a scholarship to attend Ouran Academy, a school reserved for only the most rich and prestigious. Despite what other students may think of her, she cares little for physical appearances or the fact that she is a commoner.<br><br>\nUnfortunately for Haruhi, her high school days take a sudden turn when she stumbles upon the Host Club, an elite club filled with super rich and beautiful boys who use their specific traits and charms to entertain young ladies. Even worse, Haruhi accidentally breaks an 8-million yen vase in the club. Since she is unable to repay her debt with money, Haruhi finds herself with no choice but to work for the Host Club, becoming a male host herself.","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx853-fiUtW8yohsSF.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/853-03VYT300hMaf.jpg","release_date":null,"first_air_date":"2006-04-05","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Drama"},{"id":3,"name":"Romance"},{"id":4,"name":"Slice of Life"}],"popularity":242765,"vote_average":8.1,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":26,"created_at":"2026-05-02T08:45:20.521624+00:00","updated_at":"2026-05-02T08:45:20.477+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"bones"},{"name":"Nomad"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2006-09-27","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"School Club"},{"id":2,"name":"Shoujo"},{"id":3,"name":"Crossdressing"},{"id":4,"name":"Surreal Comedy"},{"id":5,"name":"Parody"},{"id":6,"name":"School"},{"id":7,"name":"Male Harem"},{"id":8,"name":"Female Protagonist"},{"id":9,"name":"Primarily Teen Cast"},{"id":10,"name":"Ensemble Cast"},{"id":11,"name":"Primarily Male Cast"},{"id":12,"name":"Cute Boys Doing Cute Things"},{"id":13,"name":"Meta"},{"id":14,"name":"Twins"},{"id":15,"name":"Episodic"},{"id":16,"name":"Unrequited Love"},{"id":17,"name":"Femboy"},{"id":18,"name":"Gender Bending"},{"id":19,"name":"Satire"},{"id":20,"name":"Heterosexual"},{"id":21,"name":"Found Family"},{"id":22,"name":"LGBTQ+ Themes"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null