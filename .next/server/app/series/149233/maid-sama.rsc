10:T58c,{"@context":"https://schema.org","@type":"TVSeries","name":"Maid-Sama!","description":"Being the first female student council president isn't easy, especially when your school just transitioned from an all boys high school to a co-ed one. Aptly nicknamed \"Demon President\" by the boys for her strict disciplinary style, Misaki Ayuzawa is not afraid to use her mastery of Aikido techniques to cast judgment onto the hordes of misbehaving boys and defend the girls at Seika High School.<br>\n<br>\nYet even the perfect Ayuzawa has an embarrassing secret—she works part-time as a maid at a maid café to help her struggling family pay the bills. She has managed to keep her job hidden from her fellow students and maintained her flawless image as a stellar student until one day, Takumi Usui, the most popular boy in school, walks into the maid café. He could destroy her reputation with her secret... or he could twist the student council president around his little finger and use her secret as an opportunity to get closer to her.<br><br>\n(Source: MAL Rewrite)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx7054-GW4D7VAZG19W.png","datePublished":"2010-04-02","numberOfEpisodes":26,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Comedy","Drama","Romance"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.8,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"fc5ec6a7-6965-472e-bf56-d3d510f61320","tmdb_id":7054,"imdb_id":null,"content_type":"anime","title":"Maid-Sama!","original_title":"会長はメイド様!","overview":"Being the first female student council president isn't easy, especially when your school just transitioned from an all boys high school to a co-ed one. Aptly nicknamed \"Demon President\" by the boys for her strict disciplinary style, Misaki Ayuzawa is not afraid to use her mastery of Aikido techniques to cast judgment onto the hordes of misbehaving boys and defend the girls at Seika High School.<br>\n<br>\nYet even the perfect Ayuzawa has an embarrassing secret—she works part-time as a maid at a maid café to help her struggling family pay the bills. She has managed to keep her job hidden from her fellow students and maintained her flawless image as a stellar student until one day, Takumi Usui, the most popular boy in school, walks into the maid café. He could destroy her reputation with her secret... or he could twist the student council president around his little finger and use her secret as an opportunity to get closer to her.<br><br>\n(Source: MAL Rewrite)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx7054-GW4D7VAZG19W.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/7054-iTfiX8juTvRV.jpg","release_date":null,"first_air_date":"2010-04-02","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Drama"},{"id":3,"name":"Romance"}],"popularity":271653,"vote_average":7.8,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":26,"created_at":"2026-05-02T08:45:14.723093+00:00","updated_at":"2026-05-02T08:45:14.678+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"J.C.STAFF"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2010-09-24","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Shoujo"},{"id":2,"name":"Female Protagonist"},{"id":3,"name":"School"},{"id":4,"name":"Maids"},{"id":5,"name":"Work"},{"id":6,"name":"Tsundere"},{"id":7,"name":"Unrequited Love"},{"id":8,"name":"Ensemble Cast"},{"id":9,"name":"Heterosexual"},{"id":10,"name":"Primarily Teen Cast"},{"id":11,"name":"Episodic"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id