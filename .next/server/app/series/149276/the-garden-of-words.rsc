10:T46c,{"@context":"https://schema.org","@type":"TVSeries","name":"The Garden of Words","description":"Some people revel and play in the rain; others dread it and hide at the first drop. For high school student Takao, a summer shower is a source of artistic inspiration… but when he skips school in order to sketch in a rainy garden, Takao finds an even greater muse in Yukino, an older woman who seems adrift in the world. Despite the difference in their ages and lives, they strike up a comfortable relationship that slowly evolves as they randomly meet in the same garden whenever it rains. But with the rainy season coming to a close, Takao wonders if there's enough time left to put his feelings into actions and words.<br><br>\n(Source: Sentai Filmworks)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx16782-qpFGk18UqaHn.jpg","datePublished":"2013-05-31","numberOfEpisodes":1,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Psychological","Romance","Slice of Life"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.5,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"e7f26ed0-0238-4695-b96d-25b72b12765a","tmdb_id":16782,"imdb_id":null,"content_type":"anime","title":"The Garden of Words","original_title":"言の葉の庭","overview":"Some people revel and play in the rain; others dread it and hide at the first drop. For high school student Takao, a summer shower is a source of artistic inspiration… but when he skips school in order to sketch in a rainy garden, Takao finds an even greater muse in Yukino, an older woman who seems adrift in the world. Despite the difference in their ages and lives, they strike up a comfortable relationship that slowly evolves as they randomly meet in the same garden whenever it rains. But with the rainy season coming to a close, Takao wonders if there's enough time left to put his feelings into actions and words.<br><br>\n(Source: Sentai Filmworks)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx16782-qpFGk18UqaHn.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/16782.jpg","release_date":null,"first_air_date":"2013-05-31","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Psychological"},{"id":3,"name":"Romance"},{"id":4,"name":"Slice of Life"}],"popularity":235871,"vote_average":7.5,"vote_count":null,"runtime":46,"number_of_seasons":null,"number_of_episodes":1,"created_at":"2026-05-02T08:45:21.851784+00:00","updated_at":"2026-05-02T08:45:21.806+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"CoMix Wave"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2013-05-31","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Coming of Age"},{"id":2,"name":"Heterosexual"},{"id":3,"name":"Male Protagonist"},{"id":4,"name":"Urban"},{"id":5,"name":"Drawing"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:45:21.851784+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":16782,"anilist_id":16782},"social_ids":{"mal":"https://myanimelist.net/anime/16782","anilist":"https://anilist.co/anime/16782"},"gdvg_id":149276,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":null,"aggregate_credits":null,"original_