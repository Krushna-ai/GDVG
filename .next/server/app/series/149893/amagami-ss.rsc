5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Amagami SS\",\"description\":\"Two years ago, Junichi Tachibana had his heart broken by a girl who stood him up on a date on Christmas Eve. Now a second-year student in high school, Junichi is wary of love because of his past and dislikes celebrating Christmas. However this Christmas, his encounter with one of six girls from his school: Haruka Morishima, Kaoru Tanamachi, Sae Nakata, Ai Nanasaki, Rihoko Sakurai, or Tsukasa Ayatsuji will finally open up his heart to love again.\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/nx8676-rpRpE8lD4tbw.png\",\"datePublished\":\"2010-07-02\",\"numberOfEpisodes\":25,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Comedy\",\"Romance\",\"Slice of Life\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.9,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"d49d5907-8fa3-4cbc-b116-522b55192603","tmdb_id":8676,"imdb_id":null,"content_type":"anime","title":"Amagami SS","original_title":"アマガミSS","overview":"Two years ago, Junichi Tachibana had his heart broken by a girl who stood him up on a date on Christmas Eve. Now a second-year student in high school, Junichi is wary of love because of his past and dislikes celebrating Christmas. However this Christmas, his encounter with one of six girls from his school: Haruka Morishima, Kaoru Tanamachi, Sae Nakata, Ai Nanasaki, Rihoko Sakurai, or Tsukasa Ayatsuji will finally open up his heart to love again.","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/nx8676-rpRpE8lD4tbw.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/8676-xPUw6MBP5vqB.jpg","release_date":null,"first_air_date":"2010-07-02","status":"published","original_language":"ja","origin_country":[