5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"The Beginning After the End\",\"description\":\"After a mysterious death, King Grey is reborn as Arthur Leywin on the magical continent of Dicathen. Although he enters his second life as a baby, his previous wisdom remains. He begins to master magic and forge his own path as the years go by, seeking to correct the mistakes of his past life. \\n<br><br>\\n(Source: Crunchyroll)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx183161-5M054tuPmZJX.jpg\",\"datePublished\":\"2025-04-03\",\"numberOfEpisodes\":12,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Adventure\",\"Fantasy\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.9,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"8079b5cd-2c7e-4bbc-9809-e0c028ad1183","tmdb_id":183161,"imdb_id":null,"content_type":"anime","title":"The Beginning After the End","original_title":"最強の王様、二度目の人生は 何をする? ","overview":"After a mysterious death, King Grey is reborn as Arthur Leywin on the magical continent of Dicathen. Although he enters his second life as a baby, his previous wisdom remains. He begins to master magic and forge his own path as the years go by, seeking to correct the mistakes of his past life. \n<br><br>\n(Source: Crunchyroll)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx183161-5M054tuPmZJX.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/183161-L5X2veRcYJnh.jpg","release_date":null,"first_air_date":"2025-04-03","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Adventure"},{"id":3,"name":"Fantasy"}],"popularity":80323,"vote_average":5.9,"vote_count":null,"runtime":23,"number_of_seasons":nul