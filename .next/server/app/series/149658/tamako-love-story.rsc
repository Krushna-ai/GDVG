10:T548,{"@context":"https://schema.org","@type":"TVSeries","name":"Tamako -love story-","description":"As she edges toward the end of her high school life, the energetic but generally clueless third-year Tamako Kitashirakawa has only one major concern: pulling off a stunning baton performance at the Usagiyama Marching Festival. But all too soon, she is confronted by the reality that all her friends have big plans for their futures; she, on the other hand, just operates with the moderate goal of continuing to work at her family's restaurant.<br><br>\n\nUnder the same brilliant sky, Mochizou Ooji intends to study at a university in Tokyo, leaving behind his family, friends, and most importantly, his first and only love Tamako. Unfortunately, the shy admirer cannot bring himself to declare his love, and Tamako is yet unaware that she is the source of such anguish. With time quickly running out, Mochizou must confess his feelings to Tamako soon, or his dream of romance will never be fulfilled.\n","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20519-YdNUizVJJIWI.png","datePublished":"2014-04-26","numberOfEpisodes":1,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Romance","Slice of Life"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.8,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"28c5d7b8-5a13-4ac0-bd24-ca7e2d9d02f0","tmdb_id":20519,"imdb_id":null,"content_type":"anime","title":"Tamako -love story-","original_title":"たまこラブストーリー","overview":"As she edges toward the end of her high school life, the energetic but generally clueless third-year Tamako Kitashirakawa has only one major concern: pulling off a stunning baton performance at the Usagiyama Marching Festival. But all too soon, she is confronted by the reality that all her friends have big plans for their futures; she, on the other hand, just operates with the moderate goal of continuing to work at her family's restaurant.<br><br>\n\nUnder the same brilliant sky, Mochizou Ooji intends to study at a university in Tokyo, leaving behind his family, friends, and most importantly, his first and only love Tamako. Unfortunately, the shy admirer cannot bring himself to declare his love, and Tamako is yet unaware that she is the source of such anguish. With time quickly running out, Mochizou must confess his feelings to Tamako soon, or his dream of romance will never be fulfilled.\n","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20519-YdNUizVJJIWI.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/20519-xmPmzDJtqCRp.jpg","release_date":null,"first_air_date":"2014-04-26","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Romance"},{"id":2,"name":"Slice of Life"}],"popularity":113554,"vote_average":7.8,"vote_count":null,"runtime":78,"number_of_seasons":null,"number_of_episodes":1,"created_at":"2026-05-02T08:50:02.776983+00:00","updated_at":"2026-05-02T08:50:02.733+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Kyoto Animation"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2014-04-26","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Coming of Age"},{"id":2,"name":"Heterosexual"},{"id":3,"name":"Female Protagonist"},{"id":4,"name":"Food"},{"id":5,"name":"School"},{"id":6,"name":"Primarily Teen Cast"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:50:02.776983+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":n