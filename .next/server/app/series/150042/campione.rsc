10:T52a,{"@context":"https://schema.org","@type":"TVSeries","name":"Campione!","description":"Some people suddenly find religion, but for 16-year-old Kusanagi GoDo, it's that REALLY old time religion that's found him! As the result of defeating the God of War in mortal combat, GoDo's stuck with the unwanted position of Campione!, or God Slayer, whose duty is to fight Herectical Gods whenever they try to muscle in on the local turf. Not only is this likely to make GoDo roadkill on the Highway to Heaven, it's also a job that comes with a lot of other problems. Like how to deal with the fact that his \"enhanced status\" is attracting a bevy of overly-worshippy female followers. After all, they're just there to aid him in his demi-godly duties, right? So why is it that their leader, the demonically manipulative sword-mistress Erica Brandelli, seems to have such a devilish interest in encouraging some VERY unorthodox activities? <br><br>\n(Source: Sentai Filmworks) ","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx12293-DKc0XJ0cacSZ.jpg","datePublished":"2012-07-06","numberOfEpisodes":13,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Comedy","Ecchi","Romance"],"aggregateRating":{"@type":"AggregateRating","ratingValue":6.4,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"88b8b909-87b0-4ebc-8951-7bdb0e2811d7","tmdb_id":12293,"imdb_id":null,"content_type":"anime","title":"Campione!","original_title":"カンピオーネ！ ～まつろわぬ神々と神殺しの魔王～","overview":"Some people suddenly find religion, but for 16-year-old Kusanagi GoDo, it's that REALLY old time religion that's found him! As the result of defeating the God of War in mortal combat, GoDo's stuck with the unwanted position of Campione!, or God Slayer, whose duty is to fight Herectical Gods whenever they try to muscle in on the local turf. Not only is this likely to make GoDo roadkill on the Highway to Heaven, it's also a job that comes with a lot of other problems. Like how to deal with the fact that his \"enhanced status\" is attracting a bevy of overly-worshippy female followers. After all, they're just there to aid him in his demi-godly duties, right? So why is it that their leader, the demonically manipulative sword-mistress Erica Brandelli, seems to have such a devilish interest in encouraging some VERY unorthodox activities? <br><br>\n(Source: Sentai Filmworks) ","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx12293-DKc0XJ0cacSZ.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/12293.jpg","release_date":null,"first_air_date":"2012-07-06","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Ecchi"},{"id":3,"name":"Romance"}],"popularity":72454,"vote_average":6.4,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":13,"created_at":"2026-05-02T08:51:22.641116+00:00","updated_at":"2026-05-02T08:51:22.599+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"diomedéa"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2012-09-28","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Female Harem"},{"id":2,"name":"Magic"},{"id":3,"name":"Mythology"},{"id":4,"name":"Gods"},{"id":5,"name":"Urban Fantasy"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:51:22.641116+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":12293,"anilist_id":12293