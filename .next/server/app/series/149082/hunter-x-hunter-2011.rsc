10:T514,{"@context":"https://schema.org","@type":"TVSeries","name":"Hunter x Hunter (2011)","description":"A new adaption of the manga of the same name by Togashi Yoshihiro.<br><br>\nA Hunter is one who travels the world doing all sorts of dangerous tasks. From capturing criminals to searching deep within uncharted lands for any lost treasures. Gon is a young boy whose father disappeared long ago, being a Hunter. He believes if he could also follow his father's path, he could one day reunite with him.<br><br>\nAfter becoming 12, Gon leaves his home and takes on the task of entering the Hunter exam, notorious for its low success rate and high probability of death to become an official Hunter. He befriends the revenge-driven Kurapika, the doctor-to-be Leorio and the rebellious ex-assassin Killua in the exam, with their friendship prevailing throughout the many trials and threats they come upon taking on the dangerous career of a Hunter.","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx11061-y5gsT1hoHuHw.png","datePublished":"2011-10-02","numberOfEpisodes":148,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Adventure","Fantasy"],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.9,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"8ce31d91-b606-4332-8fa6-9f303e2ded12","tmdb_id":11061,"imdb_id":null,"content_type":"anime","title":"Hunter x Hunter (2011)","original_title":"HUNTER×HUNTER (2011)","overview":"A new adaption of the manga of the same name by Togashi Yoshihiro.<br><br>\nA Hunter is one who travels the world doing all sorts of dangerous tasks. From capturing criminals to searching deep within uncharted lands for any lost treasures. Gon is a young boy whose father disappeared long ago, being a Hunter. He believes if he could also follow his father's path, he could one day reunite with him.<br><br>\nAfter becoming 12, Gon leaves his home and takes on the task of entering the Hunter exam, notorious for its low success rate and high probability of death to become an official Hunter. He befriends the revenge-driven Kurapika, the doctor-to-be Leorio and the rebellious ex-assassin Killua in the exam, with their friendship prevailing throughout the many trials and threats they come upon taking on the dangerous career of a Hunter.","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx11061-y5gsT1hoHuHw.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/11061-8WkkTZ6duKpq.jpg","release_date":null,"first_air_date":"2011-10-02","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Adventure"},{"id":3,"name":"Fantasy"}],"popularity":787535,"vote_average":8.9,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":148,"created_at":"2026-05-02T08:44:41.343556+00:00","updated_at":"2026-05-02T08:44:41.3+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"MADHOUSE"},{"name":"Studio Live"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2014-09-24","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Shounen"},{"id":2,"name":"Super Power"},{"id":3,"name":"Male Protagonist"},{"id":4,"name":"Travel"},{"id":5,"name":"Ensemble Cast"},{"id":6,"name":"Martial Arts"},{"id":7,"name":"Primarily Male Cast"},{"id":8,"name":"Philosophy"},{"id":9,"name":"Anthropomorphism"},{"id":10,"name":"Primarily Teen Cast"},{"id":11,"name":"Crime"},{"id":12,"name":"Coming of Age"},{"id":13,"name":"Urban Fantasy"},{"id":14,"name":"Environmental"},{"id":15,"name":"Assassins"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmd