5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"My First Girlfriend is a Gal\",\"description\":\"Junichi Hashiba is nearing the end of high school and going into panic mode. His time here has not gone as expected: he has no girlfriend and worse yet—he’s still a virgin! Desperate to experience the big ‘first,’ his friends pressure him to approach the gyaru—a fashionable and boy-crazy gal—Yukana Yame for a good time. But his first mistake was thinking this gal would be an easy one!\\n<br><br>\\n(Source: Funimation)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx97863-79AXrUZ7VQa5.jpg\",\"datePublished\":\"2017-07-12\",\"numberOfEpisodes\":10,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Comedy\",\"Ecchi\",\"Romance\",\"Slice of Life\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.9,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"3c83c508-a719-4cf1-862e-7e2296cdbb5f","tmdb_id":97863,"imdb_id":null,"content_type":"anime","title":"My First Girlfriend is a Gal","original_title":"はじめてのギャル","overview":"Junichi Hashiba is nearing the end of high school and going into panic mode. His time here has not gone as expected: he has no girlfriend and worse yet—he’s still a virgin! Desperate to experience the big ‘first,’ his friends pressure him to approach the gyaru—a fashionable and boy-crazy gal—Yukana Yame for a good time. But his first mistake was thinking this gal would be an easy one!\n<br><br>\n(Source: Funimation)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx97863-79AXrUZ7VQa5.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/97863-dUQTCNacPxWL.png","release_date":null,"first_air_date":"2017-07-12","status":"published","original_language":"ja","origin_country":["JP"],