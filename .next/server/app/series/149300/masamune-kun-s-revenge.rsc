10:T43b,{"@context":"https://schema.org","@type":"TVSeries","name":"Masamune-kun's Revenge","description":"As an overweight child, Makabe Masamune was mercilessly teased and bullied by one particular girl, Adagaki Aki. Determined to one day exact his revenge upon her, Makabe begins a rigorous regimen of self-improvement and personal transformation.\n\nYears later, Masamune re-emerges as a new man. Handsome, popular, with perfect grades and good at sports, Masamune-kun transfers to Aki's school, and is unrecognizable to her. Now, Masamune-kun is ready to confront the girl who bullied him so many years ago and humiliate her at last. But will revenge be as sweet as he thought?<br><br>\n\n(Source: Seven Seas Entertainment)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/nx21857-haPDVD7DKDpg.jpg","datePublished":"2017-01-05","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Comedy","Romance","Slice of Life"],"aggregateRating":{"@type":"AggregateRating","ratingValue":6.5,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"5417d692-73e5-4340-b001-83a6d450b442","tmdb_id":21857,"imdb_id":null,"content_type":"anime","title":"Masamune-kun's Revenge","original_title":"政宗くんのリベンジ","overview":"As an overweight child, Makabe Masamune was mercilessly teased and bullied by one particular girl, Adagaki Aki. Determined to one day exact his revenge upon her, Makabe begins a rigorous regimen of self-improvement and personal transformation.\n\nYears later, Masamune re-emerges as a new man. Handsome, popular, with perfect grades and good at sports, Masamune-kun transfers to Aki's school, and is unrecognizable to her. Now, Masamune-kun is ready to confront the girl who bullied him so many years ago and humiliate her at last. But will revenge be as sweet as he thought?<br><br>\n\n(Source: Seven Seas Entertainment)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/nx21857-haPDVD7DKDpg.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21857-k7r362xG7420.png","release_date":null,"first_air_date":"2017-01-05","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Romance"},{"id":3,"name":"Slice of Life"}],"popularity":225611,"vote_average":6.5,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:45:28.42226+00:00","updated_at":"2026-05-02T08:45:28.375+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"SILVER LINK."}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2017-03-23","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Male Protagonist"},{"id":2,"name":"Revenge"},{"id":3,"name":"Tsundere"},{"id":4,"name":"School"},{"id":5,"name":"Primarily Female Cast"},{"id":6,"name":"Ojou-sama"},{"id":7,"name":"Bullying"},{"id":8,"name":"Heterosexual"},{"id":9,"name":"Kuudere"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:45:28.42226+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":33487,"anilist_id":21857},"social_ids":{"mal":"https://myanimelist.net/anime/33487","anilist":"https://anilist.co/anime/21857"},"gdvg_id":149300,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":null,"aggregate_