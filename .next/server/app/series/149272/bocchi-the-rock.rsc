10:T5d5,{"@context":"https://schema.org","@type":"TVSeries","name":"BOCCHI THE ROCK!","description":"Hitori Gotou, “Bocchi-chan,” is a girl who’s so introverted and shy around people that she’d always start her conversations with “Ah...”<br>\n<br>\nDuring her middle school years, she started playing the guitar, wanting to join a band because she thought it could be an opportunity for even someone shy like her to also shine. But because she had no friends, she ended up practicing guitar for six hours every day all by herself. After becoming a skilled guitar player, she uploaded videos of herself playing the guitar to the internet under the name “Guitar Hero” and fantasized about performing at her school’s cultural festival concert. But not only could she not find any bandmates, before she knew it, she was in high school and still wasn’t able to make a single friend!<br>\n<br>\nShe was really close to becoming a shut-in, but one day, Nijika Ijichi, the drummer in Kessoku Band, reached out to her. And because of that, her everyday life started to change little by little...<br>\n<br>\n(Source: Crunchyroll)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx130003-HTDmeL4RGeJ4.png","datePublished":"2022-10-09","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Comedy","Music","Slice of Life"],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.7,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"c1e10e7b-e42a-4590-9d5d-052be819abe9","tmdb_id":130003,"imdb_id":null,"content_type":"anime","title":"BOCCHI THE ROCK!","original_title":"ぼっち・ざ・ろっく！","overview":"Hitori Gotou, “Bocchi-chan,” is a girl who’s so introverted and shy around people that she’d always start her conversations with “Ah...”<br>\n<br>\nDuring her middle school years, she started playing the guitar, wanting to join a band because she thought it could be an opportunity for even someone shy like her to also shine. But because she had no friends, she ended up practicing guitar for six hours every day all by herself. After becoming a skilled guitar player, she uploaded videos of herself playing the guitar to the internet under the name “Guitar Hero” and fantasized about performing at her school’s cultural festival concert. But not only could she not find any bandmates, before she knew it, she was in high school and still wasn’t able to make a single friend!<br>\n<br>\nShe was really close to becoming a shut-in, but one day, Nijika Ijichi, the drummer in Kessoku Band, reached out to her. And because of that, her everyday life started to change little by little...<br>\n<br>\n(Source: Crunchyroll)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx130003-HTDmeL4RGeJ4.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/130003-5F90a7BtsPQN.jpg","release_date":null,"first_air_date":"2022-10-09","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Music"},{"id":3,"name":"Slice of Life"}],"popularity":240303,"vote_average":8.7,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:45:21.180016+00:00","updated_at":"2026-05-02T08:45:21.136+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"CloverWorks"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2022-12-25","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Band"},{"id":2,"name":"Female Protagonist"},{"id":3,"name":"Primarily Female Cast"},{"id":4,"name":"Primarily Teen Cast"},{"id":5,"name":"Rock Music"},{"id":6,"name":"Cute Girls Doing Cute Things"},{"id":7,"name":"Coming of Age"},{"id":8,"name":"Hikikomori"},{"id":9,"name":"R