9:{"metadata":[["$","title","0",{"children":"Demon Slayer: Kimetsu no Yaiba Mugen Train Arc | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"In Demon Slayer: Kimetsu no Yaiba Mugen Train Arc, Tanjiro Kamado and his fellow Demon Slayer members embark on a mission aboard the Infinity Train. Their new mission is to investigate a series of mysterious disappearances, carried out by a demon that has been terrorizing passengers and killing the demon slayers who oppose it.\n<br><br>\n<i>Note: The first episode is entirely anime original. Episodes 2-7 are a re-edited version of the movie featuring new scenes and music.</i>"}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/series/149185/demon-slayer-kimetsu-no-yaiba-mugen-train-arc"}],["$","meta","5",{"property":"og:title","content":"Demon Slayer: Kimetsu no Yaiba Mugen Train Arc"}],["$","meta","6",{"property":"og:description","content":"In Demon Slayer: Kimetsu no Yaiba Mugen Train Arc, Tanjiro Kamado and his fellow Demon Slayer members embark on a mission aboard the Infinity Train. Their new mission is to investigate a series of mysterious disappearances, carried out by a demon that has been terrorizing passengers and killing the demon slayers who oppose it.\n<br><br>\n<i>Note: The first episode is entirely anime original. Episodes 2-7 are a re-edited version of the movie featuring new scenes and music.</i>"}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/series/149185/demon-slayer-kimetsu-no-yaiba-mugen-train-arc"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx129874-g6ZKXB94Hui1.jpg"}],["$","meta","9",{"property":"og:type","content":"video.tv_show"}],["$","meta","10"