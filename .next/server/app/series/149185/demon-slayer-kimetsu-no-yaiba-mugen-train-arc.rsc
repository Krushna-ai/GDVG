5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Demon Slayer: Kimetsu no Yaiba Mugen Train Arc\",\"description\":\"In Demon Slayer: Kimetsu no Yaiba Mugen Train Arc, Tanjiro Kamado and his fellow Demon Slayer members embark on a mission aboard the Infinity Train. Their new mission is to investigate a series of mysterious disappearances, carried out by a demon that has been terrorizing passengers and killing the demon slayers who oppose it.\\n<br><br>\\n<i>Note: The first episode is entirely anime original. Episodes 2-7 are a re-edited version of the movie featuring new scenes and music.</i>\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx129874-g6ZKXB94Hui1.jpg\",\"datePublished\":\"2021-10-10\",\"numberOfEpisodes\":7,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Adventure\",\"Drama\",\"Fantasy\",\"Mystery\",\"Supernatural\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.2,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"ae19d2b2-b14a-4d23-8283-40daee730558","tmdb_id":129874,"imdb_id":null,"content_type":"anime","title":"Demon Slayer: Kimetsu no Yaiba Mugen Train Arc","original_title":"鬼滅の刃 無限列車編 (TV)","overview":"In Demon Slayer: Kimetsu no Yaiba Mugen Train Arc, Tanjiro Kamado and his fellow Demon Slayer members embark on a mission aboard the Infinity Train. Their new mission is to investigate a series of mysterious disappearances, carried out by a demon that has been terrorizing passengers and killing the demon slayers who oppose it.\n<br><br>\n<i>Note: The first episode is entirely anime original. Episodes 2-7 are a re-edited version of the movie featuring new scenes and music.</i>","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx129874-g6ZKXB94Hui1.jpg","backdrop_path":"https://s