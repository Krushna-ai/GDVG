10:T50d,{"@context":"https://schema.org","@type":"TVSeries","name":"Monster","description":"Dr. Kenzo Tenma is a renowned Japanese brain surgeon working at a leading hospital in Germany. One night, Dr. Tenma risks his reputation and career to save the life of a critically wounded young boy over that of the town mayor who had been planning to support the hospital financially. A string of mysterious murders begin to occur soon after the operation, and Dr. Tenma emerges as the primary suspect despite no incriminating evidence. \n<br><br>\nA doctor is taught to believe that all life is equal; however, when another series of murders occur in the surgeon's vicinity, Dr. Tenma's beliefs are shaken as his actions that night are shown to have much broader consequences than he could have imagined. Leaving behind his life as a surgeon he embarks on a journey across the country to unravel the mystery of the boy he saved.","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx19-gtMC64182sm4.jpg","datePublished":"2004-04-07","numberOfEpisodes":74,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Horror","Mystery","Psychological","Thriller"],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.8,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"9861e9a5-4a61-4c8b-ab57-a18c12492e96","tmdb_id":19,"imdb_id":null,"content_type":"anime","title":"Monster","original_title":"MONSTER","overview":"Dr. Kenzo Tenma is a renowned Japanese brain surgeon working at a leading hospital in Germany. One night, Dr. Tenma risks his reputation and career to save the life of a critically wounded young boy over that of the town mayor who had been planning to support the hospital financially. A string of mysterious murders begin to occur soon after the operation, and Dr. Tenma emerges as the primary suspect despite no incriminating evidence. \n<br><br>\nA doctor is taught to believe that all life is equal; however, when another series of murders occur in the surgeon's vicinity, Dr. Tenma's beliefs are shaken as his actions that night are shown to have much broader consequences than he could have imagined. Leaving behind his life as a surgeon he embarks on a journey across the country to unravel the mystery of the boy he saved.","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx19-gtMC64182sm4.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/19-kJhwsB0Z97tL.jpg","release_date":null,"first_air_date":"2004-04-07","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Horror"},{"id":3,"name":"Mystery"},{"id":4,"name":"Psychological"},{"id":5,"name":"Thriller"}],"popularity":313965,"vote_average":8.8,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":74,"created_at":"2026-05-02T08:45:05.480168+00:00","updated_at":"2026-05-02T08:45:05.438+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"MADHOUSE"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2005-09-28","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Crime"},{"id":2,"name":"Seinen"},{"id":3,"name":"Detective"},{"id":4,"name":"Philosophy"},{"id":5,"name":"Ensemble Cast"},{"id":6,"name":"Noir"},{"id":7,"name":"Primarily Adult Cast"},{"id":8,"name":"Twins"},{"id":9,"name":"Revenge"},{"id":10,"name":"Urban"},{"id":11,"name":"Adoption"},{"id":12,"name":"Police"},{"id":13,"name":"Foreign"},{"id":14,"name":"Male Protagonist"},{"id":15,"name":"Travel"},{"id":16,"name":"Amnesia"},{"id":17,"name":"Medicine"},{"id":18,"name":"Politics"},{"id":19,"name":"Orphan"},{"id":20,"name":"Historical"},{"id":21,"name":"Time Skip"},{"id":22,"name":"Primarily Male Cast"}],"alterna