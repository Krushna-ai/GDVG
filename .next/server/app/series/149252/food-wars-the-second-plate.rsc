10:T4be,{"@context":"https://schema.org","@type":"TVSeries","name":"Food Wars! The Second Plate","description":"The second season of <i>Shokugeki no Souma</i>.<br>\n<br>\nAt the Totsuki Culinary Academy, the first rule is survival of the fittest, and if you don't have what it takes to become a master chef, you need to get out of the kitchen before you get burned. With the wheat of first-year students separated from the chaff, cocky former diner cook Yukihira Souma is one of the handful of kitchen whizzes still standing. As the next round of the Autumn Elections gets underway, can he survive a brutal bento boxing match with the chemistry-obsessed granddaughter of the Academy's director? And which of the other contenders; Megumi, Ryou, Akira, Hisako, Takumi or sinister dark-horse Subaru; will advance to fight for the gold medal?<br>\n<br>\n(Source: Sentai Filmworks))","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21518-uBqzDGIuSxJ5.jpg","datePublished":"2016-07-02","numberOfEpisodes":13,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Comedy","Ecchi"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.9,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"0767de7c-86a6-4790-a19d-ff5adf530b87","tmdb_id":21518,"imdb_id":null,"content_type":"anime","title":"Food Wars! The Second Plate","original_title":"食戟のソーマ 弍ノ皿","overview":"The second season of <i>Shokugeki no Souma</i>.<br>\n<br>\nAt the Totsuki Culinary Academy, the first rule is survival of the fittest, and if you don't have what it takes to become a master chef, you need to get out of the kitchen before you get burned. With the wheat of first-year students separated from the chaff, cocky former diner cook Yukihira Souma is one of the handful of kitchen whizzes still standing. As the next round of the Autumn Elections gets underway, can he survive a brutal bento boxing match with the chemistry-obsessed granddaughter of the Academy's director? And which of the other contenders; Megumi, Ryou, Akira, Hisako, Takumi or sinister dark-horse Subaru; will advance to fight for the gold medal?<br>\n<br>\n(Source: Sentai Filmworks))","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21518-uBqzDGIuSxJ5.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21518-kKwYXPaFO9JL.jpg","release_date":null,"first_air_date":"2016-07-02","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Ecchi"}],"popularity":249367,"vote_average":7.9,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":13,"created_at":"2026-05-02T08:45:17.899995+00:00","updated_at":"2026-05-02T08:45:17.856+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"J.C.STAFF"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2016-09-24","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Food"},{"id":2,"name":"Male Protagonist"},{"id":3,"name":"School"},{"id":4,"name":"Shounen"},{"id":5,"name":"Educational"},{"id":6,"name":"Nudity"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:45:17.899995+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":32282,"anilist_id":21518},"social_ids":{"mal":"https://myanimelist.net/anime/32282","anilist":"https://anilist.co/anime/21518"},"gdvg_id":149252,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":nu