10:T58d,{"@context":"https://schema.org","@type":"TVSeries","name":"Oshi No Ko","description":"When a pregnant young starlet appears in Gorou Amemiya’s countryside medical clinic, the doctor takes it upon himself to safely (and secretly) deliver Ai Hoshino’s child so she can make a scandal-free return to the stage. But no good deed goes unpunished, and on the eve of her delivery, he finds himself slain at the hands of Ai’s deluded stalker — and subsequently reborn as Ai’s child, Aquamarine Hoshino! The glitz and glamor of showbiz hide the dark underbelly of the entertainment industry, threatening to dull the shine of his favorite star. Can he help his new mother rise to the top of the charts? And what will he do when unthinkable disaster strikes? <br>\n<br>\n(Source: HIDIVE)\n<br><br>\n\n<i>Note: Episode 1<b>【推しの子】Mother and Children</b> was pre-screened in advance in Japanese theaters on March 17, 2023. The regular TV broadcast began on April 12, 2023. The first episode has an extended runtime of ~82 minutes.</i>","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx150672-WqmmwZ4nMzAy.png","datePublished":"2023-04-12","numberOfEpisodes":11,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Mystery","Psychological","Supernatural"],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.4,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"7eb53c82-efee-49f7-a4fe-1aae8af6e19e","tmdb_id":150672,"imdb_id":null,"content_type":"anime","title":"Oshi No Ko","original_title":"【推しの子】","overview":"When a pregnant young starlet appears in Gorou Amemiya’s countryside medical clinic, the doctor takes it upon himself to safely (and secretly) deliver Ai Hoshino’s child so she can make a scandal-free return to the stage. But no good deed goes unpunished, and on the eve of her delivery, he finds himself slain at the hands of Ai’s deluded stalker — and subsequently reborn as Ai’s child, Aquamarine Hoshino! The glitz and glamor of showbiz hide the dark underbelly of the entertainment industry, threatening to dull the shine of his favorite star. Can he help his new mother rise to the top of the charts? And what will he do when unthinkable disaster strikes? <br>\n<br>\n(Source: HIDIVE)\n<br><br>\n\n<i>Note: Episode 1<b>【推しの子】Mother and Children</b> was pre-screened in advance in Japanese theaters on March 17, 2023. The regular TV broadcast began on April 12, 2023. The first episode has an extended runtime of ~82 minutes.</i>","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx150672-WqmmwZ4nMzAy.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/150672-ISwoA0eS722H.jpg","release_date":null,"first_air_date":"2023-04-12","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Mystery"},{"id":3,"name":"Psychological"},{"id":4,"name":"Supernatural"}],"popularity":300033,"vote_average":8.4,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":11,"created_at":"2026-05-02T08:45:06.681391+00:00","updated_at":"2026-05-02T08:45:06.638+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Doga Kobo"},{"name":"Doga Kobo"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2023-06-28","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Acting"},{"id":2,"name":"Idol"},{"id":3,"name":"Revenge"},{"id":4,"name":"Twins"},{"id":5,"name":"Male Protagonist"},{"id":6,"name":"Urban"},{"id":7,"name":"Reincarnation"},{"id":8,"name":"Heterosexual"},{"id":9,"name":"Ensemble Cast"},{"id":10,"name":"Female Protagonist"},{"id":11,"name":"Pregnancy"},{"id":12,"name":"Tsundere"},{"id":13,"name":"Filmmaking"}],"alternative_titles":null,"vide