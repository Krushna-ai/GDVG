5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Akudama Drive\",\"description\":\"Many years ago, a Great Civil War ravaged Japan, leaving the country fragmented between two regions: Kansai and Kanto. In Kansai, a group of six Akudama carry out missions given to them by a mysterious black cat, while evading the police. But a dangerous journey is about to unfold when a civilian girl becomes twisted into the Akudama’s way of life and witnesses their criminal drives.<br>\\n<br>\\n(Source: Funimation)\\n<br><br>\\n<i>Note: On May 28, 2021, a director's cut of the final episode was released which included approximately 5 minutes of new content.</i>\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx116566-PPIVQt359vQY.jpg\",\"datePublished\":\"2020-10-08\",\"numberOfEpisodes\":12,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Drama\",\"Sci-Fi\",\"Thriller\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.5,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"70b3dafa-f61c-44db-8c55-e557a872eacb","tmdb_id":116566,"imdb_id":null,"content_type":"anime","title":"Akudama Drive","original_title":"アクダマドライブ","overview":"Many years ago, a Great Civil War ravaged Japan, leaving the country fragmented between two regions: Kansai and Kanto. In Kansai, a group of six Akudama carry out missions given to them by a mysterious black cat, while evading the police. But a dangerous journey is about to unfold when a civilian girl becomes twisted into the Akudama’s way of life and witnesses their criminal drives.<br>\n<br>\n(Source: Funimation)\n<br><br>\n<i>Note: On May 28, 2021, a director's cut of the final episode was released which included approximately 5 minutes of new content.</i>","poster_path":"https://s4.anilist.co/file/anilistcdn/media/an