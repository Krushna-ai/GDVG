10:T53c,{"@context":"https://schema.org","@type":"TVSeries","name":"Fate/Zero Season 2","description":"As the Fourth Holy Grail War rages on with no clear victor in sight, the remaining Servants and their Masters are called upon by Church supervisor Risei Kotomine, in order to band together and confront an impending threat that could unravel the Grail War and bring about the destruction of Fuyuki City. The uneasy truce soon collapses as Masters demonstrate that they will do anything in their power, no matter how despicable, to win.\n<br><br>\nSeeds of doubt are sown between Kiritsugu Emiya and Saber, his Servant, as their conflicting ideologies on heroism and chivalry clash. Meanwhile, an ominous bond forms between Kirei Kotomine, who still seeks to find his purpose in life, and one of the remaining Servants. As the countdown to the end of the war reaches zero, the cost of winning begins to blur the line between victory and defeat.\n<br><br>\n(Source: MAL Rewrite)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx11741-oEy1fJHYm2zJ.jpg","datePublished":"2012-04-08","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Drama","Fantasy","Supernatural"],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.4,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"2e32790c-17bb-4386-ab57-e9355c11853b","tmdb_id":11741,"imdb_id":null,"content_type":"anime","title":"Fate/Zero Season 2","original_title":"Fate/Zero 2ndシーズン","overview":"As the Fourth Holy Grail War rages on with no clear victor in sight, the remaining Servants and their Masters are called upon by Church supervisor Risei Kotomine, in order to band together and confront an impending threat that could unravel the Grail War and bring about the destruction of Fuyuki City. The uneasy truce soon collapses as Masters demonstrate that they will do anything in their power, no matter how despicable, to win.\n<br><br>\nSeeds of doubt are sown between Kiritsugu Emiya and Saber, his Servant, as their conflicting ideologies on heroism and chivalry clash. Meanwhile, an ominous bond forms between Kirei Kotomine, who still seeks to find his purpose in life, and one of the remaining Servants. As the countdown to the end of the war reaches zero, the cost of winning begins to blur the line between victory and defeat.\n<br><br>\n(Source: MAL Rewrite)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx11741-oEy1fJHYm2zJ.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/11741-TWwZCgsK5aXh.jpg","release_date":null,"first_air_date":"2012-04-08","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Drama"},{"id":3,"name":"Fantasy"},{"id":4,"name":"Supernatural"}],"popularity":232655,"vote_average":8.4,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:45:25.12096+00:00","updated_at":"2026-05-02T08:45:25.075+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"ufotable"},{"name":"ufotable"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2012-06-24","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Death Game"},{"id":2,"name":"Battle Royale"},{"id":3,"name":"Magic"},{"id":4,"name":"Mythology"},{"id":5,"name":"Urban Fantasy"},{"id":6,"name":"Anti-Hero"},{"id":7,"name":"Ensemble Cast"},{"id":8,"name":"Primarily Adult Cast"},{"id":9,"name":"War"},{"id":10,"name":"Philosophy"},{"id":11,"name":"Spearplay"},{"id":12,"name":"Religion"},{"id":13,"name":"Body Horror"},{"id":14,"name":"Swordplay"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_u