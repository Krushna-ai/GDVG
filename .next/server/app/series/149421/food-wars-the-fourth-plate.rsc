10:T4b5,{"@context":"https://schema.org","@type":"TVSeries","name":"Food Wars! The Fourth Plate","description":"The fourth season of <i>Shokugeki no Souma</i>.<br>\n<br>\nThe ultimate Regimental Food War continues as the culinary rebels led by Souma and the members of Kyokusei square off against epicurean elitist Azami and the Toutsuki Ten. At stake – the future of dining across Japan. Because if the rebels fail, Azami intends to impose his own tastes and techniques on the entire restaurant industry!<br>\n<br>\nBut the fine dining control freak has made a serious mistake in threatening the futures of Souma’s friends and family, as while the rebels may seem less experienced overall, this is ultimately a clash of skill, dedication, and, most of all, taste. That may be a recipe for disaster for the seasoned veterans!<br>\n<br>\n(Source: Sentai Filmworks)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx109963-t8E9axH0Dvrn.jpg","datePublished":"2019-10-12","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Comedy","Ecchi"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.6,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"c948d10b-cc85-4bfc-9c0f-a3633e20f3ca","tmdb_id":109963,"imdb_id":null,"content_type":"anime","title":"Food Wars! The Fourth Plate","original_title":"食戟のソーマ 神ノ皿","overview":"The fourth season of <i>Shokugeki no Souma</i>.<br>\n<br>\nThe ultimate Regimental Food War continues as the culinary rebels led by Souma and the members of Kyokusei square off against epicurean elitist Azami and the Toutsuki Ten. At stake – the future of dining across Japan. Because if the rebels fail, Azami intends to impose his own tastes and techniques on the entire restaurant industry!<br>\n<br>\nBut the fine dining control freak has made a serious mistake in threatening the futures of Souma’s friends and family, as while the rebels may seem less experienced overall, this is ultimately a clash of skill, dedication, and, most of all, taste. That may be a recipe for disaster for the seasoned veterans!<br>\n<br>\n(Source: Sentai Filmworks)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx109963-t8E9axH0Dvrn.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/109963-hB2vzg1LhxkB.jpg","release_date":null,"first_air_date":"2019-10-12","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Ecchi"}],"popularity":168221,"vote_average":7.6,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:49:10.868227+00:00","updated_at":"2026-05-02T08:49:10.823+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"J.C.STAFF"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2019-12-28","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Food"},{"id":2,"name":"Shounen"},{"id":3,"name":"Educational"},{"id":4,"name":"School"},{"id":5,"name":"Male Protagonist"},{"id":6,"name":"Nudity"},{"id":7,"name":"Female Protagonist"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:49:10.868227+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":39940,"anilist_id":109963},"social_ids":{"mal":"https://myanimelist.net/anime/39940","anilist":"https://anilist.co/anime/109963"},"gdvg_id":149421,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki