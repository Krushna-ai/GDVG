5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Chainsaw Man – The Movie: Reze Arc\",\"description\":\"Theatrical follow-up to <i>Chainsaw Man</i>.<br><br>\\nDenji became “Chainsaw Man”, a boy with a devil’s heart, and is now part of Special Division 4’s devil hunters. After a date with Makima, the woman of his dreams, Denji takes shelter from the rain. There he meets Reze, a girl who works in a café.<br><br>\\n\\n(Source: MAPPA CHANNEL)\\n\\n\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx171627-ZN9D7P46yHnw.png\",\"datePublished\":\"2025-09-19\",\"numberOfEpisodes\":1,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Drama\",\"Horror\",\"Romance\",\"Supernatural\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":9,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"a3d37c55-d6f3-4b74-8534-c6673af5440f","tmdb_id":171627,"imdb_id":null,"content_type":"anime","title":"Chainsaw Man – The Movie: Reze Arc","original_title":"チェンソーマン レゼ篇","overview":"Theatrical follow-up to <i>Chainsaw Man</i>.<br><br>\nDenji became “Chainsaw Man”, a boy with a devil’s heart, and is now part of Special Division 4’s devil hunters. After a date with Makima, the woman of his dreams, Denji takes shelter from the rain. There he meets Reze, a girl who works in a café.<br><br>\n\n(Source: MAPPA CHANNEL)\n\n","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx171627-ZN9D7P46yHnw.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/171627-7esVHhgw69rn.jpg","release_date":null,"first_air_date":"2025-09-19","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Drama"},{"id":3,"name":"Horror"},{"id":4,"name":"Romance"},{"id":5,"name":"Super