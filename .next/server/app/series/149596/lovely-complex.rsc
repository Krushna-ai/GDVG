10:T587,{"@context":"https://schema.org","@type":"TVSeries","name":"Lovely Complex","description":"Love is unusual for Koizumi Risa and Ootani Atsushi, who are both striving to find their ideal partner in high school—172 cm tall Koizumi is much taller than the average girl, and Ootani is much shorter than the average guy at 156 cm. To add to their plights, their crushes fall in love with each other, leaving Koizumi and Ootani comically flustered and heartbroken. To make matters worse, they're even labeled as a comedy duo by their homeroom teacher due to their personalities and the stark difference in their heights, and their classmates even think of their arguments as sketches.<br>\n<br>\nLovely★Complex follows Koizumi and Ootani as they encourage each other in finding love and become close friends. Apart from their ridiculous antics, they soon find out an unexpected similarity in their music and fashion tastes. Maybe they possess a chemistry yet unknown, but could love ever bloom between the mismatched pair?<br>\n<br>\n(Source: MAL Rewrite)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx2034-erjg6gzDetAp.png","datePublished":"2007-04-07","numberOfEpisodes":24,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Comedy","Romance","Slice of Life"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.8,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"70dda86c-2791-4d75-854e-fdf00e86fe71","tmdb_id":2034,"imdb_id":null,"content_type":"anime","title":"Lovely Complex","original_title":"ラブ★コン","overview":"Love is unusual for Koizumi Risa and Ootani Atsushi, who are both striving to find their ideal partner in high school—172 cm tall Koizumi is much taller than the average girl, and Ootani is much shorter than the average guy at 156 cm. To add to their plights, their crushes fall in love with each other, leaving Koizumi and Ootani comically flustered and heartbroken. To make matters worse, they're even labeled as a comedy duo by their homeroom teacher due to their personalities and the stark difference in their heights, and their classmates even think of their arguments as sketches.<br>\n<br>\nLovely★Complex follows Koizumi and Ootani as they encourage each other in finding love and become close friends. Apart from their ridiculous antics, they soon find out an unexpected similarity in their music and fashion tastes. Maybe they possess a chemistry yet unknown, but could love ever bloom between the mismatched pair?<br>\n<br>\n(Source: MAL Rewrite)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx2034-erjg6gzDetAp.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/2034-AL1Xtj5GqKu3.jpg","release_date":null,"first_air_date":"2007-04-07","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Romance"},{"id":3,"name":"Slice of Life"}],"popularity":124015,"vote_average":7.8,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":24,"created_at":"2026-05-02T08:49:49.592571+00:00","updated_at":"2026-05-02T08:49:49.549+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Toei Animation"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2007-09-29","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Female Protagonist"},{"id":2,"name":"Shoujo"},{"id":3,"name":"School"},{"id":4,"name":"Primarily Teen Cast"},{"id":5,"name":"Slapstick"},{"id":6,"name":"Heterosexual"},{"id":7,"name":"Tomboy"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-