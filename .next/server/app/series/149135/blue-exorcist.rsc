10:T459,{"@context":"https://schema.org","@type":"TVSeries","name":"Blue Exorcist","description":"This world consists of two dimensions joined as one, like a mirror. The first is the world in which the humans live, Assiah. The other is the world of demons, Gehenna. Ordinarily, travel between the two, and indeed any kind of contact between the two, is impossible. However the demons can pass over into this world by possessing anything that exist within it. Satan the god of demons, but there's one thing that he doesn't have, and that's a substance in the human world that is powerful enough to contain him!! For that purpose he created Rin, his son from a human woman, but will his son agree to his plans? Or will he become something else...? An exorcist?\n","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx9919-nXS7JOZrWHfS.jpg","datePublished":"2011-04-17","numberOfEpisodes":25,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Fantasy","Supernatural"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.3,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"8c237740-3947-48ef-82c5-2e6e32564228","tmdb_id":9919,"imdb_id":null,"content_type":"anime","title":"Blue Exorcist","original_title":"青の祓魔師","overview":"This world consists of two dimensions joined as one, like a mirror. The first is the world in which the humans live, Assiah. The other is the world of demons, Gehenna. Ordinarily, travel between the two, and indeed any kind of contact between the two, is impossible. However the demons can pass over into this world by possessing anything that exist within it. Satan the god of demons, but there's one thing that he doesn't have, and that's a substance in the human world that is powerful enough to contain him!! For that purpose he created Rin, his son from a human woman, but will his son agree to his plans? Or will he become something else...? An exorcist?\n","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx9919-nXS7JOZrWHfS.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/9919-S5idQm3GbZ80.jpg","release_date":null,"first_air_date":"2011-04-17","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Fantasy"},{"id":3,"name":"Supernatural"}],"popularity":439803,"vote_average":7.3,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":25,"created_at":"2026-05-02T08:44:52.901681+00:00","updated_at":"2026-05-02T08:44:52.846+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"A-1 Pictures"},{"name":"Sakura Create"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2011-10-02","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Demons"},{"id":2,"name":"Shounen"},{"id":3,"name":"Super Power"},{"id":4,"name":"Youkai"},{"id":5,"name":"Male Protagonist"},{"id":6,"name":"Twins"},{"id":7,"name":"Exorcism"},{"id":8,"name":"Religion"},{"id":9,"name":"Urban Fantasy"},{"id":10,"name":"Primarily Teen Cast"},{"id":11,"name":"School"},{"id":12,"name":"Adoption"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:44:52.901681+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":9919,"anilist_id":9919},"social_ids":{"mal":"https://myanimelist.net/anime/9919","anilist":"https://anilist.co/anime/9919"},"gdvg_id":149135,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_pro