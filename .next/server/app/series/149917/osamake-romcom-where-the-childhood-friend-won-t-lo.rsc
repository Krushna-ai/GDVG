10:T44a,{"@context":"https://schema.org","@type":"TVSeries","name":"Osamake: Romcom Where The Childhood Friend Won't Lose","description":"She smiles just for me. Her name is Kachi Shirokusa and she's even an award-winning high school girl writer! And she's beautiful! I know that she's totally out of reach for me, a normal high school kid named Maru Sueharu! But I think something's there... No, there's definitely something there! Or so I thought... but Kachi has a boyfriend?! Seeing me depressed, my friend ever since we were little who's cute, cheerful, and loves to look after others, Shida Kuroha... who also apparently had no problem telling me that she likes me for some reason just suggested, \"Let's get revenge.\"<br>\n<br>\n(Source: Crunchyroll)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx124675-fNI06ipb65vy.jpg","datePublished":"2021-04-14","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Comedy","Romance"],"aggregateRating":{"@type":"AggregateRating","ratingValue":5.8,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"dffbf7b1-049d-480b-8a13-75727d2b8ec1","tmdb_id":124675,"imdb_id":null,"content_type":"anime","title":"Osamake: Romcom Where The Childhood Friend Won't Lose","original_title":"幼なじみが絶対に負けないラブコメ","overview":"She smiles just for me. Her name is Kachi Shirokusa and she's even an award-winning high school girl writer! And she's beautiful! I know that she's totally out of reach for me, a normal high school kid named Maru Sueharu! But I think something's there... No, there's definitely something there! Or so I thought... but Kachi has a boyfriend?! Seeing me depressed, my friend ever since we were little who's cute, cheerful, and loves to look after others, Shida Kuroha... who also apparently had no problem telling me that she likes me for some reason just suggested, \"Let's get revenge.\"<br>\n<br>\n(Source: Crunchyroll)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx124675-fNI06ipb65vy.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/124675-zPcpWLkxjcSE.jpg","release_date":null,"first_air_date":"2021-04-14","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Romance"}],"popularity":81971,"vote_average":5.8,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:50:55.51844+00:00","updated_at":"2026-05-02T08:50:55.474+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Doga Kobo"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2021-06-30","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Love Triangle"},{"id":2,"name":"School"},{"id":3,"name":"Male Protagonist"},{"id":4,"name":"Acting"},{"id":5,"name":"Heterosexual"},{"id":6,"name":"School Club"},{"id":7,"name":"Primarily Female Cast"},{"id":8,"name":"Female Harem"},{"id":9,"name":"Revenge"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:50:55.51844+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":43007,"anilist_id":124675},"social_ids":{"mal":"https://myanimelist.net/anime/43007","anilist":"https://anilist.co/anime/124675"},"gdvg_id":149917,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"