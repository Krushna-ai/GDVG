10:T4c8,{"@context":"https://schema.org","@type":"TVSeries","name":"Maoyu: Archenemy & Hero","description":"After a long and treacherous journey, our Hero finally arrives at the Dark Lady's castle only to find himself being asked for help. The Hero explains how the war that the demons have brought upon the humans have killed thousands and put more in misery. The queen of demons however argues that this war has made the human society band together as one and showed empirical evidence how it has increased population, increased production, boosted economy and improved society overall. Furthermore, she explains to the Hero that ending this war will result in a civil war that will produce more bloodshed than there ever was. The Hero, convinced that the only way to bring peace, relatively speaking, is to join forces with the Dark Lady, agrees to help with her plans!\n","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx14833-6M3yEmu4SJkH.png","datePublished":"2013-01-05","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Adventure","Fantasy","Romance"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"b804221c-8068-4810-bbd0-d4f8c677ce94","tmdb_id":14833,"imdb_id":null,"content_type":"anime","title":"Maoyu: Archenemy & Hero","original_title":"まおゆう魔王勇者","overview":"After a long and treacherous journey, our Hero finally arrives at the Dark Lady's castle only to find himself being asked for help. The Hero explains how the war that the demons have brought upon the humans have killed thousands and put more in misery. The queen of demons however argues that this war has made the human society band together as one and showed empirical evidence how it has increased population, increased production, boosted economy and improved society overall. Furthermore, she explains to the Hero that ending this war will result in a civil war that will produce more bloodshed than there ever was. The Hero, convinced that the only way to bring peace, relatively speaking, is to join forces with the Dark Lady, agrees to help with her plans!\n","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx14833-6M3yEmu4SJkH.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/14833.jpg","release_date":null,"first_air_date":"2013-01-05","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Adventure"},{"id":2,"name":"Fantasy"},{"id":3,"name":"Romance"}],"popularity":103475,"vote_average":7,"vote_count":null,"runtime":23,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:50:15.444034+00:00","updated_at":"2026-05-02T08:50:15.403+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Arms"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2013-03-30","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Female Protagonist"},{"id":2,"name":"Politics"},{"id":3,"name":"War"},{"id":4,"name":"Economics"},{"id":5,"name":"Heterosexual"},{"id":6,"name":"Kingdom Management"},{"id":7,"name":"Male Protagonist"},{"id":8,"name":"Demons"},{"id":9,"name":"Primarily Adult Cast"},{"id":10,"name":"Anachronism"},{"id":11,"name":"Marriage"},{"id":12,"name":"Large Breasts"},{"id":13,"name":"Teacher"},{"id":14,"name":"Monster Girl"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:50:15.444034+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations