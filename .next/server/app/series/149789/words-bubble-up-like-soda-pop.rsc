10:T4f7,{"@context":"https://schema.org","@type":"TVSeries","name":"Words Bubble Up Like Soda Pop","description":"Cherry is a quiet boy who loves to make haikus based off of the things he sees. One summer day in a city in the Japanese countryside…<br>\n<br>\nAt a shopping mall, he meets Smile, a beautiful girl in a mask. Cherry has trouble speaking in anything but haikus, and Smile wears a mask to hide her big, braces-covered front teeth. The two of them get closer as the south wind blows. One day, the two of them learn from Old Man Fujiyama, a master of Haiku who’s started going senile, that he’s searching for a certain record.<br>\n<br>\n“If I can hear this record again, I can remember… Something I don’t want to forget, but can’t remember…”<br>\n<br>\nCherry and Smile decide to help. This is the story of their summer, set in a shopping mall…<br>\n<br>\n(Source: Hakuhodo DY Music & Pictures)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx107625-2UIAI4TRwXz0.jpg","datePublished":"2021-07-22","numberOfEpisodes":1,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Romance","Slice of Life"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.4,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"e9992b2f-fdb5-4eeb-9896-b073ed4bb8d3","tmdb_id":107625,"imdb_id":null,"content_type":"anime","title":"Words Bubble Up Like Soda Pop","original_title":"サイダーのように言葉が湧き上がる","overview":"Cherry is a quiet boy who loves to make haikus based off of the things he sees. One summer day in a city in the Japanese countryside…<br>\n<br>\nAt a shopping mall, he meets Smile, a beautiful girl in a mask. Cherry has trouble speaking in anything but haikus, and Smile wears a mask to hide her big, braces-covered front teeth. The two of them get closer as the south wind blows. One day, the two of them learn from Old Man Fujiyama, a master of Haiku who’s started going senile, that he’s searching for a certain record.<br>\n<br>\n“If I can hear this record again, I can remember… Something I don’t want to forget, but can’t remember…”<br>\n<br>\nCherry and Smile decide to help. This is the story of their summer, set in a shopping mall…<br>\n<br>\n(Source: Hakuhodo DY Music & Pictures)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx107625-2UIAI4TRwXz0.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/107625-hwUyT33A6UK9.jpg","release_date":null,"first_air_date":"2021-07-22","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Romance"},{"id":2,"name":"Slice of Life"}],"popularity":95153,"vote_average":7.4,"vote_count":null,"runtime":87,"number_of_seasons":null,"number_of_episodes":1,"created_at":"2026-05-02T08:50:30.970516+00:00","updated_at":"2026-05-02T08:50:30.932+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Signal.MD"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2021-07-22","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Rural"},{"id":2,"name":"Coming of Age"},{"id":3,"name":"Primarily Teen Cast"},{"id":4,"name":"Male Protagonist"},{"id":5,"name":"Writing"},{"id":6,"name":"Heterosexual"},{"id":7,"name":"Female Protagonist"},{"id":8,"name":"Calligraphy"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:50:30.970516+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":39175,"anilist_id":107625},"social_ids":{"mal":"https://mya