10:T4c3,{"@context":"https://schema.org","@type":"TVSeries","name":"Bloom Into You","description":"Yuu Koito thought love would be something amazing and magical, but when a male friend asks her to date, she feels nothing. She doesn't even know how to respond until she overhears the student council president of her new high school, Touko Nanami, turning down a similar request. With Touko's help, Yuu manages to let her friend down gracefully, but then Touko confesses that she, herself, is starting to have feelings for Yuu, leaving Yuu in a quandary. Yuu doesn't think that she's in love with Touko, but she does feel something. As Yuu joins the Student Council, and she and Touko become closer, her confusion about her feelings only continues to grow. Because you can't control who you love, or who falls in love with you.<br>\n<br>\n(Source: Sentai Filmworks)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/nx101573-Gql3Q3UX1jcu.jpg","datePublished":"2018-10-05","numberOfEpisodes":13,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Romance","Slice of Life"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.8,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"61f131e2-b337-469e-878f-6ee6d5ad2a5d","tmdb_id":101573,"imdb_id":null,"content_type":"anime","title":"Bloom Into You","original_title":"やがて君になる","overview":"Yuu Koito thought love would be something amazing and magical, but when a male friend asks her to date, she feels nothing. She doesn't even know how to respond until she overhears the student council president of her new high school, Touko Nanami, turning down a similar request. With Touko's help, Yuu manages to let her friend down gracefully, but then Touko confesses that she, herself, is starting to have feelings for Yuu, leaving Yuu in a quandary. Yuu doesn't think that she's in love with Touko, but she does feel something. As Yuu joins the Student Council, and she and Touko become closer, her confusion about her feelings only continues to grow. Because you can't control who you love, or who falls in love with you.<br>\n<br>\n(Source: Sentai Filmworks)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/nx101573-Gql3Q3UX1jcu.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/101573-yaDZ76cLeMBU.jpg","release_date":null,"first_air_date":"2018-10-05","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Romance"},{"id":3,"name":"Slice of Life"}],"popularity":130299,"vote_average":7.8,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":13,"created_at":"2026-05-02T08:49:40.116387+00:00","updated_at":"2026-05-02T08:49:40.073+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"TROYCA"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2018-12-28","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Yuri"},{"id":2,"name":"Female Protagonist"},{"id":3,"name":"LGBTQ+ Themes"},{"id":4,"name":"Primarily Female Cast"},{"id":5,"name":"Coming of Age"},{"id":6,"name":"School"},{"id":7,"name":"Aromantic"},{"id":8,"name":"School Club"},{"id":9,"name":"Asexual"},{"id":10,"name":"Primarily Teen Cast"},{"id":11,"name":"Philosophy"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:49:40.116387+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":37786,"anilist_id":101573},"s