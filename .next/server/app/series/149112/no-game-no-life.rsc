5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"No Game, No Life\",\"description\":\"Bored with life and considering the real world to be just a “crappy game,” savvy sibling shut-ins Sora and Shiro have withdrawn into their own fantasy world filled with video games. \\n<br><br>\\nHowever, one day they find themselves summoned to another world by a boy who calls himself “God,” their abilities are about to be put to the ultimate test! Now not only their fates — but the fate of all of humanity — will be decided by a series of games that may just be the hardest these super-geniuses have ever faced!\\n<br><br>\\n(Source: Sentai Filmworks, edited)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/b19815-sEOQ9yQaPKlk.jpg\",\"datePublished\":\"2014-04-09\",\"numberOfEpisodes\":12,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Adventure\",\"Comedy\",\"Ecchi\",\"Fantasy\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.7,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"6e60758f-7430-4583-a818-e76e4864a234","tmdb_id":19815,"imdb_id":null,"content_type":"anime","title":"No Game, No Life","original_title":"ノーゲーム・ノーライフ","overview":"Bored with life and considering the real world to be just a “crappy game,” savvy sibling shut-ins Sora and Shiro have withdrawn into their own fantasy world filled with video games. \n<br><br>\nHowever, one day they find themselves summoned to another world by a boy who calls himself “God,” their abilities are about to be put to the ultimate test! Now not only their fates — but the fate of all of humanity — will be decided by a series of games that may just be the hardest these super-geniuses have ever faced!\n<br><br>\n(Source: Sentai Filmworks, edited)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/b19815-sEOQ9yQaPKlk.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/19815-BqbuD0wyBS3P.jpg","release_date":null,"first_air_date":"2014-04-09","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Adventure"},{"id":2,"name":"Comedy"},{"id":3,"name":"Ecchi"},{"id":4,"name":"Fantasy"}],"popularity":514179,"vote_average":7.7,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:44:46.358019+00:00","updated_at":"2026-05-02T08:44:46.312+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"MADHOUSE"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2014-06-25","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Isekai"},{"id":2,"name":"Gambling"},{"id":3,"name":"Alternate Universe"},{"id":4,"name":"Video Games"},{"id":5,"name":"Hikikomori"},{"id":6,"name":"Magic"},{"id":7,"name":"Male Protagonist"},{"id":8,"name":"Primarily Female Cast"},{"id":9,"name":"Parody"},{"id":10,"name":"Politics"},{"id":11,"name":"Gods"},{"id":12,"name":"Female Protagonist"},{"id":13,"name":"Nudity"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:44:46.358019+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":19815,"anilist_id":19815},"social_ids":{"mal":"https://myanimelist.net/anime/19815","anilist":"https://anilist.co/anime/19815"},"gdvg_id":149112,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_releas