10:T5bf,{"@context":"https://schema.org","@type":"TVSeries","name":"Durarara!! X2 The Third Arc","description":"<i>The third part of Durarara!!x2</i><br>\n<br>\nAs Mikado Ryuugamine continues to purge the Dollars from within in accordance with his warped sense of justice, Masaomi Kida hopes to bring his friend back to his senses by bringing the Yellow Scarves together once more. Little do they know that a far more dominant force is about to enter their struggle for power, one that their friend Anri Sonohara is all too familiar with.<br>\n<br>\nMeanwhile, the group that has gathered at Shinra Kishitani's apartment realizes that they are on the brink of something life-changing, an event that will throw Ikebukuro into a spiral of confusion. Their anxiety is realized when reports of Celty's head being found in public start to appear all over the news as Kasane Kujiragi begins to make her move.<br>\n<br>\nGone are the brief periods of tranquility as the current turmoil sets the stage for one final performance in this thrilling conclusion to the story of Ikebukuro's finest.<br>\n<br>\n(Source: MAL Rewrite)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20880-WsvmgSdL8lhP.png","datePublished":"2016-01-09","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Mystery","Supernatural"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.9,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"79c82524-1d64-456d-bd5b-7a444696ab1c","tmdb_id":20880,"imdb_id":null,"content_type":"anime","title":"Durarara!! X2 The Third Arc","original_title":"デュラララ!!×２ 結","overview":"<i>The third part of Durarara!!x2</i><br>\n<br>\nAs Mikado Ryuugamine continues to purge the Dollars from within in accordance with his warped sense of justice, Masaomi Kida hopes to bring his friend back to his senses by bringing the Yellow Scarves together once more. Little do they know that a far more dominant force is about to enter their struggle for power, one that their friend Anri Sonohara is all too familiar with.<br>\n<br>\nMeanwhile, the group that has gathered at Shinra Kishitani's apartment realizes that they are on the brink of something life-changing, an event that will throw Ikebukuro into a spiral of confusion. Their anxiety is realized when reports of Celty's head being found in public start to appear all over the news as Kasane Kujiragi begins to make her move.<br>\n<br>\nGone are the brief periods of tranquility as the current turmoil sets the stage for one final performance in this thrilling conclusion to the story of Ikebukuro's finest.<br>\n<br>\n(Source: MAL Rewrite)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20880-WsvmgSdL8lhP.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/20880-iQx5G0gz5n6G.jpg","release_date":null,"first_air_date":"2016-01-09","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Mystery"},{"id":3,"name":"Supernatural"}],"popularity":77357,"vote_average":7.9,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:51:06.854306+00:00","updated_at":"2026-05-02T08:51:06.813+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Shuka"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2016-03-26","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Urban Fantasy"},{"id":2,"name":"Ensemble Cast"},{"id":3,"name":"Gangs"},{"id":4,"name":"Crime"},{"id":5,"name":"Urban"},{"id":6,"name":"Achronological Order"},{"id":7,"name":"Dullahan"},{"id":8,"name":"Anti-Hero"},{"id":9,"name":"Yandere"}],"alternative_titles":null,"videos":[],"watch_pr