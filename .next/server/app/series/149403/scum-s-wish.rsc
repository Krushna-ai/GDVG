10:T484,{"@context":"https://schema.org","@type":"TVSeries","name":"Scum's Wish","description":"Hanabi has loved her older friend Narumi for years, but she’s still in high school and not only is Narumi now her new homeroom teacher, he’s also clearly in love with the music teacher, Akane. And as awkward as being the unwanted third in a romantic triangle can be, things become even more twisted for Hanabi when she learns that another student, Mugi, is in love with Akane. That leads to a strange idea: since the ones that Mugi and Hanabi are in love with aren’t available, the two unrequited thirds start to explore the idea of becoming each other’s substitute surrogate relationship. It’s not about romance, of course. Just sex and convenience.<br>\n<br>\n(Source: Sentai Filmworks)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21701-j81oh6WCNlsQ.jpg","datePublished":"2017-01-13","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Ecchi","Psychological","Romance"],"aggregateRating":{"@type":"AggregateRating","ratingValue":6.8,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"a779bbd5-ec94-475e-ac7f-85a8919eaf50","tmdb_id":21701,"imdb_id":null,"content_type":"anime","title":"Scum's Wish","original_title":"クズの本懐","overview":"Hanabi has loved her older friend Narumi for years, but she’s still in high school and not only is Narumi now her new homeroom teacher, he’s also clearly in love with the music teacher, Akane. And as awkward as being the unwanted third in a romantic triangle can be, things become even more twisted for Hanabi when she learns that another student, Mugi, is in love with Akane. That leads to a strange idea: since the ones that Mugi and Hanabi are in love with aren’t available, the two unrequited thirds start to explore the idea of becoming each other’s substitute surrogate relationship. It’s not about romance, of course. Just sex and convenience.<br>\n<br>\n(Source: Sentai Filmworks)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21701-j81oh6WCNlsQ.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21701-0YTCNADc8mzB.jpg","release_date":null,"first_air_date":"2017-01-13","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Ecchi"},{"id":3,"name":"Psychological"},{"id":4,"name":"Romance"}],"popularity":173372,"vote_average":6.8,"vote_count":null,"runtime":23,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:49:07.759035+00:00","updated_at":"2026-05-02T08:49:07.715+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Lerche"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2017-03-31","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Love Triangle"},{"id":2,"name":"Fake Relationship"},{"id":3,"name":"Coming of Age"},{"id":4,"name":"Heterosexual"},{"id":5,"name":"School"},{"id":6,"name":"Female Protagonist"},{"id":7,"name":"Age Gap"},{"id":8,"name":"Bisexual"},{"id":9,"name":"Philosophy"},{"id":10,"name":"Nudity"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:49:07.759035+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":32949,"anilist_id":21701},"social_ids":{"mal":"https://myanimelist.net/anime/32949","anilist":"https://anilist.co/anime/21701"},"gdvg_id":149403,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":