10:T4e1,{"@context":"https://schema.org","@type":"TVSeries","name":"The Girl I Like Forgot Her Glasses","description":"With the new school year comes a new homeroom, new classmates, and a new desk for the timid Komura. But any trepidation he might've felt quickly dissipates when he catches sight of Mie, his new seat neighbor. Apt to quietly blurt out the most random things, the quirky Mie wears thick glasses that accentuate her lovely eyes, making Komura’s heart skip a beat!<br>\n<br>\nUnfortunately, Mie is pathologically forgetful and can never seem to remember to bring her glasses to class. It's not all bad, though! Her resulting squinty, mean-girl face sends Komura’s heart into overdrive too! While Komura is keen to help out and share his textbooks with Mie, will his heart give out from the almost daily strain of being up close and personal with his crush?!<br>\n<br>\n(Source: Square Enix)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx160188-4RvYLaru3vKj.jpg","datePublished":"2023-07-04","numberOfEpisodes":13,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Comedy","Romance"],"aggregateRating":{"@type":"AggregateRating","ratingValue":6.8,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"15a9ee7e-5efc-4d17-9393-45555c041d73","tmdb_id":160188,"imdb_id":null,"content_type":"anime","title":"The Girl I Like Forgot Her Glasses","original_title":"好きな子がめがねを忘れた","overview":"With the new school year comes a new homeroom, new classmates, and a new desk for the timid Komura. But any trepidation he might've felt quickly dissipates when he catches sight of Mie, his new seat neighbor. Apt to quietly blurt out the most random things, the quirky Mie wears thick glasses that accentuate her lovely eyes, making Komura’s heart skip a beat!<br>\n<br>\nUnfortunately, Mie is pathologically forgetful and can never seem to remember to bring her glasses to class. It's not all bad, though! Her resulting squinty, mean-girl face sends Komura’s heart into overdrive too! While Komura is keen to help out and share his textbooks with Mie, will his heart give out from the almost daily strain of being up close and personal with his crush?!<br>\n<br>\n(Source: Square Enix)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx160188-4RvYLaru3vKj.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/160188-przLdIsscRsD.jpg","release_date":null,"first_air_date":"2023-07-04","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Romance"}],"popularity":78709,"vote_average":6.8,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":13,"created_at":"2026-05-02T08:51:05.212647+00:00","updated_at":"2026-05-02T08:51:05.17+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"GoHands"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2023-09-26","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Primarily Teen Cast"},{"id":2,"name":"Heterosexual"},{"id":3,"name":"School"},{"id":4,"name":"Male Protagonist"},{"id":5,"name":"Disability"},{"id":6,"name":"CGI"},{"id":7,"name":"Iyashikei"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:51:05.212647+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":54234,"anilist_id":160188},"social_ids":{"mal":"https://myanimelist.net/anime/54234","anilist":"https://anilist.co/anime/16