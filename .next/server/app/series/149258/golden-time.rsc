10:T4ab,{"@context":"https://schema.org","@type":"TVSeries","name":"Golden Time","description":"Due to a tragic accident, Banri Tada is struck with amnesia, dissolving the memories of his hometown and past. However, after befriending Mitsuo Yanagisawa, he decides to move on and begin a new life at law school in Tokyo. But just as he is beginning to adjust to his college life, the beautiful Kouko Kaga dramatically barges into Banri's life, and their chance meeting marks the beginning of an unforgettable year.<br>\n<br>\nAfter having a glimpse of college life, Banri learns that he is in a new place and a new world—a place where he can be reborn, to have new friends, fall in love, makes mistakes and grow. And as he begins to discover who he was, the path he has chosen leads him towards a blindingly bright life that he will never want to forget.\n","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx17895-M8yjOyMxHf5X.jpg","datePublished":"2013-10-04","numberOfEpisodes":24,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Romance"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.5,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"ca64f707-d986-415e-bbe8-2e55f007dc35","tmdb_id":17895,"imdb_id":null,"content_type":"anime","title":"Golden Time","original_title":"ゴールデンタイム","overview":"Due to a tragic accident, Banri Tada is struck with amnesia, dissolving the memories of his hometown and past. However, after befriending Mitsuo Yanagisawa, he decides to move on and begin a new life at law school in Tokyo. But just as he is beginning to adjust to his college life, the beautiful Kouko Kaga dramatically barges into Banri's life, and their chance meeting marks the beginning of an unforgettable year.<br>\n<br>\nAfter having a glimpse of college life, Banri learns that he is in a new place and a new world—a place where he can be reborn, to have new friends, fall in love, makes mistakes and grow. And as he begins to discover who he was, the path he has chosen leads him towards a blindingly bright life that he will never want to forget.\n","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx17895-M8yjOyMxHf5X.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/17895.jpg","release_date":null,"first_air_date":"2013-10-04","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Romance"}],"popularity":247087,"vote_average":7.5,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":24,"created_at":"2026-05-02T08:45:18.891389+00:00","updated_at":"2026-05-02T08:45:18.844+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"J.C.STAFF"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2014-03-28","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Amnesia"},{"id":2,"name":"College"},{"id":3,"name":"Male Protagonist"},{"id":4,"name":"Love Triangle"},{"id":5,"name":"Primarily Adult Cast"},{"id":6,"name":"Heterosexual"},{"id":7,"name":"Coming of Age"},{"id":8,"name":"Female Protagonist"},{"id":9,"name":"Yandere"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:45:18.891389+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":17895,"anilist_id":17895},"social_ids":{"mal":"https://myanimelist.net/anime/17895","anilist":"https://anilist.co/anime/17895"},"gdvg_id":149258,"wiki_plot":null,"wik