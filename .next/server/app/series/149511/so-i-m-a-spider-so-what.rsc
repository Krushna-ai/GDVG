9:{"metadata":[["$","title","0",{"children":"So I'm a Spider, So What? | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"I, the protagonist, was just an ordinary high school girl, but suddenly I was reincarnated as a spider monster in a fantasy world. Not only that, but I awakened in a dungeon filled with vicious monsters. Armed with only my human knowledge and my overwhelming positivity, I'm forced to use spiderwebs and traps to defeat far stronger monsters just to stay alive... So begins the labyrinth survival story of a girl with incredible mental strength living as one of the lowest-ranked beasts!<br><br>\n\n(Source: Crunchyroll)"}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/series/149511/so-i-m-a-spider-so-what"}],["$","meta","5",{"property":"og:title","content":"So I'm a Spider, So What?"}],["$","meta","6",{"property":"og:description","content":"I, the protagonist, was just an ordinary high school girl, but suddenly I was reincarnated as a spider monster in a fantasy world. Not only that, but I awakened in a dungeon filled with vicious monsters. Armed with only my human knowledge and my overwhelming positivity, I'm forced to use spiderwebs and traps to defeat far stronger monsters just to stay alive... So begins the labyrinth survival story of a girl with incredible mental strength living as one of the lowest-ranked beasts!<br><br>\n\n(Source: Crunchyroll)"}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/series/149511/so-i-m-a-spider-so-what"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx103632-2wsy9wFUdm1C.jpg"}],["$","meta","9",{"property":"og:type","content":"video.tv_show"}],["$","meta","10",{"nam