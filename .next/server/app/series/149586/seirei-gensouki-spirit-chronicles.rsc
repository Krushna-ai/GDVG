10:T4ee,{"@context":"https://schema.org","@type":"TVSeries","name":"Seirei Gensouki: Spirit Chronicles","description":"His past life and current life are intersecting--a boy with memories of two lives faces his destiny! After his mother was killed at an early age, the orphaned Rio fought his hardest to survive in the slums. One day, he awakens to the memories of Haruto Amakawa, who died in an accident while dreaming of being reunited with his childhood friend, and Rio realizing he has reincarnated in a world of swords and sorcery. Not only that, but after helping stop an attempt to kidnap a princess that he stumbled upon, he finds himself enrolled in a famous school where the children of the nobility gather… As Rio attempts to rise up from the bottom of a hierarchical society, he will have new encounters and say many goodbyes, as he fights to overcome fate.<br>\n<br>\n(Source: Crunchyroll)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx126546-Jujx9OvKxLzA.jpg","datePublished":"2021-07-06","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Drama","Fantasy","Romance"],"aggregateRating":{"@type":"AggregateRating","ratingValue":6.9,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"5f2e60d0-93e0-4da2-9a10-62739bc6e54d","tmdb_id":126546,"imdb_id":null,"content_type":"anime","title":"Seirei Gensouki: Spirit Chronicles","original_title":"精霊幻想記","overview":"His past life and current life are intersecting--a boy with memories of two lives faces his destiny! After his mother was killed at an early age, the orphaned Rio fought his hardest to survive in the slums. One day, he awakens to the memories of Haruto Amakawa, who died in an accident while dreaming of being reunited with his childhood friend, and Rio realizing he has reincarnated in a world of swords and sorcery. Not only that, but after helping stop an attempt to kidnap a princess that he stumbled upon, he finds himself enrolled in a famous school where the children of the nobility gather… As Rio attempts to rise up from the bottom of a hierarchical society, he will have new encounters and say many goodbyes, as he fights to overcome fate.<br>\n<br>\n(Source: Crunchyroll)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx126546-Jujx9OvKxLzA.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/126546-eSjc83C90h24.jpg","release_date":null,"first_air_date":"2021-07-06","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Drama"},{"id":3,"name":"Fantasy"},{"id":4,"name":"Romance"}],"popularity":125170,"vote_average":6.9,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:49:47.892933+00:00","updated_at":"2026-05-02T08:49:47.847+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"TMS Entertainment"},{"name":"WAO World"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2021-09-21","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Isekai"},{"id":2,"name":"Male Protagonist"},{"id":3,"name":"Magic"},{"id":4,"name":"Reincarnation"},{"id":5,"name":"Medieval"},{"id":6,"name":"Female Harem"},{"id":7,"name":"Swordplay"},{"id":8,"name":"Heterosexual"},{"id":9,"name":"Kemonomimi"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:49:47.892933+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"exter