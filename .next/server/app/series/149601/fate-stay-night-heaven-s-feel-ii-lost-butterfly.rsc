10:T4e0,{"@context":"https://schema.org","@type":"TVSeries","name":"Fate/stay night [Heaven's Feel] II. lost butterfly","description":"The second film in a trilogy adaptation of the 3rd route of the popular visual novel: Fate/stay night.<br>\n<br>\nShirou Emiya made his choice: to keep fighting, and to protect Sakura Matou. Due to the participation of Zouken Matou in the Holy Grail War, and his summoning of the Servant True Assassin, things begin to distort, steadily worsening day by day. Resolved to protect Sakura and not betray her, Shirou refuses to leave the battle. While Sakura worries about Shirou, she also finds herself entangled in her own fate as a mage. However, their fervent wishes are about be crushed by the mysterious black shadow that covers the city, killing Masters and Servants one by one…<br>\n<br>\n(Source: Aniplex of America)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21718-Hjj26Sapx1bd.jpg","datePublished":"2019-01-12","numberOfEpisodes":1,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Fantasy","Psychological","Romance","Supernatural","Thriller"],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.4,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"df9b3290-cfad-4bcb-b2aa-c0cfdabfcba7","tmdb_id":21718,"imdb_id":null,"content_type":"anime","title":"Fate/stay night [Heaven's Feel] II. lost butterfly","original_title":"Fate/stay night[Heaven's Feel] ⅠⅠ.lost butterfly","overview":"The second film in a trilogy adaptation of the 3rd route of the popular visual novel: Fate/stay night.<br>\n<br>\nShirou Emiya made his choice: to keep fighting, and to protect Sakura Matou. Due to the participation of Zouken Matou in the Holy Grail War, and his summoning of the Servant True Assassin, things begin to distort, steadily worsening day by day. Resolved to protect Sakura and not betray her, Shirou refuses to leave the battle. While Sakura worries about Shirou, she also finds herself entangled in her own fate as a mage. However, their fervent wishes are about be crushed by the mysterious black shadow that covers the city, killing Masters and Servants one by one…<br>\n<br>\n(Source: Aniplex of America)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21718-Hjj26Sapx1bd.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21718-7NXra2yezc9T.jpg","release_date":null,"first_air_date":"2019-01-12","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Fantasy"},{"id":3,"name":"Psychological"},{"id":4,"name":"Romance"},{"id":5,"name":"Supernatural"},{"id":6,"name":"Thriller"}],"popularity":123483,"vote_average":8.4,"vote_count":null,"runtime":117,"number_of_seasons":null,"number_of_episodes":1,"created_at":"2026-05-02T08:49:50.401789+00:00","updated_at":"2026-05-02T08:49:50.357+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"ufotable"},{"name":"ufotable"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2019-01-12","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Magic"},{"id":2,"name":"Urban Fantasy"},{"id":3,"name":"Battle Royale"},{"id":4,"name":"Gore"},{"id":5,"name":"Female Protagonist"},{"id":6,"name":"Found Family"},{"id":7,"name":"School"},{"id":8,"name":"Male Protagonist"},{"id":9,"name":"Super Power"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:49:50.401789+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommen