10:T5c3,{"@context":"https://schema.org","@type":"TVSeries","name":"Doukyuusei -Classmates-","description":"Sajou is an honor student with perfect scores in every subject on his high school entrance exam. Kusakabe plays guitar in his band that performs at live events and is popular among the girls. These boys would have never crossed paths. But one day Kusakabe offers to help Sajou prepare for their upcoming chorus festival and the two begin to talk. As the two meet after school, they bond through songs and begin to harmonize as their hearts beat together.<br>\n<br>\nIt starts out slowly but soon their feelings for one another grow and suddenly they both realize that they are in love. Kusakabe's emotions are frivolous, pure and direct causing Sajou to hesitate at first, but he gradually opens his heart. The boys learn about each other, as well as themselves, as they support one another during this difficult time in their youth.<br>\n<br>\nAs the time to start thinking about their futures approaches, what do these young men find as they try to move forward...<br>\n<br>\n(Source: Aniplex of America)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/nx21096-1wIOxpjtXb7J.jpg","datePublished":"2016-02-20","numberOfEpisodes":1,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Music","Romance","Slice of Life"],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.1,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"c4b7584d-3d2d-4041-bc1f-301a79155931","tmdb_id":21096,"imdb_id":null,"content_type":"anime","title":"Doukyuusei -Classmates-","original_title":"同級生","overview":"Sajou is an honor student with perfect scores in every subject on his high school entrance exam. Kusakabe plays guitar in his band that performs at live events and is popular among the girls. These boys would have never crossed paths. But one day Kusakabe offers to help Sajou prepare for their upcoming chorus festival and the two begin to talk. As the two meet after school, they bond through songs and begin to harmonize as their hearts beat together.<br>\n<br>\nIt starts out slowly but soon their feelings for one another grow and suddenly they both realize that they are in love. Kusakabe's emotions are frivolous, pure and direct causing Sajou to hesitate at first, but he gradually opens his heart. The boys learn about each other, as well as themselves, as they support one another during this difficult time in their youth.<br>\n<br>\nAs the time to start thinking about their futures approaches, what do these young men find as they try to move forward...<br>\n<br>\n(Source: Aniplex of America)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/nx21096-1wIOxpjtXb7J.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21096-Rs4Rtz03qbO3.jpg","release_date":null,"first_air_date":"2016-02-20","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Music"},{"id":3,"name":"Romance"},{"id":4,"name":"Slice of Life"}],"popularity":80580,"vote_average":8.1,"vote_count":null,"runtime":60,"number_of_seasons":null,"number_of_episodes":1,"created_at":"2026-05-02T08:51:00.730072+00:00","updated_at":"2026-05-02T08:51:00.69+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"A-1 Pictures"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2016-02-20","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Boys' Love"},{"id":2,"name":"Coming of Age"},{"id":3,"name":"LGBTQ+ Themes"},{"id":4,"name":"Primarily Male Cast"},{"id":5,"name":"Male Protagonist"},{"id":6,"name":"School"},{"id":7,"name":"Primarily Teen Cast"},{"id":8,"name":"School Club"},{"id":9,"name":"Cute Bo