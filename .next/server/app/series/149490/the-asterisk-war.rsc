10:T5ac,{"@context":"https://schema.org","@type":"TVSeries","name":"The Asterisk War","description":"Invertia (meteor storm)… an unprecedented disaster that struck the world during the 20th century.<br>\n<br>\nBecause of this disaster, numerous cities around the world were destroyed. However, within the meteor, an unknown element called mana (the all-encompassing element), was discovered, which allowed human technology to make rapid strides.<br>\n<br>\nThis also gave rise to a new species of human born with unique skills – the Star Pulse Generation (Genestella).<br>\n<br>\nThe setting for the world’s greatest comprehensive battle spectacle, the Festas (Star Warrior Festivals), is an academy city above the water surrounded by six academies called Rikka also commonly known as Asterisk. Having transferred into Seidoukan Academy in order to fulfill his own wish, scholarship student Ayato Amagiri swears he too will fight in this city.<br>\n<br>\nBurning souls race…<br>\n<br>\nThe curtain rises on this school battle spectacle!<br>\n<br>\n(Source: Crunchyroll)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21131-sh1HBXuF6qHH.jpg","datePublished":"2015-10-03","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Comedy","Ecchi","Fantasy","Romance","Sci-Fi"],"aggregateRating":{"@type":"AggregateRating","ratingValue":6.5,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"e5316389-a35f-4c8f-a9b8-e25ab4884b7b","tmdb_id":21131,"imdb_id":null,"content_type":"anime","title":"The Asterisk War","original_title":"学戦都市アスタリスク","overview":"Invertia (meteor storm)… an unprecedented disaster that struck the world during the 20th century.<br>\n<br>\nBecause of this disaster, numerous cities around the world were destroyed. However, within the meteor, an unknown element called mana (the all-encompassing element), was discovered, which allowed human technology to make rapid strides.<br>\n<br>\nThis also gave rise to a new species of human born with unique skills – the Star Pulse Generation (Genestella).<br>\n<br>\nThe setting for the world’s greatest comprehensive battle spectacle, the Festas (Star Warrior Festivals), is an academy city above the water surrounded by six academies called Rikka also commonly known as Asterisk. Having transferred into Seidoukan Academy in order to fulfill his own wish, scholarship student Ayato Amagiri swears he too will fight in this city.<br>\n<br>\nBurning souls race…<br>\n<br>\nThe curtain rises on this school battle spectacle!<br>\n<br>\n(Source: Crunchyroll)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21131-sh1HBXuF6qHH.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21131-NuvCaPakVhMS.jpg","release_date":null,"first_air_date":"2015-10-03","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Comedy"},{"id":3,"name":"Ecchi"},{"id":4,"name":"Fantasy"},{"id":5,"name":"Romance"},{"id":6,"name":"Sci-Fi"}],"popularity":147362,"vote_average":6.5,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:49:27.321869+00:00","updated_at":"2026-05-02T08:49:27.277+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"A-1 Pictures"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2015-12-19","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Male Protagonist"},{"id":2,"name":"Female Harem"},{"id":3,"name":"Magic"},{"id":4,"name":"Swordplay"},{"id":5,"name":"School"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":