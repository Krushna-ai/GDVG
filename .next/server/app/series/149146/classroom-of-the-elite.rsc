10:T487,{"@context":"https://schema.org","@type":"TVSeries","name":"Classroom of the Elite","description":"Koudo Ikusei Senior High School is a leading school with state-of-the-art facilities. The students there have the freedom to wear any hairstyle and bring any personal effects they desire. Koudo Ikusei is like a utopia, but the truth is that only the most superior students receive favorable treatment.<br><br>\n\nKiyotaka Ayanokouji is a student of D-class, which is where the school dumps its \"inferior\" students in order to ridicule them. For a certain reason, Kiyotaka was careless on his entrance examination, and was put in D-class. After meeting Suzune Horikita and Kikyou Kushida, two other students in his class, Kiyotaka's situation begins to change. <br><br>\n(Source: Anime News Network, edited)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx98659-WNyPLIZDpGGY.jpg","datePublished":"2017-07-12","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Psychological"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.6,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"d620f8cb-cfd6-49c6-a08e-35035c6044ca","tmdb_id":98659,"imdb_id":null,"content_type":"anime","title":"Classroom of the Elite","original_title":"ようこそ実力至上主義の教室へ","overview":"Koudo Ikusei Senior High School is a leading school with state-of-the-art facilities. The students there have the freedom to wear any hairstyle and bring any personal effects they desire. Koudo Ikusei is like a utopia, but the truth is that only the most superior students receive favorable treatment.<br><br>\n\nKiyotaka Ayanokouji is a student of D-class, which is where the school dumps its \"inferior\" students in order to ridicule them. For a certain reason, Kiyotaka was careless on his entrance examination, and was put in D-class. After meeting Suzune Horikita and Kikyou Kushida, two other students in his class, Kiyotaka's situation begins to change. <br><br>\n(Source: Anime News Network, edited)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx98659-WNyPLIZDpGGY.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/98659-u46B5RCNl9il.jpg","release_date":null,"first_air_date":"2017-07-12","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Psychological"}],"popularity":410166,"vote_average":7.6,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:44:54.698243+00:00","updated_at":"2026-05-02T08:44:54.656+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Lerche"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2017-09-27","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"School"},{"id":2,"name":"Ensemble Cast"},{"id":3,"name":"Primarily Teen Cast"},{"id":4,"name":"Male Protagonist"},{"id":5,"name":"Survival"},{"id":6,"name":"Kuudere"},{"id":7,"name":"Battle Royale"},{"id":8,"name":"Coming of Age"},{"id":9,"name":"Philosophy"},{"id":10,"name":"Tsundere"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:44:54.698243+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":35507,"anilist_id":98659},"social_ids":{"mal":"https://myanimelist.net/anime/35507","anilist":"https://anilist.co/anime/98659"},"gdvg_id":149146,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_g