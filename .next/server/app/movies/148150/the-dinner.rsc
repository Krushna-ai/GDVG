":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/bhGsvonAXMNbVIQ7CAA9YTrVQzz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":2500,"height":1406,"file_path":"/mZQbtLpzkxehUSEHen13EHgbJHl.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166}]},"enriched_at":"2026-04-16T02:56:46.32+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":102,"tagline":"La fuga está servida.","homepage":"","overview":"España, 15 de abril de 1939. Concluida la Guerra Civil, y con intención de celebrar su victoria, el general Franco asiste con sus generales a una cena en el hotel Palace."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"The Dinner","runtime":106,"tagline":"","homepage":"","overview":"Spain, April 15, 1939. With the Civil War concluded, and with the intention of celebrating his victory, General Franco attends a dinner with his generals at the Palace Hotel."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"La cena","runtime":106,"tagline":"","homepage":"","overview":"Hiszpania, 15 kwietnia 1939 r. Po zakończeniu wojny domowej generał Franco udaje się na kolację ze swoimi generałami do Palace Hotel, aby uczcić swoje zwycięstwo."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Dos semanas después de acabar la Guerra Civil, Franco solicita una cena de celebración en el Hotel Palace. Un joven teniente, un maître meticuloso y un grupo de prisioneros republicanos expertos en cocina, deben preparar un banquete impecable en tiempo récord. Todo parece ir sobre ruedas, pero en la cocina se trama algo más que un menú. Adaptación de la obra de José Luis Alonso de Santos."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[{"id":1896,"adult":false,"title":"Salvador (Puig Antich)","video":false,"overview":"The story of Salvador Puig Antich, one of the last political prisoners to be executed under Franco's Fascist State in 1974.","genre_ids":[18,36],"popularity":0.5348,"vote_count":63,"poster_path":"/sckxel7UsvGbTc7DOJqLWy39SE1.jpg","release_date":"2006-05-23","vote_average":6.833,"backdrop_path":"/gygtjTTi3O9uDN5BevYAPWeVi2S.jpg","original_title":"Salvador (Puig Antich)","original_language":"ca"},{"id":860703,"adult":false,"title":"Antonio García-Trevijano: Transición e historia política de España en primera persona","video":false,"overview":"Spanish jurist and republican thinker Antonio García-Trevijano (1927-2018) expounds his political thought and reflects on the recent political history of Spain.","genre_ids":[99,36],"popularity":0.284,"vote_count":2,"poster_path":"/4Q5HvaUlnwAOHRTim52saZkWFBE.jpg","release_date":"2021-07-26","vote_average":4,"backdrop_path":"/p2WD7yqDrp8InwWDu8eCM2lrINJ.jpg","original_title":"Antonio García-Trevijano: Transición e historia política de España en primera persona","original_language":"es"},{"id":24022,"adult":false,"title":"El Calentito","video":false,"overview":"Early 80's, Sara is a good-family girl, she has never been with a man, does not drinks, does not take drugs. Following her love, she enters in \"El Calentito\" a bar where the group \"las Siux\" is singing.","genre_ids":[35,18,36],"popularity":0.2685,"vote_count":23,"poster_path":"/rdYp5AvCfQALUDvJ7kJPyarpg8t.jpg","release_date":"2005-06-24","vote_average":4.8,"backdrop_path":"/5IGpRxs9faOKmKMRa5ryXTQsy6U.jpg","original_title":"El Calentito","original_language":"es"},{"id":683398,"adult":false,"title":"The Most Dangerous Man in Europe: Otto Skorzeny's After War","video":false,"overview":"Waffen-SS officer Otto Skorzeny (1908-75) became famous for his participation in daring military actions during World War II. In 1947 he was judged and imprisoned, but he escaped less than a year later and found a safe haven in Spain, ruled with an iron hand by General Francisco Franco. What did he do during the many years he spent there?","genre_ids":[99,36],"popularity":0.5972,"vote_count":13,"poster_path":"/4ftSXSlgZvp4IDuOmX7Px40q60X.jpg","release_date":"2020-01-29","vote_average":6.7,"backdrop_path":"/mopiltTJnds8foyeXVdte9LmJpr.jpg","original_title":"El hombre más peligroso de Europa: Otto Skorzeny en España","original_language":"es"},{"id":38884,"adult":false,"title":"Land and Freedom","video":false,"overview":"David Carr is a British Communist who is unemployed. In 1936, when the Spanish Civil War begins, he decides to fight for the Republican side, a coalition of liberals, communists and anarchists, so he joins the POUM militia and witnesses firsthand the betrayal of the Spanish revolution by Stalin's followers and Moscow's orders.","genre_ids":[10752,18,36],"popularity":0.7323,"vote_count":291,"poster_path":"/u5QRqW0vFYMHFzeQJ4oFgJtu5Xp.jpg","release_date":"1995-04-07","vote_average":7.3,"backdrop_path":"/nKGVLehRRJt2UK2Hn9JvNAzd4C6.jpg","original_title":"Land and Freedom","original_language":"en"},{"id":888492,"adult":false,"title":"A Forbidden Orange","video":false,"overview":"Spain, 1970s. A Clockwork Orange, a film considered by critics and audiences as one of the best works in the history of cinema, directed by Stanley Kubrick and released in 1971, was banned by the strict Franco government. However, the film was finally premiered, without going through censorship, during the 20th edition of the Seminci, the Valladolid Film Festival, on April 24, 1975. How was this possible?","genre_ids":[99,36],"popularity":0.4687,"vote_count":14,"poster_path":"/gB13mXSI18xbNDVGCXyBPGAuoqA.jpg","release_date":"2021-10-23","vote_average":5.393,"backdrop_path":"/1sSdTdzQDisjN8Tz5DPis19JKSL.jpg","original_title":"La naranja prohibida","original_language":"es"},{"id":1304681,"adult":false,"title":"Exorcismo: The Transgressive Legacy of Clasificada “S”","video":false,"overview":"Spain, 1975. Franco's death opens the door to the possibility of uncensored cinema. After two years of relaxed censorship, it is abolished in 1977, and the “S” rating is created to protect viewers from films that may “offend their sensibilities.”","genre_ids":[99,36],"popularity":0.9245,"vote_count":5,"poster_path":"/2xeTx0tIpR11YhnIBLqkBtTyE7G.jpg","release_date":"2024-10-03","vote_average":6.8,"backdrop_path":"/jIMjnNUFfq1BIwzbtIiFa1OMzZ6.jpg","original_title":"Exorcismo: The Transgressive Legacy of Clasificada “S”","original_language":"en"},{"id":881923,"adult":false,"title":"Susana y el sexo","video":false,"overview":"The story of iconic Spanish artist Susana Estrada's struggle against censorship and sexual repression during the turbulent years following the death of dictator Francisco Franco.","genre_ids":[99,36,10770],"popularity":0.3206,"vote_count":3,"poster_path":"/l4N358wv9h3x2lh59pSV2dkuAVm.jpg","release_date":"2021-10-06","vote_average":6.5,"backdrop_path":"/6DHwT3KFsZCBh9v40Cf6hewx0sr.jpg","original_title":"Susana y el sexo","original_language":"es"},{"id":50004,"adult":false,"title":"Paper Birds","video":false,"overview":"At the end of the Spanish Civil War, the members of a group of vaudeville performers have been stripped of everything: all they have left is hunger and the instinct to survive. Day after day, agonizingly, lost and helpless between the victors and the vanquished, the musician Jorge, the ventriloquist Enrique, the couplet singer Rocío and the orphan Miguel search tirelessly for something to eat and a safe place to live.","genre_ids":[18,36,53],"popularity":0.5255,"vote_count":34,"poster_path":"/xgdLPEiHr4HqtNYuzBhmY9nE4Aa.jpg","release_date":"2010-03-12","vote_average":6.6,"backdrop_path":"/9O5n17sMzUuFSkqyhzvWqvlFe6C.jpg","original_title":"Pájaros de papel","original_language":"es"},{"id":326176,"adult":false,"title":"Under the Bed","video":false,"overview":"Every night, Martín's socks disappear under his bed.","genre_ids":[35,12,14],"popularity":0.1535,"vote_count":2,"poster_path":"/i8Zun4466D6re3VZ5uw9DXx6K54.jpg","release_date":"2011-01-01","vote_average":4.5,"backdrop_path":"/vK233TCoo9xhDCxkWjUnNAkCmUd.jpg","original_title":"Ohe azpiko zera","original_language":"eu"},{"id":85462,"adult":false,"title":"A War in Hollywood","video":false,"overview":"The Spanish Civil War (1936-1939) caused a great impression on the lives of most of the American artists of that era, so many movies were made in Hollywood about it. The final defeat of the Spanish Republic left an open wound in the hearts of those who sympathized with its cause. The eventful life of screenwriter Alvah Bessie (1904-1985), one of the Hollywood Ten, serves to analyze this sadness, the tragedy of Spain and its consequences.","genre_ids":[99,36],"popularity":1.8167,"vote_count":5,"poster_path":"/ncOTBmOqaa6M8UK99PFuw0unOMb.jpg","release_date":"2009-10-16","vote_average":6.8,"backdrop_path":"/z1a5ccd6H86KODwSLIkKoPYnfpA.jpg","original_title":"Hollywood contra Franco","original_language":"es"},{"id":566970,"adult":false,"title":"Stepping Into the Boundary","video":false,"overview":"Donostia-San Sebastián, Basque Country, Spain, 2011. Maider, a filmmaker, moves to the very same flat where pedadogist Elbira Zipitria Irastorza (1906-1982) clandestinely established the first ikastola, a Basque school, under the harsh regime of dictator Francisco Franco. Despite of her pioneering work, developed throughout thirty years, her story is not well known, so Maider, intrigued, begins to research…","genre_ids":[99,36],"popularity":0.1385,"vote_count":0,"poster_path":"/smsVisTO8YuPG84RbbEAuCxst9n.jpg","release_date":"2019-05-24","vote_average":0,"backdrop_path":"/bYyuc8PKRUapeLV6DVPMX6jWvjQ.jpg","original_title":"Muga deitzen da pausoa","original_language":"eu"},{"id":358783,"adult":false,"title":"Operación Gónada","video":false,"overview":"","genre_ids":[35],"popularity":1.6496,"vote_count":0,"poster_path":"/zOdVibyHv0Q7cIM3KDGqSThYWA9.jpg","release_date":"2000-03-17","vote_average":0,"backdrop_path":null,"original_title":"Operación Gónada","original_language":"es"},{"id":79745,"adult":false,"title":"The Sleeping Voice","video":false,"overview":"Finished the Spanish Civil War in April 1939, in November 1940, while Spain is being crushed by the ruthless boot of dictator Franco, Pepita travels from rural Córdoba to Madrid to be near her sister Hortensia, who is seven months pregnant and imprisoned, haunted by the shadow of a death sentence.","genre_ids":[18,36],"popularity":0.4043,"vote_count":105,"poster_path":"/8lZkChW71KsJlhypnsbKwaYP05d.jpg","release_date":"2011-10-21","vote_average":6.638,"backdrop_path":"/3Sa0aM3gTStFkjkhNaqk2E9KLCq.jpg","original_title":"La voz dormida","original_language":"es"},{"id":64834,"adult":false,"title":"Operation Ogre","video":false,"overview":"Spain, 1973. Dictator Francisco Franco has ruled the country since 1939 with an iron fist; but he is now a very old and sick man. The future of the weakened regime is in danger. Admiral Carrero Blanco is his natural successor. The Basque terrorist gang ETA decides that he must die to prevent the dictatorship from continuing.","genre_ids":[18,36,53],"popularity":1.8034,"vote_count":43,"poster_path":"/iqxC1i7nnCPZM9icd2WeMV0Bpgs.jpg","release_date":"1979-09-28","vote_average":6.9,"backdrop_path":"/sDhDeXl6si50rJuSjkNKklrzp1M.jpg","original_title":"Operación Ogro","original_language":"es"},{"id":1178349,"adult":false,"title":"Uncensored Women","video":false,"overview":"The story of a group of actresses who, in the Spain of the seventies, and in the midst of the democratic Transition, decided to appear nude in the films of that time of radical political change, defying the rigid and deeply rooted social rules.","genre_ids":[99,36],"popularity":0.2386,"vote_count":0,"poster_path":"/nIkDLoFvzA8boapSWwE43XRn3AY.jpg","release_date":"2022-12-21","vote_average":0,"backdrop_path":"/rN3A0kprkXVn8rdtLAiReX056Wy.jpg","original_title":"Mujeres sin censura","original_language":"es"},{"id":575544,"adult":false,"title":"Magnicidios Poe","video":false,"overview":"The sarcastic account of the assassination of five Spanish politicians between 1870 and 1973 is mixed with the narration of five short stories by Edgar Allan Poe illustrated by five skillful pencil artists. A documentary, a video essay, a collage, a provocative experiment where various pop culture figures and icons perform unexpected cameos. The macabre joke of a jester. Never more.","genre_ids":[99,35,16],"popularity":0.1279,"vote_count":1,"poster_path":"/xek9Ddwy4nX7Nu5ssEL70UPnf0W.jpg","release_date":"2017-01-01","vote_average":2,"backdrop_path":"/mcTNlglcM0rdVcn5P8dcJwVzjtj.jpg","original_title":"Magnicidios Poe","original_language":"es"},{"id":99883,"adult":false,"title":"The Wheelchair","video":false,"overview":"Don Anselmo, a retired old man, decides to buy a motorized disabled stroller since all his pensioner friends own one. His family strongly refuses him to purchase the vehicle, so don Anselmo decides to take extreme measures to achieve his goal…","genre_ids":[35],"popularity":0.1632,"vote_count":54,"poster_path":"/jDh5pJ4EnIEwR9JS7DU0Mt47p6P.jpg","release_date":"1960-11-03","vote_average":6.806,"backdrop_path":"/mJ6SbrfWwviKF1NGp2z89Px7Zij.jpg","original_title":"El cochecito","original_language":"es"},{"id":737411,"adult":false,"title":"The Europeans","video":false,"overview":"Spain, 1958. Miguel and Antonio, single and in their thirties, go on a trip to Ibiza, attracted by the European sexual myth and the illusion of freedom. But on the island nothing will be as they expected.","genre_ids":[35],"popularity":0.1422,"vote_count":5,"poster_path":"/4lMCQKbjDTIqZley9DXUhlUPANg.jpg","release_date":"2020-11-20","vote_average":5.4,"backdrop_path":"/c6UizSdg1o0CCbwt4jfWD1YSh1A.jpg","original_title":"Los europeos","original_language":"es"},{"id":542921,"adult":false,"title":"While at War","video":false,"overview":"Salamanca, Spain, 1936. In the early days of the military rebellion that began the Spanish Civil War (1936-39), writer Miguel de Unamuno supports the uprising in the hope that the prevailing political chaos will end. But when the confrontation becomes bloody, Unamuno must question his initial position.","genre_ids":[18,36,10752],"popularity":0.6916,"vote_count":302,"poster_path":"/pbuMcrQBXngZS7wMOTKRCmQAjCN.jpg","release_date":"2019-09-27","vote_average":7.063,"backdrop_path":"/ab2Yq3VoDMy0MoamCUcJq3OIzZY.jpg","original_title":"Mientras dure la guerra","original_language":"es"}],"external_ids":{"imdb_id":"tt35657504","twitter_id":null,"facebook_id":null,"wikidata_id":"Q135678444","instagram_id":null,"rotten_tomatoes_id":"m/la_cena"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148150,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AU","release_dates":[{"note":"Europa Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2026-02-22T00:00:00.000Z","certification":""}]},{"iso_3166_1":"ES","release_dates":[{"note":"San Sebastián International Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-09-23T00:00:00.000Z","certification":""},{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-10-17T00:00:00.000Z","certification":"12"},{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-02-13T00:00:00.000Z","certification":""}]},{"iso_3166_1":"PR","release_dates":[{"note":"Fine Arts","type":2,"iso_639_1":"","descriptors":[],"release_date":"2025-11-26T00:00:00.000Z","certification":"NR"}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":"Q5966113","filming_location":null,"narrative_location