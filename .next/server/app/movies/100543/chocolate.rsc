kxibo0APXjaaKanCyW6O9UY.jpg","iso_639_1":"en","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/jl7DBi877DirMSgi4gOZTuSrsSp.jpg","iso_639_1":"en","vote_average":3.334},{"width":923,"height":1385,"file_path":"/g8CBVNFdJOGINQW2KuOvl5NAPS5.jpg","iso_639_1":"en","vote_average":2.542},{"width":804,"height":1206,"file_path":"/iZH7ukYZOcETRanR7GIeiFc5mKZ.jpg","iso_639_1":"de","vote_average":1.75},{"width":1000,"height":1500,"file_path":"/hOsz1Kk6QOegfCbeHbNmxwTPnDI.jpg","iso_639_1":"en","vote_average":0.166},{"width":744,"height":1075,"file_path":"/k0pV6Kkd7rp6TPzlxN1xoItFvCm.jpg","iso_639_1":"pt","vote_average":0.166},{"width":1012,"height":1500,"file_path":"/fsYJbWjg0POyXtFXKwK2f5ulgpt.jpg","iso_639_1":"en","vote_average":0.166},{"width":1000,"height":1500,"file_path":"/fK4GVB1CkwyxPMLRzcjfuORkPTw.jpg","iso_639_1":"th","vote_average":0},{"width":1519,"height":2174,"file_path":"/4fVp5nS4Y3wzf5E9ozatzSM1sNg.jpg","iso_639_1":"hu","vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/umEjgwcWIjWHoxrKTS8QPMMJjDz.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/7djbJvWv6Zoss9Ed9t8Bb7afZel.jpg","iso_639_1":"de","vote_average":3.334},{"width":3840,"height":2160,"file_path":"/keZi70i50VwVn3DRlLcLr99XDFF.jpg","iso_639_1":"en","vote_average":3.334},{"width":3840,"height":2160,"file_path":"/knt6LM6I8AYjUOGgMiQlow936cU.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/xvSLcVif0SqXVefw49vhEggGcoY.jpg","iso_639_1":null,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/5l8qImciNYcjBwZo5QNAGkkB8u5.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/uDp7MAP6W0dqLJ8KxikJNejMdLI.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-02-21T15:24:26.2+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Chocolate","runtime":93,"tagline":"She's sweet but deadly.","homepage":"","overview":"Zen, an autistic teenage girl with powerful martial arts skills, gets money to pay for her sick mother Zin's treatment by seeking out all the people who owe Zin money and making them pay."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Chocolate - Süß und tödlich","runtime":110,"tagline":"Süß und tödlich!","homepage":"","overview":"Als sich die Thailänderin Sin und der Japaner Masashi ineinander verlieben, sind deren verfeindete Gangsterbanden nicht gerade erfreut darüber. Um weiteren Kämpfen aus dem Weg zu gehen, trennen sich die beiden und Sin zieht sich mit der gemeinsamen Tochter Zen zurück. Zen ist zwar Autistin, hat aber ein großes Interesse am Muay Thai und schaut den Schülern einer Muay Thai-Schule regelmäßig beim Training zu. Eines Tages diagnostizieren die Ärzte Krebs bei Sin. Zen findet ein altes Buch, in dem Sin eine Menge Leute aufgelistet hat, die ihr aus vergangenen Tagen noch Geld schuldig geblieben sind. Also macht sich Zen auf, um das Geld für die Behandlung ihrer Mutter einzutreiben. Dank ihrer Muay Thai-Kenntnisse mischt sie die Schuldner ordentlich auf, was alte Feinde wie den Gangster No. 8 auf den Plan ruft. Als die Lage bedrohlich wird, reist auch Masashi aus Japan an und plötzlich ist ein Bandenkrieg in vollem Gange."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Chocolate","runtime":110,"tagline":"Goûtez la fureur","homepage":"","overview":"Jen, jeune fille autiste, possède un don naturel pour les arts martiaux. Elle va ainsi aider sa mère atteinte d'un cancer à récupérer l'argent qu'on lui doit à l'aide d'un carnet où sont consignés les noms des débiteurs...Problème : ils appartiennent tous à une organisation appelée \"numéro 8\" et ne sont pas décidés à coopérer."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Zen - The Warrior Within","runtime":93,"tagline":"","homepage":"","overview":"Zen är en väldigt speciell ung kvinna. Trots att hon är svårt autistisk har hon med hjälp av filmer och TV-spel blivit en mästare på kampsport – kunskaper som kommer väl till pass när maffian hotar hennes mamma. När ryktet sprids om den osannolika brottsbekämparen, skickas den undre världens mest hårdföra krigare för att stoppa Zen för gott."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"A harc szelleme","runtime":89,"tagline":"","homepage":"","overview":"Zen, egy jakuza bérgyilkos, és a thaiföldi maffia főnökének szeretője szerelméből született. A kislány autista, ám rendkívül gyors reflexei vannak. Amikor anyjával egy harcművész iskola közelébe költöznek, Zen elkezdi figyelni az edzéseket, és döbbenetes módon tökéletesen végrehajtja a látott mozdulatokat. Édesanyja időközben beteg lesz, de a kezelésre nincs elég pénzük, habár rengeteg ember tartozik nekik. Zen elhatározza, hogy kamatoztatja frissen szerzett tudását és behajtja a pénzt az adósoktól, hogy megmentse rákbeteg édesanyját."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Chocolate","runtime":90,"tagline":"Ella es dulce pero mortal.","homepage":"http://www.chocolate-movie.com/","overview":"Comienza con una disputa entre dos mafias, una liderada por un yakuza llamado Masashi, y otra liderada por un tailandés sin escrúpulos que se enfrentan por el territorio. Masashi comienza a tener una relacion amorosa con una ayudante de la otra mafia, y al enterarse el jefe tailandés provoca que la pareja se separe y Masashi viaja a Japón, pero fruto de su relación nace una niña Zen,que sufre de autismo. Cuando la niña se convierte en una adolescente, empieza a desarrollar habilidades misteriosas que ve en television y en un entrenamiento de Muay Thai, el cuál empieza a practicar en su casa. Vivendo en la pobreza el primo de Zen encuentra una libreta donde encuentra una lista de personas que le deben dinero a su tia que esta enferma gravemente."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Chocolate - La furia","runtime":93,"tagline":"Assapora il gusto della furia","homepage":"","overview":"Zen è una ragazzina autistica che cresce guardando i film di Bruce Lee e gli studenti di una vicina scuola di arti marziali. Sviluppa riflessi incredibili e una predisposizione per il combattimento a mani nude, assorbendo con facilità estrema ogni tecnica. Sua madre però, ha bisogno di cure, perchè malata di cancro, e Zen e l'amico Moom vanno in cerca di soldi, ma lo scontro con il gangster che ha relegato la madre di Zen a una vita di miserie è inevitabile."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Chocolate","runtime":0,"tagline":"","homepage":"","overview":"Chora na autyzm dziewczyna, posiada zdolność naśladowania wszystkiego co ją otacza. Dzięki temu uczy się sztuk walki, które wykorzystuje by razem z przyjacielem odbierać pieniądze od dłużników ciężko chorej matki."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Chocolate","runtime":92,"tagline":"","homepage":"","overview":"Zen is een jonge autistische vrouw die een fantastische martial arts experte is geworden door het kijken naar televisiebeelden en door naast een Muy Thai school te wonen. Ze is de dochter van Zin, de Thaise vrouw van Yakuza baas Masashi. Zin lijdt aan kanker maar heeft geen geld voor een operatie. Haar dochter Zen besluit hierop een oude Yakuza vete opnieuw leven in te blazen om het geld voor haar moeder te krijgen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Шоколад","runtime":110,"tagline":"","homepage":"","overview":"Зин, в прошлом участвовавшая в междоусобицах соперничающих бандитских группировок и ушедшая из теневого бизнеса из-за любви к японцу, члену Якудзы, вынуждена расстаться с ним, даже не сказав, что беременна. Родив девочку, Зин узнаёт страшный приговор — её дочери Зэн поставлен диагноз — аутизм. Однако по прошествии времени девочка, несмотря на кажущееся отрешение от реального мира, обнаруживает в себе редкий дар интуитивного владения боевыми искусствами. Когда выясняется, что Зин больна раком, Зэн и её единственный близкий друг Моом решили устраивать небольшие представления, чтобы собрать деньги на лечение больной матери Зэн. Однажды Моом случайно находит старые записи в тетради Зин, где перечислялись люди, которые задолжали ей крупные суммы. Не подозревая ещё, что это вовсе не долги за кредиты, выданные в бакалейной лавке, Моом и Зэн отправляются к людям из списка с требованием вернуть долги…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"女拳霸","runtime":0,"tagline":"","homepage":"","overview":"将司（阿部宽 饰）是一个来自日本的黑社会头目，在一次与泰国黑帮的交易冲突中，对方容貌妖艳、身手矫捷的女子成员阿欣（Ammara Siripong 饰）引起了他的注意。在此之后，两人开始交往，然而日本和泰国的帮派冲突却逐渐升级。最终，阿欣为了救心上人而背叛了自己的老大。将司迫于无奈逃回日本，阿欣则留在泰国，独自生下女儿阿珊。阿珊从小患有自闭症，但她却有着非凡的能力，她能迅速记下并掌握复杂的格斗动作。数年过后，成年的阿珊（杰佳·亚宁JeeJaYanin 饰）俨然成长为一个出色的格斗高手。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Chocolate","runtime":0,"tagline":"Ela é doce, mas mortal.","homepage":"","overview":"Zen é uma garota que precisa ajudar sua mãe ao descobrir que ela sofre de câncer. Ao encontrar uma pequena agenda com valores devidos à sua mãe por uma gangue de criminosos, Zen decide ir atrás deles para recuperar o dinheiro. Sendo muito habilidosa em artes marciais, isso não seria uma tarefa difícil para Zen, não fosse o fato de ser autista. Agora, com a ajuda de seu amigo Spider, Zen terá de encontrar forças para enfrentar uma legião de criminosos e salvar sua mãe... Além de sua própria vida."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":110,"tagline":"ครั้งแรกที่โลกจะได้รู้จักออทิสติกอัจฉริยะศิลปะการต่อสู้","homepage":"https://sahamongkolfilm.com/saha-movie/chocolate-movie-2551/","overview":"เด็กพิเศษที่มีแม่กำลังป่วยอย่าง “เซน” ไม่เคยรู้เลยว่าความพยายามทวงสิทธิ์ที่แม่ของเธอพึงได้รับจาก NO.8 หัวหน้าแก๊งค์มาเฟียที่ทรงอิทธิพล ที่สุดของไทย จะเป็นชนวนสำคัญอันนำไปสู่การเผชิญหน้าและปะทะกันระหว่าง NO.8 และมาซาชิ สมาชิกคนสำคัญของแก๊งค์ยากูซ่าจาก ญี่ปุ่นที่พยายามปกป้องเซนและแม่ ทางเดียวที่เซนจะทำได้ในตอนนี้ก็คือการดึงเอาพรสวรรค์ทางด้านการต่อ สู้ที่แฝงเร้นอยู่ในตัวออกมาเพื่อปกป้องแม่ให้ได้"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"チョコレート・ファイター","runtime":93,"tagline":"この蹴りに世界がひれ伏す!!!!!!","homepage":"","overview":"アクションの映像を観ただけで、同じ技を習得できる人並外れた能力を持っている美少女ゼンは、最愛の母が末期の白血病に侵されていることを知る。ゼンは母からすべてを奪ったマフィアに復讐するため、自ら体を張って抗争に身を投じるが、そこで生き別れになっていた父マサシと再会を果たし……。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Duch boje","runtime":110,"tagline":"","homepage":"","overview":"Nový film od tvůrců \"Ong Bak\"! Zen, která se narodila z lásky vraha Yakuzy a jedné nebezpečné krásky, je velmi zvláštní dívkou. Žije odřezána od světa a objeví v sobě vlastnost, která v kořenech změní její život. Tato obzvláštní vlastnost ji umožňuje okamžitě dokonale napodobit jakýkoliv bojovný pohyb, který uvidí. Mezitím dívčina matka onemocní rakovinou, ale přestože jim mnoho mužů dluží, nemají peněz na její léčení. Zen se rozhodne, že pomoci nově získaných schopností sežene peníze od dlužníků a zachrání nemocnou matku. Od této chvíle ji udržuje při životě jen jediná věc - boj. Přestože se narodila jako autistka, pomocí kousku čokolády se dokáže vymanit ze svého vnitřního světa a stát se zápasnicí bojového umění, jakou ještě svět nikdy neviděl."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"שוקולד","runtime":0,"tagline":"","homepage":"","overview":"נערה אוטיסטית עם יכולות באומנות הלחימה התאילנדית מנסה לסדר את חובותייה של אימה הכואבת ע\"י התעמתות עם חברי כנופיה שחייבים לה כסף."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Chocolate","runtime":0,"tagline":"","homepage":"","overview":"Ένα αυτιστικό κορίτσι με εξαιρετικέσ ικανότητες στις πολεμικές τέχνες προσπαθεί να βοηθήσει τη μητέρα της να ξεπληρώσει τα χρέη της και προσπαθεί να εντοπίσει την συμμορία που χρωστάει λεφτά στην οικογένειά της."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Chocolate","runtime":93,"tagline":"Ela é doce, mas mortal.","homepage":"","overview":"Zen é uma garota que precisa ajudar sua mãe ao descobrir que ela sofre de câncer. Ao encontrar uma pequena agenda com valores devidos à sua mãe por uma gangue de criminosos, Zen decide ir atrás deles para recuperar o dinheiro. Sendo muito habilidosa em artes marciais, isso não seria uma tarefa difícil para Zen, não fosse o fato de ser autista. Agora, com a ajuda de seu amigo Spider, Zen terá de encontrar forças para enfrentar uma legião de criminosos e salvar sua mãe... Além de sua própria vida."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Öfke","runtime":0,"tagline":"Aksiyon ,  Dram","homepage":"","overview":"Acımasız ve cesur Chocolate’ın nefes kesen macera dolu öyküsü. Otistik bir kadının dövüş sanatlarındaki yeteneği gelişmiştir. Acımasız gangster çetesinden ailesine ait olan parayı geri almaya çalışır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"致命巧克力","runtime":0,"tagline":"","homepage":"","overview":"雪（琴嘉飾）是個自閉症患者，與母親珊相依為命，自小就擁有極強的武術天賦，不懂與人溝通卻能過目不忘。  年輕時的珊因曾與日本黑幫岸本（阿部寬飾）相戀，卻得罪當地黑幫頭目八哥，兩人更因此成為泰國黑道的眼中釘，遭到無情的追殺。不得已之下，珊與岸本只好暫時分離，岸本則獨自回到日本。  珊與雪四處逃避，卻依然難逃魔掌，目睹母親數次被欺凌，雪以過人的天賦，無師自通，練成一副強勁身手。  而雪為湊足巨款讓患癌的珊求醫，原本希冀可從黑幫份子手上取回他們昔日積欠母親的債款，但卻遭到暴力對待。另一方面，珊唯恐女兒遭黑幫毒手，只好向身在日本的岸本求助。岸本為救妻女，決定重回泰國，怎料當地幫會卻早已佈下天羅地網。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"초콜렛","runtime":0,"tagline":"","homepage":"","overview":"아시아에 새로운 액션스타가 탄생했다. 남다른 운동신경을 지닌 자폐아 젠. 빠른 속도로 무술을 배울 수 있는 그녀는 어머니의 치료비를 벌기위해 어머니가 남긴 장부를 보고 과거 동료들을 찾아간다. 그녀를 가로막는 악당들. 수줍은 얼굴에 몸빼 바지를 입고, 화려한 발차기를 선보이는 그녀! 이제 아무도 그녀를 막을 수 없다"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Chocolate","runtime":0,"tagline":"","homepage":"","overview":"Jen, jeune fille autiste, possède un don naturel pour les arts martiaux. Elle va ainsi aider sa mère atteinte d'un cancer à récupérer l'argent qu'on lui doit à l'aide d'un carnet où sont consignés les noms des débiteurs...Problème : ils appartiennent tous à une organisation appelée \"numéro 8\" et ne sont pas décidés à coopérer."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"شکلات","runtime":0,"tagline":"","homepage":"","overview":"دختری عجیب با قدرتهای رزمی فوق العاده تلاش می کند از گروهی تبهکار که به خانواده اش بدهکار است پولهای مادرش را پس بگیرد..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Chocolate","runtime":0,"tagline":"","homepage":"","overview":"Una chica autista aprende a luchar gracias a la televisión y a una escuela de boxeo que está al lado de su casa. Cuando descubre una lista de deudores en el diario de su madre enferma, va a buscarlos uno por uno. Su decisión la lleva a enfrentarse con gángsters y miembros de la mafia"},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Quyền Cước Thượng Đẳng","runtime":0,"tagline":"","homepage":"","overview":"Bộ phim nói về một cô bé mắc chứng bệnh tự kỉ tên là Zen, cô bé là kết quả tình yêu của Mashashi - một thương gia người Nhật và Anna - người tình của một tên trùm có thế lực tại Thái Lan. Zen có khả năng học võ từ những người xung quanh, và điểm yếu của Zen là sợ... ruồi. Anna bị mắc chứng bệnh ung thư, không có tiền đóng viện phí vì thế Zen và Moom - anh trai nuôi phải đi đòi tiền nợ, với khả năng võ của mình, Zen đã đánh cho chúng một trận tơi bời và đòi được tiền. Không bao lâu thì tên trùm tìm ra được chỗ ở của hai mẹ con Anna, hắn đã quay về trả thù lại món nợ xưa kia mà Anna đã gây ra cho hắn với tuyên bố \"Sẽ trả cả vốn lẫn lời\". Zen sẽ phải làm gì để bảo vệ cha mẹ của mình trước thế lực đen tối?"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Duch boja","runtime":0,"tagline":"","homepage":"","overview":"Nový film od tvorcov \"Ong Bak\"! Zen, ktorá sa narodila z lásky vraha Yakuzy a jednej nebezpečnej krásky, je veľmi zvláštnym dievčaťom. Žije odrezaná od sveta a objaví v sebe vlastnosť, ktorá od základu zmení jej život. Tato zvláštna vlastnosť jej umožňuje okamžite dokonale napodobiť akýkoľvek bojovný pohyb, ktorý uvidí. Medzitým jej matke diagnostikujú rakovinu, ale napriek tomu, že jej mnohí dlžia, nemajú peniaze na jej liečbu. Zen sa rozhodne, že pomocou novo získaných schopností zoženie peniaze od dlžníkov a zachráni chorú matku. Od tejto chvíle ju udržuje pri živote len jediná vec - boj. I keď sa narodila ako autistka, pomocou kúsku čokolády sa dokáže vymaniť zo svojho vnútorného sveta a stať sa zápasníčkou bojového umenia, akú ešte svet nikdy nevidel."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Шоколад","runtime":0,"tagline":"Вона мила, але смертоносна.","homepage":"","overview":"Героїня фільму молода дівчина Зін, яка перебуває в одному зі злочинних угруповань. Вона вирішує піти з незаконного бізнесу заради коханого японця, проте волею долі вони розлучаються. Згодом Зін дізнається, що вагітна і в неї народжується дочка, яку вона називає Зен. У дівчинки діагностують аутизм, але попри те, що їй важко вдається спілкуватися з оточуючими людьми, Зен чудово володіє бойовими мистецтвами. Коли дочка дорослішає, Зін дізнається, що хвора на рак і потрібна терміново більша сума для її лікування. Разом зі своїм другом Зен вирушає до людей, які нібито заборгували Зін чималі гроші, не знаючи, що боржники жінки дуже небезпечні люди."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Šokoladas","runtime":0,"tagline":"","homepage":"","overview":"Mergina serganti autizmu, bet turinti galingų kovos meno įgūdžių, siekia padengti savo sergančios motinos skolas, ieškodama negailestingų gaujų, kurios yra skolingos jos šeimai pinigų."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Шоколад","runtime":0,"tagline":"","homepage":"","overview":"Зен (Йанин Висмистананда) млада жена, страдаща от аутизъм, развила необичайни бойни умения, само гледайки телевизия и живеейки в съседство до академия по Муай Тай.\r Момичето е дъщеря на китайката Зин (Амара Сирипонг), съпруга на боса на Йакудза Масаши (Хироши Абе).  Зин преди време ходила с китайският гангстер, известен като \"№8\" (Понгпат Уачирабиньонг), който ревнувал от връзката и с вражеския гангстер Масаши, затова той отрязал един от палците на краката на Зин и и забранил да вижда Масаши.  Тогава Зин се разболява от рак и няма пари за лечение. Един ден, приятелите на Зен откриват списък с длъжници в стар бележник, писан от времето когато Зин все още работела като лихварка за №8. За да събере пари за лечението на майка си, Зен решава да събере борчовете, което пък води до сблъсъци с множество престъпни банди и, накрая, със самият №8."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Ciocolată","runtime":0,"tagline":"","homepage":"","overview":"O tânără autistă cu o avansată iscusință în artele marțiale încearcă să își ajute financiar mama bolnavă. Pentru asta, femeia trebuie să plece în căutarea bandei care datoreaza bani familiei ei."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Zen","runtime":93,"tagline":"","homepage":"","overview":"Zen er en vældigt speciel ung kvinde. Selv om hun er svært autistisk, er hun ved hjælp af film og tv-spil blevet en mester i kampsport – færdigheder, som hun får god brug for, da mafiaen truer hendes mor. Da rygtet spreder sig om den usandsynlige forbryderbekæmper, sender underverdenen den mest hårdføre kriger for at stoppe Zen for altid."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Zen - The Warrior Within","runtime":93,"tagline":"","homepage":"","overview":"Zen on hyvin erityinen nuori nainen. Vaikka hän on vaikeasti autistinen, hänestä on elokuvien ja videopelien avulla tullut kamppailujalijen mestari. Kyvyistä on hänelle hyötyä, kun mafia uhkailee hänen äitiään. Kun huhu epäuskottavasta rikostaistelijasta leviää, alamaailman kovimmat soturit lähetetään pysäyttämään Zen lopullisesti."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"致命巧克力","runtime":0,"tagline":"","homepage":"","overview":"雪（琴嘉飾）是個自閉症患者，與母親珊相依為命，自小就擁有極強的武術天賦，不懂與人溝通卻能過目不忘。\r 年輕時的珊因曾與日本黑幫岸本（阿部寬飾）相戀，卻得罪當地黑幫頭目八哥，兩人更因此成為泰國黑道的眼中釘，遭到無情的追殺。不得已之下，珊與岸本只好暫時分離，岸本則獨自回到日本。\r 珊與雪四處逃避，卻依然難逃魔掌，目睹母親數次被欺淩，雪以過人的天賦，無師自通，練成一副強勁身手。\r 而雪為湊足鉅款讓患癌的珊求醫，原本希冀可從黑幫份子手上取回他們昔日積缺母親的債款，但卻遭到暴力對待。另一方面，珊唯恐女兒遭黑幫毒手，只好向身在日本的岸本求助。岸本為救妻女，決定重回泰國，怎料當地幫會卻早已佈下天羅地網。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":699060,"adult":false,"title":"For the Love of Jessee","video":false,"overview":"Doctor Luke Matthew's world comes crashing down when he loses the love of his life and becomes a father in the same night. When he hires Sage as the new nanny, they both begin to realize that the best form of medicine is letting go.","genre_ids":[18],"media_type":"movie","popularity":0.2955,"vote_count":41,"poster_path":"/cR1Pr9X8KpYzW1itOizETIdQcgd.jpg","release_date":"2020-05-01","vote_average":7.4,"backdrop_path":"/sLS21WRgILSfuKXXGYOwjUhTHkp.jpg","original_title":"For the Love of Jessee","original_language":"en"},{"id":42120,"adult":false,"title":"City on Fire","video":false,"overview":"Ko Chow is an undercover cop who is under pressure from all sides. His boss, Inspector Lau, wants him to infiltrate a gang of ruthless jewel thieves; his girlfriend wants him to commit to marriage or she will leave Hong Kong with another lover; and he is being pursued by other cops who are unaware that he is a colleague. Chow would rather quit the force, feeling guilty about betraying gang members who have become his friends.","genre_ids":[28,80,53],"media_type":"movie","popularity":1.6938,"vote_count":169,"poster_path":"/uOgCKhHsQvOFVNxOUdewPwc0Z9N.jpg","release_date":"1987-02-13","vote_average":6.911,"backdrop_path":"/ONKOwS1xCipE5tMr8VsVJySzcH.jpg","original_title":"龍虎風雲","original_language":"cn"},{"id":13512,"adult":false,"title":"Sword In The Moon","video":false,"overview":"Kingdom of Joseon, ancient Korea. A usurper has conquered the throne. His ministers are being systematically eliminated by a mysterious assassin. An arrogant master swordsman is in charge of putting an end to the carnage.","genre_ids":[28,12,18],"media_type":"movie","popularity":0.6275,"vote_count":49,"poster_path":"/sDp5vC60tzHSfNBxOKzN1M1j8n1.jpg","release_date":"2003-07-15","vote_average":5.214,"backdrop_path":"/5pGkJ9E1b9aDPATh2wjikHzBeih.jpg","original_title":"청풍명월","original_language":"ko"},{"id":40458,"adult":false,"title":"Welcome to the Jungle","video":false,"overview":"Two young couples head into the New Guinea wilderness in an effort to find Michael Rockefeller, the heir to the Rockefeller fortune who disappeared in 1961.","genre_ids":[27],"media_type":"movie","popularity":0.5331,"vote_count":52,"poster_path":"/vppaSfqiihKSRs0ky4ZLkcdVKms.jpg","release_date":"2007-04-19","vote_average":4.423,"backdrop_path":"/hx6j7IMFzJ9SiWpO8MrvBLp7CvS.jpg","original_title":"Welcome to the Jungle","original_language":"en"},{"id":443686,"adult":false,"title":"Kung Fu Traveler","video":false,"overview":"Aliens have invaded and overtaken the Earth. Trying to escape defeat, a Chinese General (Tiger Hu Chen) is sent back in time trying to devise a way to defeat the alien invaders.","genre_ids":[878,28],"media_type":"movie","popularity":0.3497,"vote_count":19,"poster_path":"/z385HmjmJKzM4BaezVHr4V0XXe7.jpg","release_date":"2017-02-01","vote_average":5.6,"backdrop_path":"/eIYyaDCgVfJdw9OShhMjMRUDeaq.jpg","original_title":"功夫机器侠","original_language":"cn"},{"id":211561,"adult":false,"title":"The City Defends Itself","video":false,"overview":"Four criminals commit a robbery at a soccer stadium, and then split up to try to hide separately from the police.","genre_ids":[80,18],"media_type":"movie","popularity":0.1248,"vote_count":16,"poster_path":"/pvF4BFYHnkFLz3JRTuxjZR57AME.jpg","release_date":"1951-10-12","vote_average":6.1,"backdrop_path":"/hAO2jIG3VjyiQ7VIaiajAH0F7Ur.jpg","original_title":"La città si difende","original_language":"it"},{"id":594174,"adult":false,"title":"Locusts","video":false,"overview":"Two estranged brothers who are reluctantly reunited in their remote hometown at their father's funeral, become the target of an extortion scam at the hands of a gang of violent local thugs.","genre_ids":[53],"media_type":"movie","popularity":0.2612,"vote_count":10,"poster_path":"/v5qphhS55KPhqmyGafHAcSVPhvU.jpg","release_date":"2020-12-03","vote_average":5,"backdrop_path":"/7YGubdw4ssfrUbfzknSVG1CSu8J.jpg","original_title":"Locusts","original_language":"en"},{"id":90219,"adult":false,"title":"Expiration Date","video":false,"overview":"Charlie Silvercloud III lives with the family curse,  on his fathers and grandfathers 25th birthday they were killed by a milk truck.  It is now Charlies turn.","genre_ids":[35,10749],"media_type":"movie","popularity":1.0347,"vote_count":6,"poster_path":"/xkL9Jd5xZjqKc62LCaNpMheUwq0.jpg","release_date":"2006-01-01","vote_average":3.833,"backdrop_path":null,"original_title":"Expiration Date","original_language":"en"},{"id":37868,"adult":false,"title":"A Serious Shock! Yes Madam!","video":false,"overview":"In this action packed Hong Kong Yes Madam installment two friends in the police force are in love with the same man. After a certain incident one of them goes crazy and does everything she can to kill her former friend.","genre_ids":[28,12],"media_type":"movie","popularity":0.6938,"vote_count":12,"poster_path":"/qscluEk87alZ6f4NmTJ8qBwLbEc.jpg","release_date":"1993-09-23","vote_average":5.9,"backdrop_path":"/ozlRMbCBW6X2mZSNPVFABN7t7JE.jpg","original_title":"末路狂花","original_language":"cn"},{"id":538597,"adult":false,"title":"The Anarchist Banker","video":false,"overview":"The after dinner chat between a banker and his friend. The overwhelming power of the money that turns a true anarchist into a true financier.","genre_ids":[18],"media_type":"movie","popularity":0.0959,"vote_count":6,"poster_path":"/95wRM2NAcpFv4AZsAt1KttLLxlj.jpg","release_date":"2018-10-10","vote_average":7.7,"backdrop_path":"/dDxwd0fpTBtp4VAnJmB4FFsCVuD.jpg","original_title":"Il banchiere anarchico","original_language":"it"},{"id":729246,"adult":false,"title":"Guardian of the Palace","video":false,"overview":"'Guardian of the Palace' tells the story of a time when a plague spreads in Heishun (Blackwater) Town during the warring warlords, and Tianya, Wunian and Jiujiu set out on a treasure hunt to find the Golden Moon Gem that cures the plague. The warlord Feng Pei Chuan was trailing them and tried to take the gems for himself, but Tianya and the others managed to subdue Feng Pei Chuan, reclaim the gems and save the people.","genre_ids":[14,28],"media_type":"movie","popularity":0.2606,"vote_count":39,"poster_path":"/gbgzQKqncLgGIEtloYJsgieg6DV.jpg","release_date":"2020-07-31","vote_average":6.8,"backdrop_path":"/eSWpozd2tx6Nn37Gab1aViuYGv8.jpg","original_title":"沙海烛龙","original_language":"zh"},{"id":471880,"adult":false,"title":"Cinderella the Cat","video":false,"overview":"Cenerentola struggles to escape the shadow and evil schemes of her stepmother and six stepsisters who all live aboard the Megaride, a ship stuck in the port of a decaying future Naples.","genre_ids":[16,80,53],"media_type":"movie","popularity":0.5779,"vote_count":225,"poster_path":"/9BgTsTWDJCGJYiOKa0JjrMR9tr4.jpg","release_date":"2017-09-14","vote_average":7.022,"backdrop_path":"/1vm4QRKJSIHL4b1fpmTOTUzYd6V.jpg","original_title":"Gatta Cenerentola","original_language":"it"},{"id":25855,"adult":false,"title":"Raging Phoenix","video":false,"overview":"A young girl joins hands with a group of kung-fu masters to stop a notorious gang from abducting young women. However, the mission is compromised after they fail to locate the gang's hideout.","genre_ids":[53,28],"media_type":"movie","popularity":0.6739,"vote_count":76,"poster_path":"/56XtvAUgRzd2rfF8Jt02qBHFdBF.jpg","release_date":"2009-08-12","vote_average":6.388,"backdrop_path":"/8t9pNKhcGFnum8nuLWvKdmZccum.jpg","original_title":"จีจ้า ดื้อ สวย ดุ","original_language":"th"},{"id":39393,"adult":false,"title":"Once Upon a Time in Rio","video":false,"overview":"Situated just above the awe-inspiring Ipanema beach in Rio is the Cantagalo slum. Every day, floods of Cantagalo residents make their way down the mountain, only to disappear into their surroundings as part of the invisible working-class that cleans apartments, works in restaurants, and sells food along the scenic, sun-drenched shores. Young Dé (Thiago Martins) is just such a man. Dé lives with his mother Bernadette (Cyria Coentro) in a cramped Cantagalo apartment, selling hot dogs on the beach in order to make the rent. His brother Beto was killed when Dé was just a young boy, and his adopted brother Carlão (Rocco Pitanga) has been jailed for a robbery that he didn't commit. One day, while working on the beach, Dé meets Nina (Vitória Frate). Nina is the only child of a successful lawyer named Evandro (Paulo César Grande), who's none to happy to discover that his daughter is dating a member of the lower class. How...","genre_ids":[18],"media_type":"movie","popularity":0.2878,"vote_count":82,"poster_path":"/iw5KVyuWtRK0mT7HIYpWzVFOdUn.jpg","release_date":"2008-07-25","vote_average":7.5,"backdrop_path":"/9PJc8wYqp2Z484pBRnoDaIZSNTm.jpg","original_title":"Era uma Vez...","original_language":"pt"},{"id":15485,"adult":false,"title":"Disney Princess Enchanted Tales: Follow Your Dreams","video":false,"overview":"Princess Aurora and Princess Jasmine learn valuable life lessons in two short stories.","genre_ids":[16,10751,14],"media_type":"movie","popularity":0.9953,"vote_count":98,"poster_path":"/beAvTAhMQpTRxmlgGgpfg9F2rc1.jpg","release_date":"2007-09-03","vote_average":6.5,"backdrop_path":"/8iwjFgudDelX4o3XdczcB2ij1L7.jpg","original_title":"Disney Princess Enchanted Tales: Follow Your Dreams","original_language":"en"},{"id":18203,"adult":false,"title":"Big Night","video":false,"overview":"Primo and Secondo, two immigrant brothers, pin their hopes on a banquet honoring Louis Prima to save their struggling restaurant.","genre_ids":[18,10749,35],"media_type":"movie","popularity":1.1061,"vote_count":262,"poster_path":"/8AJGSDyrj3Dz2B57n1ZB4qNPbmJ.jpg","release_date":"1996-09-20","vote_average":6.948,"backdrop_path":"/79EyItsEl7pnIO0jFi5HDMhsiON.jpg","original_title":"Big Night","original_language":"en"},{"id":378373,"adult":false,"title":"Brothers of the Wind","video":false,"overview":"The way of the eagle is to raise two chicks. The stronger is destined always to throw the weaker from the nest. Man also has his ways, often to hurt those closest to him.  Lukas suffers at the hands of a father who has withdrawn since the loss of his wife. Killed whilst rescuing the infant Lukas, the boy now carries the burden of her death.  Our eagle’s story begins in the nest. The first-born chick pushes his weaker brother to a certain death on the forest floor. But fate intervenes and the chick is found by Lukas. Naming him Abel, Lukas cares for the creature in secret, finding a love and companionship denied to him at home. But when the day comes to release Abel back into the wild, will Lukas find his own release into a new life?","genre_ids":[12,18,10751],"media_type":"movie","popularity":0.5192,"vote_count":192,"poster_path":"/uA3urgwFH0ctZAAS61ohM9iGOB5.jpg","release_date":"2015-12-24","vote_average":7.1,"backdrop_path":"/7rNkbQNwnTRL0fUEtudbGLQDBJj.jpg","original_title":"Brothers of the Wind","original_language":"en"},{"id":171581,"adult":false,"title":"The Marine 3: Homefront","video":false,"overview":"A Marine must do whatever it takes to save his kidnapped sister and stop a terrorist attack masterminded by a radical militia group.","genre_ids":[28],"media_type":"movie","popularity":0.8026,"vote_count":215,"poster_path":"/9liEU1O0GZIZXYf9SekjH5kb8bb.jpg","release_date":"2013-03-05","vote_average":6.2,"backdrop_path":"/uBb9OfDyhgVDNpa9v5S6dvEU8sy.jpg","original_title":"The Marine 3: Homefront","original_language":"en"},{"id":9404,"adult":false,"title":"Police Story 4: First Strike","video":false,"overview":"Hong Kong cop Chan Ka-Kui returns, working with Interpol to track down and arrest an illegal weapons dealer. Chan later realizes that things are not as simple as they appear and soon finds himself to be a pawn of an organization posing as Russian intelligence.","genre_ids":[28,12,35,80,18,53],"media_type":"movie","popularity":2.0025,"vote_count":518,"poster_path":"/bRHbteT4IORJOXY0Qrnb4FPXRS0.jpg","release_date":"1996-02-10","vote_average":6.477,"backdrop_path":"/gYLSKuxOOmUGu0fZvErHz2FkZGl.jpg","original_title":"警察故事4之簡單任務","original_language":"cn"},{"id":11779,"adult":false,"title":"Buena Vista Social Club","video":false,"overview":"In this fascinating Oscar-nominated documentary, American guitarist Ry Cooder brings together a group of legendary Cuban folk musicians (some in their 90s) to record a Grammy-winning CD in their native city of Havana. The result is a spectacular compilation of concert footage from the group's gigs in Amsterdam and New York City's famed Carnegie Hall, with director Wim Wenders capturing not only the music -- but also the musicians' life stories.","genre_ids":[99,10402],"media_type":"movie","popularity":0.6064,"vote_count":366,"poster_path":"/b203Z3qwCRMLOY00XZh4qNQCwM4.jpg","release_date":"1999-06-04","vote_average":7.497,"backdrop_path":"/y5Y12Pds6Z4ipLg482Azhp4xb9x.jpg","original_title":"Buena Vista Social Club","original_language":"en"}],"similar_content":[{"id":1471464,"adult":false,"title":"Hitman Lawyer","video":false,"overview":"Lawyer Shindo Kai is an undefeated ace, also working as a hitman who punishes criminals exploiting legal loopholes. While secretly serving justice, he hides his true identity as the illegitimate son of Gondo Heihachiro, a yakuza boss. When Gondo's group is attacked by the rising Mayhem gang, Kai, having recently lost a case due to sabotaged evidence, investigates the betrayal. His pursuit of the truth leads to a bloody reckoning.","genre_ids":[28,80],"popularity":0.1121,"vote_count":0,"poster_path":"/jGjzYQPQmkFhuStgtQT1DGpRo7h.jpg","release_date":"2023-04-21","vote_average":0,"backdrop_path":"/mCOXp6dD9jVpWD72mo5yZT4y7rr.jpg","original_title":"ヒットマン・ロイヤー","original_language":"ja"},{"id":1291946,"adult":false,"title":"我王伝 第一章","video":false,"overview":"","genre_ids":[18,80],"popularity":0.2191,"vote_count":0,"poster_path":"/zRdCTU3aMPuoHoemwsBxWpXC1Xk.jpg","release_date":"2018-01-31","vote_average":0,"backdrop_path":null,"original_title":"我王伝 第一章","original_language":"ja"},{"id":682,"adult":false,"title":"The Man with the Golden Gun","video":false,"overview":"Cool government operative James Bond searches for a stolen invention that can turn the sun's heat into a destructive weapon. He soon crosses paths with the menacing Francisco Scaramanga, a hitman so skilled he has a seven-figure working fee. Bond then joins forces with the swimsuit-clad Mary Goodnight, and together they track Scaramanga to a Thai tropical isle hideout where the killer-for-hire lures the slick spy into a deadly maze for a final duel.","genre_ids":[12,28,53],"popularity":4.9709,"vote_count":2220,"poster_path":"/xVkbKwGnBVNQ122GN5bCTMyPbWz.jpg","release_date":"1974-12-04","vote_average":6.456,"backdrop_path":"/3tpNEbRahT8smy7RraaWa0xg9Gv.jpg","original_title":"The Man with the Golden Gun","original_language":"en"},{"id":1370,"adult":false,"title":"Rambo III","video":false,"overview":"Combat has taken its toll on Rambo, but he's finally begun to find inner peace in a monastery. When Rambo's friend and mentor Col. Trautman asks for his help on a top secret mission to Afghanistan, Rambo declines but must reconsider when Trautman is captured.","genre_ids":[28,12,53,10752],"popularity":5.7202,"vote_count":3405,"poster_path":"/uycbt9iVlAnKkQIisqUWuO8hVcm.jpg","release_date":"1988-05-24","vote_average":6.199,"backdrop_path":"/Afkcvov0y7osi6NwubwpPL6pfrA.jpg","original_title":"Rambo III","original_language":"en"},{"id":942,"adult":false,"title":"Lethal Weapon 2","video":false,"overview":"Riggs and Murtaugh are on the trail of South African diplomats using their immunity to engage in criminal activities.","genre_ids":[28,12,35,80,53],"popularity":4.4713,"vote_count":3655,"poster_path":"/ZsUGxTnZ4TzTrHSAfUPJcliL1K.jpg","release_date":"1989-07-07","vote_average":7.026,"backdrop_path":"/zjRkl5PZvFujbRndrNbf4ZKbeNC.jpg","original_title":"Lethal Weapon 2","original_language":"en"},{"id":949,"adult":false,"title":"Heat","video":false,"overview":"Obsessive master thief Neil McCauley leads a top-notch crew on various daring heists throughout Los Angeles while determined detective Vincent Hanna pursues him without rest. Each man recognizes and respects the ability and the dedication of the other even though they are aware their cat-and-mouse game may end in violence.","genre_ids":[80,18,28],"popularity":14.6479,"vote_count":8089,"poster_path":"/e09dLw1Ljtccd2P4NsuUvVtS5du.jpg","release_date":"1995-12-15","vote_average":7.928,"backdrop_path":"/5JaR6UEoCJJLtLpqFOVMY4O4R7P.jpg","original_title":"Heat","original_language":"en"},{"id":2110,"adult":false,"title":"Wasabi","video":false,"overview":"Hubert is a French policeman with very sharp methods. After being forced to take 2 months off by his boss, who doesn't share his view on working methods, he goes back to Japan, where he used to work 19 years ago, to settle the probate of his girlfriend who left him shortly after marriage without a trace.","genre_ids":[18,28,35],"popularity":5.1477,"vote_count":1392,"poster_path":"/uo3MBDwn3o32GJzFyClm7r1ierb.jpg","release_date":"2001-10-31","vote_average":6.7,"backdrop_path":"/kSpfkuIykUsXr6XSU8NdyqiVcR4.jpg","original_title":"Wasabi","original_language":"fr"},{"id":2148,"adult":false,"title":"The Cotton Club","video":false,"overview":"Harlem's legendary Cotton Club becomes a hotbed of passion and violence as the lives and loves of entertainers and gangsters collide.","genre_ids":[80,18],"popularity":1.8709,"vote_count":431,"poster_path":"/qigf5fWSH1tw7z424UVKg71UIOS.jpg","release_date":"1984-12-14","vote_average":6.5,"backdrop_path":"/8vroa5RYUxD7Nv7vUGUoxZTyz7P.jpg","original_title":"The Cotton Club","original_language":"en"},{"id":591446,"adult":false,"title":"The Seven Swords: Eye of Chaos","video":false,"overview":"King Asura, the malevolent ruler, is on a quest to acquire the Seven Swords, intending to merge them into a single Holy Sword to dominate all realms. Armed with five of these formidable blades, he relentlessly seeks the last two to fulfill his ambition. These remaining swords are safeguarded by the skilled martial artists Master Weifeng and his protégé Lanzhu. As King Asura's demon warriors hunt for the swords, a complex love triangle unfolds involving Yufang and the enigmatic secrets tied to her past romance.","genre_ids":[12,28,14,10749],"popularity":0.219,"vote_count":3,"poster_path":"/wpK7cWjajJ8x5HtMMkwmJNv6TAP.jpg","release_date":"2019-03-08","vote_average":8.8,"backdrop_path":"/mjLMI7geN7m0YzINuQPYrGdV3Mz.jpg","original_title":"七剑下天山之修罗眼","original_language":"zh"},{"id":868,"adult":false,"title":"Tsotsi","video":false,"overview":"A young South African boy from the Johannesburg ghetto named Tsotsi, meaning Gangster, leaves home as a child to get away from his helpless parents. Now a teenage thug, Tsotsi finds a baby in the back seat of a car he's just stolen. He decides that it is his responsibility to care for the infant and in the process learns that maybe the criminal life isn’t the best way.","genre_ids":[80,18],"popularity":0.6634,"vote_count":338,"poster_path":"/r3ebTJFcDZ35GaKcuUQQe243z4f.jpg","release_date":"2005-12-23","vote_average":6.95,"backdrop_path":"/gLxgqHpJcMvB6cMTA4hUBxoOMJ1.jpg","original_title":"Tsotsi","original_language":"tn"},{"id":500,"adult":false,"title":"Reservoir Dogs","video":false,"overview":"A botched robbery indicates a police informant, and the pressure mounts in the aftermath at a warehouse. Crime begets violence as the survivors -- veteran Mr. White, newcomer Mr. Orange, psychopathic parolee Mr. Blonde, bickering weasel Mr. Pink and Nice Guy Eddie -- unravel.","genre_ids":[80,53],"popularity":9.2336,"vote_count":15163,"poster_path":"/xi8Iu6qyTfyZVDVy60raIOYJJmk.jpg","release_date":"1992-09-02","vote_average":8.117,"backdrop_path":"/jwt159hXWA9Q5xpBo8hWb3zwLi7.jpg","original_title":"Reservoir Dogs","original_language":"en"},{"id":327,"adult":false,"title":"Brother","video":false,"overview":"A Japanese Yakuza gangster's deadly existence in his homeland gets him exiled to Los Angeles, where he is taken in by his little brother and his brother's gang.  Original Title: ブラザー","genre_ids":[80,18,53],"popularity":1.9585,"vote_count":511,"poster_path":"/h7UKdWriX8keKOgSlBrk4OG7XRL.jpg","release_date":"2000-12-13","vote_average":7.099,"backdrop_path":"/cL1VX6WllejQQhGTUGGWHW25yor.jpg","original_title":"Brother","original_language":"ja"},{"id":591640,"adult":false,"title":"Dogfight: Stray Dogs' Elegy","video":false,"overview":"A cocaine deal is about to go down between yakuza and Hong Kong triad gangsters and a small time porn peddler is used as a mole by a dirty cop.","genre_ids":[28,80],"popularity":0.3714,"vote_count":1,"poster_path":"/u2Pnaq2H4qGlDTFLfw5FfxQYFWq.jpg","release_date":"2000-11-10","vote_average":6,"backdrop_path":"/l3jbNUAEMUMSr1ZVL5khZXyii34.jpg","original_title":"DOG FIGHT 野良犬たちの挽歌","original_language":"ja"},{"id":16851,"adult":false,"title":"Yo-Yo Girl Cop","video":false,"overview":"Recruited by a clandestine police organization, \"K\" must stop a plot by student radicals to create anarchy in Japan. Armed with a hi-tech steel yo-yo, and a new name (Asamiya Saki), she must infiltrate an elite high school to find the terrorists but finds an even more sinister plan is about to unfold.","genre_ids":[28,80,53],"popularity":0.9014,"vote_count":44,"poster_path":"/atuLBXMZmLljTVIoZAhsa1XzXkd.jpg","release_date":"2006-09-30","vote_average":5.6,"backdrop_path":"/pDVCpfNn6ef7pKH9HRC2uHpBd55.jpg","original_title":"スケバン刑事 コードネーム=麻宮サキ","original_language":"ja"},{"id":16878,"adult":false,"title":"Saving God","video":false,"overview":"Ex Con Armstrong Cane (Ving Rhames) returns to home a changed man looking to take over his father's old church and congregation. The neighborhood though is full of drugs and gangs. Those who are able are leaving for more prosperous areas and falling in with a slick preacher (Ricardo Chivara). Even with a dangerous gang leader (Dean McDermott) threatening his flock, Armstrong won't give up.","genre_ids":[80,18],"popularity":0.5406,"vote_count":20,"poster_path":"/q16Hoe5oqE9rRxakSzNikqFvy3P.jpg","release_date":"2008-10-14","vote_average":5.3,"backdrop_path":null,"original_title":"Saving God","original_language":"en"},{"id":16353,"adult":false,"title":"Ong Bak 2","video":false,"overview":"Tien, the son of Lord Sihadecho — a murdered nobleman — is taken under the wing of Chernang, a renowned warrior and leader of the Pha Beek Krut.","genre_ids":[12,28,53],"popularity":2.6321,"vote_count":696,"poster_path":"/5Iue46Q6d1EGMPl7XraeRAMdMoY.jpg","release_date":"2008-12-04","vote_ave