5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Chocolate\",\"description\":\"Zen, an autistic teenage girl with powerful martial arts skills, gets money to pay for her sick mother Zin's treatment by seeking out all the people who owe Zin money and making them pay.\",\"image\":\"https://image.tmdb.org/t/p/w500/t6G2SGFZArIkMibcpGV9K8ke7rV.jpg\",\"datePublished\":\"2008-02-07\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"TH\",\"inLanguage\":\"th\",\"genre\":[\"Action\",\"Crime\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.329,\"bestRating\":10,\"ratingCount\":545}}"}}],["$","$L10",null,{"initialDrama":{"id":"47010168-bb1b-434f-9068-5865c8aa393b","tmdb_id":15003,"imdb_id":"tt1183252","content_type":"movie","title":"Chocolate","original_title":"ช็อคโกแลต","overview":"Zen, an autistic teenage girl with powerful martial arts skills, gets money to pay for her sick mother Zin's treatment by seeking out all the people who owe Zin money and making them pay.","poster_path":"/t6G2SGFZArIkMibcpGV9K8ke7rV.jpg","backdrop_path":"/umEjgwcWIjWHoxrKTS8QPMMJjDz.jpg","release_date":"2008-02-07","first_air_date":null,"status":"published","original_language":"th","origin_country":["TH"],"genres":[{"id":28,"name":"Action"},{"id":80,"name":"Crime"}],"popularity":2.1577,"vote_average":7.329,"vote_count":545,"runtime":93,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:53:18.062555+00:00","updated_at":"2026-02-21T15:24:08.189+00:00","tagline":"She's sweet but deadly.","homepage":null,"budget":4800000,"revenue":0,"production_companies":[{"id":3007,"name":"Bam-Ram-Ewe","logo_path":null,"origin_country":""},{"id":4207,"name":"Sahamongkolfilm","logo_path":"/v5BSFwIXQmZEO16bClILNrbv4Kl.png","origin_country":"TH"}],"production_countries":[{"name":"Thailand","iso_3166_1":"TH"}],"spoken_languages":[{"name":"English","iso_639_1":"en","