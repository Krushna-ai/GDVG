so_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3000,"height":1688,"file_path":"/2abP0gckWtuS5rUVjTa37Sbr7OH.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3000,"height":1688,"file_path":"/zFNSMxbyNnvf1OsnhjKIWztqqB3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3000,"height":1688,"file_path":"/v4E0BtBYu7tHsQQbCNF9HXchuTW.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3000,"height":1688,"file_path":"/uzz23jNwK0L8CtQSKGXKGimyJSJ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3000,"height":1688,"file_path":"/vmGCNXBBc48l8oAahZ7uhZfyIYw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1920,"height":1080,"file_path":"/qSJZ9P1r5fTYopuwrfpxhmn2vIZ.jpg","iso_639_1":"no","iso_3166_1":"NO","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:52:48.03+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":150,"tagline":"On land they dreamed of being heroes. Beneath the sea they pray to be survivors.","homepage":"http://www.dasboot.com","overview":"A German submarine hunts allied ships during the Second World War, but it soon becomes the hunted. The crew tries to survive below the surface, while stretching both the boat and themselves to their limits."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"U-båden","runtime":0,"tagline":"","homepage":"","overview":"I 1942 sejler U-96 ud på Nordatlantens jagtmarker, hvor den tyske flådes ulvekoppel angriber de allierede konvojer, der holder Storbritannien i live. I månedsvis lever besætningen som sild i en tønde, mens de venter på byttet. Da det går løs, bliver de selv de jagede, og dybvandsbomberne driver u-båden længere og længere ned i dybet. Kaptajnen: Jürgen Prochnow. Løjtnant Werner: Herbert Grönemeyer. Maskinmester: Klaus Wennemann. Manuskript og instruktion: Wolfgang Petersen efter Lothar Günther-Buchheims selvbiografiske roman."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":150,"tagline":"Wenn Jäger zu Gejagten werden.","homepage":"","overview":"Der Kriegsberichterstatter Werner geht 1941 an Bord von U-96, das den Auftrag hat englische Transportschiffe zu versenken. Werner soll der Heimatfront von den Heldentaten des Kapitäns und seiner Mannschaft berichten. Doch schnell wird der Jäger zum Gejagten und der Atlantik entpuppt sich bald als nasskalte Hölle für die Besatzung. Ein Albtraum aus Klaustrophobie und Todesangst beginnt."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"U-Boot 96","runtime":216,"tagline":"Quando il cacciatore diventa preda","homepage":"","overview":"Nell'autunno 1941 dal porto di La Rochelle esce in missione un sottomarino tedesco, per attaccare e affondare i convogli provenienti dagli Stati Uniti con aiuti destinati agli Inglesi. Dopo aver subito due attacchi, riesce a rientrare a La Rochelle, ma un attacco aereo ne provoca l'affondamento definitivo e la morte di quasi tutto l'equipaggio."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Подводная лодка","runtime":281,"tagline":"Когда охотники становятся добычей","homepage":"","overview":"Осень 1941 года. Немецкая подводная лодка отправляется в Атлантический океан, место противостояния германского и английского флотов. Жизнь по строгому распорядку, учебные тревоги, воспоминания о семьях и любимых девушках, солёные мужские шуточки... Скоро всё это закончится. Потому что впереди — ад и никакой надежды на спасение..."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Le Bateau","runtime":149,"tagline":"Un voyage aux limites de l'enfer.","homepage":"","overview":"Pendant la deuxième Guerre Mondiale, 40 000 sous-mariniers allemands envoyés par Hitler embarquent pour une mission de routine dans l'Atlantique Nord. L'insouciance règne à bord. Ce qu'ils ne savent pas, c'est que seuls 10 000 hommes retourneront chez eux vivants."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Sukellusvene U-96","runtime":0,"tagline":"Kun saalistajista tulee saaliita...","homepage":"","overview":"Syksy 1941. 43 nuorta saksalaista merimiestä astuu sukellusveneeseen U-96 ja lähtee sotaan Englantia vastaan. Johtajana heillä on vasta 30-vuotias kapteeni. Sodan aikana nuorukaisista kehittyy verenhimoisia saalistajia, jotka pystyvät häikäilemättä tuhoamaan tuhansittain merimiehiä. Ennen pitkää he huomaavat olevansa myös saaliita, vankeina teräsarkussa syvällä merenpinnan alla."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Mukaddes Vazife","runtime":0,"tagline":"","homepage":"","overview":"1979 yılında çekilmiş 1981 yılında vizyona giren, İkinci Dünya Savaşı'nda U-96 adlı tip 7 sınıfı Alman U bot mürettebatını konu alan film. Savaşta Alman denizcilerin hayatlarını, içinde bulundukları psikolojik durumları görsel bir anlatış biçimiyle dile getirmektedir. İkinci Dünya Savaşı'nda görev yapan U-96 tipi bir Alman denizaltısı Atlas Okyanusu'ndaki normal devriye görevine çıkar. Gemide görevli personel haricinde bir subay da denizaltında yaşananları kaydetmek için sefere katılır. Gemi normal seyrinde iken okyanusta detroyer koruması olmadan seyreden 5 gemilik bir filoyla karşılaşır. Kaptan biraz tereddütden sonra saldırı emri verir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"A Odisseia do Submarino 96","runtime":150,"tagline":"Quando o predador se torna a presa.","homepage":"http://www.dasboot.com/","overview":"Retracta o inferno dos tripulantes de um submarino alemão que, em 1942, participou da Batalha do Atlântico. De modo realista, conhecemos como um simples submarino lutou contra os navios Ingleses e todo o sofrimento de quando eram atacados."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"从海底出击","runtime":200,"tagline":"","homepage":"","overview":"1942年，德国潜艇舰队深陷所谓的“大西洋战役”，旨在袭扰并摧毁英国航运。然而，随着驱逐舰级护航力量的加强，德国U型潜艇开始遭受重创。本片讲述了一艘U型潜艇船员的故事，聚焦这些潜艇兵如何保持军人职业素养，执行近乎不可能的任务，同时始终试图理解并服从他们所效忠的政府意识形态。[索尼影业]"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Ubåten","runtime":146,"tagline":"När jägarna är de som blir jagade…","homepage":"","overview":"Hösten 1941, 43 unga sjömän ombord på den tyska ubåten U-96 går ut i kriget mot England under befäl av en stridslysten kapten. Under de kommande åren blir de blodtörstiga jägare, som utan förvarning kan utrota tusentals sjömän – men blir också ett skräckslaget byte, fångat i en kista av stål djupt ner under havets yta."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"El submarino (Das Boot)","runtime":149,"tagline":"40000 hombres fueron enviados en los submarinos alemanes ... 30000 nunca volvieron.","homepage":"","overview":"Un submarino alemán de la Segunda Guerra Mundial es el escenario en el que un grupo de jóvenes soldados, dispuesto a defender su patria, tendrá que someterse a una dura convivencia, tras descubrir que han sido enviados a realizar una misión probablemente suicida."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Ponorka","runtime":149,"tagline":"Slavný válečný film o poslední dramatické plavbě německé ponorky za druhé světové války","homepage":"","overview":"Válečný film o mladých mužích, často ještě chlapcích hladových po dobrodružství, kteří byli svedeni nacistickou propagandou a zlákáni zázrakem techniky. Na moři musí čelit krutým silám přírody a bojovat s neviditelným nepřítelem. Řada z nich je bez zkušeností. Zažívají hrůzy války, samotu a zoufalství. Jejich možnosti jsou děsivé: buď se vynoří bez škrábnutí, nebo zemřou. Pod hladinou moře nemají zranění šanci. Za II. světové války se ze 40 000 mužů bojujících na palubách německých ponorek vrátilo zpět pouhých 10 000."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"A tengeralattjáró","runtime":208,"tagline":"Amikor a vadászok prédává válnak.","homepage":"","overview":"Az egyik német tengeralattjáró bevetésre indul a franciaországi kikötőből a második világháború idején. A legénység jószerivel csupa fiatal, éretlen és tapasztalatlan férfiból áll, akiket meggyőzött a náci propaganda, és elcsábított a technika. Nagy lelkesedéssel vetik magukat a szövetségesek elleni küzdelembe, hogy azután a saját bőrükön tapasztalják meg a tengeralattjáró-háború poklát. Az acélkoporsóban vívott idegőrlő és kimerítő harcot a természet erőivel és a láthatatlan ellenséggel."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Okręt","runtime":0,"tagline":"","homepage":"","overview":"Das Boot: arcydzieło Wolfganga Petersena oparte na bestsellerowej powieści Lothara Günthera Buchheima o ostatniej wyprawie niemieckiego U-boota podczas II wojny światowej."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":149,"tagline":"","homepage":"","overview":"Najaar 1941, La Rochelle aan de Franse kust: 50 Duitse militairen drinken zich zat en maken plezier in een Franse nachtclub. Voor hen kan dit de laatste keer zijn, aangezien ze de volgende morgen aan boord van een onderzeeër zullen gaan, om zo veel mogelijk vijandelijke schepen tot zinken te brengen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Ubåten","runtime":208,"tagline":"","homepage":"","overview":"Høsten 1941. 43 unge tyske sjøfolk om bord i den tyske ubåten U-96 legger ut i krigen mot England under ledelse av en krigserfaren kaptein på bare 30 år. I årene som kommer vil de både være blodtørstige jegere, som uten varsel kan gjøre det av med tusener av sjøfolk - men også et redselslagent bytte, fanget i en kiste av stål dypt under havets overflate. Ingen film har noensinne fanget krigens spenning og redsel med en slik styrke. Ubåten er nominert til ikke mindre enn seks Oscar, blant annet 'Beste film', og i denne versjonen kan man nyte det tekniske og fortellermessige mesterverket som den er."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"U・ボート","runtime":0,"tagline":"","homepage":"","overview":"第2次世界大戦の1941年。ナチスドイツに占領されたフランスのラ・ロシェルの港から、出撃命令によって出航する潜水艦U96にヴェルナー（ヘルバート・グリューネマイヤー）が乗り込む。ベテランの艦長（ユルゲン・プロフノウ）や乗組員に囲まれながら、荒れた海での過酷な哨戒、次々と爆雷を放ってくる敵駆逐艦との攻防、海の藻くずと化していく敵の姿など、戦争の現実を次々と目の当たりにするヴェルナー。そんな中、U96に新たな命令が下される。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Подводница U-96","runtime":209,"tagline":"Когато ловците станат уловени","homepage":"","overview":"Годината е 1941-а, разгарът на Втората световна война. Германски военен кореспондент се присъединява към екипажа на немската подводница U-96. Неговата задача е да напише материал за подводничарите-герои. Но идеалистичните му представи и планове се провалят почти веднага.  За капитана и неговия екипаж шансовете за оцеляване намаляват катастрофално с всеки изминат ден. Британските унищожители са се превърнали във велика сила, а германския подводен флот претърпява големи загуби. Младите мъже са отплавали с мисия, решени да я изпълнят, но на каква цена…  В света на подводната война законите са сурови: или изплуваш невредим, или загиваш. Под водата ранени няма."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Das Boot","runtime":149,"tagline":"Όταν οι κυνηγοί γίνονται το θήραμα.","homepage":"","overview":"Ένα Γερμανικό υποβρύχιο κυνηγάει συμμαχικά πλοία κατά το 2ο Παγκόσμιο Πόλεμο. Σύντομα γίνεται το ίδιο θήραμα. Το πλήρωμα προσπαθεί να επιβιώσει κάτω από την επιφάνεια, φτάνοντας τόσο το σκάφος όσο και τους ίδιους στα όρια της αντοχής τους..."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"הצוללת","runtime":0,"tagline":"","homepage":"","overview":"הסרט נפתח בגרמניה של שנת 1942. מלחמת העולם השניה בעיצומה, המוראל הנאצי בשלב זה גבוה, וסגן וורנר (הרברט גרונמייר), כתב צבאי צעיר, נשלח לסקר את הגיחה המבצעית הקרובה של אחד מצוותי הצוללות הנועזים באוקיינוס האטלנטי. לאחר שהוא מתוודע, על כמה כוסות בירה, לחבורת הטיפוסים החביבים ומפקדם הכריזמטי היינריך לימן (יורגן פורכנאו), עולה וורנר על סיפונה של אותה צוללת, משוכנע כי הוא עומד לתעד מסע זריז של עוד ניצחון מפואר עבור הרייך. לוורנר, כפי שברור לצופים מהכתובית הפותחת את הסרט, אין מושג לאיזה ברוך הוא נכנס. זה מתחיל עם המתנה ארוכה, משועממת, מורטת-עצבים, שמשהו יקרה. ואז דברים אכן מתחילים לקרות: מזג אוויר סוער, ספינות אויב, ומעל הכל - הנטייה של הצוללת, פאר הטכנולוגיה, להתקלקל, לדלוף, ולאיים לקחת את וורנר ואת יתר הצוות ישר למצולות האוקיינוס. צוות הצוללת, מבין וורנר מאוחר מדי, לא יצא לאוקיינוס כדי לנצח. הכי הרבה שהם מקווים לו זה לשרוד"},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"특전 U보트","runtime":0,"tagline":"","homepage":"","overview":"제2차 세계대전이 한창인 1941년. 잠수함 U-96호에 승선한 젊은 독일군들은 먹고 마시며 하루 하루를 보내지만, 시간이 지날수록 잠수함이라는 공간에 답답함을 느끼고 전쟁의 비정함을 조금씩 깨닫게 된다. 그리고 크리스마스를 앞둔 어느 날, 그들에게 위험한 명령이 떨어진다. 영국군이 장악하고 있는 지브롤터 해협을 통과하라는, 마치 자살 명령과 다름 없는 지령이다. 적지를 통과하던 U보트는 폭탄에 맞아 바닷 속 깊은 곳으로 침몰해 가고, 군인들은 극도의 공포 속에 놓이게 되는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"O Barco: Inferno no Mar","runtime":209,"tagline":"Conheça o outro lado.","homepage":"","overview":"Em plena Segunda Guerra Mundial, em 1942, o capitão de um submarino enfrenta enormes dificuldades no comando de uma tripulação pouco experiente. Durante a Batalha do Atlântico Norte, eles vivem num inferno claustrofóbico afundando navios ingleses e procurando barcos aliados."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"從海底出擊","runtime":0,"tagline":"","homepage":"","overview":"以二次世界大戰為背景，敘述德國指揮官帶領德國U型潛艇作戰的真實故事。德國U型潛艇奉命襲擊英國船隊，當任務圓滿達成後卻遭遇前所未有的危機，指揮官該如何帶領潛艇航員化險為夷？這群原本性格鮮明、思想單純的德國士兵，經過殘酷戰爭的洗禮後，長時間徘徊於生死邊緣的壓力和折磨，讓他們變得麻木與絕望。一個人失去了熱情、失去了思想，那還剩下什麼 ... 好萊塢電影行遍天下的當代，很少有以德國人觀點去檢視、反思二次世界大戰的電影，本片正是一部難得的佳作。影片不去批評敵對雙方誰對誰錯，僅以寫實客觀的角度來描述一群二戰期間普通的德國士兵，值得一看！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"從海底出擊","runtime":0,"tagline":"","homepage":"","overview":"這部引人入勝的戲劇強片講述德國 U 型潛艇在二戰期間經歷的重重考驗，榮獲六項奧斯卡獎提名。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Підводний човен","runtime":0,"tagline":"Коли мисливці перетворюються на жертву","homepage":"","overview":"Фільм розповідає про бойовий похід німецького підводного човна, що вийшов в Атлантику на перехоплення англійських морських конвоїв, а потім отримав смертельний наказ прориватися через Ґібралтарську протоку в Середземне море. Люди, поставлені волею долі й обставинами в ситуацію, коли необхідно вбивати задля виживання, - ось головна думка цієї потужної драматичної стрічки. Солдати по обидві сторони фронту в будь-якій війні просто приречені бути жертвами."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Submarinul","runtime":149,"tagline":"Când vânătorii devin vânați.","homepage":"","overview":"O privire detaliată în lumea claustrofobă și terifiantă a echipajelor submarinelor germane care vânează vapoare de sub apă. Curajos, realist și condimentat cu umor negru, acest film este unul dintre puținele care îi prezintă cu compasiune pe nemți în timpul celui de-al Doilea Război Mondial."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Povandeninis laivas","runtime":0,"tagline":"","homepage":"","overview":"1942 metais Vokietija sutelkė visas jėgas kovai su priešais tiek sausumoje, tiek vandenyje. Tūkstančiai povandeninių laivų, kurių kodinis pavadinimas prasideda raide U, ieško ir naikina priešo laivų vilkstines. Filmas pasakoja apie tragišką vieno povandeninio laivo plaukiojimą. Visi jaučia karo pabaigą ir Vokietijos pralaimėjimą. Jūreiviams nusibodo karas, girti jie tyčiojasi iš vadų. Norėdama kariams pakelti dvasią vadovybė siunčia į povandeninį laivą karo korespondentą, kuris turi juostoje užfiksuoti drąsių jūreivių šiokiadienius. Iš pradžių viskas klostosi kuo puikiausiai. Tačiau netikėtai povandeninis laivas susiduria su anglų karo laivu. Įvyksta mūšis. Tą akimirką, kai laivo įgula rengiasi švęsti pergalę, jų laukia visiškas pralaimėjimas..."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"زیردریایی","runtime":0,"tagline":"","homepage":"","overview":"در سال 1942 ناوگان زیردریایی های آلمان در نبردی موسوم به نبرد آتلانتیک شروع به حملات پی در پی و نابود کردن قایق های انگلیسی می کنند، ولی با افزایش محافظت انگلیسی ها ناوگان زیردریایی های آلمانی متحمل یک زیان سنگین می شوند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"El Submarino","runtime":0,"tagline":"Cuando los cazadores se conviertan en presas.","homepage":"","overview":"Un submarino alemán de la Segunda Guerra Mundial es el escenario en el que un grupo de jóvenes soldados, dispuesto a defender su patria, tendrá que someterse a una dura convivencia, tras descubrir que han sido enviados a realizar una misión probablemente suicida."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Trận Chiến Tàu Ngầm","runtime":0,"tagline":"","homepage":"","overview":"Có thể nói, Das Boot là một trong những bộ phim hành động đáng xem nhất từ trước tới nay. Thấm trong từng thước phim, chính là những cảm giác hồi hộp và lạnh sống lưng đầy căng thẳng mà đạo diễn Wolfgang Peterson đã dày công xây dựng. Khoác lên mình một phong cách đầy mới mẻ, Das Boot giống như một bộ phim tài liệu xoay quanh chuyến hải trình của con tàu U-96 cùng những thủy thủ trên nó. Bộ phim cung cấp một cái nhìn vô cùng thuyết phục về chiến tranh dưới những máu và nước mắt trải dài trong tác phẩm, cũng như tình người và tình đồng đội được gây dựng lên từ cuộc sống chật chội nơi một con tàu ngầm."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"عندما يصبح الصيادون مطاردون.","homepage":"","overview":"غواصة ألمانية تطارد سفن الحلفاء خلال الحرب العالمية الثانية ، لكنها سرعان ما تصبح مطاردة. يحاول الطاقم البقاء على قيد الحياة تحت السطح ، بينما يمتد كل من القارب وأنفسهم إلى أقصى حدودهم."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Podmornica","runtime":0,"tagline":"Posada njemačke podmornice očajnički se bori za život","homepage":"","overview":"Godina je 1942., njemačka podmornička flota intenzivno je uključena u bitku na Atlantiku čiji je cilj potopiti engleske transportne brodove. Pratimo posadu koja u teškim uvjetima provodi naređenja nacističkog režima čiji kapetan polako gubi vezu sa stvarnošću preispitujući ideologiju režima kojem služi."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"อู 96 นรกใต้สมุทร","runtime":0,"tagline":"","homepage":"","overview":"ผลงานดราม่าสุดเข้มข้นลุ้นระทึกเรื่องนี้ได้เข้าชิงออสการ์หกสาขา กับเรื่องราวชีวิตอันยากลำบากของกลุ่มลูกเรือเยอรมันในเรือดำน้ำระหว่างช่วงสงครามโลกครั้งที่สอง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"El submarí","runtime":0,"tagline":"40000 homes van ser enviats als submarins alemanys ... 30000 mai van tornar.","homepage":"","overview":"Un submarí alemany de la Segona Guerra Mundial és l'escenari on un grup de joves soldats, disposat a defensar la seva pàtria, s'haurà de sotmetre a una dura convivència, després de descobrir que han estat enviats a fer una missió probablement suïcida."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Das Boot: Ühe allveelaeva lugu","runtime":0,"tagline":"Kui jahimeestest saab jahisaak.","homepage":"","overview":"Saksa allveelaev U96 asub missioonile, et anda oma panus Inglise laevastiku hävitamisele. Noor ja kogenenud sõjaväereporter Werner on pardal, et toimuvast kirjutada. Kui missioon ebaõnnestub ja laev pommitamises viga saab, jääb meeskond koos laevaga merepõhja lõksu..."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"စစ်သတင်းထောက် ဗိုလ်လေးတစ်ယောက်က ရေငုပ်သင်္ဘောတစ်စင်းပေါ်ကို စစ်ကြောင်းထွက်တဲ့အချိန် လိုက်လာပြီး မှတ်တမ်းတင် အစီရင်ခံစာ တင်ဖို့ပေါ့။ အဲဒီမှာ ကပ္ပတိန်ကြီးရဲ့ အုပ်ချုပ်ပုံ၊ တိုက်ပွဲဖြစ်တဲ့ခါ ညွန်ကြားပုံတွေ နောက်ပြီး ဒီသင်္ဘောကျင်းကျင်းလေးပေါ်က နေထိုင်စားသောက်ရတဲ့ ဘဝတွေ ကြုံရပုံ တစ်ဖက်က ထောက်ပို့ယာဉ်တန်းတွေ တွေ့ရင် ဘယ်လိုအမဲလိုက်ကြပုံ ပြန်ခံရရင်လည်း ဘယ်လိုတွေ ခွာစစ်ဆုတ်ရပုံတွေ ဟိုက်ဒရိုဖုန်းဆိုတာနဲ့ အရပ်လေးမျက်နှာက အသံတွေကို နားထောင်ပြီး သင်္ဘောတစ်စင်းလုံး အပ်ကျသံမကြားရလောက်အောင်ထိ တိတ်ဆိတ်သွားပြီး ရန်သူ့အခြေအနေ အကဲခတ်လှုပ်ရှားရပုံတွေ စသဖြင့် စိတ်လှုပ်ရှားစရာ ဖြစ်ရပ်တွေနဲ့ တင်ဆက်ပြသထားတာပါ။ နောက်ပြီး သူတို့ဘဝတွေက သူများကိုအမဲလိုက်ပြီး ကြမ်းတမ်းကြတယ်ဆိုပေမယ့် တစ်ခုခုဆို သူတို့ဘဝကလည်း လေတပ်ကလူတွေလိုမျိုးပဲ သေဖို့ရာခိုင်နှုန်းများတဲ့ တပ်သားတွေပါပဲ။ ၁၉၈၁ ခုနှစ်ထွက်ရုပ်ရှင်ဆိုပေမဲ့ တော်တော်လေးအဆင်ပြေပြီး အတွေ့အကြုံအသစ်တွေ ပေးစွမ်းနိုင်မှာမို့ ပြေးသာကြည့်ကြဖို့ တိုက်တွန်းလိုက်ပါတယ်ဗျာ။"},"name":"","iso_639_1":"my","iso_3166_1":"MY","english_name":"Burmese"},{"data":{"title":"Ubåten","runtime":208,"tagline":"","homepage":"","overview":"Dette spennende krigsdramaet ble nominert til seks Oscar-priser og følger de mange utfordringene som møtte et tysk ubåtmannskap under andre verdenskrig."},"name":"Bokmål","iso_639_1":"nb","iso_3166_1":"NO","english_name":"Norwegian Bokmål"},{"data":{"title":"Ubåten","runtime":208,"tagline":"","homepage":"","overview":"Dette spennende krigsdramaet ble nominert til seks Oscar-priser og følger de mange utfordringene som møtte et tysk ubåtmannskap under andre verdenskrig."},"name":"","iso_639_1":"nn","iso_3166_1":"NN","english_name":"Norwegian Nynorsk"},{"data":{"title":"","runtime":208,"tagline":"","homepage":"","overview":"Deze spannende, dramatische film, die werd genomineerd voor zes Oscars, volgt de beproevingen van de bemanning van een Duitse U-boot tijdens WOII."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"Na kopnem so sanjali, da bodo junaki. Pod morjem molijo, da bi preživeli.","homepage":"","overview":"Nemška podmornica med drugo svetovno vojno lovi zavezniške ladje, a kmalu postane lovljena. Posadka skuša preživeti pod gladino, pri tem pa do skrajnih meja razteza tako plovilo kot sebe."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Le Bateau","runtime":0,"tagline":"","homepage":"","overview":"En 1941, un correspondant de guerre allemand, Werner, prend place à bord d'un sous-marin qui s'en va faire la course dans l'Atlantique. Il prend contact avec la dure existence des sous-mariniers forcés de vivre à plusieurs dans des quartiers réduits. Il assiste à l'attaque d'un convoi et à la fuite précipitée du submersible à l'apparition d'un destroyer. Ayant reçu l'ordre de se rendre en Méditerranée, le commandant doit guider son vaisseau à travers le dangereux détroit de Gibraltar, ce qui ne va pas sans peine."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Zemūdene","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"}],"reviews_tmdb":[{"id":"5f63a4ec87f3f2003a820a39","url":"https://www.themoviedb.org/review/5f63a4ec87f3f2003a820a39","author":"Wuchak","content":"$11","created_at":"2020-09-17T18:03:24.706Z","updated_at":"2021-06-23T15:58:44.621Z","author_details":{"name":"","rating":7,"username":"Wuchak","avatar_path":"/4KVM1VkqmXLOuwj1jjaSdxbvBDk.jpg"}},{"id":"65890452b7b69d08b36d9a4b","url":"https://www.themoviedb.org/review/65890452b7b69d08b36d9a4b","author":"janeyee","content":"$12","created_at":"2023-12-25T04:25:54.692Z","updated_at":"2023-12-27T18:50:49.409Z","author_details":{"name":"","rating":10,"username":"janeyee","avatar_path":null}},{"id":"671b5550427c5c19f025e43a","url":"https://www.themoviedb.org/review/671b5550427c5c19f025e43a","author":"CinemaSerf","content":"$13","created_at":"2024-10-25T08:22:40.831Z","updated_at":"2024-10-25T08:22:40.948Z","author_details":{"name":"CinemaSerf","rating":8,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":826,"adult":false,"title":"The Bridge on the River Kwai","video":false,"overview":"The classic story of English POWs in Burma forced to build a bridge to aid the war effort of their Japanese captors. British and American intelligence officers conspire to blow up the structure, but Col. Nicholson, the commander who supervised the bridge's construction, has acquired a sense of pride in his creation and tries to foil their plans.","genre_ids":[18,36,10752],"media_type":"movie","popularity":3.7462,"vote_count":2315,"poster_path":"/7paXMt2e3Tr5dLmEZOGgFEn2Vo7.jpg","release_date":"1957-10-11","vote_average":7.819,"backdrop_path":"/dRHfCeAoJ6SsMffQ6lavNU9E55z.jpg","original_title":"The Bridge on the River Kwai","original_language":"en"},{"id":10764,"adult":false,"title":"Quantum of Solace","video":false,"overview":"Betrayed by Vesper, the woman he loved, 007 fights the urge to make his latest mission personal. Pursuing his determination to uncover the truth, Bond and M interrogate Mr. White, who reveals that the organization that blackmailed Vesper is far more complex and dangerous than anyone had imagined.","genre_ids":[12,28,53,80],"media_type":"movie","popularity":7.0769,"vote_count":8377,"poster_path":"/e3DXXLJHGqMx9yYpXsql1XNljmM.jpg","release_date":"2008-10-29","vote_average":6.334,"backdrop_path":"/3CqMIX3ZlrD0pU3fpBL6DM0Cneb.jpg","original_title":"Quantum of Solace","original_language":"en"},{"id":60309,"adult":false,"title":"The Conspirator","video":false,"overview":"Mary Surratt is the lone female charged as a co-conspirator in the assassination trial of Abraham Lincoln. As the whole nation turns against her, she is forced to rely on her reluctant lawyer to uncover the truth and save her life.","genre_ids":[80,18,36],"media_type":"movie","popularity":1.0297,"vote_count":481,"poster_path":"/a2ubkGUjGYeKRN1C2Tib0rmjuWf.jpg","release_date":"2011-04-15","vote_average":6.6,"backdrop_path":"/i4YjA78Tf60YW5tfBJmW8Q8X1QU.jpg","original_title":"The Conspirator","original_language":"en"},{"id":13612,"adult":false,"title":"Cheech & Chong's Next Movie","video":false,"overview":"Perennially stoned Cheech and Chong tear through the city of Los Angeles, causing trouble wherever they go. After Cheech loses his job, the two pot enthusiasts head to the welfare offices where Cheech's girlfriend, Donna, works. Instead of collecting unemployment, they find themselves thrown back on the streets, searching for a way to earn new income. But when Cheech's cousin, \"Red\" Mendoza, arrives, things get even crazier.","genre_ids":[28,12,35],"media_type":"movie","popularity":0.8095,"vote_count":259,"poster_path":"/hetHB9L84jOLxajKZLKgaNBRDJ9.jpg","release_date":"1980-07-18","vote_average":5.963,"backdrop_path":"/77hMVxYiR5JTeMo0ppU6Kpfhuej.jpg","original_title":"Cheech & Chong's Next Movie","original_language":"en"},{"id":42513,"adult":false,"title":"Two English Girls","video":false,"overview":"In the early 20th-century, Frenchman Claude meets Englishwoman Ann in Paris. Ann invites him to her family home, intending him for her sister Muriel. Claude falls for Muriel, but families demand year-long separation before approving marriage.","genre_ids":[18,10749],"media_type":"movie","popularity":0.3742,"vote_count":159,"poster_path":"/2fc5hjuzJbkVKXLy0SoAr2Hbdy2.jpg","release_date":"1971-11-18","vote_average":6.9,"backdrop_path":"/tXoYHLjqZYNIWeLc6g8QCaMNsG8.jpg","original_title":"Les Deux Anglaises et le Continent","original_language":"fr"},{"id":564147,"adult":false,"title":"K.G.F: Chapter 1","video":false,"overview":"A period drama set in the 1970s, KGF follows the story of a fierce rebel who rises against the brutal oppression in Kolar Gold Fields and becomes the symbol of hope to legions of downtrodden people.","genre_ids":[28,53,12,80],"media_type":"movie","popularity":2.3744,"vote_count":264,"poster_path":"/ltHlJwvxKv7d0ooCiKSAvfwV9tX.jpg","release_date":"2018-12-20","vote_average":7.462,"backdrop_path":"/4i1ofsSpfTuswHXcgPtXbZrSnoe.jpg","original_title":"ಕೆಜಿಎಫ್ ಅಧ್ಯಾಯ ೧","original_language":"kn"},{"id":582,"adult":false,"title":"The Lives of Others","video":false,"overview":"In 1984 East Berlin, dedicated Stasi officer Gerd Wiesler begins spying on a famous playwright and his actress-lover Christa-Maria. Wiesler becomes unexpectedly sympathetic to the couple, and faces conflicting loyalties when his superior takes a liking to Christa-Maria.","genre_ids":[18,53],"media_type":"movie","popularity":3.517,"vote_count":4019,"poster_path":"/cVUDMnskSc01rdbyH0tLATTJUdP.jpg","release_date":"2006-03-23","vote_average":8.037,"backdrop_path":"/g11nKgir3nIhlG2gIDWIvJeR4fz.jpg","original_title":"Das Leben der Anderen","original_language":"de"},{"id":4787,"adult":false,"title":"Cassandra's Dream","video":false,"overview":"The tale of two brothers with serious financial woes. When a third party proposes they turn to crime, things go bad and the two become enemies.","genre_ids":[80,18,53],"media_type":"movie","popularity":0.7369,"vote_count":816,"poster_path":"/rZLKa5mXJzfmJsC9DFNkcpZ5vS0.jpg","release_date":"2007-10-31","vote_average":6.3,"backdrop_path":"/5Xb2e63jvhJqL6IUO2SqtuRIJRG.jpg","original_title":"Cassandra's Dream","original_language":"en"},{"id":3536,"adult":false,"title":"U-571","video":false,"overview":"In the midst of World War II, the battle under the sea rages and the Nazis have the upper hand as the Allies are unable to crack their war codes. However, after a wrecked U-boat sends out an SOS signal, the Allies realise this is their chance to seize the 'enigma coding machine'.","genre_ids":[10752,28,12],"media_type":"movie","popularity":2.0114,"vote_count":1318,"poster_path":"/7lc7jXmjQmITnfUBX7nN4kxKKbI.jpg","release_date":"2000-04-20","vote_average":6.519,"backdrop_path":"/lLWTiGXchR54rGizSIdK9Ibaylx.jpg","original_title":"U-571","original_language":"en"},{"id":625,"adult":false,"title":"The Killing Fields","video":false,"overview":"New York Times reporter Sydney Schanberg is on assignment covering the Cambodian Civil War, with the help of local interpreter Dith Pran and American photojournalist Al Rockoff. When the U.S. Army pulls out amid escalating violence, Schanberg makes exit arrangements for Pran and his family. Pran, however, tells Schanberg he intends to stay in Cambodia to help cover the unfolding story — a decision he may regret as the Khmer Rouge rebels move in.","genre_ids":[18,36,10752],"media_type":"movie","popularity":2.1893,"vote_count":808,"poster_path":"/cX6Bv7natnZwQjsV9bLL8mmWjkS.jpg","release_date":"1984-11-23","vote_average":7.459,"backdrop_path":"/c7OeJd34rc9bI1DXqd4ucb1wVrf.jpg","original_title":"The Killing Fields","original_language":"en"},{"id":9343,"adult":false,"title":"Fitzcarraldo","video":false,"overview":"Fitzcarraldo is a dreamer who plans to build an opera house in Iquitos, in the Peruvian Amazon, so, in order to finance his project, he embarks on an epic adventure to collect rubber, a very profitable product, in a remote and unexplored region of the rainforest.","genre_ids":[18,12],"media_type":"movie","popularity":1.3438,"vote_count":855,"poster_path":"/oBCnYEKcg1rMhr5JjDnrRpilvDd.jpg","release_date":"1982-03-02","vote_average":7.619,"backdrop_path":"/46iMqI1qzAtnXJxGRNCFwYNYqOo.jpg","original_title":"Fitzcarraldo","original_language":"de"},{"id":17962,"adult":false,"title":"After Life","video":false,"overview":"On a cold Monday morning, a group of counselors clock in at an old-fashioned social services office. Their task is to interview the recently deceased, record their personal details, then, over the course of the week, assist them in choosing a single memory to keep for eternity.","genre_ids":[14,18],"media_type":"movie","popularity":1.4057,"vote_count":264,"poster_path":"/bs2M1hqAQl5LeAOPPRV4drwouZS.jpg","release_date":"1999-04-17","vote_average":7.157,"backdrop_path":"/pXOsdvH4xuprxGmZMiCJsRAowi7.jpg","original_title":"ワンダフルライフ","original_language":"ja"},{"id":11082,"adult":false,"title":"The Seventh Sign","video":false,"overview":"Abby is a pregnant woman with a curious new boarder in the apartment over her garage. Turns out he's heaven-sent and is speeding along the Apocalypse by bloodying rivers, egging on plagues and following scripture word for word.","genre_ids":[27,18,53],"media_type":"movie","popularity":1.2449,"vote_count":371,"poster_path":"/vAgVzkPmfe2pcgzkpoz8cZ9i9wm.jpg","release_date":"1988-04-01","vote_average":6.012,"backdrop_path":"/p7WX6g9zwKvNAnvSS56Iul7r0lO.jpg","original_title":"The Seventh Sign","original_language":"en"},{"id":10725,"adult":false,"title":"Wolfen","video":false,"overview":"A New York City cop and an expert criminologist trying to solve a series of grisly deaths in which the victims have seemingly been maimed by feral animals discover a sinister connection between the crimes and an old legend.","genre_ids":[27,53],"media_type":"movie","popularity":3.6851,"vote_count":253,"poster_path":"/hb4TJBeElGyIa7tmF2466iwwItB.jpg","release_date":"1981-07-24","vote_average":5.929,"backdrop_path":"/2emn3D5215BfQrMBNXGV9Y8xInJ.jpg","original_title":"Wolfen","original_language":"en"},{"id":49398,"adult":false,"title":"Quarter to Two Before Jesus Christ","video":false,"overview":"In antique Rome, a simple pepboy for chars becomes involved in a coup against Cesar.  Rahatlocum is a North African Roman colony where Julius Caesar came to spend an expensive holiday. The revolt rumbles among the small people who find a leader in the person of Ben-Hur Marcel.","genre_ids":[35],"media_type":"movie","popularity":1.1328,"vote_count":197,"poster_path":"/ge2B2hzlaSpN8SCnBRwSq8m2mg4.jpg","release_date":"1982-10-06","vote_average":6.051,"backdrop_path":"/oBtAhRbnXCDawtBiXF169WrXpbF.jpg","original_title":"Deux heures moins le quart avant Jésus-Christ","original_language":"fr"},{"id":49982,"adult":false,"title":"A City of Sadness","video":false,"overview":"The story of a family embroiled in the \"White Terror,\" the Kuomintang government's anti-communist political repression that was wrought on the Taiwanese people from 1947-1987.","genre_ids":[18,36],"media_type":"movie","popularity":1.135,"vote_count":147,"poster_path":"/n1aIYLgnrlsUrh77G2OdQT9NV1.jpg","release_date":"1989-10-21","vote_average":7.5,"backdrop_path":"/fClREI48zqOyESHlP5SZAgFfp3k.jpg","original_title":"悲情城市","original_language":"zh"},{"id":35412,"adult":false,"title":"On the Beach","video":false,"overview":"In 1964, atomic war wipes out humanity in the northern hemisphere; one American submarine finds temporary safe haven in Australia, where life-as-usual covers growing despair. In denial about the loss of his wife and children in the holocaust, American Captain Towers meets careworn but gorgeous Moira Davidson, who begins to fall for him. The sub returns after reconnaissance a month (or less) before the end; will Towers and Moira find comfort with each other?","genre_ids":[878,18,10749],"media_type":"movie","popularity":1.8664,"vote_count":229,"poster_path":"/lTDuj5zalrI0fpQel7UfPHTexTK.jpg","release_date":"1959-12-17","vote_average":6.659,"backdrop_path":"/kiRjFt3UYI8j75h7JVlvz0jM1NM.jpg","original_title":"On the Beach","original_language":"en"},{"id":10670,"adult":false,"title":"Rollercoaster","video":false,"overview":"A young terrorist kills and injures patrons of a Norfolk amusement park by placing homemade explosives on the track of one of its roller coasters. After staging a similar incident in Pittsburgh, he sends a tape to a meeting of major amusement park executives in Chicago, demanding $1 million to make him stop.","genre_ids":[28,53],"media_type":"movie","popularity":0.7989,"vote_count":151,"poster_path":"/dy23SSGZDp3dftzhDvHXOEM6OaN.jpg","release_date":"1977-06-10","vote_average":5.967,"backdrop_path":"/pXUs9wl6jyTdarMLVcQ00pPhEPt.jpg","original_title":"Rollercoaster","original_language":"en"},{"id":380808,"adult":false,"title":"Zero Days","video":false,"overview":"Alex Gibney explores the phenomenon of Stuxnet, a self-replicating computer virus discovered in 2010 by international IT experts. Evidently commissioned by the US and Israeli governments, this malware was designed to specifically sabotage Iran’s nuclear programme. However, the complex computer worm ended up not only infecting its intended target but also spreading uncontrollably.","genre_ids":[99],"media_type":"movie","popularity":1.1177,"vote_count":250,"poster_path":"/xwQVkRJGCH59jGNPR78Aw8wzyZg.jpg","release_date":"2016-07-08","vote_average":7.358,"backdrop_path":"/ib2aD7GJwQZj5vyaPLZEIWnGgUw.jpg","original_title":"Zero Days","original_language":"en"},{"id":21494,"adult":false,"title":"Moliere","video":false,"overview":"Molière, a down-and-out actor-cum-playwright up to his ears in debt. When the wealthy Jourdain offers to cover that debt so that Molière's theatrical talents might help Jourdain win the heart of a certain widowed marquise, hilarity ensues.","genre_ids":[10749,18,35],"media_type":"movie","popularity":1.69,"vote_count":199,"poster_path":"/3nfp9JCCzt1QlRhEzQfz5EkjLYn.jpg","release_date":"2007-01-31","vote_average":6.432,"backdrop_path":"/9t328N5MiH6QgCkeEswUi5WSA3o.jpg","original_title":"Molière","original_language":"fr"}],"similar_content":[{"id":661539,"adult":false,"title":"A Complete Unknown","video":false,"overview":"New York, early 1960s. Against the backdrop of a vibrant music scene and tumultuous cultural upheaval, an enigmatic 19-year-old from Minnesota arrives in the West Village with his guitar and revolutionary talent, destined to change the course of American music.","genre_ids":[18,10402],"popularity":6.2729,"vote_count":1369,"poster_path":"/llWl3GtNoXosbvYboelmoT459NM.jpg","release_date":"2024-12-25","vote_average":7.081,"backdrop_path":"/kcCy5tKTe6WepVQ6SQaSewpmoCj.jpg","original_title":"A Complete Unknown","original_language":"en"},{"id":8417,"adult":false,"title":"Süss, the Jew","video":false,"overview":"Nazi historical drama about Duke Karl Alexander of Württemberg and his treasurer Süß Oppenheimer.","genre_ids":[18,36],"popularity":0.3031,"vote_count":45,"poster_path":"/3fN1p4OY7Mi0zXQqMJvCdhRwEYs.jpg","release_date":"1940-09-24","vote_average":4.3,"backdrop_path":"/4msV23h4lRFXQoOUUL8Oc0XTcxt.jpg","original_title":"Jud Süß","original_language":"de"},{"id":8434,"adult":false,"title":"Summer Things","video":false,"overview":"Two couple of friends, one very rich, the other almost homeless, decide to go on Holiday. Julie, a single mother, joins them too. Once at seaside, it starts a complicate love cross among them that will involve also a transsexual, a jealous brother, a Latin Lover and another nervous stressed couple. Not to mention about the daughter of one of them that is secretly in Chicago with one of her father's employees... At the end of the summer, all of them will join the same party...","genre_ids":[35,18,10749],"popularity":0.5262,"vote_count":102,"poster_path":"/laV4Xo5O1COZefAFPJLFZ28pkYS.jpg","release_date":"2002-03-04","vote_average":5.809,"backdrop_path":"/azkp4brPsmzJiyKw5ExkPDrVpWA.jpg","original_title":"Embrassez qui vous voudrez","original_language":"fr"},{"id":8435,"adult":false,"title":"A Cock and Bull Story","video":false,"overview":"Steve Coogan, an arrogant actor with low self-esteem and a complicated love life, is playing the eponymous role in an adaptation of \"The Life and Opinions of Tristram Shandy, Gentleman\" being filmed at a stately home. He constantly spars with actor Rob Brydon, who is playing Uncle Toby and believes his role to be of equal importance to Coogan's.","genre_ids":[35,36],"popularity":0.6497,"vote_count":148,"poster_path":"/g14QNhGkWLviBr18nCGDB1U8w8f.jpg","release_date":"2005-07-17","vote_average":6.149,"backdrop_path":"/8MWKVstOmGUlCsS80iPTHDH7N22.jpg","original_title":"A Cock and Bull Story","original_language":"en"},{"id":661436,"adult":false,"title":"An Accident","video":false,"overview":"In the 1980s, the building themes were transformed into bipolar moral dilemmas involving overly ambitious individuals who wanted to excel at any cost. The hero is the head of a demolition crew that demolishes large buildings, initially a sympathetic young man who, in the pursuit of career and accolades, begins to transgress the boundaries of what was then called socialist morality and legality. He gradually finds himself at odds with the principles of ordinary but honest people. The narrative's bland, proclamatory film is closely connected to its time of creation, and there are hardly any more timeless insights to be found.","genre_ids":[18],"popularity":0.2665,"vote_count":0,"poster_path":"/iFKRA8kCddfN0B23EXbSW3sOgI4.jpg","release_date":"1986-09-01","vote_average":0,"backdrop_path":null,"original_title":"Havárie","original_language":"cs"},{"id":8326,"adult":false,"title":"Holes","video":false,"overview":"After being wrongfully convicted for stealing a pair of shoes, Stanley Yelnats is sent away to Camp Green Lake, a boys detention facility where inmates are forced to dig holes all day in the hot desert sun as a form of character building. But Stanley and the other boys start to unravel a mystery, linked with the camps tough-as-nails warden —and possibly Stanley’s family itself.","genre_ids":[12,10751,18,35],"popularity":3.4761,"vote_count":1508,"poster_path":"/o2Dm2mcE1qW8vT0bpsJO5OMBbqa.jpg","release_date":"2003-04-18","vote_average":6.897,"backdrop_path":"/cVMK2k0Wbs8DV3IK5sS4ziVenrI.jpg","original_title":"Holes","original_language":"en"},{"id":8338,"adult":false,"title":"Blindness","video":false,"overview":"When a sudden plague of blindness devastates a city, a small group of the afflicted band together to triumphantly overcome the horrific conditions of their imposed quarantine.","genre_ids":[18,9648,878,53],"popularity":5.8895,"vote_count":1340,"poster_path":"/deBsx5IxyqCC217j3VY24TkkE0Z.jpg","release_date":"2008-05-14","vote_average":6.514,"backdrop_path":"/sN0czEtCT1jEFQVajWBsKwdFBKm.jpg","original_title":"Blindness","original_language":"en"},{"id":661475,"adult":false,"title":"Apinan vuosi","video":false,"overview":"A young student seeks direction in his life to counterbalance the studies through female adventures.","genre_ids":[18,35],"popularity":0.424,"vote_count":2,"poster_path":"/2OnmxCt66lXG1MuSky901gwGruq.jpg","release_date":"1983-11-11","vote_average":7,"backdrop_path":"/7XvomNV2M9UqZEa87IRk69F441R.jpg","original_title":"Apinan vuosi","original_language":"fi"},{"id":471103,"adult":false,"title":"The Fight for Rome II - The Betrayal","video":false,"overview":"The devious general Cethegus plays the Byzantine and Gothic forces against each other for his own gain.","genre_ids":[18,12,36],"popularity":0.2616,"vote_count":5,"poster_path":"/mSCCFODBAn6HE1fY3jbRegPJWZ0.jpg","release_date":"1969-02-21","vote_average":7,"backdrop_path":"/tM5nwmohCwKInwqbHyQ8WX9W75E.jpg","original_title":"Kampf um Rom II - Der Verrat","original_language":"de"},{"id":471276,"adult":false,"title":"Special Mission","video":false,"overview":"The exploits of Chief Police Inspector Chabrier, first before the invasion of France in May 1940 as he fights against spies preparing the coming the Germans, particularly Emmy de Welder, the alleged manager of the Rouen hospital. Later, Chabrier and his men go underground and resist the occupiers whatever the price to pay. When the Liberation comes Chabrier resumes his activities at the French National Police.","genre_ids":[18,10752,53],"popularity":0.6229,"vote_count":1,"poster_path":"/eafYCoecKlR76V9qKjhbB5s2wkw.jpg","release_date":"1946-03-08","vote_average":5,"backdrop_path":null,"original_title":"Mission spéciale","original_language":"fr"},{"id":8619,"adult":false,"title":"Master and Commander: The Far Side of the World","video":false,"overview":"After an abrupt and violent encounter with a French warship inflicts severe damage upon his ship, a captain of the British Royal Navy begins a chase over two oceans to capture or destroy the enemy, though he must weigh his commitment to duty and ferocious pursuit of glory against the safety of his devoted crew, including the ship's thoughtful surgeon, his best friend.","genre_ids":[12,18,10752],"popularity":3.6584,"vote_count":3437,"poster_path":"/s1cVTQEZYn4nSjZLnFbzLP0j8y2.jpg","release_date":"2003-11-14","vote_average":7.181,"backdrop_path":"/zMHyNxNt4zhL939XX8QLBW3gWfu.jpg","original_title":"Master and Commander: The Far Side of the World","original_language":"en"},{"id":8649,"adult":false,"title":"Bringing Out the Dead","video":false,"overview":"Once called \"Father Frank\" for his efforts to rescue lives, Frank Pierce sees the ghosts of those he failed to save around every turn. He has tried everything he can to get fired, calling in sick, delaying taking calls where he might have to face one more victim he couldn't help, yet cannot quit the job on his own.","genre_ids":[18],"popularity":3.3849,"vote_count":1191,"poster_path":"/gE2Q8mL0m0EA6HakRyc92uzSPJn.jpg","release_date":"1999-10-22","vote_average":6.607,"backdrop_path":"/A1V1suhllQJ1CTrKpCulcM7mjyj.jpg","original_title":"Bringing Out the Dead","original_language":"en"},{"id":1460515,"adult":false,"title":"Out of Darkness","video":false,"overview":"How does a divorced, abused and suicidal woman become one of the most successful authors in history, redeeming marriages all over the globe? This incredible true and vulnerable story of God’s healing and redemption starts before Stormie Omartian’s successful book career. In 1970’s Hollywood, Stormie was a young and ambitious actress, navigating a path filled with career setbacks and a tumultuous marriage. Amidst her journey, she encountered Michael Omartian, a music producer who sparked her spiritual curiosity. As she grappled with accepting God’s unconditional love, Stormie was forced to confront her past traumas to break free from the darkness that consumed her.","genre_ids":[18],"popularity":0.1856,"vote_count":0,"poster_path":null,"release_date":"","vote_average":0,"backdrop_path":null,"original_title":"Out of Darkness","original_language":"en"},{"id":8665,"adult":false,"title":"K-19: The Widowmaker","video":false,"overview":"When Russia's first nuclear submarine malfunctions on its maiden voyage, the crew must race to save the ship and prevent a nuclear disaster.","genre_ids":[18,36,53,9648,10752],"popularity":1.8733,"vote_count":1135,"poster_path":"/vImR0HQkJs7Xs2qgdXEUDeX49m0.jpg","release_date":"2002-07-19","vote_average":6.5,"backdrop_path":"/puleizXkdZrYW9641MZHj7IhAY4.jpg","original_title":"K-19: The Widowmaker","original_language":"en"},{"id":8680,"adult":false,"title":"The Shell Seekers","video":false,"overview":"Penelope Keeling, a sixty-four-year-old daughter of a famous artist, reflects on her life, and the fate and choices that defined it, when she arrives in the Mediterranean to stay with her headstrong daughter. Shifting through time, and falling into place like the pieces of a jigsaw, the truth of Penelope's rich, heartbreaking and surprising life unfolds.","genre_ids":[18,10749],"popularity":0.3819,"vote_count":7,"poster_path":"/y7oxk0TY47vpJ1v2kcnYak0GKkX.jpg","release_d