1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/peSgNSsqiJnBxQ4KyEZ688aMVc3.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/wCLkzvkxVbuPAkWoOLpyqJRsKpr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2000,"height":1125,"file_path":"/a238v1JPkU2q0dgYJWSODfiNyRy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/ylBBozbkhoyuJS1o6ckvb40wg8N.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/xpqQEc5IlRjJ4MZmhN65XKfW1tn.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T05:55:26.642+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":90,"tagline":"","homepage":"https://www.ace-entertainment.com/originalcontent/murder-at-the-embassy","overview":"1934. Private detective Miranda Green investigates a murder perpetrated in the British Embassy in Cairo, where a top secret document was stolen, risking to jeopardize both Buckingham Palace and the peace of the world. All those present in this closed place are suspected: the American photographer, the English student, the American actress, the Egyptian security guard, the ambassador interpreter, the Egyptian gardener and - why not? — the Ambassador himself. But who would have expected that a small group of Nazis would be behind a plot, risking to jeopardize both Buckingham Palace and the peace of the world?"},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"La Reine du crime présente : Meurtre à l'Ambassade","runtime":0,"tagline":"","homepage":"https://miniproductions.co.uk/murder-at-the-embassy/","overview":"1934. Miranda Green, détective privée, enquête sur un meurtre perpétré à l'ambassade britannique du Caire, où un document top secret a été volé, mettant en péril à la fois le palais de Buckingham et la paix du monde."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"大使馆谋杀案","runtime":0,"tagline":"","homepage":"","overview":"1934年，私家侦探米兰达·格林调查英国驻开罗大使馆发生的一起谋杀案，而谋杀案中一份绝密文件的被盗，将危及白金汉宫，震惊世界。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"大使館謀殺案","runtime":0,"tagline":"","homepage":"","overview":"1934年，私家偵探米蘭達·格林調查了一起發生在英國駐開羅大使館的謀殺案，一份絕密文件被盜，危及白金漢宮和世界和平。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"1934. Privédetective Miranda Green onderzoekt een moord die is gepleegd in de Britse ambassade in Caïro, waar een ultrageheim document is gestolen — een die zowel Buckingham Palace als de wereldvrede in gevaar kan brengen. Iedereen die zich in dit afgesloten gebouw bevond, staat onder verdenking: de Amerikaanse fotograaf, de Engelse student, de Amerikaanse actrice, de Egyptische beveiligingsmedewerker, de tolk van de ambassade, de Egyptische tuinman en — waarom niet? — de ambassadeur zelf. Maar wie had kunnen vermoeden dat een kleine groep nazi’s achter een complot zat dat zowel Buckingham Palace als de wereldvrede zou kunnen bedreigen?"},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"1934. Miranda Green, détective privée, enquête sur un meurtre perpétré à l'ambassade britannique du Caire, où un document top secret a été volé, mettant en péril à la fois le palais de Buckingham et la paix du monde."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"","runtime":83,"tagline":"","homepage":"","overview":"1934. Miranda Green, detective privada, investiga un asesinato perpetrado en la embajada británica en El Cairo, donde se robó un documento de alto secreto, con el riesgo de poner en peligro el Palacio de Buckingham y la paz del mundo."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Asesinato en la Embajada","runtime":83,"tagline":"","homepage":"","overview":"1934. Miranda Green, detective privada, investiga un asesinato perpetrado en la embajada británica en El Cairo, donde se robó un documento de alto secreto, con el riesgo de poner en peligro el Palacio de Buckingham y la paz del mundo."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"მკვლელობა საელჩოში","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Umor na veleposlaništvu","runtime":0,"tagline":"","homepage":"","overview":"Leto 1934. Zasebna detektivka Miranda Green preiskuje umor, storjen na britanskem veleposlaništvu v Kairu, kjer je bil ukraden strogo zaupni dokument, katerega izginotje bi lahko ogrozilo tako Buckinghamsko palačo kot svetovni mir."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Убийство в посольстве","runtime":0,"tagline":"","homepage":"","overview":"1934 год. Частный детектив Миранда Грин расследует убийство, совершенное в посольстве Великобритании в Каире, где был похищен сверхсекретный документ. Его исчезновение ставит под угрозу как репутацию Букингемского дворца, так и мировое спокойствие."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"قتل در سفارت","runtime":0,"tagline":"","homepage":"","overview":"سال 1934، یک کارآگاه خصوصی به‌نام میراندا گرین، پرونده قتلی در سفارتخانه انگلیس در قاهره را قبول می‌کند. در کنار قتل، مدارکی دزدیده شده که اگر کارآگاه گرین این پرونده را هرچه سریع‌تر حل نکند، امنیت کاخ باکینگهام و صلح جهانی به خطر می‌افتد."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Án Mạng ở Tòa Đại Sứ","runtime":0,"tagline":"","homepage":"","overview":"Cairo, 1934. Một án mạng trong Đại sứ quán Anh, một tài liệu tuyệt mật biến mất và danh sách nghi phạm kéo dài từ nhiếp ảnh gia Mỹ đến chính vị Đại sứ. Khi Miranda Green lần theo dấu vết, một âm mưu phát xít dần hiện hình, đe dọa Buckingham Palace và cả hòa bình thế giới."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Morderstwo w ambasadzie","runtime":83,"tagline":"","homepage":"","overview":"Kiedy prywatna detektyw zostaje wezwana do zbadania podejrzanego morderstwa w brytyjskiej ambasadzie w Kairze, odkrywa, że ​​popełniono też drugą zbrodnię, która może wywołać wojnę na całym świecie. Wszyscy w murach ambasady są podejrzani, ale największe zło czai się tuż za rogiem. Mischa Barton jako Miranda Green. Film trzyma w napięciu do ostatniej klatki i nie sposób zgadnąć, kto pociągnął za spust!"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"1934. Miranda Green, uma detetive particular, investiga um assassinato cometido na embaixada britânica no Cairo, onde um documento ultrassecreto foi roubado, com o risco de colocar em risco o Palácio de Buckingham e a paz mundial."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"רצח בשגרירות","runtime":83,"tagline":"","homepage":"","overview":"בשנת 1934. הבלשית הפרטית מירנדה גרין חוקרת מקרה רצח שהתרחש בשגרירות הבריטית בקהיר. במקביל לרצח, נגנב מסמך סודי ביותר, והאירוע מאיים לסכן הן את ארמון בקינגהאם והן את שלום העולם כולו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Crima de la ambasadă","runtime":83,"tagline":"","homepage":"","overview":"1934. Detectiva privată Miranda Green investighează o crimă comisă la Ambasada Britanică din Cairo, unde un document secret a fost furat, amenințând nu doar Palatul Buckingham, ci însăși pacea lumii."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[{"id":77,"adult":false,"title":"Memento","video":false,"overview":"Leonard Shelby is tracking down the man who raped and murdered his wife. The difficulty of locating his wife's killer, however, is compounded by the fact that he suffers from a rare, untreatable form of short-term memory loss. Although he can recall details of life before his accident, Leonard cannot remember what happened fifteen minutes ago, where he's going, or why.","genre_ids":[9648,53],"popularity":9.3686,"vote_count":15929,"poster_path":"/fKTPH2WvH8nHTXeBYBVhawtRqtR.jpg","release_date":"2000-10-11","vote_average":8.176,"backdrop_path":"/7Wev9JMo6R5XAfz2KDvXb7oPMmy.jpg","original_title":"Memento","original_language":"en"},{"id":192,"adult":false,"title":"The Name of the Rose","video":false,"overview":"14th-century Franciscan monk William of Baskerville and his young novice arrive at a conference to find that several monks have been murdered under mysterious circumstances. To solve the crimes, William must rise up against the Church's authority and fight the shadowy conspiracy of monastery monks using only his intelligence; which is considerable.","genre_ids":[18,53,9648],"popularity":4.4982,"vote_count":3253,"poster_path":"/d6dlbTBb3N7nXDz7tQslDJs2jgv.jpg","release_date":"1986-09-24","vote_average":7.492,"backdrop_path":"/v4d6PPfqHeUNSdcyBVQ2Xb8yBk0.jpg","original_title":"The Name of the Rose","original_language":"en"},{"id":1592,"adult":false,"title":"Primal Fear","video":false,"overview":"Defense attorney Martin Vail takes on jobs for money and prestige rather than any sense of the greater good. His latest case involves an altar boy, accused of brutally murdering the archbishop of Chicago. Vail finds himself up against his ex-pupil and ex-lover, but as the case progresses and the Church's dark secrets are revealed, Vail finds that what appeared a simple case takes on a darker, more dangerous aspect.","genre_ids":[80,18,9648,53],"popularity":6.9055,"vote_count":3788,"poster_path":"/qJf2TzE8nRTFbFMPJNW6c8mI0KU.jpg","release_date":"1996-03-06","vote_average":7.656,"backdrop_path":"/dZM71rHXh3Oo3WZlw8YpMMsoVB5.jpg","original_title":"Primal Fear","original_language":"en"},{"id":1841,"adult":false,"title":"Lady in the Lake","video":false,"overview":"Private eye Phillip Marlowe wants to get out of the detective racket and into crime writing. But when he's called to the office of editor Adrienne Fromsett, it's not to talk about his story ideas — she wants him to locate the missing wife of her boss, Mr. Kingsby. The assignment quickly becomes complicated when bodies start turning up.","genre_ids":[9648,53,80],"popularity":0.4277,"vote_count":110,"poster_path":"/15iAyxIgD8bKqwKALaVJ5vf5pBt.jpg","release_date":"1946-12-19","vote_average":5.991,"backdrop_path":"/tm4yDVgjqQxqOugvnGONpmTbWP8.jpg","original_title":"Lady in the Lake","original_language":"en"},{"id":1847,"adult":false,"title":"The Long Goodbye","video":false,"overview":"In 1970s Hollywood, Detective Philip Marlowe tries to help a friend who is accused of murdering his wife.","genre_ids":[9648,18,80],"popularity":1.5042,"vote_count":738,"poster_path":"/oBhUK54yBJ0aH6u9zCzSV5iV7OP.jpg","release_date":"1973-03-08","vote_average":7.406,"backdrop_path":"/g3KOnOycUThwV4PRjtiAK0CuzID.jpg","original_title":"The Long Goodbye","original_language":"en"},{"id":1939,"adult":false,"title":"Laura","video":false,"overview":"A police detective falls in love with the woman whose murder he's investigating.","genre_ids":[18,9648],"popularity":1.31,"vote_count":885,"poster_path":"/j0zEiFFrdbZnMXqD3piOtZBJeNB.jpg","release_date":"1944-10-11","vote_average":7.6,"backdrop_path":"/d5HjGve67GkNC9lWpzZVKSotLlT.jpg","original_title":"Laura","original_language":"en"},{"id":1949,"adult":false,"title":"Zodiac","video":false,"overview":"Over the course of a decade, editors of the San Francisco Chronicle entice themselves in the murders of the Zodiac Killer. However, as time runs its course, interest in the case dwindles in the eyes of the professionals. The Killer stops interacting with the public. However, believing he has the answers, an amateur cartoonist from the initial sightings races against time to prevent what he believes is another murder.","genre_ids":[80,9648,53],"popularity":8.8947,"vote_count":11350,"poster_path":"/6YmeO4pB7XTh8P8F960O1uA14JO.jpg","release_date":"2007-03-02","vote_average":7.527,"backdrop_path":"/3zCPI4JFc54xvLaJ71oI2KoP3az.jpg","original_title":"Zodiac","original_language":"en"},{"id":1958,"adult":false,"title":"8 Women","video":false,"overview":"Eight women gather to celebrate Christmas in a snowbound cottage, only to find the family patriarch dead with a knife in his back. Trapped in the house, every woman becomes a suspect, each having her own motive and secret.","genre_ids":[35,53,9648],"popularity":1.4594,"vote_count":1049,"poster_path":"/bJu4Gm7NQb2woPiIovrPD5jNWzf.jpg","release_date":"2002-02-06","vote_average":6.904,"backdrop_path":"/6TmdYhlnM7OEITeuzcrX8XVlnp2.jpg","original_title":"8 femmes","original_language":"fr"},{"id":2043,"adult":false,"title":"Along Came a Spider","video":false,"overview":"After the harrowing death of his partner, forensic psychologist and best-selling author Alex Cross cannot forgive himself and has retreated to the peace of retirement. But when a brilliant criminal kidnaps a senator's young daughter, he is lured back into action as the kidnapper wants to deal with Alex personally. Teamed with Jezzie Flanigan, the Secret Service agent assigned to protect the missing girl, Alex follows a serpentine trail of clues that leads him to a stunning discovery - the kidnapper wants more than just ransom.","genre_ids":[80,9648,53,28],"popularity":3.8589,"vote_count":2000,"poster_path":"/svXTe3qxlV4oqAe0NoUN1rMXKB7.jpg","release_date":"2001-04-06","vote_average":6.339,"backdrop_path":"/5C6njaciKvyZlKWUrQX7mjdl4D1.jpg","original_title":"Along Came a Spider","original_language":"en"},{"id":273248,"adult":false,"title":"The Hateful Eight","video":false,"overview":"Bounty hunters seek shelter from a raging blizzard and get caught up in a plot of betrayal and deception.","genre_ids":[18,9648,37],"popularity":10.5262,"vote_count":15038,"poster_path":"/jIywvdPjia2t3eKYbjVTcwBQlG8.jpg","release_date":"2015-12-25","vote_average":7.755,"backdrop_path":"/7g1zO5t0bd27Iqn5ZUDJmksOGPJ.jpg","original_title":"The Hateful Eight","original_language":"en"},{"id":6026,"adult":false,"title":"The Alphabet Murders","video":false,"overview":"The Belgian detective Hercule Poirot investigates a series of murders in London in which the victims are killed according to their initials.","genre_ids":[35,80,9648],"popularity":0.4932,"vote_count":47,"poster_path":"/AiBmQsxpMage7Vbs7NgUZT4EkhY.jpg","release_date":"1965-12-26","vote_average":5.734,"backdrop_path":"/zCHWazmCt8ljDXGD0ikeCddZ5dE.jpg","original_title":"The Alphabet Murders","original_language":"en"},{"id":6028,"adult":false,"title":"The Mirror Crack'd","video":false,"overview":"Jane Marple solves the mystery when a local woman is poisoned and a visiting movie star seems to have been the intended victim.","genre_ids":[9648,80,53],"popularity":1.6544,"vote_count":230,"poster_path":"/5rirt2BbnEDzgWfUzsAew0qHm1N.jpg","release_date":"1980-02-06","vote_average":6.1,"backdrop_path":"/stlL2pBNqJtynzNkpzbMyESxdxk.jpg","original_title":"The Mirror Crack'd","original_language":"en"},{"id":6030,"adult":false,"title":"A Caribbean Mystery","video":false,"overview":"Aging Major Palgrave, an idiosyncratic but charming mystery writer, reveals to Miss Jane Marple that one of the guests at a luxurious Caribbean resort they're staying at is a Bluebeard-type wife murderer. Unfortunately, the Major succumbs to an apparently accidental overdose of alcohol and blood pressure medication before revealing the killer's identity. When it's discovered that the medicine belonged to another guest and the revealing photograph the Major was carrying is missing, Miss Marple realizes that the serial killer has struck again and more murders will follow.","genre_ids":[10770,80,53,9648,18],"popularity":0.5863,"vote_count":19,"poster_path":"/d2csb2Qc9dgG9eYTOeXPlEfidOC.jpg","release_date":"1983-10-22","vote_average":6.1,"backdrop_path":"/diMHBtg8AXUuoLi8JgxScy2M5hJ.jpg","original_title":"A Caribbean Mystery","original_language":"en"},{"id":6032,"adult":false,"title":"Murder with Mirrors","video":false,"overview":"When Miss Jane Marple arrives at palatial Stonygates, one thing is certain. Before there's time to lather a warm scone with marmalade and place a tea cozy, murder most foul is bound to occur.","genre_ids":[9648,80,10770],"popularity":0.7727,"vote_count":22,"poster_path":"/jVRzRsYYuSuMpf5ZwlNI0ENUp1Q.jpg","release_date":"1985-02-20","vote_average":6.5,"backdrop_path":"/vrqWxqg1ANAChv4RLI1UCeUXt0J.jpg","original_title":"Murder with Mirrors","original_language":"en"},{"id":6037,"adult":false,"title":"Murder by Death","video":false,"overview":"Lionel Twain invites the world's five greatest detectives to a 'dinner and murder'. Included are a blind butler, a deaf-mute maid, screams, spinning rooms, secret passages, false identities and more plot turns and twists than are decently allowed.","genre_ids":[35,80,9648,53],"popularity":2.0502,"vote_count":875,"poster_path":"/7YGYam05qzHy0ZSzfjBSDkVvvU7.jpg","release_date":"1976-06-23","vote_average":7.168,"backdrop_path":"/frM7pCS0vWnT1Utb81YyErmohmg.jpg","original_title":"Murder by Death","original_language":"en"},{"id":6056,"adult":false,"title":"Lord Edgware Dies","video":false,"overview":"A talented American actress enlists the help of the famed Belgian detective, Hercule Poirot, to negotiate a divorce from her husband, Lord Edgware, only to find him the next day stabbed to death in his library. Who would want him dead?","genre_ids":[80,53,9648],"popularity":0.2988,"vote_count":5,"poster_path":"/pvinlmZHTOVfuOiDvCgHmsrv9nu.jpg","release_date":"1934-07-31","vote_average":5.8,"backdrop_path":"/7dPVpqM1u5aKLOqCB94kn0vdrCf.jpg","original_title":"Lord Edgware Dies","original_language":"en"},{"id":6060,"adult":false,"title":"Black Coffee","video":false,"overview":"Black Coffee is a 1931 British detective film directed by Leslie S. Hiscott. Based on the 1930 play Black Coffee by Agatha Christie featuring her famous private detective Hercule Poirot, it stars Austin Trevor as Poirot with Richard Cooper playing his companion Captain Hastings. A famous but hated scientist, Sir Amory, is killed during a house party, and some of his valuable papers are missing. Poirot rapidly determines the cause of death and the motive, then narrows down the suspects to the most likely culprit.","genre_ids":[80,53,9648],"popularity":0.2998,"vote_count":1,"poster_path":"/1ULn5tFIjy6ULGOJkna0JcFZSYu.jpg","release_date":"1931-08-24","vote_average":6,"backdrop_path":null,"original_title":"Black Coffee","original_language":"en"},{"id":6103,"adult":false,"title":"Thirteen at Dinner","video":false,"overview":"Actress Jane Wilkinson wants a divorce, but her husband, Lord Edgware, refuses. She convinces Hercule Poirot to use his famed tact and logic to make her case. Lord Edgware turns up murdered, a well-placed knife wound at the base of his neck. It will take the precise Poirot to sort out the lies from the alibis - and find the criminal before another victim dies.","genre_ids":[80,9648],"popularity":0.7316,"vote_count":77,"poster_path":"/klIFNF78wpVI4IAcntk3mGYJ9gs.jpg","release_date":"1985-09-19","vote_average":5.7,"backdrop_path":"/51XJhsd6cH9sFTe0qAV1H7Qb7w0.jpg","original_title":"Thirteen at Dinner","original_language":"en"},{"id":6104,"adult":false,"title":"Murder by the Book","video":false,"overview":"Agatha Christie’s agents propose that it’s time for her to publish the manuscript she wrote thirty-five years earlier, a novel in which she finally kills off her most famous creation. And it’s not an entirely sad occasion. “That wretched little man,” she says. “He’s always been so much trouble. How is it Miss Marple has never upset me at all, not ever?” That night, who should appear at her doorstep but the wretched little man himself, Hercule Poirot? The great fictional detective and his creator proceed to play a very Christie-like game of cat and mouse for the manuscript – and for their own lives.","genre_ids":[80,18,9648,53,10770],"popularity":0.2237,"vote_count":3,"poster_path":"/4k8u5rro0RyF2skYlYcyBFnWbSa.jpg","release_date":"1986-01-01","vote_average":4,"backdrop_path":null,"original_title":"Murder by the Book","original_language":"en"},{"id":6105,"adult":false,"title":"Dead Man's Folly","video":false,"overview":"During a murder hunt game at a country house, to which Hercule Poirot is invited as an \"expert\", a real murder occurs.","genre_ids":[80,53,9648,10770],"popularity":0.9086,"vote_count":51,"poster_path":"/thH5NjvzGInO3rkGlSPE6Ll6pGp.jpg","release_date":"1986-01-08","vote_average":6.3,"backdrop_path":"/iXW1jYLCudYiSGlgvzlmr0cakId.jpg","original_title":"Dead Man's Folly","original_language":"en"}],"external_ids":{"imdb_id":"tt22772712","twitter_id":null,"facebook_id":null,"wikidata_id":"Q131523345","instagram_id":null,"rotten_tomatoes_id":"m/murder_at_the_embassy"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148749,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AS","release_dates":[{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":"2025-11-13T00:00:00.000Z","certification":""}]},{"iso_3166_1":"ES","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date"