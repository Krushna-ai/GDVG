.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/kWt1OcPgwO1ssu57wgTKmq38JYw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/stHcCE5mQIzDDgFVxZZ0UfD0hIh.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/AvIiUxbIrxwbLAhLgMGIpCEeneP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/gK2SVpyJtGYF0mMKUkyfaU9zC7q.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/jmN4mZllbViRXebOX1bUGhTu3sz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/zcrOkTLlRfkq8tmfsdUMwbXAu6b.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1333,"height":750,"file_path":"/3bqVAVZXpl3mwHDLIdRvmW96GYq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.777,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/4wUfbof7vmIGKqoPUaZL0Lg7mBR.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":1920,"height":1080,"file_path":"/uL10xSxm17MwKDYPx82HCMUJniB.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1438,"height":808,"file_path":"/gXv8fwdJETasmMTVGjSvUpuX3r0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.78,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/cSF1I7P2rQqT88Q0SsH85ItUDtA.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":2,"aspect_ratio":1.778,"vote_average":0.166},{"width":2048,"height":1152,"file_path":"/mC7C76REFYU6yd4ynnkWmY4CuZJ.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/iGwMGMhom83BrDFtnLgSk3pIrt9.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/qXjtynjSu99yrpR2cY5vppf7QOz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/pkYDLfiglIq2NPLyqjKisVRFXcY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/usJ2DPe7sUY62DlS6xaIdqln6MF.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1712,"height":964,"file_path":"/fae824HrT99wNwwsY3DZcdjR58B.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.776,"vote_average":0},{"width":1920,"height":1080,"file_path":"/uXvQp40UXvkeWg8Zk3W6lAMvldd.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/lfM9VHaGjFCoMYjL3uXDf5gFeXY.jpg","iso_639_1":"ro","iso_3166_1":"RO","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/nDATvdXzQ8dgMWKTw4eeZP93JTK.jpg","iso_639_1":"ja","iso_3166_1":"JP","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1500,"height":844,"file_path":"/zrKFfIBv68k28YsyWPgym7P9ZdV.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1280,"height":720,"file_path":"/kAqOC9RZuTLWXxBdMPlXLGKPQT1.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/t7evKkp0PNdLa6IDo3eCzGx4tsF.jpg","iso_639_1":"zh","iso_3166_1":"HK","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:14:00.859+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":92,"tagline":"Rules are made to be broken.","homepage":"","overview":"Former Special Forces officer Frank Martin will deliver anything to anyone for the right price, and his no-questions-asked policy puts him in high demand. But when he realizes his latest cargo is alive, it sets in motion a dangerous chain of events. The bound and gagged Lai is being smuggled to France by a shady American businessman, and Frank works to save her as his own illegal activities are uncovered by a French detective."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":92,"tagline":"Regeln sind dafür da, um gebrochen zu werden.","homepage":"","overview":"Der für die kriminelle Klientel arbeitende Kurierfahrer Frank Martin plant alle Einsätze bis ins kleinste Detail und vergisst nie seine beiden ehernen Regeln: Stelle keine Fragen und mache niemals ein Paket auf. Bis zu jenem Tag, als der ultralässige Kerl mit seinen Prinzipien bricht und das zappelnde Frachtstück in seinem Kofferraum öffnet. Plötzlich hat er die schöne Lai am Hals, die gegen einen Menschenhändlerring kämpft. Und als wäre das nicht genug, ist plötzlich auch noch eine schießfreudige Mafiosi-Bande hinter dem gut gebauten Stoiker her."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Le Transporteur","runtime":92,"tagline":"Les règles sont faites pour être brisées.","homepage":"","overview":"Pour les livraisons à haut risque, Franck est toujours là. Comme les autres, il obéit aux trois règles d'or : ne poser aucune question, ne pas ouvrir les colis et ne pas enfreindre les deux premières au risque d'y trouver la mort. Mais cette fois-ci, Franck a ouvert le sac posé dans son coffre et a découvert une jeune femme se nommant Lai. Face à ce cas de conscience et à une sombre affaire de trafic humain, il ne va plus pouvoir fermer les yeux et décide d'aider ce \"colis\" un peu spécial."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Перевозчик","runtime":92,"tagline":"«Правила создаются, чтобы их нарушать»","homepage":"","overview":"Бывший десантник Фрэнк Мартин имеет неплохой бизнес — перевозит любые грузы по французскому Средиземноморью и делает свою работу быстро и качественно. Недостатка в клиентах нет, ведь, он всегда неукоснительно соблюдает три правила: не меняет условий сделки, не спрашивает никаких имен и никогда не заглядывает в багаж.Но однажды, перевозя груз клиента по имени Уолл Стрит, Фрэнк обнаруживает, что мешок шевелится."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"The Transporter","runtime":92,"tagline":"","homepage":"","overview":"Frank Martin, un ex agente delle forze speciali, vive un'esistenza tranquilla sulla costa francese nel Mediterraneo, salvo le occasionali missioni da \"Trasportatore\" mercenario. In grado di spostare carichi sia umani sia no, durante le sue missioni Frank si attiene scrupolosamente a regole che lui stesso si è imposto..."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Kuriér","runtime":88,"tagline":"Pravidlá sú aby sa porušovali.","homepage":"","overview":"Frank Martin je bývalý príslušník špeciálnej jednotky. Teraz žije zdanlivo pokojným životom na francúzskom pobreží Stredozemného mora. Príležitostne pracuje ako nájomný kuriér, ktorý prepravuje zásielky rôzneho druhu – z jedného miesta na druhé. Na nič sa nepýta, tovar preváža vo svojom špeciálne upravenom Mercedese, a plní len tajné a niekedy aj nebezpečné úlohy. Frank sa drží troch veľmi prísnych pravidiel. Frankova najnovšia úloha vyzerá rovnako ako niekoľko tých, ktoré už v minulosti robil. Najme si ho Američan, známy pod menom „Wall Street“, aby doručil zásielku. Keď Frank cestou zastaví, všimne si, že jeho „balík“ sa hýbe. Bleskurýchlo poruší pravidlo tri a pozrie sa dnu. Obsahom je krásna žena so zalepenými ústami. Teraz sa Frank ženie po diaľnici so svojou novou spolucestujúcou Lai do šokujúcich tajomstiev a smrteľných komplikácií..."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Kurýr","runtime":92,"tagline":"Pravidla jsou od toho, aby se porušovala","homepage":"","overview":"Profesionální kurýr je povolání jako každé jiné. Někdo chce někam něco přepravit, ale protože se mu zdají poštovní služby neadekvátní, raději svěří tento úkol profesionálovi, který jakoukoliv zásilku přebere s kamenným obličejem, naprosto diskrétně ji přepraví a od odběratele vyinkasuje dohodnutou sumu peněz. Přesně takhle si vydělává i Frank Martin, který patří ve svém oboru mezi nejlepší z nejlepších. Drží se totiž jednoho zásadního pravidla - nikdy danou zásilku neotevírej. Jenže jednoho dne toto pravidlo poruší a v kufru automobilu nalezne svázanou mladou dívku. Tím si však podepsal ortel smrti, protože v jeho patách je mu rázem elitní jednotka zabijáků."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"玩命快递","runtime":0,"tagline":"规则是用来打破的","homepage":"","overview":"　　故事发生在法国南部，弗兰克·马丁是个送货员，是那种专门为黑道人物送包裹的“地下送货员”，他当过特种兵，身手了得，外表冷漠，喜欢独来独往，多年来他一直坚守三条戒规，那就是：一、一旦接货就要干到底；二、从不打听雇主的情况；三、从不私自拆开包裹，这也是他能一直干到现在的原因。这不马丁又接了一单生意，一个美国人让他送一个包裹，马丁二话不说就上路了，可是路上他发现他的“包裹”动起来了。强烈的好奇心驱使他打破了自己的第三条规矩，去查看了包裹——结果发现里面是一个美丽的东方女子，嘴里被塞上了东西。这女孩是一个中国蛇头的女儿，她父亲专门把中国非法移民走私运送到法国。因为父亲在生意上得罪了人而被绑架。马丁决定帮这个女孩逃生，这个决定为他带来了种种麻烦，美国人开始追杀他们，而马丁和女孩也发生了感情。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Taşıyıcı","runtime":0,"tagline":"Kurallar çiğnenmek içindir.","homepage":"","overview":"Frank Martin yaptığı işin en iyisidir. Tehlikeli veya yasadışı maddeleri hiçbir soru sormadan bir noktadan diğerine taşır. Ama en son sevkiyatında, uluslararası esir tüccarlarının kaçırdığı güzel bir kadın, onun taşıma planlarında ölümcül problemler çıkmasına neden olur. Artık Frank değerli kargosunu ve kendi hayatını kurtarmak için durmak bilmeyen, hareket dolu bir savaşa girmelidir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Transporter","runtime":94,"tagline":"Las reglas se hicieron para romperlas.","homepage":"","overview":"El ex operador de Fuerzas Especiales Frank Martin vive lo que parece ser una vida tranquila a orillas del Mediterráneo francés, donde presta sus servicios como un “transportador”, un mercenario que traslada bienes —humanos o de cualquier tipo— de un lugar a otro. Siempre sin preguntas de por medio. Frank, que en su Mercedes equipado lleva a cabo misiones secretas y a veces peligrosas, se apega a un estricto juego de 3 reglas que nunca rompe. Regla numero uno: Nunca modifiques el trato. Dos: Omitir nombres, Frank no quiere saber para quién trabaja o qué es lo que transporta. Tres: Nunca ver qué hay dentro del paquete. La carga más reciente de Frank aparenta ser igual a los incontables paquetes que ha entregado en el pasado. Ha sido contratado por un norteamericano conocido solamente como “Wall Street” para que lleve a cabo una entrega. Pero cuando Frank se detiene en el trayecto, se percata que su “paquete” se mueve..."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":92,"tagline":"","homepage":"","overview":"Frank Martin är den bäste inom sitt område i att transportera farliga och illegala gods utan att ställa några frågor. Hans senaste leverans för dock med sig komplikationer då lasten visar sig vara en ung, vacker kvinna som kidnappats av internationella slavhandlare. Nu måste Frank lägga i högsta växeln i en actionladdad kamp utan avbrott för att rädda sin dyrbara last och sitt liv."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"A szállító","runtime":92,"tagline":"A szabályok arra valók, hogy megszegjék őket.","homepage":"","overview":"A szállító magányos profi. A szuper-járgányán hibátlanul, időre házhoz szállítja, amit rábíztak, majd elporzik. Sosem kérdez és sosem hibázik. Szigorúan betartja saját szabályait. Egyetlen egyszer mégis kivételt tesz. Kinyitja az egyik rábízott csomagot. A zsákban beragasztott szájú, gyönyörű kínai lányt talál. Nehéz szívvel kézbesíti ugyan, de amikor nemsokára a féltett autója felrobban, visszatér a címzetthez és olyat tesz, amit még soha: megmenti a küldeményt, sőt, a lány rábeszélésére még azt is megpróbálja kinyomozni, ki akarja megölni őket és miért."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Correio de Risco","runtime":92,"tagline":"","homepage":"","overview":"Frank Martin é um ex-soldado das forças especiais do exército norte-americano que trabalha transportando cargas. Vivendo incógnito na Cote d’Azur, Martin segue sempre à risca o lema de nunca saber que carga transporta, para quem é, ou de quem é. Quando é contratado pelo americano Wall Street, envolve-se em problemas. Após o pneu do seu BMW furar, Martin percebe que a carga que leva na mala mexe-se. Resolve então quebrar as suas regras: abre a mala e descobre lá dentro a bela Lai Kwai. Martin liberta-a, mas tem de fugir com ela para longe de um poderoso chefe do crime asiático e de um polícia que anda a investigar Frank por desconfiar que ele faz transporte de cargas ilegais."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":92,"tagline":"","homepage":"","overview":"Een ex-officier van de commanda's levert alles voor de juiste prijs, maar hij loopt gevaar als hij hoort dat zijn laatste lading uit levende waar bestaat."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Transporter","runtime":93,"tagline":"Reguły są po to by je łamać.","homepage":"","overview":"Były komandos Frank Martin (Jason Statham - \"Przekręt\") jest najlepszy w swej robocie jako transporter - przewozi dowolne ładunki we wskazane miejsce... szybko, solidnie i bez zbędnych pytań. Opracował system reguł, których nigdy nie łamie: Po pierwsze - nigdy nie zmieniaj warunków umowy; po drugie - żadnych nazwisk; i po trzecie - nigdy nie zaglądaj do przesyłki. Jednak jego najnowszy ładunek - piękna kobieta porwana przez międzynarodowy gang handlarzy niewolników wprowadziła nie lada zamęt ww jego klarowne zasady. Frank wplątuje się w śmiertelnie groźną intrygę i przekonuje się, że reguły są po to, by je łamać. Nagłe zwroty akcji, nieustanne napięcie, zapierające dech pościgi i sceny kaskaderskie gwarantują prawdziwie wysokooktanową rozrywkę dla wszystkich miłośników podwyższonego poziomu adrenaliny."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Транспортер","runtime":0,"tagline":"Правилата са създадени, за да се нарушават.","homepage":"","overview":"Франк Милър e бивш служител в специалните сили. Живее тихичко и спокойно нормален живот в Южна Франция. Нищо не е така както изглежда обаче. Всъщност Франк работи като \"транспортер\". Тихомълком пренася деликатни пратки от \"врата до врата\" със специално пригоденото за целта BMW."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Ο Μεταφορέας","runtime":94,"tagline":"Οι κανόνες είναι για να σπάνε.","homepage":"","overview":"Το πρώην στέλεχος των ειδικών δυνάμεων, Φρανκ Μάρτιν, μεταφέρει ο,τιδήποτε οπουδήποτε, αρκεί η τιμή να είναι καλή, και επειδή δεν κάνει ερωτήσεις είναι περιζήτητος. Αλλά όταν ανακαλύπτει πως το τελευταίο του φορτίο είναι ζωντανό, δημιουργείται μια αλυσίδα επικίνδυνων γεγονότων. Η δεμένη και φιμωμένη Λάι μεταφέρεται κρυφά στη Γαλλία από έναν ύποπτο Αμερικανό επιχειρηματία, και ο Φρανκ προσπαθεί να τη σώσει ενώ παράλληλα ένας Γάλλος ντετέκτιβ αποκαλύπτει τις παράνομες δραστηριότητές του."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"","runtime":89,"tagline":"","homepage":"","overview":"Den tidligere elitesoldat Frank Martin fragter pakker rundt i den franske underverden. Den slags udbringning giver rigtig godt, og Frank er glad indtil han en dag bryder jobbet vigtigste regel og kigger i pakken, der viser sig at indeholde en dejlig dame. Pludselig er en masse gangstere rigtig sure på Frank, der får god brug for sine køreevner og tidligere træning."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Transporter","runtime":0,"tagline":"","homepage":"","overview":"Bivši vojnik Frank Martin (Jason Statham) živi sam u Francuskoj, gdje vodi privatan biznis kao transporter, unajmljeni kriminalac čija je specijalnost prenositi pakete i putnike, bez postavljanja ikakvih pitanja.  Odličan akcijski triler redatelja Louisa Leterriera i Coreyja Yuena, snimljen po scenariju u kojem je sudjelovao i slavni Luc Besson, pravi je primjer žanrovskog vrhunca i kvalitetne kino zabave. Glavno oružje filma izvrsni je Jason Statham u ulozi Franka Martina."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"ทรานสปอร์ตเตอร์ : ขนระห่ำไปบี้นรก","runtime":0,"tagline":"ขนระห่ำไปบี้นรก","homepage":"","overview":"รัดเข็มขัดให้แน่น เพื่อรับมือความมันส์ของภาพยนตร์แอ็คชั่นพลังสูงเรื่องนี้ ที่พร้อมจุดชนวนความระทึกให้พุ่งพล่าน! แฟรงค์ มาร์ติน.(เจสัน สตาแธม - Snatch).คือเมือหนึ่งในทุกเรื่องที่เขาทำ และ.สิ่งที่เขาทำคือเรับจ้างขับรถส่งของที่อันตรายและ.ผิดกฏหมาย โดยไม่มีการซักถามหรือสงสัยใดๆเแต่เมื่อสินค้าในงานครั้งล่าสุดของแฟรงค์คือเหญิงสาวคนหนึ่ง ผู้ถูกลักพาตัวโดยฝีมือของแก็งค้าทาสข้ามประเทศที่นำอันตรายมาสู่เขา เวลานี้แฟรงค์จึงต้องขนความระห่ำในตัวทั้งหมดที่มีพุ่งชนเหล่าคนโฉดให้กระอัก เพื่อปกป้องผู้หญิงคนนี้และ.ชีวิตของเขา"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"トランスポーター","runtime":93,"tagline":"プロの運び屋、依頼品はいつもワケあり。","homepage":"","overview":"自分に課した３つのルールを厳格に守りつつ犯罪すれすれの運び屋家業を続けるフランク。ある日いつものように運び屋の依頼が舞い込む。指定された時刻に指定重量のバッグを運ぶ。簡単ないつもの仕事のはずだったが、車のパンクを修理する途中バッグが動きだし中から声がするのを見つけ不審感がぬぐえなくなったフランクはついに自分に課したルール「荷の中身は見ない」を破り  バッグを開けてしまうと中からはアジア人の美女があわられるのだった。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"המשלח","runtime":0,"tagline":"","homepage":"","overview":"הסרט מגולל את סיפורו של איש שתפקידו להעביר חבילות בלי לשאול שאלות. הסיפור מתחיל להסתבך ברגע ששאלות מתחילות להישאל. באחת מעבודותיו הוא צריך להעביר חבילה מאיש אמריקאי הידוע בכינוי \"וול סטריט\". אלא שהוא שם לב שהחבילה זזה ולכן הוא עובר על החוק שקבע לעצמו ומסתכל פנימה. שם מתגלה לו בחורה קשורה, וברור שמן התסבוכת הזו לא יהיה קל לצאת."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Перевізник","runtime":0,"tagline":"","homepage":"","overview":"Колишній десантник Френк Мартін має непоганий бізнес — перевозить любі вантажі по французькому Середземномор'ю і робить свою работу швидко та якісно. Недостатку в клієнтах немає, він же завжди неухильно дотримується трьох правил: не змінювати умов договору, не питати жодних імен і ніколи не заглядати в багаж. Але одного разу, перевозячи вантаж клієнта по імені Волл Стріт, Френк виявляє, що мішок ворушиться. Вперше за весь час Мартін порушує правило, заглядає всередину пакету і виявляє там красиву жінку, яка являється дочкою знатного китайського мафіозі…"},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Curierul","runtime":92,"tagline":"Regulile sunt făcute pentru a fi încălcate.","homepage":"","overview":"Pentru a-și câștiga existența, Frank își oferă serviciile de curier special celor care îl solicită și transportă colete dintr-un loc într-altul, fără a pune întrebări. Pentru a-și duce la bun sfârșit misiunile misterioase și, uneori, periculoase, Frank are niște reguli pe care le respectă cu sfințenie: nu încălca înțelegerea, fără nume, nu te uita niciodată să vezi ce e în colet. Noua livrare pe care trebuie s-o facă nu diferă cu nimic de precedentele. Cel care l-a angajat e cunoscut sub pseudonimul Wall Street și Frank nu întreabă mai multe. Însă, de data aceasta, coletul se mișcă, Frank îl desface și găsește înăuntru o femeie. Ignorând toate regulile care îi asigură supraviețuirea, Frank intră într-un lanț de întâmplări care presupun dezvăluirea unor secrete și diverse complicații."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"트랜스포터","runtime":0,"tagline":"액션의 모든 규칙을 파괴한다!","homepage":"","overview":"룰(rule)이 깨지기 시작하면서…  예상치 못한 사건, 밝혀지는 음모!  과거 특수부대 출신인 프랭크(제이슨 스태덤 분). 현재 그는 범죄조직이 의뢰한 물건을 비밀리에 운반해주는 ‘트랜스포터’ 일을 하고 있다. 비밀스럽고도 위험한 이 일을 하는 그에겐 확고한 룰(rule)이 있는데, ‘첫째, 계약조건을 변경하지 말 것’, ‘둘째, 거래는 익명으로 할 것’, ‘셋째, 절대 포장을 열지 말 것’이다.  그러던 어느 날, 프랭크는 가칭 ‘월 스트리트’(맷 슐츠 분)라는 사람에게서 새로운 거래를 의뢰받는다. 그러나 운반 도중 가방이 움직인다는 사실을 알게 되고, 가방을 열자 그 속에서 물건이 아닌 사람이 발견된다. 프랭크가 자신의 ‘룰’을 깨고 ‘라이’(서기 분)라는 여인을 구해주면서부터 일은 꼬이기 시작하고, 프랭크는 범죄조직으로부터 생명의 위협을 받게 된다.  한편, 평소 프랭크를 그의 주위를 살피던 형사 타르코니(프랑수아 베를레앙 분). 그는 프랭크의 자동차가 폭발사고의 현장에서 발견되고, 얼마 지나지 않아 프랭크의 집 전체가 정체 모를 일당에 의해 폭파되면서 프랭크를 더욱 의심하게 된다.  라이를 구해준 프랭크는 그녀에게서 놀라운 사실을 듣게 된다. 월 스트리트 일당이 그녀의 가족이 포함된 수백명의 중국인 밀입국자들을 암거래하려 한다는 것. 프랭크는 혼자서 이들을 구출하려는 그녀를 돕기로 한다. 거대 범죄조직이 그들을 뒤쫓고, 프랭크를 의심하는 경찰의 포위망까지 좁혀지면서 상황은 더욱 예상치 못한 곳으로 치닫는다. 그리고 계속되는 위험 속에서 프랭크는 그녀에게 뭔가 다른 비밀이 숨겨졌음을 감지하는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Carga Explosiva","runtime":0,"tagline":"Regras foram feitas para serem quebradas.","homepage":"","overview":"O ex-operador das Forças Especiais Frank Martin vive o que parece ser uma vida tranquila ao longo do Mediterrâneo francês. Na verdade ele é um transportador mercenário levando bens, humanos ou não, de um lugar para outro, sem fazer perguntas sobre que tipo de mercadoria foi contratado para transportar."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"玩命快遞","runtime":92,"tagline":"","homepage":"","overview":"從特種部隊退休的法蘭克馬丁（Jason Statham 飾），在法國地中海濱用「運輸者」的代號，駕駛BMW自營快遞生意，為各式各樣委託人完成限時交易。對於工作，法蘭克馬丁有一套嚴格的規定：「不改變交易細節」、「不過問雙方姓名」、「不在乎快遞內容」。  法蘭克接到最新指令，受雇為代號「華爾街」的委託人運送快遞。也許是命中註定，在運送過程中，法蘭克違反規則打開袋子，發現一個被五花大綁的東方美女小蘭（舒淇 飾）。長久以來嚴守規定的法蘭克終於破功，果然，在他一步步棄守原則的同時，莫名的災難接二連三，將法蘭克和小蘭推向複雜難解的致命危機；法蘭克此刻才意識到：「壞了規矩就是玩命的開始。」"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"مأمور انتقال","runtime":0,"tagline":"","homepage":"","overview":"فیلم در مورد مردی است که شغلش رانندگی است و در ازای جابجایی بسته‌ها و بدون پرسیدن هیچ‌گونه سؤالی دستمزد خود را دریافت می‌کند..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Transporteris","runtime":0,"tagline":"","homepage":"","overview":"Buvęs JAV specialiųjų pajėgų operatorius Frenkas Martinas iš pirmo žvilgsnio gyvena gana ramiai. Pragyvenimui jis užsidirba saugiai ir konfidencialiai gabendamas krovinius – paslaptingus, o kartais ir pavojingus siuntinius. Bet Frenkas lieka ištikimas savo griežtoms taisyklėms: nieku gyvu nepažeisk sutarties taisyklių; neminėk jokių vardų; nieku gyvu neatidaryk bagažo. Frenkas su gražiąja belaisve iš karto atsiduria kitoje barikadų pusėje ir stoja į kovą su galinga kinų kontrabandininkų mafija."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"El Transportador","runtime":92,"tagline":"","homepage":"","overview":"El ex operador de Fuerzas Especiales Frank Martin vive lo que parece ser una vida tranquila a orillas del Mediterráneo francés, donde presta sus servicios como un “transportador”, un mercenario que traslada bienes —humanos o de cualquier tipo— de un lugar a otro. Siempre sin preguntas de por medio. Frank, que en su BMW equipado lleva a cabo misiones secretas y a veces peligrosas, se apega a un estricto juego de 3 reglas que nunca rompe. Regla número uno: Nunca modifiques el trato. Dos: Omitir nombres, Frank no quiere saber para quién trabaja o qué es lo que transporta. Tres: Nunca ver qué hay dentro del paquete. La carga más reciente de Frank aparenta ser igual a los incontables paquetes que ha entregado en el pasado. Ha sido contratado por un norteamericano conocido solamente como “Wall Street” para que lleve a cabo una entrega. Pero cuando Frank se detiene en el trayecto, se percata que su “paquete” se mueve..."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":92,"tagline":"","homepage":"","overview":"Frank Martin er den beste til det han gjør: Å frakte farlig eller ulovlig gods uten å stille spørsmål. Men denne lasten, en vakker, ung kvinne som er kidnappet av internasjonale slavehandlere, vikler ham inn i livsfarlige komplikasjoner. Nå må Frank sette inn høygiret, i en ustoppelig actionspekket kamp til siste slutt, for å redde sin dyrebare last... og sitt eget liv."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Le Transporteur","runtime":92,"tagline":"Les règles sont faites pour être enfreintes.","homepage":"","overview":"Pour les livraisons à haut risque, Franck est toujours là. Comme les autres, il obéit aux trois règles d'or : ne poser aucune question, ne pas ouvrir les colis et ne pas enfreindre les deux premières au risque d'y trouver la mort. Mais cette fois-ci, Franck a ouvert le sac posé dans son coffre et a découvert une jeune femme se nommant Lai. Face à ce cas de conscience et à une sombre affaire de trafic humain, il ne va plus pouvoir fermer les yeux et décide d'aider ce \"colis\" un peu spécial."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Prenašalec","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Người Vận Chuyển","runtime":0,"tagline":"","homepage":"","overview":"Frank Martin - cựu thành viên của lực lượng đặc biệt tại Mỹ, sau khi về sống tại Pháp anh nhận vận chuyển hàng với 3 điều luật : 1 - Không thay đổi giao kèo.  2 - Không hỏi tên của chủ hàng. 3 - Không bao giờ xem gói hàng nhận vận chuyển.  Mọi thương vụ của anh đều làm đúng với 3 điều luật trên nhưng khi anh nhận chuyển một gói hàng của \"Wall Street\" thì anh đã vi phạm vào điều luật thứ 3. Anh phát hiện một cô gái xinh đẹp - Lai - trong đó và sự thật đằng sau phi vụ này là một đường dây buôn người từ Trung Quốc sang Pháp do chính cha của Lai làm chủ mưu."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"გადამზიდი","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"The Transporter - Välittäjä","runtime":0,"tagline":"Säännöt on tehty rikottavaksi","homepage":"","overview":"Frank Martin on alansa paras - hän ottaa kuljetettavakseen vaarallisia ja laittomia lähetyksiä mitään kyselemättä. Tämä keikka johtaa kuitenkin vaarallisille vesille, kun lähetys osoittautuu kauniiksi nuoreksi naiseksi, joka on joutunut kansainvälisen orjakaupan pyörteisiin. Frankin on ryhdyttävä tositoimiin pelastaakseen sekä lastinsa että oman henkensä taukoamattomassa toiminnantäyteisessä taistelussa."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"الناقل","runtime":0,"tagline":"","homepage":"","overview":"القواعد مصنوعة ليتم كسرها.  ضابط القوات الخاصة السابق ، فرانك مارتن ، سيقدم أي شيء لأي شخص بالسعر المناسب ، وسياسته التي لا تطرح أسئلة تضعه في ارتفاع الطلب. ولكن عندما يدرك أن حمولته الأخيرة على قيد الحياة ، فإنها تطلق سلسلة خطيرة من الأحداث. يتم تهريب لاي المقيدة والمكممة إلى فرنسا من قبل رجل أعمال أمريكي مشبوه ، ويعمل فرانك على إنقاذها حيث يتم الكشف عن أنشطته غير القانونية من قبل محقق فرنسي."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"Riskikuller","runtime":0,"tagline":"","homepage":"","overview":"Frank Martin (Jason Statham) on endine erivägede sõdur, kes teenib leiba kulleri ametiga. Kuid ta pole tavaline kuller, vaid riskikuller. Ta veab soliidse tasu eest kõikvõimalikke saadetisi, järgides seejuures kolme reeglit: 1. Ära kunagi muuda sõlmitud kokkulepet. 2. Ära küsi asjaosaliste nimesid. 3. Ära uuri, mida sa vead.  Ükskord rikub Frank aga 3. reeglit avades saadetise, milleks on võluv ja kaunis naine (Shu Qi). Reegli rikkumisega ei jää ka probleemid tulemata. Ta satub pahuksisse maffiaga, mis ei jää enne rahule, kui Frank surnud on."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"換命快遞","runtime":0,"tagline":"","homepage":"","overview":"從特種部隊退休的法蘭克馬丁（Jason Statham 飾），在法國地中海濱用「運輸者」的代號，駕駛 BMW 自營快遞生意，為各式各樣委託人完成限時交易。對於工作，法蘭克馬丁有一套嚴格的規定：「不改變交易細節」、「不過問雙方姓名」、「不在乎快遞內容」。\r 法蘭克接到最新指令，受僱為代號「華爾街」的委託人運送快遞。也許是命中註定，在運送過程中，法蘭克違反規則打開袋子，發現一個被五花大綁的東方美女小蘭（舒淇 飾）。長久以來嚴守規定的法蘭克終於破功，果然，在他一步步棄守原則的同時，莫名的災難接二連三，將法蘭克和小蘭推向複雜難解的致命危機；法蘭克此刻才意識到：「壞了規矩就是玩命的開始。」"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[{"id":"60b46fb110dad6004308a66c","url":"https://www.themoviedb.org/review/60b46fb110dad6004308a66c","author":"JPV852","content":"Fun action-thriller with Statham in his element. The car chases and fights were decent but would've been made better if not for the choppy editing. But all in all this was entertaining even though I've seen it a few times over the years. **3.75/5**","created_at":"2021-05-31T05:10:10.004Z","updated_at":"2021-06-23T15:58:56.429Z","author_details":{"name":"","rating":7,"username":"JPV852","avatar_path":"/xNLOqXXVJf9m7WngUMLIMFsjKgh.jpg"}},{"id":"6485654abf31f2505881c53c","url":"https://www.themoviedb.org/review/6485654abf31f2505881c53c","author":"Rob","content":"Jason Statham's breakout movie. And it's the perfect vehicle for him. Let's face it in almost every movie Statham is just Statham, but that's ok, it's exactly what we want to see. This is basically Luc Besson's version of a Jackie Chan movie. And it really does work. Ok, the BMW bridge jump was nothing short of cringeworthy, but the rest of the movie is enjoyable enough that we can forgive that...just.","created_at":"2023-06-11T06:10:18.384Z","updated_at":"2023-06-11T06:10:18.435Z","author_details":{"name":"Rob","rating":8,"username":"Arcanum101","avatar_path":"/w7CFzleuBl2EMBEl08fSA14aUOy.jpg"}}],"recommendations":[{"id":9335,"adult":false,"title":"Transporter 2","video":false,"overview":"Professional driver, and former Special Forces officer, Frank Martin is living in Miami, where he is temporarily filling in for a friend as the chauffeur for a government narcotics control policy director and his family. The young boy in the family is targeted for kidnapping, and Frank immediately becomes involved in protecting the child and exposing the kidnappers.","genre_ids":[28,53,80],"media_type":"movie","popularity":4.6871,"vote_count":3869,"poster_path":"/cdm17vK8PxHfTi7ayZf6WKbOgUO.jpg","release_date":"2005-08-03","vote_average":6.326,"backdrop_path":"/lbs1ood36hzj0O0cqW2a8MqptOh.jpg","original_title":"Transporter 2","original_language":"en"},{"id":13387,"adult":false,"title":"Transporter 3","video":false,"overview":"Frank Martin puts the driving gloves on to deliver Valentina, the kidnapped daughter of a Ukrainian government official, from Marseilles to Odessa on the Black Sea. En route, he has to contend with thugs who want to intercept Valentina's safe delivery and not let his personal feelings get in the way of his dangerous objective.","genre_ids":[28,53,80],"media_type":"movie","popularity":3.9247,"vote_count":3594,"poster_path":"/p4R9Le2jYW2XB2QxbUeu74jJQ5D.jpg","release_date":"2008-11-26","vote_average":6.163,"backdrop_path":"/5yrQsEuuqc4s8t8nszLxAAGQpR2.jpg","original_title":"Transporter 3","original_language":"en"},{"id":287948,"adult":false,"title":"The Transporter Refueled","video":false,"overview":"The fast-paced action movie is again set in the criminal underworld in France, where Frank Martin is known as The Transporter, because he is the best driver and mercenary money can buy. In this installment, he meets Anna and they attempt to take down a group of ruthless Russian human traffickers who also have kidnapped Frank’s father.","genre_ids":[28,53,80],"media_type":"movie","popularity":3.579,"vote_count":1578,"poster_path":"/71kaQfdrMy0LHSeLRADsvlDGCgb.jpg","release_date":"2015-09-02","vote_average":5.517,"backdrop_path":"/pH5ycIvD1Fz55tP9YWeE9sAAoGL.jpg","original_title":"The Transporter Refueled","original_language":"en"},{"id":1948,"adult":false,"title":"Crank","video":false,"overview":"Chev Chelios, a hit man wanting to go straight, lets his latest target slip away. Then he awakes the next morning to a phone call that informs him he has been poisoned and has only an hour to live unless he keeps adrenaline coursing through his body while he searches for an antidote.","genre_ids":[28,53,80],"media_type":"movie","popularity":5.3301,"vote_count":4114,"poster_path":"/bbGOV9lES80el46Hj4GLj5zY25F.jpg","release_date":"2006-08-31","vote_average":6.652,"backdrop_path":"/8JPz1636hMcaADngF4H4KOxXfp1.jpg","original_title":"Crank","original_language":"en"},{"id":10796,"adult":false,"title":"The One","video":false,"overview":"A sheriff's deputy fights an alternate universe version of himself who grows stronger with each alternate self he kills.","genre_ids":[28,878,53],"media_type":"movie","popularity":4.8613,"vote_count":1688,"poster_path":"/gcr3t71KmeXINemMrhaGBGVJPwW.jpg","release_date":"2001-11-02","vote_average":6.129,"backdrop_path":"/yZzPTih3HQZUBghrWirt0Rk17uE.jpg","original_title":"The One","original_language":"en"},{"id":710,"adult":false,"title":"GoldenEye","video":false,"overview":"When a powerful satellite system falls into the hands of Alec Trevelyan, AKA Agent 006, a former ally-turned-enemy, only James Bond can save the world from a dangerous space weapon that -- in one short pulse -- could destroy the earth! As Bond squares off against his former compatriot, he also battles Xenia Onatopp, an assassin who uses pleasure as her ultimate weapon.","genre_ids":[12,28,53],"media_type":"movie","popularity":5.5222,"vote_count":4227,"poster_path":"/z0ljRnNxIO7CRBhLEO0DvLgAFPR.jpg","release_date":"1995-11-16","vote_average":6.898,"backdrop_path":"/fIWsCpYR9iGDMSbMTSAzy8L7Kg5.jpg","original_title":"GoldenEye","original_language":"en"},{"id":9654,"adult":false,"title":"The Italian Job","video":false,"overview":"Charlie Croker pulled off the crime of a lifetime. The one thing that he didn't plan on was being double-crossed. Along with a drop-dead gorgeous safecracker, Croker and his team take off to re-steal the loot and end up in a pulse-pounding, pedal-to-the-metal chase that careens up, down, above and below the streets of Los Angeles.","genre_ids":[28,80],"media_type":"movie","popularity":4.9717,"vote_count":5892,"poster_path":"/eSkjK4kctyrWpFhxl35GPvSs6tI.jpg","release_date":"2003-05-30","vote_average":6.785,"backdrop_path":"/jPH8ROhZMLvP0owQCE1J6it7fN0.jpg","original_title":"The Italian Job","original_language":"en"},{"id":36647,"adult":false,"title":"Blade","video":false,"overview":"The Daywalker known as \"Blade\" - a half-vampire, half-mortal man - becomes the protector of humanity against an underground army of vampires.","genre_ids":[27,28],"media_type":"movie","popularity":7.5748,"vote_count":6552,"poster_path":"/hx0sdduAsr4rq03RZKZzglR25z7.jpg","release_date":"1998-08-21","vote_average":6.822,"backdrop_path":"/7NKfxJrQn053UJeLftlx4m4NTzo.jpg","original_title":"Blade","original_language":"en"},{"id":75780,"adult":false,"title":"Jack Reacher","video":false,"overview":"One morning in an ordinary town, five people are shot dead in a seemingly random attack. All evidence points to a single suspect: an ex-military sniper who is quickly brought into custody. The interrogation yields one written note: 'Get Jack Reacher!'. Reacher, an enigmatic ex-Army investigator, believes the authorities have the right man but agrees to help the sniper's defense attorney. However, the more Reacher delves into the case, the less clear-cut it appears. So begins an extraordinary chase for the truth, pitting Jack Reacher against an unexpected enemy, with a skill for violence and a secret to keep.","genre_ids":[80,18,53,28],"media_type":"movie","popularity":7.2568,"vote_count":7499,"poster_path":"/uQBbjrLVsUibWxNDGA4Czzo8lwz.jpg","release_date":"2012-12-20","vote_average":6.653,"backdrop_path":"/iwvP8XVpYVmJ3xfF9xdBi5uAOWl.jpg","original_title":"Jack Reacher","original_language":"en"},{"id":9759,"adult":false,"title":"Cellular","video":false,"overview":"A young man receives an emergency phone call on his cell phone from an older woman. She claims to have been kidnapped – and the kidnappers have targeted her husband and child next.","genre_ids":[28,53,18,80],"media_type":"movie","popularity":2.0035,"vote_count":2041,"poster_path":"/AhD3qVfVmxz5CXDxctXwK5nmrOp.jpg","release_date":"2004-09-06","vote_average":6.4,"backdrop_path":"/AjHQO6ZNDHNSg6nWR5xeRruhTOf.jpg","original_title":"Cellular","original_language":"en"},{"id":10771,"adult":false,"title":"The Tuxedo","video":false,"overview":"Cabbie-turned-chauffeur Jimmy Tong learns there is really only one rule when you work for playboy millionaire Clark Devlin : Never touch Devlin's prized tuxedo. But when Devlin is temporarily put out of commission in an explosive accident, Jimmy puts on the tux and soon discovers that this extraordinary suit may be more black belt than black tie. Paired with a partner as inexperienced as he is, Jimmy becomes an unwitting secret agent.","genre_ids":[53,28,35,878],"media_type":"movie","popularity":4.1044,"vote_count":2119,"poster_path":"/2agrcNQRtgTsN5SbffC4H2BwYW2.jpg","release_date":"2002-09-27","vote_average":5.737,"backdrop_path":"/1wo90L3F7hA9h6cG5xfz3dB1IE6.jpg","original_title":"The Tuxedo","original_language":"en"},{"id":8363,"adult":false,"title":"Superbad","video":false,"overview":"Two co-dependent high school seniors are forced to deal with separation anxiety after their plan to stage a booze-soaked party goes awry.","genre_ids":[35],"media_type":"movie","popularity":7.7929,"vote_count":7897,"poster_path":"/ek8e8txUyUwd2BNqj6lFEerJfbq.jpg","release_date":"2007-08-17","vote_average":7.259,"backdrop_path":"/giYuvpmpZbwkT3NtX4WdNYqGhxw.jpg","original_title":"Superbad","original_language":"en"},{"id":7451,"adult":false,"title":"xXx","video":false,"overview":"Xander Cage is your standard adrenaline junkie with no fear and a lousy attitude. When the US Government \"recruits\" him to go on a mission, he's not exactly thrilled. His mission: to gather information on an organization that may just be planning the destruction of the world, led by the nihilistic Yorgi.","genre_ids":[28,12,53,80,18],"media_type":"movie","popularity":43.7608,"vote_count":4796,"poster_path":"/xeEw3eLeSFmJgXZzmF2Efww0q3s.jpg","release_date":"2002-08-09","vote_average":5.979,"backdrop_path":"/2OHa6ukEq3Hce7Pc2kvu8wkmMFY.jpg","original_title":"xXx","original_language":"en"},{"id":5289,"adult":false,"title":"Chaos","video":false,"overview":"In Seattle, detective Quentin Conners is unfairly suspended and his partner Jason York leaves the police force after a tragic shooting on Pearl Street Bridge, when the hostage and the criminal die. During a bank heist with a hostage situation, Conners is assigned in charge of the operation with the rookie Shane Dekker as his partner. The thieves, lead by Lorenz, apparently do not steal a penny from the bank. While chasing the gangsters, the police team disclose that they planted a virus in the system, stealing one billion dollars from the different accounts, using the principle of the Chaos Theory. Further, they find that Lorenz is killing his accomplices.","genre_ids":[18,28,80],"media_type":"movie","popularity":5.6951,"vote_count":1120,"poster_path":"/fsqOoouBsNo69vbh2WG6PtpzGBa.jpg","release_date":"2005-01-17","vote_average":6.318,"backdrop_path":"/7hw6P8Xq8pNcIcuTknDIn5qcm3Y.jpg","original_title":"Chaos","original_language":"en"},{"id":8681,"adult":false,"title":"Taken","video":false,"overview":"Bryan Mills, a former government operative, is trying to reconnect with his teenage daughter Kim. After reluctantly agreeing with his ex-wife to let Kim go to Paris on vacation with a friend, his worst nightmare comes true. While on the phone with his daughter shortly after she arrives in Paris, she and her friend are abducted by a gang of human traffickers. Working against the clock, Bryan relies on his extensive training and skills to track down the ruthless gang that abducted her and launch a one-man war to rescue his daughter.","genre_ids":[28,53],"media_type":"movie","popularity":12.7718,"vote_count":11897,"poster_path":"/ognkaUSNgJe1a2pjB4UNdzEo5jT.jpg","release_date":"2008-02-18","vote_average":7.4,"backdrop_path":"/lMRMjd9yJsZLyaT97eiURu2zVb4.jpg","original_title":"Taken","original_language":"en"},{"id":9737,"adult":false,"title":"Bad Boys","video":false,"overview":"Marcus Burnett is a henpecked family man. Mike Lowrey is a footloose and fancy free ladies' man. Both Miami policemen, they have 72 hours to reclaim a consignment of drugs stolen from under their station's nose. To complicate matters, in order to get the assistance of the sole witness to a murder, they have to pretend to be each other.","genre_ids":[28,35,80,53],"media_type":"movie","popularity":6.5161,"vote_count":6821,"poster_path":"/x1ygBecKHfXX4M2kRhmFKWfWbJc.jpg","release_date":"1995-04-07","vote_average":6.828,"backdrop_path":"/wOLTJxfv98miIQcn0oNXq9fIgXM.jpg","original_title":"Bad Boys","original_language":"en"},{"id":699,"adult":false,"title":"For Your Eyes Only","video":false,"overview":"A British spy ship has sunk and on board was a hi-tech encryption device. James Bond is sent to find the device that holds British launching instructions before the enemy Soviets get to it first.","genre_ids":[12,28,53],"media_type":"movie","popularity":4.4544,"vote_count":2018,"poster_path":"/xV4Nnr6DjjERlqNikqDQX8LUgua.jpg","release_date":"1981-06-24","vote_average":6.541,"backdrop_path":"/z7Jp7HAsY7MqXzPYzTjJnmOQk2r.jpg","original_title":"For Your Eyes Only","original_language":"en"},{"id":6935,"adult":false,"title":"Yamakasi","video":false,"overview":"Yamakasi - Les samouraïs des temps modernes is a 2001 French movie written by Luc Besson. It demonstrates the skills of the Yamakasi, a group of traceurs who battle against injustice in the Paris ghetto. They use parkour to steal from the rich in order to pay off medical bills for a kid injured copying their techniques.","genre_ids":[28,80,18],"media_type":"movie","popularity":1.2634,"vote_count":588,"poster_path":"/7INcVJWvyT5pwnGHTYrhZXD7zvS.jpg","release_date":"2001-04-04","vote_average":6.027,"backdrop_path":"/l6zhhG4HR1ovOPkWBXIoXkJyQz5.jpg","original_title":"Yamakasi - Les samouraïs des temps modernes","original_language":"fr"},{"id":10045,"adult":false,"title":"District B13","video":false,"overview":"Set in the ghettos of Paris in 2010, an undercover cop and ex-thug try to infiltrate a gang in order to defuse a neutron bomb.","genre_ids":[28,53,878],"media_type":"movie","popularity":5.5477,"vote_count":1950,"poster_path":"/uYIDJ15RLBsFFBSAkqjIirZCgVi.jpg","release_date":"2004-11-09","vote_average":6.809,"backdrop_path":"/dSbXXdDcnQFimUf1mhkPk5dkQU3.jpg","original_title":"Banlieue 13","original_language":"fr"}],"similar_content":[{"id":24,"adult":false,"title":"Kill Bill: Vol. 1","video":false,"overview":"An assassin is shot by her ruthless employer, Bill, and other members of their assassination circle – but she lives to plot her vengeance.","genre_ids":[28,80],"popularity":14.7451,"vote_count":18603,"poster_path":"/v7TaX8kXMXs5yFFGR41guUDNcnB.jpg","release_date":"2003-10-10","vote_average":8,"backdrop_path":"/iffzIhuLAO38Po6sh1s6ZEVwlNL.jpg","original_title":"Kill Bill: Vol. 1","original_language":"en"},{"id":18,"adult":false,"title":"The Fifth Element","video":false,"overview":"In 2257, a taxi driver is unintentionally given the task of saving a young girl who is part of the key that will ensure the survival of humanity.","genre_ids":[878,28,12],"popularity":12.1549,"vote_count":11467,"poster_path":"/fPtlCO1yQtnoLHOwKtWz7db6RGU.jpg","release_date":"1997-05-02","vote_average":7.563,"backdrop_path":"/bx1W729hyWQqNQoiq9LsX30FBf.jpg","original_title":"Le Cinquième Élément","original_language":"fr"},{"id":3115,"adult":false,"title":"Ebirah, Horror of the Deep","video":false,"overview":"Searching for his brother, Ryota stows away on a boat belonging to a criminal alongside two other teenagers. The group shipwrecks on Letchi island and discover the Infant Island natives have been enslaved by a terrorist organization controlling a crustacean monster. Finding a sleeping Godzilla, they decide to awaken him to defeat the terrorists and liberate the natives.","genre_ids":[878,28,14],"popularity":1.5239,"vote_count":211,"poster_path":"/rYGsvMKjIBU5CAQrfHOv9xIfYhn.jpg","release_date":"1966-12-17","vote_average":6.287,"backdrop_path":"/xQzDpV5edHLmCM3n15pcatHynOd.jpg","original_title":"ゴジラ・エビラ・モスラ　南海の大決闘","original_language":"ja"},{"id":3051,"adult":false,"title":"Eye of the Devil","video":false,"overview":"A French nobleman deserts his wife because of an ancient family secret.","genre_ids":[27,9648,53],"popularity":0.462,"vote_count":59,"poster_path":"/14gehKJzoyoFWMqzCKDt5mHQXZs.jpg","release_date":"1966-11-18","vote_average":6.153,"backdrop_path":"/bXrx6qd0djjDDhoXyH5EvQDLLJS.jpg","original_title":"Eye of the Devil","original_language":"en"},{"id":1063161,"adult":false,"title":"1888","video":false,"overview":"When Demonetization (currency ban) is announced in India, 3 unlikely characters come face to face for a bag of cash. After that a car journey begins and some more characters come into picture. This results in a cat and mouse game with a very unexpected outcome.","genre_ids":[53,80,28,18],"popularity":0.1746,"vote_count":1,"poster_path":"/sY4f3X5yvyI6XLKpocCEr5XBdPQ.jpg","release_date":"2023-04-09","vote_average":5,"backdrop_path":"/37wFKdoXdTC89md5FWmCNbVAFHh.jpg","original_title":"1888","original_language":"kn"},{"id":3201,"adult":false,"title":"The Vindicator","video":false,"overview":"An employee of a secret company operation becomes the victim of the company's special weapons project. He is transformed into a robotic killing machine that, because of his programming must destroy anything that comes near him.","genre_ids":[28,27,878],"popularity":0.339,"vote_count":38,"poster_path":"/vgdqGHVBYQJX9QDuWjmrwbB54T1.jpg","release_date":"1986-02-14","vote_average":4.487,"backdrop_path":"/1YtAKUcYHwJrGWaNJtQoGD2xKtP.jpg","original_title":"The Vindicator","original_language":"en"},{"id":467464,"adult":false,"title":"Black Belt Karate","video":false,"overview":"Young man travels to Indonesia to visit relatives and learns the art of karate.","genre_ids":[28],"popularity":0.3587,"vote_count":0,"poster_path":"/9dsk9JtuGlWpsobNC9n7KG63AXt.jpg","release_date":"1977-01-01","vote_average":0,"backdrop_path":null,"original_title":"Karate sabuk hitam","original_language":"id"},{"id":467136,"adult":false,"title":"Immortal Warriors","video":false,"overview":"Immortal Warriors is a Taiwanese Martial Arts movie.","genre_ids":[18,28,12,36],"popularity":0.5502,"vote_count":0,"poster_path":"/zSZM4d5DSBDGJWZH3WmxxcwjYK2.jpg","release_date":"1978-09-25","vote_average":0,"backdrop_path":"/vmoe9qDZoKNHmOvhYwvFpaVJDJX.jpg","original_title":"百戰保山河","original_language":"zh"},{"id":467139,"adult":false,"title":"The Gold Hunters","video":false,"overview":"The Gold Hunters is a Hong Kong Martial Arts movie action-directed and produced by Jackie Chan","genre_ids":[35,28,12],"popularity":0.6603,"vote_count":0,"poster_path":"/f7Jp7KHkL3YzVmxwh3YvzHmCwlc.jpg","release_date":"1981-05-15","vote_average":0,"backdrop_path":null,"original_title":"老鼠街","original_language":"cn"},{"id":274530,"adult":false,"title":"Story in the Temple Red Lily","video":false,"overview":"When the emperor becomes ill and the Sung Dynasty is threatened by an evil baron, a patriotic officer named Ree (Chia Ling) is assigned to the imperial palace to protect the sacred temple from rebels. Prepare to be chopped and kicked as Ling displays some martial arts fireworks in this 1979 curiosity.","genre_ids":[28],"popularity":0.4274,"vote_count":2,"poster_path":"/dPcGcrMpI6tgbIrErJOCTFIcQYa.jpg","release_date":"1976-10-23","vote_average":4,"backdrop_path":"/bGwSVWr1DZaRAOaIAIBanXrNhho.jpg","original_title":"火燒紅蓮寺","original_language":"zh"},{"id":658009,"adult":false,"title":"Ip Man: Kung Fu Master","video":false,"overview":"Ip Man’s promising career as a Policeman is ruined after he is framed for murder and targeted by a mob boss’s daughter.","genre_ids":[28,18],"popularity":2.2097,"vote_count":184,"poster_path":"/kHZN7zZGsWik9Sg3APaHGeTK5Jm.jpg","release_date":"2019-12-23","vote_average":6.552,"backdrop_path":"/9LoM4ATbgEFh6zyx4UytRTFdSlD.jpg","original_title":"宗师叶问","original_language":"zh"},{"id":6473,"adult":false,"title":"The Marksman","video":false,"overview":"When Chechen rebels take over a Russian nuclear reactor, it’s up to a special ops marksman to rescue the hostages and prevent nuclear catastrophe.","genre_ids":[28,12,53],"popularity":0.7411,"vote_count":136,"poster_path":"/sbXe9sBc7ZpyFJKwp24njaBI5kN.jpg","release_date":"2005-08-24","vote_average":5.353,"backdrop_path":"/v9AlJeQ1hLywJZux8i9mH84vPRH.jpg","original_title":"The Marksman","original_language":"en"},{"id":6499,"adult":false,"title":"Turbo: A Power Rangers Movie","video":false,"overview":"The legendary Power Rangers must stop the evil space pirate Divatox from releasing the powerful Maligore from his volcanic imprisonment on the island of Muranthias, where only the kindly wizard Lerigot has the key to release him. The hope of victory lies in the Ranger's incredible new Turbo powers and powerful Turbo Zords.","genre_ids":[28,12,10751,14,878],"popularity":1.538,"vote_count":307,"poster_path":"/4mau5EXQoKUTiS5wx3Wocwrh5hG.jpg","release_date":"1997-03-27","vote_average":5.741,"backdrop_path":"/zTeRNwkRxEbZ6qrwnbbyJHiPdcG.jpg","original_title":"Turbo: A Power Rangers Movie","original_language":"en"},{"id":6536,"adult":false,"title":"Streets of Rio","video":false,"overview":"Rio de Janeiro. Confronted with the violence that exists in the favela where he lives, Tiago sees the only way out to become a soccer player and, in this way, help his family to have a better life. Although he is the best player in his neighborhood and the chances of being discovered by a scout are good, he faces a number of problems. One of them is Tubarão, the leader of the most powerful gang in the favela, who wants Tiago to work for him as a drug dealer. To complicate matters even more, Tiago falls in love with Juliana, Tubarão's sister.","genre_ids":[18,80],"popularity":0.1847,"vote_count":4,"poster_path":"/zFw0Nz0Oi6oCPOzvlT7rHq7RUbM.jpg","release_date":"2008-01-30","vote_average":4.125,"backdrop_path":null,"original_title":"Show de Bola","original_language":"pt"},{"id":6978,"adult":false,"title":"Big Trouble in Little China","video":false,"overview":"Truck driver Jack Burton gets embroiled in a supernatural battle when his best friend Wang Chi's green-eyed fiancée is kidnapped by henchmen of the sorcerer Lo Pan, who must marry a girl with green eyes in order to return to the human realm.","genre_ids":[28,35,14,12],"popularity":4.4653,"vote_count":3259,"poster_path":"/gI2Qs1yTTj3NcESJyttCkbmJ4k9.jpg","release_date":"1986-05-30","vote_average":7.207,"backdrop_path":"/ehHskGgDUchxGyG33vUQZWNng43.jpg","original_title":"Big Trouble in Little China","original_language":"en"},{"id":7220,"adult":false,"title":"The Punisher","video":false,"overview":"When undercover FBI agent Frank Castle's wife and son are slaughtered, he becomes 'the Punisher' -- a ruthless vigilante willing to go to any length to avenge his family.","genre_ids":[28,80,18],"popularity":5.8163,"vote_count":3069,"poster_path":"/7rmA1HwYp2GKM85BL0cVwCaosGr.jpg","release_date":"2004-04-15","vote_average":6.356,"backdrop_path":"/ryhdEpjaJhvDVWzRQGOPxUYC0Cw.jpg","original_title":"The Punisher","original_language":"en"},{"id":6935,"adult":false,"title":"Yamakasi","video":false,"overview":"Yamakasi - Les samouraïs des temps modernes is a 2001 French movie written by Luc Besson. It demonstrates the skills of the Yamakasi, a group of traceurs who battle against injustice in the Paris ghetto. They use parkour to steal from the rich in order to pay off medical bills for a kid injured copying their techniques.","genre_ids":[28,80,18],"popularity":1.2634,"vote_count":588,"poster_path":"/7INcVJWvyT5pwnGHTYrhZXD7zvS.jpg","release_date":"2001-04-04","vote_average":6.027,"backdrop_path":"/l6zhhG4HR1ovOPkWBXIoXkJyQz5.jpg","original_title":"Yamakasi - Les samouraïs des temps modernes","original_language":"fr"},{"id":7299,"adult":false,"title":"Equilibrium","video":false,"overview":"In a dystopian future, a totalitarian regime maintains peace by subduing the populace with a drug, and displays of emotion are punishable by death. A man in charge of enforcing the law rises to overthrow the system.","genre_ids":[28,878,53],"popularity":8.1226,"vote_count":4902,"poster_path":"/yQuovle5Ov6q69XSdTNdH52eANc.jpg","release_date":"2002-12-06","vote_average":7.045,"backdrop_path":"/mBdZvD8jCDXDHmtVDLOJeAErxVw.jpg","original_title":"Equilibrium","original_language":"en"},{"id":584,"adult":false,"title":"2 Fast 2 Furious","video":false,"overview":"It's a major double-cross when former police officer Brian O'Conner teams up with his ex-con buddy Roman Pearce to transport a shipment of \"dirty\" money for shady Miami-based import-export dealer Carter Verone. But the guys are actually working with undercover agent Monica Fuentes to bring Verone down.","genre_ids":[28,80,53],"popula