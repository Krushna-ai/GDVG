5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Bāhubali: The Epic\",\"description\":\"When a mysterious child is found by a tribal couple near a roaring waterfall, they raise him as their own. As he grows, Sivudu is drawn to the world beyond the cliffs, where he discovers the ancient kingdom of Mahishmati, ruled by a cruel tyrant, haunted by rebellion, and bound to his past. What begins as a quest for love soon unravels a legacy of betrayal, sacrifice, and a forgotten prince.\",\"image\":\"https://image.tmdb.org/t/p/w500/z9YIo2qscyaXYgRqIdRJtND3bw8.jpg\",\"datePublished\":\"2025-10-29\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"IN\",\"inLanguage\":\"te\",\"genre\":[\"Action\",\"Drama\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6,\"bestRating\":10,\"ratingCount\":33}}"}}],["$","$L10",null,{"initialDrama":{"id":"e740e950-0c8e-44e6-9b1f-1724764224d6","tmdb_id":1511417,"imdb_id":"tt37893389","content_type":"movie","title":"Bāhubali: The Epic","original_title":"Bāhubali: The Epic","overview":"When a mysterious child is found by a tribal couple near a roaring waterfall, they raise him as their own. As he grows, Sivudu is drawn to the world beyond the cliffs, where he discovers the ancient kingdom of Mahishmati, ruled by a cruel tyrant, haunted by rebellion, and bound to his past. What begins as a quest for love soon unravels a legacy of betrayal, sacrifice, and a forgotten prince.","poster_path":"/z9YIo2qscyaXYgRqIdRJtND3bw8.jpg","backdrop_path":"/wCwZ4ljSsWyZyTiyk1tGQtBHTDx.jpg","release_date":"2025-10-29","first_air_date":null,"status":"published","original_language":"te","origin_country":["IN"],"genres":[{"id":28,"name":"Action"},{"id":18,"name":"Drama"}],"popularity":46.5613,"vote_average":6,"vote_count":33,"runtime":224,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:51:13.116181+00:00","updated_a