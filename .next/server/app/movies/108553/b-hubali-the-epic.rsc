66},{"width":374,"height":212,"file_path":"/xSvRb6YcVtjmtU5DshpOONIbPoY.png","iso_639_1":"en","vote_average":0}],"posters":[{"width":2000,"height":3000,"file_path":"/z9YIo2qscyaXYgRqIdRJtND3bw8.jpg","iso_639_1":"en","vote_average":5.786},{"width":720,"height":1080,"file_path":"/4sLSorDKKDN944kWngxgQlpdDeg.jpg","iso_639_1":"te","vote_average":2.542},{"width":1969,"height":2954,"file_path":"/yOv2boj3ALoEEDtRteL7vhmRyG.jpg","iso_639_1":"te","vote_average":2.542},{"width":640,"height":960,"file_path":"/jdV8cxQOQHM8g74axjZquZBn2rQ.jpg","iso_639_1":"te","vote_average":2.278},{"width":2000,"height":2833,"file_path":"/g0AcjxmDlzFiETFSDXPfAhhT85m.jpg","iso_639_1":"te","vote_average":1.75},{"width":719,"height":1080,"file_path":"/cKL08wD07yPPlJovALFnEhhqJdl.jpg","iso_639_1":"te","vote_average":1.75},{"width":719,"height":1080,"file_path":"/FIlouJAE7r9nJg5LfGtqPJorSS.jpg","iso_639_1":"en","vote_average":1.75},{"width":798,"height":1080,"file_path":"/4UY6fVCD5AkCYsVvo7gCgyHy4rk.jpg","iso_639_1":"te","vote_average":1.75},{"width":1080,"height":1440,"file_path":"/vjYDpyoThmpwM0GdZ8SoCVMKt6V.jpg","iso_639_1":"te","vote_average":1.444},{"width":762,"height":1080,"file_path":"/tMLSWZpwtANxddV17fAEeSObeGH.jpg","iso_639_1":"te","vote_average":1.222},{"width":863,"height":1280,"file_path":"/lYmFLu0mPAwg3vt77u9L9lzt4Io.jpg","iso_639_1":"te","vote_average":0.166},{"width":1331,"height":2000,"file_path":"/603SaFtVEODmiuZcWaOyOITJFIO.jpg","iso_639_1":null,"vote_average":0},{"width":1331,"height":2000,"file_path":"/zpNc4hp6aorQN1mXyQiOnM8Xq6B.jpg","iso_639_1":null,"vote_average":0},{"width":1331,"height":2000,"file_path":"/wb8RQb1bQYlbiRcxsijc2QY7QDW.jpg","iso_639_1":null,"vote_average":0},{"width":1000,"height":1500,"file_path":"/cj9JUTPc4gQKWKb7QNNWo7pu8tR.jpg","iso_639_1":"te","vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/wCwZ4ljSsWyZyTiyk1tGQtBHTDx.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/j8WzzoAJn5LrKpgFTe1gaQVTj8z.jpg","iso_639_1":null,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/i2GPnSwsdxHtI19e7gZwFVndpqg.jpg","iso_639_1":null,"vote_average":1.222},{"width":2500,"height":1406,"file_path":"/nrkDgCOB1FOO73uC3CCKaS9ugbk.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/v220eK4aX9xiidYScMDgIHL42F.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/7TSIiZLDGA9hbBA6MdGa3krO7he.jpg","iso_639_1":"en","vote_average":0}]},"enriched_at":"2026-04-21T02:33:59.513+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Bāhubali: The Epic","runtime":224,"tagline":"","homepage":"https://baahubali.com/","overview":"When a mysterious child is found by a tribal couple near a roaring waterfall, they raise him as their own. As he grows, Sivudu is drawn to the world beyond the cliffs, where he discovers the ancient kingdom of Mahishmati, ruled by a cruel tyrant, haunted by rebellion, and bound to his past. What begins as a quest for love soon unravels a legacy of betrayal, sacrifice, and a forgotten prince."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"La Légende de Baahubali, l’épopée – Version Director’s Cut","runtime":225,"tagline":"","homepage":"https://carlottafilms.com/films/la-legende-de-baahubali/","overview":"Sauvé des eaux à la naissance, Shiva développe en grandissant une force prodigieuse et un courage exceptionnel. Parvenu à l’âge adulte, il décide d’escalader la vertigineuse cascade qui domine son village. Il découvre au sommet un monde inconnu et fait la rencontre d’Avanthika, une guerrière rebelle qui lutte pour libérer la reine Devasena, prisonnière de l’empire de Mahishmati. Fasciné par la détermination de la jeune femme, Shiva décide de lui venir en aide, ignorant encore ses propres liens avec ce royaume – dont il est en réalité le prince héritier : Baahubali."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"巴霍巴利王：史诗","runtime":0,"tagline":"","homepage":"","overview":"在壮丽的马希什马蒂王国，一段跨越两代的英雄史诗就此展开。自幼在瀑布下部落长大的青年希瓦，因某种神秘召唤爬上绝壁，意外发现自己竟是传奇君主阿玛兰德拉·巴霍巴利的遗孤。 通过老将卡塔帕的讲述，揭开了上一代因王位争夺而引发的阴谋——老巴霍巴利虽仁爱爱民，却惨遭至亲背叛与暗杀，王后德瓦塞娜也被囚禁多年。 得知真相的希瓦承袭父名，化身摩哂陀·巴霍巴利。他集结反抗力量，向暴君巴哈拉迪瓦发起最终决战，誓要夺回王权，洗刷家族耻辱。  这是一场关于勇气、背叛、牺牲与正义回归的终极较量。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"తెలుగు","iso_639_1":"te","iso_3166_1":"IN","english_name":"Telugu"},{"data":{"title":"巴霍巴利王：史詩","runtime":0,"tagline":"","homepage":"","overview":"印度著名電影製片人SS Rajamouli宣佈在《Baahubali: The Epic》10週年（星期四）上映，這是一個雄心勃勃的兩部分重新編輯版本。 根據Rajamouli在X上的帖子，《Baahubali: The Epic》是《Baahubali: The Beginning》（2015）和《Baahubali 2: The Conclusion》（2017）的組合。  新版本將合併《開始》和《結束》，並帶有更新的剪輯和報告的五小時執行時間"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Bāhubali: The Epic","runtime":0,"tagline":"","homepage":"","overview":"นักรบผู้ยิ่งใหญ่ถือกำเนิดจากจุดเริ่มต้นที่ต่ำต้อยเพื่อท้าทายอำนาจชั่วร้ายที่คุกคามบ้านเกิดเมืองนอน ขณะที่คำทำนายโบราณและสายสัมพันธ์ในครอบครัวหล่อหลอมการเดินทางของเขา"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Baahubali: The Epic","runtime":225,"tagline":"","homepage":"","overview":"Um guerreiro lendário surge de origens humildes para desafiar forças poderosas que ameaçam sua terra natal, à medida que antigas profecias e laços familiares moldam sua jornada."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Als ein Stammespaar in der Nähe eines tosenden Wasserfalls ein mysteriöses Kind findet, ziehen sie es wie ihr eigenes auf. Während er heranwächst, fühlt sich Sivudu unwiderstehlich zu der Welt jenseits der Klippen hingezogen. Dort entdeckt er das uralte Königreich Mahishmati, das von einem grausamen Tyrannen beherrscht, von Rebellion geplagt und eng mit seiner eigenen Vergangenheit verwoben ist. Was als eine Suche nach der Liebe beginnt, entpuppt sich bald als ein Vermächtnis aus Verrat, Opferbereitschaft und der Geschichte eines vergessenen Prinzen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Baahubali: The Epic","runtime":230,"tagline":"","homepage":"","overview":"Cuando una pareja tribal encuentra a un niño misterioso cerca de una estruendosa cascada, lo crían como si fuera suyo. A medida que crece, Sivudu se siente atraído por el mundo más allá de los acantilados, donde descubre el antiguo reino de Mahishmati, gobernado por un tirano cruel, asolado por la rebelión y ligado a su propio pasado. Lo que comienza como una búsqueda por amor, pronto desentraña un legado de traición, sacrificio y un príncipe olvidado."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Baahubali: The Epic","runtime":0,"tagline":"","homepage":"","overview":"Cuando una pareja tribal encuentra a un niño misterioso cerca de una estruendosa cascada, lo crían como si fuera suyo. A medida que crece, Sivudu se siente atraído por el mundo más allá de los acantilados, donde descubre el antiguo reino de Mahishmati, gobernado por un tirano cruel, asolado por la rebelión y ligado a su propio pasado. Lo que comienza como una búsqueda por amor, pronto desentraña un legado de traición, sacrificio y un príncipe olvidado."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Baahubali: The Epic","runtime":0,"tagline":"","homepage":"","overview":"Kada je izgubljeni princ spašen i odgajan u progonstvu, odrasta nesvjestan svoje prošlosti. Godinama kasnije, vraća se kako bi otkrio istinu o ubistvu njegovog oca i zatvaranju njegove majke, te se mora uzdići kako bi povratio svoje mjesto kao zakoniti kralj ..."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Egy legendás harcos szerény körülmények közül emelkedik ki, hogy szembeszálljon a hazáját fenyegető hatalmas erőkkel, miközben ősi jóslatok és családi kötelékek alakítják útját.  (Szarka Károly)R3"},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Бахубали: Епосът","runtime":0,"tagline":"","homepage":"","overview":"Когато тайнствено дете е намерено от племенна двойка близо до ревящ водопад, те го отглеждат като свое дете. Докато расте, Сивуду е привлечен от света отвъд скалите, където открива древното кралство Махишмати, управлявано от жесток тиранин, преследвано от бунт и свързано с миналото му. Това, което започва като търсене на любов, скоро разплита наследство от предателство, жертви и забравен принц."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[{"id":1259935,"adult":false,"title":"PENCOERIAN BALIK!","video":false,"overview":"","genre_ids":[28,12,36],"popularity":0.2327,"vote_count":0,"poster_path":"/k7N9jzlOK8Scz5S9VS2THtdF2e4.jpg","release_date":"2024-04-22","vote_average":0,"backdrop_path":"/2XGhoHdN5g3rqngdmWfTcROkRtY.jpg","original_title":"PENCOERIAN BALIK!","original_language":"id"},{"id":10222,"adult":false,"title":"Kickboxer","video":false,"overview":"If your enemy refuses to be humbled... Destroy him. Accompanied by his brother Kurt, American kickboxing champion Eric Sloane, arrives in Thailand to defeat the Eastern warriors at their own sport. His opponent: ruthless fighter and Thai champion, Tong Po. Tong not only defeats Eric, he paralyzes him for life. Crazed with anger, Kurt vows revenge.","genre_ids":[28,53,18],"popularity":5.4151,"vote_count":1540,"poster_path":"/tzEOkUn5708fQvF0bOPB5bLLRNk.jpg","release_date":"1989-04-20","vote_average":6.837,"backdrop_path":"/sl7hpSJR11FlfcewMJ6ihsbbAuJ.jpg","original_title":"Kickboxer","original_language":"en"},{"id":10228,"adult":false,"title":"Pokémon: The First Movie","video":false,"overview":"Determined to prove its superiority, a bio-engineered Pokémon called Mewtwo lures Ash, Pikachu and others into a Pokemon match like none before.","genre_ids":[16,10751,12,14,28],"popularity":5.5007,"vote_count":1549,"poster_path":"/xPW3AeK3iQi1Zd9dCbdNLijE48o.jpg","release_date":"1998-07-18","vote_average":6.9,"backdrop_path":"/eA0qc5ihjSKG05tdJO4QPgYPAwY.jpg","original_title":"劇場版ポケットモンスター ミュウツーの逆襲","original_language":"ja"},{"id":10243,"adult":false,"title":"The Flight of the Phoenix","video":false,"overview":"A cargo aircraft crashes in a sandstorm in the Sahara with less than a dozen men on board. One of the passengers is an airplane designer who comes up with the idea of ripping off the undamaged wing and using it as the basis for a replacement aircraft they need to build before their food and water run out.","genre_ids":[12,18],"popularity":1.5891,"vote_count":358,"poster_path":"/zrzLl7NWdjwGhVE7bqpOAxMVtF.jpg","release_date":"1965-12-15","vote_average":7.214,"backdrop_path":"/61cz8dZkyIo9m5bVwwfrYcvVZiK.jpg","original_title":"The Flight of the Phoenix","original_language":"en"},{"id":10264,"adult":false,"title":"Hamlet","video":false,"overview":"Hamlet, Prince of Denmark, finds out that his uncle Claudius killed his father to obtain the throne, and plans revenge.","genre_ids":[18,36],"popularity":1.2282,"vote_count":427,"poster_path":"/cB5HbaiFoQLLmGeN2eeJjBGrp8U.jpg","release_date":"1990-12-19","vote_average":6.6,"backdrop_path":"/mJvvEgkus4COSwzyS2tRwjvHrlY.jpg","original_title":"Hamlet","original_language":"en"},{"id":10377,"adult":false,"title":"My Cousin Vinny","video":false,"overview":"Two carefree pals traveling through rural Alabama on their way back to college are mistakenly arrested and charged with murder. Fortunately, one of them has a cousin who's a lawyer - Vincent Gambini, a former auto mechanic from Brooklyn who has just passed his bar exam after his sixth try. When he arrives with his leather-clad girlfriend to try his first case, it's a real shock - for him and the Deep South!","genre_ids":[35,18],"popularity":3.7746,"vote_count":1803,"poster_path":"/iwSURa8nS2ujwrU3s1lfxxX7voH.jpg","release_date":"1992-03-13","vote_average":7.504,"backdrop_path":"/uEoaOfvWibpvjBNxFoj4MxWn0OH.jpg","original_title":"My Cousin Vinny","original_language":"en"},{"id":10381,"adult":false,"title":"Plunkett & MacLeane","video":false,"overview":"Will Plunkett and Captain James Macleane, two men from different ends of the social spectrum in 18th-century England, enter a gentlemen's agreement: They decide to rid the aristocrats of their belongings. With Plunkett's criminal know-how and Macleane's social connections, they team up to be soon known as \"The Gentlemen Highwaymen\". But when one day these gentlemen hold up Lord Chief Justice Gibson's coach, Macleane instantly falls in love with his beautiful and cunning niece, Lady Rebecca Gibson. Unfortunately, Thief Taker General Chance, who also is quite fond of Rebecca, is getting closer and closer to getting both.","genre_ids":[28,35,18],"popularity":3.3975,"vote_count":149,"poster_path":"/9LASEwSyW2h7Zql0t1ksURC70MG.jpg","release_date":"1999-01-22","vote_average":6.081,"backdrop_path":"/tKQH4kTV9PHtDTghmlPTiLVMuWE.jpg","original_title":"Plunkett & MacLeane","original_language":"en"},{"id":10388,"adult":false,"title":"The Limey","video":false,"overview":"The Limey follows Wilson, a tough English ex-con who travels to Los Angeles to avenge his daughter's death. Upon arrival, Wilson goes to task battling Valentine and an army of L.A.'s toughest criminals, hoping to find clues and piece together what happened. After surviving a near-death beating, getting thrown from a building and being chased down a dangerous mountain road, the Englishman decides to dole out some bodily harm of his own.","genre_ids":[80,18,53,9648],"popularity":1.7744,"vote_count":485,"poster_path":"/efAnFInZYrenNvBlLIXN2oLYyNc.jpg","release_date":"1999-10-08","vote_average":6.536,"backdrop_path":"/mKm56aTBr34ciZTpTWX6WoPubUY.jpg","original_title":"The Limey","original_language":"en"},{"id":10394,"adult":false,"title":"Gangster No. 1","video":false,"overview":"An old gangster is advised that Freddie Mays would leave jail after thirty years in prison. His mood changes and he recalls when he was a young punk and who joined Freddie's gang—a man he both envied and ultimately betrayed.","genre_ids":[28,18,53,80],"popularity":1.1193,"vote_count":228,"poster_path":"/t8eUSsD2reaIR9qmklU7O2GCVn4.jpg","release_date":"2000-06-09","vote_average":6.384,"backdrop_path":"/8zmWwgtiPCWBzxCiRHdmBZoPvXc.jpg","original_title":"Gangster No. 1","original_language":"en"},{"id":470317,"adult":false,"title":"Parava","video":false,"overview":"Irshad and Haseeb, two teenage boys from Mattanchery, share a passion for pigeon flying, a local game. Later, Irshad opens up about a tragic incident that ruined many friendships in the neighbourhood.","genre_ids":[18],"popularity":0.6193,"vote_count":40,"poster_path":"/2L6SAHw8VHEP18ePIK7L8ysAb7T.jpg","release_date":"2017-09-21","vote_average":7.8,"backdrop_path":"/106oOZJ3LyqN4Qn6A1qW8eaFZMJ.jpg","original_title":"പറവ","original_language":"ml"},{"id":661996,"adult":false,"title":"Un Hombre Violento","video":false,"overview":"Bent on avenging the death of his gambling addicted father, Julian Carrera embarks on a violent spree with deadly consequences.","genre_ids":[28,80,18,53],"popularity":0.217,"vote_count":5,"poster_path":"/wOw0EtETlLyqcDG1Xq3GtaZWj3F.jpg","release_date":"1984-01-01","vote_average":4.2,"backdrop_path":null,"original_title":"Un Hombre Violento","original_language":"es"},{"id":10339,"adult":false,"title":"Moby Dick","video":false,"overview":"In 1841, young Ishmael signs up for service aboard the Pequod, a whaler sailing out of New Bedford. The ship is under the command of Captain Ahab, a strict disciplinarian who exhorts his men to find Moby Dick, the great white whale. Ahab lost his leg to that creature and is desperate for revenge. As the crew soon learns, he will stop at nothing to gain satisfaction.","genre_ids":[12,18],"popularity":3.4939,"vote_count":457,"poster_path":"/7JXcm3RyWlGsRCZ0YlOliWr6TNv.jpg","release_date":"1956-06-27","vote_average":7.043,"backdrop_path":"/lbuYAwwTuqiWgpzlxMMPrYkUop4.jpg","original_title":"Moby Dick","original_language":"en"},{"id":10357,"adult":false,"title":"Volcano","video":false,"overview":"An earthquake shatters a peaceful Los Angeles morning and opens a fissure deep into the earth, causing lava to start bubbling up. As a volcano begins forming in the La Brea Tar Pits, the director of the city's emergency management service, working with a geologist, must then use every resource in the city to try and stop the volcano from consuming LA.","genre_ids":[878,28,18,53],"popularity":4.3331,"vote_count":1633,"poster_path":"/5xIjktjXuro7anZ6AR58t5ZYWjQ.jpg","release_date":"1997-04-25","vote_average":5.9,"backdrop_path":"/lYpScP0hkba0X3HY1VrKZ7LOMxS.jpg","original_title":"Volcano","original_language":"en"},{"id":10400,"adult":false,"title":"The Hurricane","video":false,"overview":"The story of Rubin \"Hurricane\" Carter, a boxer wrongly imprisoned for murder, and the people who aided in his fight to prove his innocence.","genre_ids":[18],"popularity":1.9739,"vote_count":1489,"poster_path":"/zhnxjsNnnpsBMF5V1H7Pzkec45Y.jpg","release_date":"1999-09-17","vote_average":7.435,"backdrop_path":"/ffAL7ZiUnCay51SeHFTrTEUpUkO.jpg","original_title":"The Hurricane","original_language":"en"},{"id":10409,"adult":false,"title":"Strictly Ballroom","video":false,"overview":"Brave new steps put Scott's career in jeopardy. With a new partner and determination, can he still succeed?","genre_ids":[35,18,10749],"popularity":1.0217,"vote_count":369,"poster_path":"/f6vs4DQGuNpLuA5Z7k69uuKpbVG.jpg","release_date":"1992-08-20","vote_average":6.583,"backdrop_path":"/5gPUA8ABoBK4D1GUkL1NXTSS8Wq.jpg","original_title":"Strictly Ballroom","original_language":"en"},{"id":10431,"adult":false,"title":"War","video":false,"overview":"FBI agent Jack Crawford is out for revenge when his partner is killed and all clues point to the mysterious assassin Rogue. But when Rogue turns up years later to take care of some unfinished business, he triggers a violent clash of rival gangs. Will the truth come out before it's too late? And when the dust settles, who will remain standing?","genre_ids":[28,80,53],"popularity":4.5264,"vote_count":1997,"poster_path":"/scFc8RD4sFxB2x0eIOaymphMnYh.jpg","release_date":"2007-08-24","vote_average":6.391,"backdrop_path":"/b5IB4VGjR818tTNcCLHQCIFwQmW.jpg","original_title":"War","original_language":"en"},{"id":662285,"adult":false,"title":"New Justice Bao: The Blood Reward","video":false,"overview":"The movie tells the story of Bao Zheng, Gongsun Ce, and Zhan Zhao. When the truth about the mysterious case of Baiyun Town surrounded by the enemy was encountered, he encountered many obstacles from General Tang and his deputy. The story of how Bao Zheng and others will choose when the internal and external troubles occur.","genre_ids":[18],"popularity":0.2228,"vote_count":0,"poster_path":"/bvdlVt1KEYKEX0TFtpQ1tYJcOyk.jpg","release_date":"2019-12-01","vote_average":0,"backdrop_path":"/bTa9U3TDHeirYADcAsZELv6hScZ.jpg","original_title":"新包青天之血酬蛊","original_language":"zh"},{"id":279874,"adult":false,"title":"Battle of the Commandos","video":false,"overview":"A British Colonel is angry with his superiors after his entire platoon is slaughtered by the Germans in what he saw as a suicide mission. So for his next mission, he takes along a platoon a convicted criminals - to prepare the Normandy beaches for the D-Day landings.","genre_ids":[28,10752],"popularity":0.4427,"vote_count":8,"poster_path":"/6X7QQhWBIg3VohZyZwNVRKzUZnI.jpg","release_date":"1969-08-12","vote_average":5.5,"backdrop_path":"/1ORIRwOndtYkSpBKpjZ4tMeWCse.jpg","original_title":"La legione dei dannati","original_language":"it"},{"id":11931,"adult":false,"title":"In Her Shoes","video":false,"overview":"Irresponsible party girl Maggie is kicked out of her father's and stepmother's home—where she lives for free—and is taken in by her hard-working sister, Philadelphia lawyer Rose. After Maggie's disruptive ways ruin her sister's love life, Rose turns her out as well. But when their grandmother, who they never knew existed, comes into their lives, the sisters face some complicated truths about themselves and their family.","genre_ids":[35,18,10749],"popularity":2.1877,"vote_count":1256,"poster_path":"/4x1w6GD9XZvMpBlc44bXLjCbQDj.jpg","release_date":"2005-10-07","vote_average":6.203,"backdrop_path":"/yNhmsmCqK6bTl4xUT28fJ1r6f61.jpg","original_title":"In Her Shoes","original_language":"en"},{"id":11942,"adult":false,"title":"Bring Me the Head of Alfredo Garcia","video":false,"overview":"An American bartender and his prostitute girlfriend go on a road trip through the Mexican underworld to collect a $1 million bounty on the head of a dead gigolo.","genre_ids":[28,80,18],"popularity":0.89,"vote_count":407,"poster_path":"/gRWVf3InNlIlFT3WB9MnFdOwcYQ.jpg","release_date":"1974-08-01","vote_average":7.09,"backdrop_path":"/3U84leD4UV9HadHEHceZp9y2T6y.jpg","original_title":"Bring Me the Head of Alfredo Garcia","original_language":"en"}],"external_ids":{"imdb_id":"tt37893389","twitter_id":"BaahubaliMovie","facebook_id":"BaahubaliMovie","wikidata_id":null,"instagram_id":"baahubalimovie","metacritic_id":"movie/baahubali-the-epic","rotten_tomatoes_id":"m/baahubali_the_epic"},"social_ids":{"twitter":"BaahubaliMovie","facebook":"BaahubaliMovie","instagram":"baahubalimovie"},"gdvg_id":108553,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"FR","release_dates":[{"note":"","type":3,"iso