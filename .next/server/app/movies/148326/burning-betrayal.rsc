_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:24:19.232+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":98,"tagline":"","homepage":"https://www.netflix.com/br/title/81446391","overview":"Nesta adaptação do livro de Sue Hecker, uma contadora vê a traição do noivo como uma oportunidade de transformar sua vida sexual, resultando em consequências arriscadas."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Burning Betrayal","runtime":99,"tagline":"","homepage":"https://www.netflix.com/title/81446391","overview":"Babi discovers a betrayal by her long-term partner and decides to embark on a new adventure in life. On this journey, she meets judge Marco and they begin to live a story permeated by a lot of sexual tension."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Zdrada to nie problem","runtime":0,"tagline":"","homepage":"https://www.netflix.com/title/81446391","overview":"Babi odkrywa zdradę swojego wieloletniego partnera i postanawia rozpocząć nową przygodę w życiu. Podczas tej podróży poznaje sędziego Marco i wspólnie rozpoczynają historię przesiąkniętą wieloma napięciami seksualnymi."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"뜨거운 배신","runtime":0,"tagline":"","homepage":"","overview":"약혼자에게 배신당한 회계사. 배신감에 빠져 있기보다 성적인 자유에 눈뜰 기회로 삼기로 한다. 하지만 위험한 결과가 뒤따라온다. 수 헤케르의 소설을 각색한 작품."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Au plaisir de se faire trahir","runtime":98,"tagline":"","homepage":"","overview":"Dans cette adaptation du roman de Sue Hecker, une comptable voit dans la trahison de son fiancé l'occasion d'un éveil sexuel, avec de sombres conséquences."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Жагуча зрада","runtime":98,"tagline":"","homepage":"","overview":"Бухгалтерка розглядає зраду свого нареченого як можливість дослідити свою сексуальність… із небезпечними наслідками."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"叛我更幸福","runtime":98,"tagline":"","homepage":"","overview":"在这部改编自休·赫克小说的影片中，一名会计师将未婚夫的背叛视为性觉醒的机会，但最终带来了危险的后果。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Végzetes árulás","runtime":98,"tagline":"","homepage":"","overview":"Sue Hecker regényének adaptációjában egy könyvelőnő a vőlegénye árulását a szexuális ébredés lehetőségének tekinti, ami veszélyes következményekkel jár."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"El lado dulce de la traición","runtime":98,"tagline":"","homepage":"","overview":"En esta adaptación del libro de Sue Hecker, una contable ve la traición de su pareja como una oportunidad para vivir un despertar sexual... con consecuencias peligrosas."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Die Vorteile des Betrogenwerdens","runtime":98,"tagline":"","homepage":"","overview":"In dieser Verfilmung des Romans von Sue Hecker sieht eine Buchhalterin den Verrat ihres Verlobten als Gelegenheit für ihr sexuelles Erwachen. Doch das hat gefährliche Konsequenzen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"Die Vorteile des Betrogenwerdens","runtime":0,"tagline":"","homepage":"","overview":"Babi findet heraus, dass ihr langjähriger Partner sie betrügt und entscheidet aus dieser Enttäuschung heraus, sich selbst mal neue Abenteuer im Leben zu gönnen. Dabei trifft sie den Richter Marco und erlebt in Die Vorteile des Betrogenwerdens eine Romanze mit nie zuvor da gewesener sexueller Spannung"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"ไฟทรยศ (Burning Betrayal)","runtime":0,"tagline":"","homepage":"","overview":"นักบัญชีสาวที่ถูกคู่หมั้นนอกใจถือโอกาสเปิดประสบการณ์ทางเพศที่ท้าทายตัวตนที่มาพร้อมผลลัพธ์อันตราย ในภาพยนตร์ที่ดัดแปลงจากนิยายของซู เฮกเกอร์"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Otrohetens fördelar","runtime":0,"tagline":"","homepage":"","overview":"Filmatisering av Sue Heckers roman där en revisor som bedragits av sin fästman tar chansen att upptäcka sin sexualitet – med livsfarliga konsekvenser."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"İyi ki Aldatılmışım!","runtime":98,"tagline":"","homepage":"","overview":"Sue Hecker'ın romanının bu uyarlamasında bir muhasebeci, nişanlısı tarafından aldatılmasını kendi cinselliğini keşfetmek için bir fırsat olarak görünce başını belaya sokar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"El lado dulce de la traición","runtime":0,"tagline":"","homepage":"","overview":"Babi, una contable, ve la traición de su pareja como una oportunidad para vivir un despertar sexual… con consecuencias peligrosas."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"O Lado Bom de Ser Traída","runtime":99,"tagline":"","homepage":"","overview":"Babi ontdekt verraad door haar vaste partner en besluit een nieuw avontuur in het leven te beginnen. Tijdens deze reis ontmoet ze rechter Marco en beginnen ze een verhaal te beleven dat doordrongen is van veel seksuele spanning."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Šťastně podvedená","runtime":0,"tagline":"","homepage":"","overview":"Účetní využije zálety svého snoubence k tomu, aby znovu nakopla svůj sexuální život. Bude to ale mít nebezpečné důsledky."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Lợi Ích Của Việc Bị Phản Bội","runtime":0,"tagline":"","homepage":"","overview":"Trong bản chuyển thể từ tiểu thuyết của Sue Hecker này, một nhân viên kế toán coi sự phản bội của vị hôn phu là cơ hội để thức tỉnh tình dục, để rồi nhận những hậu quả nguy hiểm."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"I vantaggi del tradimento","runtime":0,"tagline":"","homepage":"","overview":"Babi scopre un tradimento da parte del suo compagno di lunga data e decide di intraprendere una nuova avventura nella vita. In questo viaggio incontra il giudice Marco e iniziano a vivere una storia permeata da molta tensione sessuale."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Плюсы обмана","runtime":98,"tagline":"","homepage":"","overview":"В экранизации романа Сью Хекер героиня, которая работает бухгалтером, видит в измене жениха возможность для новых сексуальных открытий. Но дело принимает опасный оборот."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Nesta adaptação do romance de Sue Hecker, uma contabilista encara a traição do noivo como uma oportunidade para viver um despertar sexual... com perigosas consequências."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Bolje mi je kad me varaš","runtime":0,"tagline":"","homepage":"","overview":"U ovoj adaptaciji romana Sue Hecker, računovotkinja u nevjeri svoga zaručnika vidi priliku za seksualno buđenje, s opasnim posljedicama."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"יתרונות הבגידה","runtime":98,"tagline":"","homepage":"","overview":"רואת חשבון רואה בבגידתו של ארוסה הזדמנות להתעוררות מינית, אבל ההשלכות מסוכנות. עיבוד לרומן של סו הקר."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"我被叛我驕傲","runtime":0,"tagline":"","homepage":"","overview":"描述一位會計師遭未婚夫背叛，她從中看到性覺醒的機會，卻引來危險的後果。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Τα Θετικά της Απιστίας","runtime":0,"tagline":"","homepage":"","overview":"Σ' αυτήν τη μεταφορά μυθιστορήματος της Σου Χέκερ, μια λογίστρια βλέπει την απιστία του αρραβωνιαστικού της ως ευκαιρία για σεξουαλική αφύπνιση, με επικίνδυνες συνέπειες."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Burning Betrayal","runtime":0,"tagline":"","homepage":"","overview":"ဇာတ်လမ်းက အချစ်ကားလိုပုံစံမျိုးပေမယ့် မထင်မှတ်ထားတဲ့အလှည့်အပြောင်းလေး ထည့်ထားပေးတော့ အတော်လေးကြည့်လို့ကောင်းတဲ့ကားလေးဖြစ်ပါတယ် ဇာတ်လမ်းအကျဉ်းကတော့ ဘာဘီဟာ သူနဲ့ငါးနှစ်တာအတူတွဲခဲ့တဲ့ ကိုင်ရိုနဲ့ လက်ထပ်တော့မယ့်အချိန်မှာပဲ ကိုင်ရိုဟာ သူ့နောက်ကွယ်မှာ တခြားကောင်မလေးတစ်ယောက်နဲ့ ဖောက်ပြန်နေတာကိုသိလိုက်ရပါတယ် နှစ်တွေအကြာကြီး လက်တွဲလာခဲ့တဲ့သူဖြစ်တဲ့အတွက် ဒီအကြောင်းကိုသိတဲ့အခါ ဘာဘီတစ်ယောက်အတော်လေး ပြိုလဲသွားပါတယ် ဒါပေမယ့် သိပ်မကြာပါဘူး သူ့ကို စိတ်ဝင်စားနေတဲ့ ခပ်မိုက်မိုက်တရားသူကြီးမာကိုနဲ့ တွေ့ခဲ့ပါတယ်ဘာဘီနဲ့ မာကိုတို့ရဲ့အချစ်ဇာတ်လမ်းက ဘယ်လိုဖြစ်မလဲ၊ ဘာဘီလိုချင်နေတဲ့ ဆက်ဆံရေးမျိုးကို မာကိုနဲ့ရော အဆင်ပြေစွာနဲ့ တည်ဆောက်နိုင်ပါ့မလားဆိုတာကိုတော့"},"name":"","iso_639_1":"my","iso_3166_1":"MY","english_name":"Burmese"},{"data":{"title":"Trădare arzătoare","runtime":98,"tagline":"","homepage":"","overview":"O contabilă vede trădarea logodnicului ei ca pe o oportunitate pentru o trezire sexuală, cu consecințe periculoase. O adaptare după romanul lui Sue Hecker."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"叛侶的祝福","runtime":0,"tagline":"","homepage":"","overview":"這部作品改編自蘇·海克的原著小説，描述一位會計師遭未婚夫背叛，她從中看到性覺醒的機會，卻引來危險的後果。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Au plaisir de se faire trahir","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ca-fr/title/81446391","overview":"Une femme aborde la trahison de son fiancé comme une occasion d'éveil sexuel – mais l'affaire n'est pas sans conséquence."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"}],"reviews_tmdb":[{"id":"677ce0555c738e1c22668a7a","url":"https://www.themoviedb.org/review/677ce0555c738e1c22668a7a","author":"vylmen","content":"What do you get when you combine softcore port with a crime thriller? That's what this is and so it just bland overall. The thriller part doesn't come to life because of the sex and lousy dialogue to bridge to the next sex scene and well, softcore sex is bland by design.\r\n\r\nHad to stop it after about 30 minutes, no redeeming qualities. Can't recommend.","created_at":"2025-01-07T08:05:41.263Z","updated_at":"2025-01-07T08:05:41.314Z","author_details":{"name":"","rating":3,"username":"vylmen","avatar_path":null}}],"recommendations":[{"id":1352821,"adult":false,"title":"A True Gentleman","video":false,"overview":"A charming male escort finds his life turned upside down when he starts to fall in love, challenging him to discover what he truly wants and needs.","genre_ids":[10749,18],"media_type":"movie","popularity":0.6871,"vote_count":53,"poster_path":"/dCMSCNy8kGerF1Dw4woWUP6ltxR.jpg","release_date":"2024-09-25","vote_average":6.019,"backdrop_path":"/zFyK00VDVqcRIYw7pw57LiTyolV.jpg","original_title":"Tam Bir Centilmen","original_language":"tr"},{"id":1116407,"adult":false,"title":"Ó Paí, Ó 2","video":false,"overview":"Experience Roque's routine years after the first movie. Joana's tenement is still full of parties, gossip and confusion. The neighborhood prepares for the Iemanjá party, while dealing with the controversies of the neighbors.","genre_ids":[35,18],"media_type":"movie","popularity":0.2118,"vote_count":21,"poster_path":"/rTus3KG0ZAbqbuHWBafV7Adsbyf.jpg","release_date":"2023-11-23","vote_average":5.5,"backdrop_path":"/a7DVQBPQj9cl6bEyn8wOWZELTLs.jpg","original_title":"Ó Paí, Ó 2","original_language":"pt"},{"id":1132079,"adult":false,"title":"Survive","video":false,"overview":"When their plane crashes on a remote snow-covered mountain, Jane and Paul have to fight for their lives as the only remaining survivors. Together they embark on a harrowing journey out of the wilderness.","genre_ids":[12,18,53],"media_type":"movie","popularity":4.0166,"vote_count":45,"poster_path":"/lFOkcoEzVX2VAu0OaDn94seP2gd.jpg","release_date":"2022-05-12","vote_average":4.989,"backdrop_path":"/dHrjWI7MnKc1Y1b03pHzFvcAu91.jpg","original_title":"Survive","original_language":"en"},{"id":522645,"adult":false,"title":"Bastaard","video":false,"overview":"Two years after the tragic loss of his older brother, 17-year-old Daan unwillingly goes along when his grieving family decides to give shelter to a homeless teenager called Radja. But as Daan witnesses how this stranger's presence deeply affects his mother, he starts to unravel Radja's mysterious past.","genre_ids":[53],"media_type":"movie","popularity":0.8634,"vote_count":19,"poster_path":"/3jQsFqoXsIOFOC2uZKt1Gxuwxqc.jpg","release_date":"2019-10-02","vote_average":5.316,"backdrop_path":"/wh9BL8WjBHULS55K7zblSzxBIW3.jpg","original_title":"Bastaard","original_language":"nl"},{"id":971511,"adult":false,"title":"Must Love Christmas","video":false,"overview":"A renowned romance novelist becomes involved in a love triangle between her childhood crush and a reporter.","genre_ids":[10770,35,10749,14],"media_type":"movie","popularity":0.2344,"vote_count":21,"poster_path":"/psgIF5lvCpm14vaoOkVnmW5Xgiv.jpg","release_date":"2022-12-11","vote_average":5.905,"backdrop_path":"/ou3PlMNBW7SUSExG4c6JZukBrNQ.jpg","original_title":"Must Love Christmas","original_language":"en"},{"id":1160025,"adult":false,"title":"Naga","video":false,"overview":"Stranded amid Riyadh's desert dunes, Sarah, a local Saudi girl, escapes heartaches and the vengeance of a vigorous camel after discreetly sneaking out of her parent's home for a romantic date that landed her astray.","genre_ids":[53],"media_type":"movie","popularity":0