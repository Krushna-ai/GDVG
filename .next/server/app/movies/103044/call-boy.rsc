fVRb3uoRDjbA9X95C88FOJ0rlZ.jpg","iso_639_1":"en","vote_average":0},{"width":975,"height":1462,"file_path":"/7Cx7LdG0NszjeKatvDMV9JLRQye.jpg","iso_639_1":"ja","vote_average":0},{"width":960,"height":1440,"file_path":"/8elI5i8cu1VXt5ERyx5nDaOwv1b.jpg","iso_639_1":"en","vote_average":0}],"backdrops":[{"width":2000,"height":1125,"file_path":"/1p98ESRDKb3W1BS8GluxHvDDhRa.jpg","iso_639_1":null,"vote_average":3.334},{"width":2620,"height":1474,"file_path":"/uPxiJyzOVIjSMbE2YKCGmWoTNHr.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/kZk1qqT7uQrNexx34rKOTx2YSJl.jpg","iso_639_1":"en","vote_average":3.334},{"width":1920,"height":1080,"file_path":"/wortdv0LtU7D4mnMFuYl78KsFpJ.jpg","iso_639_1":null,"vote_average":3.334},{"width":2060,"height":1159,"file_path":"/aGAHNqb3526WmFEsswVSnZzgV7B.jpg","iso_639_1":null,"vote_average":1.75},{"width":3100,"height":1744,"file_path":"/21JFA1GyCNu0FDCTpHMreVDzr4E.jpg","iso_639_1":"en","vote_average":0}]},"enriched_at":"2026-04-21T07:24:25.188+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Call Boy","runtime":119,"tagline":"","homepage":"http://shonen-movie.com/","overview":"Ryo Morinaka is a university student and works part-time at a bar. He is bored with his daily life and exists in a state of torpor. One day, his friend Shinya Tajima brings the owner of a host bar over to the place where Ryo Morinaka works. Shizuka Mido is the owner of the host bar. Soon, Ryo Morinaka begins to work for Shizuka Mido at the members only host bar. He feels embarrassment initially, but he fulfills the desires of women and develops a sense of purpose."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"콜보이","runtime":119,"tagline":"아무도 해본 적 없는 영화체험! 감성을 자극하는 19금 멜로드라마","homepage":"","overview":"일상에서도, 여성과의 관계에서도 따분함을 느끼며 무기력하게 생활하던 명문대생 료(마츠자카 토리). 어느 날 시즈카(마토부 세이)라는 아름다운 여성이 료가 아르바이트 하는 바에 찾아온다. 여성과의 관계가 시시하다는 료에게 시즈카는 ‘정열의 시험’을 치르게 한다. 그것은 바로 시즈카가 운영하는 회원제 클럽의 입사 시험. 시험에 통과한 료는 다음 날부터 ‘콜보이’로서 일하게 된다. 당황스러운 일을 겪기도 하지만 콜보이로 일해 나가면서 료는 점차 여성 한 명 한 명의 마음 속에 숨겨진  욕망의 신비로움을 깨닫고 진정한 보람을 느끼기 시작한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"娼年","runtime":0,"tagline":"","homepage":"","overview":"该片改编自同名小说，讲述森中领（松坂桃李 饰）是个平凡的20岁男大生，每天过着平凡无趣的生活。某天，他认识了经营会员制BOYS CLUB的老板——御堂静香（真飞圣 饰），在她的诱惑下 ，森中领决定以「娼夫（男妓）」的身份在她的店里工作。随着和各式各样的女性接触 ，森中领温柔地释放了她们内心所蕴藏的欲望，疗愈她们受伤的心，自己也渐渐有所成长。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"娼年","runtime":0,"tagline":"","homepage":"","overview":"森中領（松坂桃李 飾）是個平凡的 20 歲男大生，每天過著平凡無趣的生活。某天，他認識了經營會員制 BOYS CLUB 的老闆 - 禦堂靜香（真飛聖飾），在她 的誘惑下，森中領決定以「娼夫（男妓）」的身份在她的店裏工作。隨著和各式各樣的女性接觸，森中領温柔地釋放了她們內心所藴藏的慾望，療愈她們受傷的心，自己也漸漸有所成長。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"娼年","runtime":0,"tagline":"","homepage":"","overview":"該片改編自同名小說，講述森中領是個平凡的20歲男大生，每天過著平凡無趣的生活。某天，他認識了經營會員制BOYS CLUB的老闆——御堂靜香，在她的誘惑下，森中領決定以「娼夫（男妓）」的身份在她的店裡工作。隨著和各式各樣的女性接觸，森中領溫柔地釋放了她們內心所蘊藏的慾望，療愈她們受傷的心，自己也漸漸有所成長。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"娼年","runtime":0,"tagline":"そして僕は、娼夫になったー","homepage":"","overview":"大学生のリョウこと森中領（松坂桃李）は、バーのアルバイトに精を出していた。ある晩、ホストクラブで働いている中学時代のクラスメートの田島進也が、客の御堂静香を連れてリョウがいるバーを訪れる。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Call Boy","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Call Boy","runtime":90,"tagline":"","homepage":"","overview":"Ryo Morinaka es un estudiante universitario y trabaja a tiempo parcial en un bar. Él está aburrido con su vida diaria y existe en un estado de letargo. Un día, su amigo Shinya Tajima lleva al dueño de una barra de host al lugar donde trabaja Ryo Morinaka. Shizuka Mido es el dueño de la barra de host. Pronto, Ryo Morinaka comienza a trabajar para Shizuka Mido en la barra de host solo para miembros. Inicialmente se siente avergonzado, pero cumple los deseos de las mujeres mayores y desarrolla un sentido de propósito. (Géneros: Erótico, Drama)"},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Call Boy","runtime":119,"tagline":"","homepage":"","overview":"Een jongeman die geplaagd wordt door zijn verleden probeert zich in zijn eigen levensonderhoud te voorzien door als callboy te gaan werken, met als clientèle hoofdzakelijk vrouwen van middelbare leeftijd die hun verborgen seksuele fantasieën werkelijkheid willen laten worden. De bijzondere seksuele uitspattingen helpen zowel zijn clientèle als hem zichzelf weer terug te vinden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Call Boy","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Call Boy","runtime":0,"tagline":"","homepage":"","overview":"Bir üniversite öğrencisi olan, Ryo, para kazanmak için barda yarı zamanlı çalışmaktadır. Genç yaşta annesini kaybeden zavallı genç, ne işinden ne de hayatından memnundur. Bir akşam arkadaşının aracılığı ile kadın bir muhabbet tellalı ile tanışır. Onu bir teste sokan bu kadın, Ryo testi geçtikten sonra ona bir iş teklifinde bulunur. Ryo artık jigalo olarak çalışacaktır. Yeni işi duyunca direk kabul eden Ryo, değişik müşterileri ile kendini tatmin etmeye başlar. Müşterilerinin isteklerini ve ihtiyaçlarını öğrenmeye başlamak, Ryo’nun kendisini daha iyi anlamasına yardımcı olur. Kendini daha iyi anlaması, kendi isteklerininde olduğunu fark etmesine sebep olur. Kendini anlaması, kavramasına... Kavraması ise, sorgulamasına sebep olacaktır!"},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Call Boy","runtime":0,"tagline":"","homepage":"","overview":"Ryo a vingt ans, et la vie lisse, docile et banale que convoitent ses camarades d’université ne l’intéresse pas. Ce jeune homme désabusé de tout, passionné de rien, est abordé par la gérante d’un club privé réservé aux femmes. Au fil de rencontres qui sont autant de découvertes, ce sont ces femmes portant chacune un désir différent qui vont lui permettre de mûrir au cours d’un insolite parcours initiatique.\r Chacune recèle une fêlure, une attente secrète, qui échappent parfois radicalement aux normes sociales."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Trai Bao","runtime":0,"tagline":"","homepage":"","overview":"Morinaka Ryo là sinh viên đại học và đang làm việc bán thời gian tại một quán bar. Thông qua người bạn cùng lớp thời trung học của mình là Tajima Shinya hiện đang làm việc tại host club, Ryo đã gặp gỡ một người phụ nữ tên Mido Shizuka. Morinaka Ryo vốn không có hứng thú gì với tình yêu hay phụ nữ, đã chấp nhận lời mời gia nhập câu lạc bộ nam có tên Passion do Shizuka làm chủ, để “làm chồng”. Morinaka Ryo ngạc nhiên và dần cảm thấy đồng cảm với những mong muốn của những người phụ nữ cô đơn mà anh tiếp xúc, để rồi từ đó càng hiểu hơn về Shizuka."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Мальчик по вызову","runtime":0,"tagline":"","homepage":"","overview":"Рё Моринака учится в университете и подрабатывает в местном баре. Дни парня текут максимально однообразно и вгоняют в уныние. Однажды его друг приводит в бар, где работает Рё, Сидзуку Мидо, хозяйку хост-бара. Она предлагает парню работу, он с готовностью соглашается и вскоре начинает лучше понимать, чего хотят женщины."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Shonen - Call Boy","runtime":0,"tagline":"","homepage":"","overview":"Ryo Morinaka (Tôri Matsuzaka) ist Student und arbeitet nachts als Barkeeper in einer kleinen Kneipe. Immer mal wieder trifft er dort Mädchen, mit denen er bedeutungslose One-Night-Stands hat. Doch der Sex langweilt ihn ebenso wie sein restliches Leben. Seine Einstellung ändert sich erst, als sein Freund Shinya (Yû Koyanagi) ihn mit Shizuka (Sei Matobu) bekannt macht. Fasziniert von der etwas älteren, aber sehr attraktiven Frau geht er mit ihr nach Hause. In ihrem Schlafzimmer verweigert sie sich ihm dann allerdings und verlangt stattdessen, ihm beim Sex mit der jungen Sakura (Ami Tomite) zuzusehen. Am Ende des Abends bezahlt sie Ryo, doch ihr Urteil über den jungen Mann fällt nicht gerade positiv aus. Nur dank Sakuras Fürsprache besteht Ryo dennoch den Test und erhält von Shizuka das Angebot, als Gigolo und Callboy in ihrem Klub zu arbeiten. Verführt vom Geld und dem Wunsch, endlich wirklich aufregenden Sex zu erleben, geht er darauf ein ..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"ဖန်းဆင်းခဲ့ပြီးသော မိန်းမသားများ၏  ဖြစ်တည်ခဲ့သော သဘာဝတရားများသည်ယောင်္ကျားသားများနှင့်ယှဉ်လျှင် အနည်းငယ် ဒုက္ခရောက်ရသော ကိစ္စများရှိလေသည် ထို့ကြောင့်ပင် အားနွဲ့သောမိန်းမသားလို့ သုံးနှုံးကြလေသည် ထို့ကြောင့်  မိန်းမသားများသည် မိမိတို့၏ အားနည်းချက်များကို ဖုံးကွယ်ရန်အလို့ငှါ ဉာဏ်ကိုတတ်နိုင်သမျှ သုံးကြလေသည် ထိုဉာဏ်ကို မာယာဟု တစ်ချို့သောသူတွေက ခေါ်ဆိုကြပြန်သည် ဒီကားလေးကတော့ မာယာနတ္ထိနဲ့မိန်းမသားအချို့အကြောင်းကိုခပ်လှလှလေးရိုက်ပြထားတာပါ ဒီဂျပန်ကားလေးမှာတော့ အချို့သောအမျိုးသမီးများသည် လိင်မှုကိစ္စများနှင့်အခြားမွန်းကြတ်နေသောကိစ္စများကိုဖြေဖျောက်ရန် အခကြေးငွေးပေးကာ  တိတ်တဆိတ်ခေါ်ယူရနိုင်သည့် ကောင်လေးများနှင့်အကြောင်းကို ရိုက်ကူးထားခြင်းဖြစ်သည် ဒီကားကိုကြည့်ခြင်းအားဖြင့် အမျိုးသမီးတွေရဲ့ ကွယ်ဝှက်ထားသော အလွှာများကိုမြင်တွေ့နိုင်သည် ပြီးတော့ ဇာတ်အိမ်ကောင်းကောင်းလေးနဲ့ ခမ်းခမ်းနားနားလှလှပပလေးကိုရိုက်ပြထားတာ နောက်ခံသီးချင်းသံကအစ Lighting အဆုံး လူတွေကိုစနစ်တကျလေးရွေးချယ်ထားတာရောတော်တော်ကိုမိုက်တယ် (18+ အခန်းပေါင်းများစွာ ပါဝင်သဖြင့် မိသားစုနှင့်အတူမကြည့်သင့်ပါ)"},"name":"","iso_639_1":"my","iso_3166_1":"MY","english_name":"Burmese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Băiatul de chemat","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"}],"reviews_tmdb":[],"recommendations":[{"id":80662,"adult":false,"title":"Guilty of Romance","video":false,"overview":"While police investigate a woman found dead in a derelict love hotel, a romance novelist's wife lives a life that seems simply a daily repetition without romance. To escape the loveless monotony, she follows her desires and becomes a nude model. Soon, she meets a mentor and begins selling her body to strangers, while at home, she hides behind the façade of the doting wife.","genre_ids":[53,27,9648],"media_type":"movie","popularity":1.8956,"vote_count":235,"poster_path":"/9Yc6ip8cBDbkfy5K8Ob401PjlJa.jpg","release_date":"2011-09-30","vote_average":6.9,"backdrop_path":"/5nbmhg54or0ruvIg3d2pMRov8RD.jpg","original_title":"恋の罪","original_language":"ja"},{"id":571603,"adult":false,"title":"Juror 8","video":false,"overview":"Seoul, South Korea, September 21st, 2008. Eight citizens, the first to intervene as jurors in the country's legal history, are randomly selected to examine a matricide case that appears to have been resolved due to the existence of apparently conclusive evidence.","genre_ids":[18],"media_type":"movie","popularity":0.7391,"vote_count":31,"poster_path":"/hNbbdoGVNzwOu22VW2sfiyxDtcK.jpg","release_date":"2019-05-15","vote_average":7.4,"backdrop_path":"/tseYcE382x1goVptRC62AHUG9xX.jpg","original_title":"배심원들","original_language":"ko"},{"id":128883,"adult":false,"title":"Crayon Shin-chan: The Legend Called Dance! Amigo!","video":false,"overview":"Something sinister's afoot in Kasukabe. Shin-chan doesn't know what it is, but he's pretty sure it involves samba-dancing doppelgängers.","genre_ids":[35,16],"media_type":"movie","popularity":1.5067,"vote_count":39,"poster_path":"/vjWBUrPshZiBHAEXR9mlMlVlbOZ.jpg","release_date":"2006-04-15","vote_average":7.5,"backdrop_path":"/jUKn2iQK2pd2XNM1dhcP7Gb991b.jpg","original_title":"クレヨンしんちゃん 伝説を呼ぶ 踊れ！アミーゴ！","original_language":"ja"},{"id":658006,"adult":false,"title":"Romance Doll","video":false,"overview":"It was a pre-destined love and marriage for Sonoko and Tetsuo. They tied the knot and became husband and wife no questions asked. All is well then. Well, perhaps not. Each holds a secret that even the binds of matrimony cannot untie.","genre_ids":[10749,18],"media_type":"movie","popularity":1.314,"vote_count":48,"poster_path":"/68tDy1xSJcT3kFpKimenuVVHqzJ.jpg","release_date":"2020-01-24","vote_average":7.1,"backdrop_path":"/5GGaoOxrSeFAGXoLOISyD4cjZAQ.jpg","original_title":"ロマンスドール","original_language":"ja"},{"id":1070032,"adult":false,"title":"Beyond Utopia","video":false,"overview":"A courageous pastor uses his underground network to rescue and aid North Korean families as they risk their lives to embrace freedom.","genre_ids":[99,36],"media_type":"movie","popularity":0.5692,"vote_count":60,"poster_path":"/fcyCtyXabv0X8TInqoL9yq5DCdb.jpg","release_date":"2023-10-23","vote_average":7.7,"backdrop_path":"/2pBDP2Ip5mQemw3PYTjDLYv9XI9.jpg","original_title":"Beyond Utopia","original_language":"en"},{"id":117352,"adult":false,"title":"Crayon Shin-chan: Super-Dimension! The Storm Called My Bride","video":false,"overview":"Shin-chan is approached by his time-traveling future bride-to-be Tamiko, who asks him to help save his adult self from the ruler of Neo Tokio.","genre_ids":[16,35,10751],"media_type":"movie","popularity":1.4157,"vote_count":61,"poster_path":"/zUoLr4wvk45t19HdrNWFGp0RtbG.jpg","release_date":"2010-04-17","vote_average":7.7,"backdrop_path":"/snDGwQ3fbfNiGwUfT7dVPQ4MTSV.jpg","original_title":"クレヨンしんちゃん 超時空！嵐を呼ぶオラの花嫁","original_language":"ja"},{"id":447180,"adult":false,"title":"My Teacher","video":false,"overview":"Hibiki Shimada, a normal 17-year-old high-school student, still does not know how to fall in love—although surrounded by love \"experts\"—until one day she realizes she's fallen in love with her hot and nice 26-year-old teacher, Itō. She then takes a path to make her teacher understand how she feels for him.","genre_ids":[10749,18],"media_type":"movie","popularity":0.863,"vote_count":32,"poster_path":"/An1er9gMQZMVdamZI2Un8sd3FbJ.jpg","release_date":"2017-10-28","vote_average":7.3,"backdrop_path":"/dxPDr0aeJFF1ZCOKAVtnrcjPFjG.jpg","original_title":"先生！　、、、好きになってもいいですか？","original_language":"ja"},{"id":318541,"adult":false,"title":"Casa Amor: Exclusive for Ladies","video":false,"overview":"A beautiful workaholic is fired from her job as a marketing executive for a children's toy company. With her life spinning out of control she teams up with her neighbour, who owns a sex shop, to design and promote better sex toys.","genre_ids":[35,10749],"media_type":"movie","popularity":1.2191,"vote_count":22,"poster_path":"/1JjotwfRfgHbdE4jXkcRh86QveU.jpg","release_date":"2015-01-07","vote_average":5.7,"backdrop_path":"/5hSA5hza4zuE1efI7HRNhyPzw5F.jpg","original_title":"워킹걸","original_language":"ko"},{"id":462858,"adult":false,"title":"Call","video":false,"overview":"Paris To Kyiv’s Fragmenti recording was originally released in 2005, a sonic tapestry of ancient Ukrainian song fragments and contemporary sounds. Nearly 11 years later, after circulating throughout the roster of artists on Balanced Records, a remix album has been compiled featuring electronic and avant garde interpretations by Ken Gregory, Joe Silva, Rise Ashen, Kasm, J57, Solidaze, Cayetano, Miguel Graça, Trevor Walker and Anders Peterson.  This film accompanies the remix by Joe Silva.","genre_ids":[10402],"media_type":"movie","popularity":0.128,"vote_count":6,"poster_path":null,"release_date":"2016-05-14","vote_average":6.2,"backdrop_path":null,"original_title":"Call","original_language":"en"},{"id":460105,"adult":false,"title":"Revenge Porn: Love Is Dead","video":false,"overview":"A female office worker grows tired of her popular and attractive colleague's office affairs, and releases explicit footage of her as revenge.","genre_ids":[18,53],"media_type":"movie","popularity":0.4976,"vote_count":20,"poster_path":"/xA7BPYt95hED5BGCDMekEQYxeA7.jpg","release_date":"2015-12-25","vote_average":5.2,"backdrop_path":"/gDEwUA8SYBoalYbS9IgDyjCMUCo.jpg","original_title":"リベンジポルノ LOVE IS DEAD","original_language":"ja"},{"id":442987,"adult":false,"title":"Our Meal for Tomorrow","video":false,"overview":"A 7 year love story between Ryota Hayama and Koharu Uemura from their first date to eventual marriage.  Ryota and Koharu are high school students. Ryota is indifferent to people and says very little. Koharu is not afraid of to speak her mind and she has a bright personality. Since a game of rice bag jump, they begin to date. They date at a fast-food restaurant, realize they love each other at a family restaurant and finally swear their love on a dining table with white rice.","genre_ids":[18,10749],"media_type":"movie","popularity":0.6571,"vote_count":7,"poster_path":"/mvlf8drQekYlNuH3ZMtwU3omcM6.jpg","release_date":"2017-01-07","vote_average":5.6,"backdrop_path":"/6C53cLTD69k5X78EpLY5O9Vpul5.jpg","original_title":"僕らのごはんは明日で待ってる","original_language":"ja"},{"id":681882,"adult":false,"title":"Walking with My Grandma","video":false,"overview":"Natsumi is proposed to by Yamato, a man who aims to become a fisherman to succeed his father. Her grandmother Kiyo, who raised her since a young age, broke her legs and uses a wheelchair now. Kiyo lives in a facility where Natsumi visits to tell her about the wedding. Natsumi suggests the idea of Kiyo walking along the wedding aisle with her, which encourages the week Kiyo. With that mindset, Kiyo regains hope and try to get better with the help of Natsumi","genre_ids":[35],"media_type":"movie","popularity":0.225,"vote_count":1,"poster_path":"/vpcaJRHcUAODOEFnhxNvHYBvqTI.jpg","release_date":"2018-04-14","vote_average":8,"backdrop_path":"/bhsCWzrw9q4h4wbbpFLl56H1j5B.jpg","original_title":"ばぁちゃんロード","original_language":"ja"},{"id":499028,"adult":false,"title":"Be with You","video":false,"overview":"Along with his young son, Ji-ho, Woo-jin misses his wife Soo-a, who died after promising to return a year later with the rainy season. Miraculously, they reunite with Soo-a when the rainy season comes around, but she has no memory of her husband and son whom she dearly loved.","genre_ids":[10749,18,14],"media_type":"movie","popularity":1.4098,"vote_count":219,"poster_path":"/mvstNgM68EyCRWwpArakLhWvvtk.jpg","release_date":"2018-03-14","vote_average":8.162,"backdrop_path":"/dw9KDRImNzj3jWYSkTte7wvzamO.jpg","original_title":"지금 만나러 갑니다","original_language":"ko"},{"id":571785,"adult":false,"title":"Time to Hunt","video":false,"overview":"Four young men want to leave their dystopian world behind and go to a distant paradise to execute a money robbery, a daring act that will have unexpected consequences.","genre_ids":[18,28,53],"media_type":"movie","popularity":1.3583,"vote_count":339,"poster_path":"/bkuuvDoPkOJpg0ZDzHkUWt8ZG5A.jpg","release_date":"2020-02-22","vote_average":7.168,"backdrop_path":"/a8ppJJIQmEJcLSFfhxupc4aT4KW.jpg","original_title":"사냥의 시간","original_language":"ko"},{"id":55931,"adult":false,"title":"The Animatrix","video":false,"overview":"Straight from the creators of the groundbreaking Matrix trilogy, this collection of short animated films from the world's leading anime directors fuses computer graphics and Japanese anime to provide the background of the Matrix universe and the conflict between man and machines. The shorts include Final Flight of the Osiris, The Second Renaissance, Kid's Story, Program, World Record, Beyond, A Detective Story and Matriculated.","genre_ids":[16,878],"media_type":"movie","popularity":3.3849,"vote_count":1722,"poster_path":"/eDjIG2hAeMU5cxLrd6oiQqdqoZt.jpg","release_date":"2003-05-09","vote_average":7