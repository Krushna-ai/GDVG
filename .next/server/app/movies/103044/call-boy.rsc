5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Call Boy\",\"description\":\"Ryo Morinaka is a university student and works part-time at a bar. He is bored with his daily life and exists in a state of torpor. One day, his friend Shinya Tajima brings the owner of a host bar over to the place where Ryo Morinaka works. Shizuka Mido is the owner of the host bar. Soon, Ryo Morinaka begins to work for Shizuka Mido at the members only host bar. He feels embarrassment initially, but he fulfills the desires of women and develops a sense of purpose.\",\"image\":\"https://image.tmdb.org/t/p/w500/3fVRb3uoRDjbA9X95C88FOJ0rlZ.jpg\",\"datePublished\":\"2018-04-06\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Drama\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.444,\"bestRating\":10,\"ratingCount\":54}}"}}],["$","$L10",null,{"initialDrama":{"id":"3cb1e865-2e23-4c96-8cae-941ffa627596","tmdb_id":499191,"imdb_id":"tt7529650","content_type":"movie","title":"Call Boy","original_title":"娼年","overview":"Ryo Morinaka is a university student and works part-time at a bar. He is bored with his daily life and exists in a state of torpor. One day, his friend Shinya Tajima brings the owner of a host bar over to the place where Ryo Morinaka works. Shizuka Mido is the owner of the host bar. Soon, Ryo Morinaka begins to work for Shizuka Mido at the members only host bar. He feels embarrassment initially, but he fulfills the desires of women and develops a sense of purpose.","poster_path":"/3fVRb3uoRDjbA9X95C88FOJ0rlZ.jpg","backdrop_path":"/1p98ESRDKb3W1BS8GluxHvDDhRa.jpg","release_date":"2018-04-06","first_air_date":null,"status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":18,"name":"Drama"}],"popularity":5.4582,"vote_average":6.444,"vote_count":54,"runtime":119,"number_of_seasons":null,"num