tio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/d2RWT4IPPUiGQIZhoDiDm4HXtxA.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/1IE0qEPqhONadr1MF29Au50hYqy.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/vrC8aAA7E28ckMEUqOWtXqMCF2f.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/141TxZfFdxp0d3GT6E9quuhOq7g.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/7WxNJ7Ei9kKx7dkP7pzbKb1lwsv.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/7UKMdjseEgxb9lAmVmvOFp3NDaM.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/cEO5gcJZGutNzmuc4V3NN4J3ZuK.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/tLf5hjuO4gx62lVojPiHsIzCroh.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":2.542},{"width":1500,"height":844,"file_path":"/dE7EkdlFRmXzugANiwtVOtqNw4u.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.777,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/gFHJ9dHtgO06n7NFoDDq9j7n4Zs.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/KBBvrPFX4OkjQ2zYqHFyoKo0ac.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/55BzBTepLbmspUWs07VINnluby1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/deyKBSQz6llryBQLFB4eWc9L4Su.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/o2l3nln5VbfqQzhTrEBPQWpDwMq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/sBCtbFg3Ej0cH0NdyWawXzXxkQr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/uVqAOLNggs7v9Kyj6uTHKVVbkBX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T06:50:46.506+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":101,"tagline":"Chaque seconde compte.","homepage":"https://www.snd-films.com/movies/7","overview":"Nord de la France, 2005 : Malik, inspecteur de police, assiste impuissant à la mort d’une enfant suite à un kidnapping. En charge de l’enquête, il échoue à retrouver le meurtrier. DIX ANS PLUS TARD, sans élément nouveau, sans trace d'un dangereux criminel qui court toujours, l'affaire s’apprête à être classée définitivement. Mais quand de nouveaux faits en lien avec l’affaire se révèlent, Malik entame une course contre la montre dans l’espoir de résoudre l'enquête avant l’expiration du délai de prescription. Dans Six Jours. C’est le temps qui lui reste pour retrouver le coupable."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"The Chase","runtime":95,"tagline":"","homepage":"","overview":"11 years ago, inspector Malik couldn’t solve a kidnapping case and a little girl died. Now with only a few days before the crime gets classified, he decides to reopen the case. Malik owes it to the mother and to himself. As he digs into the past, a child is kidnapped again. The pattern is the same one as a decade ago, it’s no coincidence. Malik knows he has a few days to make things right and to bring justice."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"6 dni","runtime":95,"tagline":"","homepage":"","overview":"Jedenaście lat temu policjantowi nie udało się złapać mordercy młodej dziewczyny. Kiedy na kilka dni przed zamknięciem sprawy w ten sam sposób zostaje porwane kolejne dziecko, postanawia powrócić do nierozwiązanej sprawy porwania."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"По следу тени","runtime":95,"tagline":"«Каждая секунда на счету»","homepage":"","overview":"В 2005 году инспектор полиции Малик занимался расследованием похищения и убийства ребенка. Преступник исчез, а следствие зашло в тупик. Спустя десять лет, когда дело готовятся окончательно закрыть, происходит новое похищение с тем же почерком. У Малика остается шесть дней до истечения срока давности — шесть дней, чтобы выйти на след убийцы, предотвратить новую трагедию и, наконец, добиться справедливости."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":95,"tagline":"Chaque seconde compte.","homepage":"","overview":"Malik, inspecteur de police, assiste impuissant à la mort d’une enfant suite à un kidnapping. En charge de l’enquête, il échoue à retrouver le meurtrier. Dix ans plus tard l'affaire s’apprête à être classée définitivement. Mais quand de nouveaux faits se révèlent, il entame une course contre la montre dans l’espoir de résoudre l'enquête avant l’expiration du délai de prescription dans six jours."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"六天","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"六天","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"A Perseguição","runtime":0,"tagline":"","homepage":"","overview":"Anos depois de não conseguir resolver o assassinato de uma jovem, um detetetive se vê obrigado a reabrir o caso quando um crime semelhante acontece. Faltando apenas 6 dias para o caso ser definitivamente arquivado, ele sente o dever de solucioná-lo e evitar que outra criança sofra o mesmo destino."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Six Days - 6 Tage Zeit","runtime":0,"tagline":"","homepage":"","overview":"Vor elf Jahren konnte Inspektor Malik einen Entführungsfall nicht aufklären, und ein kleines Mädchen starb. Nur wenige Tage vor der Aufklärung des Verbrechens beschließt er, den Fall wieder aufzurollen. Malik ist es der Mutter und sich selbst schuldig. Als er in der Vergangenheit gräbt, wird erneut ein Kind entführt. Das Muster ist dasselbe wie vor zehn Jahren, es ist kein Zufall. Malik weiß, dass ihm nur noch wenige Tage bleiben, um die Dinge in Ordnung zu bringen und Gerechtigkeit walten zu lassen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Seis días: Caza al asesino","runtime":0,"tagline":"","homepage":"","overview":"Hace 11 años, el inspector Malik no pudo resolver un caso de secuestro y una niña murió. Ahora, a pocos días de que se cierre el caso, decide reabrirlo. Malik se lo debe a la madre y a sí mismo. Mientras indaga en el pasado, una niña vuelve a ser secuestrada. El patrón es el mismo que hace una década, no es casualidad. Malik sabe que dispone de pocos días para arreglar las cosas y hacer justicia. El tiempo corre..."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Seis días: Caza al asesino","runtime":95,"tagline":"","homepage":"","overview":"Hace 11 años, el inspector Malik no pudo resolver un caso de secuestro y una niña murió. Ahora, a pocos días de que se cierre el caso, decide reabrirlo. Malik se lo debe a la madre y a sí mismo. Mientras indaga en el pasado, una niña vuelve a ser secuestrada. El patrón es el mismo que hace una década, no es casualidad. Malik sabe que dispone de pocos días para arreglar las cosas y hacer justicia. El tiempo corre..."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"}],"reviews_tmdb":[],"recommendations":[{"id":1511556,"adult":false,"title":"Under Fire","video":false,"overview":"Story unfolds in the scorching heat of the Mexico border, where rival drug dealers Griff and Abbott arrive at a remote drop point for a routine drug deal. But when the exchange goes down, both reveal undercover badges — Griff is FBI, Abbott is DEA — and neither knew they were working the same case.","genre_ids":[28,35,53,18],"media_type":"movie","popularity":2.3816,"vote_count":40,"poster_path":"/dIQcDDuDPewwELfhmYMnt25AyZ6.jpg","release_date":"2025-08-07","vote_average":6.738,"backdrop_path":"/sxnGmIx9PpHjL5497jZQGtQeCa9.jpg","original_title":"Under Fire","original_language":"en"},{"id":959596,"adult":false,"title":"Maldoror","video":false,"overview":"When two girls go missing, Paul Chartier, an impulsive young police recruit, is assigned to “Maldoror”. This secret unit has been set up to monitor a dangerous sex offender. When the operation fails, fed up with the limits of the legal system, Chartier embarks on a solitary hunt to bring down the culprits.","genre_ids":[53,80,18],"media_type":"movie","popularity":0.7965,"vote_count":92,"poster_path":"/kdOeeJOZySlQ5pDFijMIUuwLIPG.jpg","release_date":"2024-09-08","vote_average":6.391,"backdrop_path":"/5N3w3cC5d8fDMLuuDMn8io4StUE.jpg","original_title":"Le Dossier Maldoror","original_language":"fr"},{"id":1156108,"adult":false,"title":"La Fille d'un grand amour","video":false,"overview":"Ana and Yves loved each other passionately, then parted ways. Years later, their daughter Cécile made a documentary about their meeting. They meet again. Still scarred by their past love, they set out to find a way back to each other.","genre_ids":[18,35,10749],"media_type":"movie","popularity":0.242,"vote_count":19,"poster_path":"/qp8udYuCvUZh7vPbGTuv0RWrtc4.jpg","release_date":"2025-01-08","vote_average":5.184,"backdrop_path":"/mbvxLGEFRGzwyGIM6WTJ4Nbdgsj.jpg","original_title":"La Fille d'un grand amour","original_language":"fr"},{"id":1071064,"adult":false,"title":"Love Is Overrated","video":false,"overview":"Diagnosed «crap with girls» by his friends, Anis’ love life has barely a pulse. Three years after the loss of Isma, his best friend and mentor, Anis takes his courage in both hands and decides finally to get out and meet people again. And the person he meets is Madeleine. Thinking she’s way out of his league, Anis gets tangled in a web of silly lies trying to impress her. But something huge is about to start. An unexpected thing. A thing called love.","genre_ids":[35,10749],"media_type":"movie","popularity":1.2836,"vote_count":151,"poster_path":"/8gbHgEfP8h64HrW3mXpurirbZLC.jpg","release_date":"2025-04-23","vote_average":6.742,"backdrop_path":"/9ByGi07suLR0E1WqxnKjvoCG8T.jpg","original_title":"L'Amour c'est surcoté","original_language":"fr"},{"id":1156104,"adult":false,"title":"Call of Water","video":false,"overview":"Sarah, in her forties, is on the verge of exhaustion. Her children, ages 9 and 5, take up all her time and her husband is constantly on business trips. After disappearing on the beach for a few minutes, Simon becomes strange. He spends hours in his bathroom and seeks contact with water at the slightest opportunity. Sarah's life will change when her son confesses the truth...","genre_ids":[18],"media_type":"movie","popularity":0.3608,"vote_count":12,"poster_path":"/3OlqCaJ8KECISjCzYXeg7pR6uEb.jpg","release_date":"2024-10-14","vote_average":5.792,"backdrop_path":"/anm4weP3FrUWMllycTI6jV1aepC.jpg","original_title":"Par amour","original_language":"fr"},{"id":1064758,"adult":false,"title":"Planet B","video":false,"overview":"France, 2039. One night, a group of activists who are being pursued by the State vanish without a trace. Julia Bombarth is one of them. When she awakens, she finds herself trapped in an entirely unfamiliar world: PLANET B.","genre_ids":[878,53],"media_type":"movie","popularity":0.7246,"vote_count":49,"poster_path":"/zCi5WZbYeFkM1KsOcbSv2qd37Bf.jpg","release_date":"2024-12-25","vote_average":5,"backdrop_path":"/ncdoorCh3P5yyaqOq0iv6nL1EYO.jpg","original_title":"Planète B","original_language":"fr"},{"id":506775,"adult":false,"title":"Nekrotronic","video":false,"overview":"A man discovers that he is part of a secret sect of magical beings who hunt down and destroy demons in the internet.","genre_ids":[35,27,878],"media_type":"movie","popularity":3.2843,"vote_count":170,"poster_path":"/zT0G9rNziv26mx5Q2QS1ecwzaQ6.jpg","release_date":"2018-10-01","vote_average":5.856,"backdrop_path":"/1PiZCvIXL0AgeRcUuO9CegSvrG6.jpg","original_title":"Nekrotronic","original_language":"en"},{"id":1118848,"adult":false,"title":"The Quiet Son","video":false,"overview":"Pierre, a devoted father in his 50s, raises his two sons alone. When Louis, the youngest, leaves home to attend the Sorbonne in Paris, Fus, slightly older and not as successful academically, becomes more and more secretive. Driven by a fascination for violence, he gets entangled in far-right extremist groups, at the very opposite of his father’s values. Between them, there is love and hate, until tragedy happens.","genre_ids":[18],"media_type":"movie","popularity":0.9578,"vote_count":133,"poster_path":"/CLpEUf9FutbFkLX3PGaKKEqXjf.jpg","release_date":"2025-01-22","vote_average":6.447,"backdrop_path":"/OhOA3pvYlllL0Bq3Fbb4voHtLe.jpg","original_title":"Jouer avec le feu","original_language":"fr"},{"id":1277884,"adult":false,"title":"Leave One Day","video":false,"overview":"Cécile is about to open her own gourmet restaurant, finally making her dream come true, when suddenly her father has a heart attack and she is called back to the village where she was born. Far from the hubbub of Paris life, she runs into her teenage crush. The memories come flooding back, destabilizing her certainties.","genre_ids":[18,35,10402],"media_type":"movie","popularity":1.3552,"vote_count":182,"poster_path":"/txzzgq2Rviv2Ljxnbh9Fy6gfDId.jpg","release_date":"2025-05-13","vote_average":6.4,"backdrop_path":"/cEKnZxnCBiFWNfVl8eTi73cZFCM.jpg","original_title":"Partir un jour","original_language":"fr"},{"id":507241,"adult":false,"title":"The Killer's Game","video":false,"overview":"When top hitman Joe Flood is diagnosed with a terminal illness, he decides to take matters into his own hands – by taking a hit out on himself. But when the very hitmen he hired also target his ex-girlfriend, he must fend off an army of assassin colleagues and win back the love of his life before it's too late.","genre_ids":[28,35,53],"media_type":"movie","popularity":5.5536,"vote_count":513,"poster_path":"/4bKlTeOUr5AKrLky8mwWvlQqyVd.jpg","release_date":"2024-09-12","vote_average":6.401,"backdrop_path":"/zGLQmrmIB56kMZPnzqReIOBay1B.jpg","original_title":"The Killer's Game","original_language":"en"},{"id":3432,"adult":false,"title":"Mr. Brooks","video":false,"overview":"A psychological thriller about a man who is sometimes controlled by his murder-and-mayhem-loving alter ego.","genre_ids":[80,53],"media_type":"movie","popularity":3.9595,"vote_count":1833,"poster_path":"/yYleq0qmb67Ig2ViY3hFmUOrH77.jpg","release_date":"2007-05-31","vote_average":6.926,"backdrop_path":"/6M2IeELPSKZZ4iAPz2w0i7wdm6X.jpg","original_title":"Mr. Brooks","original_language":"en"},{"id":744653,"adult":false,"title":"The Thursday Murder Club","video":false,"overview":"A group of senior sleuths passionate about solving cold cases get plunged into a real-life murder mystery in this comic crime caper.","genre_ids":[35,9648,80],"media_type":"movie","popularity":4.3753,"vote_count":908,"poster_path":"/jbnazCHr8S2l2glyvjPTpa4NbEw.jpg","release_date":"2025-08-22","vote_average":6.599,"backdrop_path":"/4KN06gns94rQFoYQWDGunK7Cob4.jpg","original_title":"The Thursday Murder Club","original_language":"en"},{"id":1376434,"adult":false,"title":"Predator: Killer of Killers","video":false,"overview":"While three of the fiercest warriors in human history—a Viking raider, a ninja in feudal Japan, and a WWII pilot—are killers in their own right, they are merely prey for their new opponent: the ultimate killer of killers.","genre_ids":[16,28,878,53],"media_type":"movie","popularity":10.0355,"vote_count":1098,"poster_path":"/2XDQa6EmFHSA37j1t0w88vpWqj9.jpg","release_date":"2025-06-05","vote_average":7.821,"backdrop_path":"/3AGZKVr2DPT9H53gYtkSEC1tK1E.jpg","original_title":"Predator: Killer of Killers","original_language":"en"},{"id":1138194,"adult":false,"title":"Heretic","video":false,"overview":"Two young missionaries are forced to prove their faith when they knock on the wrong door and are greeted by a diabolical Mr. Reed, becoming ensnared in his deadly game of cat-and-mouse.","genre_ids":[53,27],"media_type":"movie","popularity":12.0555,"vote_count":2483,"poster_path":"/fr96XzlzsONrQrGfdLMiwtQjott.jpg","release_date":"2024-10-31","vote_average":6.976,"backdrop_path":"/ag66gJCiZ06q1GSJuQlhGLi3Udx.jpg","original_title":"Heretic","original_language":"en"},{"id":915935,"adult":false,"title":"Anatomy of a Fall","video":false,"overview":"A woman is suspected of her husband's murder, and their blind son faces a moral dilemma as the sole witness.","genre_ids":[53,9648,80],"media_type":"movie","popularity":7.7127,"vote_count":3150,"poster_path":"/kQs6keheMwCxJxrzV83VUwFtHkB.jpg","release_date":"2023-08-23","vote_average":7.531,"backdrop_path":"/kszooR7v1TLFM4pzx6IkKq2jDAN.jpg","original_title":"Anatomie d'une chute","original_language":"fr"},{"id":120467,"adult":false,"title":"The Grand Budapest Hotel","video":false,"overview":"The Grand Budapest Hotel tells of a legendary concierge at a famous European hotel between the wars and his friendship with a young employee who becomes his trusted protégé. The story involves the theft and recovery of a priceless Renaissance painting, the battle for an enormous family fortune and the slow and then sudden upheavals that transformed Europe during the first half of the 20th century.","genre_ids":[35,18],"media_type":"movie","popularity":11.3126,"vote_count":15792,"poster_path":"/eWdyYQreja6JGCzqHWXpWHDrrPo.jpg","release_date":"2014-02-26","vote_average":8.031,"backdrop_path":"/9udCLTxTFl28RxnK8Q05E154ZGa.jpg","original_title":"The Grand Budapest Hotel","original_language":"en"},{"id":945961,"adult":false,"title":"Alien: Romulus","video":false,"overview":"While scavenging the deep ends of a derelict space station, a group of young space colonizers come face to face with the most terrifying life form in the universe.","genre_ids":[27,878],"media_type":"movie","popularity":14.05,"vote_count":4307,"poster_path":"/2uSWRTtCG336nuBiG8jOTEUKSy8.jpg","release_date":"2024-08-13","vote_average":7.169,"backdrop_path":"/iYqSQaWDttQIQzsxg9xHyg0bttG.jpg","original_title":"Alien: Romulus","original_language":"en"},{"id":1084199,"adult":false,"title":"Companion","video":false,"overview":"During a weekend getaway at a secluded lakeside estate, a group of friends finds themselves entangled in a web of secrets, deception, and advanced technology. As tensions rise and loyalties are tested, they uncover unsettling truths about themselves and the world around them.","genre_ids":[27,878,53],"media_type":"movie","popularity":12.805,"vote_count":2098,"poster_path":"/oCoTgC3UyWGfyQ9thE10ulWR7bn.jpg","release_date":"2025-01-22","vote_average":7.012,"backdrop_path":"/qA6MHDGDY0LyutjLUgFJRbPXLpW.jpg","original_title":"Companion","original_language":"en"},{"id":1233413,"adult":false,"title":"Sinners","video":false,"overview":"Trying to leave their troubled lives behind, twin brothers return to their hometown to start again, only to discover that an even greater evil is waiting to welcome them back.","genre_ids":[27,28,53],"media_type":"movie","popularity":37.799,"vote_count":3775,"poster_path":"/qTvFWCGeGXgBRaINLY1zqgTPSpn.jpg","release_date":"2025-04-16","vote_average":7.489,"backdrop_path":"/nAxGnGHOsfzufThz20zgmRwKur3.jpg","original_title":"Sinners","original_language":"en"},{"id":1140817,"adult":false,"title":"As","video":false,"overview":"Three years after the death of her beloved child, Elouise, Mara still feels her presence when she sits on the butterfly bedding in front of the jar with her ashes in it. Mara arranges a twelfth birthday party for Elouise, further alienating her from her husband, Richter, and remaining daughter, Hannah. Although Mara eventually vacates Elouise's room at the insistence of her husband, she does find a way to stay close to Elouise. Before long, however, Hannah discovers her mother's secret.","genre_ids":[],"media_type":"movie","popularity":0.2105,"vote_count":185,"poster_path":null,"release_date":"2023-01-01","vote_average":7.054,"backdrop_path":null,"original_title":"As","original_language":"en"}],"similar_content":[],"external_ids":{"imdb_id":"tt29610108","twitter_id":null,"facebook_id":null,"wikidata_id":"Q131560840","instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148279,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"BE","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-01-08T00:00:00.000Z","certification":""}]},{"iso_3166_1":"FR","release_dates":[{"note":"Avant-première au