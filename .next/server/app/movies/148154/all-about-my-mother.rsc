9:{"metadata":[["$","title","0",{"children":"All About My Mother | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Following the tragic death of her teenage son, Manuela travels from Madrid to Barcelona in an attempt to contact the long-estranged father the boy never knew. She reunites with an old friend, an outspoken transgender sex worker, and befriends a troubled actress and a pregnant, HIV-positive nun."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148154/all-about-my-mother"}],["$","meta","5",{"property":"og:title","content":"All About My Mother"}],["$","meta","6",{"property":"og:description","content":"Following the tragic death of her teenage son, Manuela travels from Madrid to Barcelona in an attempt to contact the long-estranged father the boy never knew. She reunites with an old friend, an outspoken transgender sex worker, and befriends a troubled actress and a pregnant, HIV-positive nun."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148154/all-about-my-mother"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/hjQhzhkGYXPNM96k0mOgob6HMmn.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"All About My Mother"}],["$","meta","12",{"name":"twitter:description","content":"Following the tragic death of her teenage son, Manuela travels from Madrid to Barcelona in an attempt to contact the long-estranged father the boy never knew. She reunites with an old friend, an outspoken transgender sex worker, and befriends a troubled actress and a pregnant, HIV-positive nun."}],["$","meta","13",{"name":"twitter:image","c