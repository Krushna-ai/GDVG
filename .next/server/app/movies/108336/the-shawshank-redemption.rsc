5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Shawshank Redemption\",\"description\":\"Imprisoned in the 1940s for the double murder of his wife and her lover, upstanding banker Andy Dufresne begins a new life at the Shawshank prison, where he puts his accounting skills to work for an amoral warden. During his long stretch in prison, Dufresne comes to be admired by the other inmates -- including an older prisoner named Red -- for his integrity and unquenchable sense of hope.\",\"image\":\"https://image.tmdb.org/t/p/w500/9cqNxx0GxF0bflZmeSMuL5tnGzr.jpg\",\"datePublished\":\"1994-09-23\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"US\",\"inLanguage\":\"en\",\"genre\":[\"drama film\",\"prison film\",\"buddy film\",\"crime film\",\"film based on literature\",\"Drama\",\"Crime\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.717,\"bestRating\":10,\"ratingCount\":29997}}"}}],["$","$L10",null,{"initialDrama":{"id":"9fbaebae-680d-4cf0-88f2-d7a231e35eff","tmdb_id":278,"imdb_id":"tt0111161","content_type":"movie","title":"The Shawshank Redemption","original_title":"The Shawshank Redemption","overview":"Imprisoned in the 1940s for the double murder of his wife and her lover, upstanding banker Andy Dufresne begins a new life at the Shawshank prison, where he puts his accounting skills to work for an amoral warden. During his long stretch in prison, Dufresne comes to be admired by the other inmates -- including an older prisoner named Red -- for his integrity and unquenchable sense of hope.","poster_path":"/9cqNxx0GxF0bflZmeSMuL5tnGzr.jpg","backdrop_path":"/zfbjgQE1uSd9wiPTX4VzsLi0rGG.jpg","release_date":"1994-09-23","first_air_date":null,"status":"published","original_language":"en","origin_country":["US"],"genres":[{"name":"drama film"},{"name":"prison film"},{"name":"buddy film"},{"name":"crime film"},{"name":"film based on literature"}