9:{"metadata":[["$","title","0",{"children":"GATAO: Big Brothers | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Michael and his right-hand man Scorpion, who find themselves embroiled in their father Ko's turf war against rival gangs in Taipei, setting off a conflict between old and new generations of gangsters. The film is the latest installment in the Gatao franchise, following the narrative of a young successor trying to expand his power while navigating the volatile underworld."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/106687/gatao-big-brothers"}],["$","meta","5",{"property":"og:title","content":"GATAO: Big Brothers"}],["$","meta","6",{"property":"og:description","content":"Michael and his right-hand man Scorpion, who find themselves embroiled in their father Ko's turf war against rival gangs in Taipei, setting off a conflict between old and new generations of gangsters. The film is the latest installment in the Gatao franchise, following the narrative of a young successor trying to expand his power while navigating the volatile underworld."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/106687/gatao-big-brothers"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/tc5z5OADIYlOZLn0xNNM32c0Cq5.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"GATAO: Big Brothers"}],["$","meta","12",{"name":"twitter:description","content":"Michael and his right-hand man Scorpion, who find themselves embroiled in their father Ko's turf war against rival gangs in Taipei, setting off a conflict between old and new generations o