atch?locale=SA","flatrate":[{"logo_path":"/kC6JTo59Gj6I4vJPyBAYGh0sKAE.jpg","provider_id":629,"provider_name":"OSN+","display_priority":20}]},"SE":{"buy":[{"logo_path":"/auWzottqpExOHUlJwDZ4DvdHGoL.jpg","provider_id":423,"provider_name":"Blockbuster","display_priority":14},{"logo_path":"/sNmIwrniZZORvNJOmEuWGhwBJNf.jpg","provider_id":426,"provider_name":"SF Anytime","display_priority":15}],"link":"https://www.themoviedb.org/movie/10529-outlander/watch?locale=SE","rent":[{"logo_path":"/auWzottqpExOHUlJwDZ4DvdHGoL.jpg","provider_id":423,"provider_name":"Blockbuster","display_priority":14},{"logo_path":"/sNmIwrniZZORvNJOmEuWGhwBJNf.jpg","provider_id":426,"provider_name":"SF Anytime","display_priority":15}]},"SM":{"link":"https://www.themoviedb.org/movie/10529-outlander/watch?locale=SM","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1}]},"US":{"ads":[{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":332,"provider_name":"Fandango at Home Free","display_priority":38},{"logo_path":"/4tJBhJcuF1ZstI5Yqu82G0yroLa.jpg","provider_id":235,"provider_name":"YouTube Free","display_priority":96},{"logo_path":"/zLYr7OPvpskMA4S79E3vlCi71iC.jpg","provider_id":73,"provider_name":"Tubi TV","display_priority":361}],"buy":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"free":[{"logo_path":"/j7D006Uy3UWwZ6G0xH6BMgIWTzH.jpg","provider_id":212,"provider_name":"Hoopla","display_priority":34},{"logo_path":"/vLZKlXUNDcZR7ilvfY9Wr9k80FZ.jpg","provider_id":538,"provider_name":"Plex","display_priority":126},{"logo_path":"/pSUa7lMYLoQAU00ikXoHxmOfTZ9.jpg","provider_id":2409,"provider_name":"Fawesome","display_priority":145}],"link":"https://www.themoviedb.org/movie/10529-outlander/watch?locale=US","rent":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"flatrate":[{"logo_path":"/bEI5UgVjthdjiBXGiKRy7uSCRvF.jpg","provider_id":2445,"provider_name":"MovieSphere+ Amazon Channel","display_priority":297}]},"VA":{"link":"https://www.themoviedb.org/movie/10529-outlander/watch?locale=VA","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":0}]}}},"wikidata_id":"Q651950","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-20T22:16:39.12416+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":[{"data":{"title":"","runtime":115,"tagline":"It destroyed his world. He won't let it destroy ours.","homepage":"","overview":"During the reign of the Vikings, a man from another world crash-lands on Earth, bringing with him an alien predator. The man must fuse his advanced technology with the weaponry of the vikings to fight the monster."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":115,"tagline":"Es zerstörte seine Welt. Er wird nicht zulassen das es unsere zerstört.","homepage":"","overview":"709 nach Christus: Der Raumfahrer Kainan stürzt mit seinem Raumschiff inmitten von Wikinger-Clangebiet ab, seine Crew stirbt bei dem Unglück, doch Kainan ist trotzdem nicht allein gekommen. Denn den Absturz hatte ein Moorwen, eine reißende Bestie außerirdischen Ursprungs, zu verantworten. Bei seiner Jagd auf den Moorwen wird Kainan von Wikingern gefangen genommen, die dem angeblichen Drachenjäger erst nicht glauben. Bis der Moorwen beginnt über ihre Siedlungen herzufallen..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Outlander : Le Dernier Viking","runtime":115,"tagline":"Cela a détruit son monde. Il ne le laissera pas détruire le nôtre.","homepage":"","overview":"Sous le règne des Vikings, un homme venu de l'espace - Kainan - s'écrase sur la Terre, apportant avec lui une créature terrifiante, un prédateur extraterrestre connu sous le nom de Moorwen. Alors que la bête plonge les environs dans le chaos, les vikings, d'abord suspicieux envers ce mystérieux étranger, s'associent bientôt à Kainan pour en venir à bout. Lui seul pourra les mener à la victoire..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"A kívülálló","runtime":115,"tagline":"Elpusztította a világát. Nem hagyja, hogy elpusztítsa a miénket.","homepage":"","overview":"Messze a távolban, fénycsík lobban az éjszakában. Egy űrhajó ütközik a norvég fjordoknak, és a roncsok közül egy másik világ szülötte emelkedik ki, Kainan, a harcos. Ám nincs egyedül, az űrhajó potyautasa, a vérszomjas Moorwen már lesben áll, hogy megbosszulja Kainan hadseregének tetteit. Elvágva otthonától az idegen bolygón, mely évszázadokkal le van maradva saját civilizációjától, Kainan elindul, hogy elpusztítsa félelmetes ellenségét."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Kainan, mies toisesta maailmasta, syöksyy aluksellaan planeetallemme, keskelle armotonta viikinkiaikaa. Hän ei kuitenkaan saapunut yksin… Armoton, verta janoava hirviö Moorwen jahaa Kainia väsymättä, tuhoten ja tappaen kaiken tielleen osuvan. Kainan onnistuu liittoutumaan viikinkien kanssa ja korkein teknologia kohtaa rauta-ajan primitiivisen ja raa’an voiman taistelussa Moorwenia vastaan."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Outlander - L'ultimo vichingo","runtime":115,"tagline":"Ha distrutto il suo mondo. Non lascerà che distrugga il nostro.","homepage":"http://www.outlander-themovie.com/","overview":"Kainan è un alieno che giunge nella Norvegia del 709 D.C. in seguito all'avaria della sua astronave. Il suo compagno di viaggio muore nell'impatto, così l'extraterrestre si ritrova nel mondo dei Vichinghi, che lo ritengono un \"outlander\", e viene catturato dalla tribù del vecchio Rothgar, divenuto re da poco e insidiato dal nipote Wiglif. Freya, la figlia ribelle di Rothgar, è subito attratta da Kainan, il quale però ha una famiglia nel pianeta d'origine ed è perseguitato da Morwen, un mostro assetato di sangue."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Yabancı","runtime":0,"tagline":"Onun dünyasını yok eti: Ama o, bizim dünyamızı da yok etmesine izin vermeyecektir...","homepage":"","overview":"Vikingler'in hükümdarlık sürdüğü bir dönemde, başka dünyadan gelmiş bir savaşçı olan Kainan'ın gemisi büyük bir şiddetle İskandinav kıyılarına vurur ve fark eder ki gemiden tek sağ kalan kendisi değildir. İkinci bir yolcu, Moorwen olarak bilinen vahşi yaratıkta enkaz altından belirir. Amacı kendine uygulanan şiddetin öcünü almak olan kana susamış Moorwen yoluna çıkan her şeyi öldürmektedir. Kainan, Vikingler ile ortak çalışıp kendi teknolojisini Demir Çağı'nın silahlarıyla birleştirip her şeyi yok etmeden önce yaratığı etkisiz hale getirmelidir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Outlander - A Vingança","runtime":115,"tagline":"Isso destruiu o mundo dele. Ele não vai deixar que destrua o nosso.","homepage":"","overview":"Os Vikings, grandes exploradores e desbravadores dos mares, seguem numa jornada quando uma gigante e poderosa criatura surge e pode destruir toda a população. Para salvá-los, o povo contará com a ajuda de um homem vindo de outro universo que poderá deter a fúria deste predador. Agora será necessário unir a coragem e os conhecimentos deste soldado com a força dos Vikings para vencer esta batalha."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Викинги","runtime":115,"tagline":"«Оно разрушило его мир. Он не позволит ему разрушить наш»","homepage":"","overview":"Инопланетный корабль потерпел крушение на Земле во времена викингов. И только один член экипажа чудом выжил.  Однако он оказался не единственным выжившим в аварии. Опасный хищник, содержавшийся в заточении на корабле, вырвался на свободу.  Главному герою с помощью викингов предстоит отыскать и уничтожить его..."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"Kainan, en man från en annan värld kraschlandar på jorden med sin märkliga farkost, mitt under vikingatiden. Men han kommer inte ensam. En fruktansvärd varelse vid namn Moorwen kommer honom tätt i spåren och förintar allt i sin väg i jakt på rymdfararen. Kainan lyckas till slut liera sig med vikingarna och avancerad teknologi möter nu järnålderns primitiva teknik i kampen mot monstret."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"Kainan (James Caviezel) jest żołnierzem pochodzącym z innego świata. Jego statek kosmiczny rozbija się pośród norweskich fiordów w czasach panowania Wikingów. Niestety Kainan nie był jedynym pasażerem, któremu udało się wyjść z życiem z płonącego wraku. Krainę zaczyna terroryzować okrutny, żądny krwi drapieżnik. Pokonać go może jedynie Kainan, którego znajomość nowoczesnej techniki, posłuży wprawionym w walkach z bestią Wikingom."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"Ten tijde van de hoogtijdagen van de Vikingen, landt de buitenaardse man Kainan op de aarde. Kainan is echter niet alleen op de aarde gekomen. Het buitenaardse roofdier Moorwen heeft hem vergezeld. Deze twee gezworen vijanden zetten hun strijd dan ook voort op de aarde. Om Moorwen te verslaan, zoekt Kainan hulp bij de Vikingen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Outlander","runtime":115,"tagline":"Destruyó su mundo. No permitirá que destruya el nuestro.","homepage":"","overview":"Vikingos, año 509. Una nave espacial se estrella en la antigua Noruega. De su interior salen un guerrero humanoide llamado Kainan y una sanguinaria criatura conocida como El Moorwen, una bestia salvaje dispuesta a vengar la extinción de su raza a manos del ejército del guerrero. Mientras El Moorwen devasta los territorios vikingos, asesinando a quien se le pone por delante, Kainan, combinando su avanzada tecnología con armas antiguas, se dedica a formar a un grupo de primitivos pero feroces guerreros. El objetivo es claro: acabar con la brutal criatura."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"魔兽战场","runtime":0,"tagline":"","homepage":"","overview":"故事发生在古代的挪威，当时正处于维京人统治时期。一个外星人驾驶的飞船紧急降落在地球上，因为飞船的毁坏，随船的一只嗜血怪物被释放出来。为了消灭怪物，外星人必须和当地的维京人一起联手，阻止它的血腥杀戮……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"Det ødelagde hans verden. Han vil ikke lade det ødelægge vores.","homepage":"","overview":"Under regeringstid af vikingerne, en mand fra en anden verden nødlander på Jorden, hvilket bringer med sig en fremmed rovdyr. Manden skal smelte sin avancerede teknologi med våben af vikingerne til at bekæmpe uhyret."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Αουτλάντερ","runtime":115,"tagline":"Κατάστρεψε τον κόσμο του. Δεν θα το αφήσει να καταστρέψει τον δικό μας.","homepage":"","overview":"Μετά από μια μάχη στο διάστημα, ένα σκάφος συντρίβεται σε μια σκανδιναβική ακτή. Ένας επιβάτης, ο Κέιναν, επέζησε της σύγκρουσης, αλλά σύντομα θα διαπιστώσει ότι δεν ήταν ο μόνος. Ένας ακόμη επιβάτης έχει επιζήσει, και συγκεκριμένα ένα ζωώδες πλάσμα, που από τη φύση του έχει την τάση να καταστρέφει ότι νιώθει ότι το απειλεί. Κι ενώ το πλάσμα σκοτώνει ότι βρει μπροστά του, ο Κέιναν θα συμμαχήσει με τους Βίκινγκς για να εξοντώσουν το αιμοβόρο αυτό πλάσμα."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Vikingové II","runtime":110,"tagline":"Zničilo to jeho svět. Nedovolí, aby zničil náš.","homepage":"","overview":"Když se mimozemská kosmická loď zřítí na Zemi, lidé zde právě prožívají období Vikingů. A skandinávští bojovníci se pustí do bitvy s tím nejneobvyklejším nepřítelem. Užijte si sci-fi thriller z dílny režiséra Howarda McCaina.\r Mezi hvězdami zuří staletí staré bitvy. Jedna z vesmírných lodí se zřítí na Zemi, konkrétně do fjordů Norska. Přežije jen Kainan a k jeho velkému zděšení také Moorwen – divoké stvoření podobní zvířeti, které záměrně škodí těm, kteří mu v jeho očích ublížili. Moorwen zabíjí všechno, co mu vstoupí do cesty. Kainan se musí chtě nechtě spojit s Vikingy a zničit agresivní bestii dříve, než ona zničí je."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"נחיתה רכה","runtime":0,"tagline":"","homepage":"","overview":"בזמן תקופת ימי הויקינגים, נוחת אדם בשם קיינן, מעולם רחוק ומתקדם, על כדור הארץ ומביא עימו חייזר טורף. קיינן מכיר לויקינגים את הטכנולוגיה המתקדמת שלו ומנהיג קבוצת לוחמים במטרה להרוג את החייזר אשר מאיים עליהם."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Outlander: Guerreiro vs Predador","runtime":115,"tagline":"Destruíram o seu mundo. Ele não deixará que destruam o nosso.","homepage":"","overview":"Os Vikings, grandes exploradores e desbravadores dos mares, seguem numa jornada quando uma gigante e poderosa criatura surge e pode destruir toda a população. Para salvá-los, o povo contará com a ajuda de um homem vindo de outro universo que poderá deter a fúria deste predador. Agora será necessário unir a coragem e os conhecimentos deste soldado com a força dos Vikings para vencer esta batalha."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"아웃랜더","runtime":0,"tagline":"","homepage":"","overview":"먼 미래에서 우주선 사고로 지구에 도착한 케이난이 첨단 장비를 이용하여 도착한 지구의 정보를 습득한다. 주변을 살피던 도중 바이킹 부족의 울프릭에게 적대세력인 거나 부족으로 오해를 받고 끌려간 케이난은 틈을 살피다 탈출한다. 하지만 때마침 부족을 습격한 괴물 발견하게 되고, 그 괴물이 자신의 행성을 파괴한 무어웬이 우주선을 같이 타고 지구로 온 것을 알게 된다. 다시 부족에게 붙잡혀 끌려온 케이난은 부족장 로스가에게 괴물 무어웬에 대해 이야기하고, 로스가는 그를 믿고 무어웬을 없애기 위해 병사들을 보낸다. 무어웬의 동굴로 짐작되는 곳을 습격한 그들은 그곳에서 거대한 곰을 죽이고, 케이난이 이야기했던 괴물에 대해서 점차 잊게 되는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Чуждоземец","runtime":110,"tagline":"То унищожи света му. Той няма да му позволи да унищожи и нашия.","homepage":"","overview":"По време на царуването на викингите, Кайнан - човек от далечен свят идва на Земята. Той води със себе си извънземен хищник, на име Морвен. Въпреки че и мъжът, и чудовището търсят отмъщение, заради насилието, упражнено върху тях, Кайнан се съюзява с викингите срещу Морвен благодарение от оръжия, познати от Желязната ера."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Atnācējs","runtime":0,"tagline":"","homepage":"","overview":"Skandināvija, vikingu valdīšanas laiks. Uz Zemes avarē kosmosa kuģis, izdzīvo tikai viens vīrs - Keinans. Tomēr izrādās, ka uz kuģa bijis vēl kaut kas - brutāls, spēcīgs un slepkavniecisks radījums, ar kuru Keinans un viņa rase reiz cīnījās uz savas planētas. Nežēlīgais radījums slepkavo vietējos iedzīvotājus un draud iznīcināt vikingu ciltis. Keinanam nākas apvienoties spēkiem ar vietējām ciltīm un, lietojot tikai viņu primitīvos ieročus, stāties pretī plēsoņai."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Una nau espacial s'estrella en un planeta. L'únic supervivent és Kainan (Jim Caviezel), un guerrer que ha portat amb ell a Moorwen, una monstruosa criatura decidida a venjar la mort de la seva raça. Quan Kainan surt de la seva nau disposat a destruir a la bèstia, es dóna compte que ha aterrat a la Terra en plena època dels víkings."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"アウトランダー","runtime":0,"tagline":"","homepage":"","overview":"最強の巨大殺戮エイリアンの暴走を食い止めるため、1人の異星人がバイキングたちと共に立ち上がる。超迫力のSFアドベンチャー・アクション！"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Svetimšalis","runtime":0,"tagline":"","homepage":"","overview":"Viešpatauja nuožmūs vikingų laikai. Kiekvienas kovoja už save ir išlieka tik stipriausieji – aplinkinės gyvenvietės\r nebūtinai draugiškos ir visi svetimšaliai, pasirodantys horizonte, nėra laukiami svečiai.  Netoli senovinio vikingų Heroto kaimo sudūžta kosminis laivas, tačiau jo pilotas išgyvena. Jis vardu Kainanas (akt.\r James Caviezel). Jis – ateivis iš tolimųjų žvaigždžių. Išsilaisvinęs iš po laivo skeveldrų liekanų, Kainanas suvokia, jog jis\r ne vienintelis, likęs gyvas po katastrofos.  Kartu su Kainanu į Žemę atskriejo dar vienas – nuožmus ir grobuoniškas - ateivis Murvenas. Murvenas keliauja vikingų\r žemėmis šluodamas viską, kas pasitaiko pakeliui."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Outlander, le dernier Viking","runtime":115,"tagline":"Cela a détruit son monde. Il ne le laissera pas détruire le nôtre.","homepage":"","overview":"Sous le règne des Vikings, un homme venu de l'espace - Kainan - s'écrase sur la Terre, apportant avec lui une créature terrifiante, un prédateur extraterrestre connu sous le nom de Moorwen. Alors que la bête plonge les environs dans le chaos, les vikings, d'abord suspicieux envers ce mystérieux étranger, s'associent bientôt à Kainan pour en venir à bout. Lui seul pourra les mener à la victoire..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"魔獸戰場","runtime":0,"tagline":"","homepage":"","overview":"西元709年，外星人凱坦（James Caviezel飾）駕駛的飛船墜毀在挪威境內，同伴重傷死亡，飛船損毀，沉入湖底。凱坦憑藉隨身攜帶的先進機器掌握了地球的知識和當地的語言，在森林內游蕩之際，他遇到了維京人烏弗里克（Jack Huston傑克•休斯頓飾），並隨之回到了村莊。\r 　　凱坦告訴維京人自己正在尋找一頭“惡龍”，而這條惡龍正是他飛船上的一隻怪獸，因飛船墜毀逃遁。維京人起初認為凱坦是個說大話的騙子，但隨著村民一個個離奇消失，他們才發現所謂的“惡龍”真的存在…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Străinul","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Вікінги","runtime":115,"tagline":"Це зруйнувало його світ. Він не дозволить знищити наш.","homepage":"","overview":"Прибулець з далекої галактики терпить крах на Землі за часів вікінгів. Проте він виявився не єдиним вцілілим в аварії. Небезпечний інопланетний хижак, що був ув’язненим на кораблі, вирвався на свободу, і головному герою належить відшукати та знищити його за допомогою одного з кланів вікінгів."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"越空魔龍","runtime":0,"tagline":"遠古國度外星異獸 宇宙恐慌天驚地滅","homepage":"","overview":"故事發生在公元前 700 年的挪威海岸，「外星人」基爾 (佔卡雲素\r 飾) 駕駛的太空船墜毀於維京人部落，匿藏船上的外星魔龍逃入民居，血腥覓食！流落地球的基爾，説服備受尊敬的帝王盧夫卡 (尊赫特\r 飾) 和他的女兒菲娜 (蘇菲亞梅爾\r 飾)，聯合各族精兵捕殺魔龍。可惜，面對神秘兇殘的天外異獸，石器時代的維京人根本無招架之力。失去支援又備受排斥的基爾，必須解決自己造成的災難，誓與魔龍同歸於盡. . . . ."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Stranac","runtime":0,"tagline":"Kako bi uništio zastrašujuće stvorenje ratnik s drugog planeta udružuje snage s Vikinzima","homepage":"","overview":"U doba kada su Vikinzi dominirali svijetom, čovjek s daleke druge planete, Kainan (Caviezel), ruši se letjelicom na Zemlju donoseći sa sobom opasnog predatora poznatog pod imenom Moorwen. Iako i čovjek i čudovište traže osvetu zbog nasilja koje je nad njima počinjeno, Kainan potajno stvara savezništvo kako bi ubio Moorwena, pokušavajući stopiti njegovu naprednu tehnologiju i drevnih vikinških oružja."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Vikingovia 2","runtime":0,"tagline":"","homepage":"https://voyo.markiza.sk/filmy/4597-vikingovia-2","overview":"Medzi hviezdami zúria stáročia staré bitky. Jedna z vesmírnych lodí sa zrúti na Zemi, konkrétne do fjordov Nórska. Prežije len Kainan a k jeho veľkému zdeseniu aj Moorwen – divoké stvorenie podobné zvieraťu, ktoré zámerne škodí tým, ktorí mu v jeho očiach ublížili. Moorwen zabíja všetko, čo mu vstúpi do cesty. Kainan sa musí chtiac nechtiac spojiť s Vikingami a zničiť agresívnu beštiu skôr, než ona zničí ich."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"ไวกิ้ง ปีศาจมังกรไฟ","runtime":0,"tagline":"","homepage":"","overview":"ไคแนนคือนักรบจากต่างดาวที่ตกลงมามาบนพื้นโลก ที่ดูเหมือนจะล้าหลังกว่าโลกที่เขาจากมากว่าหนึ่งศตวรรษ อีกทั้งยังมีแขกไม่ได้รับเชิญอีกหนึ่งชีวิต มัวร์เวน คือสัตว์ประหลาดที่ได้ทำสงครามกับเผ่าพันธ์ของไคแนนมาอยู่ก่อนแล้ว"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"უცხოელი","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Vikingos, año 709. Una nave espacial se estrella en la antigua Noruega. De su interior salen un guerrero humanoide llamado Kainan y una sanguinaria criatura conocida como El Moorwen, una bestia salvaje dispuesta a vengar la extinción de su raza."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"}],"reviews_tmdb":[{"id":"55c7f6e992514105d8002d95","url":"https://www.themoviedb.org/review/55c7f6e992514105d8002d95","author":"John Chard","content":"Outlandish!\r\n\r\nDuring the reign of the Vikings, a man from another planet crash lands on Earth and unfortunately brings with him a giant alien beast known as the Moorwen. Not only that, but once assimilating himself with this particular Viking faction, he finds that he is now part of a war they are engaged in with another Viking race.\r\n\r\nYep, it's predator in the Viking age, berserker sci-fi played purely for entertainment and cheese sandwiches. Jesus Jimmy Caviezel brings the broody macho posturing, John Hurt the ham, while Ron Perlman picks up an easy pay check for growling a lot. It's still a lot of fun, though, the mixture of TV movie type production values mixing with a cheeky idea that sees the creation of a genuinely cool monster (effects not half bad at all). Good genre action for the undemanding genre faithful. 6/10","created_at":"2015-08-10T00:57:13.365Z","updated_at":"2024-05-16T15:22:09.785Z","author_details":{"name":"","rating":6,"username":"John Chard","avatar_path":"/utEXl2EDiXBK6f41wCLsvprvMg4.jpg"}}],"recommendations":[{"id":771502,"adult":false,"title":"The Bachelorette Party","video":false,"overview":"Five women celebrate one of the girl's bachelorette party but one of them doesn't show up.","genre_ids":[35],"media_type":"movie","popularity":0.5863,"vote_count":94,"poster_path":"/tQDdMsjQ0GEN93G0GEl4RU8kt01.jpg","release_date":"2021-02-24","vote_average":5.479,"backdrop_path":"/lx3qLjA0lW7dZGIk7xBEJaBeKDN.jpg","original_title":"Addio al nubilato","original_language":"it"},{"id":15676,"adult":false,"title":"Nobel Son","video":false,"overview":"Soon after his insufferably arrogant father wins the Nobel Prize for chemistry, Barkley Michaelson is kidnapped by Thaddeus James, a young genius who claims to be Barkley's illegitimate half-brother. Motivated not so much by money as revenge, Thaddeus tries to convince Barkley to help him carry out a multimillion-dollar extortion plot against their patriarch.","genre_ids":[35,80,18],"media_type":"movie","popularity":1.1294,"vote_count":141,"poster_path":"/9fA6M3zAnS09x1hUth4AviCMWFZ.jpg","release_date":"2007-04-28","vote_average":6,"backdrop_path":"/vfubmDHN4kuQsFcjQI8ZxkkfPyI.jpg","original_title":"Nobel Son","original_language":"en"},{"id":22267,"adult":false,"title":"Ride with the Devil","video":false,"overview":"Ride with the Devil follows four people who are fighting for truth and justice amidst the turmoil of the American Civil War. Director Ang Lee takes us to a no man's land on the Missouri/Kansas border where a staunch loyalist, an immigrant's son, a freed slave, and a young widow form an unlikely friendship as they learn how to survive in an uncertain time. In a place without rules and redefine the meaning of bravery and honor.","genre_ids":[18,10752,10749,37],"media_type":"movie","popularity":1.7244,"vote_count":201,"poster_path":"/pH3J5IUzho4ZVaRuTuErzqHHovb.jpg","release_date":"1999-11-24","vote_average":6.3,"backdrop_path":"/yBkZyxzIl46PVgFEDsTCtoGd5F4.jpg","original_title":"Ride with the Devil","original_language":"en"},{"id":15801,"adult":false,"title":"What Doesn't Kill You","video":false,"overview":"Two childhood friends from South Boston turn to crime as a way to get by, ultimately causing a strain in their personal lives and their friendship.","genre_ids":[28,80,18],"media_type":"movie","popularity":1.447,"vote_count":217,"poster_path":"/zqnhe3LFtFVeXv0vBO3vaOiY2ZX.jpg","release_date":"2008-12-12","vote_average":5.977,"backdrop_path":"/xpXkdDAw1ilEtkhiCcUSgIwrttX.jpg","original_title":"What Doesn't Kill You","original_language":"en"},{"id":466361,"adult":false,"title":"Kingdom of Swords","video":false,"overview":"This is the story about man who had a great way. His adventures and losses, his life make you to be surprised. We invite you in the middle ages - a times of darkness, of heroes, of big power and of eternity love.","genre_ids":[28,12],"media_type":"movie","popularity":2.3555,"vote_count":33,"poster_path":"/8XrCCz444RTgRltkhNItEm8w4tu.jpg","release_date":"2018-11-22","vote_average":6.1,"backdrop_path":"/vhkNWBMzhGr2IKwkeNx79VMp7O1.jpg","original_title":"Король Данило","original_language":"uk"},{"id":696070,"adult":false,"title":"Atakan. The Bloody Legend","video":false,"overview":"Atakan is a bloody boulder, a giant granite block, on which pagans sacrificed human sacrifices for centuries. A group of student historians, led by a young teacher, descend into the dungeons of St. Petersburg to find the legendary stone. With each step, the situation gets out of control, only death awaits them. The attack craves new blood. Who will survive?","genre_ids":[27],"media_type":"movie","popularity":0.1261,"vote_count":49,"poster_path":"/i44SqyITIbAeiTW4xAzTmDs5MRR.jpg","release_date":"2020-08-13","vote_average":6.5,"backdrop_path":"/txb2uPRQS1TfiVUVLQZjMqHNmd6.jpg","original_title":"Атакан. Кровавая легенда","original_language":"ru"},{"id":17956,"adult":false,"title":"He Said, She Said","video":false,"overview":"Womanising, right-wing Dan Hanson and quiet, liberal Lorie Bryer work for the Baltimore Sun. Rivals for the job of new writer of a vacant column, the paper ends up instead printing their very different opinions alongside each other, which leads to a similarly combative local TV show. At the same time their initial indifference to each other looks like it may evolve into something more romantic.","genre_ids":[35,18,10749],"media_type":"movie","popularity":0.9162,"vote_count":129,"poster_path":"/5uYv11zTTa83WMWwI3B6EOZtI0Z.jpg","release_date":"1991-02-22","vote_average":5.8,"backdrop_path":"/1y43OB6R4vfBKEuVpGxyFENMAqh.jpg","original_title":"He Said, She Said","original_language":"en"},{"id":24243,"adult":false,"title":"The Best Things in the World","video":false,"overview":"Everyday family life as perfectly normal madness. “As Melhores Coisas do Mundo“ follows a few days in the life of the 15-year-old Mano, who is fighting on two fronts: his parents have just got divorced and he is going through puberty. Mano tries to make his way through life, with its first sexual experiences, his depressed brother and his self-centered parents. It’s a humorous homage to the pitfalls of daily life and the diversity of life.","genre_ids":[35,18,10749],"media_type":"movie","popularity":0.1507,"vote_count":55,"poster_path":"/ykvUvNuqb61Fw6k6oI6Xeo4GSZU.jpg","release_date":"2010-05-22","vote_average":6.3,"backdrop_path":"/wAbZ47Tm1EdrugJCTBdYCjYCqIP.jpg","original_title":"As Melhores Coisas do Mundo","original_language":"pt"},{"id":339533,"adult":false,"title":"San Andreas Quake","video":false,"overview":"When a discredited L.A. Seismologist warns of an impending 12.7 earthquake, no one takes her seriously. Now on her own, she races desperately to get her family to safety before the earthquake breaks Los Angeles apart from the mainland.","genre_ids":[28,878,10770],"media_type":"movie","popularity":0.6577,"vote_count":192,"poster_path":"/4dx0K5ZbdhQDfcyBqqHJFH1OW71.jpg","release_date":"2015-05-19","vote_average":4.234,"backdrop_path":"/gSArEgFJb4qUYpjhqMApcKmD7Ye.jpg","original_title":"San Andreas Quake","original_language":"en"},{"id":25320,"adult":false,"title":"Hysteria: The Def Leppard Story","video":false,"overview":"A dramatization of the early years of the hard rock band, Def Leppard, the group faces both success and personal tragedies such as drummer, Rick Allen losing his arm in a car accident and guitarist Steve Clark's alcohol addiction.","genre_ids":[18,10402],"media_type":"movie","popularity":0.3894,"vote_count":45,"poster_path":"/fMgeiw7AHkogdP1GEFSeJHKYUbP.jpg","release_date":"2001-07-18","vote_average":7,"backdrop_path":null,"original_title":"Hysteria: The Def Leppard Story","original_language":"en"},{"id":6309,"adult":false,"title":"Flood","video":false,"overview":"Timely yet terrifying, The Flood predicts the unthinkable. When a raging storm coincides with high seas it unleashes a colossal tidal surge, which travels mercilessly down England's East Coast and into the Thames Estuary. Overwhelming the Barrier, torrents of water pour into the city. The lives of millions of Londoners are at stake.","genre_ids":[18,28,53],"media_type":"movie","popularity":5.0214,"vote_count":155,"poster_path":"/s0F2iDMtj6uYQPqbjwCPlwug2O4.jpg","release_date":"2007-08-24","vote_average":5.261,"backdrop_path":"/8RHqeBwgHIZnNeswqLJdm0pz05Y.jpg","original_title":"Flood","original_language":"en"},{"id":12490,"adult":false,"title":"Ordinary Decent Criminal","video":false,"overview":"Michael Lynch is a notorious criminal with two wives and a flair for showmanship. He's also a huge embarrassment to the local police, who are determined to bring him down once and for all.","genre_ids":[35,53],"media_type":"movie","popularity":1.1289,"vote_count":241,"poster_path":"/jZiORaxALVDGoMUBau85E4CWB0d.jpg","release_date":"2000-01-07","vote_average":6.147,"backdrop_path":"/sHnvSBVKjbkqTXFRgDbaBfGKIOL.jpg","original_title":"Ordinary Decent Criminal","original_language":"en"},{"id":16167,"adult":false,"title":"From Within","video":false,"overview":"When the citizens of a small evangelical town systematically begin committing suicide, a young girl struggling to reconcile her Christian upbringing with her desire to experience the outside world finds her faith put to the ultimate test.","genre_ids":[27,9648,53],"media_type":"movie","popularity":1.3926,"vote_count":157,"poster_path":"/yyAiGq6SycABwV9m9KqqB2i6Ctl.jpg","release_date":"2008-04-25","vote_average":5.631,"backdrop_path":"/owoOf2hXNIdIArXFu2QPffU96vb.jpg","original_title":"From Within","original_language":"en"},{"id":44032,"adult":false,"title":"Bending The Rules","video":false,"overview":"Detective Nick Blades is a New Orleans cop on trial for corruption. Assistant District Attorney Theo Gold is the man in charge of putting him behind bars. When these two unlikely partners from opposite sides of the law stumble onto a criminal plot, they’ll need to rely on luck – and patience – to take down a dangerous killer without killing each other first.","genre_ids":[28,18,35,80],"media_type":"movie","popularity":0.6751,"vote_count":70,"poster_path":"/jjh6utQh3IPGXkVi8D1U8erDVgt.jpg","release_date":"2012-03-09","vote_average":5.4,"backdrop_path":"/z3i6Ej57dmyFTzFMSzGv8MxW91N.jpg","original_title":"Bending The Rules","original_language":"en"},{"id":2927,"adult":false,"title":"Moon 44","video":false,"overview":"Year 2038: The mineral resources of the earth are drained, in space there are fights for the last deposits on other planets and satellites. This is the situation when one of the bigger mining corporations has lost all but one mineral moons and many of their fully automatic mining robots are disappearing on their flight home. Since nobody else wants the job, they send prisoners to defend the mining station. Among them undercover agent Stone, who shall clear the whereabouts of the expensive robots. In an atmosphere of corruption, fear and hatred he gets between the fronts of rivaling groups.","genre_ids":[878],"media_type":"movie","popularity":0.8985,"vote_count":140,"poster_path":"/ia7Ew8QXiN1Urh63xYFYZ7ZfF2t.jpg","release_date":"1990-02-15","vote_average":5.021,"backdrop_path":"/sWExgcLS5zqCsVeGpuhVqK8Q4YO.jpg","original_title":"Moon 44","original_language":"en"},{"id":208436,"adult":false,"title":"Salt & Gold","video":false,"overview":"A fairy-tale about the power of love. The old king Pravoslav feels it is time to entrust the rule over his kingdom to one of his three daughters - the one that loves him the most. The youngest, Maruška, fails her father's expectations about proving how deep her love him is. He misunderstands her and she is made to leave the castle. She faces many dangers on the way to her loved one, the Salt Prince.","genre_ids":[14,10751],"media_type":"movie","popularity":0.2191,"vote_count":18,"poster_path":"/skWJaxZnZH37BnIOZJp6pWrVCyF.jpg","release_date":"1983-02-27","vote_average":5.917,"backdrop_path":"/sCkAIFt5AZKcUJhqhpSujTfhIgQ.jpg","original_title":"Soľ nad zlato","original_language":"sk"},{"id":345235,"adult":false,"title":"Monk Comes Down the Mountain","video":false,"overview":"A monk leaves his monastery and ventures out into the real world for the first time in his life, and ends up in an adventure with a kung-fu master who is guarding a special artifact.","genre_ids":[28],"media_type":"movie","popularity":2.1569,"vote_count":108,"poster_path":"/eS2wMBnOCBUB3g58andUYIVkICF.jpg","release_date":"2015-07-03","vote_average":5.111,"backdrop_path":"/rHjNt4SbHYg0Mhs6LTyGWaH7wgA.jpg","original_title":"道士下山","original_language":"zh"},{"id":13054,"adult":false,"title":"Rise of the Footsoldier","video":false,"overview":"Rise of the Footsoldier follows the inexorable rise of Carlton Leach from one of the most feared generals of the football terraces to becoming a member of a notorious gang of criminals who rampaged their way through London and Essex in the late eighties and early nineties.","genre_ids":[28,80,53],"media_type":"movie","popularity":1.1991,"vote_count":228,"poster_path":"/k8lbsM0Nl0c1Qp7NnARWjS6TTRA.jpg","release_date":"2007-09-07","vote_average":6.322,"backdrop_path":"/omalLKaiwcLE1H9K22T6rLXmxtg.jpg","original_title":"Rise of the Footsoldier","original_language":"en"},{"id":18887,"adult":false,"title":"Darby O'Gill and the Little People","video":false,"overview":"A wily old codger matches wits with the King of the Leprechauns and helps play matchmaker for his daughter and the strapping lad who has replaced him as caretaker.","genre_ids":[12,10751,14,10749],"media_type":"movie","popularity":1.3499,"vote_count":169,"poster_path":"/2SB5yYMIk3wIgkcJ3k2KwCrRtIB.jpg","release_date":"1959-06-24","vote_average":6.636,"backdrop_path":"/8SLK1d5oUGzA1Lz7fFHOIXYJgc3.jpg","original_title":"Darby O'Gill and the Little People","original_language":"en"},{"id":874965,"adult":false,"title":"The Four of Us","video":false,"overview":"After their partner swap experiment takes a turn, four friends arrive at a remote beach hut to face the fallout and purge themselves of deeper truths.","genre_ids":[35,10749,18],"media_type":"movie","popularity":0.8559,"vote_count":107,"poster_path":"/yAlmGXeAtc7ejp2G1V3qT4mATlb.jpg","release_date":"2021-10-15","vote_average":5.444,"backdrop_path":"/347pJmCLkuFwA0NqTrNVwBL9wNY.jpg","original_title":"Du Sie Er & Wir","original_language":"de"}],"similar_content":[{"id":167,"adult":false,"title":"K-PAX","video":false,"overview":"Prot is a patient at a mental hospital who claims to be from a far away planet. His psychiatrist tries to help him, only to begin to doubt his own explanations.","genre_ids":[878,18,9648],"popularity":4.1785,"vote_count":2664,"poster_path":"/tafXZX0I6rso7EyoEzfygfTqxq6.jpg","release_date":"2001-10-26","vote_average":7.204,"backdrop_path":"/m9ELo5SDNZvp7CGbSVIMYBeY8wl.jpg","original_title":"K-PAX","original_language":"en"},{"id":169,"adult":false,"title":"Predator 2","video":false,"overview":"A police chief in the war-torn streets of Los Angeles discovers that an extraterrestrial creature is hunting down residents - and that he is the next target.","genre_ids":[878,28,53],"popularity":9.8721,"vote_count":3710,"poster_path":"/83X4VwY9sdSJykskmsplIVG0a4h.jpg","release_date":"1990-11-21","vote_average":6.292,"backdrop_path":"/8GGAXEXaTPMDGa0sCPyFcitvlD9.jpg","original_title":"Predator 2","original_language":"en"},{"id":589989,"adult":false,"title":"Furple Reign","video":false,"overview":"A lonely alien and a tiny robot are on a lonely journey through space. Their destination: earth. Their mission: Top Secret.","genre_ids":[878,35],"popularity":0.2161,"vote_count":1,"poster_path":"/l9mnqbQ1wRPjdPNftUYh1hkXOOs.jpg","release_date":"2013-10-21","vote_average":10,"backdrop_path":"/4icpkGojOaBBI0gJCK4sIoAhJMB.jpg","original_title":"Furple Reign","original_la