":720,"file_path":"/lf8iLrqZ9qOpaqgx9oV4HEH6mLu.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":1280,"height":720,"file_path":"/jcuExcRBzR1rdDi6ljCkiuPiaCV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/zPAlbI6MQzyDm8maGW1MToDJBQ1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1281,"height":721,"file_path":"/nT4OgFGxsHyJC1ccjsQJgAUQwdC.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1281,"height":721,"file_path":"/4oeoieeorPOunmjKi6WxRpKP5Oq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1280,"height":720,"file_path":"/v7Ww2cQqe0danNXBmdKIhWVyHfV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2832,"height":1593,"file_path":"/c97HdVj30vspXvHfltG20Ppk6p3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2912,"height":1638,"file_path":"/geyNmDD8sfgMgK7BXHg84Jtjjql.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2849,"height":1603,"file_path":"/vAgxLvUrsaOjvoLRYiptUrcls6I.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2895,"height":1628,"file_path":"/kmdmMdbwJKFa3OttnaOu05OrBxs.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2811,"height":1581,"file_path":"/gS3EST52BYIRu0Pa9vfZKRmE258.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2923,"height":1644,"file_path":"/7hGuIADdxISfsy3njFLyemkAn2M.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2905,"height":1634,"file_path":"/ooPJX4x9Vynkmj7qseuxGUGUbaC.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:46:48.018+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":104,"tagline":"These six students are about to discover their teachers really are from another planet.","homepage":"https://www.miramax.com/movie/the-faculty","overview":"When some very creepy things start happening around school, the kids at Herrington High make the chilling discovery that confirms their worst suspicions: their teachers really are from another planet!"},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Fakülte","runtime":104,"tagline":"Bu fakülteden kolay mezun olacaksınız. Çıkışta diplomanızı almayı unutmayın...","homepage":"","overview":"Herrington Lisesi’nde okuyan bir grup uyumsuz genç, okuldaki öğretmenlerle ilgili yolunda gitmeyen bir şeyler olduğunu farkettiklerinde iş işten geçmiştir. Suyla beslenen ve insanların kılığına giren bu yaratıklar gerçekten uzaydan mı gelmiştir? Peki onları durdurmak bu birbirleriyle dahi anlaşamayan gençlere mi düşmüştür?Robert Rodriguez, bilim kurgu, korku ve gençlik filmleri karışımı ilgi çekici bir tür filmine imza atttı. Her ne kadar El Mariachi ayarında bir film bekleyenleri memnun etmekten uzak bazı klişeler içerse de, meraklısı için pek çok filme göndermelerle dolu kült bir yapım."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Faculty - Trau keinem Lehrer!","runtime":104,"tagline":"Sieben Schüler kurz vor Abschluss...ihres Lebens","homepage":"","overview":"Außerirdische nisten sich in den Körpern der Lehrer der Herrington High School ein, um so als Brückenkopf für die bevorstehende Invasion zu dienen. Einzig sechs Schüler stellen sich der feindlichen Macht zum Kampf. Während die Schule nach und nach von den Aliens in Menschengestalt übernommen wird, sucht das Sextett verzweifelt nach deren drahtziehenden Königin. Doch auch die tapferen Kids sind nicht immun gegen die bösartige Infektion aus dem All. Schließlich weiß keiner mehr, wem er noch trauen kann. Das Ende der Welt scheint nahe …"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"The Faculty","runtime":104,"tagline":"Séchez les cours ! C'est une question de vie ou de mort.","homepage":"","overview":"Herrington High est une école comme les autres. Ses murs sont devenus peu à peu crasseux, ses manuels scolaires périmés, ses professeurs paraissent usés bien avant la retraite, ses élèves, cerveaux et crétins, sérieux ou cancres notoires, affrontent des parents qui ne les comprennent plus et des professeurs qui ne les ont jamais compris. Mais les adolescents de Herrington High se heurtent à un problème inédit. Un de leurs professeurs est tellement bizarre et inquiétant qu'ils le soupçonnent d'appartenir à une autre espèce, de venir d'une autre planète..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Mistério na Faculdade","runtime":100,"tagline":"","homepage":"","overview":"Herrington High é um liceu velho e degradado. Não há dinheiro para nada, as paredes estão sujas, os livros desactualizados e os professores são velhos e ultrapassados. Mas, como em qualquer escola, os corredores enchem-se de vida assim que dispara a campainha. Os alunos são adolescentes iguais aos de qualquer outra escola norte-americana: uns dedicam-se ao desporto, outros aos estudos e outros à vida social. E como jovens que são, lutam por impor os seus pontos de vista no mundo dos adultos. Mas os estudantes de Herrington High vão ter de encarar uma situação nunca antes imaginada: os seus professores estão tão \"fora\"... que nem sequer são deste mundo..."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Факультет","runtime":0,"tagline":"","homepage":"","overview":"Колледж Хэррингтон давно утратил свою первозданность. Его обшарпанные коридоры ежедневно заполняет будущее Америки — одиночки и лидеры, пижоны и наркоманы, умники и кретины. Подобно подросткам везде и всюду, они ведут постоянную борьбу друг с другом.  Но однажды студенты делают ужасающее открытие: их преподаватели — пришельцы с другой планеты! Столкнувшись с вызовом, который они даже не могли себе вообразить, бывшие враги вынуждены объединиться, чтобы спастись от инопланетного вторжения…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":104,"tagline":"Portami dal tuo insegnante.","homepage":"","overview":"Siamo all'Herrington High (situato nel mezzo dell'Ohio) nel quale gli insegnanti ed il personale vengono posseduti da parassiti. Gli insegnanti iniziano quindi a infettare gli studenti con l'organismo. Un gruppetto di studenti capisce la situazione e resiste. Tra questi abbiamo: Zeke Tyler (Josh Hartnett), un genio solitario che ripete il suo ultimo anno, i cui genitori sono sempre in viaggio, che vende una droga simile alla cocaina ai suoi compagni di corso; Stan Rosado (Shawn Hatosy), un burlone che decide all'ultimo anno di uscire dalla squadra di football per incentrarsi sullo studio; la fidanzata di Stan, Delilah Profit (Jordana Brewster), una ragazza popolare e vendicativa che è l'editor-in-chief della testata studentesca; Casey Connor (Elijah Wood), un disadattato picchiato costantemente dagli studenti con un debole per Delilah ed è un abile fotografo per il giornale studentesco."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"The Faculty","runtime":104,"tagline":"Los estudiantes de Herrington High siempre sospecharon sus profesores eran de otro planeta... ¡tenían razón!","homepage":"","overview":"El instituto Herrington es un sitio de mugrientas paredes, anticuados libros de texto y profesores quemados. No hay dinero para excursiones ni para ordenadores nuevos ni para el departamento de Música. Los alumnos son de lo más heterogéneo: solitarios, líderes, pandilleros y cerebritos. Como todos los adolescentes del mundo, han de vérselas con unos padres que no los entienden, con unos profesores que los subestiman y, además, con sus activas hormonas. Lo que ignoran es que están a punto de enfrentarse con algo que nunca podrían haber imaginado."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Факултетът","runtime":104,"tagline":"","homepage":"","overview":"Когато в гимназията \"Харингтън\" започват да се случват странни неща, група от ученици, което надминава и най-страшните им кошмари. Техните учители са обсебени от извънземни паразити, контролиращи съзнанието. Те бързо се разпространяват от преподавателите сред учениците, а малцината останали незасегнати. Нетипична компания от лидери и аутсайдери са тези, които трябва да спасят света от извънземното нашествие и да се справят с тази смъртоносна заплаха за човешкия вид, преди да е станало твърде късно и \"новата\" извънземна раса да се е разпространил и обладала всички..."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":104,"tagline":"","homepage":"","overview":"De leraren op de Herrington High School beginnen van het ene op het andere moment vreemd te doen. Wanneer Casey en Delilah zich moeten verstoppen in een kast in de lerarenkamer zijn ze getuigen van de wurging van zuster Harper door twee van hen. Een paar momenten later blijkt de zuster ineens springlevend, maar dan anders dan ervoor."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":104,"tagline":"","homepage":"","overview":"På Herrington High, en ganske almindelig skole i en ganske almindelig by, begynder lærerne pludselig at opføre sig meget underligt. Da to elever Casey og Delilah en dag gemmer sig i et skab i lærerværelset, overværer de, hvordan to lærere kvæler sygeplejersken Harper. Men hun dør ikke. Hun bliver også bare underlig. Hvad er det, der er ved at ske? Hvem er det, der er ved at overtage menneskerne? Og er det kun Casey og Delilah, der kan se, at der er noget galt. Helt galt..."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Faculty - Az invázium","runtime":104,"tagline":"Hatan rádöbbennek, idegen erő a tanerő","homepage":"","overview":"Mint oly sok mai középiskola, a Herrington High felett is elszállt az idő. Koszosak a falak, könyvei idejétmúltak, tanárai kiégtek. Nincs pénz tanulmányi kirándulásra, új számítógépekre vagy a színjátszócsoport musical - bemutatójára. A zsibongó folyosóin mégis Amerika jövője vibrál: magányosok, nagymenők, drogosok, okosok és focisok. Mint minden tinédzser, ők is küszködnek a szüleikkel, tanáraikkal, no és persze a hormonjaikkal. De a Herrington High diákjai most olyan kihívással szembesülnek, ami minden képzeletüket felülmúlja..."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"老师不是人","runtime":0,"tagline":"","homepage":"","overview":"　　俄亥俄州赫灵顿高中，似乎就在一夜之间，学校的老师以及部分优等生就变得十分奇怪。原本态度和蔼的他们如今冷峻阴森，而这种情况似乎愈演愈烈。  　　问题学生凯西（Elijah Wood 伊利亚·伍德 饰）和黛丽拉（Jordana Brewster 乔丹娜·布鲁斯特 饰）偶然机缘躲进了衣橱，并由此见证了护士罗莎（Salma Hayek 饰）被残忍杀害的场面。但未过多久，罗莎又完好无损地出现众人面前，表情却如其他老师一般阴森。凯西等人逐渐意识到，这一连串事件和他们发现的某种神秘生物有关，而今这种生物似乎正以令人难以想象的恐怖速度大肆蔓延。危险不断迫近……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Oni","runtime":104,"tagline":"Szkoła w małym amerykańskim miasteczku zostaje opanowana przez kosmitów, co skutkuje dziwnymi zachowaniami wśród nauczycieli i uczniów.","homepage":"","overview":"Nauczyciele pewnej amerykańskiej szkoły średniej coraz częściej dziwnie się zachowują, stają się bezwzględni, a nawet okrutni wobec uczniów. Szczególnie bezlitosny jest trener szkolnej drużyny futbolowej, Willis. Po pewnym czasie grupa uczniów odkrywa, że za podejrzane zachowanie odpowiedzialne są istoty pozaziemskie."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Fakulta","runtime":104,"tagline":"","homepage":"","overview":"Všechny staré školy včetně Herrington High mají hrubé stěny, temné chodby a unavené profesory. V jejich třídách však sedí studenti, kteří budou tvořit naši budoucnost. Šest z nich má před sebou mnohem těžší úlohu. Musí obstát v zavěrečném testu: Zachránit Planetu před invazí z vesmíru.  Tento napínavý thriller se odehrává v prostředí školy, kde studenti po záhadných událostech zjistí, že nebezpečná forma s nadpřirozenými schopnostmi infikovala profesory a chce kolonizovat planetu. Studenti, které vetřelci zatím neovládli, jim musí uniknout a najit způsob jak je zastavit. (Oficiální text distributora)"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"סיוט בחדר המורים","runtime":0,"tagline":"התלמידים מגלים שהמורים הפעם שונים לגמרי...","homepage":"","overview":"כמו בתי ספר רבים בימינו, בית הספר התיכון הרינגטון ראה זמנים טובים יותר. קירות בית הספר מלוכלכים, ספרי הלימוד עבר זמנם והמורים תשושים. אין תקציב לטיולים, למחשבים חדשים ואף לא למימון ההצגה המוסיקלית שאמורה להעלות מחלקת הדרמה בבית הספר. אך בפרוזדורים המתפוררים מורגשת האנרגיה של עתידה של ארה\"ב: מתבודדים, מנהיגים, \"יורמים\", \"פרופסורים\" וספורטאים. כמו נערים ונערות בכל מקום, גם הם נאבקים בהורים שלא מבינים לליבם, במורים שמעולם לא הבינו ובהורמונים ללא גבול. אך תלמידי ביה\"ס התיכון הרינגטון יעמדו פנים אל פנים מול אתגר גדול יותר מכל מה שיוכלו לתאר..."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Les Enseignants","runtime":104,"tagline":"Séchez les cours ! C'est une question de vie ou de mort.","homepage":"","overview":"Herrington High est une école comme les autres. Ses murs sont devenus peu à peu crasseux, ses manuels scolaires périmés, ses professeurs paraissent usés bien avant la retraite, ses élèves, cerveaux et crétins, sérieux ou cancres notoires, affrontent des parents qui ne les comprennent plus et des professeurs qui ne les ont jamais compris. Mais les adolescents de Herrington High se heurtent à un problème inédit. Un de leurs professeurs est tellement bizarre et inquiétant qu'ils le soupçonnent d'appartenir à une autre espèce, de venir d'une autre planète..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Prova Final","runtime":104,"tagline":"O Perigo é real. Os professores podem não ser.","homepage":"","overview":"Repentinamente, em uma escola de uma pequena cidade no Ohio, os professores começam a agir estranhamente. Dois estudantes escondidos em um armário testemunham dois professores matando a enfermeira do colégio, mas logo a vítima aparece viva e eles logo concluem que algum alienígena está se apossando do corpos. Assim, o medo toma conta deles e de seus amigos, pois qualquer um pode ser dominado por este ser que ninguém sabe de onde veio, mas parece ter um objetivo definido: possuir todos os terrestres que surjam na sua frente."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"老師不是人","runtime":104,"tagline":"","homepage":"","overview":"一群處於邊緣人的學生，在一次偶然的機會下，發現有一種不明的生物體出現在校園中，他們拿去做化驗時，發現那是非常奇怪的物種，同時遇水就會產生旺盛的活動力，並且會不斷的分化。  接著校園中不斷地出現怪事，老師們的行徑都跟以往大不相同，最後他們發現許多老師和所謂的乖乖牌學生都被異形寄身。這樣的理論當然被其他的人嗤之以鼻，他們只好自己去求證，同時這群學生也必須躲避異形老師的追殺。  危機步步逼近，被異形寄生的人已蔓延到全校，而最恐怖的是他們搞不清楚身邊最親近的同學，究竟還是不是人類？最後他們發現對付異形的致命武器，就是他們自製的毒品，他們要如何才能消滅這些入侵人類並計畫控制地球的恐怖異形？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"패컬티","runtime":0,"tagline":"","homepage":"","overview":"재정난에 허덕이고 있는 해링톤 고등학교에서는 주민들의 환호를 받고 있는 아메리칸 풋볼팀 외에는 학생 교사 모두 무기력하기만 하다.  이 학교에는 아웃사이더 6명이 있다. 치어 리더이자 학보 편집장인 미모의 여학생 딜라일라(조다나 브루스터), 사람과 어울리지 않기 위해 레즈비언인 척 하는 스토클리(클리어 듀발), 교통사고로 부모를 잃은 후 전학 온 메리베스(로라 해리스), 학교의 사고뭉치 제키(조쉬 하트넷), 모범생이지만 학생들에게는 왕따인 케이시(엘리야 우드), 풋볼팀 쿼터백으로 엄청난 인기를 누리지만 풋볼팀과 대우받는 현실이 싫어 팀을 나온 스탠(숀 해토시)이 그들이다.  이들 아웃사이더는 교사들의 미움을 받던 드레이크 교장이 살해되자 범인을 찾기 위해 나선다. 그런데 이후 교사들이 하나씩 차례대로 살해되자 서로가 서로를 의심하는 혼란에 빠지기도 한다.  하지만 생물선생님인 펄롱이 죽던 날 케이시가 풋볼 경기장에서 결정적인 단서를 얻는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Faculty","runtime":104,"tagline":"","homepage":"","overview":"I en amerikansk småstad byts invånarna undan för undan ut till känslokalla utomjordingar. På skolan, Herrington High, blir lärarna plötsligt energiska. Men en grupp elever tar upp striden med inkräktarna."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Aulas Peligrosas","runtime":104,"tagline":"Aulas Peligrosas","homepage":"","overview":"Cuando una maestra de escuela secundaria aparece muerta, sus alumnos comienzan a sospechar, puesto que sus profesores se comportan de forma extraña. Posteriormente los chicos descubren que han sido poseídos por unos extraterrestres que pretenden conquistar la Tierra."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"パラサイト","runtime":0,"tagline":"それは<水>を伝わり接触する","homepage":"","overview":"「デスペラード」「フロム・ダスク・ティル・ドーン」のロバート・ロドリゲスと、「スクリーム」の脚本家ケヴィン・ウィリアムソンが組んだSFスリラー。気弱な少年ケイシーは、ある日、グラウンドで奇妙な生き物を見つける。その生き物を水槽に入れた時、その生き物は変形し、攻撃的な本性を露にした。やがて、ケイシーはやたらに水を欲しがる辺りの人達のおかしな行動に気づく。「あの生物が人間に寄生しているかもしれない」と感じたケイシーは、仲間と共に学園の調査を開始。そこで、取り付かれた先生が保険医を襲う場面に遭遇する……。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Факультет","runtime":0,"tagline":"","homepage":"","overview":"Коледж Херрінгтон давно втратив свою первозданність. Його обшарпані коридори щоденно заповнює майбутнє Америки - одинаки і лідери, піжони і наркомани, розумники і кретини. Схожі на підлітків завжди і всюди, вони ведуть постійну боротьбу один з одним. Але одного разу студенти роблять жахливе відкриття: їх викладачі - прибульці з іншої планети! Зіткнувшись з викликом, який вони навіть не могли собі уявити, колишні вороги змушені об'єднатися, щоби врятуватись від іншопланетного вторгнення..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Fakultet","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ozbek","iso_639_1":"uz","iso_3166_1":"UZ","english_name":"Uzbek"},{"data":{"title":"โรงเรียนสยองโลก","runtime":0,"tagline":"","homepage":"","overview":"เมื่อ “โรงเรียนสยองโลก” ช่างฝีมือการถ่ายภาพบนกระดาษของโรงเรียนมัธยม Herrington ได้เห็นการฆาตกรรมของพี่เลี้ยงและเห็นเธอมีชีวิตอีกครั้ง เธอจึงตัดสินใจสำรวจเหตุการณ์ที่ไม่ปกติที่ Harrington High School ในโอไฮโอ แมรีเบธ หลุยส์\r ฮัทชินสันมือสมัครเล่นพยายามเป็นเพื่อนกับ มิทเชลล์ที่แตะต้องไม่ได้ Stokely ‘Works up’ กองหลัง สแตน โรซาโด หยุดกลุ่มฟุตบอลและตัดขาดกับเดไลลาห์ โปรฟิตต์ ผู้เป็นบรรณาธิการหนังสือพิมพ์ของโรงเรียนและหัวหน้ากลุ่มผู้โฆษณา ซีค ไทเลอร์\r ซึ่งกำลังเรียนปีสุดท้ายซ้ำแล้วซ้ำเล่าและเสนอยาให้กับนักเรียนนักศึกษาหลายคน มีข้อขัดแย้งกับครูฝึกของเขา เอลิซาเบธ เบิร์ก เมื่อเคซี่ย์ คอนเนอร์ผู้วุ่นวายพบสิ่งมีชีวิตประหลาดในสนามฟุตบอล"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"ფაკულტეტი","runtime":0,"tagline":"","homepage":"","overview":"როდესაც ჰერინგტონის სკოლაში საშიში ამბები დატრიალდა ბავშვებმა აღმოაჩინეს, რომ მათი ცუდი ეჭვები გამართლდა. მასწავლებლები მართლაც რომ უცხოპლანეტელები აღმოჩნდნენ. გონების მაკონტროლებელი პარაზიტი ნელნელა ყველა მოსწავლეში გადადის სანამ საბოლოოდ ძალიან ცოტანი არ დარჩებიან ისინი, ვისაც ეს ჯერ არ დამართნია. ამ ჯგუფში ყველა კატეგორიის ბავშვი მოხვდა. ახლა მათ ერთად უნდა გადაარჩინონ სამყარო უცხოპლანეტელების შემოსევისგან."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Kauhun oppitunnit","runtime":104,"tagline":"","homepage":"","overview":"Pienen kaupungin lukion opettajat alkavat käyttäytyä tavallistakin oudommin. He ovat suorastaan kuin vieraalta planeetalta. Pari oppilasta sattuu näkemään kuinka koulun terveydenhoitaja tapetaan. Mutta hän ei kuole. Pian lähes kaikki koulun oppilaatkin ovat todella omituisia. Mitä on tekeillä? Mikä ihme ottaa vallan ihmisistä? Vain kourallinen oppilaita osaa epäillä jotain outoa olevan tekeillä. Jotain todella outoa..."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Fakulta","runtime":0,"tagline":"","homepage":"","overview":"Na jednej strednej škole v Ohiu začne vyčíňať mimozemský parazit, ktorý sa zmocnil učiteľa telocviku Willisa a ovládol jeho telo. Postupne sa zmocňuje aj ďalších členov profesorského zboru, ktorých správanie sa zásadným spôsobom mení. V tom čase nastupuje do školy nesmelá študentka Marybeth, ktorá sa postupne stretáva s hlavnými aktérmi príbehu."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Harrington High és una escola de parets brutes, antiquats llibres de text i professors cremats. No hi ha diners per a excursions ni per a ordinadors nous ni per al departament de Música. Els alumnes són molt heterogenis: solitaris, líders, colles i cervellets. Com tots els adolescents del món, les han de veure amb uns pares que no els entenen, amb uns professors que els subestimen i, a més, amb les seves actives hormones. El que ignoren és que estan a punt d'enfrontar-se amb una cosa que mai no podrien haver imaginat."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"","runtime":104,"tagline":"","homepage":"","overview":"Filmen utspilles i en amerikansk småby der innbyggerne byttes ut én etter én til følelseskalde kopier fra det ytre verdensrom. På den nedslitte skolen, Herrington High, er lærerne bitre og utbrente og skolens eneste stolthet er fotballaget. Men så begynner det å skje saker. Lærerne blir plutselig engasjerte og skoletrøtte elever begynner å lese. Men så begynner det å skje saker. Lærerne blir plutselig engasjerte og skoletrøtte elever begynner å lese. Noen elever innser at det må være romvesener som har tatt over lærernes og kompisenes kropper og de beslutter å ta opp kampen mot inntrengerne."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"奪命高校","runtime":104,"tagline":"","homepage":"","overview":"一群處於邊緣人的學生，在一次偶然的機會下，發現有一種不明的生物體出現在校園中，他們拿去做化驗時，發現那是非常奇怪的物種，同時遇水就會產生旺盛的活動力，並且會不斷的分化。  接著校園中不斷地出現怪事，老師們的行徑都跟以往大不相同，最後他們發現許多老師和所謂的乖乖牌學生都被異形寄身。這樣的理論當然被其他的人嗤之以鼻，他們只好自己去求證，同時這群學生也必須躲避異形老師的追殺。  危機步步逼近，被異形寄生的人已蔓延到全校，而最恐怖的是他們搞不清楚身邊最親近的同學，究竟還是不是人類？最後他們發現對付異形的致命武器，就是他們自製的毒品，他們要如何才能消滅這些入侵人類並計畫控制地球的恐怖異形？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Fakultetas","runtime":0,"tagline":"","homepage":"","overview":"Heringtono koledžas jau seniai prarado savo pirmykštę išvaizdą. Tarp jo nutriušusių sienų kasdien mokosi Amerikos ateitis: vienišiai ir lyderiai, dabitos ir narkomanai. Kaip ir visi paaugliai, jie nuolat kariauja tarpusavyje. Tačiau vieną dieną mokiniai išsiaiškina siaubingą dalyką: jų mokytojai - ateiviai! Atsidūrę iki šiol neįsivaizduojamoje situacijoje, buvę priešai susivienija prieš ateivius..."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Dosje Alien","runtime":0,"tagline":"Učenici srednje škole otkriju da su im profesori vanzemaljci te im se odluče suprotstaviti","homepage":"","overview":"Nekolicina učenika srednje škole Herrington sumnja da su im profesore zaposjeli vanzemaljci. Casey i Delilah započinju istragu, no ono što otkriju je veoma šokantno. Krijući se u ormaru u garderobi, vide kako dvoje profesora dave medicinsku sestru. U šoku su, no uspiju pobjeći. Nekoliko trenutaka poslije medicinska sestra čini se živa, no nekako drukčija, baš kao i svi profesori i većina učenika. Čini se da samo Casey, Delilah i četvero drugih učenika sumnjaju na nešto. Profesor kemije napokon nađe dokaz o izvanzemaljskoj infekciji i objasni im kako će ubiti zaražene ljude. U očajničkom pokušaju da spase školu, gradić, a možda i čitav svijet, njih dvoje se udruže s dilerom droge Zekeom, sportskom zvijezdom Stanom i novopridošlom ljepoticom Marybeth."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Zbornica","runtime":0,"tagline":"","homepage":"","overview":"Razpadla šola Herrington High je prizorišče zgodbe o zbornici, ki jo zavzamejo vesoljska bitja. Vendar je med dijaki skupina navdihnjenih lovcev na pošasti, ki bo poskrbela za nedobrodošle prišleke. Ko se začnejo v stari na pol razpadli šoli Herrington High v Ohiu dogajati srhljive in nepojasnjene stvari, dijaki naletijo na odkritje, ki potrdi njihova najhujša sumničenja: učitelji so v resnici bitja z drugega planeta. Medtem ko se iz šolske zbornice vse bolj širijo umski paraziti, ki nadzorujejo razum in telo gostitelja, se mora skupina osamljenih dijakov, piflarjev in šolskih športnikov organizirati v moštvo lovcev na pošasti, ki bo poskrbelo za nedobrodošle prišleke."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Fakultāte","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"}],"reviews_tmdb":[{"id":"5b10f6429251415ec800f6de","url":"https://www.themoviedb.org/review/5b10f6429251415ec800f6de","author":"Gimly","content":"Totally underrated, prime late 90s Sci-Fi/Horror/Comedy with an incredible cast that has somehow managed to stay under the radar even now, twenty years later on. _The Faculty_ is one of those movies I make everybody watch.\r\n\r\n_Final rating:★★★½ - I really liked it. Would strongly recommend you give it your time._","created_at":"2018-06-01T07:31:14.563Z","updated_at":"2021-06-23T15:58:09.088Z","author_details":{"name":"Gimly","rating":7,"username":"Ruuz","avatar_path":"/xUObnJSvHrFPsIpoDmb1jiQZLq7.jpg"}},{"id":"5d2c1f7e0745e1000f7755e1","url":"https://www.themoviedb.org/review/5d2c1f7e0745e1000f7755e1","author":"John Chard","content":"$11","created_at":"2019-07-15T06:38:54.266Z","updated_at":"2024-05-16T15:22:23.416Z","author_details":{"name":"","rating":7,"username":"John Chard","avatar_path":"/utEXl2EDiXBK6f41wCLsvprvMg4.jpg"}},{"id":"5fcd3115a67254003e775de9","url":"https://www.themoviedb.org/review/5fcd3115a67254003e775de9","author":"Wuchak","content":"$12","created_at":"2020-12-06T19:29:25.929Z","updated_at":"2021-06-23T15:58:48.427Z","author_details":{"name":"","rating":5,"username":"Wuchak","avatar_path":"/4KVM1VkqmXLOuwj1jjaSdxbvBDk.jpg"}}],"recommendations":[{"id":9367,"adult":false,"title":"El Mariachi","video":false,"overview":"El Mariachi just wants to play his guitar and carry on the family tradition. Unfortunately, the town he tries to find work in has another visitor, a killer who carries his guns in a guitar case. The drug lord and his henchmen mistake el Mariachi for the killer, Azul, and chase him around town trying to kill him and get his guitar case.","genre_ids":[28,80,53],"media_type":"movie","popularity":2.6189,"vote_count":1250,"poster_path":"/zRh7K4SV1xQ419m8gzGITak51vc.jpg","release_date":"1993-02-22","vote_average":6.745,"backdrop_path":"/zERY2aaCrLExpR6NQ1ceIs0WG8S.jpg","original_title":"El Mariachi","original_language":"es"},{"id":11252,"adult":false,"title":"Psycho","video":false,"overview":"A young female embezzler arrives at the Bates Motel, which has terrible secrets of its own.","genre_ids":[27,9648,53],"media_type":"movie","popularity":4.6948,"vote_count":1028,"poster_path":"/6pQpZu6JjPsbHzjhG545OsjU2TG.jpg","release_date":"1998-12-04","vote_average":5.1,"backdrop_path":"/8mxJjrPymsCg4rJxmVNjXByQ2ee.jpg","original_title":"Psycho","original_language":"en"},{"id":10206,"adult":false,"title":"Buffy the Vampire Slayer","video":false,"overview":"Blonde, bouncy Buffy is your typical high school cheerleader. But all that changes when a strange man informs her she's been chosen by fate to kill vampires.","genre_ids":[28,35,27],"media_type":"movie","popularity":1.7231,"vote_count":890,"poster_path":"/tcF3S4UdFpuoZEWovMDq5AXazNF.jpg","release_date":"1992-07-24","vote_average":5.6,"backdrop_path":"/tgyQPJKl4Af0mC0YObcuJbc79P3.jpg","original_title":"Buffy the Vampire Slayer","original_language":"en"},{"id":23966,"adult":false,"title":"Deadgirl","video":false,"overview":"When high school misfits Rickie and JT decide to ditch school and find themselves lost in the crumbling facility of a nearby abandoned hospital, they come face-to-face with a gruesome discovery: a body of a woman stripped naked, chained to a table and covered in plastic and soon realize she is anything but dead. Quickly the boys find themselves embarking on a twisted yet poignant journey testing the limits of their friendship, and forces both to decide just how far they're willing to stretch their understanding of right and wrong.","genre_ids":[27,53],"media_type":"movie","popularity":3.497,"vote_count":374,"poster_path":"/ff00BtvdnSHO8qoblBhiXmJKvCm.jpg","release_date":"2008-09-06","vote_average":5.266,"backdrop_path":"/cxBbDUlZ10GibvyQ2iThASBm1Dj.jpg","original_title":"Deadgirl","original_language":"en"},{"id":32536,"adult":false,"title":"Rejected","video":false,"overview":"A hilarious collection of animated television commercials that were rejected because of their creator's failing grip on sanity.","genre_ids":[16,35],"media_type":"movie","popularity":0.5281,"vote_count":224,"poster_path":"/vbci2t9eg4l7fmPzyBaa0OFiyYP.jpg","release_date":"2000-07-25","vote_average":7.3,"backdrop_path":"/qRgpl30lxdWfhJfd1YFJhpZJYVk.jpg","original_title":"Rejected","original_language":"en"},{"id":278878,"adult":false,"title":"The Gunfighter","video":false,"overview":"In the tradition of classic westerns, a narrator sets up the story of a lone gunslinger who walks into a saloon. However, the people in this saloon can hear the narrator and the narrator may just be a little bit bloodthirsty.","genre_ids":[35,37],"media_type":"movie","popularity":0.3976,"vote_count":130,"poster_path":"/4eIbuaBagTpDXFsckDE80JbuqBR.jpg","release_date":"2014-03-21","vote_average":7.088,"backdrop_path":"/9ELF0RS2mdxc933WeJjU9MM4elF.jpg","original_title":"The Gunfighter","original_language":"en"},{"id":97787,"adult":false,"title":"Digimon Adventure","video":false,"overview":"Two children receive a strange egg that hatches into their very first Digimon, leading to the night that would change their lives forever.","genre_ids":[16,12,28,14],"media_type":"movie","popularity":1.0502,"vote_count":90,"poster_path":"/tn65LMkjjFFRdhwV2eSFH3WRlwA.jpg","release_date":"1999-03-06","vote_average":7.489,"backdrop_path":"/xNlNH4Rv0Grba4HR2XIZwgWUFlE.jpg","original_title":"映画 デジモンアドベンチャー","original_language":"ja"},{"id":427025,"adult":false,"title":"Axolotl Overkill","video":false,"overview":"Mifti is a teenager as beautiful as she is reckless. Mentally unstable, fed up with her dysfunctional family, oblivious to the youthful world, and aware of the sexual magnetism she gives off with her peculiar appearance, she wanders through the dark path of several bohemian adults with questionable lifestyles.","genre_ids":[18],"media_type":"movie","popularity":0.4285,"vote_count":50,"poster_path":"/rrO2OVw8eqSlYiFboTU2H39kbA9.jpg","release_date":"2017-06-29","vote_average":5.03,"backdrop_path":"/zmsYBpmDCrruCCXsgluXo7pmuLE.jpg","original_title":"Axolotl Overkill","original_language":"de"},{"id":54013,"adult":false,"title":"The Visitor","video":false,"overview":"An ancient intergalactic warrior arrives on Earth to put a stop to a demonic child's plot to reproduce Satan's next generation of evil.","genre_ids":[27,878],"media_type":"movie","popularity":1.0757,"vote_count":119,"poster_path":"/o8UceYrcX1KuFznKxMtp9N7JpQR.jpg","release_date":"1979-03-22","vote_average":5.2,"backdrop_path":"/bVsGMzJ1jpJpxCzzGbXjvrd4Hcq.jpg","original_title":"Stridulum","original_language":"en"},{"id":31586,"adult":false,"title":"North","video":false,"overview":"Eleven-year-old North has had it with his parents. They are always busy with their careers and don't give North the attention he needs, so he files a lawsuit against them. The judge rules that North should either find new parents or return to his own parents within two months. Thus North starts off on a journey around the world to find parents that really care about him.","genre_ids":[35,10751,14,12,18],"media_type":"movie","popularity":5.1435,"vote_count":274,"poster_path":"/e4JEG7dstmurXMUPOW9Jy6UDR9F.jpg","release_date":"1994-07-22","vote_average":5.018,"backdrop_path":"/ddtoVAha6yUyuMdHUWMzn5o5njX.jpg","original_title":"North","original_language":"en"},{"id":430826,"adult":false,"title":"Casting JonBenet","video":false,"overview":"Twenty years after the modern world's most notorious child murder, the legacy of the crime and its impact are explored.","genre_ids":[99,80,18],"media_type":"movie","popularity":0.3908,"vote_count":171,"poster_path":"/aHDr48Zq4IojCHRMxzGaS1EMaDB.jpg","release_date":"2017-04-28","vote_average":5.7,"backdrop_path":"/hEBBtwQ4ZU0pjrXbKbRTU1IQOrj.jpg","original_title":"Casting JonBenet","original_language":"en"},{"id":11055,"adult":false,"title":"Flatfoot in Africa","video":false,"overview":"Inspector Rizzo in Napoli gets a message from a policeman from South Africa who wants to meet him. Immediately before this meeting the South African policeman is killed. Dying he shows Rizzo a picture of his young son Bodo. Rizzo travels to Johannesburg to find out what the policeman was working on and to find Bodo.","genre_ids":[28,35,80,18],"media_type":"movie","popularity":0.3946,"vote_count":171,"poster_path":"/qNdEEsnYgKaaKIhlcRyAjSbpni4.jpg","release_date":"1978-03-22","vote_average":6.2,"backdrop_path":"/giUXzKkVLWeU2opZNMKPK54Z07C.jpg","original_title":"Piedone l'africano","original_language":"it"},{"id":21430,"adult":false,"title":"New Rose Hotel","video":false,"overview":"A corporate raider and his henchman use a chanteuse to lure a scientific genius away from his employer and family.","genre_ids":[18,9648,878],"media_type":"movie","popularity":1.4717,"vote_count":142,"poster_path":"/pMk6iJSmbt5uovZ1LEhhBZdR5cz.jpg","release_date":"1999-03-19","vote_average":5.236,"backdrop_path":"/9GXU40cPceT5L4AgQs4cl0yjA8l.jpg","original_title":"New Rose Hotel","original_language":"en"},{"id":529649,"adult":false,"title":"The Row","video":false,"overview":"A killer stalks and terrorizes a group of sorority girls on a college campus.","genre_ids":[53,27],"media_type":"movie","popularity":0.4774,"vote_count":66,"poster_path":"/xR2PZ92HTZDFuEpxePJhf0WBCyJ.jpg","release_date":"2018-07-27","vote_average":4.5,"backdrop_path":"/hGh3kaaX0dAFjScvVwOCwtMiKjM.jpg","original_title":"The Row","original_language":"en"},{"id":513857,"adult":false,"title":"The Nanny","video":false,"overview":"Young Noa and Michael are put in the care of their new nanny, Leonor, who Noa suspects is a malicious supernatural being. Dismissed by those around her, Noa works to uncover Leonor's true identity, but soon finds herself with far more than she bargained for.","genre_ids":[878,53,27,14,9648],"media_type":"movie","popularity":0.6756,"vote_count":104,"poster_path":"/h324sCgqkyQVre5a4uDfkXhm5c5.jpg","release_date":"2018-05-01","vote_average":5.413,"backdrop_path":"/grsp3vbmL41wKDRHQPvHxoXJpZW.jpg","original_title":"The Nanny","original_language":"en"},{"id":422153,"adult":false,"title":"Hulk: Where Monsters Dwell","video":false,"overview":"This All Hallows’ Eve, Nightmare is bent on conquering our waking world by crossing through the Dream Dimension, and converting each dreamer into a monster. Can Dr. Strange, Hulk and the Howling Commandos hold the line and put an end to his nefarious scheme?","genre_ids":[28,16,14,878],"media_type":"movie","popularity":0.7155,"vote_count":92,"poster_path":"/udUnSnQKzYddDpU6WNdTMB5XVEE.jpg","release_date":"2016-10-21","vote_average":6.614,"backdrop_path":"/kDTLxyxFJhK0YPD1RN0BR5gQAjR.jpg","original_title":"Hulk: Where Monsters Dwell","original_language":"en"},{"id":30579,"adult":false,"title":"Hallowed Ground","video":false,"overview":"After she becomes stranded in a small town, a young woman discovers her arrival there was foretold a century earlier by the town's founding preacher and that she is an integral part of his impending - and terrifying - rebirth.","genre_ids":[27],"media_type":"movie","popularity":0.3276,"vote_count":38,"poster_path":"/5yLHghnybsyrofVwHzQdXxiWx4J.jpg","release_date":"2007-10-09","vote_average":5.1,"backdrop_path":"/zf6n8ElECEn50Rkh6YDaOJK9qjS.jpg","original_title":"Hallowed Ground","original_language":"en"},{"id":434221,"adult":false,"title":"Legend of the Demon Cat","video":false,"overview":"During the Late Tang Dynasty, a manor is invaded by a demon cat and a sense of unrest befalls the capital of Changan.  A poet is charged with investigating the case and meets up with a monk. The two work together and pull apart the thread of clues to reveal a history of truths leading to the events.","genre_ids":[14,12,10751],"media_type":"movie","popularity":1.5116,"vote_count":102,"poster_path":"/AtFfxjspbiAxYuH1LHvb9UDH0Kz.jpg","release_date":"2017-12-22","vote_average":6.3,"backdrop_path":"/gG7CAYIQz2uhYYRyBIn4iyH4V1N.jpg","original_title":"妖猫传","original_language":"zh"},{"id":39341,"adult":false,"title":"Big Bad Wolf","video":false,"overview":"In Cameron, a group of hunters is attacked by a wild animal, and Charlie Cowley survives, but sees his brother Scott dying. Seven years later, his teenage nephew Derek Cowley steals the key of his stepfather's cabin in the isolated Fire Road 13, and travels with four classmates and his friend Sam to spend the weekend having a party with booze and sex. However, they are attacked by a Beast that kills his friends in a sadistic way. Sam and Derek survive, and they suspect that his stepfather, Mitchell Toblat, is a werewolf. When Charlie meets Derek and Sam, they decide to collect evidence to prove that Mitchell is the Beast and kill him, but Mitchell discovers their plot and chases the trio.","genre_ids":[27,35],"media_type":"movie","popularity":0.9682,"vote_count":112,"poster_path":"/31nFN67QsO3oJ4DDaytejEKKB1J.jpg","release_date":"2006-10-25","vote_average":6.156,"backdrop_path":"/77RUNIreKz94Q8MlIfmjE8raO1U.jpg","original_title":"Big Bad Wolf","original_language":"en"},{"id":447941,"adult":false,"title":"Racketeer 2","video":false,"overview":"Sayan has survived the accident but 10 years later the past comes after him.","genre_ids":[18],"media_type":"movie","popularity":0.125,"vote_count":6,"poster_path":"/iYjf2gtbLhmP0a7tkMH5yPCXuIB.jpg","release_date":"2015-05-28","vote_average":7.3,"backdrop_path":null,"original_title":"Рэкетир 2","original_language":"ru"}],"similar_content":[{"id":106,"adult":false,"title":"Predator","video":false,"overview":"A team of elite commandos on a secret mission in a Central American jungle come to find themselves hunted by an extraterrestrial warrior.","genre_ids":[878,28,12,53],"popularity":14.8271,"vote_count":8869,"poster_path":"/k3mW4qfJo6SKqe6laRyNGnbB9n5.jpg","release_date":"1987-06-12","vote_average":7.5,"backdrop_path":"/otkJlfjB7zJ5h34FEIfemenMbCy.jpg","original_title":"Predator","original_language":"en"},{"id":63,"adult":false,"title":"Twelve Monkeys","video":false,"overview":"In the year 2035, convict James Cole reluctantly volunteers to be sent back in time to discover the origin of a deadly virus that wiped out nearly all of the earth's population and forced the survivors into underground communities. But when Cole is mistakenly sent to 1990 instead of 1996, he's arrested and locked up in a mental hospital. There he meets psychiatrist Dr. Kathryn Railly and the son of a famous virus expert who may hold the key to the Army of the 12 Monkeys; thought to be responsible for unleashing the killer disease.","genre_ids":[878,53,9648],"popularity":8.5281,"vote_count":8939,"poster_path":"/gt3iyguaCIw8DpQZI1LIN5TohM2.jpg","release_date":"1995-12-29","vote_average":7.601,"backdrop_path":"/mKIkGoyuR71qz6FdiEiOjxvBQcS.jpg","original_title":"Twelve Monkeys","original_language":"en"},{"id":653569,"adult":false,"title":"Save Yourselves!","video":false,"overview":"A young Brooklyn couple head upstate to disconnect from their phones and reconnect with themselves. Cut off from their devices, they miss the news that the planet is under attack.","genre_ids":[35,878],"popularity":0.5839,"vote_count":214,"poster_path":"/bvNwVJ3Wh6KeE28TMIczJD6OEPm.jpg","release_date":"2020-10-02","vote_average":5.766,"backdrop_path":"/2vJewgdaf0N8BnAgHZ8R7y3w5qQ.jpg","original_title":"Save Yourselves!","original_language":"en"},{"id":74,"adult":false,"title":"War of the Worlds","video":false,"overview":"Ray Ferrier is a divorced dockworker and less-than-perfect father. Soon after his ex-wife and her new husband drop off his teenage son and young daughter for a rare weekend visit, a strange and powerful lightning storm touches down.","genre_ids":[12,53,878],"popularity":8.8816,"vote_count":8977,"poster_path":"/6Biy7R9LfumYshur3YKhpj56MpB.jpg","release_date":"2005-06-28","vote_average":6.531,"backdrop_path":"/bInicBgSHfQiWLbnRT5jxw9Grvm.jpg","original_title":"War of the Worlds","original_language":"en"},{"id":75,"adult":false,"title":"Mars Attacks!","video":false,"overview":"A fleet of Martian spacecraft surrounds the world's major cities and all of humanity waits to see if the extraterrestrial visitors have, as they claim, \"come in peace.\" U.S. President James Dale receives assurance from science professor Donald Kessler that the Martians' mission is a friendly one. But when a peaceful exchange ends in the total annihilation of the U.S. Congress, military men call for a full-scale nuclear retaliation.","genre_ids":[35,14,878],"popularity":4.8484,"vote_count":5779,"poster_path":"/hll4O5vSAfnZDb6JbnP06GPtz7b.jpg","r