9:{"metadata":[["$","title","0",{"children":"The Running Man | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Desperate to save his sick daughter, working-class Ben Richards is convinced by The Running Man's charming but ruthless producer to enter the deadly competition game as a last resort. But Ben's defiance, instincts, and grit turn him into an unexpected fan favorite — and a threat to the entire system. As ratings skyrocket, so does the danger, and Ben must outwit not just the Hunters, but a nation addicted to watching him fall."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/108500/the-running-man"}],["$","meta","5",{"property":"og:title","content":"The Running Man"}],["$","meta","6",{"property":"og:description","content":"Desperate to save his sick daughter, working-class Ben Richards is convinced by The Running Man's charming but ruthless producer to enter the deadly competition game as a last resort. But Ben's defiance, instincts, and grit turn him into an unexpected fan favorite — and a threat to the entire system. As ratings skyrocket, so does the danger, and Ben must outwit not just the Hunters, but a nation addicted to watching him fall."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/108500/the-running-man"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/dKL78O9zxczVgjtNcQ9UkbYLzqX.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"The Running Man"}],["$","meta","12",{"name":"twitter:description","content":"Desperate to save his sick daughter, working-class Ben Richards is convinced by The Running Ma