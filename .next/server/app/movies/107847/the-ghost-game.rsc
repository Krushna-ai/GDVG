fB06YLK1lZ.jpg","iso_639_1":null,"vote_average":3.954},{"width":3840,"height":2160,"file_path":"/mQsw8idwkyPPmjUQof0Pzx7jBuG.jpg","iso_639_1":null,"vote_average":2.066},{"width":3840,"height":2160,"file_path":"/o0kIw3ICa1l4X8R6QiooXsb7aIZ.jpg","iso_639_1":null,"vote_average":2.066},{"width":3840,"height":2160,"file_path":"/gVuJsKFaIdO9zIGavSWKOaMuqi7.jpg","iso_639_1":null,"vote_average":2.066},{"width":3840,"height":2160,"file_path":"/c2osnfnsU1Uodw7nrL1CGROmorP.jpg","iso_639_1":null,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/c4OLy9vSg6KwVeyDWvP2nVmPnFJ.jpg","iso_639_1":null,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/9Sa9HPUmTukNZh2MTzPYN0QxrGf.jpg","iso_639_1":null,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/ddSn6LWBDYgSx97Q4a2MwG1cUP6.jpg","iso_639_1":null,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/uvNWY1pb6433AtcDLiYq6FaMSCo.jpg","iso_639_1":null,"vote_average":1.222}]},"enriched_at":"2026-02-21T12:02:33.312+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Ghost Game","runtime":95,"tagline":"That day, we should never have started.","homepage":"","overview":"Aspiring YouTuber Gi-ho stages a fake seance for viral content, but Ja-young joins, seeking her missing sister Seo-woo. In an underground cistern, Seo-woo volunteers as the \"possessed,\" but when she collapses, terror unfolds. Trapped with sinister forces, the students face a deadly fate, leading to a shocking twist."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":95,"tagline":"돌이킬 수 없는 저주가 시작되었다","homepage":"","overview":"문을 열었습니다. 열었습니다. 열었습니다. 공모전에 제출할 독특한 영상을 위해 ‘무엇이든 알려주는 강령술’을 촬영하기로 한 ‘자영’과 친구들. 언니 ‘자영’을 잘 따르는 동생 ‘서우’까지 합류하고, 어두운 밤 6명의 아이들은 폐쇄된 지하 저수조로 향한다. 촬영 도중, 호기심이 발동한 ‘자영’과 친구들은 진짜 강령술을 시도한다. 걱정과 달리 잠잠한 분위기에 안도감과 아쉬움이 교차하던 순간, 빙의자 역할을 하던 ‘서우’가 검은 물을 토하며 쓰러지고, 질문이 적힌 부적에 답이 나타난다. 들어오세요. 들어오세요. 들어오세요. 가벼운 마음으로 시작한 강령술은 곧 끔찍한 저주가 되어, 아이들의 목숨을 위협하기 시작하는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"降灵：鬼神游戏","runtime":94,"tagline":"","homepage":"","overview":"立志成为 YouTuber 的基浩，为打造爆款内容策划了一场假降灵仪式，而智英的加入另有目的 —— 她是为寻找失踪的妹妹书雨而来。在一处地下蓄水池中，书雨主动请缨扮演 “被附身者”，可她突然晕倒后，恐怖开始蔓延。这群学生被困在邪恶力量之中，面临着致命的结局，最终迎来一个惊人反转。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"降靈：鬼神遊戲","runtime":0,"tagline":"","homepage":"","overview":"藏有童年秘密的子英，與學校好友為參加 YouTube 徵選，在廢棄儲水槽拍攝「萬事皆知的通靈術」影片，並在拍攝途中嘗試了真正的招靈儀式。起初只是出於好奇與娛樂，沒想到妹妹瑞優突然吐出黑水倒地，符紙上出現詭異回應「請進來」。儀式引來的不是答案，而是無法收拾的詛咒。隨著封閉空間中的恐懼升級，友情崩裂、秘密曝光，通靈術成了奪命惡夢。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Bẫy Hồi Sinh","runtime":95,"tagline":"","homepage":"","overview":"Một nhóm học sinh quyết định quay video dự thi với chủ đề “gọi hồn” tại một bể chứa nước ngầm bỏ hoang. Ban đầu chỉ là một trò đùa mang tính câu view, nhưng mọi thứ nhanh chóng vượt khỏi tầm kiểm soát khi một thành viên bất ngờ nôn ra nước đen và gục ngã giữa nghi lễ."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"降靈：鬼神遊戲","runtime":0,"tagline":"","homepage":"","overview":"藏有童年秘密的子英，與學校好友為參加YouTube徵選，在廢棄儲水槽拍攝「萬事皆知的通靈術」影片，並在拍攝途中嘗試了真正的招靈儀式。起初只是出於好奇與娛樂，沒想到妹妹瑞優突然吐出黑水倒地，符紙上出現詭異回應「請進來」。儀式引來的不是答案，而是無法收拾的詛咒。隨著封閉空間中的恐懼升級，友情崩裂、祕密曝光，通靈術成了奪命惡夢。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"The Ghost Game","runtime":0,"tagline":"","homepage":"","overview":"\"จายอง\" (เยริ) และเพื่อนๆ ตัดสินใจถ่ายวิดีโอเพื่อชิงเงินรางวัล โดยถ่ายพิธีกรรมติดต่อกับวิญญาณ ณ ตึกร้างแห่งนึง แต่เพื่อนๆในกลุ่มไม่รู้ว่า จริงๆแล้วจายองต้องการจะหาเบาะแสเกี่ยวกับการหายไปของพี่สาวของเธอเอง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"O jogo fantasma","runtime":95,"tagline":"","homepage":"","overview":"Um filme de terror e mistério que retrata o que acontece quando Ja Yyeong, que tem um segredo de seu passado, e seus amigos da escola realizam um ritual de necromancia para convocar espíritos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Два, три, призрак, приди!","runtime":0,"tagline":"","homepage":"","overview":"Компания старшеклассников проникает в окутанное легендами заброшенное здание. Они планируют сымитировать и заснять ритуал вызова призрака, который отвечает на любой вопрос, выложить на видеохостинг, набрать просмотры и получить денежный приз, но одна из девушек предлагает провести обряд по-настоящему."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Gi-ho, seorang calon YouTuber, menggelar ritual pemanggilan arwah palsu untuk mendapatkan konten viral, tetapi Ja-young ikut bergabung karena mencari saudara perempuannya yang hilang, Seo-woo. Di sebuah sumur bawah tanah, Seo-woo menawarkan diri sebagai \"orang yang kerasukan,\" tetapi ketika dia pingsan, teror pun terjadi. Terperangkap oleh kekuatan jahat, para siswa menghadapi nasib yang mematikan, yang berujung pada sebuah kejutan yang mengejutkan."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"The Ghost Game","runtime":94,"tagline":"","homepage":"","overview":"Un film d'horreur mystérieux qui raconte ce qui se passe lorsque Ja-yeong, qui cache un secret sur son passé, et ses camarades de classe pratiquent un rituel de nécromancie pour invoquer des fantômes."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"}],"reviews_tmdb":[{"id":"697d922f87299b04c9719aba","url":"https://www.themoviedb.org/review/697d922f87299b04c9719aba","author":"Alunauwie","content":"The Ghost Game follows a group of teenagers who treat a dangerous spirit-summoning ritual as harmless fun, despite the risks lurking beneath. Although the premise and opening set up emotional horror, weak character development and stiff dialogue dilute the tension as the story unfolds. The film offers atmospheric moments, but without deeper emotional stakes, its horror ultimately feels fleeting rather than haunting.\r\n\r\nRead the full review here: (Indonesian version : alunauwie.com) and  (English version : uwiepuspita.com)","created_at":"2026-01-31T05:25:03.508Z","updated_at":"2026-01-31T05:25:03.516Z","author_details":{"name":"","rating":5,"username":"Alunauwie","avatar_path":null}}],"recommendations":[{"id":1149395,"adult":false,"title":"My Sweet Dear","video":false,"overview":"Top chef Do Gun clashes with recipe-copying Jung Woo in a tense kitchen rivalry. But as sparks fly, their feud may simmer into something more.","genre_ids":[18,10749],"media_type":"movie","popularity":0.094,"vote_count":9,"poster_path":"/xeL8IMmv57zJYm4C5MIwLTExabN.jpg","release_date":"2021-12-02","vote_average":9.6,"backdrop_path":"/qeLKSfovyxxo79igrm06aJf1uMh.jpg","original_title":"마이 스윗 디어 (영화)","original_language":"ko"},{"id":1167271,"adult":false,"title":"Weekend in Taipei","video":false,"overview":"A former DEA agent and a former undercover operative revisit their romance during a fateful weekend in Taipei, unaware of the dangerous consequences of their past.","genre_ids":[28,12,53],"media_type":"movie","popularity":2.8801,"vote_count":258,"poster_path":"/qSc0AUvs8mRy00R9y8QYEHWIAQ9.jpg","release_date":"2024-09-19","vote_average":6.339,"backdrop_path":"/eItpQ7dJfSp8aFrX1MdjaUv0HrE.jpg","original_title":"Weekend in Taipei","original_language":"en"},{"id":9384,"adult":false,"title":"Starsky & Hutch","video":false,"overview":"Join uptight David Starsky and laid-back Ken \"Hutch\" Hutchinson as they're paired for the first time as undercover cops. The new partners must overcome their differences to solve an important case with help from street informant Huggy Bear and persuasive criminal Reese Feldman.","genre_ids":[35,80],"media_type":"movie","popularity":2.7824,"vote_count":2470,"poster_path":"/fmBYVkBjhVspPv3GGus84qhBo1a.jpg","release_date":"2004-03-05","vote_average":5.824,"backdrop_path":"/k6Qnu4fTXskJwjFBEZRtTPSLHu9.jpg","original_title":"Starsky & Hutch","original_language":"en"},{"id":1081316,"adult":false,"title":"Prism","video":false,"overview":"A beautiful and lonely story of growth about high school students who dreamed of being ballet dancers at a young age, finding the meaning of life through each other, suffering and badly hurting each other.","genre_ids":[10749,18],"media_type":"movie","popularity":0.0977,"vote_count":2,"poster_path":"/bX8r4BzVexBrCeyx4waBr1635kA.jpg","release_date":"2022-12-01","vote_average":6.5,"backdrop_path":null,"original_title":"프리즘","original_language":"ko"},{"id":806900,"adult":false,"title":"Twenty Hacker","video":false,"overview":"A movie about a white hacker club 'Better World' and a genius hacker 'HEX' having an inevitable showdown with the black hackers as the Songdo International Exchange was hacked in the fourth industrial revolution.","genre_ids":[28],"media_type":"movie","popularity":0.5548,"vote_count":8,"poster_path":"/yNCZyHoZpddbfwPvE7LA4f8Frac.jpg","release_date":"2021-03-24","vote_average":7.1,"backdrop_path":"/rYZY3Q9L9tTy5xqVkDkvHJFIAGF.jpg","original_title":"트웬티 해커","original_language":"ko"},{"id":693134,"adult":false,"title":"Dune: Part Two","video":false,"overview":"Follow the mythic journey of Paul Atreides as he unites with Chani and the Fremen while on a path of revenge against the conspirators who destroyed his family. Facing a choice between the love of his life and the fate of the known universe, Paul endeavors to prevent a terrible future only he can foresee.","genre_ids":[878,12],"media_type":"movie","popularity":23.1578,"vote_count":7533,"poster_path":"/1pdfLvkbY9ohJlCjQH2CZjjYVvJ.jpg","release_date":"2024-02-27","vote_average":8.132,"backdrop_path":"/ylkdrn23p3gQcHx7ukIfuy2CkTE.jpg","original_title":"Dune: Part Two","original_language":"en"},{"id":1140817,"adult":false,"title":"As","video":false,"overview":"Three years after the death of her beloved child, Elouise, Mara still feels her presence when she sits on the butterfly bedding in front of the jar with her ashes in it. Mara arranges a twelfth birthday party for Elouise, further alienating her from her husband, Richter, and remaining daughter, Hannah. Although Mara eventually vacates Elouise's room at the insistence of her husband, she does find a way to stay close to Elouise. Before long, however, Hannah discovers her mother's secret.","genre_ids":[],"media_type":"movie","popularity":0.2508,"vote_count":185,"poster_path":null,"release_date":"2023-01-01","vote_average":7.054,"backdrop_path":null,"original_title":"As","original_language":"en"},{"id":945961,"adult":false,"title":"Alien: Romulus","video":false,"overview":"While scavenging the deep ends of a derelict space station, a group of young space colonizers come face to face with the most terrifying life form in the universe.","genre_ids":[27,878],"media_type":"movie","popularity":13.8151,"vote_count":4292,"poster_path":"/2uSWRTtCG336nuBiG8jOTEUKSy8.jpg","release_date":"2024-08-13","vote_average":7.171,"backdrop_path":"/iYqSQaWDttQIQzsxg9xHyg0bttG.jpg","original_title":"Alien: Romulus","original_language":"en"},{"id":11324,"adult":false,"title":"Shutter Island","video":false,"overview":"World War II soldier-turned-U.S. Marshal Teddy Daniels investigates the disappearance of a patient from a hospital for the criminally insane, but his efforts are compromised by troubling visions and a mysterious doctor.","genre_ids":[18,53,9648],"media_type":"movie","popularity":15.0553,"vote_count":25436,"poster_path":"/nrmXQ0zcZUL8jFLrakWc90IR8z9.jpg","release_date":"2010-02-14","vote_average":8.2,"backdrop_path":"/8xt8AMb1OKC63AdhNSaYBWxB4Iq.jpg","original_title":"Shutter Island","original_language":"en"},{"id":105,"adult":false,"title":"Back to the Future","video":false,"overview":"Eighties teenager Marty McFly is accidentally sent back in time to 1955, inadvertently disrupting his parents' first meeting and attracting his mother's romantic interest. Marty must repair the damage to history by rekindling his parents' romance and - with the help of his eccentric inventor friend Doc Brown - return to 1985.","genre_ids":[12,35,878],"media_type":"movie","popularity":17.301,"vote_count":21403,"poster_path":"/vN5B5WgYscRGcQpVhHl6p9DDTP0.jpg","release_date":"1985-07-03","vote_average":8.324,"backdrop_path":"/qskzmLTbarKnXDbo2HRj4NJ3vcW.jpg","original_title":"Back to the Future","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":21.4528,"vote_count":11363,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.036,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":844409,"adult":false,"title":"The Unlikely Pilgrimage of Harold Fry","video":false,"overview":"Harold Fry is an unremarkable man who has made mistakes with all the important things: being a husband, a father and a friend. And now, well into his 60s, he is content to fade quietly into the background of life. Until, one day – Harold learns his old friend Queenie is dying. Harold leaves home, walking to his post office to send her a letter. And out of the blue, Harold decides to keep walking, all the way to her hospice, 450 miles away.","genre_ids":[18],"media_type":"movie","popularity":1.1814,"vote_count":150,"poster_path":"/pmP1Z6qKYCTLZH2JKqxltwAZHSY.jpg","release_date":"2023-04-27","vote_average":6.62,"backdrop_path":"/pk5OlCei3eXKf6U5k8QNbFEb6Eo.jpg","original_title":"The Unlikely Pilgrimage of Harold Fry","original_language":"en"},{"id":467244,"adult":false,"title":"The Zone of Interest","video":false,"overview":"The commandant of Auschwitz, Rudolf Höss, and his wife Hedwig, strive to build a dream life for their family in a house and garden next to the camp.","genre_ids":[18,36],"media_type":"movie","popularity":6.1619,"vote_count":2487,"poster_path":"/hUu9zyZmDd8VZegKi1iK1Vk0RYS.jpg","release_date":"2023-12-15","vote_average":7.008,"backdrop_path":"/pnTSOKcYnvdpQNQElAtJM1rWOxH.jpg","original_title":"The Zone of Interest","original_language":"en"},{"id":939243,"adult":false,"title":"Sonic the Hedgehog 3","video":false,"overview":"Sonic, Knuckles, and Tails reunite against a powerful new adversary, Shadow, a mysterious villain with powers unlike anything they have faced before. With their abilities outmatched in every way, Team Sonic must seek out an unlikely alliance in hopes of stopping Shadow and protecting the planet.","genre_ids":[28,878,35,10751],"media_type":"movie","popularity":16.3792,"vote_count":3138,"poster_path":"/d8Ryb8AunYAuycVKDp5HpdWPKgC.jpg","release_date":"2024-12-19","vote_average":7.628,"backdrop_path":"/noPEm6Vu9Lm6QUdTGLOyRgk4M6s.jpg","original_title":"Sonic the Hedgehog 3","original_language":"en"},{"id":653346,"adult":false,"title":"Kingdom of the Planet of the Apes","video":false,"overview":"Several generations following Caesar's reign, apes – now the dominant species – live harmoniously while humans have been reduced to living in the shadows. As a new tyrannical ape leader builds his empire, one young ape undertakes a harrowing journey that will cause him to question all he's known about the past and to make choices that will define a future for apes and humans alike.","genre_ids":[878,12,28],"media_type":"movie","popularity":9.3534,"vote_count":4099,"poster_path":"/gKkl37BQuKTanygYQG1pyYgLVgf.jpg","release_date":"2024-05-08","vote_average":7.055,"backdrop_path":"/iHYh4cdO8ylA3W0dUxTDVdyJ5G9.jpg","original_title":"Kingdom of the Planet of the Apes","original_language":"en"},{"id":565770,"adult":false,"title":"Blue Beetle","video":false,"overview":"Recent college grad Jaime Reyes returns home full of aspirations for his future, only to find that home is not quite as he left it. As he searches to find his purpose in the world, fate intervenes when Jaime unexpectedly finds himself in possession of an ancient relic of alien biotechnology: the Scarab.","genre_ids":[28,878,12],"media_type":"movie","popularity":5.9665,"vote_count":3021,"poster_path":"/mXLOHHc1Zeuwsl4xYKjKh2280oL.jpg","release_date":"2023-08-16","vote_average":6.647,"backdrop_path":"/3H9NA1KWEQN0ItL3Wl3SFZYP6yV.jpg","original_title":"Blue Beetle","original_language":"en"},{"id":527774,"adult":false,"title":"Raya and the Last Dragon","video":false,"overview":"Long ago, in the fantasy world of Kumandra, humans and dragons lived together in harmony. But when an evil force threatened the land, the dragons sacrificed themselves to save humanity. Now, 500 years later, that same evil has returned and it’s up to a lone warrior, Raya, to track down the legendary last dragon to restore the fractured land and its divided people.","genre_ids":[16,10751,14,28,12],"media_type":"movie","popularity":7.2216,"vote_count":7177,"poster_path":"/5nVhgCzxKbK47OLIKxCR1syulOn.jpg","release_date":"2021-03-03","vote_average":7.805,"backdrop_path":"/zmX7ObPaRfiCmY6LMalUb1bJDKj.jpg","original_title":"Raya and the Last Dragon","original_language":"en"},{"id":920342,"adult":false,"title":"Monster's Battlefield","video":false,"overview":"The soldier king Qin Yang's fiancée Ye Qin met with an unknown beast and died tragically. Gu Ping invites him to participate in Ye Qin's scientific research before her death. But Gu Ping is using Ye Qin's research results to combine the genes of unknown beasts to create the \"Zero\" dragon creature. The intelligent dragon creature, coupled with the extra-terrestrial beast evolved by devouring,  an imminent city war is coming...","genre_ids":[878,28,27],"media_type":"movie","popularity":1.257,"vote_count":194,"poster_path":"/nBVYp2xxx2R02n21EGlDky8CgWR.jpg","release_date":"2021-12-27","vote_average":6.8,"backdrop_path":"/7kQvHmGyKJv2wSKVfCUux50rd7A.jpg","original_title":"异兽战场","original_language":"zh"},{"id":1151244,"adult":false,"title":"Vermiglio","video":false,"overview":"In the last days of the Second World War, a deserting soldier disrupts a tranquil and isolated mountain community. For one family, his arrival brings excitement and romance, but tragedy lies in wait.","genre_ids":[18],"media_type":"movie","popularity":3.9587,"vote_count":302,"poster_path":"/aeCwM7c1Y1IAu3Oqqj5A2tSziWR.jpg","release_date":"2024-09-19","vote_average":7.061,"backdrop_path":"/fYepNPcgAYHQRMNZW95oOykLRgQ.jpg","original_title":"Vermiglio","original_language":"it"},{"id":1155089,"adult":false,"title":"Justice League: Crisis on Infinite Earths Part One","video":false,"overview":"Death is coming. Worse than death: oblivion. Not just for our Earth, but for everyone, everywhere, in every universe! Against this ultimate destruction, the mysterious Monitor has gathered the greatest team of Super Heroes ever assembled. But what can the combined might of Superman, Wonder Woman, Batman, The Flash, Green Lantern and hundreds of Super Heroes from multiple Earths even do to save all of reality from an unstoppable antimatter armageddon?!","genre_ids":[16,878,28],"media_type":"movie","popularity":2.7918,"vote_count":390,"poster_path":"/zR6C66EDklgTPLHRSmmMt5878MR.jpg","release_date":"2024-01-08","vote_average":7.277,"backdrop_path":"/tWEcrdHbQLJUuetCQupgCJaTRQ9.jpg","original_title":"Justice League: Crisis on Infinite Earths Part One","original_language":"en"}],"similar_content":[],"external_ids":{"imdb_id":"tt37285917","twitter_id":null,"facebook_id":null,"wikidata_id":"Q135653079","instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":107847,"wiki_plot":null,"wiki_synops