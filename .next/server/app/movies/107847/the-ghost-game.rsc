5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Ghost Game\",\"description\":\"Aspiring YouTuber Gi-ho stages a fake seance for viral content, but Ja-young joins, seeking her missing sister Seo-woo. In an underground cistern, Seo-woo volunteers as the \\\"possessed,\\\" but when she collapses, terror unfolds. Trapped with sinister forces, the students face a deadly fate, leading to a shocking twist.\",\"image\":\"https://image.tmdb.org/t/p/w500/6uF6PnY1gWNmDkAMYO1qhgdgozM.jpg\",\"datePublished\":\"2025-08-06\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"horror film\",\"Horror\",\"Mystery\",\"Thriller\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.679,\"bestRating\":10,\"ratingCount\":28}}"}}],["$","$L10",null,{"initialDrama":{"id":"394f7e8d-c38b-4917-9f34-dfc717551535","tmdb_id":1354700,"imdb_id":"tt37285917","content_type":"movie","title":"The Ghost Game","original_title":"강령: 귀신놀이","overview":"Aspiring YouTuber Gi-ho stages a fake seance for viral content, but Ja-young joins, seeking her missing sister Seo-woo. In an underground cistern, Seo-woo volunteers as the \"possessed,\" but when she collapses, terror unfolds. Trapped with sinister forces, the students face a deadly fate, leading to a shocking twist.","poster_path":"/6uF6PnY1gWNmDkAMYO1qhgdgozM.jpg","backdrop_path":"/et17Am3i8QE80HA7YUilG82Dz1x.jpg","release_date":"2025-08-06","first_air_date":null,"status":"published","original_language":"ko","origin_country":["KR"],"genres":[{"name":"horror film"},{"id":27,"name":"Horror"},{"id":9648,"name":"Mystery"},{"id":53,"name":"Thriller"}],"popularity":8.7888,"vote_average":6.679,"vote_count":28,"runtime":95,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:47:58.098669+00:00","updated_at":"2026-02-21T12:02:28.13+00:00","tagline":"That day, we should never h