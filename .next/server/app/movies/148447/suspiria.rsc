VZwxFvII8n9hrmzZ3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1755,"height":987,"file_path":"/yOhJhz9Y6VAjMyx9VspwBKZchP6.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1754,"height":987,"file_path":"/wYTOreqqsZKblprLWBnIoyFvUt7.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1755,"height":987,"file_path":"/lYnoPnWyOaxB4i3hnc8DAg4g88Q.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1755,"height":987,"file_path":"/70hhNryhGb9pMVp34CtO6eNOIZ5.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1755,"height":987,"file_path":"/dzDmXloOjXIavkisxwHfDlFgvq0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1755,"height":987,"file_path":"/qklaIWzERuXz6AjJFCtHKUlDwk0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1755,"height":987,"file_path":"/ln722aNFAMw75g4BmISG63i5NZk.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1755,"height":987,"file_path":"/so0Sj2vhAbGg97OwwuE6gl7fp1s.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:36:28.173+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":99,"tagline":"Do You Know Anything About Witches?","homepage":"","overview":"An American newcomer to a prestigious German ballet academy comes to realize that the school is a front for something sinister amid a series of grisly murders."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":98,"tagline":"","homepage":"","overview":"Susy va a Friburgo per iscriversi a un'accademia di danza, ma un paio di compagne vengono massacrate in maniera orripilante. Sull'edificio che ospita la scuola, una vecchia costruzione isolata e immersa in un bosco, grava un'antica maledizione e la direttrice sembra essere in comunicazione con l'aldilà. O meglio, con una strega dura a morire..."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":98,"tagline":"","homepage":"","overview":"Susan (Harper) é uma jovem americana que viaja para a Europa para estudar numa prestigiada escola de Balé. Desde o primeiro dia, porém, ela começa a se assustar com estranhas situações que ocorrem no local que a fazem crer que há bruxas por todas a parte. (Seguido de \"Inferno\" e \"A Mãe das Lágrimas\")"},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":99,"tagline":"Jamais l'horreur n'a été aussi sublime.","homepage":"","overview":"Suzy, une jeune américaine, arrive à Fribourg afin de suivre des cours dans une académie de danse prestigieuse. L’atmosphère générale dans l’école surprend la jeune fille, c’est une atmosphère étrange et inquiétante. Puis cela tourne au cauchemar lorsque surviennent des accidents terribles : un jeune élève est assassiné, un pianiste aveugle est égorgé par son propre chien… Suzy est par ailleurs souvent prise de malaises. Elle apprend que l’académie était autrefois la demeure d’une terrible sorcière surnommée la Mère des Soupirs. Et si l’école était encore sous son emprise ?"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Suspiria - In den Krallen des Bösen","runtime":94,"tagline":"Ein unheimlich starker Schocker","homepage":"","overview":"Die junge Ballett-Elevin Suzy kommt aus den USA nach Freiburg, um dort an einer angesehenen Schule Tanz zu studieren. Als sie dort ankommt, beobachtet sie noch ein junges Mädchen, das aus der Schule flieht, um dann aber später in der eigenen Wohnung auf mysteriöse Art und Weise ermordet zu werden. Doch auch Suzy kommt die Schule zunehmend merkwürdig vor. Die Lehrerinnen führen ein hartes Regiment, nachts hört man seltsame Geräusche und etwas schleicht nachts durch den provisorischen Schlafsaal. Langsam aber sicher forscht Suzy den merkwürdigen Vorgängen nach und findet heraus, dass das Haus an sich eine unheimliche Geschichte hat und eine dunkle Macht beherbergt."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":98,"tagline":"","homepage":"","overview":"Una joven (Jessica Harper) ingresa en una exclusiva academia de baile la misma noche en que asesinan a una de las alumnas. La subdirectora del centro es la amable Madame Blank, que brinda a la nueva alumna las comodidades y facilidades necesarias para su aprendizaje. Pero, poco a poco, una atmósfera malsana se va apoderando del lugar, y la estancia de la joven se va convirtiendo en una verdadera pesadilla."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Odgłosy","runtime":99,"tagline":"","homepage":"","overview":"Amerykanka Susy Banyon, przyjeżdża do słynnej szkoły baletowej w Wiedniu, aby rozwijać swój talent. Na miejscu niemal natychmiast orientuje się, że nie wszystko jest w porządku. Studentki giną w strasznych, niewyjaśnionych okolicznościach. Z czasem dowiaduje się zaskakujących faktów, które pomogą dziewczynie rozwiązać zagadkę."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"阴风阵阵","runtime":91,"tagline":"唯一比这部电影的最后 12 分钟更恐怖的是前 80 分钟。","homepage":"","overview":"经典恐怖片，讲一个年轻的美国芭蕾舞学生到欧洲上芭蕾学校。她在一个大雨的夜晚来到德国一所有名的芭蕾舞学校，这是一家豪华的私立学校，但在堂皇的外表后面居然是一个女巫的魔窟，于是一系列的恐怖事件发生了。从她抵达校园的一开始目睹一名惊惶失措的女子跑出校园，接着就不断的听闻或目睹一连串怪异与谋杀的事件，整个学校像是被诅咒了一般，最后Suzy决定逃离这所学校所带来无法解释的一切怪异现象。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Sóhajok","runtime":0,"tagline":"Tud valamit a boszorkányokról?","homepage":"","overview":"Susy Bannion egy viharos, szörnyű éjszakán érkezik meg a németországi Freiburgba, amelynek világhírű balettanodájában szeretné a táncművészet legmagasabb fokát elsajátítani. Az intézet azonban minden, csak nem marasztaló: az őrült-expresszionista épület tele van gonosz tanárokkal és üresfejű, önző tanulókkal, akik sorra életüket vesztik. Suzy-t nem hagyja nyugodni a hely nyomasztó hangulata és társai eltűnése, magánnyomozásba kezd..."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Uvidende om, hvad der kommer til at ske, ankommer Suzy Bannion til den prestigefyldte balletskole Tanz Dance. Det er sent om aftenen og tordenvejr, da hun bliver mødt af en skrækslagen elev, der flygter væk fra skolen. Da skoleåret starter, indser Suzy hurtigt, at noget er galt, og hendes tid på akademiet udvikler sig til et mareridt, da der sker en række mystiske mord..."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Σουσπίρια","runtime":0,"tagline":"Το μόνο πιο τρομακτικό πράγμα από τα τελευταία 12 λεπτά του έργου, είναι τα πρώτα 92.","homepage":"","overview":"Μια νεαρή Αμερικανίδα ταξιδεύει στη Γερμανία, προκειμένου να φοιτήσει σε διάσημη σχολή χορού. Κατά την άφιξή της βλέπει μια κοπέλα να εγκαταλείπει το οίκημα σε αλλόφρονα κατάσταση. Την επομένη μαθαίνει ότι βρέθηκε νεκρή. Στην περίεργη στάση που κρατούν οι καθηγητές και το προσωπικό προστίθεται η φήμη ότι στις αρχές του αιώνα η σχολή ήταν κέντρο μαγείας και αποκρυφισμού."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"サスペリア","runtime":99,"tagline":"決して ひとりでは見ないでください──","homepage":"","overview":"“決してひとりでは見ないでください－－” この名キャッチコピーは公開当時の流行語に。鮮烈な色彩、ゴブリンが参加した不気味なサウンド、過激演出が三位一体となって独自の緊張感を生み、今も語られることが多い逸品。1977年日本公開の洋画でベストテンに入るヒットを記録。影響で翌年、アルジェントによる1975年の無関係な作品が「サスペリアPART2」として日本公開。監督にとっては「インフェルノ」「サスペリア・テルザ　最後の魔女」に続く“魔女3部作”の第1弾に。\r アメリカからドイツのバレエ学校に留学してきたスージー。校舎に到着した夜、ある女性が何か言いながら消えていく姿を目撃する。直後、女性は何者かに殺される。入学したスージーは厳しいレッスンを受けるようになるが、体調に異変が起きて倒れたり、同じ寮で友人になったサラとともに怪しいうめき声や足音を聞くなど、異常な事態が続く。ついにある夜、サラは何者かに追われている気がして、寮の中をひとりで逃げるが……。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"סוספיריה","runtime":0,"tagline":"","homepage":"","overview":"סרט האימה הקלאסי של אמן הז'אנר האיטלקי דאריו ארג'נטו, הוא חלקה הראשון של טרילוגיית \"שלוש האמהות\" שלו. רקדנית אמריקאית מגיע ללמוד בלט בבית ספר יוקרתי באירופה. קולות משונים הבוקעים מהקירות והתנהגות מבשרת רעות מצד הסובבים אותה, גורמים לה להאמין שבית הספר הוא יותר מסתם מוסד חינוכי. לאט לאט נחשפת כת שטנית ביותר של מכשפות שפועלות בשם כוח רב עצמה ואפל. אלים, עשיר בצבע ומסוגנן כיאה למאסטר."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"서스페리아","runtime":98,"tagline":"당신이 지금까지 본 가장 무서운 영화!","homepage":"","overview":"독일의 유명한 발레 학교로 유학 온 미국인 소녀 수지는 도착 첫날 밤, 겁에 질려 학교에서 도망쳐나오는 학생을 목격하고, 이튿날 아침 도망치던 학생과 다른 여학생이 끔찍하게 살해당했다는 소식을 듣는다. 수지는 발레 학교에 적응하려고 애쓰지만 이상한 선생과 학생들, 밤에 기숙사에 울려퍼지는 기이한 소리들 때문에 힘이 든다. 그 지방 전설로 내려오는 마녀 이야기와 살인 사건이 관련있으리라 추측하던 수지는 자신도 모르는 사이에 흑마술의 표적이 되는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Суспирия","runtime":98,"tagline":"«Знаете ли вы что-нибудь о ведьмах?»","homepage":"","overview":"Юная американка Сьюзи приезжает в Германию обучаться мастерству танца в престижной мюнхенской балетной школе. В ночь приезда её туда почему-то не пустили, но она видела, как из здания выбежала девушка, которая позже в ту же ночь была жестоко убита. На утро недоразумение разрешится, Сьюзи примут, и она приступит к занятиям. Девушке придётся жить в пансионате при школе, на ночь её будут поить вином с подмешанным снотворным, но она всё равно почувствует витающую в воздухе школы угрозу и захочет выяснить, что ей угрожает."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":98,"tagline":"Karanlıkta bir daha asla güvende hissetmeyeceksiniz.","homepage":"","overview":"Amerikalı bale öğrencisi Suzy Bannion, dünyaca ünlü ve saygın bir Alman yatılı dans akademisinde eğitim görmeye gelir. Suzy okula adım attığı andan itibaren bir dizi esrarengiz olaya tanıklık eder. Önceki gece okuldan kaçan bir öğrenci, ölü bulunmuştur. Piyanist Daniel ise kendi köpeği tarafından öldürülür. Akademide bir salgın hastalık baş gösterir ve korkutucu okul binasının her yanından tuhaf sesler yükselmektedir. Suzy biraz araştırma yapınca okulun geçmişte bir “cadılar meclisi” mekanı olduğunu öğrenir. Ama işaretler, binada cadı geleneğinin ve ayinlerinin geçmişte kalmadığını, hâlâ devam ettiğini göstermektedir!"},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":0,"tagline":"Você sabe alguma coisa sobre bruxas?","homepage":"","overview":"Susan é uma jovem americana que viaja para a Europa para estudar numa prestigiada escola de Balé. Desde o primeiro dia, porém, ela começa a se assustar com estranhas situações que ocorrem no local que a fazem crer que há bruxas por todas a parte."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":98,"tagline":"","homepage":"","overview":"Gestileerde horror over de Amerikaanse ballet-studente Susy Banyon, die afreist naar een Duitse ballet-academie in het Zwarte Woud. Daar vallen al snel twee slachtoffers, en Susy ontdekt dat de academie een wel heel bizarre geschiedenis kent."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"坐立不安","runtime":0,"tagline":"","homepage":"","overview":"美國女孩遠赴德國學習芭蕾，但在舞蹈學院內，某些學生不是失蹤便慘遭殺害，校方冷淡的反應和接連發生的怪事更令她心啟疑竇，隨著深入追查，她竟發現不可告人的內幕。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Flykten från helvetet","runtime":97,"tagline":"","homepage":"","overview":"Ovetande om vad som komma skall anländer Suzy Bannion till prestigefulla balettskolan Tanz Dance. Det är sent på kvällen, mitt i ett åskoväder, och hon möts av att en skräckslagen student flyr skolan. När terminen väl kommit igång dröjer det inte länge innan Suzy inser att något är fel, och hennes tid på akademien blir till en övernaturlig mardröm kantad med en rad mystiska mord..."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Суспирия","runtime":94,"tagline":"Най-плашещият филм, който ще видите!","homepage":"","overview":"Младата американка Сузи Бениън се надява да усъвършенства уменията си в швейцарската академия на мадам Бланк, но ще й се наложи да изучи науката за страха, изкуството да оцелееш, хореографията на безумието. \"Суспирия\" - оживелият, но оставащ невидим страх, величествен и безграничен. Той е в египетските рисунки по стените на пансиона, в шума на вятъра зад прозореца, в гласовете зад стената, в празното легло на съквартирантката, в шепота на невидими крила над безлюден площад?"},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"陰風陣陣","runtime":0,"tagline":"","homepage":"","overview":"母親三部曲之首，蘇斯寄宿德國芭蕾學校，遇上魔影重重，背後隱藏駭人秘密。據説故事源自合寫人之一妮歌洛蒂的祖母真實經歷，加以血腥想像。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Suspiria: Alarido","runtime":0,"tagline":"","homepage":"","overview":"Una joven (Jessica Harper) ingresa en una exclusiva academia de baile la misma noche en que asesinan a una de las alumnas. La subdirectora del centro es la amable Madame Blank, que brinda a la nueva alumna las comodidades y facilidades necesarias para su aprendizaje. Pero, poco a poco, una atmósfera malsana se va apoderando del lugar, y la estancia de la joven se va convirtiendo en una verdadera pesadilla."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Vũ Điệu Tử Thần","runtime":0,"tagline":"","homepage":"","overview":"Câu chuyện về cô gái có tên là Suzy được học một trường múa đẳng cấp quốc tế.Thế nhưng, nhiều điều kì lạ xảy ra, Suzy quyết định điều tra về ngôi truong này."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Суспірія","runtime":0,"tagline":"","homepage":"","overview":"Юна Америка Сюзі приїжджає в Німеччину навчатися мастерству танців у старій римській балетній школі. В ніч приїзду її туда чомусь не пустили, але вона побачила, як з будинку школи вибігла дівчина, яка пізніше в ту ж ніч була жорстоко убита. На ранок Сюзи приймуть, і вона приступає до занять. Її змусять залишитися жити в пансіонаті при школі, на ніч будуть поїти вином з підмішаним снодійним, але дівчина все одно відчує витає в повітрі школи загрозу і захоче з’ясувати, що їй загрожує."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"","runtime":98,"tagline":"","homepage":"","overview":"Baletní akademie bývají povětšinou klidná, světlem prosluněná, místa. Vedle nich existují i školy zalité měsícem. Suzy Bannion, mladá talentovaná Američanka, do jedné takové zrovna přijíždí. Suspiria je první díl z kultovní trilogie „Tři Matky“"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"ดวงอาถรรพณ์","runtime":0,"tagline":"","homepage":"","overview":"เรื่องราวของ ซูซี่หญิงสาวผู้เดินทางจากนิวยอร์คมาสู่เยอรมัน เพื่อเข้าเรียนยังสถาบันสอนบัลเล่ต์ชื่อดังของยุโรป และในคืนแรกเธอก็พบกับสิ่งแปลก ๆ ที่น่ากลัว..แต่เธอไม่รู้ว่ามันคืออะไร!! และเธอก็ยังคงเข้าเรียนที่นั่นต่อไปด้วยความคลางแคลง ใจ แต่ยิ่งอยู่นานไปสิ่งแปลก ๆ ลึกลับบางอย่าง ก็ยังเกิดกับเธอเรื่อย ๆ และไม่ใช่เธอเท่านั้นที่เจอ..เพื่อนนักเรียนของเธอก้ อเช่นกัน เมื่อเหตุการณ์ดำเนินมาถึงขีดสุด\r ซูซี่จึงตัดสินใจค้นหาความจริง.."},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Lugu järgib noort Ameerika balletitantsijat Suzy Bannionit, kes saabub Saksamaale Freiburgi, et õppida prestiižikas tantsuakadeemias. Suzy peagi avastab, et koolis toimuvad kummalised ja seletamatud sündmused, mis viivad ta kurjakuulutava saladuse jälgedele. Selgub, et akadeemia pole lihtsalt tantsuõppeasutus, vaid peidab endas salapärast iidset kurjust. Filmi süžeed iseloomustab unenäoline ja hallutsinogeenne rütm, mis juhib vaatajat üha sügavamale õuduse ja saladuste labürinti."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"Nopūtas","runtime":0,"tagline":"","homepage":"","overview":"Mīklaini notikumi kādas prestižas vācu baletskolas gaiteņos. Tajā ierodas jaunā amerikāņu dejotāja Sūzena, kurai lemts kļūt par liecinieci tam, ko ritualizētas performances laikā spēj radīt cilvēka ķermenis."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"}],"reviews_tmdb":[{"id":"58a24fdcc3a36829410006a2","url":"https://www.themoviedb.org/review/58a24fdcc3a36829410006a2","author":"tmdb17996075","content":"$11","created_at":"2017-02-14T00:31:24.154Z","updated_at":"2021-06-23T15:57:54.038Z","author_details":{"name":"","rating":10,"username":"tmdb17996075","avatar_path":null}},{"id":"5ac9377192514162a4047807","url":"https://www.themoviedb.org/review/5ac9377192514162a4047807","author":"tmdb47633491","content":"If you can, check out the Synapse remaster. Seems to be the only one that gets the colors right, and the little-heard 4.0 English mix is absolute insanity","created_at":"2018-04-07T21:26:09.850Z","updated_at":"2021-06-23T15:58:07.525Z","author_details":{"name":"","rating":7,"username":"tmdb47633491","avatar_path":null}},{"id":"5e5cce9155c9260015534a58","url":"https://www.themoviedb.org/review/5e5cce9155c9260015534a58","author":"missmiserys","content":"$12","created_at":"2020-03-02T09:14:57.182Z","updated_at":"2021-06-23T15:58:34.662Z","author_details":{"name":"","rating":10,"username":"missmiserys","avatar_path":null}}],"recommendations":[{"id":20126,"adult":false,"title":"Deep Red","video":false,"overview":"An English pianist living in Rome witnesses the brutal murder of his psychic neighbor. With the help of a tenacious young reporter, he tries to discover the killer using very unconventional methods. The two are soon drawn into a shocking web of dementia and violence.","genre_ids":[27,9648,53],"media_type":"movie","popularity":1.9904,"vote_count":1570,"poster_path":"/wq7RxV5gMvgO0EKeWpNhegnpJBh.jpg","release_date":"1975-03-07","vote_average":7.727,"backdrop_path":"/nIl67C3sKQ68y1kVxuDTLXBJqYX.jpg","original_title":"Profondo rosso","original_language":"it"},{"id":361292,"adult":false,"title":"Suspiria","video":false,"overview":"A darkness swirls at the center of a world-renowned dance company, one that will engulf the artistic director, an ambitious young dancer, and a grieving psychotherapist. Some will succumb to the nightmare. Others will finally wake up.","genre_ids":[27,9648,18],"media_type":"movie","popularity":3.2678,"vote_count":2721,"poster_path":"/bRpKFPb8CWKRQxVo9NzOuPPlO3Q.jpg","release_date":"2018-10-26","vote_average":6.906,"backdrop_path":"/k4renoGJzagylgBYWbpjQLYGAfB.jpg","original_title":"Suspiria","original_language":"en"},{"id":16395,"adult":false,"title":"Inferno","video":false,"overview":"A young man returns from Rome to his sister's satanic New York apartment house.","genre_ids":[27,53],"media_type":"movie","popularity":1.5675,"vote_count":662,"poster_path":"/A92SmwJ4w2GSF6Mp2m8xE9GbG39.jpg","release_date":"1980-02-07","vote_average":6.626,"backdrop_path":"/eJGbf7RB8YNE9s3YLCt6lgqAOB9.jpg","original_title":"Inferno","original_language":"it"},{"id":29161,"adult":false,"title":"Phenomena","video":false,"overview":"A young girl, with an amazing ability to communicate with insects, is transferred to an exclusive Swiss boarding school, where her unusual capability might help solve a string of murders.","genre_ids":[27,53],"media_type":"movie","popularity":1.9414,"vote_count":897,"poster_path":"/8u14C2FLMSCLIT5znmye6RovonO.jpg","release_date":"1985-01-25","vote_average":6.787,"backdrop_path":"/hcLJi6WEZWskxsY3EVh4V0hXKjE.jpg","original_title":"Phenomena","original_language":"en"},{"id":29702,"adult":false,"title":"Tenebre","video":false,"overview":"A razor-wielding serial killer is on the loose, murdering those around Peter Neal, an American mystery author in Italy to promote his newest novel.","genre_ids":[27,53,9648],"media_type":"movie","popularity":1.3403,"vote_count":679,"poster_path":"/uWNCyUX9sjtnhleqyw2W5ECijlP.jpg","release_date":"1982-10-28","vote_average":6.818,"backdrop_path":"/toYJpo6mezPMzO91hWfH8TU6kPF.jpg","original_title":"Tenebre","original_language":"it"},{"id":3763,"adult":false,"title":"Onibaba","video":false,"overview":"While her son, Kichi, is away at war, a woman and her daughter-in-law survive by killing samurai who stray into their swamp, then selling whatever valuables they find. Both are devastated when they learn that Kichi has died, but his wife soon begins an affair with a neighbor who survived the war, Hachi. The mother disapproves and, when she can't steal Hachi for herself, tries to scare her daughter-in-law with a mysterious mask from a dead samurai.","genre_ids":[27],"media_type":"movie","popularity":1.4056,"vote_count":464,"poster_path":"/xyPLG53OodhJtvfQEfcmC43l16O.jpg","release_date":"1964-11-21","vote_average":7.669,"backdrop_path":"/wZwA7HN8ahWsz5AGsTR5I0UdsjZ.jpg","original_title":"鬼婆","original_language":"ja"},{"id":27431,"adult":false,"title":"The Cat o' Nine Tails","video":false,"overview":"A newsman works with a blind puzzle-solver to uncover a deadly conspiracy linked to a genetic research facility.","genre_ids":[27,9648,53],"media_type":"movie","popularity":0.7474,"vote_count":446,"poster_path":"/vVfylUKX9Lz3Idpu0J3ds7vGXoF.jpg","release_date":"1971-02-12","vote_average":6.698,"backdrop_path":"/5yunPf3vpOMYon7HBJtrwZNs1YG.jpg","original_title":"Il gatto a nove code","original_language":"it"},{"id":12262,"adult":false,"title":"The Hills Have Eyes","video":false,"overview":"Taking an ill-advised detour en-route to California, the Carter family soon run into trouble when their RV breaks down in the middle of the desert. Stranded, they find themselves at the mercy of monstrous cannibals lurking in the surrounding hills.","genre_ids":[27,53],"media_type":"movie","popularity":1.5017,"vote_count":979,"poster_path":"/1G2DBIEkoS0JdCiOFIeR3mD8ROE.jpg","release_date":"1977-07-22","vote_average":6.171,"backdrop_path":"/e5ecjQw8AK0e924UIkMOUTxGhMj.jpg","original_title":"The Hills Have Eyes","original_language":"en"},{"id":15206,"adult":false,"title":"The Mother of Tears","video":false,"overview":"An ancient urn is found in a cemetery outside Rome. Once opened, it triggers a series of violent incidents: robberies, rapes and murders increase dramatically, while several mysterious, evil-looking young women coming from all over the world are gathering in the city. All these events are caused by the return of Mater Lacrimarum, the last of three powerful witches who have been spreading terror and death for centuries. Alone against an army of psychos and demons, Sarah Mandy, an art student who seems to have supernatural abilities of her own, is the only person left to prevent the Mother of Tears from destroying Rome.","genre_ids":[27],"media_type":"movie","popularity":0.5113,"vote_count":455,"poster_path":"/6ewz6PCWBzKZnQBbG4wODnjwvDm.jpg","release_date":"2007-10-31","vote_average":4.53,"backdrop_path":"/tEJf6vcobkTzIk2cRJYvLKeUuLY.jpg","original_title":"La terza madre","original_language":"it"},{"id":20115,"adult":false,"title":"Opera","video":false,"overview":"A young opera singer is stalked by a deranged fan bent on killing the people associated with her to claim her for himself.","genre_ids":[27,53,9648],"media_type":"movie","popularity":2.8852,"vote_count":521,"poster_path":"/v5VBvSVu2sWLAmyQhKQwBV5aPJA.jpg","release_date":"1987-12-19","vote_average":6.743,"backdrop_path":"/jh1TMz3AUe40HbCigQ7weCDEW0d.jpg","original_title":"Opera","original_language":"it"},{"id":57447,"adult":false,"title":"The House with Laughing Windows","video":false,"overview":"Stefano, a young restorer, is commissioned to save a controversial mural located in the church of a small, isolated village.","genre_ids":[9648,53,27],"media_type":"movie","popularity":0.5158,"vote_count":385,"poster_path":"/oinsJI8Rlz8EjSOO6ahsFDsDhwN.jpg","release_date":"1976-08-20","vote_average":7.235,"backdrop_path":"/hN8BEjmyqsPdwSPsdDWenoid1as.jpg","original_title":"La casa dalle finestre che ridono","original_language":"it"},{"id":11815,"adult":false,"title":"The Fly","video":false,"overview":"Industrialist François Delambre is called late at night by his sister-in-law, Helene, who tells him that she has just killed her husband. Reluctant at first, she eventually explains to the police that he invented a matter transportation apparatus and, while experimenting on himself, a fly entered the chamber.","genre_ids":[878,27,18],"media_type":"movie","popularity":2.4641,"vote_count":592,"poster_path":"/kXdBcDh2EbgSIf4Oo1dxKapZM2f.jpg","release_date":"1958-07-16","vote_average":7.029,"backdrop_path":"/wpz62HFxCGaMX6jImELAspwqjT1.jpg","original_title":"The Fly","original_language":"en"},{"id":16007,"adult":false,"title":"Death Note","video":false,"overview":"Light Yagami finds the \"Death Note,\" a notebook with the power to kill, and decides to create a Utopia by killing the world's criminals, and soon the world's greatest detective, \"L,\" is hired to find the mysterious murderer. An all out battle between the two greatest minds on earth begins and the winner will control the world.","genre_ids":[14,9648,53],"media_type":"movie","popularity":2.7622,"vote_count":767,"poster_path":"/xiJPZntaz1BMooXfiwi2iZAMbhY.jpg","release_date":"2006-06-17","vote_average":7.066,"backdrop_path":"/mJMriqsFTXzNE37maThHHb6zCGy.jpg","original_title":"デスノート","original_language":"ja"},{"id":948,"adult":false,"title":"Halloween","video":false,"overview":"Fifteen years after murdering his sister on Halloween Night 1963, Michael Myers escapes from a mental hospital and returns to the small town of Haddonfield, Illinois to kill again.","genre_ids":[27,53],"media_type":"movie","popularity":5.9042,"vote_count":6064,"poster_path":"/wijlZ3HaYMvlDTPqJoTCWKFkCPU.jpg","release_date":"1978-10-24","vote_average":7.553,"backdrop_path":"/sHI9xlFRWCJ38AIIfOqnGjuEvXz.jpg","original_title":"Halloween","original_language":"en"},{"id":26451,"adult":false,"title":"Investigation of a Citizen Above Suspicion","video":false,"overview":"Rome, Italy. After committing a heinous crime, a senior police officer exposes evidence incriminating him because his moral commitment prevents him from circumventing the law and the social order it protects.","genre_ids":[18,53],"media_type":"movie","popularity":0.8424,"vote_count":854,"poster_path":"/vPTZwlq1IC4o1DCsEZEl2uGljzm.jpg","release_date":"1970-10-16","vote_average":8.167,"backdrop_path":"/7SUT9mYb7SD88Gz7rFeLbjC2YeG.jpg","original_title":"Indagine su un cittadino al di sopra di ogni sospetto","original_language":"it"},{"id":16306,"adult":false,"title":"Fantastic Planet","video":false,"overview":"On the planet Ygam, the Draags, extremely technologically and spiritually advanced blue humanoids, consider the tiny Oms, human beings descendants of Terra's inhabitants, as ignorant animals. Those who live in slavery are treated as simple pets and used to entertain Draag children; those who live hidden in the hostile wilderness of the planet are periodically hunted and ruthlessly slaughtered as if they were vermin.","genre_ids":[16,878],"media_type":"movie","popularity":1.8537,"vote_count":1076,"poster_path":"/prq0j1S0K07UjwLZLF6oMGflRUI.jpg","release_date":"1973-12-01","vote_average":7.6,"backdrop_path":"/AwrqoanoZVYoc0MRyE0RiHEKm71.jpg","original_title":"La Planète sauvage","original_language":"fr"},{"id":15916,"adult":false,"title":"Angel's Egg","video":false,"overview":"In the ruins of a strange city, a young girl takes care of a large egg she holds carefully in her arms. She bonds with a boy who is searching for a bird he saw in a dream.","genre_ids":[16,14,9648],"media_type":"movie","popularity":2.1137,"vote_count":551,"poster_path":"/dcEUGvckbePFzPKhGXnS9T3kZMG.jpg","release_date":"1985-12-22","vote_average":7.7,"backdrop_path":"/nZn384qWYugXu6U1N8Ya0Iv0NXE.jpg","original_title":"天使のたまご","original_language":"ja"},{"id":10331,"adult":false,"title":"Night of the Living Dead","video":false,"overview":"A ragtag group barricade themselves in an old Pennsylvania farmhouse to remain safe from a horde of flesh-eating ghouls ravaging the Northeast.","genre_ids":[27,53],"media_type":"movie","popularity":2.3485,"vote_count":2670,"poster_path":"/rb2NWyb008u1EcKCOyXs2Nmj0ra.jpg","release_date":"1968-10-04","vote_average":7.614,"backdrop_path":"/5KtmBSqFtHY3I9t8lgH27Mc0bqY.jpg","original_title":"Night of the Living Dead","original_language":"en"},{"id":814,"adult":false,"title":"An American Werewolf in London","video":false,"overview":"American tourists David and Jack are savagely attacked by an unidentified animal while hiking on the Yorkshire Moors. After retiring to the home of a beautiful nurse to recuperate, David soon begins experiencing disturbing changes to his body and mind.","genre_ids":[35,27],"media_type":"movie","popularity":3.6921,"vote_count":2646,"poster_path":"/hVEqUASJmCQaolkKFEySCHZ8uKG.jpg","release_date":"1981-08-21","vote_average":7.4,"backdrop_path":"/4js6VLf6qHWUbW42BpXiQKPBP7t.jpg","original_title":"An American Werewolf in London","original_language":"en"},{"id":1116,"adult":false,"title":"The Wind That Shakes the Barley","video":false,"overview":"In 1920s Ireland young doctor Damien O'Donovan prepares to depart for a new job in a London hospital. As he says his goodbyes at a friend's farm, British Black and Tans arrive, and a young man is killed. Damien joins his brother Teddy in the Irish Republican Army, but political events are soon set in motion that tear the brothers apart.","genre_ids":[18,10752],"media_type":"movie","popularity":2.1733,"vote_count":874,"poster_path":"/yCb4LweL6U7KTgSda3Wb7vHiA9J.jpg","release_date":"2006-06-23","vote_average":7.3,"backdrop_path":"/fKrFGB96kVeJ9uE83Jc4fIWBgqO.jpg","original_title":"The Wind That Shakes the Barley","original_language":"en"}],"similar_content":[{"id":8461,"adult":false,"title":"Funny Games","video":false,"overview":"When Ann, husband George, and son Georgie arrive at their holiday home they are visited by a pair of polite and seemingly pleasant young men. Armed with deceptively sweet smiles and some golf clubs, they proceed to terrorize and torture the tight-knit clan, giving them until the next day to survive.","genre_ids":[53,27],"popularity":4.9356,"vote_count":2217,"poster_path":"/zs92sAOh3Q0kDIJkgaJFTBzSFka.jpg","release_date":"2008-03-14","vote_average":6.556,"backdrop_path":"/6P4R7kYUdJprHpyBmOQO6aB85xX.jpg","original_title":"Funny Games","original_language":"en"},{"id":8689,"adult":false,"title":"Cannibal Holocaust","video":false,"overview":"A New York University professor returns from a rescue mission to the Amazon rainforest with the footage shot by a lost team of documentarians who were making a film about the area's local cannibal tribes.","genre_ids":[27],"popularity":5.9907,"vote_count":1814,"poster_path":"/otxZzMh53TsN7yYFqSZ3rwH1yMd.jpg","release_date":"1980-02-07","vote_average":6.3,"backdrop_path":"/7QBBvE6tA1kUlo7AKeZZMygdSHp.jpg","original_title":"Cannibal Holocaust","original_language":"it"},{"id":8843,"adult":false,"title":"The Cell","video":false,"overview":"A psychotherapist journeys inside a comatose serial killer in the hopes of saving his latest victim.","genre_ids":[27,878,53],"popularity":4.5201,"vote_count":1669,"poster_path":"/kfYVxvDDAJoFq2knHUzAZP09pAc.jpg","release_date":"2000-08-18","vote_average":6.267,"backdrop_path":"/wMvqec4N7Na5DHdyQugh7w0UpBF.jpg","original_title":"The Cell","original_language":"en"},{"id":8851,"adult":false,"title":"The Blob","video":false,"overview":"A drive-in favorite, this sci-fi classic follows teenagers Steve and his best girl, Jane, as they try to protect their hometown from a gelatinous alien life form that engulfs everything it touches. The first to discover the substance and live to tell about it, Steve and Jane witness the blob destroying an elderly man, then it growing to a terrifying size. But no one else has seen the goo, and policeman Dave refuses to believe the kids without proof.","genre_ids":[27,878],"popularity":2.2651,"vote_count":645,"poster_path":"/ctOwn1Ibg3SjDG4WulvFvSH0PRT.jpg","release_date":"1958-09-10","vote_average":6.216,"backdrop_path":"/32l2szM3oY7kdI3TMBral5dsc2E.jpg","original_title":"The Blob","original_language":"en"},{"id":8852,"adult":false,"title":"Prince of Darkness","video":false,"overview":"A priest discovers an ancient canister containing a strange liquid in an abandoned church. When a group of graduate students and scientists are tasked with studying it, they unknowingly unleash an evil force waiting to destroy all of humanity.","genre_ids":[27],"popularity":1.9395,"vote_count":1118,"poster_path":"/jjcAOhtGuX4p8XvlVn1WXUT1jWi.jpg","release_date":"1987-10-23","vote_average":6.779,"backdrop_path":"/9FYa8R1VQdgfuX4QcgZgvbaQ2ca.jpg","original_title":"Prince of Darkness","original_language":"en"},{"id":1259362,"adult":false,"title":"The Christ of the Skull","video":false,"overview":"In the darkness of a gothic night, two knights engage in a deadly duel, illuminated only by the mysterious light of a lantern. A noble lady, confined in a castle, has woven a mysterious connection with the contenders. Supernatural forces and inexplicable events will determine the fate of the duelists in a night of horror.","genre_ids":[14,27,36],"popularity":0.1553,"vote_count":2,"poster_path":"/82hT9yNibO1MuhRnJ9La5kU2qtQ.jpg","release_date":"2023-10-14","vote_average":6.5,"backdrop_path":"/vbd0iCYB46vD69QehNdVZHsCoG8.jpg","original_title":"El Cristo de la Calavera","original_language":"es"},{"id":9360,"adult":false,"title":"Anaconda","video":false,"overview":"A 'National Geographic' film crew is taken hostage by an insane hunter, who takes them along on his quest to capture the world's largest — and deadliest — snake.","genre_ids":[12,27,53],"popularity":5.8133,"vote_count":2736,"poster_path":"/33NysOnLpLZY0ewHTcfpalzAsRG.jpg","release_date":"1997-04-11","vote_average":5.259,"backdrop_path":"/e2oO1FPwMiDEi119rJJspYI6TiG.jpg","original_title":"Anaconda","original_language":"en"},{"id":9003,"adult":false,"title":"Hellraiser","video":false,"overview":"A hedonistic man finds a mysterious puzzle box that summons a group of gruesome beings known as the Cenobites. These otherworldly entities open the doors to a dominion where pain and pleasure are indivisible.","genre_ids":[27,53],"popularity":3.913,"vote_count":2803,"poster_path":"/3Z0oPHyLnk3Vx6ZMC1MiVwIrKhO.jpg","release_date":"1987-09-11","vote_average":6.877,"backdrop_path":"/j4irvwRLITgGr6vcP8NIKCUA67y.jpg","original_title":"Hellraiser","original_language":"en"},{"id":9009,"adult":false,"title":"Dark Water","video":false,"overview":"Dahlia and her five-year-old daughter are ready to begin a new life together. But their new apartment — dilapidated and worn — suddenly seems to take on a life of its own. Mysterious noises, persistent leaks of dark water and other strange happenings send Dahlia on a haunting and mystifying pursuit — one that unleashes a torrent of living nightmares.","genre_ids":[27,9648],"popularity":1.4874,"vote_count":1096,"poster_path":"/cm4M9xaBu78IjuAVNG4LCXdXsg.jpg","release_date":"2005-07-08","vote_average":5.682,"backdrop_path":"/XKZjyePvRYPn7JdfRGZO3Q87qu.jpg","original_title":"Dark Water","original_language":"en"},{"id":9100,"adult":false,"title":"The Craft","video":false,"overview":"A Catholic school newcomer falls in with a clique of teen witches who wield their powers against all who dare to cross them -- be they teachers, rivals or meddlesome parents.","genre_ids":[27,18,14],"popularity":3.1778,"vote_count":2012,"poster_path":"/8bW2RdRkloYtEPhbQZN4wcdmJP4.jpg","release_date":"1996-05-03","vote_average":6.777,"backdrop_path":"/yAaAsbossCADVFdiqm8qAhd2gL0.jpg","original_title":"The Craft","original_language":"en"},{"id":9406,"adult":false,"title":"An American Werewolf in Paris","video":false,"overview":"An American man unwittingly gets involved with werewolves who have developed a serum allowing them to transform at will.","genre_ids":[27,35,14],"popularity":2.323,"vote_count":742,"poster_path":"/1NUOprbP7LLfKPArLJY7wziUiHT.jpg","release_date":"1997-05-29","vote_average":5.915,"backdrop_path":"/3umSuaSibCcNGAnsWYUyauLTZwE.jpg","original_title":"An American Werewolf in Paris","original_language":"en"},{"id":9378,"adult":false,"title":"Thir13en Ghosts","video":false,"overview":"Arthur and his two children inherit his uncle's estate: a glass house that serves as a prison to twelve ghosts. When the family, accompanied by a nanny and an attorney, enter the house they find themselves trapped inside an evil machine 'designed by the Devil and powered by the dead' to open the Eye of Hell. Aided by a ghost hunter and his rival, a ghost rights activist out to set the ghosts free, the group must do what they can to get out of the house alive.","genre_ids":[27,53],"popularity":6.6334,"vote_count":2316,"poster_path":"/6yrrddjIjx0ElCRZp5pTZeqrj3k.jpg","release_date":"2001-10-26","vote_average":6.285,"backdrop_path":"/mUffUjlJ007XAzdogdZqhaqSp4O.jpg","original_title":"Thir13en Ghosts","original_language":"en"},{"id":662728,"adult":false,"title":"Kisah Tanah Jawa: Pocong Gundul","video":false,"overview":"HAO has retrocognitive ability, an ability to see past events. With his ability, Hao helps SARI, a vocational school student, who was kidnapped by ‘Pocong Gundul’ - a evil pocong figure with a bald head. Together with his best friend RIDA, Hao manages to save Sari, but Hao's actions ignites anger from the Pocong Gundul. Terror after terror threatens Hao's life. With his ability, he travels into Pocong Gundul's past and finds out that in his past, he was a black shaman named WALISDI. An evil man who performs a dangerous ancient ritual, a ritual that turns him into ‘Pocong Gundul’. If Hao does not do anything, Pocong Gundul will roam around and take more victims. Hao must do his best to stop Pocong Gundul's evil plan, even though his life is at stake.","genre_ids":[27],"popularity":0.2144,"vote_count":8,"poster_path":"/pzREo2uh5jyxKoUR8TizxKZ7n3b.jpg","release_date":"2023-09-21","vote_average":7.2,"backdrop_path":"/4fTW4N1CdnyRr2EjKJUx3eYuXiS.jpg","original_title":"Kisah Tanah Jawa: Pocong Gundul","original_language":"id"},{"id":1260004,"adult":false,"title":"Island of Death","video":false,"overview":"Dara disregarded her mother's prohibition to celebrate graduation with Pandu, Niki, Lathi, and Noah on a ship. Unbeknownst to them, their ship stranded on an unnamed island. Longing enveloped Dara for her mother as she and her friends were trapped there. Can Dara and her friends escape from the island?","genre_ids":[12,27],"popularity":3.3937,"vote_count":3,"poster_path":"/5Rvs6cM1yZs7iGRlpZNj7o2yFtK.jpg","release_date":"2024-10-10","vote_average":7.7,"backdrop_path":"/xdWp1LpiutVD79d9E68JaHrltU9.jpg","original_title":"Pulau Hantu","original_language":"id"},{"id":9423,"adult":false,"title":"Virus","video":false,"overview":"When the crew of an American tugboat boards an abandoned Russian research vessel, the alien life form aboard regards them as a virus which must be destroyed.","genre_ids":[27,28,878],"popularity":2.3383,"vote_count":664,"poster_path":"/5Np88iigCfnXvMlMKmCcbPVIbYQ.jpg","release_date":"1999-01-14","vote_average":5.402,"backdrop_path":"/j3Nvs9rZDjsOU3jwtxUwyEum1pn.jpg","original_title":"Virus","original_language":"en"},{"id":9424,"adult":false,"title":"Disturbing Behavior","video":false,"overview":"Steve Clark is a newcomer in the town of Cradle Bay, and he quickly realizes that there's something odd about his high school classmates. The clique known as the \"Blue Ribbons\" are the eerie embodiment of academic excellence and clean living. But, like the rest of the town, they're a little too perfect. When Steve's rebellious friend Gavin mysteriously joins their ranks, Steve searches for the truth with fellow misfit Rachel.","genre_ids":[9648,27,878],"popularity":1.4912,"vote_count":408,"poster_path":"/uAhvaueOUUQ6ORCRdsJr1WXz1w0.jpg","release_date":"1998-07-24","vote_average":5.775,"backdrop_path":"/9bMAhzkuvwSXdxUIoFrYuAvkxDU.jpg","original_title":"Disturbing Behavior","original_language":"en"},{"id":9456,"adult":false,"title":"The Crow: Salvation","video":false,"overview":"Alex Corvis, a man wrongly executed for the murder of his girlfriend, returns from the dead and sets out to find the real killer.","genre_ids":[28,53,27,14],"popularity":1.3007,"vote_count":399,"poster_path":"/5JkLJ0HS1hGxZHok9pjBcLCpLuX.jpg","release_date":"2000-01-23","vote_average":5.466,"backdrop_path":"/s6cgAveWCam2hYgdPhD3WbrjSBt.jpg","original_title":"The Crow: Salvation","original_language":"en"},{"id":136,"adult":false,"title":"Freaks","video":false,"overview":"A circus' beautiful trapeze artist agrees to marry the leader of side-show performers, but his deformed friends discover she is only marrying him for his inheritance.","genre_ids":[18,27],"popularity":1.8676,"vote_count":1283,"poster_path":"/fX2Wxd0W9E7eVClUd8kJTfennoV.jpg","release_date":"1932-01-01","vote_average":7.77,"backdrop_path":"/r18vpGFsNf6n984x4KdJmAAWKkP.jpg","original_title":"Freaks","original_language":"en"},{"id":170,"adult":false,"title":"28 Days Later","video":false,"overview":"Twenty-eight days after a killer virus was accidentally unleashed from a British research facility, a small group of London survivors are caught in a desperate struggle to protect themselves from the infected. Carried by animals and humans, the virus turns those it infects into homicidal maniacs -- and it's absolutely impossible to contain.","genre_ids":[27,53,878],"popularity":17.7462,"vote_count":8256,"poster_path":"/sQckQRt17VaWbo39GIu0TMOiszq.jpg","release_date":"2002-10-31","vote_average":7.236,"backdrop_path":"/aJFwk1clMal1prxAvKAgHxKPAf.jpg","original_title":"28 Days Later","original_language":"en"},{"id":17,"adult":false,"title":"The Dark","video":false,"overview":"In an attempt to pull her family together, Adèlle travels with her young daughter Sarah to Wales to visit her father. The morning after they arrive, Sarah mysteriously vanishes in the ocean. Not long after, a little girl bearing a striking resemblance to their missing daughter reveals that she has retuned from the dead  — and that Sarah has been taken to the Welsh underworld.","genre_ids":[27,53,9648],"popularity":0.6963,"vote_count":290,"poster_path":"/h6gCVAzjFLhzkffv2VZO1RgVCBt.jpg","release_date":"2005-09-28","vote_average":5.697,"backdrop_path":"/dhr0q4eiRr8ltqPig32TwhPRdaD.jpg","original_title":"The Dark","original_language":"en"}],"external_ids":{"imdb_id":"tt0076786","twitter_id":null,"facebook_id":null,"wikidata_id":"Q546900","instagram_id":null,"metacritic_id":"movie/suspiria","mydramalist_id":"350","rotten_tomatoes_id":"m/1020662-suspiria"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148447,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AU","release_dates":[{"note":"Blu-ray","type":5,"iso_639_1":"","descriptors":[],"release_date":"2012-10-03T00:00:00.000Z","certification":""}]},{"iso_3166_1":"CZ","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2024-08-15T00:00:00.000Z","certification":"18+"}]},{"iso_3166_1":"DE","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"1977-05-05T00:00:00.000