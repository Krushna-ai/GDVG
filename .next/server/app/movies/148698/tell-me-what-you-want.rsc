I0fa.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.781,"vote_average":0},{"width":1920,"height":1079,"file_path":"/94kQrbY3PZ97PO1mE1dwd04Hdee.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":3840,"height":2160,"file_path":"/hJ88fHjpDSE93J5I9J6F8U8bLui.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/fSO7cnetDfNEflwAsxlkzV446Ua.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/tweYHSe3UTErkVIBcryJ3UWndza.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/bTKU007TXVT4fcDj0m4rgmuoZPB.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/1J9CUvbnhjyohCqsoxILyAILgnk.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/wrSM0u9DgHMK67fkwdbIGLnjj7l.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/n7xFXu7wtTEHDmWJtZXKrCkTRM0.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T06:37:09.366+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":114,"tagline":"","homepage":"","overview":"Judith Flores es una chica normal. Tiene un trabajo que le apasiona, muy buenos amigos y un padre encantador. Pero su vida cambia radicalmente cuando conoce a Eric Zimmerman, dueño de la empresa donde ella trabaja. Su relación con Eric está a punto de dinamitar su vida por completo."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Tell Me What You Want","runtime":114,"tagline":"","homepage":"","overview":"After his father's death, Eric Zimmerman travels to Spain to oversee his company's branches. In Madrid, he falls for Judith and engage in an intense, erotic relationship full of exploration. However, Eric fears his secret may end their affair."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Pídeme lo que quieras","runtime":114,"tagline":"","homepage":"","overview":"Po śmierci ojca Eric Zimmerman udaje się do Hiszpanii, aby nadzorować oddziały swojej firmy. W Madrycie zakochuje się w Judith i angażuje się w intensywny, erotyczny związek pełen eksploracji. Eric obawia się, że jego sekret może zakończyć ich romans."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":114,"tagline":"","homepage":"https://www.warnerbros.es/peliculas/pideme-lo-que-quieras","overview":"La agradable vida de Judith Flores cambia radicalmente cuando conoce a Eric Zimmerman, dueño de la empresa donde ella trabaja. Ambos se embarcan en una relación intensa y erótica llena de exploración."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Peça-me o Que Quiser","runtime":114,"tagline":"","homepage":"","overview":"Após a morte de seu pai, Eric Zimmerman viaja para a Espanha para supervisionar as filiais de sua empresa. Em Madri, ele se apaixona por Judith e se envolve em um relacionamento intenso e erótico cheio de exploração. Eric teme que seu segredo possa acabar com o caso deles."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"告诉我你想要什么","runtime":114,"tagline":"","homepage":"","overview":"父亲去世后，埃里克·齐默尔曼前往西班牙监督公司的分支机构。在马德里，他爱上了朱迪思，并开始了一段充满探索的激烈的性爱关系。埃里克担心他的秘密可能会结束他们的恋情。\r 改编自梅根·麦克斯韦（Megan Maxwell）的畅销小说《告诉我你想要什么（Tell Me What You Want）》。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"După moartea tatălui său, Eric Zimmerman călătorește în Spania pentru a supraveghea filialele companiei sale. La Madrid, se îndrăgostește de Judith și începe o relație intensă și erotică, plină de explorări. Cu toate acestea, Eric se teme că secretul său ar putea pune capăt relației lor."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Na de dood van zijn vader reist Eric Zimmerman naar Spanje om toezicht te houden op de filialen van zijn bedrijf. In Madrid valt hij voor Judith en gaat hij een intense, erotische relatie vol ontdekkingen aan. Eric vreest echter dat zijn geheim een einde kan maken aan hun affaire."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Проси у меня все, что захочешь","runtime":0,"tagline":"","homepage":"","overview":"После смерти своего отца немецкий бизнесмен Эрик Циммерман отправляется в Испанию, чтобы руководить делегациями своей компании. В центральном офисе в Мадриде он знакомится с Джудит, молодой женщиной, в которую сразу влюбляется. Она поддается влечению, которое оказывает на нее ее босс, и соглашается участвовать в его сексуальных играх, полных фантазий и эротики. Вместе с ним вы узнаете, что у всех нас есть внутренний вуайерист, и что люди делятся на покорных и властных."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Проси у мене все, що захочеш","runtime":0,"tagline":"","homepage":"","overview":"Ерік тяжко переживає втрату батька. Незабаром він змушений їхати до Іспанії, щоб наглядати за філіями своєї компанії. У Мадриді мимоволі починає закохуватись в молоду жінку, вступивши із нею в дуже інтенсивні еротичні стосунки. З плином часу спадкоємець корпорації починає боятися того, що його таємниця може покласти край їхнім відносинам."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Po smrti svého otce odjíždí Eric Zimmerman do Španělska, aby dohlédl na pobočky své společnosti. V Madridu se zamiluje do Judith a naváže s ní intenzivní, erotický vztah plný zkoumání. Eric se však obává, že jeho tajemství může jejich vztah ukončit."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"اطلب منّي ما تريد","runtime":114,"tagline":"","homepage":"","overview":"بعد وفاة والده، يسافر إريك زيمرمان إلى إسبانيا للإشراف على فروع شركته. في مدريد، يقع في حب جوديث ويدخل في علاقة عاطفية حميمة مليئة بالمغامرات. مع ذلك، يخشى إريك أن يُنهي سره علاقتهما."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Питай ме каквото искаш","runtime":0,"tagline":"","homepage":"","overview":"След смъртта на баща си, Ерик Цимърман пътува до Испания, за да наблюдава клоновете на компанията си. В Мадрид той се влюбва в Юдит и започват интензивна, еротична връзка, изпълнена с открития. Въпреки това, Ерик се страхува, че тайна от миналото му може да сложи край на тяхната афера."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Hãy Hỏi Tôi Điều Bạn Muốn","runtime":0,"tagline":"","homepage":"","overview":"Ask Me What You Want (2024) dựa trên tiểu thuyết cùng tên của Megan Maxwell, kể về một câu chuyện tình cảm đầy đam mê, xoáy sâu vào sự hấp dẫn, bí mật và khám phá bản thân. Khi Judith Flores, một thư ký trẻ đầy cá tính, bước vào thế giới của Eric Zimmerman, một doanh nhân quyền lực, mối quan hệ của họ nhanh chóng trở thành một cuộc chơi nguy hiểm giữa cảm xúc và dục vọng."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Après la mort de son père, Eric Zimmerman se rend en Espagne pour superviser les succursales de son entreprise. À Madrid, il tombe amoureux de Judith et s'engage dans une relation intense, érotique et pleine d'exploration. Eric craint que son secret ne mette fin à leur liaison."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Peça-me O Que Quiser","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Sag mir, was du willst","runtime":0,"tagline":"","homepage":"","overview":"Sie ist jung, ehrgeizig und hat ihr Leben fest im Griff – bis sie eines Tages mit einem charmanten Geschäftsmann im Aufzug steckenbleibt. Er ist nicht nur attraktiv und reich, sondern auch ihr neuer Vorgesetzter. Zwischen ihnen entfacht sofort ein unwiderstehliches Knistern. Was als sinnliches Abenteuer beginnt, führt sie schon bald in eine Welt, in der keine Grenzen zu existieren scheinen. Doch je tiefer sie in diese betörende Sphäre eintaucht, desto riskanter wird das Spiel. Die leidenschaftliche Beziehung droht schließlich nicht nur ihren Ruf zu ruinieren, sondern auch ihr bisher geordnetes Leben völlig aus der Bahn zu werfen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"挑逗你的慾望","runtime":0,"tagline":"","homepage":"","overview":"父親去世後，名望顯赫的企業家艾瑞克季默曼前往馬德里視察家族企業，期間邂逅了機智迷人的茱蒂，並瞬間為她傾心，茱蒂無法抗拒艾瑞克的魅力，漸漸陷入他充滿幻想與情慾的遊戲之中，然而，隨著兩人關係加深，茱蒂開始懷疑艾瑞克迷人笑容背後隱藏的祕密，並思索自己究竟願意付出多少代價來揭開那些真相。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"나의 S 파트너","runtime":0,"tagline":"","homepage":"","overview":"주디는 어느 날, 회사의 인수합병을 위해 방문한 억만장자 CEO 에릭과 엘리베이터에 갇히게 된다. 우연히 시작된 치명적인 끌림. 주디는 에릭의 유혹 앞에 흔들리고 만다. 그의 따뜻한 진심에 마음을 연 주디는 결국, 위험하고 달콤한 제안을 받아들인다. 에릭이 이끄는 금기의 세계에 발을 들인 주디. 비밀스러운 만남이 이어질수록, 그녀는 에릭의 숨겨진 진짜 얼굴을 알고 싶어지고, 동시에 자신 안에 잠든 본능까지 깨워가는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"危険なCEO　快楽と秘密のオフィス","runtime":0,"tagline":"","homepage":"","overview":"巨大企業の若きCEOアレックスは、革新的な才能と危ういカリスマで社員を魅了する。新任秘書エマは昇進を餌にした甘い誘いと社内の機密漏洩事件に巻き込まれ、快楽・権力・秘密が交錯するオフィスの闇を暴いていく。任務はやがて心とキャリアを賭けた危険な駆け引きへ。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"}],"reviews_tmdb":[],"recommendations":[{"id":317735,"adult":false,"title":"A","video":false,"overview":"Experimental short by Anna Lajolo and Guido Lombardi.","genre_ids":[],"media_type":"movie","popularity":0.2183,"vote_count":27,"poster_path":"/mFAdbTVkhvYzgQ7tULBzy3LbHlh.jpg","release_date":"1969-06-12","vote_average":5.7,"backdrop_path":null,"original_title":"A","original_language":"it"},{"id":780723,"adult":false,"title":"Q","video":false,"overview":"Seven men and women caught in a strange death game are forced to survive!","genre_ids":[27],"media_type":"movie","popularity":0.2511,"vote_count":33,"poster_path":"/c7eiQsPxIg0ZWIHjUQVgdy3YQCC.jpg","release_date":"2007-03-23","vote_average":6.2,"backdrop_path":null,"original_title":"Q","original_language":"ja"},{"id":1165067,"adult":false,"title":"Cosmic Chaos","video":false,"overview":"Battles in virtual reality, survival in a post-apocalyptic wasteland, a Soviet spaceship giving a distress signal - Fantastic stories created with advanced special effects and passion.","genre_ids":[53,878],"media_type":"movie","popularity":1.5499,"vote_count":50,"poster_path":"/mClzWv7gBqgXfjZXp49Enyoex1v.jpg","release_date":"2023-08-03","vote_average":6,"backdrop_path":"/m2mzlsJjE3UAqeUB5fLUkpWg4Iq.jpg","original_title":"Cosmic Chaos","original_language":"en"},{"id":1165736,"adult":false,"title":"X","video":false,"overview":"","genre_ids":[99],"media_type":"movie","popularity":0.182,"vote_count":21,"poster_path":"/8LdMmzzTsc7sn8QFsviaoNSEhmv.jpg","release_date":"2023-09-01","vote_average":6,"backdrop_path":"/jOIH2q69Gg0TbQJf3k3AxpQuB6K.jpg","original_title":"X","original_language":"zh"},{"id":348237,"adult":false,"title":"F*ggot","video":false,"overview":"This is Arturo's tale, a coming of age story about a boy who tries to find and accept his sexual identity. It takes place in a small town in the state of Zacatecas during the 90's, and explores the stigma the homosexual community lived during the HIV crisis.","genre_ids":[18],"media_type":"movie","popularity":0.2015,"vote_count":24,"poster_path":"/nEYWMhh5y4Fm6v3hVQoQlJ8KLVL.jpg","release_date":"2014-10-21","vote_average":6.563,"backdrop_path":null,"original_title":"P*to","original_language":"es"},{"id":1294931,"adult":false,"title":"Come Into My Life","video":false,"overview":"After a series of romantic and professional disappointments, Eugenia decides to become an influencer in order to put a new spin on her life","genre_ids":[35,10749],"media_type":"movie","popularity":0.3464,"vote_count":19,"poster_path":"/p0zlgGiq4mCNzaKH3Tf112k51p0.jpg","release_date":"2024-07-11","vote_average":7.5,"backdrop_path":"/dQLvepGVFY3V5NehYoG76dfh6vT.jpg","original_title":"Entra En Mi Vida","original_language":"es"},{"id":651536,"adult":false,"title":"Gone","video":false,"overview":"When the detectives won’t believe she was abducted, a woman must do her own investigation to identify the person who kidnapped her.","genre_ids":[10770,53,80],"media_type":"movie","popularity":0.4863,"vote_count":14,"poster_path":"/AkZVpekR1eCDplnsy4811HLnSmR.jpg","release_date":"2019-11-08","vote_average":4.643,"backdrop_path":"/g6vwnZ6EeXhmKj8qe101UjXVzOC.jpg","original_title":"Gone","original_language":"en"},{"id":443359,"adult":false,"title":"Q","video":false,"overview":"This film portraits a woman living in a big city in India, and a six year old girl from nowhere. The girl has a code name DOLL. Their lives had no contact point till getting implicated in an unstoppable mission. Woman, perfectly aware, girl, perfectly unaware. The time bomb of destiny has been started...","genre_ids":[53,18],"media_type":"movie","popularity":0.0214,"vote_count":12,"poster_path":null,"release_date":"2014-02-23","vote_average":4.5,"backdrop_path":null,"original_title":"Q","original_language":"en"},{"id":1233327,"adult":false,"title":"Matka","video":false,"overview":"Set between the years 1958 and 1982, Matka tells the story of Vasu, who rises from poverty to create a powerful gambling empire in India, ultimately leading the nation into a battle with the government. Based on real events, the tale explores themes of love, moral choices, and the consequences of ambition.","genre_ids":[28,80],"media_type":"movie","popularity":0.2395,"vote_count":10,"poster_path":"/1LzHbFk93Lp00ZsqGHPAnAoUJW8.jpg","release_date":"2024-11-14","vote_average":5.2,"backdrop_path":"/kyVcNF6GRthdiT4oZn5XgJtl0F7.jpg","original_title":"మట్కా","original_language":"te"},{"id":1427792,"adult":false,"title":"A.","video":false,"overview":"Having lost her memory, A. could barely recall glimpses of her childhood in Argentina. After her death, her son visits the empty house for the last time. A sensory journey through a house without objects but filled with memory.","genre_ids":[99,18],"media_type":"movie","popularity":0.221,"vote_count":6,"poster_path":"/r0Hqb2529mtXQZWpIjCAHGzD8cp.jpg","release_date":"2025-02-26","vote_average":6.8,"backdrop_path":"/fzhvjT11iGiTTralGks7EVJwVb6.jpg","original_title":"A.","original_language":"ca"},{"id":1217345,"adult":false,"title":"Girl Haunts Boy","video":false,"overview":"Cole, a teen grieving the loss of his dad, forms an unlikely bond with Bea, a ghost. As they navigate life and death, they must break an ancient curse.","genre_ids":[14,10749,35],"media_type":"movie","popularity":1.7398,"vote_count":52,"poster_path":"/6mabVBqKWdGbBKgUz6YK4G6Caws.jpg","release_date":"2024-10-09","vote_average":6.735,"backdrop_path":"/zOz4Dsg2JiplITr4SnPir0SyRIp.jpg","original_title":"Girl Haunts Boy","original_language":"en"},{"id":39405,"adult":false,"title":"U","video":false,"overview":"Since her parents passed away, Princess Mona lives by herself in a castle with two hideous, ghastly characters, Goomi and His Lordship. One day her sobs draw the attention of a unicorn, called U, who wants to comfort and protect Mona for as long as she needs. U becomes Mona's companion, her confidant and her inseparable friend. While Mona grows into a beautiful princess, a group of charming, peaceful and fanciful Yeah-Yeah’s settles in the neighboring forest. They have no particular special powers, yet they soon bring about major changes in everyone's lives, especially in Kulka, the dreamy musician.","genre_ids":[16,14],"media_type":"movie","popularity":1.9544,"vote_count":100,"poster_path":"/fPyDf7cl4NrtjSn5jnmODDF70kS.jpg","release_date":"2006-10-11","vote_average":6.6,"backdrop_path":"/zbrSxpgeNscm06Wz39qa9YP5h9m.jpg","original_title":"U","original_language":"fr"},{"id":1311550,"adult":false,"title":"House of Ga'a","video":false,"overview":"At the height of the Oyo Empire, the ferocious Bashorun Ga'a became more powerful than the kings he enthroned, only to be undone by his own blood.","genre_ids":[28,36],"media_type":"movie","popularity":1.5126,"vote_count":119,"poster_path":"/fVSbkXzeTrNGfMBvZcIFk6fdxK.jpg","release_date":"2024-07-26","vote_average":5.6,"backdrop_path":"/c3rwwFFVbkyEI6wPtpPd9lvovPW.jpg","original_title":"House of Ga'a","original_language":"en"},{"id":34186,"adult":false,"title":"The Ax","video":false,"overview":"Bruno loved his job as a middle manager at a paper company, but optimistically views being laid off as an opportunity. After two years of searching for a comparable position, optimism turns to desperation. His wife works two jobs, and their marriage slowly deteriorates as their hold on the middle class slips away. Bruno concocts a grimly audacious plan to identify and kill his fellow job applicants so that he is the only qualified person left.","genre_ids":[35,80,18,53],"media_type":"movie","popularity":0.6439,"vote_count":212,"poster_path":"/v6upsNV9GWkSn0ODM8hFpvbQNJn.jpg","release_date":"2005-03-02","vote_average":6.92,"backdrop_path":"/8aMGsqLtJ9wfGkFRvGJSm4kUDGU.jpg","original_title":"Le Couperet","original_language":"fr"},{"id":1277988,"adult":false,"title":"Caramelo","video":false,"overview":"After a life-changing diagnosis, a promising chef finds hope and humor with the help of a fur-midable dog friend.","genre_ids":[35,18],"media_type":"movie","popularity":4.3403,"vote_count":252,"poster_path":"/c4ZEAah5a01cu27w7vT2IAoFogk.jpg","release_date":"2025-10-07","vote_average":7.718,"backdrop_path":"/wBV11KLQcp5pyxl8JW1lBaDshqr.jpg","original_title":"Caramelo","original_language":"pt"},{"id":1000075,"adult":false,"title":"The Price of Money: A Largo Winch Adventure","video":false,"overview":"Largo Winch, devastated by the kidnapping of his son, realizes that if he finds those responsible for his bankruptcy, maybe he'll see his son again.","genre_ids":[28,12,53],"media_type":"movie","popularity":2.6394,"vote_count":270,"poster_path":"/myS41ZUmFvslkT8LeD2irAKxyrf.jpg","release_date":"2024-07-31","vote_average":5.902,"backdrop_path":"/fZMgyDbtF1T3r9EHN55hzXBU4eY.jpg","original_title":"Largo Winch : Le Prix de l'argent","original_language":"fr"},{"id":787787,"adult":false,"title":"Anything's Possible","video":false,"overview":"Anything’s Possible is a delightfully modern Gen Z coming-of-age story that follows Kelsa, a confident high school girl who is trans, as she navigates through senior year. When her classmate Khal gets a crush on her, he musters up the courage to ask her out, despite the drama he knows it could cause. What transpires is a romance that showcases the joy, tenderness, and pain of young love.","genre_ids":[10749,35,18],"media_type":"movie","popularity":0.6769,"vote_count":85,"poster_path":"/aLeswI1zxf2xN5iIdcJpqx9XEnX.jpg","release_date":"2022-07-14","vote_average":5.718,"backdrop_path":"/uc427uPu7q12bT27IkhZ4aPPyjB.jpg","original_title":"Anything's Possible","original_language":"en"},{"id":1087421,"adult":false,"title":"I Hate Summer","video":false,"overview":"Due to a rental mistake, three families are forced to share a house in the Canary Islands, leading to chaotic and humorous situations 