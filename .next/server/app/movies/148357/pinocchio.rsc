/1D8XdYZ3JCjHR3kcCkrYCG5CNg5.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/nM0rBV35ESYTDF4KWXZsN8vTuw7.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1620,"height":911,"file_path":"/8xcvoGexJHC6aQwq1M6v3wpOWXt.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/tIRPWuIMz2G8hXsUyStEeiOHqlc.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1600,"height":900,"file_path":"/2vP6JqRrpmJj3Mk7uSHbQs7wZ8v.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/y9qCHofzl7ip37njcrm7ldZIG9Q.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:16:28.132+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":110,"tagline":"","homepage":"","overview":"Roberto Benigni adapts the classic children's tale by Carlo Collodi for the big-budget family-oriented comedy Pinocchio."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Roberto Benigni's Pinocchio","runtime":108,"tagline":"","homepage":"","overview":"Italienische Komödie von und mit Roberto Benigni, der die hölzerne Puppe Pinocchio spielt. Pinocchio hat eine lange Nase, die ihm immer wächst, wenn er schwindelt. Sein größter Wunsch ist es, ein lebendiger Junge werden."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Pinocchio","runtime":105,"tagline":"","homepage":"","overview":"Il falegname Geppetto decide di fare un burattino usando un ceppo di legno e di chiamarlo Pinocchio. Questi, magicamente, è in grado di muoversi e di parlare come un vero bambino. Nella speranza di avviarlo all'istruzione, Geppetto, vendendo la sua casacca, gli compra un abbecedario, ma il birbantello lo rivende per vedere uno spettacolo di burattini. Qui il terribile capo della compagnia Mangiafuoco, lasciatosi impietosire dagli sgangherati racconti di Pinocchio, gli regala cinque monete d'oro. Pinocchio, vittima della sua ingenuità, viene poi adescato da una coppia di furfanti, il Gatto e la Volpe, decisi a truffarlo per impossessarsi del suo denaro. Alcune disavventure porteranno Pinocchio fino al Paese dei Balocchi in compagnia di Lucignolo, suo nuovo amico, ed infine nel ventre di un pescecane, ove con grande sorpresa ritroverà suo padre. Fuggito dal corpo dell'animale, con l'aiuto della Fata Turchina si trasformerà finalmente in un bambino vero, generoso e volenteroso."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Pinocho","runtime":105,"tagline":"","homepage":"","overview":"Gepetto, quien siempre ha deseado tener un hijo, esculpe una marioneta utilizando un tronco de madera con propiedades mágicas. Luego, durante la noche, una hada madrina da vida al muñeco que, de esta manera, se convierte en Pinocho, un niño desobediente que baila, canta y ríe. El hada madrina ofrece a Pinocho la oportunidad de convertirse en un niño de verdad si promete ser un muñeco bueno, pero Pinocho es demasiado travieso... (FILMAFFINITY)"},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":108,"tagline":"","homepage":"","overview":"Un pantin de bois nommé Pinocchio, créé par Gepetto, un vieux menuisier toscan, s'anime par la magie de la Fée Bleue. Devenu un vrai petit garçon, il fait l'apprentissage de la vie.  Au lieu d'aller à l'école, Pinocchio se rend au théâtre de marionnettes de Mangiafuoco. Sans le savoir, il s'apprête à vivre de grandes aventures dans de merveilleux endroits comme le Pays des Jouets, et, à rencontrer de drôles de personnages comme Lucignolo, un adolescent déluré, ou encore un chat et un renard - deux fripouilles - qui vont lui donner du fil à retordre..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Pinóquio","runtime":0,"tagline":"","homepage":"","overview":"Gepeto (Carlo Giuffrè), um solitário carpinteiro, decide fazer um boneco de madeira para lhe fazer companhia. Com pena da solidão de Gepeto, a Fada Azul (Nicoletta Braschi) decide satisfazer seu desejo e dá vida a Pinóquio (Roberto Benigni), o boneco de madeira. Porém logo Pinóquio busca se tornar um garoto de verdade, o que faz com que ele se envolva em diversas confusões."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Пиноккио","runtime":0,"tagline":"","homepage":"","overview":"Сказка Карло Коллоди одна из самых смешных в мировой литературе. Деревянный Пиноккио в исполнении мастера комедийного жанра Роберто Бениньи не оставит равнодушным никого!  Его герой все такой же несносный, доверчивый, остроумный, упрямый и добрый. А фильм, снятый с большим размахом, фантазией и душой, населен живописными существами, говорящими животными и многочисленными сказочными персонажами!"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Pinokkió","runtime":0,"tagline":"","homepage":"","overview":"Egyszer volt, hol nem volt, volt egyszer egy magányos fafaragó, akit Dzsepettó-nak hívtak. Egy csillagfényes éjszakán, a csodák éjszakáján egy tündér életre kelti az öregember fabábuját, Pinokkiót, és ezzel fantasztikus kalandok egész sora veszi kezdetét, amelyek próbára teszik a kis fickó bátorságát, hűségét és őszinteségét - azokat az erényeket, amelyeket meg kell tanulnia ahhoz, hogy igazi hús-vér kisfiú váljon belle. Bölcs barátja, Tücsök Tihamér hiába próbálja figyelmeztetni, Pinokkió csetlik-botlik, és egyik butaságot követi el a másik után."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"פינוקיו","runtime":0,"tagline":"","homepage":"","overview":"רוברטו בניני, זוכה פעמיים פרס האקדמיה, מביא אל המסכים את גירסתו ל\"פינוקיו\", גרסה אשר כתב, ביים ואשר בה גם כיכב. ילד-העץ פינוקיו, אשר נוצר ע\"י ג'פטו (קרלו גויפר), מתאווה להיות ילד בשר-ודם. סקרנותו הרבה מערבת אותו בכל מיני הרפתקאות, אשר בכללם גם פגישה עם הפייה הכחולה (ניקולטה בראצ'י)."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":106,"tagline":"Ve světě pohádek je všechno možné","homepage":"","overview":"Klasický příběh o tom, jak se dřevěná loutka stala živoucí bytostí. Přes všemožnou pomoc dobré a krásné Modré víly a lásku svého otce Gepetta, vede neobvyklá povaha a vidění světa Pinocchia z jednoho neuvěřitelného dobrodružství do druhého."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Пинокио","runtime":106,"tagline":"","homepage":"","overview":"Голямо парче дърво се озовава на прага на възрастния дърводелец Джепето и той решава да превърне цепеницата в кукла - така се ражда Пинокио. Дървената кукла с издайнически нос оживява и започва поредица от зашеметяващи приключения."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":108,"tagline":"","homepage":"","overview":"De film vertelt het klassieke verhaal van een houten pop die tot leven komt, en van zijn pogingen om een echt jongetje te worden. Ondanks de hulp van de Blauwe Fee en de liefde van zijn vader Gepetto raakt Pinocchio van het ene avontuur in het andere terecht."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Піноккіо","runtime":0,"tagline":"","homepage":"","overview":"Класична італійська казка про дерев'яну іграшку Піннокіо, яка мріє стати справжнім хлопчиком."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"木偶奇遇记","runtime":108,"tagline":"","homepage":"","overview":"盖比特（Carlo Giuffrè 饰）是一位经验丰富的老木匠，在他漫长的一生中，创作了无数鬼斧神工般的出色艺术品，但匹诺曹（罗伯托·贝尼尼 Roberto Benigni 饰），这个活灵活现的木偶男孩，则凝聚了他毕生全部的心血与期望。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"피노키오","runtime":0,"tagline":"","homepage":"","overview":""},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Pinóquio","runtime":108,"tagline":"","homepage":"","overview":"Gepeto (Carlo Giuffrè), um solitário carpinteiro, decide fazer um boneco de madeira para lhe fazer companhia. Com pena da solidão de Gepeto, a Fada Azul (Nicoletta Braschi) decide satisfazer seu desejo e dá vida a Pinóquio (Roberto Benigni), o boneco de madeira. Porém logo Pinóquio busca se tornar um garoto de verdade, o que faz com que ele se envolva em diversas confusões."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"پینوکیو","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Pinokyo","runtime":108,"tagline":"","homepage":"","overview":"hikaye, ihtiyar kukla ustası Geppetto ile Pinokyo arasındaki ilişkisi çevresinde gelişiyor. Tahtadan yapılmış cansız kukla Pinokyo, mucizevi bir şekilde canlanıyor ve ne zaman bir yalan söylese burnu uzuyor. Perisinin yol göstermesine ve Geppetto ustanın sevgisine rağmen, meraklılığı yüzünden Pinokyo’nun başı bir türlü beladan kurtulmuyor. Hiç çocuğu olmamış Geppetto, Pinokyo’nun ‘babası’ oluyor ve ikisi arasında özel bir bağ oluşuyor. Ama bu bağ, Pinokyo’yu ele geçirerek onu karanlık emellerine alet etmek isteyen kötü niyetli Lorenzini yüzünden tehlikeye giriyor. Ve ne yazık ki, Lorenzini, her zaman istediğini elde ediyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Pinokio","runtime":108,"tagline":"","homepage":"","overview":"Bajka o chłopcu z drewna, który ucieka od swego 'ojca' stolarza i przeżywa szereg przygód, niedoli i niebezpieczeństw, zanim stanie się przykładnym, kochającym synem i wróci do domu."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"木偶奇遇記","runtime":0,"tagline":"","homepage":"","overview":"蓋比特（Carlo Giuffrè 飾）是一位經驗豐富的老木匠，在他漫長的一生中，創作了無數鬼斧神工般的出色藝術品，但匹諾曹（羅伯託·貝尼尼 Roberto Benigni 飾），這個活靈活現的木偶男孩，則凝聚了他畢生全部的心血與期望。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":10846,"adult":false,"title":"The Tiger and the Snow","video":false,"overview":"Love and injury in time of war. Attilio de Giovanni teaches poetry in Italy. He has a romantic soul, and women love him. But he is in love with Vittoria, and the love is unrequited. Every night he dreams of marrying her, in his boxer shorts and t-shirt, as Tom Waits sings. Vittoria travels to Iraq with her friend, Fuad, a poet; they are there with the second Gulf War breaks out. Vittoria is injured. Attilio must get to her side, and then, as war rages around him, he must find her the medical care she needs. In war, does love conquer all?","genre_ids":[35,18,10749],"media_type":"movie","popularity":0.5584,"vote_count":489,"poster_path":"/18ZaN20XRwG2dOJYuo8tvWdDMCR.jpg","release_date":"2005-10-14","vote_average":6.748,"backdrop_path":"/eoYqlqSKE381giHHxVafHa5eUDi.jpg","original_title":"La tigre e la neve","original_language":"it"},{"id":58451,"adult":false,"title":"The Adventures of Pinocchio","video":false,"overview":"Mastro Geppetto is a poor carpenter with no wife and no children. The man is very lonely, and after trading a piece of wood with his colleague Mastro Ciliegia, decides to build himself a puppet to keep him company.","genre_ids":[14,18,10751,35],"media_type":"movie","popularity":0.6129,"vote_count":322,"poster_path":"/xjoYc9umKoZHTVr2B0uBbn3bCXj.jpg","release_date":"1972-12-21","vote_average":7.516,"backdrop_path":"/1gAIPtpuHSYWJ6PjF8r9jOJdSmG.jpg","original_title":"Le avventure di Pinocchio","original_language":"it"},{"id":43645,"adult":false,"title":"The Little Devil","video":false,"overview":"Father Maurice, a priest living in a residential college for priests in Rome, is called out one day to \"exorcise\" the devil from someone. The devil turns out to be in the form of a fun-loving man called Giuditta. What Father Maurice doesn't know is that this type of devil will turn his life around.","genre_ids":[35,14],"media_type":"movie","popularity":0.5714,"vote_count":429,"poster_path":"/ck1dLdsmjwYljlnwQRNj4XhBa55.jpg","release_date":"1988-07-01","vote_average":6.705,"backdrop_path":"/cpoCmsmKGsqxwSRPWFKegZbmoQz.jpg","original_title":"Il piccolo diavolo","original_language":"it"},{"id":12776,"adult":false,"title":"Johnny Stecchino","video":false,"overview":"Good hearted but not very wordly-wise, Dante is happy driving the school bus for a group of mentally handicapped children, while feeling he is somehow missing out on life and love. So he is very excited when after nearly being knocked down by her car he meets Maria, who seems immediately enamoured of him. He is soon invited to her sumptuous Palermo villa, little suspecting that this is part of a plot. He bears an amazing likeness to Maria's stool-pigeon gangster husband and it would be convenient for them if the mobster, in the shape of Dante, was seen to be dead and buried.","genre_ids":[35],"media_type":"movie","popularity":0.8284,"vote_count":1059,"poster_path":"/5scWsRsH5MUJEgXB52w0fM6I2gM.jpg","release_date":"1991-10-24","vote_average":7.337,"backdrop_path":"/aKNctt6HWvN152JQUf7JrbVxuQg.jpg","original_title":"Johnny Stecchino","original_language":"it"},{"id":53412,"adult":false,"title":"A Night in the Show","video":false,"overview":"Mr. Pest tries several theatre seats before winding up in front in a fight with the conductor. He is thrown out. In the lobby he pushes a fat lady into a fountain and returns to sit down by Edna. Mr. Rowdy, in the gallery, pours beer down on Mr. Pest and Edna. He attacks patrons, a harem dancer, the singers Dot and Dash, and a fire-eater.","genre_ids":[35],"media_type":"movie","popularity":0.2358,"vote_count":91,"poster_path":"/j9aFYk99nbwPlZ3hj1FJWMyPfoa.jpg","release_date":"1915-11-20","vote_average":6.176,"backdrop_path":"/n5oOMwzemLd81OARilBWDh2XR9A.jpg","original_title":"A Night in the Show","original_language":"en"},{"id":186137,"adult":false,"title":"Le ali della vita","video":false,"overview":"The end of the 1950s: Rosanna returns as a music teacher to the claustrophobic confines of the convent boarding school from which she escaped as a young girl. Her happy, understanding ways, unconventional teaching methods and deep love of music soon win her the hearts of her girl pupils. Vithold, a nice young doctor, is also fascinated by Rosanna and gradually manages to convince her of his deep feelings for her. Rosanna encounters rejection and hatred from Alberta, the Mother Superior, who has a deep belief in strict discipline and order, as well as from her close associate Sister Federica, who is severe to the point of inhumanity.","genre_ids":[],"media_type":"movie","popularity":0.2995,"vote_count":28,"poster_path":"/30H9vIvjvXhAtHMkQbRJwkXHW2e.jpg","release_date":"2000-03-21","vote_average":7.4,"backdrop_path":"/ydALCe5kg1SWAPYpaN7DDBmIN1E.jpg","original_title":"Le ali della vita","original_language":"en"},{"id":64711,"adult":false,"title":"Long-Haired Hare","video":false,"overview":"Bugs Bunny vs. a famous opera singer at the Hollywood Bowl.","genre_ids":[16,35],"media_type":"movie","popularity":0.3501,"vote_count":134,"poster_path":"/2d0PCqbNnaeF8ivonyovzWERXRZ.jpg","release_date":"1949-06-25","vote_average":7.078,"backdrop_path":"/q3o4PHBEZALcrq6dAqBk3klh2NP.jpg","original_title":"Long-Haired Hare","original_language":"en"},{"id":105410,"adult":false,"title":"Two of a Kind","video":false,"overview":"Italian comedy in two episodes starring a house painter who emigrated to Switzerland who pretends to be a millionaire and an employee on holiday in Kenya, the victim of catastrophic misadventures.","genre_ids":[35],"media_type":"movie","popularity":0.3422,"vote_count":106,"poster_path":"/s4aiPMLsrjD2GIq6OxZ0J0RosYp.jpg","release_date":"1983-04-14","vote_average":5.637,"backdrop_path":"/btRmrrXmSzWcFkLufNeF1n7weXZ.jpg","original_title":"Pappa e ciccia","original_language":"it"},{"id":41481,"adult":false,"title":"Night Bus","video":false,"overview":"Valerio Mastandrea is Franz, a night bus driver on the airport route who owes a lot of money from poker debts. He's stumbled upon by the variously named Leila, a thief who has accidentally become wrapped up in a secretive blackmail deal involving the President. As the film unfolds, a secret war between factions of the Security Services, a series of confusions among the various criminal fraternities whose activites have been touched upon by the deal, and Leila's past all complicate the situation.","genre_ids":[35,80,18],"media_type":"movie","popularity":0.2943,"vote_count":70,"poster_path":"/mZfsmSTKvKyFzOBsRmJSnQywE3U.jpg","release_date":"2007-05-11","vote_average":6.229,"backdrop_path":"/yooJLeARyKmDY4sHq92GVfvYSbk.jpg","original_title":"Notturno Bus","original_language":"it"},{"id":507671,"adult":false,"title":"La mossa del cavallo","video":false,"overview":"Montelusa, Sicily, Italy, 1877. Giovanni Bovara, the new chief inspector of the mills, is charged with collecting a severe tax. Sicilian by birth, but Ligurian by adoption, he reasons and speaks as a man of northern Italy and does not understand the dynamics of the law of silence that regulate the Sicilian land, so his intransigence immediately gives him several enemies…","genre_ids":[18,53,10770],"media_type":"movie","popularity":0.2229,"vote_count":44,"poster_path":"/pRhJ7TLCPmVZYPu9mWaIOaufCyh.jpg","release_date":"2018-02-26","vote_average":7.591,"backdrop_path":"/r1D0uM1BDv45jXxuPMvGbwXsvNT.jpg","original_title":"La mossa del cavallo","original_language":"it"},{"id":70088,"adult":false,"title":"You Upset Me","video":false,"overview":"The first movie directed by Roberto Benigni in four surreal short stories: \"Durante Cristo\" (During Christ), \"Angelo\" (Angel), , \"In Banca\" (At the Bank) and \"I Due Militi\" (The Two Soldiers). An excursus in Benigni's satirical views on man, religion and society.","genre_ids":[35],"media_type":"movie","popularity":0.4518,"vote_count":67,"poster_path":"/6Sk2R4fwjqDUoYZR9N4YqYZzpjx.jpg","release_date":"1983-02-12","vote_average":6.604,"backdrop_path":"/fXtbr0Dm438ScA44eSAmGP3HiPs.jpg","original_title":"Tu mi turbi","original_language":"it"},{"id":33821,"adult":false,"title":"Pinocchio","video":false,"overview":"The enchanted story of Pinocchio.","genre_ids":[12,18,14],"media_type":"movie","popularity":0.645,"vote_count":101,"poster_path":"/gOiT5YjhS7nQGoPOhaEaaEwjBxS.jpg","release_date":"2009-11-01","vote_average":6,"backdrop_path":"/hvZmzx6ekvbPQo8F4bcARwS91FU.jpg","original_title":"Pinocchio","original_language":"en"},{"id":103122,"adult":false,"title":"Desirable Teacher","video":false,"overview":"In a school where the meeting seems more complete sampling of teachers and professors stupid airhead, there is the class of Peter, repeating in life, which is the \"grandfather\" to the far more young companions concerning jokes and vulgarity. Even outside the school walls, in the family or in the streets of the village where he lives, Peter is not far behind and his antics continue to freewheel.","genre_ids":[35],"media_type":"movie","popularity":0.6005,"vote_count":93,"poster_path":"/r7Pyv6f0r2jgnKb2nFR2jWLIUBW.jpg","release_date":"1981-09-19","vote_average":5.597,"backdrop_path":"/spS3mhiBlhXSXPlfPf5dptTYPaI.jpg","original_title":"Pierino contro tutti","original_language":"it"},{"id":18503,"adult":false,"title":"Caterina in the Big City","video":false,"overview":"When her social-climbing father is relocated from a one-horse town to his native Rome, 12-year-old Caterina enrolls in his old school, finding herself adrift in an environment where eighth-graders form friendships based on social class and their parents' political affiliations.","genre_ids":[35,18],"media_type":"movie","popularity":0.5432,"vote_count":265,"poster_path":"/20YWJFpf42UxcGUgXimyLrP6A5E.jpg","release_date":"2003-10-24","vote_average":6.534,"backdrop_path":"/z2nW9qeIYThKTyDll86v1A6Lwv.jpg","original_title":"Caterina va in città","original_language":"it"},{"id":121286,"adult":false,"title":"Buona giornata","video":false,"overview":"A common day in the actual Italy, narrated by the different stories of seven different people, it's the starting point for an overview to the 21st century's italian society, among corrupt politicians, unfaithful husbands, hardcore soccer fans and dishonest businessmen.","genre_ids":[35],"media_type":"movie","popularity":0.33,"vote_count":158,"poster_path":"/stryeFI6GpYc0YByEyVpLra0b5R.jpg","release_date":"2012-03-30","vote_average":4.956,"backdrop_path":"/bV3vwuijGmC393xf7koW0YiBgoO.jpg","original_title":"Buona giornata","original_language":"it"},{"id":59050,"adult":false,"title":"The Voice of the Moon","video":false,"overview":"Odd couple Ivo Salvini, recently released from a mental asylum, and former prefect Gonnella wander through the countryside and discover a dystopia made of television commercials, beauty pageants, rock music, Catholicism, and pagan rituals.","genre_ids":[12,35,14],"media_type":"movie","popularity":0.3381,"vote_count":136,"poster_path":"/1E9bSjMK72pqYvpPioFuQd3IUBx.jpg","release_date":"1990-03-05","vote_average":6.706,"backdrop_path":"/cq6So4kDrMRQQS284qLxrTwy69d.jpg","original_title":"La voce della luna","original_language":"it"},{"id":567738,"adult":false,"title":"American Hangman","video":false,"overview":"An unidentified man posts a live feed on social media showing that he has kidnapped two strangers and intends to kill one before the day is out. His intention is to hold a capital 'trial' online. As the authorities recognize what's happening, it becomes apparent that the online public is going to act as judge and jury.","genre_ids":[53],"media_type":"movie","popularity":0.3263,"vote_count":158,"poster_path":"/xKoXpgqEk8RSezV05oRDCZP9fhT.jpg","release_date":"2019-01-04","vote_average":6.016,"backdrop_path":"/cuUj9ybfVZssvhvzu7IK0arbcGJ.jpg","original_title":"American Hangman","original_language":"en"},{"id":159704,"adult":false,"title":"The Cave of the Golden Rose","video":false,"overview":"After a queen's tragic death, the king abandons his newborn daughter in a cave, but a witch saves her. Years later, the tomboy princess must confront and ultimately falls in love with the enemy king.","genre_ids":[12,10751,14,10749],"media_type":"movie","popularity":0.4778,"vote_count":160,"poster_path":"/6oZjPqEp9KUxxgyHNZuuGvVxEOq.jpg","release_date":"1991-12-22","vote_average":6.4,"backdrop_path":"/5OSmuOor2OK0eXDLJovCkFMtZLL.jpg","original_title":"Fantaghirò","original_language":"it"},{"id":348390,"adult":false,"title":"Confirmation","video":false,"overview":"Judge Clarence Thomas' nomination to the United States' Supreme Court is called into question when former colleague, Anita Hill, testifies that he had sexually harassed her.","genre_ids":[18,36,10770],"media_type":"movie","popularity":0.6356,"vote_count":152,"poster_path":"/9lxg4KidKhRAMupBYvgdHxAnxKE.jpg","release_date":"2016-04-16","vote_average":6.9,"backdrop_path":"/oJuMZHOjmm9CSNIqDPGgKNIHXh6.jpg","original_title":"Confirmation","original_language":"en"},{"id":29743,"adult":false,"title":"Attila Scourge of God","video":false,"overview":"The misadventures of Attila and his band of barbarians as they take up arms against the Roman Empire in their native Milano","genre_ids":[35],"media_type":"movie","popularity":0.4518,"vote_count":235,"poster_path":"/ecizJo3j1PPvLBMhl3thYk82rXK.jpg","relea