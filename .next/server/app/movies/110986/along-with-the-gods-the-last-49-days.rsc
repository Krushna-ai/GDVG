Vn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":9,"provider_name":"Amazon Prime Video","display_priority":5},{"logo_path":"/jCgWMxqGaq0h0VOxyJPfQdTqmii.jpg","provider_id":514,"provider_name":"AsianCrush","display_priority":118},{"logo_path":"/pPoqVHcko7XoCRrPus4boDW90uM.jpg","provider_id":503,"provider_name":"Hi-YAH","display_priority":122},{"logo_path":"/8aBqoNeGGr0oSA85iopgNZUOTOc.jpg","provider_id":2100,"provider_name":"Amazon Prime Video with Ads","display_priority":204},{"logo_path":"/ni2JXG9zznS4RYIGmeyBap1KwTD.jpg","provider_id":2367,"provider_name":"Midnight Pulp Amazon Channel","display_priority":241},{"logo_path":"/aysFX0644QGN9wQghp46qn08N0d.jpg","provider_id":2403,"provider_name":"Hi-YAH Amazon Channel","display_priority":259}]},"UY":{"link":"https://www.themoviedb.org/movie/518068/watch?locale=UY","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0},{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1}]},"VE":{"buy":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3}],"link":"https://www.themoviedb.org/movie/518068/watch?locale=VE","rent":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3}],"flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0},{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":2}]},"YE":{"link":"https://www.themoviedb.org/movie/518068/watch?locale=YE","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZA":{"link":"https://www.themoviedb.org/movie/518068/watch?locale=ZA","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZM":{"link":"https://www.themoviedb.org/movie/518068/watch?locale=ZM","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZW":{"link":"https://www.themoviedb.org/movie/518068/watch?locale=ZW","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":4}]}}},"wikidata_id":"Q54803694","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-20T21:53:51.070789+00:00","region":null,"main_poster":null,"images":null,"enriched_at":"2026-04-21T07:52:41.918+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Along with the Gods: The Last 49 Days","runtime":141,"tagline":"Unveiling millennium-old secrets.","homepage":"","overview":"As the deceased soul Ja-hong and his three afterlife guardians prepare for their remaining trials for reincarnation, the guardians soon come face to face with the truth of their tragic time on Earth 1,000 years earlier."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"신과함께-인과 연","runtime":141,"tagline":"이승과 저승, 현재와 과거를 오가는 천 년의 비밀이 밝혀진다","homepage":"","overview":"천 년 동안 48명의 망자를 환생시킨 저승 삼차사, 한 명만 더 환생시키면 그들도 새로운 삶을 얻을 수 있다. 하지만 강림은 원귀였던 수홍을 자신들의 마지막 귀인으로 정한다. 저승법 상 원귀는 소멸되어야하나 염라대왕은 새로운 조건을 내걸며 강림의 제안을 수락한다. 염라의 조건은 성주신이 버티고 있어 저승 차사들이 가는 족족 실패하는 허춘삼 노인을 수홍의 재판이 끝나기 전까지 저승으로 데려오는 것. 허춘삼을 데리러 이승으로 내려간 해원맥과 덕춘, 하지만 성주신의 막강한 힘 앞에 속수무책으로 당하기만 하는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"與神同行：終極審判","runtime":141,"tagline":"","homepage":"","overview":"地獄三使者(河正宇、朱智勛、金香起 飾）引渡千年最後一個貴人金秀鴻(金東旭 飾)展開七七四十九天審判，準備四人一起投胎轉世之際，鎮守家宅的成造神(馬東石 飾)為搶救爺爺亡魂，不惜挑戰一切規則，翻轉人間，觸怒了閻羅王(李政宰 飾)。地獄三使者為了重整人間秩序，一方面帶領秀鴻繼續地獄審判；另一方面於人間與成造神正面交鋒﹗陰間與人間翻天覆地，意外驚醒了所有人的前世記憶！因果迴旋之下，各大神祇將在49日狹路重逢，迎戰終極審判……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"与神同行2：因与缘","runtime":0,"tagline":"","homepage":"","overview":"三位阴间使者江林（河正宇 饰）、解怨脉（朱智勋 饰）、德春（金香起 饰）即将带领第49位「贵人」金秀鸿（金东旭 饰）进行地狱审判，他们同时发现人间有一位家神（马东锡 饰），试图把早该阳寿已尽的老人强留人间。阴间使者为了带走该名老人，开始与家神展开激烈决斗，而在这个过程之中，三位阴间使者千年以前的前世之谜也将被一一揭开…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"與神同行：最終審判","runtime":142,"tagline":"千年謎團 即將揭曉","homepage":"","overview":"三位陰間使者即將帶領第49位「貴人」金秀鴻進行地獄審判，他們同時發現人間有一位家神，試圖把早該陽壽已盡的老人強留人間。陰間使者為了帶走該名老人，開始與家神展開激烈決鬥，而在這個過程之中，三位陰間使者千年以前的前世之謎也將被一一揭開…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Along with the Gods : The last 49 Days","runtime":141,"tagline":"","homepage":"","overview":"Les anges de la mort Kang-rim, Won-maek et Deok-choon sont sur le point de prendre part au procès de Soo-hong. Les trois anges de la mort rencontrent le Dieu de la Maison. Il se souvient de leur passé qui remonte à plus de 1000 ans. Voyageant entre ce monde, l'autre monde et le passé, les anges de la mort essaient de découvrir ce qui les lie."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"С Богами: Последние 49 дней","runtime":0,"tagline":"","homepage":"","overview":"Бывший мстительный призрак Ким Су-хон предстаёт перед королём Подземного мира, и ангел смерти Кан-ним просит для него прохождение обычной процедуры — он уверен, что сможет убедить судей в невиновности своего подопечного. Король соглашается, но ставит условия: в течение 49 дней ангелы должны вознести душу старика Хо, чьё земное время давно истекло, и доказать невиновность Су-хона. Душу защищает Домовой, который мало того, что регулярно выписывает тумаков пришедшим за ней, так ещё и проявился перед дедом и его малолетним внуком и помогает им по хозяйству. При ближайшем знакомстве с Домовым ангелы выясняют, что тот помнит подробности их жизней и связь друг с другом тысячелетней давности."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"Tanrı ile Günah ve Cezaya 2 : Son 49 gün","runtime":142,"tagline":"","homepage":"","overview":"Üç ölüm meleği  itfaiyeci Ja-hong'un reenkarne olmasından sonra, 49. ruhları Ja-hong'un kardeşi Kim Soo-hong'a yeraltı dünyasında duruşmaları için rehberlik edeceklerdir. Üç ölüm meleği duruşmalara hazırlanırken 1000 yıl önce Dünya'da yaşadıkları trajik zamanların gerçeğiyle de yüzleşirler."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Ανάμεσα στους Θεούς: Οι Τελευταίες 49 Μέρες","runtime":0,"tagline":"","homepage":"","overview":"Στη μετά θάνατον ζωή, ένας θεματοφύλακας βοηθάει έναν άνθρωπο στις δοκιμασίες του, ενώ οι δύο συνάδελφοί του βοηθούν έναν πρώην φύλακα στη γη.."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Среща с Боговете 2: Последните 49 дни","runtime":142,"tagline":"","homepage":"","overview":"Историята на тримата Пазители от Отвъдното продължава. Този път те се опитват да оневинят братът на пожарникаря Ким, сержант Ким Сухон.Историята придобива неочакван обрат, когато пазителите започват да връщат спомените от последното си прераждане като хора отпреди едно хилядолетие.\r \"Всички хора живеят с определени грехове и само единици намират в себе си сили да простят. И само част от тези единици действително се разкайват и получават опрощение.\"\r Йомра, върховно божество"},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Заједно са боговима: последњих 49 дана","runtime":0,"tagline":"","homepage":"","overview":"Филм прати путовање 3 оноземаљских чувара и Су-хонг-а, док путују кроз њихово 49. суђење, како би стекли своје реинкарнације, и како се чуварима полако враћају заборављена сећања кроз Божји дом у живом свету."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"ฝ่า 7 นรกไปกับพระเจ้า 2","runtime":0,"tagline":"","homepage":"","overview":"การผจญภัยครั้งใหม่ของเหล่ายมทูตทั้ง 3 คือ คังลิม (ฮา จองอู), เฮ วอนเมก (จู จีฮุน), ดักชุน (คิม ฮยางกี) ที่เลือกจะพาวิญญาอาฆาตอย่าง คิม ซูฮง (คิม ดงอุก) เข้าสู่กระบวนการตัดสินว่าแท้จริงแล้ว ซูฮง เป็นวิญญาณบริสุทธิ์ พร้อมทั้งเผยปริศนาชวนตื่นตะลึง กับอดีตชาติพันปีของทีมยมทูต ที่มีเพียงเทพนอกรีตอย่าง ซอง จูชิน (มา ดงซอก) เท่านั้น ที่กุมเรื่องราวความลับเหล่านั้นเอาไว้"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Along With the Gods: The Last 49 Days","runtime":141,"tagline":"O passado dos guardiões na Terra será revelado!","homepage":"","overview":"Segue a jornada de 3 Guardiões da Vida após a morte e Su-hong em sua jornada através de sua 49ª tentativa para ganhar suas reencarnações e como os Guardiões lentamente recuperam suas memórias esquecidas através do Deus da Casa no mundo dos vivos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Entre Os Deuses - Os Últimos 49 Dias","runtime":142,"tagline":"","homepage":"","overview":"Na vida após a morte, um guardião ajuda um homem nas suas provações, enquanto os seus dois colegas ajudam um ex-guardião na Terra."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Junto a los Dioses 2: Los Últimos 49 Días","runtime":141,"tagline":"","homepage":"","overview":"La continuación de Junto a los Dioses: Los dos mundos. Su-Hong y sus tres guardianes del más allá viajan a través de los siete infiernos para conseguir reencarnarse. Mientras, un dios desafía todas las reglas para ayudar a gente común en el mundo de los vivos."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Junto a los dioses: Los últimos 49 días","runtime":142,"tagline":"","homepage":"","overview":"La continuación de \"Along with the Gods: The Two Worlds\" no se hace de rogar. Aquí, Su-Hong y sus tres guardianes del más allá viajan a través de los siete infiernos para conseguir reencarnarse. Mientras, un dios desafía todas las reglas para ayudar a gente común en el mundo de los vivos."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Kartu su dievais: Paskutinės 49 dienos","runtime":0,"tagline":"","homepage":"","overview":"Istorija prasideda nuo bebaimių pomirtinio gyvenimo palydovų - Saugotojų, kurie ruošiasi naujam teismo procesui, 49-ajai lemiamai sielai - Suhongui, dorybių paragono broliui, kuris tapo kerštinga siela Dviejuose Pasauliuose.\r Karalius Jeomras nenoriai pasižada reinkarnuoti Suhongą kaip ir Havonmaką, Deokčiūną ir jų vadą Ganglimą po tūkstantmetį trūkusių kančių tik tuomet, jei pastarieji du pasiims iš Žemės ten užsibuvusį senelį, o Ganlimas liks spręsti Suhongo bylos vienas."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Singwa Hamkke: Ingwa Yeon","runtime":141,"tagline":"","homepage":"","overview":"De overleden ziel Su-hong en zijn drie levensechte beschermers zien de resterende beproevingen onder ogen om hun reïncarnatie te verkrijgen. Ondertussen komen de bewakers oog in oog met de begraven waarheid van hun tragische tijd op aarde. Dit culmineert tot een intens gevecht met een kwaadaardige god."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Thử Thách Thần Chết 2: 49 Ngày Cuối Cùng","runtime":0,"tagline":"","homepage":"","overview":"“Thử thách thần chết” là câu chuyện về những vệ thần bảo vệ và giúp cho những linh hồn thuần khiết được đầu thai chuyển kiếp. Phần 2 “Thử thách thần chết – 49 ngày cuối cùng” sẽ là câu chuyện xoay quanh bí ẩn đằng sau kí ức ngàn năm của những vệ thần. Ký ức ngàn năm trở về, liệu rằng đó sẽ là những kỉ niệm tươi vui hay sẽ là những ký ức không ai muốn khơi gợi ..."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Istenek között: Az utolsó 49 nap","runtime":142,"tagline":"","homepage":"","overview":"A túlvilágon egy őrző segíti az embert a próbák során. 2 társa segít egy korábbi őrzőnek a földön..."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"همراه با خدایان ۲: ۴۹ روز آخر","runtime":0,"tagline":"افشای رازهای هزاره.","homepage":"","overview":"همراه با خدایان ۲ ، فیلمی اکشن و فانتزی محصول سال ۲۰۱۸ به کارگردانی کیم یونگ هوا می‌باشد. در خلاصه داستان قسمت دوم این فیلم آمده است ، در زندگی پس از مرگ ، یک محافظ به مردی در طول آزمون‌هایش کمک می‌کند ، در حالی که دو نفر از همکاران او نیز به یک محافظ سابق بر روی زمین یاری می‌رسانند و…"},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Along with the Gods: The Last 49 Days","runtime":0,"tagline":"","homepage":"","overview":"Film se zaměřuje na trojici průvodců a jejich osudové propojení z budoucnosti. Děj se tak odehrává ve dvou časových rovinách (ta současná má přednost před tou, která je stará tisíc let) a přichází z mnoha nečekanými odhaleními. Také tentokrát dojde na cestu skrze posmrtné soudy, to se týká ale jen jednoho z průvodců. Zbylí dva hrdinové musí řešit ryze pozemský problém s jedním staříkem, jeho malým vnukem a duchem, který sídlí v domě."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Along with the Gods: The Last 49 Days","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"神と共に  第二章：因と縁","runtime":141,"tagline":"大人気K-POPグループEXOのD.O.ことド・ギョンス、「キングダム」のチュ・ジフン共演の、メガヒットを記録した作品。","homepage":"","overview":"思わぬ人物の魂を弁護することになった冥界の使者たち。寿命が尽きている老人を下界から連れ戻す任務にあたるなかで、彼ら自身の知られざる過去が明らかに。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Alături de zei: Ultimele 49 de zile","runtime":141,"tagline":"","homepage":"","overview":"Along with the Gods: The Last 49 Days este un film sud-coreean din genul fantasy-action, lansat în 2018, ce servește ca sequel al filmului din 2017, Along with the Gods: The Two Worlds. Filmul ne poartă mai departe în povestea lui Ja-hong (Cha Tae-hyun), un pompier care a murit accidental și acum se află în lumea de dincolo, unde trebuie să treacă prin șapte judecăți pentru a se putea reîncarna.  Alături de cei trei gardieni ai săi din lumea de dincolo, Gang-rim (Ha Jung-woo), Haewonmak (Ju Ji-hoon) și Lee Deok-choon (Kim Hyang-gi), Ja-hong va trebui să-și confrunte greșelile din viața anterioară și să demonstreze că merită o a doua șansă la viață.  Pe parcursul celor 49 de zile petrecute în lumea de dincolo, Ja-hong va descoperi adevăruri șocante despre viața sa anterioară și va fi nevoit să ia decizii cruciale care îi vor determina destinul."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Along with the Gods: The Last 49 Days","runtime":0,"tagline":"","homepage":"","overview":""},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Along with the Gods: The Last 49 Days","runtime":0,"tagline":"","homepage":"","overview":"Die drei Sensenmänner Gang-rim, Haewonmak und Lee Deok-choon werden ihre 49. Seele Kim Soo-hong in die Jenseitsprüfungen führen. In der Zwischenzeit wird God of the House die Erinnerungen der Sensenmänner an die Zeit vor 1.000 Jahren wiederherstellen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Razem z bogami: Ostatnie 49 dni","runtime":0,"tagline":"","homepage":"","overview":"Trzech ponurych żniwiarzy musi udowodnić, że zmarły nie ponosi odpowiedzialności za swoje czyny w świecie żywych i ma prawo do reinkarnacji, jednocześnie odkrywając swoje przeszłe życia oraz powody, dla których pełnią swoje role w zaświatach."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"}],"reviews_tmdb":[],"recommendations":[{"id":397567,"adult":false,"title":"Along with the Gods: The Two Worlds","video":false,"overview":"Having died unexpectedly, firefighter Ja-hong is taken to the afterlife by 3 afterlife guardians. Only when he passes 7 trials over 49 days and proves he was innocent in human life, he’s able to reincarnate, and his 3 afterlife guardians are by his side to defend him in trial.","genre_ids":[28,12,18,14,53],"media_type":"movie","popularity":3.9347,"vote_count":1165,"poster_path":"/gJSvIsI6oQfFim0PGyuuiCYfqKs.jpg","release_date":"2017-12-20","vote_average":8.037,"backdrop_path":"/wyv2Y9vXYJwJzF6cNVuVwVOsOUj.jpg","original_title":"신과함께-죄와 벌","original_language":"ko"},{"id":517991,"adult":false,"title":"The Spy Gone North","video":false,"overview":"South Korea, 1993. An agent of the National Intelligence Service is sent to Beijing to infiltrate a group of North Korean officials with the ultimate goal of obtaining information about their nuclear program.","genre_ids":[18,36,53],"media_type":"movie","popularity":2.009,"vote_count":215,"poster_path":"/ib7SNOKqPKLyVXTjhuVJIglTC3E.jpg","release_date":"2018-08-08","vote_average":7.358,"backdrop_path":"/fReqenpUkU83y7rpEMscE5EjoDr.jpg","original_title":"공작","original_language":"ko"},{"id":124157,"adult":false,"title":"The Thieves","video":false,"overview":"A gang of South Korean thieves team up with a Hong Kong crew to steal a diamond necklace from a heavily-guarded casino safe in Macau. As the cops close in, old betrayals — and misunderstandings — resurface.","genre_ids":[28,80],"media_type":"movie","popularity":2.7021,"vote_count":324,"poster_path":"/eYJihoMqME80tp9uJIpIlRF9RI0.jpg","release_date":"2012-07-25","vote_average":6.71,"backdrop_path":"/h1vNqJzPCTPg9Hhfxtv2XdE6Pna.jpg","original_title":"도둑들","original_language":"ko"},{"id":386467,"adult":false,"title":"Absolute Whiteness: Magical Girl","video":false,"overview":"Kuramoto Erica, Nitta Yui, Suzuhara Misa and Sasaki Kotone are not your average school girls. They are in fact blessed with supernatural powers, which they use to defend the common people from alien creatures.","genre_ids":[28,16,14],"media_type":"movie","popularity":1.1112,"vote_count":33,"poster_path":"/uIDnnnfpX4F4tePVAPTgTBbnYuM.jpg","release_date":"2012-08-12","vote_average":6.8,"backdrop_path":"/oxAJyNCp13kmXmBMx1StnAAtYzd.jpg","original_title":"絶対純白♡魔法少女","original_language":"ja"},{"id":532327,"adult":false,"title":"How High 2","video":false,"overview":"When two jobless friends discover a hidden weed bible and the ultimate bud, they think that they’ve got it made…with 'seed' money to start a new snack delivery app. But, when nearly all of their stash and weed bible are stolen, the two potpreneurs set off on an outrageous, mind-bending adventure through Atlanta to find them. Stoned with supernatural powers, they search 'high' and low, stopping at nothing to recover their ticket to starting a legit business.","genre_ids":[35,10770],"media_type":"movie","popularity":0.8642,"vote_count":104,"poster_path":"/7eYIWzBQGdB955PnHyPxXrseXFK.jpg","release_date":"2019-08-24","vote_average":6.24,"backdrop_path":"/8tgjvsyiOh5s7foxvYl62m2y5RM.jpg","original_title":"How High 2","original_language":"en"},{"id":628053,"adult":false,"title":"Happy Old Year","video":false,"overview":"While decluttering her home, a woman's hefty house renovation leads her back to the past when she uncovers her ex-boyfriend's belongings.","genre_ids":[18],"media_type":"movie","popularity":0.616,"vote_count":82,"poster_path":"/mTHtSbeBThnpWScOVBOm9URlPFq.jpg","release_date":"2019-12-26","vote_average":6.957,"backdrop_path":"/njlQxhgA8A6CiQq6x2NbCHQ4gl6.jpg","original_title":"ฮาวทูทิ้ง..ทิ้งอย่างไรไม่ให้เหลือเธอ","original_language":"th"},{"id":979806,"adult":false,"title":"Shades of Desire","video":false,"overview":"After her twin sister Aubrey goes missing, Jennifer uncovers the scandalous, secret double-life that Aubrey leads - and that has put both of them in danger.","genre_ids":[27,53],"media_type":"movie","popularity":0.7845,"vote_count":28,"poster_path":"/qLW0ufxvu4Xl4k1gZXNxiRXnsos.jpg","release_date":"2023-04-02","vote_average":6.696,"backdrop_path":"/sDhfPvuGe6e5pnWlC8BOg7uTKOa.jpg","original_title":"Shades of Desire","original_language":"en"},{"id":996720,"adult":false,"title":"Feed Me","video":false,"overview":"Following the death of his wife, a broken man spirals into an abyss of night tremors and depression and finds himself in the home of a deranged cannibal who convinces him to take his own life in the most horrific way imaginable.","genre_ids":[27,35],"media_type":"movie","popularity":0.9421,"vote_count":35,"poster_path":"/ztYN6xo5meeEHLH3bXU6jej3Tad.jpg","release_date":"2022-10-06","vote_average":5.086,"backdrop_path":"/3wLLqr6yaVmZw4jRuPwU9VCQyda.jpg","original_title":"Feed Me","original_language":"en"},{"id":33794,"adult":false,"title":"Arang","video":false,"overview":"A salt storehouse near the sea may be haunted. A penniless ex-con dies a gristly death in a house he can ill afford. The detectives assigned the case are Min, newly reinstated after a suspension, and Lee, a new transfer from forensics. Min has nightmares: a sexual assault that haunts her. She and Lee work well together, but soon two more deaths occur - each mysteriously poisoned, both friends of the ex-con. A fourth friend, a newly married doctor, is a suspect. But what has all this to do with the salt storehouse, a death ten years ago, and a missing girl? Can Min and Lee get to the bottom of it, or is the supernatural beyond a cop's reach?","genre_ids":[27],"media_type":"movie","popularity":0.9874,"vote_count":44,"poster_path":"/osSqqnw0LOWxhdCLkFt1klKG4rG.jpg","release_date":"2006-06-28","vote_average":5.636,"backdrop_path":"/uq6JzvW00Ynw2dQsaKdSH8nsJ0t.jpg","original_title":"아랑","original_language":"ko"},{"id":48773,"adult":false,"title":"Game of Death II","video":false,"overview":"In this dark tale of revenge, Bruce Lee \"returns\" as Billy Lo, whose best friend Chin Ku dies of a sudden illness. But suspicion of foul play arises when a gang tries to steal Ku's coffin at the funeral using a helicopter. When Lo's younger brother Lo hears about the incident, he leaves his Buddhist master to investigate the truth. His trail soon leads him to the Castle of Death, the last place Chin Ku was seen alive. There, he meets and befriends an unlikely ally--a cruel and merciless martial arts expert  who is also the tower's master. But when the master dies under mysterious circumstances, Lo ends up dueling with someone far more terrifying.","genre_ids":[18,28],"media_type":"movie","popularity":1.771,"vote_count":182,"poster_path":"/lVL0oX4ZA2owOtQwTsmbw92lhCp.jpg","release_date":"1981-03-21","vote_average":5.703,"backdrop_path":"/kKCA2KS9ShIQwOnK8ef6A4T2Zem.jpg","original_title":"死亡塔","original_language":"cn"},{"id":529569,"adult":false,"title":"The Witness","video":false,"overview":"An ordinary man witnesses a cruel murder and becomes entangled in circumstances out of his control.","genre_ids":[53,80],"media_type":"movie","popularity":1.3394,"vote_count":102,"poster_path":"/fxLYTY9HsnZtscMrKwkSG5PDww4.jpg","release_date":"2018-08-15","vote_average":6.716,"backdrop_path":"/wU57MNkOTtCvLgEfJzTUIGFdvbc.jpg","original_title":"목격자","original_language":"ko"},{"id":48691,"adult":false,"title":"Goodbye Uncle Tom","video":false,"overview":"Two documentary filmmakers go back in time to the pre-Civil War American South, to film the slave trade.","genre_ids":[18,80,27],"media_type":"movie","popularity":0.9374,"vote_count":70,"poster_path":"/nLw410E9rnJw13kufNgOtjiGvGk.jpg","release_date":"1971-09-23","vote_average":6.6,"backdrop_path":"/qMYvxKZ4ocJbU32bZvFVft7ZjJz.jpg","original_title":"Addio zio Tom","original_language":"it"},{"id":24973,"adult":false,"title":"The Egyptian","video":false,"overview":"In eighteenth-dynasty Egypt, Sinuhe, a poor orphan, becomes a brilliant physician and with his friend Horemheb is appointed to the service of the new Pharoah. Sinuhe's personal triumphs and tragedies are played against the larger canvas of the turbulent events of the 18th dynasty. As Sinuhe is drawn into court intrigues he learns the answers to the questions he has sought since his birth.","genre_ids":[36,18],"media_type":"movie","popularity":1.556,"vote_count":103,"poster_path":"/vYLY2YIGCWINPSzLg6tBiN6ub7X.jpg","release_date":"1954-08-25","vote_average":6.4,"backdrop_path":"/qTU1lVXsGfW4e0eZ7YM7WVySvnj.jpg","original_title":"The Egyptian","original_language":"en"},{"id":392709,"adult":false,"title":"System of a Down - Rock in Rio","video":false,"overview":"System of a Down at Cidade do Rock, Rio de Janeiro, Brazil on September 24, 2015. Setist: I-E-A-I-A-I-O / Suite-Pee (Incomplete) / Attack / Prison Song / Know / Aerials / Soldier Side - Intro / B.Y.O.B. / Soil / Darts / Radio/Video / Hypnotize / Temper / CUBErt / Needles / Deer Dance / Bounce / Suggestions / Psycho / Chop Suey! / Lonely Day / Question! / Lost in Hollywood / Vicinity of Obscenity / Forest / Cigaro / Toxicity (with Chino Moreno) / Sugar","genre_ids":[10402],"media_type":"movie","popularity":0.09,"vote_count":17,"poster_path":"/hOnWAl0IYjr6MogwdfhF2R7cK3B.jpg","release_date":"2015-09-24","vote_average":8.5,"backdrop_path":"/bbNe4BPpcdaj2ca7lih1LkVohEE.jpg","original_title":"System of a Down - Rock in Rio","original_language":"en"},{"id":52444,"adult":false,"title":"Seducing Mr. Perfect","video":false,"overview":"A Korean company analyst rear-ends an American man's car then discovers he's her new boss. Unlucky at love, she begins to take romance lessons from him in order to seduce him.","genre_ids":[10749,35],"media_type":"movie","popularity":3.4623,"vote_count":55,"poster_path":"/yj4AXMYp7KQGkhd1NwNeZzyAEEq.jpg","release_date":"2006-12-07","vote_average":6.018,"backdrop_path":"/3Vgbq364enirFB3qEbP9oNO5I5W.jpg","original_title":"Mr. 로빈 꼬시기","original_language":"ko"},{"id":287284,"adult":false,"title":"Swung","video":false,"overview":"David’s life is on the slide: he’s broke, in the middle of a divorce and ‘can’t get it up’.  His girlfriend, Alice, is his rock, but the magazine she writes for is going down and the pressure is on to find a story.  While job hunting online, David stumbles across the perfect antidote to his boredom: a ‘Swingers’ site. The resulting inbox of lewd invitations on the home-laptop justifiably upsets Alice, until she realises this could be just the ‘story’ she needs.  The idea of uncovering the swinging scene causes quite a stir in Alice’s office and, much to David’s chagrin, she is urged to pursue the story.  Their first reluctant foray is an hysterically low-rent initiation, however, an unexpected upturn for David’s manhood is all the extra encouragement they need.  As events accelerate beyond their control the once adoring couple become lost and fundamental questions are asked of their relationship.","genre_ids":[10749,18],"media_type":"movie","popularity":2.252,"vote_count":61,"poster_path":"/wRjm5zztXRUYhXEl3FQKbIbgtMC.jpg","release_date":"2015-06-19","vote_average":5.425,"backdrop_path":"/jcli1SIkrjxs4UTbJi5slxRKgHO.jpg","original_title":"Swung","original_language":"en"},{"id":469321,"adult":false,"title":"Dark Was the Night","video":false,"overview":"In the aftermath of tragedy, a woman and her teenage son must forge into uncharted territory in order to move on with their lives.","genre_ids":[18],"media_type":"movie","popularity":0.6251,"vote_count":38,"poster_path":"/65WxI8brgXAzzkIT93WCEQGdIdi.jpg","release_date":"2018-11-30","vote_average":5.5,"backdrop_path":"/sQfECqKxfN2Xno1QU6wiZWVhTxA.jpg","original_title":"Dark Was the Night","original_language":"en"},{"id":541057,"adult":false,"title":"The Wind Guardians","video":false,"overview":"A young man who lives in Xiaoyanggang dreams of martyrdom, but he is blind and can only sneak into the market by swindling. One day, Rakshasa attacked Xiaoyanggang, and his mother, who was dependent on him, suddenly disappeared. Lang Ming had to embark on the road of finding the truth. After a wave of unrest, ancient gods and beasts are in danger, and the legendary chivalrous also appear before them. Lang Ming embarks on a journey of adventure that will change his life...","genre_ids":[16,28,12,18,14],"media_type":"movie","popularity":0.5241,"vote_count":19,"poster_path":"/t3pYiazT21B35NZIdJSJPnATQHM.jpg","release_date":"2018-08-03","vote_average":6.579,"backdrop_path":"/1QmYuKm3P5McrlOopGxSWAt3pcE.jpg","original_title":"风语咒","original_language":"zh"},{"id":843324,"adult":false,"title":"Let's Dream","video":false,"overview":"Let, a reclusive, insomniac photographer, is hired to photograph a mysterious client in the forest late one night, and soon finds himself pulled into a bizarre, otherworldly quest.","genre_ids":[878,27],"media_type":"movie","popularity":0.0575,"vote_count":12,"poster_path":"/gX9PnhFarHrpBYSNhCEJnZbzHRH.jpg","release_date":"2021-06-19","vote_average":5.4,"backdrop_path":"/lKrpXRNylen4RZvD86JcwPZzdQ3.jpg","original_title":"Let's Dream","original_language":"en"},{"id":611337,"adult":false,"title":"Deception of the Novelist","video":false,"overview":"A famous novelist receives a large inheritance after his father’s passing. He rents out one of his inherited properties to a Japanese/Chinese woman named Elaine and they embark on an affair, causing rifts in his marriage with Jeanna Ho. One night, Elaine is suddenly found dead in the balcony of the house. When police start their investigation, they realize that there are a lot of suspicious factors to the case leading them to suspect that this is not their normal kidnapping or revenge against an unfaithful husband case.","genre_ids":[80,35,9648,53],"media_type":"movie","popularity":1.1559,"vote_count":12,"poster_path":"/bZwhndYitrRyR3k3dJ3yHKeh1jv.jpg","release_date":"2019-06-20","vote_average":5.8,"backdrop_path":"/o4wW2Xv6BPOEIqIBDlUSsUaJBSq.jpg","original_title":"作家的謊言：筆忠誘罪","original_language":"cn"}],"similar_content":[{"id":155,"adult":false,"title":"The Dark Knight","video":false,"overview":"Batman raises the stakes in his war on crime. With the help of Lt. Jim Gordon and District Attorney Harvey Dent, Batman sets out to dismantle the remaining criminal organizations that plague the streets. The partnership proves to be effective, but they soon find themselves prey to a reign of chaos unleashed by a rising criminal mastermind known to the terrified citizens of Gotham as the Joker.","genre_ids":[28,80,53],"popularity":29.8871,"vote_count":35202,"poster_path":"/qJ2tW6WMUDux911r6m7haRef0WH.jpg","release_date":"2008-07-16","vote_average":8.526,"backdrop_path":"/dqK9Hag1054tghRQSqLSfrkvQnA.jpg","original_title":"The Dark Knight","original_language":"en"},{"id":184,"adult":false,"title":"Jackie Brown","video":false,"overview":"Jackie Brown is a flight attendant who gets caught in the middle of smuggling cash into the country for her gunrunner boss. When the cops try to use Jackie to get to her boss, she hatches a plan — with help from a bail bondsman — to keep the money for herself.","genre_ids":[80,18,53],"popularity":5.0152,"vote_count":6808,"poster_path":"/rOUx7qg4KmEh1juEDwqzbDSL1Nr.jpg","release_date":"1997-12-25","vote_average":7.36,"backdrop_path":"/gvaeY5kz3wHrMU6xLdnybziwYXw.jpg","original_title":"Jackie Brown","original_language":"en"},{"id":187,"adult":false,"title":"Sin City","video":false,"overview":"Welcome to Sin City. This town beckons to the tough, the corrupt, the brokenhearted. Some call it dark… Hard-boiled. Then there are those who call it home — Crooked cops, sexy dames, desperate vigilantes. Some are seeking revenge, others lust after redemption, and then there are those hoping for a little of both. A universe of unlikely and reluctant heroes still trying to do the right thing in a city that refuses to care.","genre_ids":[80,53],"popularity":7.572,"vote_count":8671,"poster_path":"/i66G50wATMmPrvpP95f0XP6ZdVS.jpg","release_date":"2005-04-01","vote_average":7.463,"backdrop_path":"/t9kQnqiaxQ8TLB25rTzDKLd0fdM.jpg","original_title":"Sin City","original_language":"en"},{"id":251,"adult":false,"title":"Ghost","video":false,"overview":"After a young man is murdered, his spirit stays behind to warn his lover of impending danger, with the help of a reluctant psychic.","genre_ids":[14,18,53,9648,10749],"popularity":10.2648,"vote_count":5909,"poster_path":"/w9RaPHov8oM5cnzeE27isnFMsvS.jpg","release_date":"1990-07-13","vote_average":7.228,"backdrop_path":"/6nLdSON3ErniBZTXWG7WRqs5jGz.jpg","original_title":"Ghost","original_language":"en"},{"id":948300,"adult":false,"title":"The Artifice","video":false,"overview":"An experimental visual piece delving into concepts like afterlife and existence in an abstract but accessible way.","genre_ids":[18,9648,53,878],"popularity":0.3611,"vote_count":1,"poster_path":"/utU7Bv4MDiZPsMUSOqzDR2CQ5XU.jpg","release_date":"2009-03-01","vote_average":10,"backdrop_path":"/hPWmPt5YruHStzbTpb2CvN2KdR8.jpg","original_title":"The Artifice","original_language":"en"},{"id":414,"adult":false,"title":"Batman Forever","video":false,"overview":"Batman faces off against two foes: the schizophrenic, horribly scarred former District Attorney Harvey Dent, aka Two-Face, and the Riddler, a disgruntled ex-Wayne Enterprises inventor seeking revenge against his former employer by unleashing his brain-sucking weapon on Gotham City's residents. As the caped crusader also copes with tortured memories of his parents' murder, he has a new romance, with psychologist Chase Meridian.","genre_ids":[28,80,14],"popularity":6.1609,"vote_count":5490,"poster_path":"/i0fJS8M5UKoETjjJ0zwUiKaR8tr.jpg","release_date":"1995-06-16","vote_average":5.454,"backdrop_path":"/snlu32RmjldF9b068UURJg8sQtn.jpg","original_title":"Batman Forever","original_language":"en"},{"id":415,"adult":false,"title":"Batman & Robin","video":false,"overview":"Batman and his sidekick Robin attempt to the foil the sinister schemes of a deranged set of new villains, most notably the melancholy Mr. Freeze, who wants to make Gotham City into an arctic region, and the sultry Poison Ivy, a botanical femme fatale. As the Dynamic Duo contend with these bad guys, a third hero, Batgirl, joins the ranks of the city's crime-fighters.","genre_ids":[28,878,12],"popularity":8.1892,"vote_count":5320,"poster_path":"/i7hEUpDuMN2LOrCEifFyGSHZQSY.jpg","release_date":"1997-06-20","vote_average":4.386,"backdrop_path":"/rpOqHZMNIaI4qP4r7nw1B7oA0mx.jpg","original_title":"Batman & Robin","original_language":"en"},{"id":490,"adult":false,"title":"The Seventh Seal","video":false,"overview":"When disillusioned Swedish knight Antonius Block returns home from the Crusades to find his country in the grips of the Black Death, he challenges Death to a chess match for his life. Tormented by the belief that God does not exist, Block sets off on a journey, meeting up with traveling players Jof and his wife, Mia, and becoming determined to evade Death long enough to commit one redemptive act while he still lives.","genre_ids":[14,18],"popularity":4.7272,"vote_count":3274,"poster_path":"/wcZ21zrOsy0b52AfAF50XpTiv75.jpg","release_date":"1957-02-16","vote_average":8.2,"backdrop_path":"/6s2BqtDvp1BMiP70zCDU5OW6hMy.jpg","original_title":"Det sjunde inseglet","original_language":"sv"},{"id":9312,"adult":false,"title":"Mortal Kombat","video":false,"overview":"For nine generations an evil sorcerer has been victorious in hand-to-hand battle against his mortal enemies. If he wins a tenth Mortal Kombat tournament, desolation and evil will reign over the multiverse forever. To save Earth, three warriors must overcome seemingly insurmountable odds, their own inner demons, and superhuman foes.","genre_ids":[28,14],"popularity":4.1973,"vote_count":2459,"poster_path":"/fcK7tzSSXMYiMN8E9KlZJL1BYyp.jpg","release_date":"1995-08-18","vote_average":5.874,"backdrop_path":"/dfU9xyEEyLxvZ5unTn05Whm9Lce.jpg","original_title":"Mortal Kombat","original_language":"en"},{"id":9318,"adult":false,"title":"Asterix in Britain","video":false,"overview":"One little ancient British village still holds out against the Roman invaders. Asterix and Obelix are invited to help. They must face fog, rain, warm beer and boiled boar with mint sauce, but they soon have Governor Encyclopaedius Britannicus's Romans declining and falling. Until a wild race for a barrel of magic potion lands them in the drink.","genre_ids":[10751,16,12,35],"popularity":1.2095,"vote_count":711,"poster_path":"/10L5R1l03MqDx36e0LJ99NKLGD3.jpg","release_date":"1986-12-03","vote_average":6.768,"backdrop_path":"/cNwnAack1iyaLoWqGyTGocMOarg.jpg","original_title":"Astérix chez les Bretons","original_language":"fr"},{"id":9369,"adult":false,"title":"Asterix Conquers America","video":false,"overview":"When marauding Romans capture - and catapult - their pal Getafix into lands unknown, the shrewd and cunning Asterix and his able sidekick Obelix spring into action! But their journey leads them to a strange and dangerous new world, where they must face a tribe of Indians, a stampeding herd of buffalo and a medicine man with designs on their magic potion!","genre_ids":[10751,16,12,35],"popularity":1.3316,"vote_count":631,"poster_path":"/lKSunt7dnbITSopaEeeR7KfeSHb.jpg","release_date":"1994-09-29","vote_average":6.209,"backdrop_path":"/XBY0iPOFVghrFPT5I3heiToGca.jpg","original_title":"Asterix in Amerika","original_language":"de"},{"id":9385,"adult":false,"title":"The Twelve Tasks of Asterix","video":false,"overview":"Asterix and Obelix depart on an adventure to complete twelve impossible tasks to prove to Caesar that they are as strong as the Gods. You'll roar with laughter as they outwit, outrun, and generally outrage the very people who are trying to prove them \"only human\".","genre_ids":[10751,16,35,12],"popularity":1.7516,"vote_count":1322,"poster_path":"/7cZQZOYZFJcLjZnxWjO5PcUtmDZ.jpg","release_date":"1976-06-26","vote_average":7.3,"backdrop_path":"/lyQSifurKvWmqWzouVe50JFoI35.jpg","original_title":"Les 12 travaux d'Astérix","original_language":"fr"},{"id":9389,"adult":false,"title":"Renaissance","video":false,"overview":"To find Ilona and unlock the secrets of her disappearance, Karas must plunge deep into the parallel worlds of corporate espionage, organized crime and genetic research - where the truth imprisons whoever finds it first and miracles can be bought but at a great price.","genre_ids":[28,16,878],"popularity":3.7312,"vote_count":278,"poster_path":"/fTdbmjAegzFQOCPTAckPcmTpJvp.jpg","release_date":"2006-03-16","vote_average":6.532,"backdrop_path":"/8ZwAm4sgZlAf8fvKApzla4j2eCz.jpg","original_title":"Renaissance","original_language":"fr"},{"id":10836,"adult":false,"title":"Dagon","video":false,"overview":"A boating accident off the coast of Spain sends Paul and his girlfriend Barbara to the decrepit fishing village of Imboca. As night falls, people start to disappear and things not quite human start to appear. Paul is pursued by the entire town. Running for his life, he uncovers Imboca's secret..they worship Dagon, a monstrous god of the sea...and Dagon's unholy offspring are on the loose...","genre_ids":[14,27,53],"popularity":5.01,"vote_count":458,"poster_path":"/8S648eMKObi8ERFS7cSYDocxSaZ.jpg","release_date":"2001-10-12","vote_average":6.147,"backdrop_path":"/nO8lpaJLo1UVIXL7eM5ewwudvtY.jpg","original_title":"Dagon","original_language":"en"},{"id":10546,"adult":false,"title":"The Crow: City of Angels","video":false,"overview":"A murder victim is brought back to life by a mysterious crow. With the help of a beautiful woman, he exacts revenge on his killers – only to realize his enemy has discovered the one weakness that can destroy him forever.","genre_ids":[28,14,53],"popularity":1.1127,"vote_count":588,"poster_path":"/ppOoLiO2JY0BJQdixs08xrQuAA6.jpg","release_date":"1996-08-29","vote_average":5.497,"backdrop_path":"/c0OnUa4nmLdbM63CZZtyehjCaQ2.jpg","original_title":"The Crow: City of Angels","original_language":"en"},{"id":11560,"adult":false,"title":"High Crimes","video":false,"overview":"A female attorney learns that her husband is really a marine officer awol for fifteen years and accused of murdering fifteen civilians in El Salvador. Believing her husband when he tells her that he's being framed as part of a U.S. Military cover-up, the attorney defends him in a military court.","genre_ids":[18,9648,53,80],"popularity":2.1243,"vote_count":857,"poster_path":"/9sj9rUr7Vu5IfOQHnYKnJuVEw0B.jpg","release_date":"2002-04-05","vote_average":6.3,"backdrop_path":"/l6VxsJ3eZ9l99T8ayLs4CQJXZUR.jpg","original_title":"High Crimes","original_language":"en"},{"id":11619,"adult":false,"title":"Flushed Away","video":false,"overview":"London high-society mouse, Roddy is flushed down the toilet by Sid, a common sewer rat. Hang on for a madcap adventure deep in the sewer bowels of Ratropolis, where Roddy meets the resourceful Rita, the rodent-hating Toad and his faithful thugs, Spike and Whitey.","genre_ids":[12,16,35,10751],"popularity":5.9305,"vote_count":4028,"poster_path":"/kgoZI4xh38RrEYEPVib6a12UPLn.jpg","release_date":"2006-10-22","vote_average":6.311,"backdrop_path":"/7xQk3HdCvkNmk3gblDGn9fVnbsT.jpg","original_title":"Flushed Away","original_language":"en"},{"id":11625,"adult":false,"title":"Asterix and the Big Fight","video":false,"overview":"Due to an unfortunate accident involving Obelix throwing a menhir, Getafix the druid not only loses his memory, but goes completely mad. Now deprived of the wisdom of their beloved druid and the protection provided by his magic potion, the Armorican village falls prey to a proclaimed soothsayer who comes with ominous predictions and overweening ambitions. It's up to Asterix to keep his villager friends within reason and hopefully get Getafix to remember the magic potion's recipe before the impending Roman attack.","genre_ids":[10751,16,12,35],"popularity":1.6148,"vote_count":662,"poster_path":"/7KFAtZRXzD00Zw9sWxusrInLHgJ.jpg","release_date":"1989-10-04","vote_average":6.291,"backdrop_path":"/5o65Tj8LNt0UsHzeLbU1VjMm7dm.jpg","original_title":"Astérix et le Coup du menhir","original_language":"fr"},{"id":11658,"adult":false,"title":"Tae Guk Gi: The Brotherhood of War","video":false,"overview":"When two brothers are forced to fight in the Korean War, the elder decides to take the riskiest missions if it will help shield the younger from battle.","genre_ids":[28,12,18,36,10752],"popularity":1.9454,"vote_count":753,"poster_path":"/vyG8qpimh3XSlxc6OmPq8LJRJl.jpg","release_date":"2004-02-05","vote_average":7.983,"backdrop_path":"/oqaKsofz49zjNhi48sxQIq8U73X.jpg","original_title":"태극기 휘날리며","original_language":"ko"},{"id":26600,"adult":false,"title":"Between Two Worlds","video":false,"overview":"Passengers on an ocean liner can't recall how they got onboard or where they are going. Soon it becomes apparent that they all have something in common.","genre_ids":[18,14],"popularity":0.5357,"vote_count":37,"poster_path":"/t1NeBrt65qUJCcOBOqf8MlTcnOy.jpg","release_date":"1944-05-20","vote_average":7.068,"backdrop_path":"/cOnFl1Egh1tPfIAvbkOhOp0gxNE.jpg","original_title":"Between Two Worlds","original_language":"en"}],"external_ids":{"imdb_id":"tt8116428","twitter_id":null,"facebook_id":null,"wikidata_id":"Q54803694","instagram_id":null,"metacritic_id":"movie/along-with-the-gods-the-last-49-days","rotten_tomatoes_id":"m/along_with_the_gods_the_last_49_days"},"social_ids":{"