5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Extraordinary Rescue\",\"description\":\"Military instructor Zhang Zhen becomes embroiled in a murder case, forcing him to go on the run. With help, he finds a survivor and investigates, uncovering connections to human trafficking and a military group while seeking the truth.\",\"image\":\"https://image.tmdb.org/t/p/w500/6tq7WDWohN5VbDlgSIKl06d8p5O.jpg\",\"datePublished\":\"2023-03-04\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Action\",\"Thriller\",\"Crime\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4,\"bestRating\":10,\"ratingCount\":1}}"}}],["$","$L10",null,{"initialDrama":{"id":"45d02085-e2bb-46c0-8d19-df2a4f581ecd","tmdb_id":1095460,"imdb_id":null,"content_type":"movie","title":"Extraordinary Rescue","original_title":"非凡营救","overview":"Military instructor Zhang Zhen becomes embroiled in a murder case, forcing him to go on the run. With help, he finds a survivor and investigates, uncovering connections to human trafficking and a military group while seeking the truth.","poster_path":"/6tq7WDWohN5VbDlgSIKl06d8p5O.jpg","backdrop_path":"/x09PUOdWiM3JhPRVrInG32Efedp.jpg","release_date":"2023-03-04","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":28,"name":"Action"},{"id":53,"name":"Thriller"},{"id":80,"name":"Crime"}],"popularity":4.0237,"vote_average":4,"vote_count":1,"runtime":95,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-27T21:42:22.598276+00:00","updated_at":"2026-02-23T12:40:57.871+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[],"production_countries":[{"name":"China","iso_3166_1":"CN"}],"spoken_languages":[{"name":"普通话","iso_639_1":"zh","english_name":"Mandarin"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[],"alternative_titles":[{"type":"","title":"Extraordinary.Rescue.2023","iso_3166_1":"CN"}],"videos":[],"watch_providers":{"results":{"KR":{"link":"https://www.themoviedb.org/movie/1095460/watch?locale=KR","flatrate":[{"logo_path":"/5gmEivxOGPdq4Afpq1f8ktLtEW1.jpg","provider_id":97,"provider_name":"Watcha","display_priority":4}]}}},"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/6tq7WDWohN5VbDlgSIKl06d8p5O.jpg","images":{"logos":[{"width":1699,"height":700,"file_path":"/ytK61EfRmuxKwnWAhtwNm9JRJGi.png","iso_639_1":"zh","vote_average":0}],"posters":[{"width":800,"height":1200,"file_path":"/6tq7WDWohN5VbDlgSIKl06d8p5O.jpg","iso_639_1":"zh","vote_average":0},{"width":2000,"height":2850,"file_path":"/uMAh27use5eaVFBWxhyp31eL6E.jpg","iso_639_1":"ko","vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/x09PUOdWiM3JhPRVrInG32Efedp.jpg","iso_639_1":null,"vote_average":3.334},{"width":1912,"height":1074,"file_path":"/xqKe1DlpA2kek6myEA0FmeSj5J6.jpg","iso_639_1":null,"vote_average":0.166}]},"enriched_at":"2026-04-21T04:47:17.777+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"张宸是军事战术教官，经常辗转于世界各地为安保公司做战术培训。一次实战狙击训练中，某安保公司负责人马库斯在张宸完全不知道的情况下，通过他的指导完成了一次危险的实战救援行动，张宸愤怒的以‘道不同不相为谋’回应了马库斯加入安保集团的邀请。张宸对此事始终不能释怀，正准备调查被救者的身份背景，却莫名其妙被卷入一起数十公里之外的谋杀案，成了当地的通缉犯，张宸被迫开始逃亡。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Extraordinary Rescue","runtime":95,"tagline":"","homepage":"","overview":"Military instructor Zhang Zhen becomes embroiled in a murder case, forcing him to go on the run. With help, he finds a survivor and investigates, uncovering connections to human trafficking and a military group while seeking the truth."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Extraordinary Rescue","runtime":0,"tagline":"","homepage":"","overview":"המדריך הצבאי ג'אנג ג'ן מסתבך בתיק רצח, מה שמאלץ אותו לצאת למנוסה. בעזרתו הוא מוצא ניצול וחוקר, חושף קשרים לסחר בבני אדם ולקבוצה צבאית תוך חיפוש אחר האמת."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"스나이퍼: 스페셜 미션","runtime":0,"tagline":"","homepage":"","overview":"전장의 영웅이었던 최고의 스나이퍼. 조작된 누명을 쓰고 지명수배자가 된 그는 그의 삶을 파괴한 배후의 거대 조직에 맞서게 된다. 모든 것을 잃은 그는 적들의 심장부로 치명적이고 은밀하게 침투한다. 잃어버린 명예와 정의를 되찾기 위해 그의 총성은 거대한 음모의 심장을 꿰뚫는다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"}],"reviews_tmdb":[],"recommendations":[{"id":1049713,"adult":false,"title":"Hello","video":false,"overview":"Hello explores changes in two people’s working lives: a Mexican trash picker who separates and collects recyclable materials from landfills to sell by the kilo, and a German freelance computer-animation designer working for the advertising industry in Berlin. The double interview is controlled and manipulated by a computer-generated severed hand which Maria describes as an object once discovered in the trash while working in the violent northern town of Mexicali. This CGI hand was in turn produced by Max, who was born with no arms, and sought refuge in computer-imaging as a means to operate and manipulate a digital reality.","genre_ids":[],"media_type":"movie","popularity":0.0692,"vote_count":19,"poster_path":"/tGDhbpTrXm2Vuqv0yzydGBmmRO0.jpg","release_date":"","vote_average":6.1,"backdrop_path":null,"original_title":"Hello","original_language":"en"},{"id":75015,"adult":false,"title":"How I Unleashed World War II, Part III: Among Friends","video":false,"overview":"Disguised as an Italian medic, Dolas finds himself on a ship evacuating wounded Axis soldiers to Italy. He leaves the ship disguised as a Nazi soldier, but is found out, declared a deserter and sent to the Eastern Front. However, on the flight to Russia, he is able to escape with a parachute, and finds himself back in Poland, now occupied by Nazis.","genre_ids":[35,12,10752],"media_type":"movie","popularity":0.3906,"vote_count":41,"poster_path":"/3UaRR9vc4vgXWldQtE0aoBcPuRQ.jpg","release_date":"1970-04-06","vote_average":7.634,"backdrop_path":"/p82pbolg2NcyRIyeOz4FMPMf9vM.jpg","original_title":"Jak rozpętałem drugą wojnę światową: Cz. 3 - Wśród swoich","original_language":"pl"},{"id":844613,"adult":false,"title":"Sonic 30th Anniversary Symphony","video":false,"overview":"30 years ago, on June 23rd, 1991, Sonic the Hedgehog was released on the SEGA Genesis, beginning a new era of gaming.  Since then, Sonic has been running through countless zones, beating badniks, and saving the world with the help of his friends.  This performance is to thank you, all of you, for being there every step of the way, and to remind us all of the amazing journey we've been on.  Happy 30th Anniversary, Sonic!","genre_ids":[99,10402],"media_type":"movie","popularity":0.2716,"vote_count":13,"poster_path":"/nhbXu6nIBV6lP4L93eHi7PJcILE.jpg","release_date":"2021-06-23","vote_average":7.115,"backdrop_path":"/h3lW1GzRqwVxfbTAddlNgWY9lNa.jpg","original_title":"Sonic 30th Anniversary Symphony","original_language":"en"},{"id":153529,"adult":false,"title":"The United Monster Talent Agency","video":false,"overview":"A short comedy spoof about Universal Monsters and their everyday unconventional work done at their very own talent agency for their movies.","genre_ids":[35,27],"media_type":"movie","popularity":0.3774,"vote_count":14,"poster_path":"/c0LMw7eLSXxlWqdQq8VMWxyrei1.jpg","release_date":"2010-09-27","vote_average":9.1,"backdrop_path":"/ilpp1j0rF67uMiFnY33jTSfR5HM.jpg","original_title":"The United Monster Talent Agency","original_language":"en"},{"id":290727,"adult":false,"title":"Monster High: Freaky Fusion","video":false,"overview":"While attempting to help Frankie Stein learn more about her freakycool scaritage, the fashionably fierce ghoulfriends travel back in time to the first day ever of Monster High! There, they meet Sparky, a skullastic teen with an obsession for creating life. But when Sparky follows the ghouls through a killer time portal to modern-day Monster High, the event results in eight of them fusing together into four creeperiffic hybrid Monsters. Now, they'll really have to work together to control their bodies in the big Bitecentennial Play and stop one of Sparky's experiments from destroying imperfectly perfect Monster High!","genre_ids":[16],"media_type":"movie","popularity":1.4176,"vote_count":127,"poster_path":"/jJN5LgT6GrnlvWvdCydLS0c4g8j.jpg","release_date":"2014-10-06","vote_average":7.7,"backdrop_path":"/tg0aXAvX4qKCkpPQImNEE0e90Pf.jpg","original_title":"Monster High: Freaky Fusion","original_language":"en"},{"id":14611,"adult":false,"title":"Ultimate Avengers 2","video":false,"overview":"Mysterious Wakanda lies in the darkest heart of Africa, unknown to most of the world. An isolated land hidden behind closed borders, fiercely protected by its young king: Black Panther. But when brutal alien invaders attack, the threat leaves Black Panther with no option but to go against the sacred decrees of his people and ask for help from outsiders.","genre_ids":[12,16,28,878],"media_type":"movie","popularity":1.3145,"vote_count":317,"poster_path":"/sMFyYZR9krqcQC99G6jnb10Zv4P.jpg","release_date":"2006-08-08","vote_average":6.803,"backdrop_path":"/hoJpIYgFPc75NhaSWPNUeMFPMy1.jpg","original_title":"Ultimate Avengers 2","original_language":"en"},{"id":712509,"adult":false,"title":"Six Weeks to Twelve Years","video":false,"overview":"After the death of their abusive father, two estranged twin brothers must reunite and sell off his property.","genre_ids":[35,18],"media_type":"movie","popularity":0.2248,"vote_count":4,"poster_path":"/kFHxdUKN0wOwxicowrM2htcL9d5.jpg","release_date":"2020-09-30","vote_average":6.1,"backdrop_path":"/fNLV8MCNNHkXdFtGxqIIcWg0JYv.jpg","original_title":"Six Weeks to Twelve Years","original_language":"en"},{"id":362584,"adult":false,"title":"Kizumonogatari Part 2: Nekketsu","video":false,"overview":"Koyomi Araragi was turned into a vampire by the legendary vampire, Kiss-shot Acerola-orion Heart-under-blade, and he needs to revive the weakened vampire back to her complete form to return to being human again. The only way for Koyomi to achieve his goal is to fight the three vampire hunters – Dramaturgy, Episode and Guillotinecutter.","genre_ids":[16,14,9648],"media_type":"movie","popularity":1.3663,"vote_count":217,"poster_path":"/fv9AALP1dofQUvKAkxnkz105MOv.jpg","release_date":"2016-08-19","vote_average":8,"backdrop_path":"/41XzkXiiDZGSYF2uBegeS2qQ3NC.jpg","original_title":"傷物語〈Ⅱ熱血篇〉","original_language":"ja"},{"id":413223,"adult":false,"title":"Sonic Soldier Borgman: Last Battle","video":false,"overview":"It has been three years since the end of the series. Ryo works for NASA as an engineer on a large rocket project. Anise, fellow Borgman and lover, has been reduced to flipping burgers in a restaurant. So naturally, when she gets a letter offering her a professional job in a big, Japanese, high-tech project, she jumps at the chance. Ryo, however, is as indecisive as ever and so she leaves for Japan without him. Chuck Sweager, the third Borgman, is a police officer, as is his girlfriend Miki...","genre_ids":[18,878,28,16],"media_type":"movie","popularity":0.384,"vote_count":8,"poster_path":"/l8ssJrew5Lz4oUAYJuiMDuwhKF0.jpg","release_date":"1989-09-16","vote_average":6.1,"backdrop_path":null,"original_title":"超音戦士ボーグマン ザ・ボーグマン ラストバトル","original_language":"ja"},{"id":72525,"adult":false,"title":"Syrup","video":false,"overview":"A slacker hatches a million-dollar idea. But, in order to see it through, he has to learn to trust his attractive corporate counterpart. Based on Max Barry's novel.","genre_ids":[18,35],"media_type":"movie","popularity":0.6108,"vote_count":199,"poster_path":"/l3HSd4Nj6YKKUiE6q9WGow94f45.jpg","release_date":"2013-06-07","vote_average":5.508,"backdrop_path":"/ykvSHGj9XKcYbU2E55j56mPIo2c.jpg","original_title":"Syrup","original_language":"en"},{"id":396909,"adult":false,"title":"Panda","video":false,"overview":"Two teenagers are playing by night in a dirty parking lot. After they are driving on an empty road, they start to tease each other on the way to the sea, but they seem to be too young to drive and the road is a bit strange.","genre_ids":[18],"media_type":"movie","popularity":0.3905,"vote_count":2,"poster_path":"/2L3JJI0AKn97pmhHh39PSdwwxWk.jpg","release_date":"2014-06-12","vote_average":6.5,"backdrop_path":"/r3plzrSmoefAJlQwbZmeuw3KEFi.jpg","original_title":"Panda","original_language":"fr"},{"id":512098,"adult":false,"title":"Blackmail","video":false,"overview":"When Dev finds about his wife's affair, he starts blackmailing her and her lover but the blackmail game backfires on him.","genre_ids":[35,53],"media_type":"movie","popularity":0.5216,"vote_count":103,"poster_path":"/apt3peZIUjd56Rkt0HGxp6EaxKe.jpg","release_date":"2018-04-06","vote_average":6.869,"backdrop_path":"/oXuu7LYV1ztNotZvvOJchqBgl8Z.jpg","original_title":"Blackmail","original_language":"hi"},{"id":92850,"adult":false,"title":"Nightmare Factory","video":false,"overview":"The story of how one Pittsburgh boy’s fascination with monsters drove him to the very top of the Hollywood food chain. In 1989, Greg Nicotero, much to his parents’ chagrin, quit medical school and headed for Hollywood to pursue a dream of making monsters. Together with gore masters Howard Berger and Robert Kurtzman, Nicotero went on to create KNB EFX Group, one of the most prolific makeup effects studios in the world. After twenty years as the “go to guy” for the world’s most successful horror/sci-fi films, Greg Nicotero is the first one directors like Quentin Tarantino and Robert Rodriguez call.","genre_ids":[99],"media_type":"movie","popularity":1.943,"vote_count":22,"poster_path":"/aKTceKHI7kCzs6LLFr5262HePMS.jpg","release_date":"2011-10-27","vote_average":7.3,"backdrop_path":null,"original_title":"Nightmare Factory","original_language":"en"},{"id":19404,"adult":false,"title":"Dilwale Dulhania Le Jayenge","video":false,"overview":"Raj is a rich, carefree, happy-go-lucky second generation NRI. Simran is the daughter of Chaudhary Baldev Singh, who in spite of being an NRI is very strict about adherence to Indian values. Simran has left for India to be married to her childhood fiancé. Raj leaves for India with a mission at his hands, to claim his lady love under the noses of her whole family. Thus begins a saga.","genre_ids":[35,18,10749],"media_type":"movie","popularity":5.8371,"vote_count":4560,"poster_path":"/2CAL2433ZeIihfX1Hb2139CX0pW.jpg","release_date":"1995-10-20","vote_average":8.517,"backdrop_path":"/zQDFHYNVVVp9OAYSixYAG1SyX1l.jpg","original_title":"दिलवाले दुल्हनिया ले जायेंगे","original_language":"hi"},{"id":82717,"adult":false,"title":"The Watermill Princess 2","video":false,"overview":"Happily ever after has a bumpy start for a young couple in a magical land when the husband is sent off to battle by a jealous prince.","genre_ids":[10751,14,35],"media_type":"movie","popularity":0.2847,"vote_count":16,"poster_path":"/w7JZAc065vqbpBsbNzx68luh3uh.jpg","release_date":"2000-02-03","vote_average":5.438,"backdrop_path":"/paSx0GuOAexKW5T7afgsSRKsXcS.jpg","original_title":"Princezna ze mlejna 2","original_language":"cs"},{"id":355252,"adult":false,"title":"Rate Me","video":false,"overview":"A portrait of teen escort, 'Coco'.","genre_ids":[],"media_type":"movie","popularity":2.3132,"vote_count":12,"poster_path":"/5aojxYwcHbQ6KgWGE3MeBwjX1HI.jpg","release_date":"2015-05-22","vote_average":5.1,"backdrop_path":"/orJW45NglTMRXi2FHY1etDvDXW1.jpg","original_title":"Rate Me","original_language":"en"},{"id":975399,"adult":false,"title":"Er","video":false,"overview":"","genre_ids":[],"media_type":"movie","popularity":0.0457,"vote_count":36,"poster_path":"/c1KVTD4jJQiwQLHrb4Wpo7tARhP.jpg","release_date":"2020-12-05","vote_average":5.3,"backdrop_path":null,"original_title":"Er","original_language":"it"},{"id":750271,"adult":false,"title":"Hello","video":false,"overview":"I wouldn't answer if I were you' Hello is the story of a young lady who falls prey to an evil killer.. alone in her apartment, eagerly awaiting the return of her boyfriend, the phone rings...","genre_ids":[27],"media_type":"movie","popularity":0.2054,"vote_count":31,"poster_path":"/iEWOZQdrkU4VPo1R2TtOeTJLdTJ.jpg","release_date":"2013-12-23","vote_average":6.1,"backdrop_path":null,"original_title":"Hello","original_language":"en"},{"id":1101886,"adult":false,"title":"HELLO","video":false,"overview":"Through a haze of smoke, coke, and booze; possible futures, pasts, and presents coalesce chaos inside the mind of a man drifting directionless through life. When your future calls, what will you have to say?","genre_ids":[18],"media_type":"movie","popularity":0.2329,"vote_count":22,"poster_path":"/137qvAWKLN661ZQ3l1j14tWmU0D.jpg","release_date":"2021-09-01","vote_average":5.7,"backdrop_path":"/kik5ZuXvgk5VQ54qfjL32KYGEHU.jpg","original_title":"HELLO","original_language":"en"}],"similar_content":[{"id":462605,"adult":false,"title":"Wine War","video":false,"overview":"When a world renowned Chinese sommelier residing in France is contacted by his childhood buddy in China to help him auction for a bottle of 1855 vintage wine on behalf of the Chinese government, he agrees without question. Little does he realize he is about to be sucked into an age-old feud between rivaling vineyards and a historical mystery that might shatter the whole oenological industry.","genre_ids":[35,28],"popularity":0.2547,"vote_count":4,"poster_path":"/ml4xXVCGviddlIQFJi1ojqMRmRL.jpg","release_date":"2017-05-19","vote_average":6.5,"backdrop_path":"/9L5kRXYVHYR22FxlgPkpa8XLS1e.jpg","original_title":"搶紅","original_language":"zh"},{"id":462613,"adult":false,"title":"The Pugilist","v