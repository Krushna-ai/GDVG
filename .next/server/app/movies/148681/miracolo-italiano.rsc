5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Miracolo italiano\",\"description\":\"7 segments about life in 1990s Italy: two MPs from the opposite sides of the political spectrum spend the night together; during their honeymoon, a woman cheats on her husband with her favorite soap opera star; a married man pretends to be ill to seduce his younger nurse; a family discovers that their son's beautiful fiancée is transgender; an unsatisfied single woman is duped by her celebrity crush for Kevin Costner; two best friends want to have fun; a couple on a tropical holiday is fascinated by their indigenous masseuse.\",\"image\":\"https://image.tmdb.org/t/p/w500/zAZWbx1TZDonku6HO65W8EmHD26.jpg\",\"datePublished\":\"1994-12-21\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"IT\",\"inLanguage\":\"it\",\"genre\":[\"Comedy\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4,\"bestRating\":10,\"ratingCount\":30}}"}}],["$","$L10",null,{"initialDrama":{"id":"f47ba3d7-39cb-49de-9273-5c4d4bb298a7","tmdb_id":121514,"imdb_id":"tt0110528","content_type":"movie","title":"Miracolo italiano","original_title":"Miracolo italiano","overview":"7 segments about life in 1990s Italy: two MPs from the opposite sides of the political spectrum spend the night together; during their honeymoon, a woman cheats on her husband with her favorite soap opera star; a married man pretends to be ill to seduce his younger nurse; a family discovers that their son's beautiful fiancée is transgender; an unsatisfied single woman is duped by her celebrity crush for Kevin Costner; two best friends want to have fun; a couple on a tropical holiday is fascinated by their indigenous masseuse.","poster_path":"/zAZWbx1TZDonku6HO65W8EmHD26.jpg","backdrop_path":"/jdAQ3izQqJtd257WKL8XGMlc2lZ.jpg","release_date":"1994-12-21","first_air_date":null,"status":"published","original_language":"it","origin_country":["IT"],"genres":[{"id":35,"name":"Comedy"},"comedy film"],"popularity":5.4588,"vote_average":4,"vote_count":30,"runtime":104,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-26T01:04:48.714845+00:00","updated_at":"2026-02-26T01:04:48.54+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":43711,"name":"Dean Film","logo_path":null,"origin_country":"IT"},{"id":371,"name":"Cecchi Gori Group Tiger Cinematografica","logo_path":"/caz3eGyRd4OW7oR31Aij5ZwjOXD.png","origin_country":"IT"}],"production_countries":[{"name":"Italy","iso_3166_1":"IT"}],"spoken_languages":[{"name":"Italiano","iso_639_1":"it","english_name":"Italian"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[{"id":9706,"name":"anthology"}],"alternative_titles":[{"type":"","title":"Miracolo italiano (Greggio)","iso_3166_1":"IT"}],"videos":[],"watch_providers":{"results":{}},"wikidata_id":"Q3858749","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-26T01:04:48.714845+00:00","region":null,"main_poster":null,"images":{"logos":[{"width":615,"height":269,"file_path":"/22ypsJJhtLDIbM90UzlGkw0SFag.png","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":2.286,"vote_average":0}],"posters":[{"width":656,"height":984,"file_path":"/zAZWbx1TZDonku6HO65W8EmHD26.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":500,"height":750,"file_path":"/tLTcCZ13GIBuH7gKzgQrV9G7SMU.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":2,"aspect_ratio":0.667,"vote_average":1.75}],"backdrops":[{"width":1280,"height":720,"file_path":"/fjkioLUIyKBLHvfLJ4a8Eo2gGXG.jpg","iso_639_1":"cu","iso_3166_1":"CU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/jdAQ3izQqJtd257WKL8XGMlc2lZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/qtUQzw7Ny1BtErAs9mDWXDEg1sK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/h5x2AQOkwDdiQZCZksE0C69yZ5Y.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/fTaYA9x5XcvHSAL0eD26YFxFeK3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/wagp33y1XW07gzC2iEgEJU4FBQt.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/zaiDF8BRH9TpHMEtwazYVwnvut6.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T03:32:16.921+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":104,"tagline":"","homepage":"","overview":"7 segments about life in 1990s Italy: two MPs from the opposite sides of the political spectrum spend the night together; during their honeymoon, a woman cheats on her husband with her favorite soap opera star; a married man pretends to be ill to seduce his younger nurse; a family discovers that their son's beautiful fiancée is transgender; an unsatisfied single woman is duped by her celebrity crush for Kevin Costner; two best friends want to have fun; a couple on a tropical holiday is fascinated by their indigenous masseuse."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":104,"tagline":"","homepage":"","overview":"Film in otto episodi. Una parlamentare di An passa una furibonda notte d'amore con un deputato di Rifondazione; Maria Carla si lascia abbordare durante la proiezione di \"Balla coi lupi\"; Rosalia s'è appena sposata, ma la sera stessa, in discoteca, si fa tentare da un divo delle telenovelas; un ragioniere s'inventa una malattia per approfittare delle grazie di un'infermiera procace; una famiglia scopre che la fidanzata del figlio è un transessuale; un presentatore televisivo s'inventa un'amicizia con Kevin Costner per conquistare una giornalista fanatica del divo; due amiche si raccontano straordinarie avventure erotiche; un marito lascia la moglie alle Seychelles tra le mani di una massaggiatrice e non si accorge che è invece un uomo."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"意大利奇迹","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"7 fragmenten over het leven in het Italië van de jaren negentig: twee parlementsleden van de tegenovergestelde kanten van het politieke spectrum brengen de nacht samen door; tijdens hun huwelijksreis bedriegt een vrouw haar man met haar favoriete soapster; een getrouwde man doet alsof hij ziek is om zijn jongere verpleegster te verleiden; een gezin ontdekt dat de mooie verloofde van hun zoon transgender is; een ontevreden alleenstaande vrouw wordt gedupeerd door haar verliefdheid op Kevin Costner; twee beste vrienden willen plezier hebben; een koppel op een tropische vakantie is gefascineerd door hun inheemse masseuse."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"義大利奇跡","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":38535,"adult":false,"title":"Nineties","video":false,"overview":"Scandalously famous collections of short Italian comedies of the 90s! All that was \"fun\" in those years in Italy - all here! The sea of black humor on all issues - sex, politics, mafia, crime, TV...","genre_ids":[35],"media_type":"movie","popularity":0.3465,"vote_count":116,"poster_path":"/dperiEKRxNMAeAo5UfX7SZ1Mofw.jpg","release_date":"1992-10-30","vote_average":5.491,"backdrop_path":"/fXgN69cYMza4Fg1JRBPRSDtB1XX.jpg","original_title":"Anni 90","original_language":"it"},{"id":57918,"adult":false,"title":"Big","video":false,"overview":"Marco, a nine year old boy, is in love with his elementary teacher, and feels neglected by his workaholic parents. When they forget about his birthday he wishes he could grow up at once. This really happens and Marco begins a new life as an adult. He rents a room in his teacher's flat and she falls in love with him. He even fakes a kidnapping when he runs out of money but he is mistaken for the kidnapper.","genre_ids":[14,35],"media_type":"movie","popularity":0.3001,"vote_count":196,"poster_path":"/7uJk2ykIVkiUM40XolqEkaNO5dH.jpg","release_date":"1987-12-23","vote_average":6.02,"backdrop_path":"/z83OZ8UNcvvrIsiQ8Ye4bFbE1so.jpg","original_title":"Da grande","original_language":"it"},{"id":411088,"adult":false,"title":"The Invisible Guest","video":false,"overview":"Barcelona, Spain. Adrián Doria, a young and successful businessman accused of murder, meets one night with Virginia Goodman, an expert interrogation lawyer, in order to devise a defense strategy.","genre_ids":[18,9648,53],"media_type":"movie","popularity":5.792,"vote_count":4882,"poster_path":"/fptnZJbLzKUHeNlYrAynbyoL5YJ.jpg","release_date":"2017-01-06","vote_average":8.088,"backdrop_path":"/1ZSWFzAP4AZuFCigZZoib2RdcUO.jpg","original_title":"Contratiempo","original_language":"es"},{"id":1032823,"adult":false,"title":"Trap","video":false,"overview":"A father and teen daughter attend a pop concert, where they realize they're at the center of a dark and sinister event.","genre_ids":[80,27,53],"media_type":"movie","popularity":8.0758,"vote_count":2681,"poster_path":"/jwoaKYVqPgYemFpaANL941EF94R.jpg","release_date":"2024-07-31","vote_average":6.237,"backdrop_path":"/nra0mwygGORHlD0Rd84DhQ9jkdf.jpg","original_title":"Trap","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":28.4976,"vote_count":26828,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.903,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":297222,"adult":false,"title":"PK","video":false,"overview":"A stranger in the city asks questions no one has asked before. Known only by his initials, the man's innocent questions and childlike curiosity take him on a journey of love, laughter and letting go.","genre_ids":[35,18,878],"media_type":"movie","popularity":6.4022,"vote_count":1122,"poster_path":"/z2x2Y4tncefsIU7h82gmUM5vnBJ.jpg","release_date":"2014-12-18","vote_average":7.698,"backdrop_path":"/gxfvtq5eYiClS2X7hxAAPBNrbWA.jpg","original_title":"पीके","original_language":"hi"},{"id":264660,"adult":false,"title":"Ex Machina","video":false,"overview":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl.","genre_ids":[18,878],"media_type":"movie","popularity":7.7588,"vote_count":14042,"poster_path":"/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg","release_date":"2015-01-21","vote_average":7.573,"backdrop_path":"/uqOuJ50EtTj7kkDIXP8LCg7G45D.jpg","original_title":"Ex Machina","original_language":"en"},{"id":115,"adult":false,"title":"The Big Lebowski","video":false,"overview":"Jeffrey 'The Dude' Lebowski, a Los Angeles slacker who only wants to bowl and drink White Russians, is mistaken for another Jeffrey Lebowski, a wheelchair-bound millionaire, and finds himself dragged into a strange series of events involving nihilists, adult film producers, ferrets, errant toes, and large sums of money.","genre_ids":[35,80],"media_type":"movie","popularity":8.0204,"vote_count":11962,"poster_path":"/9mprbw31MGdd66LR0AQKoDMoFRv.jpg","release_date":"1998-03-06","vote_average":7.839,"backdrop_path":"/hXsy4XCCHrUk81XoRhcooyWejao.jpg","original_title":"The Big Lebowski","original_language":"en"},{"id":475557,"adult":false,"title":"Joker","video":false,"overview":"During the 1980s, a failed stand-up comedian is driven insane and turns to a life of crime and chaos in Gotham City while becoming an infamous psychopathic crime figure.","genre_ids":[80,53,18],"media_type":"movie","popularity":18.0422,"vote_count":27338,"poster_path":"/udDclJoHjfjb8Ekgsd4FDteOkCU.jpg","release_date":"2019-10-01","vote_average":8.128,"backdrop_path":"/hO7KbdvGOtDdeg0W4Y5nKEHeDDh.jpg","original_title":"Joker","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":19.7563,"vote_count":11389,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":61791,"adult":false,"title":"Rise of the Planet of the Apes","video":false,"overview":"A highly intelligent chimpanzee named Caesar has been living a peaceful suburban life ever since he was born. But when he gets taken to a cruel primate facility, Caesar decides to revolt against those who have harmed him.","genre_ids":[53,28,18,878],"media_type":"movie","popularity":8.9895,"vote_count":12560,"poster_path":"/oqA45qMyyo1TtrnVEBKxqmTPhbN.jpg","release_date":"2011-08-03","vote_average":7.339,"backdrop_path":"/6cCF0KMUO2QmrVsQFujkQduREXX.jpg","original_title":"Rise of the Planet of the Apes","original_language":"en"},{"id":345920,"adult":false,"title":"Collateral Beauty","video":false,"overview":"Retreating from life after a tragedy, a man questions the universe by writing to Love, Time and Death. Receiving unexpected answers, he begins to see how these things interlock and how even loss can reveal moments of meaning and beauty.","genre_ids":[18,10749],"media_type":"movie","popularity":2.2768,"vote_count":5510,"poster_path":"/4vfqosgik5pLb32RpskYifp8PWJ.jpg","release_date":"2016-12-15","vote_average":7.218,"backdrop_path":"/iovi35nPfjbYTw2gRo7uImWblRU.jpg","original_title":"Collateral Beauty","original_language":"en"},{"id":11324,"adult":false,"title":"Shutter Island","video":false,"overview":"World War II soldier-turned-U.S. Marshal Teddy Daniels investigates the disappearance of a patient from a hospital for the criminally insane, but his efforts are compromised by troubling visions and a mysterious doctor.","genre_ids":[18,53,9648],"media_type":"movie","popularity":14.6244,"vote_count":25460,"poster_path":"/nrmXQ0zcZUL8jFLrakWc90IR8z9.jpg","release_date":"2010-02-14","vote_average":8.2,"backdrop_path":"/8xt8AMb1OKC63AdhNSaYBWxB4Iq.jpg","original_title":"Shutter Island","original_language":"en"},{"id":400928,"adult":false,"title":"Gifted","video":false,"overview":"Frank, a single man raising his child prodigy niece Mary, is drawn into a custody battle with his mother.","genre_ids":[18,35],"media_type":"movie","popularity":5.714,"vote_count":5854,"poster_path":"/9Ts7Vc4wLlpI9oox9mkVUE1tBHy.jpg","release_date":"2017-04-07","vote_average":7.999,"backdrop_path":"/aH63TQfTFgAT8tYZs0CjDsqfMo2.jpg","original_title":"Gifted","original_language":"en"},{"id":278,"adult":false,"title":"The Shawshank Redemption","video":false,"overview":"Imprisoned in the 1940s for the double murder of his wife and her lover, upstanding banker Andy Dufresne begins a new life at the Shawshank prison, where he puts his accounting skills to work for an amoral warden. During his long stretch in prison, Dufresne comes to be admired by the other inmates -- including an older prisoner named Red -- for his integrity and unquenchable sense of hope.","genre_ids":[18,80],"media_type":"movie","popularity":33.781,"vote_count":29800,"poster_path":"/9cqNxx0GxF0bflZmeSMuL5tnGzr.jpg","release_date":"1994-09-23","vote_average":8.716,"backdrop_path":"/zfbjgQE1uSd9wiPTX4VzsLi0rGG.jpg","original_title":"The Shawshank Redemption","original_language":"en"},{"id":245891,"adult":false,"title":"John Wick","video":false,"overview":"Ex-hitman John Wick comes out of retirement to track down the gangsters that took everything from him.","genre_ids":[28,53],"media_type":"movie","popularity":9.7043,"vote_count":20493,"poster_path":"/wXqWR7dHncNRbxoEGybEy7QTe9h.jpg","release_date":"2014-10-22","vote_average":7.454,"backdrop_path":"/ff2ti5DkA9UYLzyqhQfI2kZqEuh.jpg","original_title":"John Wick","original_language":"en"},{"id":13510,"adult":false,"title":"Eden Lake","video":false,"overview":"When a young couple goes to a remote wooded lake for a romantic getaway, their quiet weekend is shattered by an aggressive group of local kids. Rowdiness quickly turns to rage as the teens terrorize the couple in unimaginable ways, and a weekend outing becomes a bloody battle for survival.","genre_ids":[27,53],"media_type":"movie","popularity":4.608,"vote_count":2024,"poster_path":"/tOg6ElTe1mJwaCFN0172U4oso22.jpg","release_date":"2008-09-12","vote_average":6.832,"backdrop_path":"/s9v1QZMVhwShQ7415jPhtfqzyjG.jpg","original_title":"Eden Lake","original_language":"en"},{"id":49046,"adult":false,"title":"All Quiet on the Western Front","video":false,"overview":"Paul Baumer and his friends Albert and Muller, egged on by romantic dreams of heroism, voluntarily enlist in the German army. Full of excitement and patriotic fervour, the boys enthusiastically march into a war they believe in. But once on the Western Front, they discover the soul-destroying horror of World War I.","genre_ids":[10752,36,18],"media_type":"movie","popularity":8.1591,"vote_count":4528,"poster_path":"/2IRjbi9cADuDMKmHdLK7LaqQDKA.jpg","release_date":"2022-10-07","vote_average":7.721,"backdrop_path":"/zbOlpFM306PHE7EP1OELCH5qSmS.jpg","original_title":"Im Westen nichts Neues","original_language":"de"},{"id":545609,"adult":false,"title":"Extraction","video":false,"overview":"A hardened gun-for-hire's latest mission becomes a soul-searching race to survive when he's sent into Bangladesh to rescue a drug lord's kidnapped son.","genre_ids":[28,53],"media_type":"movie","popularity":5.7883,"vote_count":6492,"poster_path":"/nygOUcBKPHFTbxsYRFZVePqgPK6.jpg","release_date":"2020-04-23","vote_average":7.297,"backdrop_path":"/1R6cvRtZgsYCkh8UFuWFN33xBP4.jpg","original_title":"Extraction","original_language":"en"}],"similar_content":[{"id":5,"adult":false,"title":"Four Rooms","video":false,"overview":"It's Ted the Bellhop's first night on the job...and the hotel's very unusual guests are about to place him in some outrageous predicaments. It seems that this evening's room service is serving up one unbelievable happening after another.","genre_ids":[35],"popularity":2.8027,"vote_count":2802,"poster_path":"/75aHn1NOYXh4M7L5shoeQ6NGykP.jpg","release_date":"1995-12-09","vote_average":5.889,"backdrop_path":"/c1BaOxC8bo5ACFYkYYxL0bBWRaq.jpg","original_title":"Four Rooms","original_language":"en"},{"id":653593,"adult":false,"title":"Omniboat: A Fast Boat Fantasia","video":false,"overview":"Chronicling the life of Lay'n Pipe, a 47 foot TopGun Cigarette speedboat, from its conception through the end of human civilization. It's not just a speedboat ride, it's a Miami adventure.","genre_ids":[35,12,18],"popularity":0.3316,"vote_count":6,"poster_path":"/mOkJY1gMIEdOHJ2AgDgSknO6gsi.jpg","release_date":"2020-01-26","vote_average":5,"backdrop_path":"/iiet47MoVtPzH0aHvHokXf2sQPq.jpg","original_title":"Omniboat: A Fast Boat Fantasia","original_language":"en"},{"id":657813,"adult":false,"title":"This Is How Love Begins...","video":false,"overview":"Two hilarious short stories set in the milieu of apprentice youth, depicting the amorous travails of teenage boys. In the first story, \"The Sorrows of the Devil's Apprentice\", we see a talkative storekeeper who is constantly advising his charges on how they should behave, unaware that one of the young men has fallen in love with his daughter. Overcoming shyness is also depicted in the second of the stories, entitled \"May I Beg, Helen?\"","genre_ids":[35],"popularity":0.2293,"vote_count":1,"poster_path":"/nM9VcTLCeQ1eiS1DhWQU5wXzFqe.jpg","release_date":"1975-10-31","vote_average":2,"backdrop_path":null,"original_title":"Tak láska začíná...","original_language":"cs"},{"id":3098,"adult":false,"title":"The Tulse Luper Suitcases, Part 2: Vaux to the Sea","video":false,"overview":"A comic study of 20th-century history, reconstructing the life of writer, creator and professional prisoner Tulse Luper. Born in 1911 Newport and last heard of in 1989, Luper’s life is pieced together from the evidence found in 92 suitcases scattered across the globe. In the second of three parts, we follow Luper as he works in a cinema, giving him ample opportunity to cross paths with virtually every artistic device and dramatic character known to man.","genre_ids":[18,12,35,10749],"popularity":0.2902,"vote_count":11,"poster_path":"/49WgZjZoTG8gBYbrnx2wkgevsHU.jpg","release_date":"2004-06-11","vote_average":4.6,"backdrop_path":"/2HvZ71X6OlQyi9AqklolOfIPfjs.jpg","original_title":"The Tulse Luper Suitcases, Part 2: Vaux to the Sea","original_language":"en"},{"id":654403,"adult":false,"title":"30/30 Vision: Three Decades of Strand Releasing","video":false,"overview":"Over 30 filmmakers and friends of Strand Releasing have come together to honor the company’s indelible contribution to independent cinema over the past thirty years. The participating filmmakers have each created a short film for the project, all shot on iPhones.","genre_ids":[35,878,18],"popularity":0.369,"vote_count":6,"poster_path":"/tdRHjL7sWp87mDfDQebnV7AM1RW.jpg","release_date":"2019-12-14","vote_average":5.3,"backdrop_path":"/nOiItOedPFUAvbg4zIsZOzIrrpm.jpg","original_title":"30/30 Vision: Three Decades of Strand Releasing","original_language":"en"},{"id":274883,"adult":false,"title":"01:00 A.M.","video":false,"overview":"A film that foretells three modern-day ghost stories, set in the City of Hong Kong. The first segment deals with a popular singer that mysteriously falls into a deep coma, and the public is unaware that his spirit is detained by the ghost of an obsessed fan of his. His plea for help is only recognized by his nurse. In the second segment, four college girls are assigned an unusual project, and their selected-topic is to \"interview\" the ghost of the \"Braided Woman.\" When they encounter the streets where the ghost was claimed to roam, they find themselves in a mist of terror. In the third segment, two night-duty police officers stumble upon a mysterious crisis when their speed-tracking camera detects a image of an old woman. After the woman's first sighting, the officers encounter her in every place they go, and their only solution is to find out what she wants.","genre_ids":[35,27],"popularity":0.4067,"vote_count":2,"poster_path":"/c8ez78xU8BAXGtVguYr1PPBVgyd.jpg","release_date":"1995-06-02","vote_average":3.5,"backdrop_path":"/oTHrcPiiTCD5raOSH7VhgeTmtCR.jpg","original_title":"夜半1點鐘","original_language":"cn"},{"id":9686,"adult":false,"title":"New York Stories","video":false,"overview":"Three tales of love, ambition, and neurosis unfold in the city that never sleeps. In \"Life Lessons\" (Martin Scorsese), a tormented painter channels heartbreak into his art. In \"Life Without Zoë\" (Francis Ford Coppola), a precocious 12-year-old navigates privilege and loneliness in a Manhattan hotel. And in \"Oedipus Wrecks\" (Woody Allen), a man’s domineering mother literally becomes a looming presence over New York.","genre_ids":[35,18,10749],"popularity":1.8026,"vote_count":394,"poster_path":"/mViGEH5dfsAnUgJmce1RJkFycAi.jpg","release_date":"1989-03-10","vote_average":6.204,"backdrop_path":"/41EKMZkoZY2GSGwGLVsZIRVFViM.jpg","original_title":"New York Stories","original_language":"en"},{"id":464910,"adult":false,"title":"60 Seconds of Solitude in Year Zero","video":false,"overview":"An anthology of one-minute films created by 51 international filmmakers on the theme of the death of cinema. Intended as an ode to 35mm, the film was screened one time only on a purpose-built 20x12 meter public cinema screen in the Port of Tallinn, Estonia, on 22 December 2011. A special projector was constructed for the event which allowed the actual filmstrip to be burnt at the same time as the film was shown.","genre_ids":[18,35,99,16,27,53,9648],"popularity":0.295,"vote_count":6,"poster_path":"/9HcuU9JzCWTweaAL8KsCtTTWa4U.jpg","release_date":"2011-12-22","vote_average":3.8,"backdrop_path":"/oqVGh3bliUZfDYsQRfgZDZkcKxC.jpg","original_title":"60 Sekundit Üksindust Aastal Null","original_language":"en"},{"id":1073054,"adult":false,"title":"God is a Lobster","video":false,"overview":"A girl needs her brother to fulfill an odd request, a good trip turns bad, a CEO gets invited to a mysterious party, and it all centers around the iconic red crustacean.","genre_ids":[35],"popularity":0.2157,"vote_count":1,"poster_path":"/siKeezfHougXPPP4U2NVBV2PCye.jpg","release_date":"2020-10-23","vote_average":10,"backdrop_path":"/gc2AWa8syNuiX8fTsoGWojb1eWP.jpg","original_title":"God is a Lobster","original_language":"en"},{"id":474866,"adult":false,"title":"Waterloo po česku","video":false,"overview":"The short stories about marriage that Vít Olmer wrote for Playboy magazine when Arnošt Lustig was its editor-in-chief are witty, often with absurd punchlines, and clearly show that the author is a keen observer of life around us. He selected five of them for his new Czech comedy, whose common denominator is actor Jiří Krampol, the main character in each of them.","genre_ids":[35],"popularity":0.1677,"vote_count":2,"poster_path":"/lOQykZZQRbxpDPfsArOFxZbA2rZ.jpg","release_date":"2002-09-12","vote_average":1.5,"backdrop_path":"/zaeLhgQDkCF2OtrIsVkVms41x2j.jpg","original_title":"Waterloo po česku","original_language":"cs"},{"id":281707,"adult":false,"title":"The Horror Vault 3","video":false,"overview":"Five new stories of grueling horror: A Christmas Haunting, Zombie Office, Undone, Unchangeable and The Psychomanteum - ghosts, zombies and bloody revenge.","genre_ids":[35,27],"popularity":0.1495,"vote_count":5,"poster_path":"/jCeZX7GfVTN5QkgA0ocS3duNxop.jpg","release_date":"2010-07-13","vote_average":2.2,"backdrop_path":null,"original_title":"The Horror Vault 3","original_language":"en"},{"id":285798,"adult":false,"title":"Tales from the Darkside","video":true,"overview":"A compilation of episodes from the classic '80s horror anthology TV series \"Tales From The Darkside\" for the VHS market.","genre_ids":[27,35],"popularity":0.4297,"vote_count":8,"poster_path":"/sBEK8XJNpOzX6x1ogHU7YTqyhW3.jpg","release_date":"1990-11-29","vote_average":6.375,"backdrop_path":null,"original_title":"Tales from the Darkside","original_language":"en"},{"id":15400,"adult":false,"title":"Mickey's Once Upon a Christmas","video":false,"overview":"Mickey, Minnie, and their famous friends Goofy, Donald, Daisy and Pluto gather together to reminisce about the love, magic and surprises in three wonder-filled stories of Christmas past.","genre_ids":[16,10751,35],"popularity":2.6978,"vote_count":708,"poster_path":"/b6h6HwucncSxn06sMNROJ9apLC5.jpg","release_date":"1999-10-31","vote_average":7.1,"backdrop_path":"/fYVfFDDBTkLYwsRsHhQ1nbpdHDE.jpg","original_title":"Mickey's Once Upon a Christmas","original_language":"en"},{"id":15423,"adult":false,"title":"Snoop Dogg's Hood of Horror","video":false,"overview":"A hip hop horror anthology of three tales of terror told by the Hound of Hell (Snoop Dogg) that revolve around the residents of an inner-city neighborhood whose actions determine where they will go in the afterlife.","genre_ids":[35,27],"popularity":0.7534,"vote_count":79,"poster_path":"/98abrZgWTnGP0noaY2Cli7SNhVb.jpg","release_date":"2006-06-27","vote_average":4.759,"backdrop_path":"/7IYaAEw2dSvUzs9fMDw9Pg7veYk.jpg","original_title":"Snoop Dogg's Hood of Horror","original_language":"en"},{"id":656925,"adult":false,"title":"Dogs and People","video":false,"overview":"The first short story \"Naked in the Thorns\" tells the story of a man whose clothes were taken away by a dog during his bath in the river. In the second short story \"Games of Love\", a retired professor paints a biblical scene of Susan and the old man. In the last short story, \"Fidelity\", the dog Argos perishes while defending his beloved master.","genre_ids":[35],"popularity":0.1974,"vote_count":1,"poster_path":"/1wleBcFoDcdviUPVNMjIEN8usbu.jpg","release_date":"1971-09-03","vote_average":10,"backdrop_path":"/reIGqrJ3vxmbuzMKzJR0hpfNVPu.jpg","original_title":"Psi a lidé","original_language":"cs"},{"id":5709,"adult":false,"title":"Amazon Women on the Moon","video":false,"overview":"Centered around a television station which features a 1950s-style sci-fi movie interspersed with a series of wild commercials, wacky shorts and weird specials, this lampoon of contemporary life and pop culture skewers some of the silliest spectacles ever created in the name of entertainment.","genre_ids":[35,878],"popularity":2.3118,"vote_count":181,"poster_path":"/p77UlHHzyBUCKgdbLosrAnltDgw.jpg","release_date":"1987-09-18","vote_average":5.912,"backdrop_path":"/nAl380kw8qxE7FeSdbbghKuUlp6.jpg","original_title":"Amazon Women on the Moon","original_language":"en"},{"id":1065426,"adult":false,"title":"Metro... In Dino","video":false,"overview":"Follows interconnected stories of several different couples, each facing a crossroads at different stages in their lives and relationships.","genre_ids":[18,10749,35],"popularity":0.761,"vote_count":16,"poster_path":"/AlmzM8CNm2fRJQW2iA9Ittwv0ig.jpg","release_date":"2025-07-04","vote_average":6.063,"backdrop_path":"/8ycWZizMNfYlQE5CdLSbOboNDko.jpg","original_title":"मेट्रो... इन दिनों","original_language":"hi"},{"id":11624,"adult":false,"title":"Everything You Always Wanted to Know About Sex *But Were Afraid to Ask","video":false,"overview":"A collection of seven vignettes, which each address a question concerning human sexuality. From aphrodisiacs to sexual perversion to the mystery of the male orgasm, characters like a court jester, a doctor, a queen and a journalist adventure through lab experiments and game shows, all seeking answers to common questions that many would never ask.","genre_ids":[35],"popularity":1.4975,"vote_count":978,"poster_path":"/A1ZNhNd8FV8kCW39OeDelokT0tv.jpg","release_date":"1972-08-06","vote_average":6.522,"backdrop_path":"/yJsgsM2f6HmfR9I1vTpqjmgD836.jpg","original_title":"Everything You Always Wanted to Know About Sex *But Were Afraid to Ask","original_language":"en"},{"id":883,"adult":false,"title":"Coffee and Cigarettes","video":false,"overview":"An anthology of eleven vignettes featuring star-studded casts of extremely unique individuals who all share the common activities of conversing while drinking coffee and smoking cigarettes.","genre_ids":[35,18],"popularity":1.7717,"vote_count":1020,"poster_path":"/pfG02QCsutx3PIxFS8UY4iM9AsS.jpg","release_date":"2004-03-12","vote_average":6.909,"backdrop_path":"/AtPCvNJVrngHxpoogQsQkIZBs3D.jpg","original_title":"Coffee and Cigarettes","original_language":"en"},{"id":8938,"adult":false,"title":"Tokyo!","video":false,"overview":"Three distinct tales unfold in the bustling city of Tokyo. Merde, a bizarre sewer-dweller, emerges from a manhole and begins terrorizing pedestrians. After his arrest, he stands trial and lashes out at a hostile courtroom. A man who has resigned himself to a life of solitude reconsiders after meeting a charming pizza delivery woman. And finally, a happy young couple find themselves undergoing a series of frightening metamorphoses.","genre_ids":[35,18,14,10749],"popularity":3.7652,"vote_count":257,"poster_path":"/6xbq2EBAOwy0V7bzd1um3sJX1jd.jpg","release_date":"2008-08-16","vote_average":6.891,"backdrop_path":"/hUpP1NUVKCg66xFBWjSSxaLzJx9.jpg","original_title":"TOKYO!","original_language":"ja"}],"external_ids":{"imdb_id":"tt0110528","twitter_id":null,"facebook_id":null,"wikidata_id":"Q3858749","instagram_id":null,"mydramalist_id":"94655"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148681,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"IT","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"1994-12-21T00:00:00.000Z","certification":""}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":"Rome","review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikidata_metadata":{},"mood_tags":null,"trope_tags":null,"vibe_description":null,"ai_enriched_at":null,"ai_enrichment_version":0}}]]
9:{"metadata":[["$","title","0",{"children":"Miracolo italiano | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"7 segments about life in 1990s Italy: two MPs from the opposite sides of the political spectrum spend the night together; during their honeymoon, a woman cheats on her husband with her favorite soap opera star; a married man pretends to be ill to seduce his younger nurse; a family discovers that their son's beautiful fiancée is transgender; an unsatisfied single woman is duped by her celebrity crush for Kevin Costner; two best friends want to have fun; a couple on a tropical holiday is fascinated by their indigenous masseuse."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148681/miracolo-italiano"}],["$","meta","5",{"property":"og:title","content":"Miracolo italiano"}],["$","meta","6",{"property":"og:description","content":"7 segments about life in 1990s Italy: two MPs from the opposite sides of the political spectrum spend the night together; during their honeymoon, a woman cheats on her husband with her favorite soap opera star; a married man pretends to be ill to seduce his younger nurse; a family discovers that their son's beautiful fiancée is transgender; an unsatisfied single woman is duped by her celebrity crush for Kevin Costner; two best friends want to have fun; a couple on a tropical holiday is fascinated by their indigenous masseuse."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148681/miracolo-italiano"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/zAZWbx1TZDonku6HO65W8EmHD26.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Miracolo italiano"}],["$","meta","12",{"name":"twitter:description","content":"7 segments about life in 1990s Italy: two MPs from the opposite sides of the political spectrum spend the night together; during their honeymoon, a woman cheats on her husband with her favorite soap opera star; a married man pretends to be ill to seduce his younger nurse; a family discovers that their son's beautiful fiancée is transgender; an unsatisfied single woman is duped by her celebrity crush for Kevin Costner; two best friends want to have fun; a couple on a tropical holiday is fascinated by their indigenous masseuse."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/zAZWbx1TZDonku6HO65W8EmHD26.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
