9:{"metadata":[["$","title","0",{"children":"Detective Conan: One-Eyed Flashback | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"As police inspector Yamato Kansuke pursues a certain man in the snowy mountains of Nagano, a shadow suddenly appears in his field of vision. While he's distracted, a rifle bullet fired by someone grazes his left eye and causes an avalanche accompanied by a roar. Ten months later, Kansuke, having miraculously survived the avalanche, receives a report that a researcher at the Nobeyama National Astronomical Observatory has been attacked."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148494/detective-conan-one-eyed-flashback"}],["$","meta","5",{"property":"og:title","content":"Detective Conan: One-Eyed Flashback"}],["$","meta","6",{"property":"og:description","content":"As police inspector Yamato Kansuke pursues a certain man in the snowy mountains of Nagano, a shadow suddenly appears in his field of vision. While he's distracted, a rifle bullet fired by someone grazes his left eye and causes an avalanche accompanied by a roar. Ten months later, Kansuke, having miraculously survived the avalanche, receives a report that a researcher at the Nobeyama National Astronomical Observatory has been attacked."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148494/detective-conan-one-eyed-flashback"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/1wl6eAHbIDSz61tGwYTOKlSRvZb.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Detective Conan: One-Eyed Flashback"}],["$","meta","12",{"name":"twitter:description","content":"As police inspector Yamato Kansuke pursues a certain man in the snowy mountains of Nagano, a shadow suddenly appears in his field of vision. While he's distracted, a rifle bullet fired by someone grazes his left eye and causes an avalanche accompanied by a roar. Ten months later, Kansuke, having miraculously survived the avalanche, receives a report that a researcher at the Nobeyama National Astronomical Observatory has been attacked."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/1wl6eAHbIDSz61tGwYTOKlSRvZb.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L12","15",{}]],"error":null,"digest":"$undefined"}
