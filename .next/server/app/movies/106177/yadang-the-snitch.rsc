ess.","genre_ids":[28,12,80,53],"popularity":2.6714,"vote_count":1402,"poster_path":"/5ncvnNPaN73cOqD4muE413sSOyY.jpg","release_date":"2000-06-15","vote_average":6.008,"backdrop_path":"/sblTwYXpm6Nrl4qewg3526lBdlK.jpg","original_title":"Shaft","original_language":"en"},{"id":481,"adult":false,"title":"7 Virgins","video":false,"overview":"Tano is 16-years-old and is already sitting in jail. In 48 hours he’s a free man and off to the wedding of his brother. In the two days he recounts his neighborhood in a section of Sevilla.","genre_ids":[18,80],"popularity":1.9882,"vote_count":89,"poster_path":"/aIGNKsJFfaxIOtxjcLT0uy1HBLU.jpg","release_date":"2005-10-14","vote_average":6.045,"backdrop_path":"/f7ipX1Uc9XJFf2skYp4zptqVzS7.jpg","original_title":"7 vírgenes","original_language":"es"},{"id":507,"adult":false,"title":"Killing Zoe","video":false,"overview":"Zed is an American vault-cracker who travels to Paris to meet up with his old friend Eric. Eric and his gang have planned to raid the only bank in the city which is open on Bastille day. After offering his services, Zed soon finds himself trapped in a situation beyond his control when heroin abuse, poor planning and a call-girl named Zoe all conspire to turn the robbery into a very bloody siege.","genre_ids":[28,80,18,53],"popularity":1.5833,"vote_count":361,"poster_path":"/k3UEKMVnkljOlsO5sLmz87YGlaG.jpg","release_date":"1993-10-01","vote_average":6.198,"backdrop_path":"/lA2EYuuyvWDDSL9rqONIByoQRDy.jpg","original_title":"Killing Zoe","original_language":"en"},{"id":273,"adult":false,"title":"The White Sound","video":false,"overview":"Lukas, a young schizophrenic man, has to deal with a new town, a new relationship, and the paranoia in his head.","genre_ids":[18],"popularity":0.2982,"vote_count":58,"poster_path":"/kYJLb69aANQhf6EvewCnKRpiJ5O.jpg","release_date":"2001-12-31","vote_average":7,"backdrop_path":"/bGpRDAU5b0Ejc64wydAxt2ovx20.jpg","original_title":"Das weisse Rauschen","original_language":"de"},{"id":302,"adu