5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"A Dog's Will\",\"description\":\"The lively João Grilo and the sly Chicó are poor guys living in the hinterland who cheat a bunch of people in a small town in Northeastern Brazil. When they die, they have to be judged by Christ, the Devil and the Virgin Mary before they are admitted to paradise.\",\"image\":\"https://image.tmdb.org/t/p/w500/ctfNJw6gofTjQvhOZeH8QKt0O2x.jpg\",\"datePublished\":\"2000-09-15\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"BR\",\"inLanguage\":\"pt\",\"genre\":[\"Comedy\",\"Drama\",\"Fantasy\",\"Romance\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.4,\"bestRating\":10,\"ratingCount\":1203}}"}}],["$","$L10",null,{"initialDrama":{"id":"5dfe02e5-8490-46aa-b029-faf648d71d67","tmdb_id":40096,"imdb_id":"tt0271383","content_type":"movie","title":"A Dog's Will","original_title":"O Auto da Compadecida","overview":"The lively João Grilo and the sly Chicó are poor guys living in the hinterland who cheat a bunch of people in a small town in Northeastern Brazil. When they die, they have to be judged by Christ, the Devil and the Virgin Mary before they are admitted to paradise.","poster_path":"/ctfNJw6gofTjQvhOZeH8QKt0O2x.jpg","backdrop_path":"/alQqTpmEkxSLgajfEYTsTH6nAKB.jpg","release_date":"2000-09-15","first_air_date":null,"status":"published","original_language":"pt","origin_country":["BR"],"genres":[{"id":35,"name":"Comedy"},{"id":18,"name":"Drama"},{"id":14,"name":"Fantasy"},{"id":10749,"name":"Romance"},"comedy film"],"popularity":2.358,"vote_average":8.4,"vote_count":1203,"runtime":104,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-26T01:27:01.036551+00:00","updated_at":"2026-02-26T01:27:00.849+00:00","tagline":"Lying with faith is not always a sin.","homepage":null,"budget":0,"revenue":4903192,"production_companies":[{"id":11446,"n