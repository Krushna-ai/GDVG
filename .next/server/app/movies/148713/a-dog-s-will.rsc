pect_ratio":0.676,"vote_average":0.166},{"width":1432,"height":2048,"file_path":"/45EjQwGz0Y1HVecXQa2lmzLer6U.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":1,"aspect_ratio":0.699,"vote_average":0.166},{"width":2000,"height":3000,"file_path":"/aovknfdLnFp1IiWi3yvTAg8Gm5k.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":3,"aspect_ratio":0.667,"vote_average":0.166},{"width":1400,"height":2100,"file_path":"/zWL7X5tJ3mXe1U7ZVsqvrYi5Yhh.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1400,"height":2100,"file_path":"/jCCX7XRVVeFjogKAb3qWUpBWWxc.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":960,"height":1440,"file_path":"/1gH7rdVJZMOM3eaF5TO6RB8gB36.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":960,"height":1440,"file_path":"/r2Mow5CZB8CP8OXndc76JSJz7RX.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":667,"height":1000,"file_path":"/6GszETKm1Q3ICLKBgs3Z4th1ym4.jpg","iso_639_1":"hu","iso_3166_1":"HU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":726,"height":1024,"file_path":"/ee5SUAyG8vl62aFslbup8Q3Vr9S.jpg","iso_639_1":"ml","iso_3166_1":"IN","vote_count":0,"aspect_ratio":0.709,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/alQqTpmEkxSLgajfEYTsTH6nAKB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":10,"aspect_ratio":1.778,"vote_average":5.25},{"width":1920,"height":1080,"file_path":"/aiPwQvYaM8t868QritCBrh1B04Y.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/yLalJNnSwJJLZfRVV4xxkqIlY9K.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/xw1gA0lm0AEhGLoR6sE8IYCQAV4.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":1920,"height":1080,"file_path":"/xf5LitErZM7DEDd3nz72D7mtRXR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":0.166}]},"enriched_at":"2026-02-26T04:15:38.049+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"A Dog's Will","runtime":104,"tagline":"Lying with faith is not always a sin.","homepage":"","overview":"The lively João Grilo and the sly Chicó are poor guys living in the hinterland who cheat a bunch of people in a small town in Northeastern Brazil. When they die, they have to be judged by Christ, the Devil and the Virgin Mary before they are admitted to paradise."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"As aventuras de João Grilo, um sertanejo pobre e esperto, e de Chicó, o seu amigo cobarde. No árido Nordeste do Brasil, a dupla luta pelo pão de cada dia enganando os habitantes da pequena cidade de Taperoá, incluindo o padeiro, o padre e o bispo. Quando o temido cangaceiro Severino de Aracaju ataca a cidade, a sobrevivência torna-se impossível e todos encontram a morte. Agora, no além, têm de enfrentar o Juízo Final, onde o Diabo atua como promotor implacável e a única esperança reside na intervenção de Nossa Senhora, a Compadecida."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":104,"tagline":"Mentir com fé nem sempre é pecado.","homepage":"","overview":"As aventuras dos nordestinos João Grilo, um sertanejo pobre e mentiroso, e Chicó, o mais covarde dos homens. Ambos lutam pelo pão de cada dia e atravessam por vários episódios enganando a todos do pequeno vilarejo de Taperoá, no sertão da Paraíba. A salvação da dupla acontece com a aparição da Nossa Senhora. Adaptação da obra de Ariano Suassuna."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Kutyaper","runtime":104,"tagline":"","homepage":"","overview":"Mi történik akkor, amikor két brazil jóbarát elindul Spanyolországba szerencsét próbálni? Egyikük rendkívül kreatív hazudozó, a másik éles elméjű írástudatlan. Míg Chico azzal foglalkozik, hogy minél inkább kiszínezze a velük történt, amúgy sem sima kalandokat, Grilo arra használja pengeként vágó eszét, hogy kimenekítse magukat ezekből a kalamajkákból (amelyek pedig szép számmal akadnak útjuk során)."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"O Auto da Compadecida","runtime":104,"tagline":"","homepage":"","overview":"En el interior del estado de Paríba, en el pueblo de Taperoá, viven João Grilo y Chicó, dos tipos muy pobres que van anunciando por las calles la mejor película del mundo, 'La Pasión de Cristo'. La sesión tiene éxito y ellos ganan algo de dinero pero siguen luchando por la supervivencia. João Grilo y Chicó planean nuevas tretas para conseguir algún dinero y se enfrentan a numeroso desafíos provocando múltiples confusiones causadas por la astucia de João Grilo, siempre acompañado de Chicó."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Сам о сострадании","runtime":104,"tagline":"","homepage":"","overview":"Бойкий Жоао Грило и хитрый Чико - бедные парни, живущие в центральном районе, которые обманывают группу людей в небольшом северо-восточном бразильском городке. Но когда они умирают, им предстоит быть осуждеными Христом, Дьяволом и Девой Марией, прежде чем их допустят в рай."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Will A Dog","runtime":104,"tagline":"","homepage":"","overview":"Le quartier animé João Grilo et chico sournoise sont pauvres gars qui vivent dans l'arrière-pays qui trichent un tas de gens dans une petite ville du Nord-Est du Brésil. Mais quand ils meurent, ils doivent être jugés par le Christ, le diable et la Vierge Marie, avant d'être admis au paradis."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"蛊惑兄弟","runtime":0,"tagline":"","homepage":"","overview":"智高和杰克，一对患难穷兄弟，四出寻找工作，最终在面包店找到差事。但店主极为刻薄，兄弟俩的食物比狗还要差。阴差阳错，他们弄死了店主的狗，更要哄骗神父替小狗祈福，闹出笑话连篇。及后智高暗恋大财主之女路仙霞。但智高过于害羞，久久未能成事；杰克唯有替智高制造机会。一日，镇里来了一班悍匪，洗劫村民之余，更进行杀戮游戏……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Bir Köpeğin Vasiyeti","runtime":0,"tagline":"","homepage":"","overview":"Brezilya'nın hinterlandında yaşayan iki arkadaş, neşeli Joao Grilo ile kurnaz Chico, Brezilya'nın Kuzey Doğusundaki ufak bir kasabada önüne gelen kişileri kazıklamışlardır. Ama öldükleri zaman Cennete girebilmeleri için Hazreti İsa, Şeytan ve Meryem Ana tarafından yargılanacaklardır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":104,"tagline":"","homepage":"","overview":"De opgewekte João Grilo en de sluwe Chicó proberen hun armoedige bestaan in een Braziliaans provinciestadje op te vrolijken door hun grappen en grollen, waarbij ze de rijken en machtigen telkens weer te grazen nemen. Maar wanneer een bandietenbende een ware slachting aanricht in de stad, is ook hun liedje uitgezongen. Gelukkig weten ze bij het voorsorteren in het hiernamaals ook de Duivel, de Maagd Maria en Jezus Christus bij de neus te nemen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"A Dog's Will","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Hra o slitování","runtime":0,"tagline":"","homepage":"","overview":"Snímek vypráví o dobrodružstvích dvou chudých, ale velmi důvtipných přátel Joãa a Chica, kteří žijí na brazilském maloměstě. Ačkoli dostanou práci v místním pekařství, v boji o každodenní chléb podvádějí své spoluobčany až do okamžiku, kdy do města vtrhnou obávaní bandité, kteří zabijí nejen pekaře a jeho ženu. Tím ovšem dobrodružství hrdinů nekončí, ale začíná… Film, inspirovaný starými původem španělskými pikareskními romány, se stal v Brazílii rekordním kasovním trhákem."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":104,"tagline":"","homepage":"","overview":"Dobrodružstvo dvoch chudých, ale veľmi dôvtipných kamarátov Joãa a Chica, ktorý žijú v brazílskom mestečku. Napriek tomu že dostanú prácu v miestnom pekárstve, v boji o každodenný chlieb podvádzajú svojich spoluobčanov až do okamihu, keď do mesta vtrhnú obávaný banditi, ktorý zabijú nielen pekára a jeho ženu. Tým sa však dobrodružstvo hrdinov nekončí, ale začína..."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"O auto da Compadecida","runtime":104,"tagline":"Aventuras. Comedia. Drama","homepage":"","overview":"En el pueblo de Taperoá, en el interior del estado de Paraíba, João Grilo y Chicó, dos tipos muy pobres del nordeste de Brasil, van por las calles anunciando “La Pasión de Cristo”, la mejor película del mundo. La sesión obtiene éxito, ellos ganan un poco de dinero, pero sigue la lucha por la supervivencia. João Grilo y Chicó preparan innúmeros planes para conseguirse algún dinero. Surgen nuevos desafíos, provocando aún más confusiones armadas por la astucia de João Grilo, siempre junto a Chicó..."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"어 독스 윌","runtime":0,"tagline":"","homepage":"","overview":""},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Ауто про співчуття","runtime":104,"tagline":"","homepage":"","overview":"У цьому фентезійному фільмі (адаптація п'єси, на основі якої перед цим був знятий популярний бразильський серіал) розповідається про двох бідних, але кмітливих молодих людей - Джека на прізвисько Цвіркун і Чіко - і їхні пригоди."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"En hunds testamente","runtime":0,"tagline":"","homepage":"","overview":"Två fattiga killar jobbar åt byns rika bagare. De serveras hundmat medan husets hund får fina middagar. En dag byter de ut sin mat mot hundens, vilket hunden inte överlever."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"اراده یک سگ","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Testament psa","runtime":0,"tagline":"","homepage":"","overview":"Film nagrodzony na MFF w Kartagenie i Mar del Plata oraz Brazylijskimi Nagrodami Filmowymi, a w Polsce pokazywany w ramach 3. Festiwalu Filmów Latynoamerykańskich.  \"Testament psa\" to zabawna komedia pełna magii i surrealizmu, która podbiła serca milionów widzów w Brazylii. Główny bohater to przebiegły biedak, który aby zdobyć kawałek chleba wodzi za nos bogatszych, choć głupszych mieszkańców swojej wioski. Konsekwencje jego intryg są katastrofalne dlatego staje przed obliczem (czarnego) Jezusa Chrystusa i Matki Boskiej, aby wytłumaczyć się ze swoich czynów."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"蠱惑兄弟","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"ชูเอา กรีโล และ ชิโก สองเพื่อนยากเจ้าเล่ห์ในบราซิล ดิ้นรนเอาตัวรอดด้วยการหลอกลวงผู้คน หลังตาย พวกเขาต้องเผชิญหน้ากับการพิพากษาครั้งสุดท้ายโดยพระเยซู ซาตาน และพระแม่มารีผู้เมตตา เพื่อตัดสินชะตากรรม"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"}],"reviews_tmdb":[{"id":"64db97057719d7013dd6e7e3","url":"https://www.themoviedb.org/review/64db97057719d7013dd6e7e3","author":"badelf","content":"This film is deeply steeped in Brazilian culture, which may make it inaccessible to some. It's based on a play by Ariano Suassuna, who made his life's mission to preserve Brazilian culture. If you're put off by the surrealistic religion scenes, keep in mind that this spiritualism was still firmly anchored in Brazil in 2000, along with the mash-up of African beliefs - candomblé.\r\n\r\nI loved the Laurel-and-Hardy style of comedy. The film was not short on laughs. The actors' comedic timing is spot on. The direction is totally in the style of the 20th century comedic soaps (novelas), which were (and maybe still are) wildly popular there.","created_at":"2023-08-15T15:17:25.233Z","updated_at":"2023-08-15T15:17:25.333Z","author_details":{"name":"","rating":8,"username":"badelf","avatar_path":null}}],"recommendations":[{"id":52345,"adult":false,"title":"Lisbela and the Prisoner","video":false,"overview":"Lisbela is a young woman who loves going to the movies. Leléu is a con man, going from town to town selling all sort of things and performing as master of ceremonies for some cheesy numbers, such as the woman who gets transformed into a gorilla. He gets involved with Linaura, a sexy and beautiful woman who happens to be the wife of the most frightening hitman of the place. The hitman finds out his wife's affair and goes after Leléu, who has to leave in a hurry. In another town, he meets and falls instantly in love with Lisbela, who is engaged to Douglas, a hillbilly who tries hard to pass for a cosmopolitan Rio de Janeiro dweller.","genre_ids":[35,10749],"media_type":"movie","popularity":0.6118,"vote_count":402,"poster_path":"/raCdo5Hjpd3uXbpSd1JZ7tEyE31.jpg","release_date":"2003-08-22","vote_average":7.826,"backdrop_path":"/eAOOeqa14oCxgdKxLvpDYxCJhqQ.jpg","original_title":"Lisbela e o Prisioneiro","original_language":"pt"},{"id":30127,"adult":false,"title":"The Invisible Woman","video":false,"overview":"A man is abandoned by his wife and then falls in love with his neighbor, the perfect, ideal woman. The only problem: she doesn't exist!","genre_ids":[35],"media_type":"movie","popularity":0.2883,"vote_count":262,"poster_path":"/kcmKSsjIJFHgvOmP0bkst8odCHX.jpg","release_date":"2009-06-05","vote_average":6.1,"backdrop_path":"/cOgCWwLTggdHvPOY5v6Qga9U47J.jpg","original_title":"A Mulher Invisível","original_language":"pt"},{"id":1099413,"adult":false,"title":"The Rogue's Trial","video":false,"overview":"After 20 years missing, João Grilo returns to Taperoá to join his old friend Chicó and, after his story of resurrection spreads, he is disputed as an electoral candidate by the two most powerful politicians in the city.","genre_ids":[35,18],"media_type":"movie","popularity":0.4853,"vote_count":119,"poster_path":"/pRuYcFAq2kUha5ceFe42HR14335.jpg","release_date":"2024-12-25","vote_average":6.7,"backdrop_path":"/90s8Bj0lWL06PW7Whncib6TuHgf.jpg","original_title":"O Auto da Compadecida 2","original_language":"pt"},{"id":49367,"adult":false,"title":"Two Sons of Francisco","video":false,"overview":"The story of Francisco, a very simple and poor man whose dream was to see his children become country music stars, and who made all the efforts to make it happen.","genre_ids":[18,36,10402],"media_type":"movie","popularity":0.7555,"vote_count":418,"poster_path":"/ub8vYfI1zgW4WItWDQ5mT6q5tzQ.jpg","release_date":"2005-08-19","vote_average":6.848,"backdrop_path":"/fzGvBBXOKmSCMTvaUdRkrf9A5kk.jpg","original_title":"2 Filhos de Francisco","original_language":"pt"},{"id":17358,"adult":false,"title":"My Name Ain't Johnny","video":false,"overview":"The true story of João Guilherme Estrella (\"Johnny\"), a young middle-class bon vivant who became a big-time cocaine dealer in Rio de Janeiro in the early 1990s.","genre_ids":[80,18],"media_type":"movie","popularity":0.429,"vote_count":276,"poster_path":"/mKDKutX0bCvg401k68U9Nt7EG0y.jpg","release_date":"2008-01-04","vote_average":7.1,"backdrop_path":"/uAX6NW8kFFrGmc0nJTWL7ajymQf.jpg","original_title":"Meu Nome não é Johnny","original_language":"pt"},{"id":37817,"adult":false,"title":"Ó Paí, Ó: Look at This","video":false,"overview":"During the Carnival in the historical site of Pelourinho, Salvador da Bahia, we follow the lives of the tenants of a falling-to-pieces tenement house who try to get by using creativity, irony, humor, and music.","genre_ids":[10402,35],"media_type":"movie","popularity":0.4817,"vote_count":198,"poster_path":"/BFVGUEQxhORXLRsclpzvGsIIFY.jpg","release_date":"2007-03-30","vote_average":6.955,"backdrop_path":"/aQtgaQ4nOIKaPtbyqLLQs94DRvZ.jpg","original_title":"Ó Paí, Ó","original_language":"pt"},{"id":40823,"adult":false,"title":"The Man Who Copied","video":false,"overview":"A young photocopier operator becomes infatuated with his neighbor and, unable to afford anything from her shop, turns to shady schemes to make money.","genre_ids":[35,18,10749,80],"media_type":"movie","popularity":0.6106,"vote_count":371,"poster_path":"/3RsEkEdLEFd0Q5HThqMd4X8tYZk.jpg","release_date":"2003-06-13","vote_average":7.503,"backdrop_path":"/fN4OThflKQ8ZT1w2qRRIJmLejKk.jpg","original_title":"O Homem Que Copiava","original_language":"pt"},{"id":666,"adult":false,"title":"Central Station","video":false,"overview":"An emotional journey of a former school teacher, who writes letters for illiterate people, and a young boy, whose mother has just died, as they search for the father he never knew.","genre_ids":[18],"media_type":"movie","popularity":1.5937,"vote_count":1025,"poster_path":"/zJvp7XjQ2LhPbDVYhFXyucs40vR.jpg","release_date":"1998-04-03","vote_average":8.135,"backdrop_path":"/lrLIy9OFRQg4VkhrCyolfNXJEUH.jpg","original_title":"Central do Brasil","original_language":"pt"},{"id":34588,"adult":false,"title":"If I Were You","video":false,"overview":"The publicist Claudio and the housewife and choral teacher Helena have been married for many years, but they do not understand and respect the feelings and view point of the partner. Claudio sees Helena as a shopper and \"little teacher of a choral\" and Helena sees Claudio as an insensitive and rough man. On the night before the fiftieth anniversary of Claudio, they changed places with each other.","genre_ids":[35,14],"media_type":"movie","popularity":0.2713,"vote_count":384,"poster_path":"/6ZQCy9TSZr1lhJqLtt6hSEDaxH6.jpg","release_date":"2006-01-06","vote_average":6.384,"backdrop_path":"/6QZzrX0lvtSS5kv2Uc4T1W59M5k.jpg","original_title":"Se Eu Fosse Você","original_language":"pt"},{"id":73624,"adult":false,"title":"The Man from the Future","video":false,"overview":"Zero is a brilliant scientist. However, 20 years ago, he was publicly humiliated when he lost Helena, the love of his life. One day, an accidental experience with one of his inventions causes him to travel back in time to 1991. Having taken the opportunity to change history, Zero returns to own time to find totally changed.","genre_ids":[35,14,878,10749],"media_type":"movie","popularity":1.307,"vote_count":382,"poster_path":"/cWfdBMbe3SodE14h3VptXy6sQZm.jpg","release_date":"2011-09-02","vote_average":7.219,"backdrop_path":"/hel4RhpqHWamrfCueE7TZMEWJ5c.jpg","original_title":"O Homem do Futuro","original_language":"pt"},{"id":21253,"adult":false,"title":"Four Days in September","video":false,"overview":"Fernando, a journalist, and his friend César join terrorist group MR8 in order to fight Brazilian dictatorial regime during the late sixties. César, however, is wounded and captured during a bank hold up. Fernando then decides to kidnap the American ambassador in Brazil and ask for the release of fifteen political prisoners in exchange for his life.","genre_ids":[53,18,36],"media_type":"movie","popularity":0.5611,"vote_count":132,"poster_path":"/zkA5riIdjtanpSoTNh3icKNjACZ.jpg","release_date":"1997-10-01","vote_average":7.5,"backdrop_path":"/mqFaz5jlBNHwCNRxNzLPXLS2vgR.jpg","original_title":"O Que é Isso, Companheiro?","original_language":"pt"},{"id":77710,"adult":false,"title":"My Uncle Killed a Guy","video":false,"overview":"Éder is arrested after confessing the murder of a man. Duca, his nephew, is sure that his uncle confessed the crime to protect his girlfriend, Soraya, ex-wife of the deceased, so he enlists two of his friends to help prove his theory.","genre_ids":[12,35,80],"media_type":"movie","popularity":0.2205,"vote_count":168,"poster_path":"/kJS0v5sjb7LaVMBCSzjll5lB7d7.jpg","release_date":"2004-12-12","vote_average":6.158,"backdrop_path":"/fw7CPAMk8Cums6i4Kz7EbjT3IFt.jpg","original_title":"Meu Tio Matou um Cara","original_language":"pt"},{"id":79934,"adult":false,"title":"The Clown","video":false,"overview":"The life of the owners of Circus Esperança, Puro Sangue e Pangaré, father and son, who plays two clowns. At a certain point, Pangaré starts showing tiredness and sadness for being an unhappy clown.","genre_ids":[35,18],"media_type":"movie","popularity":3.3762,"vote_count":186,"poster_path":"/v2SKEIl8PxRHZGHhrLCIxRKb0UN.jpg","release_date":"2011-10-28","vote_average":7.239,"backdrop_path":"/nuw4wILKmmN9dn6PEN1QnCd9j4B.jpg","original_title":"O Palhaço","original_language":"pt"},{"id":8440,"adult":false,"title":"Carandiru","video":false,"overview":"When a doctor decides to carry out an AIDS prevention program inside Latin America’s largest prison: the Casa de Detenção de São Paulo - Carandiru, he meets the future victims of one of the darkest days in Brazilian History when the State of São Paulo’s Military Police, with the excuse for law enforcement, shot to death 111 people. Based on real facts and on the book written by Dráuzio Varella.","genre_ids":[18],"media_type":"movie","popularity":3.1432,"vote_count":594,"poster_path":"/kKAgIMwQWQ6u4s0c56XKSDX3vAs.jpg","release_date":"2003-03-21","vote_average":7.577,"backdrop_path":"/rhrBU761a5B4w7hhpA9og3fNBCH.jpg","original_title":"Carandiru","original_language":"pt"},{"id":315205,"adult":false,"title":"Good Manners","video":false,"overview":"Clara, a lonely nurse from the outskirts of São Paulo, is hired by mysterious and wealthy Ana as the nanny for her unborn child. The two women develop a strong bond, but soon Clara discovers a terrifying secret about the child.","genre_ids":[14,27,9648,18],"media_type":"movie","popularity":0.389,"vote_count":241,"poster_path":"/dFGfmI9tIWCpEZbGUhI40uznL1F.jpg","release_date":"2017-08-04","vote_average":6.539,"backdrop_path":"/bDmDpjKFHovVk5cQFKeV7njJYtB.jpg","original_title":"As Boas Maneiras","original_language":"pt"},{"id":704264,"adult":false,"title":"Primal: Tales of Savagery","video":true,"overview":"Genndy Tartakovsky's Primal: Tales of Savagery features a caveman and a dinosaur on the brink of extinction. Bonded by tragedy, this unlikely friendship becomes the only hope of survival.","genre_ids":[28,12,16,18],"media_type":"movie","popularity":1.3719,"vote_count":345,"poster_path":"/9NBBkdxH0TjQEBSN2AzeE1sgsF9.jpg","release_date":"2019-11-21","vote_average":8.378,"backdrop_path":"/uBZQOYZLIU9dBmd62fdzBAoropu.jpg","original_title":"Primal: Tales of Savagery","original_language":"en"},{"id":154441,"adult":false,"title":"Till Luck Do Us Part","video":false,"overview":"Check out the hilarious story of luck and misadventures of Tino, a family man whose life is transformed after he wins the lottery. Dazzled by wealth, this boaster spends all his money on a life of luxury and ostentation. But after finding out that he is bankrupt, he faces comical situations: besides not telling his wife he is broke because she is pregnant and cannot get upset, Tino must accept help from his neighbor who is an extremely thrifty financial adviser and the only one capable of getting him out of the rut.","genre_ids":[35],"media_type":"movie","popularity":0.2446,"vote_count":313,"poster_path":"/xAd1DeclHsJ0lnrizw4bTYivFqB.jpg","release_date":"2012-10-05","vote_average":6.4,"backdrop_path":"/aDu4NawDawBsBkRiEJUU2NDKdv.jpg","original_title":"Até que a Sorte nos Separe","original_language":"pt"},{"id":566221,"adult":false,"title":"The Edge of Democracy","video":false,"overview":"A cautionary tale for these times of democracy in crisis—the personal and political fuse to explore one of the most dramatic periods in Brazilian history. With unprecedented access to Presidents Dilma Rousseff and Lula da Silva, we witness their rise and fall and the tragically polarized nation that remains.","genre_ids":[99],"media_type":"movie","popularity":0.5902,"vote_count":374,"poster_path":"/mIbPkZelgguJMPOx9vvCb5oqMxI.jpg","release_date":"2019-01-24","vote_average":7.662,"backdrop_path":"/b8LjR8NjRjrWs6uIfGfrDn0OeI6.jpg","original_title":"Democracia em Vertigem","original_language":"pt"},{"id":598,"adult":false,"title":"City of God","video":false,"overview":"In the poverty-stricken favelas of Rio de Janeiro in the 1970s, two young men choose different paths. Rocket is a budding photographer who documents the increasing drug-related violence of his neighborhood, while José “Zé” Pequeno is an ambitious drug dealer diving into a dangerous life of crime.","genre_ids":[18,80],"media_type":"movie","popularity":8.1472,"vote_count":8021,"poster_path":"/k7eYdWvhYQyRQoU2TB2A2Xu2TfD.jpg","release_date":"2002-08-30","vote_average":8.427,"backdrop_path":"/uvitbjFU4JqvMwIkMWHp69bmUzG.jpg","original_title":"Cidade de Deus","original_language":"pt"},{"id":80426,"adult":false,"title":"Mango Yellow","video":false,"overview":"The lives of a macho butcher, his wife, a lonely waitress, a sadist and a flophouse manager intersect in Recife, Brazil.","genre_ids":[18],"media_type":"movie","popularity":0.862,"vote_count":78,"poster_path":"/jPpO7RQQQ9pHGowyhLdyX0Koeoh.jpg","release_date":"2002-08-14","vote_average":6.6,"backdrop_path":"/dPQBK2pWa5Ht1qGFDakv1B1z2J9.jpg","original_title":"Amarelo Manga","original_language":"pt"}],"similar_content":[{"id":8440,"adult":false,"title":"Carandiru","video":false,"overview":"When a doctor decides to carry out an AIDS prevention program inside Latin America’s largest prison: the Casa de Detenção de São Paulo - Carandiru, he meets the future victims of one of the darkest days in Brazilian History when the State of São Paulo’s Military Police, with the excuse for law enforcement, shot to death 111 people. Based on real facts and on the book written by Dráuzio Varella.","genre_ids":[18],"popularity":3.1432,"vote_count":594,"poster_path":"/kKAgIMwQWQ6u4s0c56XKSDX3vAs.jpg","release_date":"2003-03-21","vote_average":7.577,"backdrop_path":"/rhrBU761a5B4w7hhpA9og3fNBCH.jpg","original_title":"Carandiru","original_language":"pt"},{"id":8463,"adult":false,"title":"Torch Song Trilogy","video":false,"overview":"Arnold Beckoff is looking for love and acceptance, but as a gay man working as a female impersonator in 1970s New York City, neither come easily. After a series of heartaches, Arnold believes he has found the love of his life in Alan, and the couple make plans to adopt. But when tragedy strikes, Arnold's life is shaken to its very core, leading to a confrontation with his overbearing mother, who has never approved of her son's lifestyle.","genre_ids":[35,18,10749],"popularity":0.5473,"vote_count":100,"poster_path":"/uoMiWYfycupTa7PxJ1XUwqnN6gO.jpg","release_date":"1988-12-14","vote_average":7.25,"backdrop_path":"/oDGXonGryIJ38XgPSRC3NfYQ6lg.jpg","original_title":"Torch Song Trilogy","original_language":"en"},{"id":8618,"adult":false,"title":"The History Boys","video":false,"overview":"The story of an unruly class of bright, funny history students at a Yorkshire grammar school in pursuit of an undergraduate place at Oxford or Cambridge. Bounced between their maverick English master, a young and shrewd teacher hired to up their test scores, a grossly out-numbered history teacher, and a headmaster obsessed with results, the boys attempt to pass.","genre_ids":[18],"popularity":0.5165,"vote_count":211,"poster_path":"/klybhTU75GUcQbzdVXUhsZgq1EV.jpg","release_date":"2006-10-02","vote_average":6.626,"backdrop_path":"/A159OAi9EAU9v4l3sfMhpMqSK5v.jpg","original_title":"The History Boys","original_language":"en"},{"id":8749,"adult":false,"title":"Hamlet Goes Business","video":false,"overview":"When Hamlet discovers his father’s deceased body, he finds himself pulled into a power struggle as his scheming uncle attempts to secure a monopoly on the Scandinavian rubber duck industry. Will Hamlet avenge his father? Will he become the king of rubber ducks? Does any of it really matter?","genre_ids":[35,18],"popularity":0.3931,"vote_count":49,"poster_path":"/5OjVh44NDV3m8ePTt2BXMWTzlH5.jpg","release_date":"1987-08-21","vote_average":6.735,"backdrop_path":"/YbzfnWSeZvfABKn0zSyY3IY0IV.jpg","original_title":"Hamlet liikemaailmassa","original_language":"fi"},{"id":1067519,"adult":false,"title":"Emaranhado","video":false,"overview":"","genre_ids":[35,18],"popularity":0.2645,"vote_count":2,"poster_path":"/zUM0KsWTwcR8HTOdVOlS8AgVg4h.jpg","release_date":"2023-02-14","vote_average":10,"backdrop_path":"/nFVly9dCnG4gT1STaXhhyPPJHAt.jpg","original_title":"Emaranhado","original_language":"pt"},{"id":661914,"adult":false,"title":"One Night in Miami...","video":false,"overview":"In the aftermath of Cassius Clay's defeat of Sonny Liston in 1964, the boxer meets with Malcolm X, Sam Cooke and Jim Brown to change the course of history in the segregated South.","genre_ids":[18],"popularity":1.3031,"vote_count":681,"poster_path":"/1DLUb9PTDqXMSgsD7RmiJs7ZJIx.jpg","release_date":"2020-12-25","vote_average":7.021,"backdrop_path":"/yUyuDacqA0IhWqEbPQPXBsEIbPX.jpg","original_title":"One Night in Miami...","original_language":"en"},{"id":8818,"adult":false,"title":"Evita","video":false,"overview":"The hit musical based on the life of Evita Duarte, an Argentinian actress who eventually became the wife of Argentinian president Juan Perón, and the most beloved and hated woman in Argentina.","genre_ids":[36,18],"popularity":3.0158,"vote_count":500,"poster_path":"/hkcSlu3PMw0WyC9vHlvML6nK3Id.jpg","release_date":"1996-12-14","vote_average":6.081,"backdrop_path":"/w1nDjTcn878ao6LeowTSSLBHPj5.jpg","original_title":"Evita","original_language":"en"},{"id":277712,"adult":false,"title":"Two Women","video":false,"overview":"A headstrong young woman is married to land baron. Her feelings for her son's tutor becomes a complex web of unrequited love.","genre_ids":[10749,18],"popularity":0.9747,"vote_count":14,"poster_path":"/q0uEDP7BTjsF4DrrrYLIvLinlrL.jpg","release_date":"2014-11-23","vote_average":6.4,"backdrop_path":"/cbSfIgVMD6pjWVfYbV7Tls0G2Yt.jpg","original_title":"Две женщины","original_language":"ru"},{"id":9267,"adult":false,"title":"And Now for Something Completely Different","video":false,"overview":"A collection of Monty Python's Flying Circus skits from the first two seasons of their British TV series.","genre_ids":[35],"popularity":1.0677,"vote_count":568,"poster_path":"/ajbdFQLvJTlNu4LnVWGnNMb4mZ8.jpg","release_date":"1971-09-28","vote_average":7.203,"backdrop_path":"/aDFKsJW39VxoFcs9oTcMPpMiSZQ.jpg","original_title":"And Now for Something Completely Different","original_language":"en"},{"id":278427,"adult":false,"title":"Family Guy Presents: It's a Trap!","video":false,"overview":"With the Griffins stuck again at home during a blackout, Peter tells the story of “Star Wars Episode VI: Return of the Jedi.”","genre_ids":[16,35,878,28,12,10770],"popularity":1.3797,"vote_count":439,"poster_path":"/nGER5w4H3g2ujD8Zodxn0WXk1l4.jpg","release_date":"2010-12-21","vote_average":6.764,"backdrop_path":"/jbYJbHBsCtcewKM68YIyIzjvdhP.jpg","original_title":"Family Guy Presents: It's a Trap!","original_language":"en"},{"id":9504,"adult":false,"title":"Glengarry Glen Ross","video":false,"overview":"Times are tough at Premiere Properties. Shelley \"the machine\" Levene and Dave Moss are veteran salesmen, but only Ricky Roma is on a hot streak. The new Glengarry sales leads could turn everything around, but the front office is holding them back until these \"losers\" prove themselves. Then someone decides to take matters into his own hands, stealing the Glengarry leads and leaving everyone wondering who did it.","genre_ids":[80,18,9648],"popularity":2.0049,"vote_count":1554,"poster_path":"/zcaEDx8KlVfh4vKfMNLhiSi5Oz4.jpg","release_date":"1992-09-10","vote_average":7.3,"backdrop_path":"/qukaw3P4MOFNdxjhNpClhT9unr8.jpg","original_title":"Glengarry Glen Ross","original_language":"en"},{"id":9523,"adult":false,"title":"Lantana","video":false,"overview":"Plagued with grief over the murder of her daughter, Valerie Somers suspects that her husband John is cheating on her. When Valerie disappears, Detective Leon Zat attempts to solve the mystery of her absence. A complex web of love, sex and deceit emerges -- drawing in four related couples whose various partners are distrustful and suspicious about each other's involvement.","genre_ids":[80,18,9648],"popularity":0.4935,"vote_count":223,"poster_path":"/nTEUCdpDsfVDZJ5H0ndP1EmVtj.jpg","release_date":"2001-10-04","vote_average":6.666,"backdrop_path":"/s9ivjpkMFQNRNXbfGBGgFGcthCS.jpg","original_title":"Lantana","original_language":"en"},{"id":472032,"adult":false,"title":"Buried Treasure","video":false,"overview":"Fortunes shift for a man stricken by tragedy when he unwittingly stumbles upon hidden treasure.","genre_ids":[10749,35,18],"popularity":0.2036,"vote_count":0,"poster_path":"/9hn4SZNASdJ0gUtwBqQ7J0C9KBF.jpg","release_date":"2012-12-01","vote_average":0,"backdrop_path":null,"original_title":"Buried Treasure","original_language":"en"},{"id":472025,"adult":false,"title":"Dublin Oldschool","video":false,"overview":"Join Jason on a chemically enhanced trip through the streets of Dublin as he stumbles from one misguided adventure to another. Somewhere between the DJs, decks, drug busts and hilltop raves, he stumbles across a familiar face from the past, his brother Daniel. Daniel is an educated homeless heroin addict living on the streets of Dublin. The brothers haven’t seen or spoken to each other in years but over a lost weekend they reconnect and reminisce over tunes, trips, their history and their city. Two brothers living on the edge but perhaps they have more in common than they think.","genre_ids":[18],"popularity":0.1723,"vote_count":11,"poster_path":"/mIlNuvcq6lH6MgINGiBcn0dI60r.jpg","release_date":"2018-06-29","vote_average":7.1,"backdrop_path":"/lYTk0kgtJPvNxIMBChgxYj0qYoR.jpg","original_title":"Dublin Oldschool","original_language":"en"},{"id":462919,"adult":false,"title":"Sierra Burgess Is a Loser","video":false,"overview":"A case of mistaken identity results in unexpected romance when the most popular girl in high school and the biggest loser must come together to win over their crushes.","genre_ids":[35,18,10749],"popularity":1.4019,"vote_count":3453,"poster_path":"/vjnHRySiVM4YcBYzjCxw344y9g.jpg","release_date":"2018-09-07","vote_average":6.288,"backdrop_path":"/fdFIVBpq57ZbHok07SI3gNLWUbO.jpg","original_title":"Sierra Burgess Is a Loser","original_language":"en"},{"id":653768,"adult":false,"title":"Neporažení","video":false,"overview":"As Nazi troops prepare to occupy the already truncated Czechoslovak Republic, a small military garrison made up of communists defies orders to abandon their post.","genre_ids":[18,10752],"popularity":0.3331,"vote_count":1,"poster_path":"/nIEMDcMIQFCYvZ8RjnBJdaAFoZz.jpg","release_date":"1956-11-16","vote_average":7,"backdrop_path":null,"original_title":"Neporažení","original_language":"cs"},{"id":462788,"adult":false,"title":"An Enemy of the People","video":false,"overview":"Set in a Norwegian hamlet, an idealistic physician discovers that the town's hot springs are contaminated. But with the community relying on the spa for tourist dollars, his warning to the powers-that-be falls on deaf ears.","genre_ids":[10770,18],"popularity":0.2822,"vote_count":0,"poster_path":"/zRTXTnS7nsd7UuSfv5Kn4GSWT59.jpg","release_date":"1966-12-02","vote_average":0,"backdrop_path":null,"original_title":"An Enemy of the People","original_language":"en"},{"id":465348,"adult":false,"title":"Kuriton sukupolvi","video":false,"overview":"Aging professor of mathematics completes his life's work, a research project that has taken him decades, and climbs up from the boiler room (his study) and back to real life. He can hardly recognize his rebellious teenage kids and materialistic wife who hardly seem to notice his existence. The only person who is interested in the professor's work is Marja, his son's girlfriend and freshman at the university. An innocent infatuation flares up between the old man and the young girl, while the professor's family is only interested in the prize money awarded to the professor by an international jury for his academic achievements.","genre_ids":[35],"popularity":2.5685,"vote_count":4,"poster_path":"/hae0SUmAdA4RbgXkwaWybq9jFMu.jpg","release_date":"1957-03-29","vote_average":6.5,"backdrop_path":null,"original_title":"Kuriton sukupolvi","original_language":"fi"},{"id":656061,"adult":false,"title":"Omena putoaa…","video":false,"overview":"Ilona Jonsson deceives the old industrialist Österberg. He takes pity on the poor girl, who looks like the doppelganger of his dead daughter. Also involved in the plot are Ilona's father, who was supposedly at sea but has just been released from prison, his accomplices Murto-Kalle and Ventti-Ville, a rival criminal gang, and the councilor's relatives, who are guarding their inheritance money.","genre_ids":[35],"popularity":0.1256,"vote_count":3,"poster_path":"/o3hSeQV0Q3mdpnSKtuLgOLtMQ1Y.jpg","release_date":"1952-09-19","vote_average":7,"backdrop_path":null,"original_title":"Omena putoaa…","original_language":"fi"},{"id":1653,"adult":false,"title":"The Motorcycle Diaries","video":false,"overview":"Based on the journals of Che Guevara, leader of the Cuban Revolution. In his memoirs, Guevara recounts adventures he and best friend Alberto Granado had while crossing South America by motorcycle in the early 1950s.","genre_ids":[18],"popularity":2.1759,"vote_count":1401,"poster_path":"/qz2aBYT8CAiJYvX4fRZpJ5G0Oz1.jpg","release_date":"2004-02-06","vote_average":7.411,"backdrop_path":"/o6Ln9k