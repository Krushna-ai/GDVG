37.jpg","iso_639_1":"zh","vote_average":3.334},{"width":1497,"height":2245,"file_path":"/swAJD9Uejz1C2HzkjBAhfT5VUO7.jpg","iso_639_1":"zh","vote_average":3.334},{"width":1500,"height":2250,"file_path":"/l1XyXikmhfRIvkQ3NEQuzBgsJ1S.jpg","iso_639_1":"es","vote_average":3.334},{"width":1000,"height":1482,"file_path":"/1EvtCY1jv0hIrzJhgKY1dtLTDcM.jpg","iso_639_1":"en","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/vSw4efzuMTN5f1dnuL0VVa4BHHl.jpg","iso_639_1":"zh","vote_average":3.334},{"width":535,"height":761,"file_path":"/99qLCYw2zud9CoFOWHmiePAWOl3.jpg","iso_639_1":"es","vote_average":2.278},{"width":1047,"height":1500,"file_path":"/iRTcRVjB3cLglALPV6Tp4RpULcc.jpg","iso_639_1":"ko","vote_average":1.75},{"width":1000,"height":1500,"file_path":"/vUFKHCFiLMXNWqUNlps0Xhao9eJ.jpg","iso_639_1":"it","vote_average":1.75},{"width":2000,"height":3000,"file_path":"/2N7xHzoVHJENJ4Xh2zgR2IxCWUS.jpg","iso_639_1":"ko","vote_average":1.75},{"width":1500,"height":2250,"file_path":"/6OizMjnSQ8oZtMQuiK7opIawcM3.jpg","iso_639_1":"en","vote_average":1.75},{"width":2000,"height":3000,"file_path":"/gSoR1jAlJD0sYU9thyj9ZocScJU.jpg","iso_639_1":"ko","vote_average":1.75},{"width":1497,"height":2245,"file_path":"/aCmvcVs8blmeVm4ipRzSSl9r3xT.jpg","iso_639_1":"en","vote_average":1.222},{"width":1497,"height":2245,"file_path":"/vK7ksV0wHQf1DVJj92c9ZMRGsVD.jpg","iso_639_1":"en","vote_average":1.222},{"width":1400,"height":2100,"file_path":"/9oEKwrgFLTjnsd0dT8zYNVMO7U1.jpg","iso_639_1":"en","vote_average":0.958}],"backdrops":[{"width":3780,"height":2126,"file_path":"/18J7JnWOb9UqfQZHrTCLPz4CeyO.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/xSbillJPLt1LliijiK3LyM25YgY.jpg","iso_639_1":"zh","vote_average":3.334},{"width":3840,"height":2160,"file_path":"/dHnY1f5I7CpjV4LMIjAz7LEnLRA.jpg","iso_639_1":null,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/hlsunTykCOQD18k3lP2lmsVceT9.jpg","iso_639_1":null,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/nagSWhGsQIOwpg1kOFj3BBUXES0.jpg","iso_639_1":null,"vote_average":3.334},{"width":1500,"height":844,"file_path":"/zGq3cmgKzESfC0Vdxb4DQjWy14h.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/gsFSwe0AaCOaQl2utUYHIPpagXZ.jpg","iso_639_1":null,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/iusYrf4bXgA6acdtbLHBx28u7eV.jpg","iso_639_1":null,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/j8LfeaM6xMfkEUHr2xK4YI08HQE.jpg","iso_639_1":null,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/xQgUFU3BmG3UEZkLIhhcLodpshe.jpg","iso_639_1":null,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/oHX5Abgjy7GLZWJaqQ54p8GsQvl.jpg","iso_639_1":null,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/pTvnEMXJtf8PDQM71J6vWOCs0vl.jpg","iso_639_1":null,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/sg0VjfJcPDVoggVnEEqzbN5tlcp.jpg","iso_639_1":null,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/1mG44fHzWywO63K7yQSKWNejdnR.jpg","iso_639_1":null,"vote_average":0.166},{"width":1480,"height":831,"file_path":"/1uUlFfN03UVSZjCm4WQGjhpNmvL.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-02-21T09:14:37.242+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Assassin","runtime":105,"tagline":"","homepage":"","overview":"9th century China. Ten year old general’s daughter Nie Yinniang is abducted by a nun who initiates her into the martial arts, transforming her into an exceptional assassin charged with eliminating cruel and corrupt local governors. One day, having failed in a task, she is sent back by her mistress to the land of her birth, with orders to kill the man to whom she was promised – a cousin who now leads the largest military region in North China. After 13 years of exile, the young woman must confront her parents, her memories and her long-repressed feelings."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"The Assassin","runtime":105,"tagline":"","homepage":"","overview":"Cina, IX secolo. Sotto la dinastia Tang il Paese vive e prospera. A minacciare la sua età d’oro si adoperano gli ambiziosi e corrotti governatori della provincia. L'ordine degli assassini è incaricato di eliminarli. Nelle sue fila serve e combatte Nie Yinniang, abile con la spada e sotto la chioma nera di inchiostro lucente. Rientrata nella sua città e nella sua provincia, dopo l’apprendistato marziale e un esilio lungo tredici anni, Nie Yinniang deve uccidere Tian Ji’an, governatore dissidente della provincia di Weibo. Cugino e sposo a cui fu promessa e poi negata, Tian Ji’an è l’oggetto del suo desiderio. Amato e mai dimenticato, Nie Yinniang lo avvicina e lo sfida senza riuscire ad affondare il fendente. Ostinata a seguire le ragioni del cuore e a vincere quelle della spada, Nie Yinniang abdicherà al suo mandato, congedandosi dall’ordine."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"刺客聂隐娘","runtime":0,"tagline":"","homepage":"","overview":"寂寞天宝后，巍巍大唐辉煌告终，朝廷的威严和向心力进一步削弱。此时藩镇林立，派系迭起，在四分五裂的乱象之下李氏帝国勉强维持着不堪一击的和平与威信。河北三镇之一的魏博镇，刚愎暴戾的节度使田季安（张震 饰）野心勃勃，相机而动。会朝廷派神策兵讨伐王承宗，魏博主从各执一词，纷争连 连。与此同时，田季安自幼被公主道姑带到山上修炼剑法的表妹聂隐娘（舒淇 饰）满师归来。她谨遵师父教诲，奉行杀一人以救万人的理念，接连手刃多位大僚，而此次归来则将狙击目标锁定在田季安身上。剑术已成，道心未坚，侠女聂隐娘捷若猿猱，隐迹红尘…… 本片根据唐人裴刑的传奇小说《聂隐娘》改编，并荣获第68届戛纳电影节竞赛单元最佳导演奖。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"The Assassin","runtime":120,"tagline":"","homepage":"","overview":"Dans la Chine du VIIIe siècle, une femme de l'ordre des Assassins reçoit la mission dangereuse de tuer un dirigeant politique."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"The Assassin","runtime":102,"tagline":"","homepage":"","overview":"800-talet i Kina. En 10-årig flicka från en nobel familj blir kidnappad och uppfostras i exil till att bli en skicklig lönnmördare. En dag återvänder hon till sitt hemland där hon där hon måste möta sina föräldrars och sina egna minnen och reaktioner. Men hon kommer också med ett svårt uppdrag. Ett uppdrag som tvingar henne att välja mellan att offra mannen hon älskar eller bryta med traditionerna inom en uråldrig order av rättfärdiga mördare."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Убийца","runtime":107,"tagline":"","homepage":"","overview":"Китай, время правления династии Танг. Главная героиня — убийца, влюбившаяся в человека, которого ей приказано убить."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"China, século IX. Nie Yinniang, filha de 10 anos de idade do general, é raptada por uma freira que inicia-a nas artes marciais, transformando-a em uma assassina excepcional, encarregada de eliminar governadores locais cruéis e corruptos. Um dia, depois de ter falhado em uma tarefa, ela é enviada de volta por sua senhora para a terra de seu nascimento, com ordens para matar o homem a quem ela foi prometida - um primo que agora lidera a maior região militar no norte da China. Após 13 anos de exílio, a jovem tem de enfrentar seus pais, suas memórias e seus sentimentos há muito reprimidos.\r Uma escrava às ordens de sua senhora, Nie Yinniang deve escolher: sacrificar o homem que ela ama ou quebrar para sempre com o caminho sagrado dos assassinos justos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"The Assassin (La asesina)","runtime":105,"tagline":"Un Film de Hou Hsiao-hsien","homepage":"","overview":"China, siglo IX. Nie Yinniang regresa a casa de su familia tras años de exilio. Educada por una monja que la inicia en las artes marciales, es una auténtica justiciera cuyo objetivo es eliminar a los tiranos. Su maestro le encarga la misión de matar a su primo Tian Ji'an, gobernador disidente de la provincia militar de Weibo. Nie tendrá que elegir: sacrificar al hombre que ama o romper definitivamente con la \"Secta de los Asesinos”."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Η Σιωπηλή Δολοφόνος","runtime":104,"tagline":"","homepage":"","overview":"Δυναστεία των Τανγκ (618-907). Η Νιε Γουιν Νιάνγκ απάγεται μικρή από ταοΐστριες μοναχές. Αφού διδάσκεται και τελειοποιεί την τέχνη του κουνγκ-φου, διατάζεται να πάει πίσω στα μέρη της και να δολοφονήσει τον άντρα που μικρή αγαπούσε, έναν κλέφτη. Η αγάπη της όμως δεν έχει σβήσει, και η Νιε θα αρχίσει να αμφισβητεί την πίστη της στα αφεντικά της."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Zabójczyni","runtime":105,"tagline":"Nauczona posłuszeństwa, wyszkolona, by zabijać musi zgładzić mężczyznę, którego kocha.","homepage":"http://www.kokui-movie.com","overview":"Chiny, IX wiek n.e. 10-letnia córka generała zostaje porwana przez mniszkę, która wprowadza ją w tajniki sztuk walki, zamieniając w doskonale wyszkoloną zabójczynię. Dziewczynka jest bezwzględnie posłuszna, bez wahania eliminuje okrutnych i skorumpowanych namiestników władcy."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"The Assassin","runtime":0,"tagline":"","homepage":"","overview":"I en ung alder bliver prinsessen Nie Yinniang bortført og trænet til at være en koldblodig snigmorder. Nu er hun voksen (og bliver spillet af den smukke Shu Qi), og hendes opgave er at dræbe korrupte politikere. Da hun fejler i et mord, bliver hun sendt tilbage til sin fødeby af sin herre for at dræbe egnens mest indflydelsesrige politiker. Her opdager Yinniang, at hendes nye mål er Tian Jian (Chang Chen), der også er hendes første store kærlighed."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"자객 섭은낭","runtime":0,"tagline":"검보다 강한 사랑, 차마 끊어낼 수 없던 운명의 대결","homepage":"","overview":"9세기 초 당나라. 고위 관료의 딸로 태어났지만, 정혼자와의 이별 후 부패한 관리를 살해하는 암살자로 키워진 섭은낭(서기). 어느 날, 스승으로 부터 위박 지역의 절도사이자 자신이 과거 사랑했던 전계안(장첸)을 암살하라는 명을 받게 된다. 13년 전 그들은 결혼을 약속했던 사이였다. 섭은낭은 부모, 과거, 그리고 오랫동안 억눌러 왔던 감정과 맞서게 된다. 사랑하는 남자를 암살하거나, 혹은 명령을 어기고 암살자로서의 삶을 영원히 끝내야 하는 일생일대의 선택의 기로 앞에서 은낭은 흔들리게 되는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Assassin","runtime":0,"tagline":"","homepage":"","overview":"Filmová báseň jednoho z největších filmařů současnosti zasazená do Číny 9. století je vizuálně omračujícím vyprávěním s prvky žánru wuxia (čínského ekvivalentu středověkého rytířského eposu s prvky fantasy). Jeho hrdinkou je profesionální vražedkyně Nie Yinniang, která poté, co selže ve svém úkolu, dostává od své paní rozkaz vrátit se do svého rodného kraje a zabít muže, jemuž byla kdysi přislíbena - svého bratrance, který dnes velí největší vojenské oblasti v severní Číně."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Ci Ke Nie Yin Niang","runtime":105,"tagline":"","homepage":"","overview":"China in de 9de eeuw. Nie Yinniang, de tienjarige dochter van een generaal, wordt ontvoerd door een non die haar inwijdt in de wereld van de martial arts. Nie Yinniang wordt omgevormd tot een uitzonderlijke huurmoordenaar die wrede en corrupte lokale gouverneurs uitschakelt. Op een dag faalt ze in haar opdracht en wordt ze door haar meesteres teruggestuurd naar haar geboortestreek, met de opdracht om de man te doden aan wie ze was beloofd - een neef die nu de grootste militaire regio in Noord-China leidt. Na 13 jaar ballingschap moet de jonge vrouw de confrontatie aangaan met haar ouders, haar herinneringen en haar lang onderdrukte gevoelens. Nie Yinniang, die de bevelen van haar meesteres slaafs opvolgt, zal nu moeten kiezen: de man van wie ze houdt opofferen of voorgoed breken met het heilige pad der rechtvaardige moordenaars.  (bron: http://www.moviemeter.nl/film/103575)"},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"המתנקשת","runtime":0,"tagline":"","homepage":"","overview":"סין, המאה ה-8. בתו בת ה-10 של גנרל נחטפת בידי נזירה שהופכת אותה למחסלת יוצאת דופן. יום אחד, היא נשלחת חזרה לחבל ארץ ממנו נחטפה, בהוראה לחסל את מנהיגה של יחידה צבאית החולשת על צפון סין. לאחר 13 שנות גלות, על המחסלת הצעירה להתעמת עם הוריה, זיכרונותיה וכמובן רגשותיה. כעת עליה לבחור: האם היא עדיין תחת שליטתה של זו שחטפה וגידלה אותה, או האם היא שבה הביתה. סרטו של הו שיאו-שיין (\"קיץ אצל סבא\"), שזיכה אותו בפרס הבמאי בפסטיבל קאן."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"A Assassina","runtime":0,"tagline":"","homepage":"","overview":"No século VIII, durante a dinastia Tiang, Yinniang (Shu Qi) é uma assassina profissional, treinada com os melhores mestres. Ela é encarregada de matar um homem do governo, mas não consegue cumprir a tarefa quando o vê segurando um bebê recém-nascido. Punida por sua covardia, ela recebe a tarefa mais difícil de sua vida: matar o próprio primo, por quem é apaixonada, e com quem deveria se casar desde a adolescência. Yinniang tem que se confrontar ao passado para cumprir as ordens de sua mestra."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"The Assassin","runtime":105,"tagline":"","homepage":"http://www.kokui-movie.com/","overview":"Im China des neunten Jahrhunderts, zur Zeit der Tang-Dynastie, kehrt die junge Frau Nie Yinniang (Shu Qi) nach 13 langen Jahren der Abwesenheit zurück in ihre Heimat. Einst wurde Nie von einem hochrangingen General entführt und von einer Nonne aufgezogen, die sie in die Kampfkünste einführte. Nie wurde zur tödlichen Attentäterin ausgebildet und soll nun ihren ersten Auftrag ausführen. Aber die Aufgabe ist schrecklich unmenschlich, denn Gouverneur Tian Jian (Chang Chen), den sie umbringen soll, ist der Mann, dem Nie zur Frau versprochen wurde und den sie über alles liebt. Nur politische Widerstände am Hof haben einst die Hochzeit zwischen ihnen verhindert. Nie muss sich entscheiden, ob sie ihre Pflicht als Assassinin erfüllen wird oder auf ihr Herz hören soll. Die politischen Umstände, durch die bei einem erfolgreichen Attentat der minderjährige Sohn Tian Jians und seine machthungrige und intrigante Frau an die Macht kämen, machen die Entscheidung nur noch schwerer..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Suikastçı","runtime":0,"tagline":"","homepage":"","overview":"Üç yıllık sürgünün ardından evine geri dönen genç kadın ustası tarafından kuzenini ve beşik kertmesini öldürmesi için görevlendirilince kuzeni ve onu yetiştirenlere duyduğu sadakat arasında seçim yapmak zorunda kalır. Genç kadın 13 yıl sonra ailesiyle, anılarıyla ve uzun yıllar bastırdığı duygularıyla yüzleşecektir. Rahibenin kölesine dönüşen Yinniang'ın iki seçeneği vardır: Ya sevdiği adamı feda edecektir ya da erdemli suikastçıların kutsal yolundan sonsuza dek sapacaktır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Gyilkos csapás","runtime":105,"tagline":"","homepage":"","overview":"Az isteni eredetűnek tartott Tang-dinasztia uralkodásának idején Nie Yinniang több éves száműzetése után visszatér otthonába, hogy végrehajtson egy küldetést, melynek célja, hogy eltávolítsa a kormányzókat. A nőnek két választása van: vagy feláldozza a férfit, akit szerte, vagy végleg szakít a bérgyilkosok rendjével."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"刺客聶隱娘","runtime":0,"tagline":"","homepage":"","overview":"故事發生在唐朝的安史之亂 40 年後，聶隱娘和魏博節度使田季安兩人為青梅竹馬。然而，藩鎮割據的各方利益下，隱娘成了成人世界下的犧牲者，被迫由道姑帶走，將隱娘訓練成一個身懷絕技、武功高強但殺人不眨眼的殺手！日復一日，隱娘刺殺危害天下的暴虐藩鎮。卻在一次刺殺任務中動了惻隱之心，開始反思自己過去的所作所為，因而無法再殺，對此，道姑將她送回魏博，命她刺殺田季安⋯"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Вбивця","runtime":0,"tagline":"","homepage":"","overview":"Китай, час правління династії Танг. Головна героїня - вбивця, яка закохалася в чоловіка, якого їй наказано вбити."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Убийцата Ние Ин-нян","runtime":105,"tagline":"","homepage":"","overview":"Действието се развива през 8 век по време на китайската династия Тан. Филмът, определен от Variety като \"разточително красива приказка\", е вдъхновен от древния уся наратив за Ние Ин-нян – жената войн, обучена още от дете в тайните на бойните изкуства.  Във филма на Хоу Сяо-сиен Ние Ин-нян е отпратена да живее при даоистка монахиня, която я превръща в изкусен убиец. След дълги години обучение тя се връща отново при семейството си с една единствена цел - да елиминира върховния господар, неин братовчед…"},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"刺客聶隱娘","runtime":0,"tagline":"","homepage":"","overview":"這是一個武功絕倫的女刺客，最後，卻無法殺人的故事。中國的唐代，女刺客是將門之女，十歲那年被師父帶走訓練成頂尖殺手，專門刺殺殘暴的藩鎮節度使，在一次刺殺任務失敗後，師父將她送回故鄉，這次，她要行刺的目標是北方最強大的藩鎮節度使，她的表哥，也是她幼年時候的戀人。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"The Assassin","runtime":0,"tagline":"","homepage":"","overview":"Vi befinner oss i Tang-dynastiet i det niende århundre. Her presenteres vi for Nie Yinniang som i en alder av ti år har blitt kidnappet fra familien av nonnen Jiaxin. Jiaxin har trent henne til å bli en kalkulert leiemorder, men Nie har noen svakheter som gjør at hun ikke klarer å utføre alle oppdragene like målrettet. Derfor sendes hun på en reise som skal straffe henne, men også få henne til å legge fra seg alle emosjonelle bånd. For det er ikke nok at Nie er eksemplarisk i drapets kunst. Alt hun noensinne har vært glad i, må bort. Historien om den kvinnelige leiemorderen tegner både opp en historisk konflikt, og en individuell reise der Nie må velge mellom den verdenen hun ble revet bort fra kun ti år gammel, og hennes ansvar ovenfor nonnen Jiaxin."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"ประกาศิตหงส์สังหาร","runtime":0,"tagline":"","homepage":"","overview":"เรื่องราวในศตวรรตที่ 9 ของจีน ลูกสาวของนายพลนาม นี ยินเหนียง ถูกลักพาตัวไปโดยแม่ชีผู้ที่มีวิทยายุทธเยี่ยมยอด ซึ่งเด็กน้อยได้ถูกฝึกให้กลายเป็นนักฆ่าที่แสนโหดร้ายที่คอยสำเร็จโทษกับพวกขุนนางกังฉิน แต่แล้ววันหนึ่งเมื่อภารกิจล้มเหลว เธอจึงถูกลงโทษด้วยการส่งตัวกลับไปยังไปแผ่นดินเกิด ซึ่งรับคำสั่งให้ฆ่าชายคนที่เธอเคยร่วมสาบาน คนสนิท ผู้ที่ตอนนี้กลายเป็นผู้นำกองทัพที่ยิ่งใหญ่ เธอต้องเลือก สังเวยชีวิตชายคนที่เธอรัก หรือ จะหยุดความหวาดกลัวและทำตามวิถีแห่งนักฆ่า"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Morilka","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Thích Khách Nhiếp Ẩn Nương","runtime":0,"tagline":"","homepage":"","overview":"Nhiếp Ẩn Nương được huấn luyện từ bé để trờ thành một sát thủ máu lạnh, giết người không chớp mắt. Nhưng rồi định mệnh đã bắt cô đối mặt với một tình huống - phải ám sát người chồng được hứa hôn từ lúc mới chào đời - Điền Quý An (Trương Chấn thủ vai). Với trách nhiệm của một sát thủ, Nhiếp ẩn nương phải phục tùng mệnh lệnh của sư phụ, nhưng liệu trí óc có thắng được con tim?"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"黒衣の刺客","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"مزدور","runtime":101,"tagline":"","homepage":"","overview":"یک قاتل زن ماموریت خطرناکی برای کشتن یک رهبر سیاسی در قرن هشتم چین دریافت می‌کند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"القاتلة","runtime":0,"tagline":"","homepage":"","overview":"فتاة بارعة في إستخدام فنون القتال بالسيف تقـبل بمهمة قتل قائـد سياسي في خلال القرن السابع لسلالة تانغ"},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"L’assassina","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"}],"reviews_tmdb":[{"id":"57603cf3c3a36849cf00302a","url":"https://www.themoviedb.org/review/57603cf3c3a36849cf00302a","author":"Reno","content":"$11","created_at":"2016-06-14T17:20:51.088Z","updated_at":"2024-05-16T15:18:29.893Z","author_details":{"name":"Reno","rating":3,"username":"Rangan","avatar_path":"/6ZpVUJzqXMzH35VprEtnX0sNI3.jpg"}}],"recommendations":[{"id":370984,"adult":false,"title":"You Call It Passion","video":false,"overview":"Do Ra-hee, a reporter, is assigned by her boss to report on allegations of sexual assault by Woo Ji-han, an actor. She then investigates the case but uncovers details that may turn it upside down.","genre_ids":[35,10749],"media_type":"movie","popularity":0.6897,"vote_count":29,"poster_path":"/wKO8hzAgJyl2X6chwt9iUGklG0W.jpg","release_date":"2015-11-25","vote_average":6.81,"backdrop_path":"/nVKOtxo68D2cAHKGTR0BnbpJDZA.jpg","original_title":"열정같은소리하고있네","original_language":"ko"},{"id":70555,"adult":false,"title":"The Indian Tomb","video":false,"overview":"Seetha and Harold Berger are rescued from the desert by a caravan and brought to a small village. However, the greedy owner of the house where they are lodged betrays the law of hospitality and reveals their location to Prince Ramigani. The couple tries to escape but is hunted and captured by Ramigani and his men. Meanwhile Irene Rhode and her husband Walter Rhode suspect that Maharaja Chandra is not telling the truth about Harold's destiny. The conspirator Ramigani forces Seetha to accept to get married with Chandra to provoke the wrath of the priests and get the alliance of Prince Padhu and his army. In the meantime, Harold succeeds in escaping from the dungeon and seeks out Seetha to save her.","genre_ids":[12,18,10749],"media_type":"movie","popularity":0.5425,"vote_count":115,"poster_path":"/4N9uLLo7L2xE0uW9cN2FEJluZzt.jpg","release_date":"1959-03-05","vote_average":6.1,"backdrop_path":"/iSYyMGqGazsrdZorFuNHmbgDDgs.jpg","original_title":"Das indische Grabmal","original_language":"de"},{"id":474139,"adult":false,"title":"I Am Nezha","video":false,"overview":"","genre_ids":[16,14,10751],"media_type":"movie","popularity":1.3608,"vote_count":3,"poster_path":"/b0BKVqQ25YenrJQkwGiscrmFQah.jpg","release_date":"2016-10-01","vote_average":7.7,"backdrop_path":"/gS4RrHZpz6yksjubDJLGYIVHapC.jpg","original_title":"我是哪吒","original_language":"zh"},{"id":8128,"adult":false,"title":"The Sorcerer's Apprentice","video":false,"overview":"Krabat, a beggar boy, is lured to become an apprentice to an evil, one-eyed sorcerer. With a number of other boys, he works at the sorcerer's mill while learning black magic. Every Christmas one of the boys has to face the master in a magical duel, where the boy never stands a chance because the master is the only person who is allowed to use a secret spell: The Koraktor.","genre_ids":[16,14],"media_type":"movie","popularity":1.9315,"vote_count":44,"poster_path":"/lTQyzYE1K64CeihYjEwCJZHdauC.jpg","release_date":"1978-03-01","vote_average":7.261,"backdrop_path":"/oJxViODljHew0cLmLl5iOD4t9aN.jpg","original_title":"Čarodějův učeň","original_language":"cs"},{"id":315509,"adult":false,"title":"Helios","video":false,"overview":"Wanted criminal \"Helios\" and his assistant stole a quantity of uranium and plan to produce weapons of mass destruction. They are planning to trade with a terrorist organization in Hong Kong. Chief Inspector Lee Yinming and Inspector Fan Kaming lead the Counter Terrorism Response Unit of the Hong Kong Police Force. Along with a Chinese senior official, a physics professor, and two South Korean weapon experts, they hope to defuse a crisis sufficient to destroy the world.","genre_ids":[28,9648,12,53],"media_type":"movie","popularity":0.9624,"vote_count":62,"poster_path":"/wIL0ggdzO1Y7kOMEZIUV1XzvJ92.jpg","release_date":"2015-04-30","vote_average":5.2,"backdrop_path":"/rxv2tw69MlXqGh4UyH6r5CTZKRi.jpg","original_title":"赤道","original_language":"cn"},{"id":359460,"adult":false,"title":"The Accidental Detective","video":false,"overview":"A cold-case enthusiast blogger and a washed-up veteran detective team up for a joint investigation to rescue their innocent friend who is framed for murder.","genre_ids":[35,80,53],"media_type":"movie","popularity":0.7504,"vote_count":55,"poster_path":"/jnKEUwGxe5vM4XJVElk6wBkX3PC.jpg","release_date":"2015-09-24","vote_average":7.027,"backdrop_path":"/swY1ngZzpC9QaZs2BumCBolLX4P.jpg","original_title":"탐정: 더 비기닝","original_language":"ko"},{"id":338421,"adult":false,"title":"Wild City","video":false,"overview":"Former cop-turned-bar owner Kwok and his underachieving half-brother befriends a drunken woman, they soon find themselves targeted by both her former lover, a high-powered attorney, and the gangster he employs. A suitcase full of tainted cash enters the picture as Kwok finds himself torn between the gangsters and his former colleagues.","genre_ids":[53,28,80,12],"media_type":"movie","popularity":0.8821,"vote_count":34,"poster_path":"/rs8h5dcUfDWtz7QyeJraV6dDp4b.jpg","release_date":"2015-07-25","vote_average":5.7,"backdrop_path":"/arkx8qPdTUfXf9ntvzaMKC7MYd9.jpg","original_title":"迷城","original_language":"cn"},{"id":888602,"adult":false,"title":"Unsilenced","video":false,"overview":"When the Chinese Communist Party launches a brutal crackdown on its citizens, a team of innocent students risk everything to expose the deadly p