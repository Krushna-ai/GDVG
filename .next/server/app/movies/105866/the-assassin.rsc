10:I[9474,["394","static/chunks/394-8afd38919c689f50.js","619","static/chunks/619-9168df9c2a29b74b.js","373","static/chunks/373-a84284acfc563f09.js","926","static/chunks/926-280ceaef91f1c1ec.js","9","static/chunks/9-b084111627993489.js","340","static/chunks/app/movies/%5Bid%5D/%5Bslug%5D/page-605ebf58782d3eea.js"],"default"]
