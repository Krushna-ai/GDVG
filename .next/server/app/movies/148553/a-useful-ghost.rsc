ull,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":3200,"height":1800,"file_path":"/nnZaeiX9BPKUvYJNzkMIGKM9ljt.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":3200,"height":1800,"file_path":"/ceTxx1kqdygf9mBvVOT9oE1OCil.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/nZxI8LN5Xm4fX947KfjfN4Fa69g.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":3200,"height":1800,"file_path":"/yiCmgotht3ngLAGY897kNgvJLky.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":3200,"height":1800,"file_path":"/mwcwWoeGp7LN8GckgMpqB5smBU3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":1280,"height":720,"file_path":"/7jvF9LWg7c5uOjw93t1ol1VboNU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/9FZTaDKoE0uVqrAUupY5vBkaXbn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1691,"height":951,"file_path":"/4bU5Ff8Bfkhr5doiI2S31CA4fM9.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1759,"height":989,"file_path":"/fd977aAoz8NIUN5yP2XVtheuccw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":3840,"height":2160,"file_path":"/qSDZSwpKGD0xrT2V87IYyA8QIGo.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/jPpWSbOIvHDeGFhg9pG8FLoNGjb.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/twHyJmqJ30zHJ7rkTktj5HkcaaB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/ve3BBgUJpDcDKc0n78N5CiPzHAA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/5QEuOs2Xm27e8lSevMCBx4vxMsU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/ycP6lOVO8ZJ24P9MD7wmLMCUWc2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/kpxfBrwDScUxUovSuX1L8NhraVO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/eD72YuNevjcV7td2U7yJPnjOg2Q.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/wusANtnP7i4UupIczJF0QDvDZTT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T03:49:38.526+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"A Useful Ghost","runtime":130,"tagline":"Love sucks.","homepage":"","overview":"Worried about her husband being allergic to dust, Nat, a recently-dead woman, returns as a ghost possessing a vacuum cleaner to clean the house and protect her family from other vengeful ghosts in the house. To become a useful ghost, she needs to get rid of the useless ones."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Fantôme utile","runtime":130,"tagline":"","homepage":"","overview":"March fait le deuil de sa femme Nat, récemment décédée, victime de la pollution due à la poussière. Il découvre que son esprit est revenu en prenant possession de leur aspirateur. Dérangé par un fantôme, apparu suite à la mort d’un ouvrier qui a causé la fermeture de l’usine, sa famille rejette l’étrange relation entre un homme et un fantôme. Tentant de les convaincre de leur amour, Nat se propose de faire le ménage dans l’usine. Pour devenir un fantôme utile, elle doit d’abord éliminer ceux qui ne servent à rien."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"มาร์ช สามีที่กำลังโศกเศร้ากับการเสียชีวิตของภรรยาค้นพบว่า แนท ภรรยากลับจากความตายมาเป็นผีที่สิงในเครื่องดูดฝุ่น ทั้งสองดีใจที่ได้กลับมาอยู่ด้วยกัน ท่ามกลางความไม่พอใจของครอบครัว ที่ไม่ยอมรับความรักระหว่างคนกับผี ทั้งสองพยายามพิสูจน์ความรักครั้งนี้ แนทต้องเสนอตัวเพื่อช่วยกำจัดผีร้ายที่สิงในโรงงานของครอบครัว และเพื่อให้เป็นที่ยอมรับ เธอต้องกำจัดผีตัวอื่นที่ไม่เป็นที่ต้องการเพื่อเป็น “ผีใช้ได้ค่ะ”"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"쓸모 있는 귀신","runtime":130,"tagline":"","homepage":"","overview":"젊은 여자 귀신 낫은 죽음을 거부한 채 진공청소기에 빙의하여 남편 마치를 찾아간다. 그러나 남편의 가족은 두 사람의 재결합을 완강히 반대한다. 그러던 중 그녀의 ′쓸모′를 발견하면서 마지못해 그녀를 받아들이게 된다. 그녀가 맡은 역할은 태국 곳곳을 떠도는 원혼들의 정체를 밝혀내고, 그들을 사후세계로 돌려보내는 일이다. 하지만 그 원혼들은 지난 70년간 태국의 더딘 민주화 과정 속에서 희생된 이들의 영혼이었다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Pożyteczny duch","runtime":130,"tagline":"Nieważne, czy to człowiek, czy duch – bezużyteczność oznacza brak miłości.","homepage":"","overview":"March opłakuje niedawną śmierć swojej żony Nat, ofiary zanieczyszczenia pyłowego. Odkrywa, że ​​jej duch powrócił, gdy przejął kontrolę nad odkurzaczem. Zaniepokojona duchem, który pojawił się po śmierci pracownika, powodującej zamknięcie fabryki, rodzina mężczyzny odrzuca dziwny związek między mężczyzną i duchem. Próbując przekonać ich o swojej miłości, Nat proponuje, że posprząta fabrykę. Aby stać się użytecznym duchem, musi najpierw wyeliminować tych, którzy są bezużyteczni."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"A Useful Ghost","runtime":0,"tagline":"","homepage":"","overview":"March trauert um seine Frau Nat, die kürzlich an den Folgen von Staubverschmutzung gestorben ist. Er entdeckt, dass Nats Geist zurückgekehrt ist und nun in einem Staubsauger weiterlebt. Als ein anderer Geist nach dem Tod eines Arbeiters die Fabrik heimsucht und zum Stillstand bringt, wächst die Angst in der Familie. Marchs Angehörige können seine Beziehung zu einem Geist nicht verstehen und weigern sich, sie zu akzeptieren. Um ihnen zu zeigen, dass ihre Liebe echt ist, bietet Nat an, die Fabrik von Geistern zu reinigen. Doch bevor sie selbst ein nützlicher Geist werden kann, muss sie erst die nutzlosen Geister loswerden"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"有用的鬼","runtime":0,"tagline":"","homepage":"","overview":"過世妻子的鬼魂變成吸塵器回到家中，丈夫接受了「她」。然而，婚姻從來都不是兩人之間的小事，面對婆婆的壓力與政治人物所提供的翻身任務，人與機器之間能否成為續LGBTQ後的非主流愛情模式呢？當有用或無用的準則，成為關鍵突破點，也是當代社會、家庭，甚至一個國家用來衡量生命價值的標竿。為了與丈夫再次生活一起，靈魂附在機器裡的妻子，必須成為一個「有用的鬼」！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"有用的鬼","runtime":0,"tagline":"","homepage":"","overview":"三月正在哀悼因粉尘污染去世的妻子娜特，却发现她的灵魂已附身于一台吸尘器归来。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"關於我老婆轉世成為吸塵機那件事","runtime":0,"tagline":"","homepage":"","overview":"不想被忘記，日夜陪住你。工廠女工因空氣污染去世，卻附身在一部吸塵機守護丈夫，對決一班不甘工傷而死、大肆鬧事的鬼魂。死人再培訓，做個有用鬼，靈幻黑色幽默折射出泰國當代社會變化。死亡並不可怕，可怕在社會忘記那些應該被好好記住的前人。糅合短片前作《間諜之聲》的酷兒視角，並找來《戀愛病發》人氣女星任女主角，帶來悲喜交織、視覺風格強烈的驚人首作，以瘋狂包裝政治寓言，在康城影展影評人周大放異彩。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Корисний привид","runtime":0,"tagline":"","homepage":"","overview":"Навіть після смерті Нат продовжує хвилюватися через алергію чоловіка на пил. Саме тому вона стає привидом і вселяється у порохотяг. Тепер її завдання підтримувати чистоту в будинку й захищати сім’ю від інших мстивих привидів. Щоб стати корисним привидом, їй треба позбутися тих, які користі не приносять."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"A Useful Ghost: Uma Ajuda do Além","runtime":130,"tagline":"","homepage":"https://www.pandorafilmes.com.br/filmes/a-useful-ghost-uma-ajuda-do-alem/","overview":"Depois que sua esposa Nat morre vítima da poluição do ar, March descobre que o espírito dela reencarnou em um aspirador de pó. Embora o casal tente manter seu vínculo além da morte, a família de March rejeita essa relação sobrenatural. Para provar que Nat é um “fantasma útil”, ela decide limpar a fábrica da família — enfrentando segredos do passado e revelando injustiças sociais."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Un fantasma útil","runtime":0,"tagline":"","homepage":"","overview":"Tras la trágica muerte de Nat a causa de la contaminación por polvo, March se ve consumido por el dolor. Pero su vida cotidiana da un vuelco cuando descubre que el espíritu de su mujer se ha reencarnado en una aspiradora. Por absurdo que parezca, su vínculo se reaviva, haciéndose más fuerte que nunca..."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Un fantasma para servirte","runtime":0,"tagline":"","homepage":"","overview":"Tras la trágica muerte de Nat a causa de la contaminación por polvo, March se ve consumido por el dolor. Pero su vida cotidiana da un vuelco cuando descubre que el espíritu de su mujer se ha reencarnado en una aspiradora. Por absurdo que parezca, su vínculo se reaviva, haciéndose más fuerte que nunca..."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Полезный призрак","runtime":0,"tagline":"","homepage":"","overview":"Обеспокоенная тем, что у её мужа Марча аллергия на пыль, недавно умершая Нэт возвращается в качестве призрака, вселившись в пылесос, чтобы убирать дом и защищать свою семью от других мстительных призраков в доме. Чтобы стать полезным призраком, ей нужно избавиться от бесполезных."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"}],"reviews_tmdb":[{"id":"69034275382c17457434cccf","url":"https://www.themoviedb.org/review/69034275382c17457434cccf","author":"Brent Marchant","content":"$11","created_at":"2025-10-30T10:48:21.110Z","updated_at":"2025-10-30T10:48:21.209Z","author_details":{"name":"Brent Marchant","rating":8,"username":"Brent_Marchant","avatar_path":null}}],"recommendations":[{"id":1320414,"adult":false,"title":"The Witness","video":false,"overview":"In Iran, the retired dance teacher Tarlan witnesses her friend Rana's murder by her husband, who is an important government figure. When the police refuse to investigate, Tarlan must decide whether to bow to political pressure or risk her reputation and livelihood in pursuit of justice.","genre_ids":[18],"media_type":"movie","popularity":2.2257,"vote_count":20,"poster_path":"/1tzK329TG6wfzEIx60v3PUlcBDO.jpg","release_date":"2025-04-04","vote_average":7.275,"backdrop_path":"/gclxJhAVzincHlp179yeEbKmSJy.jpg","original_title":"The Witness","original_language":"fa"},{"id":1408208,"adult":false,"title":"Exit 8","video":false,"overview":"A man trapped in an endless sterile subway passageway sets out to find Exit 8. The rules of his quest are simple: do not overlook anything out of the ordinary. If you discover an anomaly, turn back immediately. If you don’t, carry on. Then leave from Exit 8. But even a single oversight will send him back to the beginning. Will he ever reach his goal and escape this infinite corridor?","genre_ids":[27,9648],"media_type":"movie","popularity":24.8979,"vote_count":200,"poster_path":"/cWHmaDXnRPAC9HBbjUBfJW7MxO0.jpg","release_date":"2025-08-28","vote_average":6.3,"backdrop_path":"/3cVrg7tzSf5AgEecYWDOSAzXAeX.jpg","original_title":"８番出口","original_language":"ja"},{"id":744653,"adult":false,"title":"The Thursday Murder Club","video":false,"overview":"A group of senior sleuths passionate about solving cold cases get plunged into a real-life murder mystery in this comic crime caper.","genre_ids":[35,9648,80],"media_type":"movie","popularity":5.2085,"vote_count":908,"poster_path":"/jbnazCHr8S2l2glyvjPTpa4NbEw.jpg","release_date":"2025-08-22","vote_average":6.599,"backdrop_path":"/4KN06gns94rQFoYQWDGunK7Cob4.jpg","original_title":"The Thursday Murder Club","original_language":"en"},{"id":1242011,"adult":false,"title":"Together","video":false,"overview":"Years into their relationship, Tim and Millie find themselves at a crossroads as they move to the country, abandoning all that is familiar in their lives except each other. With tensions already flaring, a nightmarish encounter with a mysterious, unnatural force threatens to corrupt their lives, their love, and their flesh.","genre_ids":[27,10749],"media_type":"movie","popularity":10.8229,"vote_count":947,"poster_path":"/80slKYVM5teFH3kz6ouWrZXveqj.jpg","release_date":"2025-07-28","vote_average":7,"backdrop_path":"/39Niij05MXfibXBsHiUU0Ml0POX.jpg","original_title":"Together","original_language":"en"},{"id":976893,"adult":false,"title":"Perfect Days","video":false,"overview":"Hirayama is content with his life as a toilet cleaner in Tokyo. Outside of his structured routine, he cherishes music on cassette tapes, books, and taking photos of trees. Through unexpected encounters, he reflects on finding beauty in the world.","genre_ids":[18],"media_type":"movie","popularity":5.7733,"vote_count":1797,"poster_path":"/tvUHVSTJV9ITON3oyHaWp7oaAc8.jpg","release_date":"2023-11-10","vote_average":7.785,"backdrop_path":"/hjWxngV6tidwDkfJDEgMjHD2KEz.jpg","original_title":"PERFECT DAYS","original_language":"ja"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":28.4976,"vote_count":26828,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.903,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":19.7563,"vote_count":11390,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":297222,"adult":false,"title":"PK","video":false,"overview":"A stranger in the city asks questions no one has asked before. Known only by his initials, the man's innocent questions and childlike curiosity take him on a journey of love, laughter and letting go.","genre_ids":[35,18,878],"media_type":"movie","popularity":6.4022,"vote_count":1122,"poster_path":"/z2x2Y4tncefsIU7h82gmUM5vnBJ.jpg","release_date":"2014-12-18","vote_average":7.698,"backdrop_path":"/gxfvtq5eYiClS2X7hxAAPBNrbWA.jpg","original_title":"पीके","original_language":"hi"},{"id":11324,"adult":false,"title":"Shutter Island","video":false,"overview":"World War II soldier-turned-U.S. Marshal Teddy Daniels investigates the disappearance of a patient from a hospital for the criminally insane, but his efforts are compromised by troubling visions and a mysterious doctor.","genre_ids":[18,53,9648],"media_type":"movie","popularity":14.6244,"vote_count":25462,"poster_path":"/nrmXQ0zcZUL8jFLrakWc90IR8z9.jpg","release_date":"2010-02-14","vote_average":8.2,"backdrop_path":"/8xt8AMb1OKC63AdhNSaYBWxB4Iq.jpg","original_title":"Shutter Island","original_language":"en"},{"id":475557,"adult":false,"title":"Joker","video":false,"overview":"During the 1980s, a failed stand-up comedian is driven insane and turns to a life of crime and chaos in Gotham City while becoming an infamous psychopathic crime figure.","genre_ids":[80,53,18],"media_type":"movie","popularity":18.0422,"vote_count":27340,"poster_path":"/udDclJoHjfjb8Ekgsd4FDteOkCU.jpg","release_date":"2019-10-01","vote_average":8.128,"backdrop_path":"/hO7KbdvGOtDdeg0W4Y5nKEHeDDh.jpg","original_title":"Joker","original_language":"en"},{"id":693134,"adult":false,"title":"Dune: Part Two","video":false,"overview":"Follow the mythic journey of Paul Atreides as he unites with Chani and the Fremen while on a path of revenge against the conspirators who destroyed his family. Facing a choice between the love of his life and the fate of the known universe, Paul endeavors to prevent a terrible future only he can foresee.","genre_ids":[878,12],"media_type":"movie","popularity":22.2359,"vote_count":7552,"poster_path":"/1pdfLvkbY9ohJlCjQH2CZjjYVvJ.jpg","release_date":"2024-02-27","vote_average":8.13,"backdrop_path":"/ylkdrn23p3gQcHx7ukIfuy2CkTE.jpg","original_title":"Dune: Part Two","original_language":"en"},{"id":13510,"adult":false,"title":"Eden Lake","video":false,"overview":"When a young couple goes to a remote wooded lake for a romantic getaway, their quiet weekend is shattered by an aggressive group of local kids. Rowdiness quickly turns to rage as the teens terrorize the couple in unimaginable ways, and a weekend outing becomes a bloody battle for survival.","genre_ids":[27,53],"media_type":"movie","popularity":4.608,"vote_count":2024,"poster_path":"/tOg6ElTe1mJwaCFN0172U4oso22.jpg","release_date":"2008-09-12","vote_average":6.832,"backdrop_path":"/s9v1QZMVhwShQ7415jPhtfqzyjG.jpg","original_title":"Eden Lake","original_language":"en"},{"id":264660,"adult":false,"title":"Ex Machina","video":false,"overview":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl.","genre_ids":[18,878],"media_type":"movie","popularity":7.7588,"vote_count":14042,"poster_path":"/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg","release_date":"2015-01-21","vote_average":7.573,"backdrop_path":"/uqOuJ50EtTj7kkDIXP8LCg7G45D.jpg","original_title":"Ex Machina","original_language":"en"},{"id":49046,"adult":false,"title":"All Quiet on the Western Front","video":false,"overview":"Paul Baumer and his friends Albert and Muller, egged on by romantic dreams of heroism, voluntarily enlist in the German army. Full of excitement and patriotic fervour, the boys enthusiastically march into a war they believe in. But once on the Western Front, they discover the soul-destroying horror of World War I.","genre_ids":[10752,36,18],"media_type":"movie","popularity":8.1591,"vote_count":4528,"poster_path":"/2IRjbi9cADuDMKmHdLK7LaqQDKA.jpg","release_date":"2022-10-07","vote_average":7.721,"backdrop_path":"/zbOlpFM306PHE7EP1OELCH5qSmS.jpg","original_title":"Im Westen nichts Neues","original_language":"de"},{"id":466272,"adult":false,"title":"Once Upon a Time... in Hollywood","video":false,"overview":"Los Angeles, 1969. TV star Rick Dalton, a struggling actor specializing in westerns, and stuntman Cliff Booth, his best friend, try to survive in a constantly changing movie industry. Dalton is the neighbor of the young and promising actress and model Sharon Tate, who has just married the prestigious Polish director Roman Polanski…","genre_ids":[35,18,53],"media_type":"movie","popularity":14.721,"vote_count":14580,"poster_path":"/8j58iEBw9pOXFD2L0nt0ZXeHviB.jpg","release_date":"2019-07-24","vote_average":7.423,"backdrop_path":"/kKTPv9LKKs5L3oO1y5FNObxAPWI.jpg","original_title":"Once Upon a Time... in Hollywood","original_language":"en"},{"id":37165,"adult":false,"title":"The Truman Show","video":false,"overview":"An insurance salesman begins to suspect that his whole life is actually some sort of reality TV show.","genre_ids":[35,18],"media_type":"movie","popularity":16.282,"vote_count":19835,"poster_path":"/vuza0WqY239yBXOadKlGwJsZJFE.jpg","release_date":"1998-06-04","vote_average":8.151,"backdrop_path":"/aCHn2TXYJfzPXQKA6r9mKPbMlUB.jpg","original_title":"The Truman Show","original_language":"en"},{"id":495764,"adult":false,"title":"Birds of Prey (and the Fantabulous Emancipation of One Harley Quinn)","video":false,"overview":"Harley Quinn joins forces with a singer, an assassin and a police detective to help a young girl who had a hit placed on her after she stole a rare diamond from a crime lord.","genre_ids":[28,80],"media_type":"movie","popularity":6.7382,"vote_count":10694,"poster_path":"/h4VB6m0RwcicVEZvzftYZyKXs6K.jpg","release_date":"2020-02-05","vote_average":6.885,"backdrop_path":"/uozb2VeD87YmhoUP1RrGWfzuCrr.jpg","original_title":"Birds of Prey (and the Fantabulous Emancipation of One Harley Quinn)","original_language":"en"},{"id":634649,"adult":false,"title":"Spider-Man: No Way Home","video":false,"overview":"Peter Parker is unmasked and no longer able to separate his normal life from the high-stakes of being a super-hero. When he asks for help from Doctor Strange the stakes become even more dangerous, forcing him to discover what it truly means to be Spider-Man.","genre_ids":[28,12,878],"media_type":"movie","popularity":25.0407,"vote_count":21603,"poster_path":"/1g0dhYtq4irTY1GPXvft6k4YLjm.jpg","release_date":"2021-12-15","vote_average":7.932,"backdrop_path":"/nqUThBjou0TAWXu93Q4SNFpgqai.jpg","original_title":"Spider-Man: No Way Home","original_language":"en"},{"id":1233413,"adult":false,"title":"Sinners","video":false,"overview":"Trying to leave their troubled lives behind, twin brothers return to their hometown to start again, only to discover that an even greater evil is waiting to welcome them back.","genre_ids":[27,28,53],"media_type":"movie","popularity":35.9627,"vote_count":3782,"poster_path":"/qTvFWCGeGXgBRaINLY1zqgTPSpn.jpg","release_date":"2025-04-16","vote_average":7.49,"backdrop_path":"/nAxGnGHOsfzufThz20zgmRwKur3.jpg","original_title":"Sinners","original_language":"en"},{"id":527774,"adult":false,"title":"Raya and the Last Dragon","video":false,"overview":"Long ago, in the fantasy world of Kumandra, humans and dragons lived together in harmony. But when an evil force threatened the land, the dragons sacrificed themselves to save humanity. Now, 500 years later, that same evil has returned and it’s up to a lone warrior, Raya, to track down the legendary last dragon to restore the fractured land and its divided people.","genre_ids":[16,10751,14,28,12],"media_type":"movie","popularity":6.6023,"vote_count":7181,"poster_path":"/5nVhgCzxKbK47OLIKxCR1syulOn.jpg","release_date":"2021-03-03","vote_average":7.803,"backdrop_path":"/zmX7ObPaRfiCmY6LMalUb1bJDKj.jpg","original_title":"Raya and the Last Dragon","original_language":"en"}],"similar_content":[{"id":661301,"adult":false,"title":"The Hands You Shake","video":false,"overview":"Two criminals misplace $1.5 million of dirty money, wich is discovered by three college grads on their first night in the real world. Feeling this is their only opportunity for success in a bad economy, the graduates soon find themselves plunged into the worst night of their lives as they struggle to hold on to their fortune in this darkly comic thriller.","genre_ids":[80,53,35],"popularity":0.1632,"vote_count":0,"poster_path":"/bEfITkihnK0mYeJgwLcoKVgwgOj.jpg","release_date":"2013-04-08","vote_average":0,"backdrop_path":null,"original_title":"The Hands You Shake","original_language":"en"},{"id":861101,"adult":false,"title":"Pluft, o Fantasminha","video":false,"overview":"A little kid-ghost called Pluft lives with his ghost-mother and ghost-uncle, in a remote house in a desert island. He doesn't even believe people real exist. His world will be thrown upside down, when an evil pirate (Perna de Pau) disembark on the island, after kidnapping the little girl Maribel (daughter of a famous captain), in search of Captain's hidden treasure. Three friendly sailors will help to free the girl. Based on a very well known Brazilian children's play.","genre_ids":[35,10751,14],"popularity":0.456,"vote_count":4,"poster_path":"/iCrD6A21Wmzzm1v2bOVdqD8HxRP.jpg","release_date":"2022-07-21","vote_average":6.5,"backdrop_path":"/4aErColaMWJruY2wer2SsXNDdPC.jpg","original_title":"Pluft, o Fantasminha","original_language":"pt"},{"id":8491,"adult":false,"title":"Weekend at Bernie's","video":false,"overview":"Two young insurance corporation employees try to pretend that their murdered employer is alive by puppeteering his dead body, leading a hitman to attempt to track him down to finish him off.","genre_ids":[35,80],"popularity":2.4666,"vote_count":1104,"poster_path":"/4RtjBkBSqHG46uieHgTtM7oKlpo.jpg","release_date":"1989-07-05","vote_average":6.399,"backdrop_path":"/xbGROemZqyVYrIlMOHKqmV2qmG0.jpg","original_title":"Weekend at Bernie's","original_language":"en"},{"id":8221,"adult":false,"title":"What Have I Done to Deserve This?","video":false,"overview":"A henpecked housewife ekes out a meager existence, surrounded by a host of colorful characters: her ungrateful husband, her delinquent sons, her headstrong mother-in-law, and her sex worker neighbor, among others.","genre_ids":[35,18],"popularity":0.4873,"vote_count":261,"poster_path":"/bibvOtpBuz0SuALgF5GRlmZnmjp.jpg","release_date":"1984-10-25","vote_average":7.107,"backdrop_path":"/dgp3j52f2MeNVrp7PY8A1pCtRZT.jpg","original_title":"¿Qué he hecho yo para merecer esto?","original_language":"es"},{"id":8587,"adult":false,