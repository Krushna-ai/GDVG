ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/aeH8ErePjybUjrdBcglhYvgXkiJ.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/9nEjA6f0tHlbAKybkS0EICZgdEz.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":600,"height":800,"file_path":"/uQV6OhuCYFAyeoYcBG9snDndsgj.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.75,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/kJYeyc1MNpVaxyxkKN5VGUikgz8.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":2026,"height":1140,"file_path":"/ju2i7Is6T4d6u4abdgXsHYkcg2d.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.777,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/iQxvrnEITUiriVnnM3Vf8IFt7c0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/suuUjIKghmlG1fHNWQe62yXhvnY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1499,"height":843,"file_path":"/fsVcOW1yauy7sMeh513AcgggTki.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/oFvwpruNQTrIo4JJERXANpybiPC.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/bvHsYV2XFmKUYeoaY2pj8j9CB4h.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/3GrCggVsUD3DT6UyyuB5Xdx3Sma.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0},{"width":2000,"height":1125,"file_path":"/4koAZom8XztIS6hDa1lEsMZrdjO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/tVkYTx3K253qRqVNxrt6IkLMrAv.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/dRS0SN9hm6dNOyYwty9BWAn1bYH.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/cAIYagqTyOyqdAnKpKH4BrHunh3.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3540,"height":1991,"file_path":"/zSTRJ2eWdE5CeXMnyk8M24c9bXX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/hlMKSiL4G5AAl6ZcYU4cJL63tmx.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/i0Ttryii0NsSIaoaTxQ2rCwzBqV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/cMlC1eK9EE1amEXWJe0Txo1Ggzw.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:51:11.523+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":95,"tagline":"170,000 sq miles of desert. 90 minutes of oxygen. No way out.","homepage":"http://www.experienceburied.com/index.html","overview":"Paul is a U.S. truck driver working in Iraq. After an attack by a group of Iraqis he wakes to find he is buried alive inside a coffin. With only a lighter and a cell phone it's a race against time to escape this claustrophobic death trap."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Погребённый заживо","runtime":95,"tagline":"170 000 кв. миль пустыни. 90 минут кислорода. Выхода нет","homepage":"http://experienceburied.com/","overview":"Герой фильма Пол, воюющий в Ираке по контракту на стороне США, во время одной из боевых стычек теряет сознание и спустя время приходит в себя в странном тесном тёмном месте. Не трудно догадаться, что воспользовавшись зажигалкой, Пол обнаруживает себя похороненным в гробу. Ему предстоит пережить много страшных, психологически тяжёлых, физически невозможных мгновений борьбы за собственную жизнь в попытках выбраться из неожиданной ловушки..."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":95,"tagline":"Il a 90 minutes pour s'en sortir.","homepage":"","overview":"Ouvrez les yeux. Vous êtes dans un espace clos, sous une tonne de terre irakienne avec 90 minutes d’oxygène et pour seule connexion vers l’extérieur un téléphone portable à moitié rechargé. Tel est le destin de Paul, entrepreneur Américain prit en otage et enfermé dans un cercueil. Le temps file et chaque seconde qui passe le rapproche d’une mort certaine…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Toprak Altında","runtime":0,"tagline":"90 dakikalık yaşam mücadelesi","homepage":"","overview":"Paul Conroy Irak'ta görev yapan bir Amerikan askeridir. Bir grup Irak'lı direnişçinin saldırısına uğrayan Paul, gözünü açtığında ölümle burun buruna olduğunu görür. Paul uyandığında kendisini bir tabutun içinde gömülü halde bulmuştur. Oraya nasıl ve kim tarafından getirildiğini bilmemektedir. Ölmemek için zamana karşı yarışmak ve klostrofobinin doruklarındaki bu kabusu atlatmak zorundadır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"I 'Buried' vågner Paul Conroy op levende begravet i en kasse under jorden.Paul er ikke klar til at dø, så en kamp mod alle odds for at blive reddet begynder. Med i kassen har Paul en lighter og en mobiltelefon, der er ved at løbe tør for batteri.Den unge lastbilchauffør og familiefar forsøger desperat at få kontakt til omverdenen og at forstå, hvorfor han er havnet i denne katastrofale situation, og hvem der står bag.Ilten forsvinder langsomt, men sikkert, og den ultimative kamp for overlevelse begynder.I rollen som Paul i 'Buried' ses Ryan Reynolds ('Smokin’ Aces', 'The Proposal')."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Buried - Lebend begraben","runtime":95,"tagline":"","homepage":"","overview":"Paul Conroy erwacht aus einer Bewusstlosigkeit und findet sich in einem Sarg begraben wieder. Das Letzte, an das er sich erinnert: Er war als LKW-Fahrer im Irak unterwegs um Hilfsgüter auszuliefern. Mit einem Handy und einem Feuerzeug ausgestattet bleiben ihm nun nur 90 Minuten, um den Wünschen seiner Entführer zu entsprechen und das Lösegeld für ihn rechtzeitig besorgen zu lassen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"活埋","runtime":0,"tagline":"","homepage":"","overview":"一个美国承包商在伊拉克遭到绑架，醒来后发现自己被人活埋在沙漠的一个棺材里，手边只有手机、打火机和一把小刀，他该怎么办？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Buried - Sepolto","runtime":95,"tagline":"Un accendino. Un cellulare. 90 minuti d'aria.","homepage":"","overview":"Paul (Ryan Reynolds) si ritrova rinchiuso in una cassa di legno a 3 metri sotto terra e con in tasca un cellulare, una matita e un accendino. Grazie a questi 3 elementi, deve capire come è finito in quella cassa, per quale motivo e come fare a guidare i soccorritori fino a lui per poterlo liberare. Mentre i 90 minuti di aria a disposizione scorrono, mantenere la calma è sempre più difficile."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Élve eltemetve..","runtime":0,"tagline":"","homepage":"","overview":"Paul a USA haderő egyik beszállítója Irakban. Egy támadást követően egy koporsóban ébred fel, ahol egy öngyújtó és mobiltelefon van mellette. Hogy hogyan és miért került oda, csak emléktöredékei segítségével tudja kideríteni, ám a visszaszámlálás már megkezdődött, csakhogy a homokszemcsék pergése helyett az éltető oxigén fogyása a mérője. (port.hu)"},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Enterrado","runtime":95,"tagline":"170 000 milhas quadradas de deserto. 90 minutos de oxigénio. Sem saída.","homepage":"","overview":"Paul Conroy (Ryan Reynolds) é um americano que trabalha como motorista de caminhão no Iraque. Ele acorda, sem saber como, enterrado vivo dentro de caixão de madeira. Sem saber o que aconteceu e o porquê de estar ali, ele tem em suas mãos apenas um telefone celular e um isqueiro. Começa então uma tensa corrida contra o tempo e a falta de ar. A pressão aumenta ainda mais quando os sequestradores exigem um resgate milionário para libertá-lo e um vídeo com suas imagens vai parar no YouTube."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Buried (Enterrado)","runtime":93,"tagline":"Su destino no está sellado.","homepage":"","overview":"Después de ser secuestrado, Paul Conroy (Ryan Reynolds), contratista civil en Irak, se despierta enterrado vivo en un viejo ataúd de madera, sin más recursos que un teléfono móvil y un mechero. El teléfono podría ser el único medio que lo salvara de esa mortal pesadilla, pero la precariedad de la cobertura y la escasa batería parecen obstáculos insuperables en su lucha contra el tiempo: sólo dispone de 90 minutos para ser rescatado antes de que se le agote el oxígeno."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Autonkuljettaja Paul Conroy joutuu aavikolla yllätyshyökkäyksen uhriksi. Tilanteen äärimmäinen tukaluus paljastuu kuitenkin vasta Paulin tullessa tajuihinsa. Hänet on haudattu elävältä hallussaan vain sytytin, kännykkä ja hatarat muistikuvat tapahtuneesta. Paniikki ja kuolema kaivautuvat joka henkäisyllä lähemmäs Paulin yrittäessä paeta kynsin ja hampain omista hautajaisistaan. Katsojat haukkovat henkeään kun oudon tapauksen viimeinen naula lyödään arkkuun."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Paul Conroy är amerikan och jobbar i Irak som kontrakterad lastbilschaufför. Under en attack kidnappas han och begravs levande i en träkista i väntan på att kidnapparna ska få ut en lösensumma för honom. Med sig i kistan har han en Zippotändare och en mobiltelefon med låg batterinivå. Vi får följa Pauls desperata försök att få kontakt med omvärlden och ta sig ur sin klaustrofobiska dödsfälla. Det finns begränsat med syre, men obegränsat med panik..."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":95,"tagline":"","homepage":"","overview":"Paul Conroy is een vrachtwagenchauffeur uit de Verenigde Staten die werkzaam is in Irak. Na een aanslag van een groep terroristen wordt Paul wakker in een kist, onder de grond. Hij is levend begraven. Met enkel een aansteker en een mobiele telefoon moet Paul aan deze claustrofobische val proberen te ontsnappen..."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Pohřben zaživa","runtime":95,"tagline":"Statisíce kilometrů pouště. Vzduch na devadesát minut. Žádná cesta ven.","homepage":"","overview":"Paul je řidič kamionu, toho času pracuje jako dodavatel pro vojáky US v Iráku. Po útoku Iráčanů se vzbudí pohřbený v rakvi. U sebe má pouze zapalovač a mobilní telefon. Začíná závod s časem, neboť vzduch v rakvi nevydrží dlouho. S pomocí mobilního telefonu se sice spojí s okolním světem, avšak lidé venku nejsou příliš nápomocní a hledat chlapa v rakvi, kdesi v Irácké poušti, se jim moc nechce. Paul se bude muset spolehnout na to nejlepší, co má – sám na sebe."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Pogrzebany","runtime":95,"tagline":"","homepage":"","overview":"Paul (Ryan Reynolds) jest Amerykaninem pracującym w Iraku. Po ataku przez grupę Irakijczyków budzi się pogrzebany żywcem w trumnie. Ma przy sobie tylko zapalniczkę i komórkę. Prowadzi wyścig z czasem, aby uniknąć śmierci."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Îngropat","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"קבור","runtime":0,"tagline":"","homepage":"","overview":"פול הוא קבלן אמריקאי שעובד בעיראק. אחרי שהוא מותקף ע\"י חבורה של עיראקים הוא שב להכרתו, ומוצא את עצמו קבור בעודו חי, בתוך ארון קבורה מתחת לאדמה. רק עם מצית וטלפון סלולרי בידו, הוא מתחיל במרוץ נגד הזמן, לנסות למצוא דרך להימלט ממלכודת המוות הקלסטרופובית אליה נקלע."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"베리드","runtime":0,"tagline":"","homepage":"","overview":"이라크에서 근무하는 미국인 트럭 운전사 폴 콘로이(라이언 레이놀즈 분). 갑작스런 습격을 받고 눈을 떠보니 그는 어딘가에 묻혀 있다. 직감적으로 그곳이 땅 아래 관 속 임을 안 그. 그에게 주어진 것이라곤 라이터, 칼, 그리고 누구의 것인지 알 수 없는 핸드폰뿐이다. 과연 그는 탈출할 수 있을 것인가?"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":95,"tagline":"Ο χρόνος τελειώνει για τον Paul Conroy.","homepage":"","overview":"Ο Πολ είναι ένας Αμερικανός οδηγός νταλίκας που εργάζεται στο Ιράκ. Ξυπνώντας ύστερα από μία επίθεση Ιρακινών, βρίσκει τον εαυτό του θαμμένο ζωντανό μέσα σε ένα φέρετρο. Με μοναδικό του αντίπαλο τον χρόνο και έχοντας πάνω του μόνο έναν αναπτήρα και ένα κινητό, ο αγώνας για να ξεφύγει από αυτή την κλειστοφοβική παγίδα θανάτου ξεκινά."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Enterrado Vivo","runtime":95,"tagline":"Prenda a respiração.","homepage":"","overview":"Um motorista de caminhão civil no Iraque, Paul Conroy cai nas mãos de rebeldes. Não se sabe quanto tempo depois, Paul acorda em um caixão, com pouco mais além de um isqueiro, um telefone celular e sua ansiedade crescente. Com o oxigênio e a bateria acabando, Paul precisa lutar contra o pânico, o desespero e o delírio enquanto espera por um socorro que pode não chegar a tempo."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Sepultado","runtime":95,"tagline":"El tiempo se agota para Paul Conroy.","homepage":"","overview":"Después de ser secuestrado, Paul Conroy (Ryan Reynolds), contratista civil en Irak, se despierta enterrado vivo en un viejo ataúd de madera, contando únicamente con un teléfono móvil y un mechero. El teléfono es el único medio que puede sacarlo de una pesadilla mortal, pero la precariedad de la cobertura y la escasa batería parecen obstáculos insalvables en su lucha contra el tiempo: sólo dispone de 90 minutos para ser rescatado antes de que se le agote el oxígeno. Interesante film español de suspense, que fue presentado en Sundance 2010 y que levantó mucha expectación."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Погребан","runtime":90,"tagline":"","homepage":"","overview":"Това е историята на човек, чийто кошмар е станал реалност. Пол Конрой е шофьор на камион със стабилно семейство. Един ден той се събужда погребан на 2 метра под земята. Най големият му страх, че ще умре се сбъдва. Пол няма врагове или хора желаещи да му причинят това. В положението, в което се намира, не му остава нищо друго освен да впрегне всички сили и да спаси живота си. Само с телефон и фенерче, Пол трябва от открие и си спомни всички улики от изминалите дни, за да разбере кой го е заровил жив. Но първо трябва да открие местоположението си. С изчерпваща се батерия на телефона и с намаляващ кислород, Пол има само 90 минути, за да успее да оцелее."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Похований живцем","runtime":0,"tagline":"","homepage":"","overview":"Ця історія про боротьбу зі своїм страхом і боротьбу за виживання в непростій ситуації, в якій опинився головний герой фільму. Пол — солдат армії США, що воює в Іраку. Одного разу, в одному з боїв, він втрачає свідомість. Прокинувшись в темному, незрозумілому місці, Пола охоплює жах, оскільки розуміє, що його поховали живцем. В його пам’яті не залишилося спогадів про те, як це сталося, і єдине, про що пам’ятає солдат — це те, що його чекають вдома, і він повинен вибратися з цього мороку."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Pochovaný zaživa","runtime":0,"tagline":"","homepage":"","overview":"Paul je vodičom kamionu, ktorý pracuje ako dodávateľ pre vojakov USA v Iraku. Po útoku Iráčanov sa zobudí pochovaný v rakve. Pri sebe má iba zapaľovač a mobilný telefón. Začína závod s časom, pretože vzduch v rakve nevydrží dlho. Pomocou mobilného telefónu sa však spojí s okolitým svetom, ale ľudia vonku nie sú príliš nápomocní a hľadať ľudí v rakve, kdesi v Iráckej púšti sa moc nechce. Paul sa bude musieť spoľahnúť na najlepšie čo má - sám na seba."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"活埋","runtime":0,"tagline":"","homepage":"","overview":"本片描述一位美國技術人員保羅（萊恩雷諾飾），因受僱於美國承包商而前往伊拉克戰區工作…，災難自此開始。  有天，正在工作的他，突然遭遇一群伊拉克人的襲擊，當場陷入昏迷，醒來時，赫然發現自己受困伸手不見五指的棺材裡。  手邊只有打火機的保羅，逐漸發現，自己被深埋在伊拉克沙漠底下，在這個寬達17萬平方哩的不毛之地，保羅唯能嘗試以手機對外聯絡，焦慮、無助的他，腦際尋思著整件事的來龍去脈…，就在這時，手機突然響起，來電的赫然是綁架他的伊拉克恐怖份子，對方威脅要他限時供出美軍基地情報，否則，他伊拉克工作的同事，逐一被處決的畫面，將透過手機畫面即時影音轉播。  保羅陷入前所未有的天人交戰，單單手上一支手機，要如何自救救人呢？這不但是一場鬥智，更是絕地求生的生存之戰…，分秒浪費不得。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Enterré","runtime":95,"tagline":"Il a 90 minutes pour s'en sortir…","homepage":"","overview":"Ouvrez les yeux. Vous êtes dans un espace clos, sous 1 tonne de terre irakienne avec 90 minutes d’oxygène et pour seule connexion vers l’extérieur un téléphone portable à moitié rechargé. Tel est le destin de Paul, entrepreneur Américain pris en otage et enfermé dans une boîte. Le temps file et chaque seconde qui passe le rapproche d’une morte certaine…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"คนเป็นฝังทั้งเป็น","runtime":0,"tagline":"","homepage":"","overview":"เรื่องราวของ ผู้รับเหมาในอีรัก หลังจากที่เขาถูกกองกำลังฝ่ายร้ายของอีรักโจมตี เมื่อเขาฟื้นขึ้นมาอีกครั้งในโลงศพที่ถูกฝังไว้ใต้ดิน ถูกมัดมือมัดเท้า มีแสงสว่างจากไฟแช็ค และมือถือที่มีแบตเหลือไม่มาก กับการลุ้นว่าเขาจะเอาชีวิตรอดได้อย่างไร?"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Palaidotas gyvas","runtime":0,"tagline":"","homepage":"","overview":"Polas Konrojus (akt. Ryanas Reynoldsas) dar nesiruošia mirti, tačiau pabunda šešios pėdos po žeme. Įveikęs pirmąją panikos bangą, ankštame karste vyrukas randa mobilųjį telefoną ir žiebtuvėlį, bet pristinga atsakymų – kaip jis čia atsidūrė ir kodėl? Irake sunkvežimio vairuotoju dirbęs amerikietis – palaidotas gyvas! Blanki sąmonė, sparčiai senkanti mobiliojo baterija ir mažėjantis deguonis tampa didžiausiais Polo priešais kraupiose lenktynėse su laiku. Grumdamasis su panika, neviltimi ir kliedesiais jis turi tik 90 minučių būti išgelbėtas, prieš išsipildant baisiausiam jo košmarui – kankinančiai mirčiai ankštoje mirties duobėje…"},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Chôn Sống","runtime":0,"tagline":"Sa mạc mênh mông. 90 phút dưỡng khí. Không lối thoát.","homepage":"","overview":"Câu chuyện về Conroy, một tài xế xe tải. Một ngày kia, anh tỉnh dậy thì thấy mình nằm sâu dưới lòng đất mà không hề biết ai đẩy anh vào tình trạng này và tại sao lại bị như vậy. Bị chôn sống dưới đất với một chiếc điện thoại di động và một cái bật lửa, anh ra sức đấu tranh cho sự sống của mình từ dưới địa ngục.  Đấu tranh với nỗi hoảng sợ, tuyệt vọng và mê sảng, khi bật lửa dần cạn kiệt, ôxy để thở hầu như sắp hết, Conroy chỉ có 90 phút để thoát khỏi cái bẫy chết người này trước khi cơn ác mộng tồi tệ nhất của anh trở thành sự thật."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"［リミット］","runtime":0,"tagline":"","homepage":"","overview":"トラック運転手の男が突然何者かの襲撃に遭う。意識を失った彼が次に目を覚ました場所は、地中に埋められた棺型の狭い箱の中だった。刻一刻と酸素がなくなっていくという極限状況の中、男は必死に脱出を図る。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"ცოცხლად დამარხული","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"مدفون","runtime":0,"tagline":"","homepage":"","overview":"بول كونروي، سائق شاحنة أمريكي يعمل في العراق، يستيقظ ليجد نفسه مدفونًا حيًا داخل تابوت خشبي بعد تعرضه لهجوم. بحوزته ولاعة وهاتف محمول فقط، يخوض سباقًا مع الزمن في محاولة يائسة للنجاة من هذا المصير المميت المحاصر بالظلام والقلق."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"活埋","runtime":0,"tagline":"","homepage":"","overview":"本片描述一位美國技術人員保羅（萊恩雷諾飾），因受僱於美國承包商而前往伊拉克戰區工作…，災難自此開始。\r 有天，正在工作的他，突然遭遇一群伊拉克人的襲擊，當場陷入昏迷，醒來時，赫然發現自己受困伸手不見五指的棺材裏。\r 手邊只有打火機的保羅，逐漸發現，自己被深埋在伊拉克沙漠底下，在這個寬達 17 萬平方哩的不毛之地，保羅唯能嘗試以手機對外聯絡，焦慮、無助的他，腦際尋思著整件事的來龍去脈…，就在這時，手機突然響起，來電的赫然是綁架他的伊拉克恐怖份子，對方威脅要他限時供出美軍基地情報，否則，他伊拉克工作的同事，逐一被處決的畫面，將透過手機畫面即時影音轉播。\r 保羅陷入前所未有的天人交戰，單單手上一支手機，要如何自救救人呢？這不但是一場鬥智，更是絕地求生的生存之戰…，分秒浪費不得。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Paul er en amerikansk lastebilsjåfør som jobber i Irak. Etter et angrep fra en gruppe irakere våkner han og oppdager at han er levende begravet i en kiste. Med bare en lighter og en mobiltelefon er det et kappløp mot klokken for å unnslippe denne klaustrofobiske dødsfellen."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"}],"reviews_tmdb":[{"id":"5229d074760ee312bc13e8a2","url":"https://www.themoviedb.org/review/5229d074760ee312bc13e8a2","author":"Andres Gomez","content":"Interesting and entertaining movie getting the maximum from just an actor and a coffin. However, you will feel cheated every now and then when you see how the coffin seems to enlarge and shrink.","created_at":"2013-09-06T12:54:12.308Z","updated_at":"2021-06-23T15:57:22.282Z","author_details":{"name":"Andres Gomez","rating":7,"username":"tanty","avatar_path":null}},{"id":"5ed7ae65528b2e0020736251","url":"https://www.themoviedb.org/review/5ed7ae65528b2e0020736251","author":"SamySam","content":"I really LOVE this movie ! I love films like this and “Entrapped . A Day of Terror” , entirely shooted inside one claustrophobic location :-) only a perfect screenplay can make the film Adrenalinic and not annoying, as of course the set is on few square mq2 !","created_at":"2020-06-03T14:06:29.371Z","updated_at":"2021-06-23T15:58:38.869Z","author_details":{"name":"","rating":null,"username":"SamySam","avatar_path":"/i9Gi6Lgx05hHtufMmgOycA2b0Xb.jpg"}},{"id":"679b72ddceb49e671d345c87","url":"https://www.themoviedb.org/review/679b72ddceb49e671d345c87","author":"CinemaSerf","content":"$11","created_at":"2025-01-30T12:38:53.008Z","updated_at":"2025-01-30T12:38:53.161Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}},{"id":"67ad4d887241eef4869f45db","url":"https://www.themoviedb.org/review/67ad4d887241eef4869f45db","author":"r96sk","content":"$12","created_at":"2025-02-13T01:40:24.977Z","updated_at":"2025-02-13T01:40:25.101Z","author_details":{"name":"","rating":7,"username":"r96sk","avatar_path":"/mwR7rFHoDcobAx1i61I3skzMW3U.jpg"}}],"recommendations":[{"id":8884,"adult":false,"title":"Franklyn","video":false,"overview":"Set between the parallel worlds of contemporary London and the futuristic faith dominated metropolis of Meanwhile City, Franklyn weaves a tale of four souls, whose lives are intertwined by fate, romance and tragedy. As these worlds collide, a single bullet determines the destiny of these four characters.","genre_ids":[14,53,18],"media_type":"movie","popularity":0.9896,"vote_count":382,"poster_path":"/5yns10om8I19j4OHy1zoVRilAnw.jpg","release_date":"2008-10-16","vote_average":6,"backdrop_path":"/6hQgTpZVNHrLafE6IeSAoThQwkH.jpg","original_title":"Franklyn","original_language":"en"},{"id":42296,"adult":false,"title":"Catfish","video":false,"overview":"Nev, a 24-year-old New York-based photographer, has no idea what he's in for when Abby, an eight-year-old girl from rural Michigan, contacts him on Facebook, seeking permission to paint one of his photographs. When he receives her remarkable painting, Nev begins a friendship and correspondence with Abby's family. But things really get interesting when he develops a cyber-romance with Abby's attractive older sister, Megan, a musician and model. Prompted by some startling revelations about Megan, Nev and his buddies embark on a road trip in search of the truth.","genre_ids":[99],"media_type":"movie","popularity":0.8131,"vote_count":545,"poster_path":"/mXNxee2ix6Ke0bSIqFST0UhbVLR.jpg","release_date":"2010-09-17","vote_average":6.81,"backdrop_path":"/369Fi0BqGvyut1B4CqmJAzxo5xo.jpg","original_title":"Catfish","original_language":"en"},{"id":13509,"adult":false,"title":"The Monster Squad","video":false,"overview":"Count Dracula returns to the world of humans accompanied by Frankenstein's Monster, the Wolfman, the Mummy, and the Gillman. The uglies are in search of a powerful amulet that will grant them the ability to rule the world. A group of horror-loving heroes are the only ones daring to stand in their way.","genre_ids":[35,28,14],"media_type":"movie","popularity":2.3157,"vote_count":626,"poster_path":"/8EVuqCcqFzQvc7X8E3fx3w4B5Td.jpg","release_date":"1987-08-14","vote_average":6.712,"backdrop_path":"/thYgTJfMO2HG7OJTVIAbbuHCx2D.jpg","original_title":"The Monster Squad","original_language":"en"},{"id":12403,"adult":false,"title":"A Perfect Getaway","video":false,"overview":"For their honeymoon, newlyweds Cliff and Cydney head to the tropical islands of Hawaii. While journeying through the paradisaical countryside the couple encounters Kale and Cleo, two disgruntled hitchhikers and Nick and Gina, two wild but well-meaning spirits who help guide them through the lush jungles. The picturesque waterfalls and scenic mountainsides quickly give way to terror when Cliff and Cydney learn of a grisly murder that occurred nearby and realize that they're being followed by chance acquaintances that suspiciously fit the description of the killers.","genre_ids":[53,9648,12],"media_type":"movie","popularity":2.1581,"vote_count":1359,"poster_path":"/ncuGG0hIlA03dQBJmdoT2LWgodG.jpg","release_date":"2009-06-08","vote_average":6.35,"backdrop_path":"/wQE7BCTo9sdGEG5hywmC0hz8NoZ.jpg","original_title":"A Perfect Getaway","original_language":"en"},{"id":44040,"adult":false,"title":"Devil","video":false,"overview":"A group of people are trapped in an elevator high above Philadelphia, and one of them is the devil.","genre_ids":[27,9648,53],"media_type":"movie","popularity":2.3798,"vote_count":3049,"poster_path":"/aivXPSi53H95BoUa5njEYso389s.jpg","release_date":"2010-09-16","vote_average":6.097,"backdrop_path":"/yuGyks7DE9NrRfguRWYomN4KNcm.jpg","original_title":"Devil","original_language":"en"},{"id":43933,"adult":false,"title":"Monsters","video":false,"overview":"Six years ago NASA discovered the possibility of alien life within our solar system. A probe was launched to collect samples, but crashed upon re-entry over Central America. Soon after, new life forms began to appear and half of Mexico was quarantined as an infected zone. Today, the American and Mexican military still struggle to contain \"the creatures,\" while a journalist agrees to escort a shaken tourist through the infected zone in Mexico to the safety of the U.S. border.","genre_ids":[18,53,878],"media_type":"movie","popularity":1.6561,"vote_count":1732,"poster_path":"/qpJyTxR33KG9qFmXoCD5AUTToPl.jpg","release_date":"2010-06-18","vote_average":6.186,"backdrop_path":"/imiBIsvNU3TbMB3sbqKanKODS33.jpg","original_title":"Monsters","original_language":"en"},{"id":39053,"adult":false,"title":"Cyrus","video":false,"overview":"With John's social life at a standstill and his ex-wife about to get remarried, a down on his luck divorcée finally meets the woman of his dreams, only to discover she has another man in her life - her son. Before long, the two are locked in a battle of wits for the woman they both love-and it appears only one man can be left standing when it's over.","genre_ids":[35,18,10749],"media_type":"movie","popularity":3.4801,"vote_count":441,"poster_path":"/qkJ0rB1qf62TJ6thxEVRT7Eccqn.jpg","release_date":"2010-06-18","vote_average":5.918,"backdrop_path":"/1XC5EcGNIW0LGPGRineTcDUGzVB.jpg","original_title":"Cyrus","original_language":"en"},{"id":16028,"adult":false,"title":"They","video":false,"overview":"A psychology student who experienced night terrors as a child must face the chilling realization that her nightmares were not all in her head.","genre_ids":[27,53],"media_type":"movie","popularity":0.6848,"vote_count":289,"poster_path":"/nHG0VOW6o99tP5EACtKTMADqxJQ.jpg","release_date":"2002-11-01","vote_average":5.033,"backdrop_path":"/cmR0FQlL2JTe0b8Gq1kFjtG8IEv.jpg","original_title":"They","original_language":"en"},{"id":42802,"adult":false,"title":"The Dinner Guest","video":false,"overview":"Fifty years old, three years past of unemployment, benefits decreasing very quickly... Gerard is at the end of the rope when a position is offered him in Indonesia. To win the favor of his new employer, Gerard invites him to dinner at home. Fatal Error ! Terrified at the idea of not being up to par, his wife Colette begs Alexandre, their neighbor to help. Communication guru, Alexander accepts the challenge and gives a makeover to the couple in twenty-four hours. Apartment, decoration, lifestyle, dinner menu, uniforms, culture... Everything !","genre_ids":[35],"media_type":"movie","popularity":0.5095,"vote_count":115,"poster_path":"/liNUP5DCJz2g7YwzsrPAZtQ5GAj.jpg","release_date":"2007-09-19","vote_average":5.491,"backdrop_path":"/nGSw9g3NKvIjNOiHg4GjJ7wyvJT.jpg","original_title":"L'Invité","original_language":"fr"},{"id":44737,"adult":false,"title":"Babies","video":false,"overview":"A non-narrated documentary following the lovesome lives of four infants from birth to their first birthday. The babies featured are two from rural areas: Ponijao from Opuwo, Namibia, and Bayar from Bayanchandmani, Mongolia, as well as two from urban areas: Mari from Tokyo, Japan, and Hattie from San Francisco, USA.","genre_ids":[99],"media_type":"movie","popularity":0.5585,"vote_count":142,"poster_path":"/zfXmRDjbMewZWAIGfKwMG5xjxzj.jpg","release_date":"2010-05-07","vote_average":6.972,"backdrop_path":"/m5InPcwZSJx1J49XSKl1WEB4JCd.jpg","original_title":"Bébés","original_language":"fr"},{"id":135670,"adult":false,"title":"Amber Alert","video":false,"overview":"When a group of friends decides to follow a car they've seen posted on an Amber Alert, things start to go very wrong.","genre_ids":[27,9648,53],"media_type":"movie","popularity":0.3127,"vote_count":79,"poster_path":"/jP8nszewPaJvSPprobpItyRbsB5.jpg","release_date":"2012-11-02","vote_average":5.025,"backdrop_path":"/dZxrLnGfWWXvKxCxeQyedqZ3c7Y.jpg","original_title":"Amber Alert","original_language":"en"},{"id":10797,"adult":false,"title":"Terkel in Trouble","video":false,"overview":"6th-grader Terkel begins experiencing a streak of bad luck after sitting on a black spider. His teacher dies and is replaced by the strange Justin. At home, Terkel's Uncle Stewart erupts in sporadic fits of rage, and at school Terkel is bullied by two boys after they learn that fat Doris likes him. On a school camping trip, Terkel begins receiving death threats and must figure out who wants to kill him.","genre_ids":[16,35,9648,53],"media_type":"movie","popularity":0.6136,"vote_count":133,"poster_path":"/ewylxRYsBcqjYvbeAKryNr1JiBz.jpg","release_date":"2004-04-02","vote_average":6.602,"backdrop_path":"/wpmZWHcWEwe5J4ikm2Pos5OC0M6.jpg","original_title":"Terkel i knibe","original_language":"da"},{"id":137409,"adult":false,"title":"Cold War","video":false,"overview":"Five police officers in Hong Kong are kidnapped. The police commissioner is on a business trip overseas. Two vice commissioners, Sean Rau and M.B. Lee, then take over the case. The two vice commissioners are rivals who both vie for the police commissioner seat. At first, M.B. Lee takes the lead in the case, but comes to a dead end. Sean Lau then takes the lead, but he falls into a trap. Both men are then investigated by the ICAC (Independent Commission Against Corruption).","genre_ids":[28,53],"media_type":"movie","popularity":1.2007,"vote_count":185,"poster_path":"/zFiHdFJHppW43xmsnS8whzYnVQ8.jpg","release_date":"2012-11-08","vote_average":6.665,"backdrop_path":"/uw28cMvJBFBzgaMM5YeKlXTtUqE.jpg","original_title":"寒戰","original_language":"cn"},{"id":145668,"adult":false,"title":"Butcher Boys","video":false,"overview":"A gut-wrenching, non-stop roller coaster ride through the hellish underbelly of inner-city America. A birthday celebration at an upscale restaurant sets in motion events that bring Sissy, her brother, Mikey, and friends, Kenny and Barbie, face to face with the macabre world of the Boneboys. Inspired by Jonathan Swift's cannibalistic tale A Modest Proposal, the Boneboys are international predators who deal in human flesh - dead or alive. Their hunting grounds are the cities of the world.","genre_ids":[27,28,35,53],"media_type":"movie","popularity":0.4591,"vote_count":62,"poster_path":"/uD91BX9GSfkdUauxKuxMy2wUsm3.jpg","release_date":"2013-09-06","vote_average":4.452,"backdrop_path":"/c3vNfXjLBfGrMAHdN1QykmpyCEQ.jpg","original_title":"Butcher Boys","original_language":"en"},{"id":12490,"adult":false,"title":"Ordinary Decent Criminal","video":false,"overview":"Michael Lynch is a notorious criminal with two wives and a flair for showmanship. He's also a huge embarrassment to the local police, who are determined to bring him down once and for all.","genre_ids":[35,53],"media_type":"movie","popularity":1.358,"vote_count":241,"poster_path":"/jZiORaxALVDGoMUBau85E4CWB0d.jpg","release_date":"2000-01-07","vote_average":6.147,"backdrop_path":"/sHnvSBVKjbkqTXFRgDbaBfGKIOL.jpg","original_title":"Ordinary Decent Criminal","original_language":"en"},{"id":15741,"adult":false,"title":"Dorothy Mills","video":false,"overview":"When a gloomy, God-fearing island community is rocked by the assault of an infant, a psychiatrist is called in to examine Dorothy Mills, the teenager accused of the crime. Despite the villagers' hostility to her inquiry, she soon comes to suspect that Dorothy suffers from multiple personality disorder...","genre_ids":[18,53,9648,27],"media_type":"movie","popularity":1.454,"vote_count":259,"poster_path":"/nluoNHRQzJoyvMin0P4hOFC1d5M.jpg","release_date":"2008-08-06","vote_average":6.031,"backdrop_path":"/gBCtSmIHEH6CoslOJJU9Ptr5L7l.jpg","original_title":"Dorothy Mills","original_language":"en"},{"id":283389,"adult":false,"title":"Stones for the Rampart","video":false,"overview":"To be defeated and not be - a victory. This is the motto that life is guided by three young friends: Alek, Sophy and Rudy. Scouts, high school graduates high school in Warsaw drifting ambitious plans for the future broken through September 1939. Entering adulthood in a very dramatic times, which puts them a choice - to survive at any cost, or to join the fighting for a free homeland, risking everything. The boys brought up in patriotic homes, shaped by the ideals of scouting, they decide to fight. They become soldiers, and although every scrape with death, they can live a full life.","genre_ids":[10752,18,36],"media_type":"movie","popularity":0.3912,"vote_count":88,"poster_path":"/lQ06u4MiQx3EIN4T6S3M8CeeRSD.jpg","release_date":"2014-03-07","vote_average":6.7,"backdrop_path":"/aFLlJ16Iq439taolf0VR88Dbe39.jpg","original_title":"Kamienie na szaniec","original_language":"pl"},{"id":66120,"adult":false,"title":"The Monk","video":false,"overview":"A virtuous monk descends to the depths of sin and depravity after Satan sends an unholy temptress to lead him astray.","genre_ids":[53],"media_type":"movie","popularity":0.4427,"vote_count":116,"poster_path":"/1LoYkzsxNroQe42BHEqhxgBBuMK.jpg","release_date":"2011-07-12","vote_average":5.4,"backdrop_path":"/nMuTeS8Rq7IeM59RGIFyuvCYoVw.jpg","original_title":"Le Moine","original_language":"fr"},{"id":238589,"adult":false,"title":"Enemies Closer","video":false,"overview":"After a major shipment of drugs goes missing on the US-Canadian border, forest ranger and former Navy SEAL Henry is plunged into survival mode when the drug cartel forces him to help retrieve the downed package. Trapped in the wilderness with no communication to the outside world, Henry finds himself face to face with Clay, a man with a personal vendetta against Henry who has returned for retribution. Now, the two mortal enemies must make a choice: put aside their past and work together, or die alone at the hands of the drug runners, a ruthless gang who will stop at nothing to retrieve their lost cargo.","genre_ids":[53,28],"media_type":"movie","popularity":0.6293,"vote_count":194,"poster_path":"/5njeDzYgcFV8wyVnytKPc3U62Cc.jpg","release_date":"2013-12-04","vote_average":5.369,"backdrop_path":"/cM5zEPXTudPjjcYwjzFcIdxpIsp.jpg","original_title":"Enemies Closer","original_language":"en"},{"id":636891,"adult":false,"title":"Scare Package","video":false,"overview":"Chad Buckley is super crazy about horror movies, but also very lonely. He mostly spends his days in his small movie shop having wild discussions with his only returning customer, Sam.","genre_ids":[27,35],"media_type":"movie","popularity":0.4576,"vote_count":151,"poster_path":"/gRf46QmAsSKoHPKNTnCdyPIo1bG.jpg","release_date":"2019-10-04","vote_average":5.576,"backdrop_path":"/60w5MmaN69s3FAkKTkbz60EKjQk.jpg","original_title":"Scare Package","original_language":"en"}],"similar_content":[{"id":48650,"adult":false,"title":"Room in Rome","video":false,"overview":"A hotel room in the center of Rome serves as the setting for Alba and Natasha, two sexy and recently acquainted women, to have a physical adventure that touches their very souls.","genre_ids":[18,10749],"popularity":4.804,"vote_count":813,"poster_path":"/w90ItYf9qagQKVEBr1uFxPomAtf.jpg","release_date":"2010-05-07","vote_average":6.416,"backdrop_path":"/30TgnSvXiL7NQoQ5WWwHqw0FRhA.jpg","original_title":"Habitación en Roma","original_language":"es"},{"id":48691,"adult":false,"title":"Goodbye Uncle Tom","video":false,"overview":"Two documentary filmmakers go back in time to the pre-Civil War American South, to film the slave trade.","genre_ids":[18,80,27],"popularity":1.4479,"vote_count":70,"poster_path":"/nLw410E9rnJw13kufNgOtjiGvGk.jpg","release_date":"1971-09-23","vote_average":6.6,"backdrop_path":"/qMYvxKZ4ocJbU32bZvFVft7ZjJz.jpg","original_title":"Addio zio Tom","original_language":"it"},{"id":705397,"adult":false,"title":"Thorns","video":false,"overview":"Stopping at a sketchy motel for some private intimacy, Gwen and Jade get the sense that someone’s watching them.","genre_ids":[27,53],"popularity":0.2797,"vote_count":1,"poster_path":"/eckuZ4L5Q5hd0IGhMztmiyc1H9U.jpg","release_date":"2020-05-22","vote_average":8,"backdrop_path":"/uh2pvn9FrplaNHua3HzP1cuIgis.jpg","original_title":"Thorns","original_language":"en"},{"id":48572,"adult":false,"title":"Red State","video":false,"overview":"Set in Middle America, a group of teens receive an online invitation for sex, though they soon encounter Christian fundamentalists with a much more sinister agenda.","genre_ids":[27,28,53],"popularity":1.3421,"vote_count":1016,"poster_path":"/mbukOgivZWGNAxEQVt4hLUVME2P.jpg","release_date":"2011-08-19","vote_average":6.1,"backdrop_path":"/hUZnrKEag9fmwsc44revKqkYHRE.jpg","original_title":"Red State","original_language":"en"},{"id":48753,"adult":false,"title":"Cannibal","video":false,"overview":"Cannibal is based on the true-crime story of Armin Meiwes, the \"Rotenburg Cannibal\" who posted an online ad searching for someone to volunteer to be mutilated and eaten. Unlikely as it may seem, someone actually replied. The film shows a fictional portrayal of the meeting between the cannibal and his victim/participant, their homosexual relationship, and the eventual mutilation and murder of said victim.","genre_ids":[18,27,53,80],"popularity":2.5709,"vote_count":47,"poster_path":"/8BirIrKffS6JvBS55wwA1jX4SlW.jpg","release_date":"2006-12-05","vote_average":5.1,"backdrop_path":"/62rGPICStsCJiH1Tmu5G8UjLR4Y.jpg","original_title":"Cannibal","original_language":"de"},{"id":49018,"adult":false,"title":"Insidious","video":false,"overview":"A family discovers that dark spirits have invaded their home after their son inexplicably falls into an endless sleep. When they reach out to a professional for help, they learn things are a lot more personal than they thought.","genre_ids":[27,53],"popularity":5.3403,"vote_count":7196,"poster_path":"/1egpmVXuXed58TH2UOnX1nATTrf.jpg","release_date":"2011-03-31","vote_average":6.9,"backdrop_path":"/yZP6GyrgzdpjH1AxPHlb8ACLkiA.jpg","original_title":"Insidious","original_language":"en"},{"id":49021,"adult":false,"title":"Killer Elite","video":false,"overview":"Based on a shocking true story, Killer Elite pits two of the world’s most elite operatives—Danny, an ex-special ops agent and Hunter, his longtime mentor—against the cunning leader of a secret military society. Covering the globe from Australia to Paris, London and the Middle East, Danny and Hunter are plunged into a highly dangerous game of cat and mouse—where the predators become the prey.","genre_ids":[28,12,53],"popularity":3.2226,"vote_count":2269,"poster_path":"/7O2U0WPFPSvNSUYZlhbnV081lBF.jpg","release_date":"2011-09-22","vote_average":6.264,"backdrop_path":"/RzIuQRoXiO8WeFdjtnjUCzSymV.jpg","original_title":"Killer Elite","original_language":"en"},{"id":49026,"adult":false,"title":"The Dark Knight Rises","video":false,"overview":"Following the death of District Attorney Harvey Dent, Batman assumes responsibility for Dent's crimes to protect the late attorney's reputation and is subsequently hunted by the Gotham City Police Department. Eight years later, Batman encounters the mysterious Selina Kyle and the villainous Bane, a new terrorist leader who overwhelms Gotham's finest. The Dark Knight resurfaces to protect a city that has branded him an enemy.","genre_ids":[28,80,18,53],"popularity":15.4056,"vote_count":24020,"poster_path":"/hr0L2aueqlP2BYUblTTjmtn0hw4.jpg","release_date":"2012-07-17","vote_average":7.791,"backdrop_path":"/y2DB71C4nyIdMrANijz8mzvQtk6.jpg","original_title":"The Dark Knight Rises","original_language":"en"},{"id":313582,"adult":false,"title":"Deadline","video":false,"overview":"A journalist sets out to report on a minor earthquake in the Australian outback, and finds that the tremor was a result of a small nuclear explosion - part of an extortion threat that has the government fearing nuclear blackmail. With the help of local reporters, and despite the harassment of the security agencies, he sets out to avert the crisis.","genre_ids":[53,10770],"popularity":0.2194,"vote_count":3,"poster_path":"/jQeNqGyhOuv63UTklNiCNayerfH.jpg","release_date":"1982-01-01","vote_average":6,"backdrop_path":null,"original_title":"Deadline","original_language":"en"},{"id":513983,"adult":false,"title":"Baphomet","video":false,"overview":"An American family celebrates their 28-year-old daughter's pregnancy. The celebration is interrupted when a Satanic cult leader, Henrik Brandr, unexpectedly visits their ranch. Henrik offers to pay the family a large sum for ownership of their land. Jacob Richardson, the father, rejects the offer due to the priceless sentimental value of the ranch. Henrik, displeased, begins to put devastating curses on the Richardsons, trying to force them off their land - even if it means murdering them. After suffering unexplainable tragedies, the Richardsons seek help from Marybeth, a white witch high priestess. They soon discover a terrible secret about their house, revealing why their land is so valuable to the cult. They realize they must protect their house from the cult at all costs, and a violent battle between good and evil ensues.","genre_ids":[27,53],"popularity":0.2853,"vote_count":62,"poster_path":"/1l6S3EID762dvTOrNwoCRNTESa3.jpg","release_date":"2021-06-08","vote_average":5.629,"backdrop_path":"/dnntDAQTicvgtl313Ju4dIpZwtq.jpg","original_title":"Baphomet","original_language":"en"},{"id":514207,"adult":false,"title":"Invasion","video":false,"overview":"Two years after the fall of the alien ship, the life of a young woman from Moscow has been changed forever. Her growing powers are now at the focus of both human and celestial investigation: an alien force takes an interest in her, and will stop short of nothing, including an invasion. Can love and compassion save humanity, when faced with a much greater and more demanding test this time?","genre_ids":[878,18,28],"popularity":3.312,"vote_count":873,"poster_path":"/eNkewJGOW44OznlnfXA8ewWPPmI.jpg","release_date":"2020-02-27","vote_average":6.863,"backdrop_path":"/cbJNZeFkiG4ggsNcwzBs6yeCXga.jpg","original_title":"Вторжение","original_language":"ru"},{"id":313922,"adult":false,"title":"Green Room","video":false,"overview":"A punk rock band is forced to fight for survival after witnessing an act of violence at a skinhead bar.","genre_ids":[27,80,53],"popularity":1.9081,"vote_count":2885,"poster_path":"/evZicaR7nXe4LiD9G6QYTorcJGO.jpg","release_date":"2016-04-15","vote_average":6.721,"backdrop_path":"/qRjahAq8JVoJBT2x18x2A01kxZT.jpg","original_title":"Green Room","original_language":"en"},{"id":314389,"adult":false,"title":"Baby","video":false,"overview":"A nascent elite team of the Indian intelligence system perpetually strives to detect and eliminate terrorists and their plots. Officer Ajay leads his team to destroy one such potentially lethal ploy in their biggest operation yet.","genre_ids":[28,53],"popularity":2.0493,"vote_count":186,"poster_path":"/5yezGgo37qmd6kDknZKFzbhT19b.jpg","release_date":"2015-01-23","vote_average":6.817,"backdrop_path":"/w94ZL3AcTZpebSLyhKuYfdeeuV6.jpg","original_title":"Baby","original_language":"hi"},{"id":514593,"adult":false,"title":"You Should Have Left","video":false,"overview":"In an effort to repair their relationship, a couple books a vacation in the countryside for themselves and their daughter. What starts as a perfect retreat begins to fall apart as one loses their grip on reality, and a sinister force tries to tear them apart.","genre_ids":[27,53],"popularity":2.6548,"vote_count":952,"poster_path":"/tpOwE6xsWnu4lKeKbKW0R3iClM.jpg","release_date":"2020-06-18","vote_average":6.085,"backdrop_path":"/chAGSv4DB9s3fsgULpSZQLN7LgN.jpg","original_title":"You Should Have Left","original_language":"en"},{"id":49530,"adult":false,"title":"In Time","video":false,"overview":"In the not-too-distant future, the aging gene has been switched off. To avoid overpopulation, time has become the currency and the way people pay for luxuries and necessities. The rich can live forever, while the rest struggle to negotiate for their immortality. A poor young man who suddenly comes into a fortune of time finds himself on the run from a corrupt police force known as the \"time keepers\".","genre_ids":[28,53,878],"popularity":8.4209,"vote_count":11972,"poster_path":"/3Mwj2sIONQckOZP3YwsUXF7U5I4.jpg","release_date":"2011-10-27","vote_average":6.97,"backdrop_path":"/pxL08w7Eq0vKrQ3mJzYp0VHGaKG.jpg","original_title":"In Time","original_language":"en"},{"id":706862,"adult":false,"title":"Annabellum - The Curse of Salem","video":false,"overview":"In the form of an old doll a vengeful witches curse from 1692 Salem is released upon a family trapped in a historic English mansion.","genre_ids":[27,9648,53],"popularity":0.1264,"vote_count":11,"poster_path":"/9cMiaJOtIorpr0IiQPyTlb9tYVk.jpg","release_date":"2019-08-12","vote_average":3.5,"backdrop_path":"/sfJHgrkhjUcEyqU5evsmsk0lDII.jpg","original_title":"Annabellum - The Curse of Salem","original_language":"en"},{"id":49730,"adult":false,"title":"Red Riding Hood","video":false,"overview":"Valerie is in love with a brooding outsider, Peter, but her parents have arranged for her to marry another man. Unwilling to lose each other, Valerie and Peter plan to run away together when Valerie's older sister is killed by a werewolf that prowls the dark forest surrounding their village. Panic grips the town as Valerie discovers that she has a unique connection to the beast--one that inexorably draws them together, making her both suspect ... and bait.","genre_ids":[53,18,14,9648,27,10749],"popularity":3.9177,"vote_count":3282,"poster_path":"/dMI4XZCfC0VhUNN1Ds6ty6iRoyJ.jpg","release_date":"2011-03-10","vote_average":5.978,"backdrop_path":"/r4A5SQSGTfleodMm45w7MJgE2WF.jpg","original_title":"Red Riding Hood","original_language":"en"},{"id":314422,"adult":false,"title":"Beautiful","video":false,"overview":"A surreal fantasy based on the short story by Caitlyn Walter, a woman wakes to to find the man of her dreams laying beside her but something just seems to be missing from this idyllic scene","genre_ids":[27,10749,53],"popularity":0.8824,"vote_count":1,"poster_path":null,"release_date":"2014-12-11","vote_average":8,"backdrop_path":null,"original_title":"Beautiful","original_language":"en"},{"id":49526,"adult":false,"title":"Premium Rush","video":false,"overview":"In Manhattan, a bike messenger picks up an envelope that attracts the interest of a dirty cop, who pursues the cyclist throughout the city.","genre_ids":[80,28,53],"popularity":2.4063,"vote_count":2242,"poster_path":"/gHnGhJmE0LByOd4RS2mOASmUqQ