5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Extinct\",\"description\":\"Op and Ed, two adorable donut-shaped animals - flummels - accidentally time-travel from 1835 to modern-day Shanghai.  There they discover traffic, trans fats, and worst of all, that flummels are now extinct. It's up to this bumbling pair to save themselves and their species...and, just maybe, change the course of history.\",\"image\":\"https://image.tmdb.org/t/p/w500/kchu0regBPDjWORUzvTblyoA5aE.jpg\",\"datePublished\":\"2021-02-11\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CA\",\"inLanguage\":\"en\",\"genre\":[\"Animation\",\"Comedy\",\"Family\",\"Adventure\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.2,\"bestRating\":10,\"ratingCount\":180}}"}}],["$","$L10",null,{"initialDrama":{"id":"00dba247-df45-48aa-a53f-55403e563d30","tmdb_id":664236,"imdb_id":"tt8241000","content_type":"movie","title":"Extinct","original_title":"Extinct","overview":"Op and Ed, two adorable donut-shaped animals - flummels - accidentally time-travel from 1835 to modern-day Shanghai.  There they discover traffic, trans fats, and worst of all, that flummels are now extinct. It's up to this bumbling pair to save themselves and their species...and, just maybe, change the course of history.","poster_path":"/kchu0regBPDjWORUzvTblyoA5aE.jpg","backdrop_path":"/yd2xws5wVT2Ss6f0Q0oTkdYtiQE.jpg","release_date":"2021-02-11","first_air_date":null,"status":"published","original_language":"en","origin_country":["CA","CN","UA","US"],"genres":[{"id":16,"name":"Animation"},{"id":35,"name":"Comedy"},{"id":10751,"name":"Family"},{"id":12,"name":"Adventure"}],"popularity":6.0048,"vote_average":6.2,"vote_count":180,"runtime":84,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-05T22:11:28.668787+00:00","updated_at":"2026-02-05T22:11:28.668787+00:00","tagline":"The end is just th