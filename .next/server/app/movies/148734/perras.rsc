5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Perras\",\"description\":\"Something terrible is happening in class 3A at Calmecatl Junior High. No one can leave the classroom until the guilty party is found. This is the device that gives us a glimpse of the ethics, games, esthetics and eroticism of these girl-women. It is not easy to say what the subject is, there are so many: the discovery of sexuality, discrimination, chance, drugs, maternity, traditions, betrayals, power, love. A mural of a complex reality from the point of view of twenty-something women in the skin of 14 to 15 year old girls.\",\"image\":\"https://image.tmdb.org/t/p/w500/jrJrgwFjAyzkZLiaU5dA8o1hcUA.jpg\",\"datePublished\":\"2011-03-04\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"MX\",\"inLanguage\":\"es\",\"genre\":[\"Thriller\",\"Drama\",\"Romance\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.224,\"bestRating\":10,\"ratingCount\":304}}"}}],["$","$L10",null,{"initialDrama":{"id":"e59f7603-376b-4a09-8b9b-55dced4ab823","tmdb_id":114168,"imdb_id":"tt1857824","content_type":"movie","title":"Perras","original_title":"Perras","overview":"Something terrible is happening in class 3A at Calmecatl Junior High. No one can leave the classroom until the guilty party is found. This is the device that gives us a glimpse of the ethics, games, esthetics and eroticism of these girl-women. It is not easy to say what the subject is, there are so many: the discovery of sexuality, discrimination, chance, drugs, maternity, traditions, betrayals, power, love. A mural of a complex reality from the point of view of twenty-something women in the skin of 14 to 15 year old girls.","poster_path":"/jrJrgwFjAyzkZLiaU5dA8o1hcUA.jpg","backdrop_path":"/b7qyTKrkFDAVyAzBgVpqjvAHneH.jpg","release_date":"2011-03-04","first_air_date":null,"status":"published","original_language":"es","origin_country":["MX"],"genres":[{"id":53,"name":"Thriller"},{"id":18,"name":"Drama"},{"id":10749,"name":"Romance"},"drama film"],"popularity":4.9329,"vote_average":7.224,"vote_count":304,"runtime":100,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-26T01:36:52.424612+00:00","updated_at":"2026-02-26T01:36:52.249+00:00","tagline":"Do your parents know?","homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":299,"name":"Instituto Mexicano de Cinematografía","logo_path":"/elssmtHcogGtF8Gxokh9phZvLKi.png","origin_country":"MX"},{"id":15878,"name":"FIDECINE","logo_path":"/iUe12EMGBPSCXd9x2BwSawujZe.png","origin_country":"MX"}],"production_countries":[{"name":"Mexico","iso_3166_1":"MX"}],"spoken_languages":[{"name":"Español","iso_639_1":"es","english_name":"Spanish"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[],"alternative_titles":[],"videos":[{"id":"533ec6e4c3a36854480089cf","key":"ftwEQPI04cE","name":"PERRAS (TRAILER)","site":"YouTube","size":360,"type":"Trailer","official":false,"iso_639_1":"en","iso_3166_1":"US","published_at":"2011-03-07T05:36:00.000Z"}],"watch_providers":{"results":{}},"wikidata_id":"Q7169598","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-26T01:36:52.424612+00:00","region":null,"main_poster":null,"images":{"logos":[],"posters":[{"width":1000,"height":1426,"file_path":"/jrJrgwFjAyzkZLiaU5dA8o1hcUA.jpg","iso_639_1":"es","iso_3166_1":"MX","vote_count":2,"aspect_ratio":0.701,"vote_average":3.334},{"width":800,"height":1200,"file_path":"/f4sZrmACtGdUaXpWUjqfnVC2963.jpg","iso_639_1":"es","iso_3166_1":"MX","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1330,"height":747,"file_path":"/b7qyTKrkFDAVyAzBgVpqjvAHneH.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.78,"vote_average":3.334},{"width":1329,"height":748,"file_path":"/kNtLEydWkUlZC03A2hvjOxEtCHi.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.777,"vote_average":0.166},{"width":1322,"height":744,"file_path":"/ogy9YqDiMpcqfhZLwfdf3Tpxpvc.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.777,"vote_average":0.166}]},"enriched_at":"2026-04-21T07:41:41.307+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":100,"tagline":"Do your parents know?","homepage":"","overview":"Something terrible is happening in class 3A at Calmecatl Junior High. No one can leave the classroom until the guilty party is found. This is the device that gives us a glimpse of the ethics, games, esthetics and eroticism of these girl-women. It is not easy to say what the subject is, there are so many: the discovery of sexuality, discrimination, chance, drugs, maternity, traditions, betrayals, power, love. A mural of a complex reality from the point of view of twenty-something women in the skin of 14 to 15 year old girls."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Nueve alumnas han de permanecer en su salón de clases, esperar a que los policías lleguen y las interroguen, ya que todas son sospechosas de haber cometido una falta imperdonable, mientras tanto se exploraran sentimientos de cada una de las alumnas."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":97,"tagline":"","homepage":"","overview":"Algo terrible está sucediendo en la clase 3A en Calmecatl Junior High. Nadie puede abandonar el aula hasta que se encuentre a la parte culpable. Este es el dispositivo que nos da una idea de la ética, los juegos, la estética y el erotismo de estas mujeres. No es fácil decir cuál es el tema, hay tantos: el descubrimiento de la sexualidad, la discriminación,  casualidad, drogas, maternidad, tradiciones, traiciones, poder, amor. Un mural de una realidad compleja desde el punto de vista de veintitantos mujeres en la piel de niñas de 14 a 15 años."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":97,"tagline":"Vos parents sont-ils au courant ?","homepage":"","overview":"Quelque chose de terrible se passe dans la classe 3A à Calmecatl Junior High. Personne ne peut quitter la salle de classe tant que le coupable n'a pas été trouvé. C'est le dispositif qui nous laisse entrevoir l'éthique, les jeux, l'esthétique et l'érotisme de ces femmes-filles. Ce n'est pas facile de dire quel est le sujet, il y en a tellement : la découverte de la sexualité, la discrimination, le hasard, la drogue, la maternité, les traditions, les trahisons, le pouvoir, l'amour. Une fresque d'une réalité complexe du point de vue de femmes d'une vingtaine d'années dans la peau de jeunes filles de 14 à 15 ans."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Er gebeurt iets vreselijks in klas 3A van Calmecatl Junior High. Niemand mag het klaslokaal verlaten totdat de schuldige is gevonden. Dit is het middel dat ons een glimp geeft van de ethiek, spelletjes, esthetiek en erotiek van deze meisjes-vrouwen. Het is niet makkelijk te zeggen wat het onderwerp is, er zijn er zoveel: de ontdekking van seksualiteit, discriminatie, toeval, drugs, moederschap, tradities, verraad, macht, liefde. Een muurschildering van een complexe realiteit vanuit het perspectief van vrouwen van in de twintig in de huid van meisjes van 14 tot 15 jaar."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"}],"reviews_tmdb":[],"recommendations":[{"id":46825,"adult":false,"title":"Lila Says","video":false,"overview":"Chimo develops a crush on the pretty, blond Lila, a girl who recently moved into his Arab ghetto with her aunt. When the leader of a rival gang also falls for Lila, the ensuing love triangle initiates a journey of sexual discovery -- and sets off a chain of devastating events.","genre_ids":[80,18,10749],"media_type":"movie","popularity":0.6833,"vote_count":103,"poster_path":"/3GCtiblUjnbhuHJnIXqWVi6zhHC.jpg","release_date":"2005-01-26","vote_average":6.442,"backdrop_path":"/5ypSneaQCsoz3IYscDQFToUODRr.jpg","original_title":"Lila dit ça","original_language":"fr"},{"id":62964,"adult":false,"title":"Slipknot: Welcome to our Neighborhood","video":false,"overview":"Welcome to Our Neighborhood is the first video album by American heavy metal band Slipknot. It was released on November 9, 1999 by Roadrunner Records and later reissued in DVD format on November 18, 2003. Characterized as a band's home video, it features a mixture of live performances footage of the songs \"Surfacing\", \"Wait and Bleed\", and \"Scissors\", interviews, and music video of \"Spit It Out\". Additional concept imagery and interview footage is included on the film, while the DVD version features more bonus material.","genre_ids":[10402],"media_type":"movie","popularity":0.1428,"vote_count":19,"poster_path":"/bJNqRRMLe0Yr0sme5X8SNOA35bF.jpg","release_date":"1999-11-09","vote_average":6.8,"backdrop_path":null,"original_title":"Slipknot: Welcome to our Neighborhood","original_language":"en"},{"id":128177,"adult":false,"title":"Elisa Before the End of the World","video":false,"overview":"10-year-old Elisa, whose parents are about to lose their new car due to financial problems, plans a bank robbery.","genre_ids":[18],"media_type":"movie","popularity":0.1743,"vote_count":21,"poster_path":"/3g6CoKlV7S5R4NqsDX0TfjBFbdv.jpg","release_date":"1997-06-22","vote_average":5.881,"backdrop_path":"/slSTeLXF0Jd3m1ha9ZMfg5tqXn9.jpg","original_title":"Elisa antes del fin del mundo","original_language":"es"},{"id":501725,"adult":false,"title":"Insurgents","video":false,"overview":"Through the reconstruction of crucial historical moments in the long struggle of the Bolivian Indians in search of the recovery of lost sovereignty, due to the Spanish colonization and the oppression of their descendants the republican Creoles, is rescued from official oblivion several indigenous heroes who shone with their own light in that extraordinary feat that culminates with the rise of an Indian to the Presidency of Bolivia.","genre_ids":[36],"media_type":"movie","popularity":0.1089,"vote_count":10,"poster_path":"/7sLJKEIKkqZHj8ZSAIHUlHWBZ0v.jpg","release_date":"2012-08-16","vote_average":7.7,"backdrop_path":null,"original_title":"Insurgentes","original_language":"es"},{"id":853354,"adult":false,"title":"Bob Ross: Happy Accidents, Betrayal & Greed","video":false,"overview":"Bob Ross brought joy to millions as the world's most famous art instructor. But a battle for his business empire cast a shadow over his happy trees.","genre_ids":[99],"media_type":"movie","popularity":0.6514,"vote_count":104,"poster_path":"/jov3rCzNT8u5b7A56c0XKCkP5Dc.jpg","release_date":"2021-08-25","vote_average":6.736,"backdrop_path":"/2HTz9iroaHnXW53dCR0V6Qlipwo.jpg","original_title":"Bob Ross: Happy Accidents, Betrayal & Greed","original_language":"en"},{"id":99306,"adult":false,"title":"The Flintstones Meet Rockula and Frankenstone","video":false,"overview":"The Flintstones and the Rubbles win a trip on \"Make a Deal or Don't\" to Count Rockula's castle in Rocksylvania, where they have an unpleasant meeting with the Count and his servant, Frankenstone.","genre_ids":[16,10751,35,10770],"media_type":"movie","popularity":0.5135,"vote_count":63,"poster_path":"/ndNmc7aQVzalas9Kb6cn3g4pYSb.jpg","release_date":"1979-10-30","vote_average":7.6,"backdrop_path":"/Na8kT41spEBDGF6XAl2nineCRP.jpg","original_title":"The Flintstones Meet Rockula and Frankenstone","original_language":"en"},{"id":808228,"adult":false,"title":"Night of the Sicario","video":false,"overview":"Taylor is forced to hide the young daughter of a Colombian woman in witness protection who will be testifying against a powerful drug cartel in Federal Court, as ruthless sicarios aim to hunt them down.","genre_ids":[28,53,18],"media_type":"movie","popularity":0.5543,"vote_count":84,"poster_path":"/7h2ndK3XyaeZJ02HKW1EbcooaaH.jpg","release_date":"2021-04-16","vote_average":5.8,"backdrop_path":"/4y6d7X7AdfBq9V4lIlhtjdYBu2E.jpg","original_title":"Night of the Sicario","original_language":"en"},{"id":277806,"adult":false,"title":"Say 'I Love You'","video":false,"overview":"Mei Tachibana is a high school student. Due to a traumatic incident when she was a kid, Mei has been unable to make friends or have boyfriends. By mistake, Mei then injures the most popular male student named Yamato Kurosawa. Somehow, Yamato Kurosawa likes Mei Tachibana and tells everyone unilaterally that Mei is his friend. One day, Yamato Kurosawa saves Mei Tachibana from a stalker by kissing her. From that kiss, their love story begins.","genre_ids":[18,10749],"media_type":"movie","popularity":0.5258,"vote_count":108,"poster_path":"/i1GbBp5YrwPrKN1I2rIMkRQUWHe.jpg","release_date":"2014-07-12","vote_average":6.8,"backdrop_path":"/cAHdFJtRqSieohiiqghnUrS7T6K.jpg","original_title":"好きっていいなよ。","original_language":"ja"},{"id":1225377,"adult":false,"title":"The Mouse Trap","video":false,"overview":"It's Alex's 21st Birthday, but she's stuck at the amusement arcade on a late shift so her friends decide to surprise her, but a masked killer dressed as Mickey Mouse decides to play a game of his own with them which she must survive.","genre_ids":[27,53],"media_type":"movie","popularity":1.0013,"vote_count":126,"poster_path":"/3ovFaFeojLFIl5ClqhtgYMDS8sE.jpg","release_date":"2024-08-23","vote_average":4.151,"backdrop_path":"/o9FgMDfXUQPXh3khwCnDMiX6Cyi.jpg","original_title":"The Mouse Trap","original_language":"en"},{"id":1215918,"adult":false,"title":"Blackwater Lane","video":false,"overview":"An American school teacher in England drives past an abandoned car late one night, unaware that the driver was the victim of a murder. As she comes to terms with the realization, seemingly supernatural events start to affect the gothic manor she lives in with her husband.","genre_ids":[53,18,9648,27,80],"media_type":"movie","popularity":1.1384,"vote_count":133,"poster_path":"/tdUFd56CFC0o6XoAkn4WRNHwqod.jpg","release_date":"2024-06-21","vote_average":6.053,"backdrop_path":"/gMivgcDVJmp8DTwMZ2YLhkJV09V.jpg","original_title":"Blackwater Lane","original_language":"en"},{"id":779047,"adult":false,"title":"Us Again","video":false,"overview":"In a vibrant city pulsating with rhythm and movement, an elderly man and his young-at-heart wife rekindle their youthful passion for life and each other on one magical night.","genre_ids":[16,18,10751,10749],"media_type":"movie","popularity":0.6442,"vote_count":342,"poster_path":"/zKnenwvQB6xA4mxc8zxL2S8qVbR.jpg","release_date":"2021-03-03","vote_average":7.8,"backdrop_path":"/9B4hHMsnjxo8NnTcKIfg3cjJzMi.jpg","original_title":"Us Again","original_language":"en"},{"id":709629,"adult":false,"title":"War of Likes","video":false,"overview":"In order to advance her career in the dynamic world of publicity in Mexico City, Raquel tries to reunite with her high school friend Cecy who has become the queen of social media. But unlike followers, friendships do not come instantly.","genre_ids":[35],"media_type":"movie","popularity":2.5619,"vote_count":241,"poster_path":"/jpdWHOu6EJbYnLXLCA52h82nLEz.jpg","release_date":"2021-03-12","vote_average":7.7,"backdrop_path":"/nq4LRhGrCZ8ucxMaLMPa3uZV6ku.jpg","original_title":"Guerra de Likes","original_language":"es"},{"id":733156,"adult":false,"title":"Sightless","video":false,"overview":"After an attack renders her blind, Ellen withdraws from the world to recover. But soon she plunges into paranoia, unable to convince anyone that her assailant has returned to terrorize her by hiding in plain sight.","genre_ids":[53,27],"media_type":"movie","popularity":0.7814,"vote_count":416,"poster_path":"/byScu2YTPLsEfDAiXm3pW6w8FBA.jpg","release_date":"2020-09-29","vote_average":6.763,"backdrop_path":"/cMcn5W38E5FVao1FqIZllO11nSF.jpg","original_title":"Sightless","original_language":"en"},{"id":653601,"adult":false,"title":"Horse Girl","video":false,"overview":"A socially awkward woman with a fondness for arts and crafts, horses, and supernatural crime shows finds her increasingly lucid dreams trickling into her waking life.","genre_ids":[18],"media_type":"movie","popularity":4.0354,"vote_count":591,"poster_path":"/hNQ7st9dFXUXENMcsAuVxcrIBfA.jpg","release_date":"2020-01-27","vote_average":5.654,"backdrop_path":"/6vLCEAVBCLCOtDxZOlnp2fkVUCw.jpg","original_title":"Horse Girl","original_language":"en"},{"id":105203,"adult":false,"title":"Violet Perfume: Nobody Hears You","video":false,"overview":"Yessica is a rebellious girl who forms an unlikely friendship with quiet schoolmate Miriam. Yessica's home life is ruled by her brutal stepfather and her amoral stepbrother, Jorge, while Miriam shares a calm, loving household with her mother. The girls' friendship is shattered after Jorge arranges to have one of his friends rape Yessica.","genre_ids":[18],"media_type":"movie","popularity":0.8439,"vote_count":218,"poster_path":"/gWuhAHj0vK4UNZvJZevxobkmGDq.jpg","release_date":"2001-03-11","vote_average":7.787,"backdrop_path":"/1fJZzkyOKNv4ExSf7uXQNUzycr9.jpg","original_title":"Nadie te oye: perfume de violetas","original_language":"es"},{"id":12103,"adult":false,"title":"Don't Say a Word","video":false,"overview":"When the daughter of a psychiatrist is kidnapped, he is horrified to discover that the abductors' demand is that he break through to a young woman, suffering from PTSD, who knows a secret six digit code number.","genre_ids":[53,9648,80],"media_type":"movie","popularity":1.8798,"vote_count":1033,"poster_path":"/mDawnZWQnePqQbiisEWZaY9e4UI.jpg","release_date":"2001-09-28","vote_average":6.265,"backdrop_path":"/biDpaYDBNDk94wzbbw3Tt3Zm6EP.jpg","original_title":"Don't Say a Word","original_language":"en"},{"id":394830,"