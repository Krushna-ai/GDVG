le_path":"/npyS4HIu33pUfivAja4OwxvlrZZ.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":1,"aspect_ratio":0.667,"vote_average":0.166},{"width":530,"height":750,"file_path":"/tBbs0uooT5BV7Qf4ebJ0RnPqsi1.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.707,"vote_average":0},{"width":960,"height":1440,"file_path":"/sVlfWVY5qWd3FpbdMTyxU4AOxlI.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1200,"height":1800,"file_path":"/xtSQDiWy1Sf4leORc91OuItRq5R.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/h6r7vWHgrvSHAty5CIUJRUgG4uD.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":960,"height":1440,"file_path":"/jt3wDtq6yzS9w8p7UTDxh7Rn5ZN.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/qQ223Np5yxmXiYQthjl2rXmIGlY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/abrJr0A4wbhoJv9FPC9w1uLdaez.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/lrGPIHxjTScbFzsyNfoqYVncnE0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/irJ1NO7LWB0ezAfw7Z1ZfenFQhj.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/cwQxQOx0lXlswJu5xYxCaeiOJSp.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:52:09.39+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Little Lips","runtime":86,"tagline":"Love can be a healer but it can also be the most powerful and destructive force on Earth.","homepage":"","overview":"A writer returns home to his estate after service in World War I. He has developed a very bad case of depression due to a war wound concerning his genitalia. He contemplates suicide, but recovers after becoming interested in his caretaker's 12 year-old war orphan niece, who now lives in the manor."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Historia de Eva","runtime":86,"tagline":"","homepage":"","overview":"Paul, un famoso escritor en sus treinta, deja el hospital militar donde ha sido tratado de varias heridas de guerra, que le han dejado impotente. Su condición hace que busque una nueva vida en el campo, donde conoce a Eva, la nieta de uno de los granjeros del lugar. La niña de doce años le ayuda a aceptar su condición física, pues la inocencia de la adolescencia no pide nada que él no pueda dar."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Маленькие губки","runtime":0,"tagline":"","homepage":"","overview":"Молодой писатель возвращается с войны."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Little Lips - Der zärtliche Tod","runtime":86,"tagline":"","homepage":"","overview":"Ein Schriftsteller kehrt aus dem Krieg ohne Lebensmut zurück. Als er ein junges Mädchen kennenlernt, bekommt sein Leben wieder einen Sinn."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"伊娃传","runtime":0,"tagline":"","homepage":"","overview":"一个作家从世界大战后回家了，战争对他造成了严重的伤害。他考虑过自杀。后来他遇见旅店老板的女儿，他们相处的很好他渐渐地迷恋上了他。他很喜欢这个女孩但是却不能和她发生关系。女孩后来遇见了另一个和她年龄相仿的男孩，她的春心萌动了……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Um escritor retorna a casa após a Primeira Guerra Mundial. Ele desenvolveu um péssimo caso de transtorno de estresse pós-traumático. Pensa em suicidar-se, mas torna-se interessado na sobrinha de 12 anos de idade do gerente do lugar onde ele está a recuperar. Não parece importar-se que estê a passar tanto tempo com ela. Torna-se profundamente apaixonado por ela, mas não pode consumar fisicamente qualquer tipo de relacionamento com ela. Ela ilumina o seu dia, mas a sua sexualidade está apenas a começar a brotar. Quando ela começa a preferir um rapaz mais perto da sua idade do que o escritor, a finalidade da trama está definida."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Birinci Dünya Savaşı sırasında cinsel organlarından olan yazar, kaldığı pansiyonun sahibinin 12 yaşındaki yeğenine ilgi duymaya başlar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"小さな唇","runtime":0,"tagline":"","homepage":"","overview":"第一次大戦から5年が経過したドイツの保養地に戦傷で性的不能となった作家が帰って来る。彼はそこで驚くべき美少女と出会い、まだ幼い彼女にのめりこんで行く。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Petites Lèvres","runtime":86,"tagline":"","homepage":"","overview":"Un écrivain rentre chez lui après la Première Guerre mondiale. Il a développé un syndrome de stress post-traumatique. Il envisage le suicide, mais s'intéresse à la nièce de douze ans de l'aubergiste de l'endroit où il est en convalescence."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Маленькі губи","runtime":86,"tagline":"","homepage":"","overview":"Молодий письменник повертається з війни. Незабаром він дізнається, що в будинку живе малолітня племінниця керуючого, яка незабаром привертає його увагу. Зустрівши її чоловік закохується в німфетку і постійно бачить себе з нею. Поки він себе стримував, дівчина віддалася більш спритному юнакові."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Piccole labbra","runtime":0,"tagline":"","homepage":"","overview":"L'austriaco Paul, reduce della Grande Guerra, torna nella sua casa di campagna, dove fa amicizia con una ragazzina di 12 anni, Eva. In lei Paul ritrova tutta la sensualità femminile pronta a sbocciare, ma sa benissimo di non poterne approfittare a causa delle ferite di guerra. Coltiva così un amore platonico che lo guida a scrivere un romanzo su Eva."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Een schrijver keert terug naar zijn landgoed na dienst in de Eerste Wereldoorlog. Hij heeft een zeer ernstige vorm van depressie ontwikkeld als gevolg van een oorlogswond aan zijn geslachtsdelen. Hij overweegt zelfmoord, maar herstelt nadat hij geïnteresseerd is geraakt in het 12-jarige oorlogswees nichtje van zijn verzorger, die nu in het landhuis woont."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"}],"reviews_tmdb":[],"recommendations":[{"id":343611,"adult":false,"title":"Jack Reacher: Never Go Back","video":false,"overview":"Years after resigning command of an elite military police unit, the nomadic, righter-of-wrongs Reacher is drawn back into the life he left behind when his friend and successor, Major Susan Turner is framed for espionage. Reacher will stop at nothing to prove her innocence and to expose the real perpetrators behind the killings of his former soldiers.","genre_ids":[28,53,18,80],"media_type":"movie","popularity":6.732,"vote_count":5232,"poster_path":"/cOg3UT2NYWHZxp41vpxAnVCOC4M.jpg","release_date":"2016-10-19","vote_average":6.004,"backdrop_path":"/ww1eIoywghjoMzRLRIcbJLuKnJH.jpg","original_title":"Jack Reacher: Never Go Back","original_language":"en"},{"id":150540,"adult":false,"title":"Inside Out","video":false,"overview":"When 11-year-old Riley moves to a new city, her Emotions team up to help her through the transition. Joy, Fear, Anger, Disgust and Sadness work together, but when Joy and Sadness get lost, they must journey through unfamiliar places to get back home.","genre_ids":[16,10751,12,18,35],"media_type":"movie","popularity":15.6425,"vote_count":23187,"poster_path":"/2H1TmgdfNtsKlU9jKdeNyYL5y8T.jpg","release_date":"2015-06-17","vote_average":7.909,"backdrop_path":"/jJKZaTBNenlFclQyjrnvzkRmvWE.jpg","original_title":"Inside Out","original_language":"en"},{"id":680,"adult":false,"title":"Pulp Fiction","video":false,"overview":"A burger-loving hit man, his philosophical partner, a drug-addled gangster's moll and a washed-up boxer converge in this sprawling, comedic crime caper. Their adventures unfurl in three stories that ingeniously trip back and forth in time.","genre_ids":[53,80,35],"media_type":"movie","popularity":25.4546,"vote_count":29734,"poster_path":"/vQWk5YBFWF4bZaofAbv0tShwBvQ.jpg","release_date":"1994-09-10","vote_average":8.486,"backdrop_path":"/96hiUXEuYsu4tcnvlaY8tEMFM0m.jpg","original_title":"Pulp Fiction","original_language":"en"},{"id":157336,"adult":false,"title":"Interstellar","video":false,"overview":"The adventures of a group of explorers who make use of a newly discovered wormhole to surpass the limitations on human space travel and conquer the vast distances involved in an interstellar voyage.","genre_ids":[12,18,878],"media_type":"movie","popularity":45.3727,"vote_count":38953,"poster_path":"/gEU2QniE6E77NI6lCU6MxlNBvIx.jpg","release_date":"2014-11-05","vote_average":8.5,"backdrop_path":"/2ssWTSVklAEc98frZUQhgtGHx7s.jpg","original_title":"Interstellar","original_language":"en"},{"id":27205,"adult":false,"title":"Inception","video":false,"overview":"Cobb, a skilled thief who commits corporate espionage by infiltrating the subconscious of his targets is offered a chance to regain his old life as payment for a task considered to be impossible: \"inception\", the implantation of another person's idea into a target's subconscious.","genre_ids":[28,878,12],"media_type":"movie","popularity":30.5689,"vote_count":38737,"poster_path":"/xlaY2zyzMfkhk0HSC5VUwzoZPU1.jpg","release_date":"2010-07-15","vote_average":8.37,"backdrop_path":"/8ZTVqvKDQ8emSGUEMjsS4yHAwrp.jpg","original_title":"Inception","original_language":"en"},{"id":264660,"adult":false,"title":"Ex Machina","video":false,"overview":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl.","genre_ids":[18,878],"media_type":"movie","popularity":7.9469,"vote_count":14040,"poster_path":"/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg","release_date":"2015-01-21","vote_average":7.573,"backdrop_path":"/uqOuJ50EtTj7kkDIXP8LCg7G45D.jpg","original_title":"Ex Machina","original_language":"en"},{"id":19995,"adult":false,"title":"Avatar","video":false,"overview":"In the 22nd century, a paraplegic Marine is dispatched to the moon Pandora on a unique mission, but becomes torn between following orders and protecting an alien civilization.","genre_ids":[28,12,14,878],"media_type":"movie","popularity":34.6739,"vote_count":33504,"poster_path":"/gKY6q7SjCkAU6FqvqWybDYgUKIF.jpg","release_date":"2009-12-16","vote_average":7.6,"backdrop_path":"/vL5LR6WdxWPjLPFRLe133jXWsh5.jpg","original_title":"Avatar","original_language":"en"},{"id":293660,"adult":false,"title":"Deadpool","video":false,"overview":"The origin story of former Special Forces operative turned mercenary Wade Wilson, who, after being subjected to a rogue experiment that leaves him with accelerated healing powers, adopts the alter ego Deadpool. Armed with his new abilities and a dark, twisted sense of humor, Deadpool hunts down the man who nearly destroyed his life.","genre_ids":[28,12,35],"media_type":"movie","popularity":14.1679,"vote_count":32390,"poster_path":"/3E53WEZJqP6aM84D8CckXx4pIHw.jpg","release_date":"2016-02-09","vote_average":7.622,"backdrop_path":"/en971MEXui9diirXlogOrPKmsEn.jpg","original_title":"Deadpool","original_language":"en"},{"id":75656,"adult":false,"title":"Now You See Me","video":false,"overview":"An FBI agent and an Interpol detective track a team of illusionists who pull off bank heists during their performances and reward their audiences with the money.","genre_ids":[53,80],"media_type":"movie","popularity":10.5254,"vote_count":16507,"poster_path":"/tWsNYbrqy1p1w6K9zRk0mSchztT.jpg","release_date":"2013-05-29","vote_average":7.332,"backdrop_path":"/xEY0MV2jSQBz9iOJfCFvLTiPGMA.jpg","original_title":"Now You See Me","original_language":"en"},{"id":389,"adult":false,"title":"12 Angry Men","video":false,"overview":"The defense and the prosecution have rested and the jury is filing into the jury room to decide if a young Spanish-American is guilty or innocent of murdering his father. What begins as an open and shut case soon becomes a mini-drama of each of the jurors' prejudices and preconceptions about the trial, the accused, and each other.","genre_ids":[18],"media_type":"movie","popularity":13.1707,"vote_count":9763,"poster_path":"/ow3wq89wM8qd5X7hWKxiRfsFf9C.jpg","release_date":"1957-04-10","vote_average":8.556,"backdrop_path":"/w4bTBXcqXc2TUyS5Fc4h67uWbPn.jpg","original_title":"12 Angry Men","original_language":"en"},{"id":49026,"adult":false,"title":"The Dark Knight Rises","video":false,"overview":"Following the death of District Attorney Harvey Dent, Batman assumes responsibility for Dent's crimes to protect the late attorney's reputation and is subsequently hunted by the Gotham City Police Department. Eight years later, Batman encounters the mysterious Selina Kyle and the villainous Bane, a new terrorist leader who overwhelms Gotham's finest. The Dark Knight resurfaces to protect a city that has branded him an enemy.","genre_ids":[28,80,18,53],"media_type":"movie","popularity":15.4056,"vote_count":24020,"poster_path":"/hr0L2aueqlP2BYUblTTjmtn0hw4.jpg","release_date":"2012-07-17","vote_average":7.791,"backdrop_path":"/y2DB71C4nyIdMrANijz8mzvQtk6.jpg","original_title":"The Dark Knight Rises","original_language":"en"},{"id":10681,"adult":false,"title":"WALL·E","video":false,"overview":"After hundreds of years doing what he was built for, WALL•E— a robot designed to clean up the earth—discovers a new purpose in life when he meets a sleek search robot named EVE. EVE comes to realize that WALL•E has inadvertently stumbled upon the key to the planet's future, and races back to space to report to the humans. Meanwhile, WALL•E chases EVE across the galaxy and sets into motion one of the most imaginative adventures ever brought to the big screen.","genre_ids":[16,10751,878],"media_type":"movie","popularity":14.8541,"vote_count":19947,"poster_path":"/hbhFnRzzg6ZDmm8YAmxBnQpQIPh.jpg","release_date":"2008-06-22","vote_average":8.107,"backdrop_path":"/fK5ssgvtI43z19FoWigdlqgpLRE.jpg","original_title":"WALL·E","original_language":"en"},{"id":44214,"adult":false,"title":"Black Swan","video":false,"overview":"A committed dancer struggles to maintain her sanity after winning the lead role in a production of Tchaikovsky's \"Swan Lake\".","genre_ids":[18,53,27],"media_type":"movie","popularity":8.6981,"vote_count":15338,"poster_path":"/viWheBd44bouiLCHgNMvahLThqx.jpg","release_date":"2010-12-03","vote_average":7.686,"backdrop_path":"/g0geLM1zXpLb9mpqKw1ePcA5bTJ.jpg","original_title":"Black Swan","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's 