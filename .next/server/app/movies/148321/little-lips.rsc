5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Little Lips\",\"description\":\"A writer returns home to his estate after service in World War I. He has developed a very bad case of depression due to a war wound concerning his genitalia. He contemplates suicide, but recovers after becoming interested in his caretaker's 12 year-old war orphan niece, who now lives in the manor.\",\"image\":\"https://image.tmdb.org/t/p/w500/rKhJiY9u2L4LInLd7Xdwry1YTdA.jpg\",\"datePublished\":\"1978-02-08\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"IT\",\"inLanguage\":\"it\",\"genre\":[\"Drama\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.9,\"bestRating\":10,\"ratingCount\":27}}"}}],["$","$L10",null,{"initialDrama":{"id":"76955996-1ac9-4766-ae4c-96f7a8285b56","tmdb_id":26550,"imdb_id":"tt0077682","content_type":"movie","title":"Little Lips","original_title":"Piccole labbra","overview":"A writer returns home to his estate after service in World War I. He has developed a very bad case of depression due to a war wound concerning his genitalia. He contemplates suicide, but recovers after becoming interested in his caretaker's 12 year-old war orphan niece, who now lives in the manor.","poster_path":"/rKhJiY9u2L4LInLd7Xdwry1YTdA.jpg","backdrop_path":"/qQ223Np5yxmXiYQthjl2rXmIGlY.jpg","release_date":"1978-02-08","first_air_date":null,"status":"published","original_language":"it","origin_country":["IT"],"genres":[{"id":18,"name":"Drama"},"drama film"],"popularity":5.5423,"vote_average":4.9,"vote_count":27,"runtime":86,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-25T00:45:50.503514+00:00","updated_at":"2026-02-25T00:45:50.339+00:00","tagline":"Love can be a healer but it can also be the most powerful and destructive force on Earth.","homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":4529,"name":"Alba Cinema