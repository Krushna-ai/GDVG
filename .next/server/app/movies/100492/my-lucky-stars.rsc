9:{"metadata":[["$","title","0",{"children":"My Lucky Stars | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Two Hong Kong cops are sent to Tokyo to catch an ex-cop who stole a large amount of money in diamonds. After one is captured by the Ninja-gang protecting the rogue cop, the other one gets his old Orphanage gang, dubbed the \"Five Lucky Stars,\" to help him. They don't like this much, but they do it."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/100492/my-lucky-stars"}],["$","meta","5",{"property":"og:title","content":"My Lucky Stars"}],["$","meta","6",{"property":"og:description","content":"Two Hong Kong cops are sent to Tokyo to catch an ex-cop who stole a large amount of money in diamonds. After one is captured by the Ninja-gang protecting the rogue cop, the other one gets his old Orphanage gang, dubbed the \"Five Lucky Stars,\" to help him. They don't like this much, but they do it."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/100492/my-lucky-stars"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/yd8ot8VNvCau74640ZzmrM0aIZP.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"My Lucky Stars"}],["$","meta","12",{"name":"twitter:description","content":"Two Hong Kong cops are sent to Tokyo to catch an ex-cop who stole a large amount of money in diamonds. After one is captured by the Ninja-gang protecting the rogue cop, the other one gets his old Orphanage gang, dubbed the \"Five Lucky Stars,\" to help him. They don't like this much, but they do it."}],["$","meta","13",{"name":"twitter:image","content":"h