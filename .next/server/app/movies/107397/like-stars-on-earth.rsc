5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Like Stars on Earth\",\"description\":\"Ishaan Awasthi is an eight-year-old whose world is filled with wonders that no one else seems to appreciate. Colours, fish, dogs, and kites don't seem important to the adults, who are much more interested in things like homework, marks, and neatness. Ishaan cannot seem to get anything right in class; he is then sent to boarding school, where his life changes forever.\",\"image\":\"https://image.tmdb.org/t/p/w500/puHRt6Raovm5ujGCdwLWvRv4NHU.jpg\",\"datePublished\":\"2007-12-21\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"IN\",\"inLanguage\":\"hi\",\"genre\":[\"drama film\",\"children's film\",\"musical film\",\"Drama\",null,null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.952,\"bestRating\":10,\"ratingCount\":1291}}"}}],["$","$L10",null,{"initialDrama":{"id":"e2f37bab-b170-4968-a22e-6aaea67d5674","tmdb_id":7508,"imdb_id":"tt0986264","content_type":"movie","title":"Like Stars on Earth","original_title":"तारे ज़मीन पर","overview":"Ishaan Awasthi is an eight-year-old whose world is filled with wonders that no one else seems to appreciate. Colours, fish, dogs, and kites don't seem important to the adults, who are much more interested in things like homework, marks, and neatness. Ishaan cannot seem to get anything right in class; he is then sent to boarding school, where his life changes forever.","poster_path":"/puHRt6Raovm5ujGCdwLWvRv4NHU.jpg","backdrop_path":"/bPwdy3zaNnMdZ22u0WCcYu0xxgt.jpg","release_date":"2007-12-21","first_air_date":null,"status":"published","original_language":"hi","origin_country":["IN"],"genres":[{"name":"drama film"},{"name":"children's film"},{"name":"musical film"},{"id":18,"name":"Drama"},"drama film","children's film","musical film"],"popularity":4.3589,"vote_average":7.952,"vote_count":1291,"runtime":162,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:54:57.632577+00:00","updated_at":"2026-02-21T13:22:19.251+00:00","tagline":"Every child is special.","homepage":null,"budget":2600000,"revenue":28430000,"production_companies":[{"id":2140,"name":"Aamir Khan Productions","logo_path":"/yJIGEhIk3yAWAIiZ4p3xEV1dzwR.png","origin_country":"IN"},{"id":63997,"name":"PVR Inox Pictures","logo_path":"/9uKga6AVuuGzVszeQgjqVYdqWw9.png","origin_country":"IN"},{"id":2320,"name":"UTV Motion Pictures","logo_path":"/nSAXfUCy16cNRiPlBMHeb700t9p.png","origin_country":"IN"}],"production_countries":[{"name":"India","iso_3166_1":"IN"}],"spoken_languages":[{"name":"हिन्दी","iso_639_1":"hi","english_name":"Hindi"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":"PG","keywords":[{"id":931,"name":"jealousy"},{"id":970,"name":"parent child relationship"},{"id":6271,"name":"boarding school"},{"id":437,"name":"painter"},{"id":5905,"name":"father"},{"id":7919,"name":"dyslexia"},{"id":10508,"name":"teacher"},{"id":9736,"name":"little boy"},{"id":14636,"name":"india"},{"id":157955,"name":"childhood"},{"id":193547,"name":"teachers and students"}],"alternative_titles":[{"type":"","title":"每一个孩子都是特别的","iso_3166_1":"CN"},{"type":"","title":"心中的小星星","iso_3166_1":"TW"},{"type":"","title":"Звездочки на земле","iso_3166_1":"RU"},{"type":"","title":"지상의 별처럼","iso_3166_1":"KR"},{"type":"","title":"Como Estrelas na Terra","iso_3166_1":"BR"},{"type":"","title":"Taare Zameen Par","iso_3166_1":"US"},{"type":"","title":"ดวงดาวเล็กๆ บนผืนโลก","iso_3166_1":"TH"},{"type":"informal short title","title":"T.Z.P.","iso_3166_1":"IN"},{"type":"","title":"Taare Zameen Par: Ein Stern auf Erden","iso_3166_1":"DE"},{"type":"","title":"Kochavim Al Pney Ha'Adama","iso_3166_1":"IL"},{"type":"","title":"Her Çocuk Özeldir","iso_3166_1":"TR"},{"type":"Devanagari","title":"तारे ज़मीन पर","iso_3166_1":"IN"},{"type":"","title":"Yerdəki Ulduzlar","iso_3166_1":"AZ"},{"type":"","title":"Taare Zameen Par","iso_3166_1":"IN"}],"videos":[{"id":"58f46d19c3a36807bd01bb7b","key":"tn_2Ie_jtX8","name":"Official Trailer","site":"YouTube","size":720,"type":"Trailer","official":false,"iso_639_1":"en","iso_3166_1":"US","published_at":"2014-08-08T15:08:30.000Z"}],"watch_providers":{"results":{"US":{"link":"https://www.themoviedb.org/movie/7508/watch?locale=US","rent":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17}]}}},"wikidata_id":"Q1043614","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"IN","main_poster":"/lExWH7x3mTM8vZEtjITwS8aZTjU.jpg","images":{"logos":[{"width":877,"height":518,"file_path":"/8a9k1ytiJ55pKiP7YCSOWIjEGwh.png","iso_639_1":"en","vote_average":0},{"width":817,"height":532,"file_path":"/7oYRdE1QEhqcxzaxjex8t4jQRaC.png","iso_639_1":"pt","vote_average":0},{"width":1256,"height":369,"file_path":"/9h2JIO0zpEN85lyRa6lvG4HE2UP.png","iso_639_1":"ja","vote_average":0},{"width":780,"height":530,"file_path":"/4jy35Zpt0njLQ9hd2X5JsWOJEcP.png","iso_639_1":"he","vote_average":0},{"width":565,"height":533,"file_path":"/7dV02zz5NYJ9XIy2B3wNcweOGi4.png","iso_639_1":"it","vote_average":0}],"posters":[{"width":623,"height":934,"file_path":"/lExWH7x3mTM8vZEtjITwS8aZTjU.jpg","iso_639_1":"ru","vote_average":3.334},{"width":500,"height":750,"file_path":"/8SBqDgcYoQHyJbD09ITpjM8MKsx.jpg","iso_639_1":"es","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/lmz3fQV9wrrYiTU1gCdjhAc8pZ6.jpg","iso_639_1":"hi","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/qP8ruHtfYDlrjr1KAeZ5iVBJKE9.jpg","iso_639_1":"hi","vote_average":3.334},{"width":600,"height":900,"file_path":"/pAtjKDGqehJbnbdIxOSruwbIlH8.jpg","iso_639_1":"zh","vote_average":3.334},{"width":800,"height":1200,"file_path":"/wEHkOBcvEiNZpFU1O3HbZLoKSaE.jpg","iso_639_1":"hi","vote_average":2.542},{"width":1536,"height":2048,"file_path":"/puHRt6Raovm5ujGCdwLWvRv4NHU.jpg","iso_639_1":"en","vote_average":2.542},{"width":953,"height":1430,"file_path":"/fwXhw9bERqKrJfJK6WGakPIh3FS.jpg","iso_639_1":"en","vote_average":1.75},{"width":1000,"height":1500,"file_path":"/gpTLhQI0yPiBTBdbGrDKZmiJ2bl.jpg","iso_639_1":"zh","vote_average":0.166},{"width":1200,"height":1721,"file_path":"/cBXvxEt9Q29uwKHcPH3KDrLOxil.jpg","iso_639_1":"ko","vote_average":0},{"width":648,"height":864,"file_path":"/wWPzuez35HzIe5oKsZsOt5fBX6E.jpg","iso_639_1":"tr","vote_average":0},{"width":960,"height":1440,"file_path":"/oi9yZXiTfpXHXk02sRyUY2PlaPi.jpg","iso_639_1":"pt","vote_average":0},{"width":2000,"height":3000,"file_path":"/m0HVW3GxhFpVBQRgxVQaXFjHDO6.jpg","iso_639_1":null,"vote_average":0},{"width":1400,"height":2100,"file_path":"/eU3WnlZPE8ipt8aNEojJ2liKTPT.jpg","iso_639_1":"hu","vote_average":0},{"width":666,"height":1000,"file_path":"/1HYwyJk0SMdqmvDknbMMXa9xfcr.jpg","iso_639_1":"ru","vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/bPwdy3zaNnMdZ22u0WCcYu0xxgt.jpg","iso_639_1":null,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/5dF4FNwM2qZIuF0WCUs5zvDGU2H.jpg","iso_639_1":null,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/ykbLjQn0JOh090yHj3F0TSi4IZI.jpg","iso_639_1":"tr","vote_average":0},{"width":2048,"height":1152,"file_path":"/owqarJSDllJGoEW8EMz8q6cvKDD.jpg","iso_639_1":"en","vote_average":0},{"width":1280,"height":720,"file_path":"/d3QJlk6YNijPzMT5gIAJuszVpcM.jpg","iso_639_1":"en","vote_average":0},{"width":1280,"height":720,"file_path":"/b7Xp9yIaz3JqdEQrbaCjZcFRDOX.jpg","iso_639_1":"en","vote_average":0},{"width":1280,"height":720,"file_path":"/39kPyMD6v9LQtBTKcROj8ojTNAz.jpg","iso_639_1":"ru","vote_average":0}]},"enriched_at":"2026-02-25T14:16:26.797+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Like Stars on Earth","runtime":162,"tagline":"Every child is special.","homepage":"","overview":"Ishaan Awasthi is an eight-year-old whose world is filled with wonders that no one else seems to appreciate. Colours, fish, dogs, and kites don't seem important to the adults, who are much more interested in things like homework, marks, and neatness. Ishaan cannot seem to get anything right in class; he is then sent to boarding school, where his life changes forever."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Taare Zameen Par - Ein Stern auf Erden","runtime":156,"tagline":"","homepage":"","overview":"Ishaan ist anders. Seine Welt ist bunt und voller kleiner Wunder. Denn der Achtjährige nimmt Dinge wahr, für die andere kein Auge haben. Doch seine Eltern und Lehrer halten ihn für zurückgeblieben und schwer erziehbar. Ein strenges Internat soll das ändern. Nur Vertretungslehrer Ram Shankar versteht den eingeschüchterten und setzt alles daran, Ishaan die Freude am Leben zurückzugeben."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Des étoiles sur la terre","runtime":175,"tagline":"","homepage":"","overview":"Ishaan Awasthi, âgé de huit ans, est un enfant espiègle et imaginatif. Issu d'une famille aisée, ses piètres résultats scolaires font le désespoir de ses parents qui décident de l'inscrire dans un pensionnat pour qu'il y acquière rigueur, goût du travail et de la réussite. Mais dans cet environnement rigide et hostile, coupé de sa famille et de ses amis, Ishaan se renferme et s'étiole jusqu'au jour où un jeune professeur découvre ses talents de peintre et sa dyslexie, cause de ses difficultés d'apprentissage."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"地球上的星星","runtime":162,"tagline":"","homepage":"","overview":"对于8岁的男孩伊夏 来说，世界是充满了惊奇和快乐的万花筒，他正在用一切他能够想到的方式和这个陌生的世界进行着交流，同时也充分的享受着大地万物慷慨的赠与。可是，这样的伊夏却是成年人眼中的问题儿童，他的成绩不好，在班上的排名靠后， 脑子里还充满了各种匪夷所思的鬼点子，在又一次闯下大祸后，忍无可忍的父母将他送往了寄宿学校..."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Somos Todos Diferentes","runtime":162,"tagline":"","homepage":"","overview":"Filme conta a história de uma criança que sofre com dislexia e custa a ser compreendida. Ishaan Awasthi, de 9 anos, já repetiu uma vez o terceiro período (no sistema educacional indiano) e corre o risco de repetir de novo. As letras dançam em sua frente, como diz, e não consegue acompanhar as aulas nem focar sua atenção. Seu pai acredita apenas na hipótese de falta de disciplina e trata Ishaan com muita rudez e falta de sensibilidade. Após serem chamados na escola para falar com a diretora, o pai do garoto decide levá-lo a um internato, sem que a mãe possa dar opinião alguma. Tal atitude só faz regredir em Ishaan a vontade de aprender e de ser uma criança. Ele visivelmente entra em depressão, sentindo falta da mãe, do irmão mais velho, da vida… e a filosofia do internato é a de disciplinar cavalos selvagens. Inesperadamente, um professor substituto de artes entra em cena e logo percebe que algo de errado estava pairando sobre Ishaan."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Stelle sulla terra","runtime":162,"tagline":"","homepage":"","overview":"Ishaan Nandkishore Awasthi è un bambino di otto anni con grandi difficoltà a scuola. Ripete la terza classe e ogni materia rappresenta un problema. Dopo un incontro con gli insegnanti, i genitori decidono di iscrivere il bambino in un collegio dove diventa amico di Rajan Damodran, il migliore studente della classe. Anche nel nuovo istituto il bambino non riesce però a fare progressi, fino all'arrivo di un nuovo maestro di arte."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Like Stars on Earth","runtime":162,"tagline":"","homepage":"","overview":"Den lilla 8-åriga pojken Ishaan Awasthi har svårt att hänga med i skolan, utan ägnar sig hellre åt att drömma sig bort och njuta av livets under."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Звездочки на земле","runtime":162,"tagline":"К звёздам из трущоб","homepage":"","overview":"Маленький мальчик 8 лет Ишан Авасти с рождения немного отличается от других детей. Ему дается с трудом то, что у других получается очень легко. Мир не понимает этого ребенка, как и его собственные родители. Когда Ишан в третий раз проваливает экзамены в школе, его отец в наказание отправляет мальчика в школу-интернат. Одиночество губит ребенка, он осуждает себя за расставание с родителями, но и их не может простить. Однажды в жизни Ишана появляется временный учитель рисования Рам Никум — единственный, кто понимает этого ребенка. Рам ставит перед собой цель изменить жизнь мальчика и отношение к нему."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Yerdeki Yıldızlar","runtime":162,"tagline":"Her Çocuk Özeldir","homepage":"","overview":"8 yaşındaki Ishaan Awasthi, hiç kimse tarafından takdir edilmeyen bir çocuktur. Okulda dersleri kötüdür, üstelik arkadaşları ile de sık sık kavga eder. Arkadaşları, öğretmenleri ve ailesi tarafından dışlanan Ishaan, ailesi tarafından disipline sokulması için yatılı okula gönderilir. Burada da durum pek farklı değildir. Ta ki resim öğretmeni Ram Shankar ile tanışana kadar. Ishaan’ın çok mutsuz ve yalnız bir çocuk olduğunu fark eden Ram, bunun nedenini araştırmaya başlar. Onun aslında çok özel bir çocuk olduğunu anlayan öğretmen, sabır ve özenle Ishaan’ın kendisini bulmasına yardımcı olur."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Estrellas en la Tierra","runtime":162,"tagline":"","homepage":"","overview":"Ishaan Awashi es un niño de 8 años cuyo mundo está plagado de maravillas que nadie más parece apreciar: colores, peces, perros y cometas, que simplemente no son importantes en la vida de los adultos, que parecen más interesados en cosas como los deberes, las notas o la limpieza. E Ishaan parece no poder hacer nada bien en clase. Cuando los problemas que ocasiona superan a sus padres, es internado en un colegio para que le disciplinen. Las cosas no mejoran en el nuevo colegio, donde Ishaan tiene además que aceptar estar lejos de sus padres. Hasta que un día, el nuevo profesor de arte, Ram Shankar Nikumbh, entra en escena y se interesa por el pequeño Ishaan."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"כוכבים על פני האדמה","runtime":162,"tagline":"כל ילד הוא מיוחד.","homepage":"","overview":"אישן, ילד שאוהב לחלום בהקיץ , נשלח לפנימייה ופוגש במורה מיוחד לאומנות שמנסה לעזור לילד היצירתי לגלות את זהותו האמיתית."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Зіроньки на Землі","runtime":162,"tagline":"Кожна дитина - унікальна","homepage":"","overview":"Восьмирічний хлопчик Ішан Авасті не такий, як інші діти. Йому важко дається те, що іншим дітям його віку дається легко. Світ не розуміє хлопчика, навіть рідні батьки його не розуміють. Коли Ішан втретє провалює шкільні іспити, батько, щоб покарати сина, відправляє його до школи-інтернату. Самотність спустошує дитину, Ішан докоряє собі за розлуку з батьками, але й їм не може пробачити. Одного дня в житті хлопчика з'являється вчитель малювання Рам Нікум – єдина людина, котра його розуміє. Рам ставить собі за мету змінити життя Ішана…"},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Como Estrelas na Terra","runtime":165,"tagline":"Toda Criança é Especial.","homepage":"","overview":"É a história de uma criança que sofre com dislexia e custa a ser compreendida. O jovem Ishaan, não consegue acompanhar as aulas ou focar sua atenção, e é tratado com muita rudeza por seu pai. Após serem chamados pela escola, o pai decide levá-lo a um internato, atitude que leva o pequeno a entrar em depressão. Um professor substituto de artes, Nikumbh, logo percebe o problema de Ishaan, e entra em ação com seu plano para devolver a ele a vontade de viver."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"지상의 별처럼","runtime":162,"tagline":"넘버원이 아니어도 돼 넌 세상에서 가장 특별한 Only.1이니까!","homepage":"","overview":"하늘의 별보다 더 빛나는  세상의 아이들은 모두 특별한 존재이다!  인도의 작은 마을, 아직은 세상의 모든 것이 신기한 8살 꼬마 아이 이샨이 있다.  물 속의 물고기는 이샨의 눈 속에서 친구가 되고, 숫자들은 눈 앞에서 날아 다닌다.  하지만 이샨의 상상력은 주위 사람들에게는 이상하게만 보인다.  친구들에게는 엉뚱한 소리만 하는 이상한 왕따가 되어가고,  선생님한테는 글 하나 제대로 읽지 못하는 문제아로 보이기 시작한다.  부모는 이샨에게 문제가 있다고만 생각해 엄격한 기숙학교로 이샨을 보내 버린다.  이샨은 자신의 뭘 잘못했는지도 모른채 낯선 환경에 홀로 남겨진다.  8살 나이에는 감당하기 힘든 외로움과 자괴감에  마음을 닫고 힘들어하는 이샨의 앞에  인생의 멘토,  미술 선생님 니쿰브가 나타난다.  학교의 선생들도, 심지어 부모조차 알지 못했던 이샨에게는 난독증이 있었고  니쿰브 선생님은 장애를 가능성으로 바꾸어 이샨의 속에서 별처럼 빛나는 능력을 발견한다.  조금씩 마음을 열어가는 이샨.  그리고 이샨을 넘버원이 아닌 세상에서 가장 특별한 온리원으로 만들고 싶은  니쿰브 선생님의 반짝이는 동행이 시작된다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Звезди на Земята","runtime":163,"tagline":"","homepage":"","overview":"Ишан е осен годишен, чийто свят е пълен с чудеса, но изглежда, че никой друг не го оценява. Цветове, риба, кучета и хвърчила просто не са важни в света на възрастните, които са много по-заинтригувани от домакинството, забележките и чистотата. Ishaan не изглежда, че може да прави правилното нещо в клас.  Когато се забърка в по-големи неприятности, тогава родителите му могат да го накажат. Той е изпратен в училище-интернат, за да бъде дисциплиниран. Нещата не са по-различни в новото училище и Ишан трябва да се бори с допълнителната травма на отделяне от семейството му. Един ден, нов учител по изкуство разпуква на сцената, Рам Шанкар, който заразява учениците с радост и оптимизъм. Той разбива всички правила за това \"как се правят нещата\", като ги моли да мислят, мечтаят и да си представит, и всички деца отвръщат с ентусиазъм, всички с изключение Ишан."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Σαν αστέρια στη γη","runtime":162,"tagline":"","homepage":"","overview":"Η ταινία πραγματεύεται το θέμα της δυσλεξίας. Αγγίζοντας με αληθινό και αφοπλιστικό τρόπο όλες τις πτυχές του φαινομένου, καταφέρνει να συγκινήσει και να προβληματίσει."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"心中的小星星","runtime":162,"tagline":"","homepage":"","overview":"《心中的小星星》是一部2007年的印度電影，由阿米爾·罕執導。「心中的小星星」講述了一位患有學習障礙的八九歲的孩子在遇到覺察出他在學習上掙扎的老師後，在他的陪伴和引領下成長的故事，是一部談及教育本質的電影。「每一個天資獨特的孩子，都需要一個懂他的老師」這是電影裡所傳達出來的核心信念，然而讓人讚嘆的是電影的手法並不刻意放入教育的氛圍，而著眼於人的關懷。更有甚者，精彩的畫面設計，以及讓人無可忽略的配樂歌曲，都讓整部電影活了起來。影片於2007年12月21日在印度首演，獲2008年印度電影觀眾獎最佳影片獎、印度國家電影獎最佳家庭電影獎。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Stele pe pământ","runtime":165,"tagline":"","homepage":"","overview":"Un profesor de arte, Ram Shankar Nikumbh predă la o școala locală și crede că fiecare copil este special în felul lui și că fiecare trebuie să aibă șansa să se bucure de zilele petrecute în școală, așa că încalcă puțin regulile referitoare la „cum trebuie făcute lucrurile” în școală. Metoda lui este un adevărat succes, toți copiii răspund cu bucurie, în afară de un băiețel de 8 ani, Ishaan Awasthi, care pare să trăiasca tot timpul într-o altă lume. Nikumbh descoperă că băiețelul este nefericit dintr-o cauză anume. Acum provocarea este să afle motivul pentru care este trist și să încerce să îl ajute."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Taare Zameen Par","runtime":165,"tagline":"","homepage":"","overview":"Ishaan Awasthi is een achtjarige jongen, die meer geïnteresseerd is in zijn omgeving, dan in school. Hierdoor wordt hij naar kostschool gestuurd. Ook hier haalt hij slechte cijfers."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Kiel steloj surtere","runtime":162,"tagline":"","homepage":"","overview":""},"name":"Esperanto","iso_639_1":"eo","iso_3166_1":"EO","english_name":"Esperanto"},{"data":{"title":"كالنجوم على الأرض","runtime":162,"tagline":"كل طفل مميز","homepage":"","overview":"Ishaan Awasthi هو طفل يبلغ من العمر ثماني سنوات وعالمه مليء بالعجائب التي لا يبدو أن أي شخص آخر يقدرها. لا تبدو الألوان والأسماك والكلاب والطائرات الورقية مهمة للبالغين ، الذين يهتمون كثيرًا بأشياء مثل الواجبات المنزلية والعلامات والأناقة. لا يبدو أن إيشان تحصل على أي شيء بشكل صحيح في الفصل ؛ ثم يتم إرساله إلى مدرسة داخلية ، حيث تتغير حياته إلى الأبد."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"地上の星たち","runtime":162,"tagline":"","homepage":"","overview":"学校でも家庭でも問題児となっていた8歳のイシャーン。勉強が苦手な彼は代わりに空想が好きだった。近所の年上の男の子を取っ組み合いの喧嘩をしたイシャーンは、父親に次に問題を起こしたら寄宿学校に入れると言われてしまう。 すこぶる悪い点数のテストを両親に見せられずサインをもらえなかった彼は、授業をサボってしまう。欠席届を出さないといけなかったため、兄のヨハンに書いてもらう。しかしある日、その欠席届が父に見つかってしまう。約束を守れなかったイシャーンに対して激怒した父は、友人のコネを使いすぐにイシャーンを寄宿学校に転校させる。 学校にはいままでよりさらに厳しい先生たちがいたうえ、家族に会えない寂しさが募り、イシャーンにとって非常に辛い環境だった。とうとう完全にふさぎこんでしまうイシャーンだったが、ちょうどその時、臨時で新しい美術の先生ニクンブ が赴任してくる。 ニクンブはイシャーンの様子を見て、彼は失読症であることを見抜くが…。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Jako hvězdy na Zemi","runtime":162,"tagline":"","homepage":"","overview":"Devítiletý chlapec je sužován svým okolím - ve škole není schopen přečíst jedinou větu, nosí špatné známky a s tím se nesou i další problémy - dusno doma, šikana... Smyčka kolem krku se mu utahuje, až se zoufalý otec rozhodne \"nepovedeného\" synka poslat na internát. Tam po mnoha útrapách potkává nového učitele výtvarné výchovy, který ví zcela přesně, jak se jeho problém nazývá - dyslexie. A začíná osvěta na všechny strany a vše se začíná obracet k lepšímu..."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Mint a csillagok a földön","runtime":162,"tagline":"","homepage":"","overview":"A nyolc éves Ishaan számára az iskola csupa szenvedés. Nem elég, hogy nehezen boldogul a tanulással, még az iskolatársaival és a tanáraival is küzdenie kell. A helyzet otthon sem jobb, hiszen szülei lustának és butának tartják, amiért mindig csupa rossz jegyet hoz haza. Pedig Ishaan világa tele van csodákkal, hála színes képzeletének és művészi hajlamának. Ezt a világot azonban senki nem akarja észrevenni egészen addig, míg a bentlakásos iskolába új tanár nem érkezik."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Como estrellas en la tierra","runtime":162,"tagline":"Lo importante de la infancia","homepage":"","overview":"Ishaan Awasthi es un niño de ocho años cuyo mundo está lleno de maravillas que nadie más parece apreciar. Los colores, los peces, los perros y las cometas no parecen importantes para los adultos, que están mucho más interesados en cosas como los deberes, las notas y la pulcritud. Ishaan parece no poder hacer nada bien en clase; luego lo envían a un internado, donde su vida cambia para siempre."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"ვარსკვლავები დედამიწაზე","runtime":162,"tagline":"","homepage":"","overview":"პატარა 8 წლის იშან ავატი დანადებიდან განსხვავდება სხვა ბავშვებისაგან. მას გაცილებით უჭირს იმის ათვისება დასაც მისი ასაკის ბავშვები მარტივად აკეთებენ. მისი გაგება მშობლებს უჭირთ, როდესაც იშანი მესამე ჯერზეც ვერ ჩააბარებს გამოცდას სკოლაში, მამა დასჯის და სკოლა-ინტერნატში გააგზავნის."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"ดวงดาวเล็กๆ บนผืนโลก","runtime":162,"tagline":"","homepage":"","overview":"อิชานคือเด็กน้อยช่างฝันที่ถูกส่งไปโรงเรียนประจำ ครูศิลปะหัวสมัยใหม่พยายามช่วยให้เด็กมากจินตนาการคนนี้ค้นพบตัวตนที่แท้จริง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"心中的小星星","runtime":162,"tagline":"","homepage":"","overview":"成天作白日夢的伊山被送去念寄宿學校後，一名新潮的美術老師努力幫助這位充滿想像力的學生，探索他真正的一面。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Gwiazdy na ziemi","runtime":162,"tagline":"","homepage":"","overview":"Niezwykła historia małego chłopca, który zamknięty jest w świecie marzeń, fantazji i cudów. Mimo, że widzi wszystko w kolorowych barwach, nikt nie podziela jego wizji. Dorośli nie rozumieją jego fascynacji zwykłymi, przyziemnymi zjawiskami. Rodzice są rozczarowani jego wynikami w szkole, gdyż Ishaan nie potrafi sprostać stawianym mu zadaniom. Nie umie czytać ani liczyć. Nikt nie potrafi mu pomóc. Jest odrzucany i pogardzany. W końcu chłopiec nie wytrzymuje presji, zaczyna się buntować, przestaje chodzić do szkoły. Zostaje więc wysłany do szkoły z internatem. To jeszcze bardziej deprymuje Ishaana – jeszcze bardziej zamyka się w sobie, a świat powoli zaczyna tracić kolory. Jednak znajduje przyjazną duszę – nauczyciela rysunku, który rozumie chłopca i pragnie mu pomóc.."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Like Stars on Earth","runtime":162,"tagline":"","homepage":"","overview":"Ishaan, un rêveur débordant d'imagination, est envoyé au pensionnat, où un professeur d'art original tente de l'aider à découvrir sa vraie nature."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Ligesom stjerner på jorden","runtime":162,"tagline":"","homepage":"","overview":"Da dagdrømmeren Ishaan bliver sendt på kostskole, forsøger en utraditionel billedkunstlærer at hjælpe den fantasifulde elev med at realisere sig selv."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":162,"tagline":"","homepage":"","overview":"सपनों की दुनिया में रहने वाले ईशान को हॉस्टल भेज दिया जाता है, जहां लीक से हट कर सोचने वाला एक टीचर उसकी कल्पना को उड़ान भरने के लिए नए पंख देता है."},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"地球上的星星","runtime":162,"tagline":"","homepage":"","overview":"爱好幻想的伊夏被送至寄宿学校，一位打破常规的美术老师试图帮助这名富有想象力的学生找到自我。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"المشاكس الموهوب","runtime":162,"tagline":"كل طفل مميز","homepage":"","overview":"عندما يُرسَل \"إيشان\" الحالِم إلى مدرسة داخلية، يحاول معلّم الفن غير التقليدي مساعدة التلميذ واسع المخيلة على اكتشاف هويته الحقيقية."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"Taare Zameen Par","runtime":162,"tagline":"","homepage":"","overview":"Als dagdromer Ishaan naar een kostschool wordt gestuurd, probeert een onconventionele kunstdocent de creatieve student te helpen om zijn ware identiteit te ontdekken."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"Taare Zameen Par - Ein Stern auf Erden","runtime":162,"tagline":"","homepage":"","overview":"Tagträumer Ishaan wird von seinen Eltern ins Internat geschickt. Doch ein unkonventioneller Kunstlehrer hilft dem malbegabten Schüler dabei, sich selbst zu finden."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"Taare Zameen Par - Ein Stern auf Erden","runtime":162,"tagline":"","homepage":"","overview":"Tagträumer Ishaan wird von seinen Eltern ins Internat geschickt. Doch ein unkonventioneller Kunstlehrer hilft dem malbegabten Schüler dabei, sich selbst zu finden."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"CH","english_name":"German"},{"data":{"title":"Like Stars on Earth","runtime":162,"tagline":"","homepage":"","overview":"Dagdrømmeren Ishaan blir sendt på kostskole, der en utradisjonell lærer prøver å hjelpe den oppfinnsomme studenten med å finne seg selv."},"name":"Bokmål","iso_639_1":"nb","iso_3166_1":"NO","english_name":"Norwegian Bokmål"},{"data":{"title":"Like Stars on Earth","runtime":162,"tagline":"","homepage":"","overview":"Dagdrømmeren Ishaan blir sendt på kostskole, der en utradisjonell lærer prøver å hjelpe den oppfinnsomme studenten med å finne seg selv."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Like Stars on Earth","runtime":162,"tagline":"","homepage":"","overview":"Dagdrømmeren Ishaan blir sendt på kostskole, der en utradisjonell lærer prøver å hjelpe den oppfinnsomme studenten med å finne seg selv."},"name":"","iso_639_1":"nn","iso_3166_1":"NN","english_name":"Norwegian Nynorsk"},{"data":{"title":"Taare Zameen Par","runtime":162,"tagline":"","homepage":"","overview":"Mielikuvituksekas Ishaan joutuu sisäoppilaitokseen, jossa omaperäinen kuvaamataidon opettaja yrittää auttaa nuorta haaveilijaa löytämään todellisen identiteettinsä."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Cậu Bé Đặc Biệt","runtime":0,"tagline":"","homepage":"","overview":"Ishaan Awasthi là một cậu bé tám tuổi có thế giới tràn ngập những điều kỳ diệu mà dường như không ai khác đánh giá cao. Màu sắc, con cá, con chó và con diều dường như không quan trọng đối với người lớn, những người quan tâm nhiều hơn đến những thứ như bài tập về nhà, điểm số và sự ngăn nắp. Ishaan dường như không thể đạt được bất cứ điều gì trong lớp; sau đó anh ấy được gửi đến trường nội trú, nơi cuộc sống của anh ấy thay đổi mãi mãi."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Žemės Žvaigždutės","runtime":0,"tagline":"","homepage":"","overview":"Aštuonmetis Išanas atrodo kaip visi jo bendraamžiai, tačiau jam nesiseka mokykloje. Blogi pažymiai, mokytojų ir bendraklasių patyčios ir kitos nesėkmės lydi Išaną, kad ir ką jis bedarytų.  Tėvai suka galvą, kaip išgydyti sūnaus tinginystę, o Išanas tuo tarpu nuo jį supančios kasdienybės pabėga į savo sugalvotą spalvotą fantazijų pasaulį. Neapsikentę sūnaus nesėkmių mokykloje, tėvai išsiunčia jį į internatą, tikėdamiesi, kad griežtesnė tvarka “išgydys“ berniuką. Ir tik pasirodžius naujam mokytojui ima aiškėti Išano tikrosios problemos. Filmas “Žemės Žvaigždutės” – šiltas ir nuoširdus Amiro Khano kūrinys, vienas iš nedaugelio Indijos filmų, nagrinėjančių vidinį vaiko pasaulį, vaizduotę ir bandymą pritapti visuomenėje. Filmas – ir ypač Išano personažo atlikėjas Darsheel Safary – jau per pirmąsias demonstravimo savaites susilaukė daugybės žiūrovų simpatijų."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"}],"reviews_tmdb":[],"recommendations":[{"id":611791,"adult":false,"title":"Star","video":false,"overview":"Tito and Jay are two brothers living in the Montreal neighborhood of Park Extension. Accompanying these young people in their daily life marked by complicity and intimidation, Star tackles themes dear to teenagers: identity and friendship.","genre_ids":[],"media_type":"movie","popularity":0.1542,"vote_count":38,"poster_path":"/hVGnSMBc42TGwvV5QTHpH0PgyJp.jpg","release_date":"2015-09-30","vote_average":5.8,"backdrop_path":null,"original_title":"Star","original_language":"fr"},{"id":587030,"adult":false,"title":"Kaithi","video":false,"overview":"Dilli, a convicted criminal, is out on parole to meet his daughter. However, a drug bust sets him off on a mission to save the life of police officers.","genre_ids":[28,53,80],"media_type":"movie","popularity":0.6091,"vote_count":141,"poster_path":"/mxvOvom5zKRp4WPURKrhjoatt4P.jpg","release_date":"2019-10-25","vote_average":7.585,"backdrop_path":"/seTFDq1iKyJ6YHr7HePbC20DMsy.jpg","original_title":"கைதி","original_language":"ta"},{"id":7913,"adult":false,"title":"Rang De Basanti","video":false,"overview":"After a group of friends graduate from Delhi University, they listlessly haunt their old campus, until a British filmmaker casts them in a film she's making about freedom fighters under British rule. Although the group is largely apolitical, the tragic death of a friend owing to local government corruption awakens their patriotism. Inspired by the freedom fighters they represent in the film, the friends collectively decide to avenge the killing.","genre_ids":[35,18,36,10749],"media_type":"movie","popularity":1.0505,"vote_count":486,"poster_path":"/f1bF8CHzEu621bPSIg6XiUNAabh.jpg","release_date":"2006-01-26","vote_average":7.083,"backdrop_path":"/fgRhyGbMAolDsQ65VRBRBtVQZNn.jpg","original_title":"रंग दे बसंती","original_language":"hi"},{"id":360814,"adult":false,"title":"Dangal","video":false,"overview":"Dangal is an extraordinary true story based on the life of Mahavir Singh and his two daughters, Geeta and Babita Phogat. The film traces the inspirational journey of a father who trains his daughters to become world class wrestlers.","genre_ids":[18,10751,35],"media_type":"movie","popularity":3.2308,"vote_count":1114,"poster_path":"/1CoKNi3XVyijPCvy0usDbSWEXAg.jpg","release_date":"2016-12-21","vote_average":7.895,"backdrop_path":"/l0fNAHLOFReQJsxCOmGWvJDnimn.jpg","original_title":"दंगल","original_language":"hi"},{"id":8453,"adult":false,"title":"Fanaa","video":false,"overview":"Zooni Ali Beg is a blind Kashmiri girl who travels without her parents for the first time with a dance troupe to Delhi to perform in a ceremony for independence day. On her journey, she meets Rehan Khan, a casanova and tour guide who flirts with her. Although her friends warn Zooni about him, she cannot resist falling in love with him and he takes her on a private tour of New Delhi. But there is more to Rehan than meets the eye and Zooni will have to make a heartbreaking decision.","genre_ids":[28,18,10749,53],"media_type":"movie","popularity":0.9993,"vote_count":221,"poster_path":"/1Ji0nyfJmXJDw5icyOZcsVAyiiT.jpg","release_date":"2006-05-26","vote_average":6.751,"backdrop_path":"/97wqvp0BXrXQyKhFCasdZ1XR0tI.jpg","original_title":"फ़ना","original_language":"hi"},{"id":14070,"adult":false,"title":"Ghajini","video":false,"overview":"A man suffering from anterograde amnesia as a result of a violent attack in the past sets out to avenge his girlfriend's death with the aid of photographs, notes and tattoos all over his body.","genre_ids":[28,10749,53],"media_type":"movie","popularity":1.4513,"vote_count":433,"poster_path":"/cPLzHxPFRjzNvoyncdtDGBAxjp.jpg","release_date":"2008-12-25","vote_average":6.985,"backdrop_path":"/lDOwQKy0PjXmp9K6mZ87vb8t31B.jpg","original_title":"गजनी","original_language":"hi"},{"id":114372,"adult":false,"title":"Fist of the North Star: Legend of Raoh - Chapter of Fierce Fighting","video":false,"overview":"A film adaptation of the Last Nanto General story arc from the manga, depicting the final battle between Kenshiro and Raoh that led to Kenshiro becoming the successor of Hokuto Shinken. Some events from the manga / anime have been excluded from the story (such as Raoh's fight with Juza) whereas others have been altered or expanded. New content featuring the final battle from Raoh's perspective have been added. This film serves as the follow-up to the first film in the series, which introduced Raoh and Reina's relationship, this time bringing it to a conclusion.","genre_ids":[28,16,12,10749],"media_type":"movie","popularity":1.6598,"vote_count":81,"poster_path":"/kghwkWiK99pPscP61Tm771Vu5lm.jpg","release_date":"2007-04-28","vote_average":6.488,"backdrop_path":"/qtr8bm14X04mcq8chjSJmNX5TJm.jpg","original_title":"真救世主伝説 北斗の拳 ラオウ伝 激闘の章","original_language":"ja"},{"id":20453,"adult":false,"title":"3 Idiots","video":false,"overview":"Rascal. Joker. Dreamer. Genius... You've never met a college student quite like \"Rancho.\" From the moment he arrives at India's most prestigious university, Rancho's outlandish schemes turn the campus upside down—along with the lives of his two newfound best friends. Together, they make life miserable for \"Virus,\" the school’s uptight and heartless dean. But when Rancho catches the eye of the dean's daughter, Virus sets his sights on flunking out the \"3 idiots\" once and for all.","genre_ids":[18,35],"media_type":"movie","popularity":4.5657,"vote_count":2642,"poster_path":"/66A9MqXOyVFCssoloscw79z8Tew.jpg","release_date":"2009-12-23","vote_average":7.997,"backdrop_path":"/8gT3UKtglLVpu0YfccwbmXZ5Eis.jpg","original_title":"3 Idiots","original_language":"hi"},{"id":297222,"adult":false,"title":"PK","video":false,"overview":"A stranger in the city asks questions no one has asked before. Known only by his initials, the man's innocent questions and childlike curiosity take him on a journey of love, laughter and letting go.","genre_ids":[35,18,878],"media_type":"movie","popularity":5.6684,"vote_count":1118,"poster_path":"/z2x2Y4tncefsIU7h82gmUM5vnBJ.jpg","release_date":"2014-12-18","vote_average":7.707,"backdrop_path":"/gxfvtq5eYiClS2X7hxAAPBNrbWA.jpg","original_title":"पीके","original_language":"hi"},{"id":109080,"adult":false,"title":"Fist of the North Star: The Legend of the True Savior: Legend of Raoh-Chapter of Death in Love","video":false,"overview":"A film adaptation of the Holy Emperor story arc, which primarily depicted the conflict between Kenshiro and Souther. New characters Reina, one of Raoh's army officers who falls in love with him, and her brother Soga, Raoh's advisor, play an important part with much of the plot involving Raoh's relationship with Reina as he conquers the land; most of this portion is new content exclusive to this film. The other side of the story is the retelling of Ken's attempt to save and protect the villagers from Souther's army with the help of Shū. There is also a small subplot of Bart returning to his home.","genre_ids":[16,28,12],"media_type":"movie","popularity":1.5128,"vote_count":96,"poster_path":"/yZfAVFIlzA61dsHZx5cyUX9PzYX.jpg","release_date":"2006-03-11","vote_average":6.667,"backdrop_path":"/ur8uFUIS1hRCZjn5ykDf7iDIiDV.jpg","original_title":"真救世主伝説 北斗の拳 ラオウ伝 殉愛の章","original_language":"ja"},{"id":412862,"adult":false,"title":"Ratsasan","video":false,"overview":"A serial killer is murdering school girls, and a newbie cop has to track him down before the victim count increases.","genre_ids":[53,80,9648],"media_type":"movie","popularity":1.0778,"vote_count":180,"poster_path":"/mruUFlrVKiL994y3vvQBT8R2Vnf.jpg","release_date":"2018-10-05","vote_average":7.4,"backdrop_path":"/fMH9dtbohJegWDgOEM2ZJSfcrDi.jpg","original_title":"ராட்சசன்","original_language":"ta"},{"id":19625,"adult":false,"title":"Munna Bhai M.B.B.S.","video":false,"overview":"A gangster sets out to fulfill his father's dream of becoming a doctor.","genre_ids":[35,18],"media_type":"movie","popularity":0.8158,"vote_count":343,"poster_path":"/nZNUTxGsSB4nLEC9Bpa2xfu81qV.jpg","release_date":"2003-12-19","vote_average":7.171,"backdrop_path":"/smaFFzbd1flJKUqDI2ylljQ8Pki.jpg","original_title":"मुन्ना भाई एम बी बी एस","original_language":"hi"},{"id":118628,"adult":false,"title":"English Vinglish","video":false,"overview":"In the United States for the first time, an Indian housewife with a limited command of English turns Manhattan into her personal language school.","genre_ids":[35,18,10751],"media_type":"movie","popularity":1.0939,"vote_count":285,"poster_path":"/ccEVR8sf18psGH5daio9y7OGu93.jpg","release_date":"2012-09-21","vote_average":7.253,"backdrop_path":"/5faqsJ8TMT0IhkZ1xgD6PEWm8xm.jpg","original_title":"इंग्लिश विंग्लिश","original_language":"hi"},{"id":1412,"adult":false,"title":"sex, lies, and videotape","video":false,"overview":"Ann, a frustrated wife, enters into counseling due to a troubled marriage. Unbeknownst to her, her husband John has begun an affair with her sister. When John’s best friend Graham arrives, his penchant for interviewing women about their sex lives forever changes John and Ann’s rocky marriage.","genre_ids":[18],"media_type":"movie","popularity":4.3553,"vote_count":1005,"poster_path":"/pj1uKm07svgXZDHbYE8AzRfNHcu.jpg","release_date":"1989-08-04","vote_average":6.938,"backdrop_path":"/wD95UmpUazo9820qnbbjRtbQ884.jpg","original_title":"sex, lies, and videotape","original_language":"en"},{"id":928,"adult":false,"title":"Gremlins 2: The New Batch","video":false,"overview":"Young sweethearts Billy and Kate move to the Big Apple, land jobs in a high-tech office park and soon reunite with the friendly and lovable Gizmo. But a series of accidents creates a whole new generation of Gremlins. The situation worsens when the devilish green creatures invade a top-secret laboratory and develop genetically altered powers, making them even harder to destroy!","genre_ids":[35,27,14],"media_type":"movie","popularity":3.7069,"vote_count":2829,"poster_path":"/35F5yD7MljvBE2AC0NHAVCoPGEi.jpg","release_date":"1990-06-15","vote_average":6.524,"backdrop_path":"/iR3tV8NXFls4UKzPA60D4zrI7Jh.jpg","original_title":"Gremlins 2: The New Batch","original_language":"en"},{"id":28165,"adult":false,"title":"The Toxic Avenger Part II","video":false,"overview":"Melvin Junko was a nerdy weakling until he fell into a vat of toxic waste, turning him into the first ever superhuman creature from New Jersey. This time, he takes on Tokyo.","genre_ids":[28,35,27,878],"media_type":"movie","popularity":0.9271,"vote_count":197,"poster_path":"/m5o7B3VSAjvinjtSYxXD38senvb.jpg","release_date":"1989-07-15","vote_average":5.396,"backdrop_path":"/oZQNh7OuSsLyPDyyEXPOFILQ6ko.jpg","original_title":"The Toxic Avenger Part II","original_language":"en"},{"id":547654,"adult":false,"title":"Badhaai Ho","video":false,"overview":"A 25-year-old man tries to suppress his embarrassment when his mother announces that she is pregnant.","genre_ids":[35,10749,18],"media_type":"movie","popularity":0.618,"vote_count":167,"poster_path":"/1RCzZkjxnL9MiAOP4oQQm63Ku0p.jpg","release_date":"2018-10-19","vote_average":7.189,"backdrop_path":"/wFOgP3PX907fhfVpeP3YItmPQtS.jpg","original_title":"बधाई हो","original_language":"hi"},{"id":54890,"adult":false,"title":"Dhobi Ghat","video":false,"overview":"Arun is a reclusive and lonely modern art painter. Shai is an American banker who is on a visit to Mumbai. Munna is a washerboy also living near Arun and Yasmin. The movie is about these four characters from different class of society and how the lives of four characters are intertwined.","genre_ids":[18],"media_type":"movie","popularity":0.6114,"vote_count":90,"poster_path":"/hSNbvyrRbfAxz29yJSz7bJ1Ujuu.jpg","release_date":"2010-01-21","vote_average":6.428,"backdrop_path":"/vs4kj5fFi2UaOAglZZstvbyETvp.jpg","original_title":"धोबी घाट","original_language":"hi"},{"id":27953,"adult":false,"title":"For Love and Honor","video":false,"overview":"Ali Osman is a former bully of city of Istanbul. But lately he gives up bully and starts to operate a synthetic pitch. He often meets his old friends, former bullies, too. One day Ali Osman receives a news which is related with his previous passionate life. Then the whole action stats as a chain of events.","genre_ids":[28,80,18],"media_type":"movie","popularity":1.9692,"vote_count":113,"poster_path":"/q8mpVlzCOoF92bHICJkJQGodqVN.jpg","release_date":"2007-12-13","vote_average":7.133,"backdrop_path":"/440vQGWmldYZqiVQitKOwCxpF3U.jpg","original_title":"Kabadayı","original_language":"tr"},{"id":128341,"adult":false,"title":"Ci hai rotto papà","video":false,"overview":"Kids from a huge apartment complex in Rome form a secret society to unite their forces and get back at the nasty adults who 'oppress' them, playing pranks on them to expose their weaknesses.","genre_ids":[35],"media_type":"movie","popularity":0.2977,"vote_count":100,"poster_path":"/ouTV4zQAXRDY32W1SZkEQOwMlSn.jpg","release_date":"1993-09-03","vote_average":6.12,"backdrop_path":"/qtpWXlBxueMtNT3SfAFAVHtEEKN.jpg","original_title":"Ci hai rotto papà","original_language":"it"}],"similar_content":[{"id":1124876,"adult":false,"title":"Ulajh","video":false,"overview":"The journey of a young IFS officer, belonging to a prominent family of patriots, who gets embroiled in a dangerous personal conspiracy while far from her home turf, at a career-defining post.","genre_ids":[18,53],"popularity":0.4481,"vote_count":13,"poster_path":"/tRTaE89m8As6G6aqgYjCBmm6MKN.jpg","release_date":"2024-08-02","vote_average":5.462,"backdrop_path":"/gOvb0MWKeg97AWr7Cpvi3aDnB0r.jpg","original_title":"Ulajh","original_language":"hi"},{"id":166,"adult":false,"title":"The Party","video":false,"overview":"A thirteen-year-old French girl deals with moving to a new city and school in Paris, while at the same time her parents are getting a divorce.","genre_ids":[18,10749,35],"popularity":3.2982,"vote_count":1199,"poster_path":"/usGV1Q7KWR0Uq4dOIppGZ0ba8kz.jpg","release_date":"1980-12-17","vote_average":6.595,"backdrop_path":"/An4QeEvTDmWBnDmorMo0H8xxn6w.jpg","original_title":"La Boum","original_language":"fr"},{"id":171,"adult":false,"title":"The Party 2","video":false,"overview":"A young French teenage girl after moving to a new city falls in love with a boy and is thinking of having sex with him because her girlfriends have already done it.","genre_ids":[35,10749,18],"popularity":1.153,"vote_count":649,"poster_path":"/pbkccDoxH1H1VdqWcQYycZxHTIK.jpg","release_date":"1982-12-08","vote_average":6.4,"backdrop_path":"/apgY9DqYzqgMAGu0HRhOkJi8mHV.jpg","original_title":"La Boum 2","original_language":"fr"},{"id":175,"adult":false,"title":"The Big Blue","video":false,"overview":"Childhood friends Jacques and Enzo share a passion for the danger of free diving. Professional diver Jacques opted to follow in the footsteps of his father, who died at sea when Jacques was a boy; to the bewilderment of scientists, Jacques harbors a remarkable ability to adjust his heart rate and breathing pattern in the water, so that his vital signs more closely resemble that of dolphins than men. As Enzo persuades a reluctant Jacques to compete against him in a free diving contest -- determining who can dive deeper and longer without scuba gear -- Jacques meets Johana, a beautiful American insurance investigator, and finds that he must choose between his love for her and his love of the sea.","genre_ids":[10749,12,18],"popularity":2.7086,"vote_count":1536,"poster_path":"/3t5t7yaFiTJQlqxiTkXJMFZdkh3.jpg","release_date":"1988-05-10","vote_average":7.444,"backdrop_path":"/1J28PJOkusMN5Ab9Q3oF310e11k.jpg","original_title":"Le Grand Bleu","original_language":"fr"},{"id":191,"adult":false,"title":"The State I Am In","video":false,"overview":"Clara and Hans are left-wing terrorists who have been sought by police for almost fifteen years. Their increasingly rebellious daughter Jeanne begins to pose a threat to their security when she falls in love with a boy she meets on the beach.","genre_ids":[18],"popularity":0.2208,"vote_count":64,"poster_path":"/wQoYYvXYaeZNsGPtP1vvvyTmuhF.jpg","release_date":"2001-02-01","vote_average":6.8,"backdrop_path":"/xCkTEYAF5mQIgJzdqhrqoI8IXll.jpg","original_title":"Die innere Sicherheit","original_language":"de"},{"id":207,"adult":false,"title":"Dead Poets Society","video":false,"overview":"At an elite, old-fashioned boarding school in New England, a passionate English teacher inspires his students to rebel against convention and seize the potential of every day, courting the disdain of the stern headmaster.","genre_ids":[18],"popularity":11.8108,"vote_count":12309,"poster_path":"/l5NbiHKUmahlAT3Q1ig8Tyl9xrc.jpg","release_date":"1989-06-02","vote_average":8.301,"backdrop_path":"/yYvBNN96Ym3wtPxGCFl7F888WwB.jpg","original_title":"Dead Poets Society","original_language":"en"},{"id":247430,"adult":false,"title":"Meera","video":false,"overview":"Meera, a devotee of Lord Krishna, believes she is married to the lord and rejects her marriage to a Rajput prince. However, her spirituality leads her to face many hardships.","genre_ids":[18,36],"popularity":0.1743,"vote_count":0,"poster_path":"/fLNGltURx1dFtIzyg55tIx3J5GR.jpg","release_date":"1979-05-18","vote_average":0,"backdrop_path":"/aMj0ka2IlRGiq426MUfrM6jbnME.jpg","original_title":"मीरा","original_language":"hi"},{"id":247472,"adult":false,"title":"Saare Jahaan Se Mehnga","video":false,"overview":"A satire on inflation-hit middle-class Indian family from a small city in North India. The story revolves around our protagonist who is struggling to survive in this spiraling inflation and how he comes up with a solution to battle it, only to find himself in an even bigger mess due to their innocence and naivety.","genre_ids":[35,18],"popularity":0.1231,"vote_count":8,"poster_path":"/gEqSOypPdbcpNkY3S7I17XKGWCc.jpg","release_date":"2013-03-08","vote_average":7.2,"backdrop_path":"/zGnt4Xzubekrpd4rZ8NVMhjWCQ9.jpg","original_title":"Saare Jahaan Se Mehnga","original_language":"hi"},{"id":649,"adult":false,"title":"Belle de Jour","video":false,"overview":"Beautiful young housewife Séverine Serizy cannot reconcile her masochistic fantasies with her everyday life alongside dutiful husband Pierre. When her lovestruck friend Henri mentions a secretive high-class brothel run by Madame Anais, Séverine begins to work there during the day under the name Belle de Jour. But when one of her clients grows possessive, she must try to go back to her normal life.","genre_ids":[18,10749],"popularity":2.1796,"vote_count":998,"poster_path":"/iUAFECovwPA0cVV9bo4uNGLJSGL.jpg","release_date":"1967-05-24","vote_average":7.308,"backdrop_path":"/9fJPLvrUV32MzpfDwXk7cOnj8hM.jpg","original_title":"Belle de jour","original_language":"fr"},{"id":666,"adult":false,"title":"Central Station","video":false,"overview":"An emotional journey of a former school teacher, who writes letters for illiterate people, and a young boy, whose mother has just died, as they search for the father he never knew.","genre_ids":[18],"popularity":1.3443,"vote_count":1022,"poster_path":"/zJvp7XjQ2LhPbDVYhFXyucs40vR.jpg","release_date":"1998-04-03","vote_average":8.135,"backdrop_path":"/lrLIy9OFRQg4VkhrCyolfNXJEUH.jpg","original_title":"Central do Brasil","original_language":"pt"},{"id":713,"adult":false,"title":"The Piano","video":false,"overview":"When an arranged marriage brings Ada and her spirited daughter to the wilderness of nineteenth-century New Zealand, she finds herself locked in a battle of wills with both her controlling husband and a rugged frontiersman to whom she develops a forbidden attraction.","genre_ids":[18,10749],"popularity":7.0613,"vote_count":1617,"poster_path":"/dUxjG6baSzGIgP7R8BQI5rpMuET.jpg","release_date":"1993-05-18","vote_average":7.377,"backdrop_path":"/bo96LKNbkNHqWZBYBllrnjbmRBY.jpg","original_title":"The Piano","original_language":"en"},{"id":746,"adult":false,"title":"The Last Emperor","video":false,"overview":"A dramatic history of Pu Yi, the last of the Emperors of China, from his lofty birth and brief reign in the Forbidden City, the object of worship by half a billion people; through his abdication, his decline and dissolute lifestyle; his exploitation by the invading Japanese, and finally to his obscure existence as just another peasant worker in the People's Republic.","genre_ids":[18,36],"popularity":4.9386,"vote_count":1868,"poster_path":"/7TILJhdeJAaEyDiwvJZMo9SQBoe.jpg","release_date":"1987-10-04","vote_average":7.582,"backdrop_path":"/k29qVmwWwR0i5A1UMIws1Vmv6hV.jpg","original_title":"The Last Emperor","original_language":"en"},{"id":421614,"adult":false,"title":"Backwards: The Riddle of Dyslexia","video":false,"overview":"13-year-old Brian has problems reading, which his teachers attribute to laziness. It is later discovered that he has Dyslexia.","genre_ids":[18,10770],"popularity":0.4502,"vote_count":1,"poster_path":"/cpXVTnG37lWmF6L1Snlm73hbaoT.jpg","release_date":"1984-03-07","vote_average":8,"backdrop_path":"/z3n7YLp4H0GxLkWhVICWE6qrRIe.jpg","original_title":"Backwards: The Riddle of Dyslexia","original_language":"en"},{"id":1965,"adult":false,"title":"A Perfect Murder","video":false,"overview":"Millionaire industrialist Steven Taylor is a man who has everything but what he craves most: the love and fidelity of his wife. A hugely successful player in the New York financial world, he considers her to be his most treasured acquisition. But she needs more than simply the role of dazzling accessory.","genre_ids":[80,53,18],"popularity":2.5596,"vote_count":1515,"poster_path":"/wC0ax12N9GQ8vMXPEs4nES5AAiB.jpg","release_date":"1998-06-05","vote_average":6.546,"backdrop_path":"/dNW7ftcqEAvKmDkuRPaLC4gnhwJ.jpg","original_title":"A Perfect Murder","original_language":"en"},{"id":1986,"adult":false,"title":"Live and Become","video":false,"overview":"In 1980, the black Falashas in Ethiopia are recognised as genuine Jews and are secretly carried to Israel. The day before the transport the son of a Jewish mother dies. In his place and with his name (Schlomo) she takes a Christian 9-year-old boy.","genre_ids":[18],"popularity":0.4035,"vote_count":193,"poster_path":"/kc1GnNnFH99VWoSCQwPQ9ZslU4t.jpg","release_date":"2005-03-30","vote_average":7.409,"backdrop_path":"/12YKdvErSqcMp33ZeNe7MjSW06A.jpg","original_title":"Va, vis et deviens","original_language":"fr"},{"id":1987,"adult":false,"title":"Benny's Video","video":false,"overview":"A 14-year-old video enthusiast obsessed with violent films decides to make one of his own and show it to his parents, with tragic results.","genre_ids":[80,18],"popularity":0.5191,"vote_count":384,"poster_path":"/gCjViGVeChg4TAJqPEbeVHrTpGB.jpg","release_date":"1992-11-06","vote_average":6.906,"backdrop_path":"/uH7zKI0YsvZhEju7f9NpVNhtjHw.jpg","original_title":"Benny's Video","original_language":"de"},{"id":1993,"adult":false,"title":"Golden Door","video":false,"overview":"The story is set at the beginning of the 20th century in Sicily. Salvatore, a very poor farmer, and a widower, decides to emigrate to the US with all his family, including his old mother. Before they embark, they meet Lucy. She is supposed to be a British lady and wants to come back to the States. Lucy, or Luce as Salvatore calls her, for unknown reasons wants to marry someone before to arrive to Ellis Island in New York. Salvatore accepts the proposal. Once they arrive in Ellis Island they spend the quarantine period trying to pass the examinations to be admitted to the States. Tests are not so simple for poor farmers coming from Sicily. Their destiny is in the hands of the custom officers.","genre_ids":[36,18,10749],"popularity":3.3329,"vote_count":143,"poster_path":"/gjSK4pyVDt8Pwt9KpB8OtC246DC.jpg","release_date":"2006-09-22","vote_average":6.5,"backdrop_path":"/rXjSUFn6muQvKq78IQpiKFew2t9.jpg","original_title":"Nuovomondo","original_language":"it"},{"id":2001,"adult":false,"title":"We Own the Night","video":false,"overview":"A New York nightclub manager tries to save his brother and father from Russian mafia hitmen.","genre_ids":[18,80,53],"popularity":2.6961,"vote_count":1468,"poster_path":"/fcb2c9BcRc21iiWih23FQfT39uB.jpg","release_date":"2007-10-12","vote_average":6.7,"backdrop_path":"/fJWeJL39Pddz30ULiQBn4WIv5hx.jpg","original_title":"We Own the Night","original_language":"en"},{"id":2007,"adult":false,"title":"Lorenzo's Oil","video":false,"overview":"Augusto and Michaela Odone are dealt a cruel blow by fate when their five-year-old son Lorenzo is diagnosed with a rare and incurable disease. But the Odones' persistence and faith leads to an unorthodox cure which saves their boy and re-writes medical history.","genre_ids":[18],"popularity":1.4133,"vote_count":555,"poster_path":"/suRf59zRu1h8Zq4Gxekn6UiLGaM.jpg","release_date":"1992-12-30","vote_average":7.1,"backdrop_path":"/gYapxyWZXFYcCHtf5dVB2Ub9RTy.jpg","original_title":"Lorenzo's Oil","original_language":"en"},{"id":2011,"adult":false,"title":"Persepolis","video":false,"overview":"In 1970s Iran, Marjane 'Marji' Satrapi watches events through her young eyes and her idealistic family of a long dream being fulfilled of the hated Shah's defeat in the Iranian Revolution of 1979. However as Marji grows up, she witnesses first hand how the new Iran, now ruled by Islamic fundamentalists, has become a repressive tyranny on its own.","genre_ids":[16,18],"popularity":1.6504,"vote_count":2098,"poster_path":"/aU8i2QAdTyRR1nYb36Gq51xXP8p.j