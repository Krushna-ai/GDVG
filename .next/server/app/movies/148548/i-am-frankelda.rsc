":"Trailer","official":false,"iso_639_1":"en","iso_3166_1":"US","published_at":"2025-09-26T01:00:01.000Z"},{"id":"685f5396169b3434cd915582","key":"SgQunhb-MAg","name":"Teaser de Soy Frankelda","site":"YouTube","size":1080,"type":"Teaser","official":false,"iso_639_1":"en","iso_3166_1":"US","published_at":"2025-06-28T01:48:52.000Z"}],"watch_providers":{"results":{"MX":{"link":"https://www.themoviedb.org/movie/1119090-soy-frankelda/watch?locale=MX","flatrate":[{"logo_path":"/jbe4gVSfRlbPTdESXhEKpornsfu.jpg","provider_id":1899,"provider_name":"HBO Max","display_priority":5},{"logo_path":"/5AkEgpCNaBP3Fbwd2m1GdQIk0vv.jpg","provider_id":1825,"provider_name":"HBO Max Amazon Channel","display_priority":15}]}}},"wikidata_id":"Q123050446","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-25T23:37:44.95021+00:00","region":null,"main_poster":null,"images":{"logos":[{"width":963,"height":289,"file_path":"/eFenGhKFWic2PMQvpzvWd5nlt01.png","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":3.332,"vote_average":0}],"posters":[{"width":1434,"height":2048,"file_path":"/bp7TxHXrUlTfCIiA0z2pdkX9X56.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":2,"aspect_ratio":0.7,"vote_average":3.334},{"width":2000,"height":3000,"file_path":"/hDzllxB1TQ7uUxVvjnGHirJJovt.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":2,"aspect_ratio":0.667,"vote_average":3.334},{"width":2000,"height":2857,"file_path":"/6nK8CVTRf1XrZaB8qyTSDS9V7OD.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":0.7,"vote_average":3.334},{"width":1080,"height":1620,"file_path":"/rh3HNzV7o8ouH4NnCuL76OFPFBF.jpg","iso_639_1":"es","iso_3166_1":"MX","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":1434,"height":2048,"file_path":"/uaqDBPmUM2TOrf1RWThVh5MEOc6.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":3,"aspect_ratio":0.7,"vote_average":2.278},{"width":600,"height":900,"file_path":"/hifq4a3EjDOnm9hlHhpB9eaHcNP.jpg","iso_639_1":"es","iso_3166_1":"MX","vote_count":2,"aspect_ratio":0.667,"vote_average":1.75},{"width":1436,"height":2048,"file_path":"/2BmxkhtzrGAEEdIU7x24lnd7HI8.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":2,"aspect_ratio":0.701,"vote_average":1.75},{"width":811,"height":1216,"file_path":"/dDDGbn41VnmZW6ZYWfdBp9BHpxi.jpg","iso_639_1":"es","iso_3166_1":"MX","vote_count":1,"aspect_ratio":0.667,"vote_average":0.166},{"width":1094,"height":1641,"file_path":"/mgMkhwBXsc5GHBvhVsrdgsrZFiE.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1434,"height":2048,"file_path":"/mhL3szkL4ZMs80BKpiUEsd4zZhh.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":1436,"height":2048,"file_path":"/zhYD3JwHUgKurhAGivPoXAD5t7I.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.701,"vote_average":0},{"width":901,"height":1352,"file_path":"/iGaATyyHFjyOltTL8L45PERbikT.jpg","iso_639_1":"es","iso_3166_1":"MX","vote_count":0,"aspect_ratio":0.666,"vote_average":0},{"width":853,"height":1279,"file_path":"/tOGRa8A0rBzeCWZIHb19MKR2PZ9.jpg","iso_639_1":"es","iso_3166_1":"MX","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/pme7D46PxaOdNWika46q5VUS2CR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/pZr3484MENVj3m7toTUk7Cw4bnW.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/dx96FZ0PD1F9bAIx8dSGBY8vHUn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/gIuhNTnqgL78UEMOhw9Usb4nNio.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2347,"height":1320,"file_path":"/pqCc4MJ0oXHtzs1ilMU2xproudv.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/hSeZSli7UNpUjsPoXyuNCFyMXhO.jpg","iso_639_1":"es","iso_3166_1":"MX","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T03:48:19.953+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"I Am Frankelda","runtime":104,"tagline":"What you imagine has long been imagining you.","homepage":"https://www.frankeldasbookofspooks.com/i-am-frankelda","overview":"Frankelda, a frustrated young Mexican writer from the 19th Century, travels in the form of a ghost to a kingdom of her own invention inhabited by Spooks, which are all the monstrous characters she created in her horror tales. Her guide is Herneval, the Prince of Spooks, who takes her to help him save the balance between the Realm of Fiction and the Realm of Existence by using her talent as a writer."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":114,"tagline":"Lo que imaginas lleva tiempo imaginándote.","homepage":"","overview":"La joven escritora mexicana frustrada del siglo XIX, Frankela, viaja en forma de fantasma a un reino de su propia invención habitado por Espectros, unos monstruosos personajes que creó en sus relatos de terror."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Frankelda, una decidida escritora mexicana del siglo XIX, viaja a su subconsciente para enfrentarse a los monstruos sobre los que ha escrito. Guiada por un príncipe atormentado, deberá restablecer el equilibrio entre ficción y realidad antes de que sea demasiado tarde."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Frankelda, een gefrustreerde jonge Mexicaanse schrijfster uit de 19e eeuw, reist in de vorm van een geest naar een koninkrijk van haar eigen uitvinding dat wordt bewoond door spoken, allemaal monsterlijke personages die ze in haar horrorverhalen heeft gecreëerd. Haar gids is Herneval, de Prins der Spoken, die haar meeneemt om hem te helpen de balans tussen het Rijk van Fictie en het Rijk van het Bestaan te redden door haar talent als schrijver te gebruiken."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"怪誕鬼作家","runtime":0,"tagline":"","homepage":"","overview":"繼在爛番茄拿下100%好評的Cartoon Network電視動畫《Frankelda's Book of Spooks》，Ambriz兄弟終於帶來首部電影長片。19世紀一位不得志的恐怖小說家Frankelda，筆下的怪物突然活了過來！她必須進入自己的潛意識，與憂鬱王子聯手，在現實與虛構崩塌前重奪自己的聲音。電影融合哥德式恐怖、黑色幽默與華麗的歌舞場景，以極致瘋狂的視覺風格，開展一場關於創作、恐懼與自我的奇幻冒險。作為墨西哥首部定格動畫長片，本片不僅寫下影史，更接連獲安錫國際動畫影展等影展選映，技驚四座。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"프랑켈다","runtime":113,"tagline":"","homepage":"","overview":"어릴 적부터 어둡고 공포스러운 이야기만 써온 프란치스카 앞에 어느 날 헤르네발 왕자가 나타난다. 그의 설명에 따르면 두려움이라는 감정으로 유지되는 왕국이 존폐 위기에 처했다고 한다. 이어 호러 작가로서 프란치스카의 힘이 절실하다는 말과 함께 그를 무의식 세계로 초대한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"Ciò che immagini ti sta immaginando da molto tempo.","homepage":"","overview":"Frankelda, una giovane scrittrice messicana del XIX secolo tormentata e insoddisfatta, viaggia sotto forma di fantasma in un regno di sua invenzione abitato dagli Spettri, le mostruose creature nate dalle sue storie dell’orrore. La sua guida è Herneval, il Principe degli Spettri, che la conduce con sé per aiutarlo a salvare l’equilibrio tra il Regno della Finzione e quello dell’Esistenza, sfruttando il suo talento di scrittrice."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"Die junge Frankelda ist eine äußerst talentierte Schriftstellerin, deren düstere Werke im Mexiko des 19. Jahrhunderts jedoch nur wenig Beachtung finden. In ihrem Unterbewusstsein jedoch erwachen all ihre Kreationen zum Leben, und drängen schon bald aus ihren Träumen in die Realität. Diese unter dem Mentorat von Guillermo del Toro entstandene Stop-Motion-Meisterstück ist in jedem Einzelbild zum Bersten gefüllt mit Kreativität und Einfallsreichtum."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"}],"reviews_tmdb":[{"id":"6891676961a7ed9dbb2620c3","url":"https://www.themoviedb.org/review/6891676961a7ed9dbb2620c3","author":"Chris Sawin","content":"$11","created_at":"2025-08-05T02:07:37.011Z","updated_at":"2025-08-05T02:07:37.082Z","author_details":{"name":"Chris Sawin","rating":6,"username":"ChrisSawin","avatar_path":null}}],"recommendations":[{"id":1194963,"adult":false,"title":"Noise","video":false,"overview":"Ju-young is a young woman with a hearing impediment who decides to investigate her sister's inexplicable disappearance, last seen in her apartment. Feeling more and more cornered, Ju-young begins to hear strange sounds and sense an evil presence in the apartment.","genre_ids":[27,53],"media_type":"movie","popularity":7.0519,"vote_count":42,"poster_path":"/uU3NXe7QqjJNxVpYPdz8dscFWlj.jpg","release_date":"2025-06-25","vote_average":6.226,"backdrop_path":"/zeMMVjOFwXPfRIW6HzaEr0UQlRY.jpg","original_title":"노이즈","original_language":"ko"},{"id":666277,"adult":false,"title":"Past Lives","video":false,"overview":"After decades apart, childhood friends Nora and Hae Sung are reunited in New York for one fateful weekend as they confront notions of destiny, love, and the choices that make a life.","genre_ids":[18,10749],"media_type":"movie","popularity":6.6651,"vote_count":2206,"poster_path":"/k3waqVXSnvCZWfJYNtdamTgTtTA.jpg","release_date":"2023-06-02","vote_average":7.718,"backdrop_path":"/7HR38hMBl23lf38MAN63y4pKsHz.jpg","original_title":"Past Lives","original_language":"en"},{"id":1205656,"adult":false,"title":"Hallow Road","video":false,"overview":"Two parents enter a race against time when they receive a distressing late-night phone call from their daughter after she caused a tragic car accident.","genre_ids":[9648,53,27],"media_type":"movie","popularity":3.5683,"vote_count":156,"poster_path":"/dVsgV7ak6vR5xyXFggooJQinXBg.jpg","release_date":"2025-04-16","vote_average":6.298,"backdrop_path":"/yPU89i5KvCrfPkbgsUqYjRycPaY.jpg","original_title":"Hallow Road","original_language":"en"},{"id":36593,"adult":false,"title":"Naked Gun 33⅓: The Final Insult","video":false,"overview":"Frank Drebin is persuaded out of retirement to go undercover in a state prison. There he has to find out what top terrorist, Rocco, has planned for when he escapes. Adding to his problems, Frank's wife, Jane, is desperate for a baby.","genre_ids":[35,80],"media_type":"movie","popularity":5.0557,"vote_count":2440,"poster_path":"/p0AYsdgkudR9P5fNV5AjzbwQt8W.jpg","release_date":"1994-03-18","vote_average":6.497,"backdrop_path":"/crWTzII9OYzQmnrY3u9sTJ3L94D.jpg","original_title":"Naked Gun 33⅓: The Final Insult","original_language":"en"},{"id":1234821,"adult":false,"title":"Jurassic World Rebirth","video":false,"overview":"Five years after the events of Jurassic World Dominion, covert operations expert Zora Bennett is contracted to lead a skilled team on a top-secret mission to secure genetic material from the world's three most massive dinosaurs. When Zora's operation intersects with a civilian family whose boating expedition was capsized, they all find themselves stranded on an island where they come face-to-face with a sinister, shocking discovery that's been hidden from the world for decades.","genre_ids":[878,12,28],"media_type":"movie","popularity":35.5748,"vote_count":3023,"poster_path":"/1RICxzeoNCAO5NpcRMIgg1XT6fm.jpg","release_date":"2025-07-01","vote_average":6.306,"backdrop_path":"/zNriRTr0kWwyaXPzdg1EIxf0BWk.jpg","original_title":"Jurassic World Rebirth","original_language":"en"},{"id":1130022,"adult":false,"title":"Sovereign","video":false,"overview":"Struggling single father Jerry indoctrinates his son Joe into the sovereign citizen movement, teaching him that laws are mere illusions and freedom is something you take. But, as Jerry’s ideology consumes them, they are set on a collision course with a police chief who has spent his life upholding the rules that Jerry has spent his tearing down.","genre_ids":[80,18,53],"media_type":"movie","popularity":1.4923,"vote_count":100,"poster_path":"/cWXUMfnMj4ioReprwsDZgt8sghK.jpg","release_date":"2025-07-11","vote_average":6.815,"backdrop_path":"/ml9WFOTF3liDw3gfbCJ9c1c4DW9.jpg","original_title":"Sovereign","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":28.4976,"vote_count":26828,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.903,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":926606,"adult":false,"title":"The Home","video":false,"overview":"A troubled man starts working at a retirement home and realizes its residents and caretakers harbor sinister secrets. As he investigates the building and its forbidden fourth floor, he starts to uncover connections to his own past and upbringing as a foster child.","genre_ids":[9648,27,53],"media_type":"movie","popularity":3.5209,"vote_count":187,"poster_path":"/qyGY1k5GqAORsVhfZA3gFKirZWD.jpg","release_date":"2025-07-24","vote_average":6.727,"backdrop_path":"/Lu57GTE24Ja5O61jieY2aIBk8d.jpg","original_title":"The Home","original_language":"en"},{"id":979660,"adult":false,"title":"Freaky Tales","video":false,"overview":"In 1987 Oakland, a mysterious force guides The Town's underdogs in four interconnected tales: teen punks defend their turf against Nazi skinheads, a rap duo battles for hip-hop immortality, a weary henchman gets a shot at redemption, and an NBA All-Star settles the score.","genre_ids":[28,35,80],"media_type":"movie","popularity":2.8549,"vote_count":209,"poster_path":"/lo5mfglsGeMYmAkSRXs9DATNJxk.jpg","release_date":"2025-04-04","vote_average":6.303,"backdrop_path":"/elZZLzhDzjRIIkGcIK0FGmZSUaq.jpg","original_title":"Freaky Tales","original_language":"en"},{"id":1119878,"adult":false,"title":"Ice Road: Vengeance","video":false,"overview":"Big rig ice road driver Mike McCann travels to Nepal to scatter his late brother’s ashes on Mt. Everest. While on a packed tour bus traversing the deadly 12,000 ft. terrain of the infamous Road to the Sky, McCann and his mountain guide encounter a group of mercenaries and must fight to save themselves, the busload of innocent travelers, and the local villagers’ homeland.","genre_ids":[28,53,18],"media_type":"movie","popularity":12.1962,"vote_count":579,"poster_path":"/cQN9rZj06rXMVkk76UF1DfBAico.jpg","release_date":"2025-06-27","vote_average":6.257,"backdrop_path":"/2nwhxEyefcIFKwOrSigiamoIzu2.jpg","original_title":"Ice Road: Vengeance","original_language":"en"},{"id":1084199,"adult":false,"title":"Companion","video":false,"overview":"During a weekend getaway at a secluded lakeside estate, a group of friends finds themselves entangled in a web of secrets, deception, and advanced technology. As tensions rise and loyalties are tested, they uncover unsettling truths about themselves and the world around them.","genre_ids":[27,878,53],"media_type":"movie","popularity":14.4777,"vote_count":2099,"poster_path":"/oCoTgC3UyWGfyQ9thE10ulWR7bn.jpg","release_date":"2025-01-22","vote_average":7.012,"backdrop_path":"/qA6MHDGDY0LyutjLUgFJRbPXLpW.jpg","original_title":"Companion","original_language":"en"},{"id":1061474,"adult":false,"title":"Superman","video":false,"overview":"Superman, a journalist in Metropolis, embarks on a journey to reconcile his Kryptonian heritage with his human upbringing as Clark Kent.","genre_ids":[878,12,28],"media_type":"movie","popularity":28.4139,"vote_count":4376,"poster_path":"/ldyfo0BKmz5rWtJJKCvwaNS4cJT.jpg","release_date":"2025-07-09","vote_average":7.359,"backdrop_path":"/aJDLz1748CIMZkCkyISYe5Hl6I7.jpg","original_title":"Superman","original_language":"en"},{"id":1037052,"adult":false,"title":"Palazzina LAF","video":false,"overview":"Caterino is a worker at the Ilva factory in Taranto. When the company executives decide to use him as a spy to identify the workers they should get rid of, Caterino starts to track his colleagues, in search of reasons to report them. He then asks to be assigned himself to the Palazzino LAF where as punishment, some employees sit out their time with no job assignment. There he discovers that what looks like paradise is actually a strategy to psychologically break troublesome workers.","genre_ids":[18],"media_type":"movie","popularity":0.4298,"vote_count":170,"poster_path":"/Avkcz7wPGEadCInD5X7MyWGPy46.jpg","release_date":"2023-10-21","vote_average":6.888,"backdrop_path":"/45MOCK83I3EwY4nvI2msxG8BArn.jpg","original_title":"Palazzina LAF","original_language":"it"},{"id":1939,"adult":false,"title":"Laura","video":false,"overview":"A police detective falls in love with the woman whose murder he's investigating.","genre_ids":[18,9648],"media_type":"movie","popularity":1.7114,"vote_count":885,"poster_path":"/j0zEiFFrdbZnMXqD3piOtZBJeNB.jpg","release_date":"1944-10-11","vote_average":7.6,"backdrop_path":"/d5HjGve67GkNC9lWpzZVKSotLlT.jpg","original_title":"Laura","original_language":"en"},{"id":13510,"adult":false,"title":"Eden Lake","video":false,"overview":"When a young couple goes to a remote wooded lake for a romantic getaway, their quiet weekend is shattered by an aggressive group of local kids. Rowdiness quickly turns to rage as the teens terrorize the couple in unimaginable ways, and a weekend outing becomes a bloody battle for survival.","genre_ids":[27,53],"media_type":"movie","popularity":4.608,"vote_count":2024,"poster_path":"/tOg6ElTe1mJwaCFN0172U4oso22.jpg","release_date":"2008-09-12","vote_average":6.832,"backdrop_path":"/s9v1QZMVhwShQ7415jPhtfqzyjG.jpg","original_title":"Eden Lake","original_language":"en"},{"id":911430,"adult":false,"title":"F1","video":false,"overview":"Racing legend Sonny Hayes is coaxed out of retirement to lead a struggling Formula 1 team—and mentor a young hotshot driver—while chasing one more chance at glory.","genre_ids":[28,18],"media_type":"movie","popularity":33.1588,"vote_count":3413,"poster_path":"/vqBmyAj0Xm9LnS1xe1MSlMAJyHq.jpg","release_date":"2025-06-25","vote_average":7.8,"backdrop_path":"/1KFv63mmcBGVbFl3jxxozoSFlhA.jpg","original_title":"F1","original_language":"en"},{"id":262903,"adult":false,"title":"Main Tera Hero","video":false,"overview":"Seenu loves Sunaina but they're chased by a stalking cop, an infatuated beauty and her mafia don dad - can Seenu's heroics work?","genre_ids":[10749,35],"media_type":"movie","popularity":1.5111,"vote_count":192,"poster_path":"/bupZH3i1SAaLLC0OgYMSLDZN63Q.jpg","release_date":"2014-04-04","vote_average":5.667,"backdrop_path":"/wgYx4MwezeoAkRVAJsYdOMAMeWC.jpg","original_title":"मैं तेरा हीरो","original_language":"hi"},{"id":7294,"adult":false,"title":"The Man Without a Past","video":false,"overview":"Arriving in Helsinki, a nameless man is beaten within an inch of his life by thugs, miraculously recovering only to find that he has completely lost his memory. Back on the streets, he attempts to begin again from zero, befriending a moody dog and becoming besotted with a Salvation Army volunteer.","genre_ids":[35,18,10749],"media_type":"movie","popularity":2.5966,"vote_count":423,"poster_path":"/9tBepCujkyNg1qM52MsaJfDkIRw.jpg","release_date":"2002-03-01","vote_average":7.418,"backdrop_path":"/nvzRMLQSYB1XYooexBr8Nqp5vcU.jpg","original_title":"Mies vailla menneisyyttä","original_language":"fi"},{"id":744653,"adult":false,"title":"The Thursday Murder Club","video":false,"overview":"A group of senior sleuths passionate about solving cold cases get plunged into a real-life murder mystery in this comic crime caper.","genre_ids":[35,9648,80],"media_type":"movie","popularity":5.2085,"vote_count":908,"poster_path":"/jbnazCHr8S2l2glyvjPTpa4NbEw.jpg","release_date":"2025-08-22","vote_average":6.599,"backdrop_path":"/4KN06gns94rQFoYQWDGunK7Cob4.jpg","original_title":"The Thursday Murder Club","original_language":"en"},{"id":1241921,"adult":false,"title":"A Big Bold Beautiful Journey","video":false,"overview":"Sarah and David are single strangers who meet at a mutual friend’s wedding and soon, through a surprising twist of fate, find themselves on a funny, fantastical, sweeping adventure together where they get to re-live important moments from their respective pasts, illuminating how they got to where they are in the present... and possibly getting a chance to alter their futures.","genre_ids":[10749,14,18],"media_type":"movie","popularity":4.895,"vote_count":314,"poster_path":"/uMAkmQlKthQpTMiyPAKOYK3JnMs.jpg","release_date":"2025-09-17","vote_average":6.279,"backdrop_path":"/2ha0wAOqrUcLScStWQcgeOOXapQ.jpg","original_title":"A Big Bold Beautiful Journey","original_language":"en"}],"similar_content":[{"id":8067,"adult":false,"title":"A Life Less Ordinary","video":false,"overview":"A couple of angels, O'Reilly and Jackson, are sent to Earth to make sure that their next supervised love-connection succeeds. They follow Celine, a spoiled rich girl who has just accidentally shot a suitor and, due to a misunderstanding, is kidnapped by janitor Robert. Although Celine quickly frees herself, she stays with Robert for thrills. O'Reilly and Jackson pursue, hoping to unite the prospective lovers.","genre_ids":[14,35,10749],"popularity":1.015,"vote_count":483,"poster_path":"/tk7WNEwLZepFU2yPIIkRuQOO0Q9.jpg","release_date":"1997-10-24","vote_average":6.127,"backdrop_path":"/78fqm4OGHe4a1Sl1WhX12pV8Ocr.jpg","original_title":"A Life Less Ordinary","original_language":"en"},{"id":1066955,"adult":false,"title":"Mon Copain?","video":false,"overview":"","genre_ids":[16],"popularity":0.3577,"vote_count":0,"poster_path":"/9d7S24Y0lfRnfsIQsl51H3jtMQV.jpg","release_date":"2003-09-12","vote_average":0,"backdrop_path":"/ylAuhqIWSAyfy5pQ4QqabBUUuR.jpg","original_title":"Mon Copain?","original_language":"fr"},{"id":1066959,"adult":false,"title":"Le vœu","video":false,"overview":"","genre_ids":[16],"popularity":0.5108,"vote_count":0,"poster_path":"/pBdERquT1BXcn3sjsrt1cIudM7c.jpg","release_date":"2001-12-19","vote_average":0,"backdrop_path":"/g3Sist7MtSADFfX5OXm1p9LF7rQ.jpg","original_title":"Le vœu","original_language":"fr"},{"id":8077,"adult":false,"title":"Alien³","video":false,"overview":"After escaping with Newt and Hicks from the alien planet, Ripley crash lands on Fiorina 161, a prison planet and host to a correctional facility. Unfortunately, although Newt and Hicks do not survive the crash, a more unwelcome visitor does. The prison does not allow weapons of any kind, and with aid being a long time away, the prisoners must simply survive in any way they can.","genre_ids":[878,28,27],"popularity":7.6072,"vote_count":6237,"poster_path":"/xh5wI0UoW7DfS1IyLy3d2CgrCEP.jpg","release_date":"1992-05-22","vote_average":6.376,"backdrop_path":"/lU0zVj8KcQVkPczdGGraYGiRC72.jpg","original_title":"Alien³","original_language":"en"},{"id":8078,"adult":false,"title":"Alien Resurrection","video":false,"overview":"Two hundred years after Lt. Ripley died, a group of scientists clone her, hoping to breed the ultimate weapon. But the new Ripley is full of surprises … as are the new aliens. Ripley must team with a band of smugglers to keep the creatures from reaching Earth.","genre_ids":[878,27,28],"popularity":7.1534,"vote_count":5438,"poster_path":"/9aRDMlU5Zwpysilm0WCWzU2PCFv.jpg","release_date":"1997-11-12","vote_average":6.161,"backdrop_path":"/ikr0UILfvRerzMNoBTtJtyuWAEV.jpg","original_title":"Alien Resurrection","original_language":"en"},{"id":1067282,"adult":false,"title":"Demon Slayer: Kimetsu no Yaiba -To the Swordsmith Village-","video":true,"overview":"A recap of Kimetsu no Yaiba episodes 43–45, with new footage and special end credits. Together with his comrades, Zenitsu and Inosuke, along with one of the top-ranking members of the Demon Slayer Corps, Tengen Uzui, Tanjiro embarks on a mission within the Entertainment District, where they encounter the formidable, high-ranking demons, Daki and Gyutaro.","genre_ids":[16,28,14,53],"popularity":4.5706,"vote_count":393,"poster_path":"/hEhGrcST85vMd63PBDgPBqih2tR.jpg","release_date":"2023-02-03","vote_average":7.322,"backdrop_path":"/tcYO8ay3A0liCWxHu2creU3Q9IB.jpg","original_title":"「鬼滅の刃」上弦集結、そして刀鍛冶の里へ","original_language":"ja"},{"id":1067283,"adult":false,"title":"Still Meadows","video":false,"overview":"Washed-up horror novelist Owen Slater has hit rock bottom following his exploitation of a family's tragedy in one of his best-selling novels. But, when paranormal investigator Jack Grady recruits him for his subsequent investigation in the town of Still Meadows (the setting of Owen's book) Owen sees this as the perfect opportunity to redeem himself.","genre_ids":[27,53],"popularity":0.8624,"vote_count":0,"poster_path":"/4HbnJaIT5iQGydEni9wmnTE7v4p.jpg","release_date":"2012-05-05","vote_average":0,"backdrop_path":null,"original_title":"Still Meadows","original_language":"en"},{"id":8216,"adult":false,"title":"Meet the Feebles","video":false,"overview":"Heidi, star of the \"Meet The Feebles Variety Hour\" discovers her lover Bletch the Walrus is cheating on her. And with all the world waiting for the show, the assorted co-stars must contend with drug addiction, extortion, robbery, disease, drug dealing, and murder.","genre_ids":[35,10402,14],"popularity":1.2726,"vote_count":311,"poster_path":"/31DqGazwdE9N4Y9FHC6Q4NvstuW.jpg","release_date":"1989-08-12","vote_average":6.339,"backdrop_path":"/fji432Vjgj89p0ISOJONYyfNUmy.jpg","original_title":"Meet the Feebles","original_language":"en"},{"id":1459285,"adult":false,"title":"Life in the clouds","video":false,"overview":"\"Life in the clouds\" tells a part of the protagonist's life, Q, above the clouds with his pet. In an age of uncertainty and loneliness for Q, they suddenly meet Y, a foreigner of a similar race. Friendship and some feelings soon flourish.","genre_ids":[16,878,14],"popularity":0.2081,"vote_count":1,"poster_path":"/qnbNr9bLyHaiD5kW8MA7j1Fe5wR.jpg","release_date":"2025-04-04","vote_average":10,"backdrop_path":"/xmCFIZ2niMcQvfE0wv5GlhqQART.jpg","original_title":"Life in the clouds","original_language":"en"},{"id":8587,"adult":false,"title":"The Lion King","video":false,"overview":"Young lion prince Simba, eager to one day become king of the Pride Lands, grows up under the watchful eye of his father Mufasa; all the while his villainous uncle Scar conspires to take the throne for himself. Amid betrayal and tragedy, Simba must confront his past and find his rightful place in the Circle of Life.","genre_ids":[10751,16,18,12],"popularity":17.1511,"vote_count":19408,"poster_path":"/sKCr78MXSLixwmZ8DyJLrpMsd15.jpg","release_date":"1994-06-15","vote_average":8.252,"backdrop_path":"/6GF9uJs7AnbcJvyfoZyjZv063Oo.jpg","original_title":"The Lion King","original_language":"en"},{"id":1067413,"adult":false,"title":"Didi & Friends The Movie","video":false,"overview":"With his best friends by his wings, a chirpy chicken leaves home for an exciting adventure to help his village elders find some magical medicine.","genre_ids":[16,10402,12,35,10751,14],"popularity":0.1313,"vote_count":1,"poster_path":"/tRyjJkzL9TxUm1URolxlhcTmLhw.jpg","release_date":"2023-02-23","vote_average":7,"backdrop_path":"/dCNt0hHTMSqzkm7n0SReOyj60h6.jpg","original_title":"Didi & Friends The Movie","original_language":"ms"},{"id":277368,"adult":false,"title":"Nicholas on Holiday","video":false,"overview":"It's the end of the school year. The long-awaited moment of the holidays is arrive. The little Nicolas, her parents and Grandma take the road towards the sea, and settle in for some time at the Hotel Beau-Rivage.","genre_ids":[10751,35],"popularity":0.4467,"vote_count":472,"poster_path":"/woRTbC7qJdU8OhuOju0Fw2UiBZV.jpg","release_date":"2014-07-09","vote_average":5.4,"backdrop_path":"/2e703w8SGp65F9BVRlSK8w5kPeD.jpg","original_title":"Les Vacances du Petit Nicolas","original_language":"fr"},{"id":8355,"adult":false,"title":"Ice Age: Dawn of the Dinosaurs","video":false,"overview":"Times are changing for Manny the moody mammoth, Sid the motor mouthed sloth and Diego the crafty saber-toothed tiger. Life heats up for our heroes when they meet some new and none-too-friendly neighbors – the mighty dinosaurs.","genre_ids":[16,35,10751,12],"popularity":7.379,"vote_count":8749,"poster_path":"/cXOLaxcNjNAYmEx1trZxOTKhK3Q.jpg","release_date":"2009-06-26","vote_average":6.761,"backdrop_path":"/o0zPARvs47f0UhAJuUqdQsyQaji.jpg","original_title":"Ice Age: Dawn of the Dinosaurs","original_language":"en"},{"id":8446,"adult":false,"title":"Bugsy Malone","video":false,"overview":"New York, 1929, a war rages between two rival gangsters, Fat Sam and Dandy Dan. Dan is in possession of a new and deadly weapon, the dreaded \"splurge gun\". As the custard pies fly, Bugsy Malone, an all-round nice guy, falls for Blousey Brown, a singer at Fat Sam's speakeasy. His designs on her are disrupted by the seductive songstress Tallulah who wants Bugsy for herself.","genre_ids":[18,28,35,10402,10751],"popularity":0.8131,"vote_count":306,"poster_path":"/j9BPl3jkNCFgsYe5poKrirUqrf8.jpg","release_date":"1976-07-22","vote_average":6.578,"backdrop_path":"/vF6HsyBdaJAZIYNUVs2hyY5itBy.jpg","original_title":"Bugsy Malone","original_language":"en"},{"id":8839,"adult":false,"title":"Casper","video":false,"overview":"Casper is a kind young ghost who peacefully haunts a mansion in Maine. When specialist James Harvey arrives to communicate with Casper and his fellow spirits, he brings along his teenage daughter, Kat. Casper quickly falls in love with Kat, but their budding relationship is complicated not only by his transparent state, but also by his troublemaking apparition uncles and their mischievous antics.","genre_ids":[14,35,10751],"popularity":5.7829,"vote_count":4858,"poster_path":"/2ah8fNJFZVU3vcXhU5xfAYi2eym.jpg","release_date":"1995-05-26","vote_average":6.3,"backdrop_path":"/sQPckU0TfSeYIlUneHfIXwzQC2f.jpg","original_title":"Casper","original_language":"en"},{"id":8953,"adult":false,"title":"Steamboy","video":false,"overview":"In 1860s Britain, a boy inventor finds himself caught in the middle of a deadly conflict over a revolutionary advance in steam power.","genre_ids":[16,14,878],"popularity":2.0606,"vote_count":477,"poster_path":"/wszfXaMx74a91yRTBgO1fwSvMj3.jpg","release_date":"2004-07-17","vote_average":6.901,"backdrop_path":"/c31SAQjVMeVGv7mZsrw5BKGXj2P.jpg","original_title":"スチームボーイ","original_language":"ja"},{"id":8965,"adult":false,"title":"Atlantis: Milo's Return","video":false,"overview":"Milo and Kida reunite with their friends to investigate strange occurances around the world that seem to have links to the secrets of Atlantis.","genre_ids":[14,16,878,10751,28],"popularity":2.9405,"vote_count":3887,"poster_path":"/hyAbWGld5WLdrmUB9OHyewcJQGL.jpg","release_date":"2003-02-25","vote_average":6.3,"backdrop_path":"/GDTwA5FBvVUOjCGKoNDMflbs3Z.jpg","original_title":"Atlantis: Milo's Return","original_language":"en"},{"id":8856,"adult":false,"title":"The Karate Kid Part II","video":false,"overview":"Summoned by his dying father, Miyagi returns to his homeland of Okinawa, with Daniel, after a 40-year exile. There he must confront Yukie, the love of his youth, and Sato, his former best friend turned vengeful rival. Sato is bent on a fight to the death, even if it means the destruction of their village. Daniel finds his own love in Yukia's niece, Kumiko, and his own enemy in Sato's nephew, the vicious Chozen. Now, far away from the tournaments, cheering crowds and safety of home, Daniel will face his greatest challenge ever when the cost of honor is life itself.","genre_ids":[12,18,28,10749,10751],"popularity":3.5398,"vote_count":2416,"poster_path":"/k0OwgRR6PNu7h3SiqpCbRdZWNaG.jpg","release_date":"1986-06-18","vote_average":6.335,"backdrop_path":"/7rfcRXbFD0xr8NteNq1hwXUd4Af.jpg","original_title":"The Karate Kid Part II","original_language":"en"},{"id":277834,"adult":false,"title":"Moana","video":false,"overview":"In Ancient Polynesia, when a terrible curse incurred by Maui reaches an impetuous Chieftain's daughter's island, she answers the Ocean's call to seek out the demigod to set things right.","genre_ids":[12,35,10751,16],"popularity":3.3037,"vote_count":13554,"poster_path":"/9tzN8sPbyod2dsa0lwuvrwBDWra.jpg","release_date":"2016-10-13","vote_average":7.564,"backdrop_path":"/iYLKMV7PIBtFmtygRrhSiyzcVsF.jpg","original_title":"Moana","original_language":"en"},{"id":471265,"adult":false,"title":"Dastan","video":false,"overview":"Indira (Suraiya) is an orphan brought up the strict and uprighteous Rani (Veena). Indira grows up to be a beauty and is sought by three suitors Raj (Raj Kapoor), Kundan (Al Nasir), and Ramesh (Suresh). Rani does not like Indira to marry into her family as both Raj and Kundan are her brothers, and she wants Indira to marry Ramesh, and as such arranges a meeting with Ramesh's mom (Pratima Devi) and finalizes the marriage. Indira does not appreciate this and refuses to marry Ramesh. Raj speaks of his love with Rani, and Rani warns him that Indira is to marry Ramesh, but also has an on-going affair with his brother Kundan. Who does Indira really love? Will she ever marry her dream man?","genre_ids":[18,10751,10749],"popularity":0.2004,"vote_count":1,"poster_path":"/1