5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Windmill\",\"description\":\"In the last years of the Ottoman Empire, a poor little Anatolian town named Saripinar is hit by a minor earthquake which has neither destroyed nor left it with many casualties. However, a telegraph sent to the central government exaggerates the situation and mentions that the governor of the town has been severely wounded, making the event a nationwide matter.\",\"image\":\"https://image.tmdb.org/t/p/w500/4N3qikpEcTBLooR86hx6PAfMLmX.jpg\",\"datePublished\":\"1986-02-04\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"TR\",\"inLanguage\":\"tr\",\"genre\":[\"Comedy\",\"History\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.175,\"bestRating\":10,\"ratingCount\":20}}"}}],["$","$L10",null,{"initialDrama":{"id":"65adcf9e-6c6e-4230-b0f1-b418a0cd3da9","tmdb_id":232326,"imdb_id":"tt0263257","content_type":"movie","title":"The Windmill","original_title":"Değirmen","overview":"In the last years of the Ottoman Empire, a poor little Anatolian town named Saripinar is hit by a minor earthquake which has neither destroyed nor left it with many casualties. However, a telegraph sent to the central government exaggerates the situation and mentions that the governor of the town has been severely wounded, making the event a nationwide matter.","poster_path":"/4N3qikpEcTBLooR86hx6PAfMLmX.jpg","backdrop_path":"/gu4AFMhKYGAbgAT5m2pgLlHAe00.jpg","release_date":"1986-02-04","first_air_date":null,"status":"published","original_language":"tr","origin_country":["TR"],"genres":[{"id":35,"name":"Comedy"},{"id":36,"name":"History"},"comedy film"],"popularity":3.9172,"vote_average":7.175,"vote_count":20,"runtime":99,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-25T01:40:54.603812+00:00","updated_at":"2026-02-25T01:40:54.451+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":103123,"name":"Odak Film","logo_path":null,"origin_country":"TR"}],"production_countries":[{"name":"Turkey","iso_3166_1":"TR"}],"spoken_languages":[{"name":"Türkçe","iso_639_1":"tr","english_name":"Turkish"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[],"alternative_titles":[],"videos":[],"watch_providers":{"results":{}},"wikidata_id":"Q6059200","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-25T01:40:54.603812+00:00","region":null,"main_poster":null,"images":{"logos":[],"posters":[{"width":2000,"height":3000,"file_path":"/4N3qikpEcTBLooR86hx6PAfMLmX.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":2,"aspect_ratio":0.667,"vote_average":3.334},{"width":2000,"height":3000,"file_path":"/nP7LxJlEc4n9wyk4my0TstuquBM.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":2,"aspect_ratio":0.667,"vote_average":1.75},{"width":539,"height":809,"file_path":"/hVswnWtTg4IXMwXxCGZhIYlA4wM.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":3,"aspect_ratio":0.666,"vote_average":1.222},{"width":1984,"height":2806,"file_path":"/hgD8gQXrX93KYxDItkv27qjdtaH.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":1,"aspect_ratio":0.707,"vote_average":0.166}],"backdrops":[{"width":1366,"height":768,"file_path":"/gu4AFMhKYGAbgAT5m2pgLlHAe00.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.779,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/dWctPQ9RWlIrsGJcY9mN5endfg1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:02:28.189+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Windmill","runtime":99,"tagline":"","homepage":"","overview":"In the last years of the Ottoman Empire, a poor little Anatolian town named Saripinar is hit by a minor earthquake which has neither destroyed nor left it with many casualties. However, a telegraph sent to the central government exaggerates the situation and mentions that the governor of the town has been severely wounded, making the event a nationwide matter."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":98,"tagline":"","homepage":"","overview":"Birinci Dünya Savaşı’nın arifesinde Sarıpınar kasabasının başında Kaymakam Halil Hilmi Bey vardır. Halil Hilmi ne kasabasında yaşanan yoksulluğun ne de etrafını kuşatan dalkavukların farkındadır. Karaborsa ve rüşvetle geçinen kasaba eşrafı kaymakamı da yanlarına çekmek için bir konakta gece âlemi düzenlerler. Âlem sırasında kasabada nam salmış Naciye isimli hayat kadını oynarken konak sallanmaya başlar. Naciye’den ve içkiden etkilenen konuklar deprem olduğunu düşünüp kaçışırken birbirlerini yaralarlar. Ertesi sabah âleme katılan isimlerden bazıları deprem olduğunu İstanbul’a haber verirler. Ancak geceye katılanlar dışında kimse depremi duymamıştır. Kaymakam kasabayı gezince evlerin yıkılmış olduğunu görür. Ancak bu yıkımın sebebi deprem değildir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"}],"reviews_tmdb":[],"recommendations":[{"id":365620,"adult":false,"title":"Ferrari","video":false,"overview":"Set during the summer of 1957. Ex-racecar driver, Enzo Ferrari, is in crisis. Bankruptcy stalks the company he and his wife, Laura, built from nothing ten years earlier. Their tempestuous marriage struggles with the mourning for one son and the acknowledgement of another.","genre_ids":[36,18],"media_type":"movie","popularity":3.9602,"vote_count":1209,"poster_path":"/LyCOcGqOTyTmaXu2TK8LfGveIb.jpg","release_date":"2023-12-14","vote_average":6.373,"backdrop_path":"/Ac3rRrduoKoXwQ6ZDgWh8euKhN5.jpg","original_title":"Ferrari","original_language":"en"},{"id":11372,"adult":false,"title":"The Eagle Has Landed","video":false,"overview":"When the Nazi high command learns in late 1943 that Winston Churchill will be spending time at a country estate in Norfolk, it hatches an audacious scheme to kidnap the prime minister and spirit him to Germany for enforced negotiations with Hitler.","genre_ids":[12,18,28,53,10752],"media_type":"movie","popularity":2.3978,"vote_count":371,"poster_path":"/dxLuj7VIv0ZRdvaIB6eY5fApONF.jpg","release_date":"1976-12-24","vote_average":6.6,"backdrop_path":"/rJ9jwmYKf0SC5M6TISpvjeYJJtZ.jpg","original_title":"The Eagle Has Landed","original_language":"en"},{"id":43802,"adult":false,"title":"The Little Foxes","video":false,"overview":"In 1900, a clan attempts to strike a deal with a Chicago industrialist to get him to build cotton mills in their Deep South town.","genre_ids":[18,10749,36],"media_type":"movie","popularity":0.8098,"vote_count":187,"poster_path":"/eOU0IkN2dtfVfV4zFlzZBGrESXB.jpg","release_date":"1941-08-29","vote_average":7.537,"backdrop_path":"/zcGLxxXHUtjbkZLIrdQjXSLGQmx.jpg","original_title":"The Little Foxes","original_language":"en"},{"id":32143,"adult":false,"title":"Billy Two Hats","video":false,"overview":"After a bank robbery, runaway Scottish outlaw Arch Deans and his young half-breed Kiowa partner Billy Two Hats develop a father-son relationship, but Sheriff Henry Gifford is determined to capture or kill them.","genre_ids":[37],"media_type":"movie","popularity":0.461,"vote_count":42,"poster_path":"/nDgbZ1JYQxrqNmv3HNLULDBysKL.jpg","release_date":"1974-03-07","vote_average":5.6,"backdrop_path":"/plNeBZJYJPQPvwo5ne619JMPlPr.jpg","original_title":"Billy Two Hats","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":30.0131,"vote_count":26824,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.903,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":23.0611,"vote_count":11386,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":346698,"adult":false,"title":"Barbie","video":false,"overview":"Barbie and Ken are having the time of their lives in the colorful and seemingly perfect world of Barbie Land. However, when they get a chance to go to the real world, they soon discover the joys and perils of living among humans.","genre_ids":[35,12],"media_type":"movie","popularity":19.1444,"vote_count":10796,"poster_path":"/iuFNMS8U5cb6xfzi51Dbkovj7vM.jpg","release_date":"2023-07-19","vote_average":6.929,"backdrop_path":"/ctMserH8g2SeOAnCw5gFjdQF8mo.jpg","original_title":"Barbie","original_language":"en"},{"id":545611,"adult":false,"title":"Everything Everywhere All at Once","video":false,"overview":"An aging Chinese immigrant is swept up in an insane adventure, where she alone can save what's important to her by connecting with the lives she could have led in other universes.","genre_ids":[28,12,878],"media_type":"movie","popularity":11.7985,"vote_count":7694,"poster_path":"/u68AjlvlutfEIcpmbYpKcdi09ut.jpg","release_date":"2022-03-24","vote_average":7.721,"backdrop_path":"/ss0Os3uWJfQAENILHZUdX8Tt1OC.jpg","original_title":"Everything Everywhere All at Once","original_language":"en"},{"id":13510,"adult":false,"title":"Eden Lake","video":false,"overview":"When a young couple goes to a remote wooded lake for a romantic getaway, their quiet weekend is shattered by an aggressive group of local kids. Rowdiness quickly turns to rage as the teens terrorize the couple in unimaginable ways, and a weekend outing becomes a bloody battle for survival.","genre_ids":[27,53],"media_type":"movie","popularity":5.0582,"vote_count":2024,"poster_path":"/tOg6ElTe1mJwaCFN0172U4oso22.jpg","release_date":"2008-09-12","vote_average":6.832,"backdrop_path":"/s9v1QZMVhwShQ7415jPhtfqzyjG.jpg","original_title":"Eden Lake","original_language":"en"},{"id":693134,"adult":false,"title":"Dune: Part Two","video":false,"overview":"Follow the mythic journey of Paul Atreides as he unites with Chani and the Fremen while on a path of revenge against the conspirators who destroyed his family. Facing a choice between the love of his life and the fate of the known universe, Paul endeavors to prevent a terrible future only he can foresee.","genre_ids":[878,12],"media_type":"movie","popularity":24.0699,"vote_count":7549,"poster_path":"/1pdfLvkbY9ohJlCjQH2CZjjYVvJ.jpg","release_date":"2024-02-27","vote_average":8.13,"backdrop_path":"/ylkdrn23p3gQcHx7ukIfuy2CkTE.jpg","original_title":"Dune: Part Two","original_language":"en"},{"id":297222,"adult":false,"title":"PK","video":false,"overview":"A stranger in the city asks questions no one has asked before. Known only by his initials, the man's innocent questions and childlike curiosity take him on a journey of love, laughter and letting go.","genre_ids":[35,18,878],"media_type":"movie","popularity":7.0848,"vote_count":1122,"poster_path":"/z2x2Y4tncefsIU7h82gmUM5vnBJ.jpg","release_date":"2014-12-18","vote_average":7.698,"backdrop_path":"/gxfvtq5eYiClS2X7hxAAPBNrbWA.jpg","original_title":"पीके","original_language":"hi"},{"id":49046,"adult":false,"title":"All Quiet on the Western Front","video":false,"overview":"Paul Baumer and his friends Albert and Muller, egged on by romantic dreams of heroism, voluntarily enlist in the German army. Full of excitement and patriotic fervour, the boys enthusiastically march into a war they believe in. But once on the Western Front, they discover the soul-destroying horror of World War I.","genre_ids":[10752,36,18],"media_type":"movie","popularity":7.9517,"vote_count":4528,"poster_path":"/2IRjbi9cADuDMKmHdLK7LaqQDKA.jpg","release_date":"2022-10-07","vote_average":7.721,"backdrop_path":"/zbOlpFM306PHE7EP1OELCH5qSmS.jpg","original_title":"Im Westen nichts Neues","original_language":"de"},{"id":264660,"adult":false,"title":"Ex Machina","video":false,"overview":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl.","genre_ids":[18,878],"media_type":"movie","popularity":7.9469,"vote_count":14040,"poster_path":"/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg","release_date":"2015-01-21","vote_average":7.573,"backdrop_path":"/uqOuJ50EtTj7kkDIXP8LCg7G45D.jpg","original_title":"Ex Machina","original_language":"en"},{"id":61791,"adult":false,"title":"Rise of the Planet of the Apes","video":false,"overview":"A highly intelligent chimpanzee named Caesar has been living a peaceful suburban life ever since he was born. But when he gets taken to a cruel primate facility, Caesar decides to revolt against those who have harmed him.","genre_ids":[53,28,18,878],"media_type":"movie","popularity":6.6848,"vote_count":12558,"poster_path":"/oqA45qMyyo1TtrnVEBKxqmTPhbN.jpg","release_date":"2011-08-03","vote_average":7.339,"backdrop_path":"/6cCF0KMUO2QmrVsQFujkQduREXX.jpg","original_title":"Rise of the Planet of the Apes","original_language":"en"},{"id":508442,"adult":false,"title":"Soul","video":false,"overview":"Joe Gardner is a middle school teacher with a love for jazz music. After a successful audition at the Half Note Club, he suddenly gets into an accident that separates his soul from his body and is transported to the You Seminar, a center in which souls develop and gain passions before being transported to a newborn child. Joe must enlist help from the other souls-in-training, like 22, a soul who has spent eons in the You Seminar, in order to get back to Earth.","genre_ids":[16,10751,35,14,18,10402],"media_type":"movie","popularity":11.8533,"vote_count":11202,"poster_path":"/6jmppcaubzLF8wkXM36ganVISCo.jpg","release_date":"2020-12-25","vote_average":8.097,"backdrop_path":"/rQaHA74pevnGsxcKGaoZVGWe9TC.jpg","original_title":"Soul","original_language":"en"},{"id":150540,"adult":false,"title":"Inside Out","video":false,"overview":"When 11-year-old Riley moves to a new city, her Emotions team up to help her through the transition. Joy, Fear, Anger, Disgust and Sadness work together, but when Joy and Sadness get lost, they must journey through unfamiliar places to get back home.","genre_ids":[16,10751,12,18,35],"media_type":"movie","popularity":15.6425,"vote_count":23187,"poster_path":"/2H1TmgdfNtsKlU9jKdeNyYL5y8T.jpg","release_date":"2015-06-17","vote_average":7.909,"backdrop_path":"/jJKZaTBNenlFclQyjrnvzkRmvWE.jpg","original_title":"Inside Out","original_language":"en"},{"id":475557,"adult":false,"title":"Joker","video":false,"overview":"During the 1980s, a failed stand-up comedian is driven insane and turns to a life of crime and chaos in Gotham City while becoming an infamous psychopathic crime figure.","genre_ids":[80,53,18],"media_type":"movie","popularity":19.3785,"vote_count":27337,"poster_path":"/udDclJoHjfjb8Ekgsd4FDteOkCU.jpg","release_date":"2019-10-01","vote_average":8.128,"backdrop_path":"/hO7KbdvGOtDdeg0W4Y5nKEHeDDh.jpg","original_title":"Joker","original_language":"en"},{"id":578,"adult":false,"title":"Jaws","video":false,"overview":"When the seaside community of Amity finds itself under attack by a dangerous great white shark, the town's chief of police, a young marine biologist, and a grizzled shark hunter embark on a desperate quest to kill the beast before it strikes again.","genre_ids":[27,53,12],"media_type":"movie","popularity":12.522,"vote_count":11325,"poster_path":"/tjbLSFwi0I3phZwh8zoHWNfbsEp.jpg","release_date":"1975-06-20","vote_average":7.679,"backdrop_path":"/i1yf91svRHX45l9BXL8rVFzLoPH.jpg","original_title":"Jaws","original_language":"en"},{"id":2108,"adult":false,"title":"The Breakfast Club","video":false,"overview":"Five high school students from different walks of life endure a Saturday detention under a power-hungry principal. The disparate group includes rebel John, princess Claire, outcast Allison, brainy Brian and Andrew, the jock. Each has a chance to tell his or her story, making the others see them a little differently -- and when the day ends, they question whether school will ever be the same.","genre_ids":[35,18],"media_type":"movie","popularity":5.8345,"vote_count":8414,"poster_path":"/gp4zlj7wgbiofLMNsTPndMuO3PN.jpg","release_date":"1985-02-15","vote_average":7.725,"backdrop_path":"/kjVgUMsG0PKBXzlP8HGNQpWDxAX.jpg","original_title":"The Breakfast Club","original_language":"en"},{"id":361743,"adult":false,"title":"Top Gun: Maverick","video":false,"overview":"After more than thirty years of service as one of the Navy’s top aviators, and dodging the advancement in rank that would ground him, Pete “Maverick” Mitchell finds himself training a detachment of TOP GUN graduates for a specialized mission the likes of which no living pilot has ever seen.","genre_ids":[28,18],"media_type":"movie","popularity":20.7841,"vote_count":10612,"poster_path":"/62HCnUTziyWcpDaBO2i1DX17ljH.jpg","release_date":"2022-05-21","vote_average":8.156,"backdrop_path":"/AaV1YIdWKnjAIAOe8UUKBFm327v.jpg","original_title":"Top Gun: Maverick","original_language":"en"}],"similar_content":[],"ext