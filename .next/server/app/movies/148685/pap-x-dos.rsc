5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Papá x dos\",\"description\":\"Santiago decides to start a family with his girlfriend Ana, even though she is pregnant with her ex, Pancho's. However, the real challenge will come when Pancho unexpectedly returns from Miami to get involved in the pregnancy, unleashing a series of comical and chaotic situations in his home.\",\"image\":\"https://image.tmdb.org/t/p/w500/gclIrK0PYAVXhROFQuH6ju15k8h.jpg\",\"datePublished\":\"2025-09-18\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"AR\",\"inLanguage\":\"es\",\"genre\":[\"Family\",\"Comedy\",\"Romance\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.292,\"bestRating\":10,\"ratingCount\":12}}"}}],["$","$L10",null,{"initialDrama":{"id":"1fa1ca60-fa3f-4deb-9710-f89ea415eb99","tmdb_id":1366745,"imdb_id":"tt33728446","content_type":"movie","title":"Papá x dos","original_title":"Papá x dos","overview":"Santiago decides to start a family with his girlfriend Ana, even though she is pregnant with her ex, Pancho's. However, the real challenge will come when Pancho unexpectedly returns from Miami to get involved in the pregnancy, unleashing a series of comical and chaotic situations in his home.","poster_path":"/gclIrK0PYAVXhROFQuH6ju15k8h.jpg","backdrop_path":"/y6MgDckBAzPfvRDCR093UNaWItQ.jpg","release_date":"2025-09-18","first_air_date":null,"status":"published","original_language":"es","origin_country":["AR"],"genres":[{"id":10751,"name":"Family"},{"id":35,"name":"Comedy"},{"id":10749,"name":"Romance"},"comedy film"],"popularity":6.6865,"vote_average":4.292,"vote_count":12,"runtime":104,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-26T01:06:21.844883+00:00","updated_at":"2026-02-26T01:06:21.516+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":109712,"name":"FAM Contenidos","lo