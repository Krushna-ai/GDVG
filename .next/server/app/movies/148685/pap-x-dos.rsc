erage":3.334},{"width":500,"height":750,"file_path":"/aJvszJS1nIcv2IWHEEkJsNl6VW3.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":2,"aspect_ratio":0.667,"vote_average":1.75},{"width":1000,"height":1500,"file_path":"/yd1FqtFNV7ubC1PvnwN6Qfl0hkB.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":2,"aspect_ratio":0.667,"vote_average":1.75},{"width":500,"height":750,"file_path":"/twItHmr3ETSan7RhNIc2YMzC4SC.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":2,"aspect_ratio":0.667,"vote_average":0.166}],"backdrops":[{"width":3840,"height":2160,"file_path":"/y6MgDckBAzPfvRDCR093UNaWItQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/aXbNOA8Wy9614W3rO8NZJfNWcGk.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/v0QXRj3UGU4bqhE0TEIjCkZhfbg.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:14:50.265+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Santiago decide formar una familia con su novia Ana, a pesar de que ella está embarazada de su ex, Pancho, sin embargo, el verdadero desafío llegará cuando Pancho regrese inesperadamente de Miami para involucrarse en el embarazo, desatando una serie de situaciones cómicas y caóticas en su hogar."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":104,"tagline":"","homepage":"","overview":"Santiago decides to start a family with his girlfriend Ana, even though she is pregnant with her ex, Pancho's. However, the real challenge will come when Pancho unexpectedly returns from Miami to get involved in the pregnancy, unleashing a series of comical and chaotic situations in his home."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Santiago sueña con formar una familia con Ana y todo parece ir en esa dirección cuando ella le anuncia que está embarazada. ¡El único problema es que también le cuenta que el papá, es su Ex!"},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"PAPAI X DOIS","runtime":0,"tagline":"","homepage":"","overview":"Santiago sonha em formar uma família com Ana , mas tudo muda quando ela revela que está grávida… do ex! Determinado a lutar por seu amor, ele enfrenta uma convivência inesperada: Pancho, o ex de Ana, se muda para a casa para acompanhar a gravidez. Entre rivalidade e situações divertidas, começa uma guerra para conquistar Ana, onde nem tudo vale."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"}],"reviews_tmdb":[],"recommendations":[{"id":16418,"adult":false,"title":"Barbie Presents: Thumbelina","video":false,"overview":"Meet a tiny girl named Thumbelina who lives in harmony with nature in the magical world of the Twillerbees that's hidden among the wildflowers. At the whim of a spoiled young girl named Makena, Thumbelina and her two friends have their patch of wildflowers uprooted and are transported to a lavish apartment in the city.","genre_ids":[16,10751],"media_type":"movie","popularity":1.5752,"vote_count":505,"poster_path":"/ytKd2jWnzWLCiccutqqMNzcP5RE.jpg","release_date":"2009-02-24","vote_average":6.6,"backdrop_path":"/y8w1IaNDP0jMcZ0AfSruXlEVllY.jpg","original_title":"Barbie Presents: Thumbelina","original_language":"en"},{"id":10162,"adult":false,"title":"Waking Ned","video":false,"overview":"When a lottery winner dies of shock, his fellow townsfolk attempt to claim the money.","genre_ids":[35],"media_type":"movie","popularity":2.0196,"vote_count":335,"poster_path":"/bsxiOOKC40HlhdIJYCUE2BkpJv0.jpg","release_date":"1998-11-20","vote_average":7.1,"backdrop_path":"/et3pBXfI1Q1fb7kLwZIoW7CYQgh.jpg","original_title":"Waking Ned","original_language":"en"},{"id":48035,"adult":false,"title":"Ordet","video":false,"overview":"The three sons of devout Danish farmer Morten have widely disparate religious beliefs. Youngest son Anders shares his father's religion, but eldest son Mikkel has lost his faith, while middle child Johannes has become delusional and proclaims that he is Jesus Christ himself. When Mikkel's wife, Inger goes into a difficult childbirth, everyone's beliefs are put to the test.","genre_ids":[18],"media_type":"movie","popularity":0.9919,"vote_count":402,"poster_path":"/q8DuzIhRsDGeCJaB9K80Fqtq6Y4.jpg","release_date":"1955-01-09","vote_average":7.943,"backdrop_path":"/62pTb3zkfE2860lIqQFlxQ5tUEL.jpg","original_title":"Ordet","original_language":"da"},{"id":15362,"adult":false,"title":"Mesrine: Public Enemy #1","video":false,"overview":"After nearly two decades of legendary criminal feats, making him France's most notorious criminal while simultaneously feeding his desire for media attention and public adoration, Mesrine becomes increasingly paranoid and isolated, leading to a dramatic confrontation with the law that ultimately seals his fate as the nation's most infamous public enemy.","genre_ids":[28,53,80,18],"media_type":"movie","popularity":0.6556,"vote_count":931,"poster_path":"/k9lhZ0PhY78nzwG034rNpsLXlpW.jpg","release_date":"2008-11-19","vote_average":7.271,"backdrop_path":"/czLjLCZTie8Oaf9Bz9ANhsD705i.jpg","original_title":"L'ennemi public n°1","original_language":"fr"},{"id":46629,"adult":false,"title":"On Board","video":false,"overview":"Sailors want to remain in their small world, which is warm and cozy and full of lies, but their routine life turns upside down when one of them gets mugged and badly beaten.","genre_ids":[18,80],"media_type":"movie","popularity":0.3921,"vote_count":98,"poster_path":"/vnQE1WvcP9CvQSbYAyXIQU9Sc1S.jpg","release_date":"1998-12-04","vote_average":7.351,"backdrop_path":"/jleMgDeeVaaC35ei7VUTEaF4OVu.jpg","original_title":"Gemide","original_language":"tr"},{"id":10651,"adult":false,"title":"The Dead Pool","video":false,"overview":"Dirty Harry Callahan returns for his final film adventure. Together with his partner Al Quan, he must investigate the systematic murder of actors and musicians. By the time Harry learns that the murders are a part of a sick game to predict the deaths of celebrities before they happen, it may be too late...","genre_ids":[28,80,53],"media_type":"movie","popularity":2.255,"vote_count":912,"poster_path":"/krxLLDnFuDtjagN7KrCjuH6QrcW.jpg","release_date":"1988-07-13","vote_average":6.258,"backdrop_path":"/m8SXRtfIOR4BZ6c3hSpL9wpBxyI.jpg","original_title":"The Dead Pool","original_language":"en"},{"id":53168,"adult":false,"title":"King of Comedy","video":false,"overview":"Wan Tin-Sau is an actor who cannot seem to catch a break, since his only professional jobs are limited to being a movie extra. As well as being an actor, he is also the head of his village's community center.","genre_ids":[35,18,10749],"media_type":"movie","popularity":1.8305,"vote_count":205,"poster_path":"/dmJWvKNgeCrIwJH6AapdSMiZHop.jpg","release_date":"1999-02-08","vote_average":7.4,"backdrop_path":"/fGzO3qGIaBlLlW53fsaRSUPEjw0.jpg","original_title":"喜劇之王","original_language":"cn"},{"id":3078,"adult":false,"title":"It Happened One Night","video":false,"overview":"A runaway heiress makes a deal with the rogue reporter trailing her but the mismatched pair end up stuck with each other when their bus leaves them behind.","genre_ids":[35,10749],"media_type":"movie","popularity":2.6621,"vote_count":1372,"poster_path":"/2PNUGWAflH6UUumas0POMmokHlc.jpg","release_date":"1934-02-22","vote_average":7.8,"backdrop_path":"/hmiC0MsI0PDd1TJXC62xyw0tX0s.jpg","original_title":"It Happened One Night","original_language":"en"},{"id":194834,"adult":false,"title":"Re-Generator","video":false,"overview":"A plane containing a highly classified government project crashes outside of a small town in the US. Realizing the level of danger, the government tries to secretly fix the problem. As tensions grow, the situation gets out of control, and civilians from the town find themselves facing their worst nightmare: a genetically enhanced killing machine that doesn't know how to stop.","genre_ids":[28,878],"media_type":"movie","popularity":0.1426,"vote_count":44,"poster_path":"/91DuiopktCSjCi4ozPePJWTaIL5.jpg","release_date":"2010-01-23","vote_average":6.216,"backdrop_path":"/wSLKn9Mml6W9h7pvCfxRjQdoAO9.jpg","original_title":"Re-Generator","original_language":"en"},{"id":82120,"adult":false,"title":"The Sprinkler Sprinkled","video":false,"overview":"A gardener is watering his flowers, when a mischievous boy sneaks up behind his back, and puts a foot on the water hose. The gardener is surprised and looks into the nozzle to find out why the water has stopped coming. The boy then lifts his foot from the hose, whereby the water squirts up in the gardener's face. The gardener chases the boy, grips his ear and slaps him in his buttocks. The boy then runs away and the gardener continues his watering. Three separate versions of this film exist, this is the original, filmed by Louis Lumière.","genre_ids":[35],"media_type":"movie","popularity":0.6439,"vote_count":272,"poster_path":"/rSZghvrFWTGqi4UecyG9jimzpEO.jpg","release_date":"1895-06-10","vote_average":6.8,"backdrop_path":"/A0hONP6cxTthAsw6IvPMX4Aowkr.jpg","original_title":"Arroseur et arrosé","original_language":"fr"},{"id":31534,"adult":false,"title":"The Chaos Class Failed the Class","video":false,"overview":"A young and beautiful female teacher starts working in an all boys high school.","genre_ids":[35],"media_type":"movie","popularity":0.5744,"vote_count":139,"poster_path":"/zMfsVXGxJy2xh0FwUWcZ1XXDZus.jpg","release_date":"1975-04-15","vote_average":7.773,"backdrop_path":"/9sVMciEvGTc6wOTD0hi5regoyxZ.jpg","original_title":"Hababam Sınıfı Sınıfta Kaldı","original_language":"tr"},{"id":1923,"adult":false,"title":"Twin Peaks: Fire Walk with Me","video":false,"overview":"In the questionable town of Deer Meadow, Washington, FBI Agent Desmond inexplicably disappears while hunting for the man who murdered a teen girl. The killer is never apprehended, and, after experiencing dark visions and supernatural encounters, Agent Dale Cooper chillingly predicts that the culprit will claim another life. Meanwhile, in the more cozy town of Twin Peaks, hedonistic beauty Laura Palmer hangs with lowlifes and seems destined for a grisly fate.","genre_ids":[18,9648,27],"media_type":"movie","popularity":6.3879,"vote_count":2204,"poster_path":"/mxsGXqetGnirf99qapYd5MMY1VL.jpg","release_date":"1992-06-03","vote_average":7.407,"backdrop_path":"/amGU1FpELmenVvNmPShW58Orepy.jpg","original_title":"Twin Peaks: Fire Walk with Me","original_language":"en"},{"id":41391,"adult":false,"title":"Day of Wrath","video":false,"overview":"In a Danish village in the early 1600s, a young woman named Anne, whose mother was thought to be a witch, develops sympathy toward an old woman, Marte, who is accused of witchcraft. The intervention of Anne's older but kindly husband, Pastor Absalon saved her mother -- but now, urged on by his overbearing mother, he refuses to help Marte. When Absalon's son returns home and is attracted to Anne, it's a matter of time before her family destiny catches up with her.","genre_ids":[18,36],"media_type":"movie","popularity":2.6484,"vote_count":247,"poster_path":"/jEOqbGLFo8fxHHgYoZVTMVYMoQG.jpg","release_date":"1943-11-13","vote_average":7.966,"backdrop_path":"/kKZ9kUZ1mMthbjgp1VS7x3fBeRl.jpg","original_title":"Vredens dag","original_language":"da"},{"id":8217,"adult":false,"title":"Alice","video":false,"overview":"Alice Tate, mother of two, with a marriage of 16 years, finds herself falling for a handsome sax player, Joe. Stricken with a backache, she consults herbalist Dr. Yang, who realizes that her problems are not related to her back, but in her mind and heart. Dr. Yang's magical herbs give Alice wondrous powers, taking her out of her well-established rut.","genre_ids":[14,18,10749,35],"media_type":"movie","popularity":1.7147,"vote_count":332,"poster_path":"/g6PGzYqXNofrrGKS7dixoc2P5M7.jpg","release_date":"1990-12-25","vote_average":6.357,"backdrop_path":"/ofIyN1TZJFvoCePNpbJebsg54D4.jpg","original_title":"Alice","original_language":"en"},{"id":68721,"adult":false,"title":"Iron Man 3","video":false,"overview":"When Tony Stark's world is torn apart by a formidable terrorist called the Mandarin, he starts an odyssey of rebuilding and retribution.","genre_ids":[28,12,878],"media_type":"movie","popularity":13.768,"vote_count":23168,"poster_path":"/qhPtAc1TKbMPqNvcdXSOn9Bn7hZ.jpg","release_date":"2013-04-18","vote_average":6.931,"backdrop_path":"/iVped1djsF0tvGkvnHbzsE3ZPTF.jpg","original_title":"Iron Man 3","original_language":"en"},{"id":11694,"adult":false,"title":"Cat Ballou","video":false,"overview":"A woman seeking revenge for her murdered father hires a famous gunman, but he's very different from what she expects.","genre_ids":[37,35],"media_type":"movie","popularity":2.0264,"vote_count":271,"poster_path":"/3WJmB1F5z4mLwt84i1FuIrSYEe.jpg","release_date":"1965-06-24","vote_average":6.402,"backdrop_path":"/vITHhBDV2t4QIT9UBcLl4zEa7Zy.jpg","original_title":"Cat Ballou","original_language":"en"},{"id":16642,"adult":false,"title":"Days of Heaven","video":false,"overview":"In 1916, a Chicago steel worker accidentally kills his supervisor and flees to the Texas panhandle with his girlfriend and little sister to work harvesting wheat in the fields of a stoic farmer.","genre_ids":[18,10749],"media_type":"movie","popularity":1.724,"vote_count":1127,"poster_path":"/rwxTYjOZmX2rGhz7avLe1qsjNqe.jpg","release_date":"1978-09-13","vote_average":7.48,"backdrop_path":"/5JrPWR6ve6gry6LG8SKr6tsQSBo.jpg","original_title":"Days of Heaven","original_language":"en"},{"id":1396,"adult":false,"title":"Mirror","video":false,"overview":"A dying man in his forties recalls his childhood, his mother, the war and personal moments that tell of and juxtapose pivotal moments in Soviet history with daily life.","genre_ids":[18,36],"media_type":"movie","popularity":1.8652,"vote_count":1064,"poster_path":"/AttDP5OEsMxtHPPN7Z92p2Ntnmd.jpg","release_date":"1975-03-07","vote_average":8,"backdrop_path":"/9UAcMhSCDJ2OCo5QdPpSERjhMA1.jpg","original_title":"Зеркало","original_language":"ru"},{"id":238,"adult":false,"title":"The Godfather","video":false,"overview":"Spanning the years 1945 to 1955, a chronicle of the fictional Italian-American Corleone crime family. When organized crime family patriarch, Vito Corleone barely survives an attempt on his life, his youngest son, Michael steps in to take care of the would-be killers, launching a campaign of bloody revenge.","genre_ids":[18,80],"media_type":"movie","popularity":36.9611,"vote_count":22509,"poster_path":"/3bhkrj58Vtu7enYsRolD1fZdja1.jpg","release_date":"1972-03-14","vote_average":8.687,"backdrop_path":"/tSPT36ZKlP2WVHJLM4cQPLSzv3b.jpg","original_title":"The Godfather","original_language":"en"},{"id":8052,"adult":false,"title":"Hard Eight","video":false,"overview":"A stranger mentors a young Reno gambler who weds a hooker and befriends a vulgar casino regular.","genre_ids":[18,80],"media_type":"movie","popularity":1.2533,"vote_count":939,"poster_path":"/1l5UaoP25Ak8PWCKIULQz70yF03.jpg","release_date":"1997-02-28","vote_average":6.846,"backdrop_path":"/4rt35cuyJ3CwpZgeIdXm5fmCinx.jpg","original_title":"Hard Eight","original_language":"en"}],"similar_content":[],"external_ids":{"imdb_id":"tt33728446","twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148685,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AR","release_dates":[{"note":"","type"