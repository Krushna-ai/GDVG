o_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/dPLgmvYXYMvVW1wWpZrJfayIcqq.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/kyMxufO1LPaNffXIy50ohpUhp1I.jpg","iso_639_1":"eu","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/f2t1LwpNxpehzsvgrmcRrl6R4id.jpg","iso_639_1":"gl","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/lgZxjTjtwfUdoeiVhEZOmyA8jCv.jpg","iso_639_1":"hi","iso_3166_1":"IN","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/fRooXEs8vDSN8gsiSV0Ozp70mfZ.jpg","iso_639_1":"ta","iso_3166_1":"IN","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/ok3Agy6RKKEGWZVyhbbVpHbZqk1.jpg","iso_639_1":"te","iso_3166_1":"IN","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/vPTNgY9YWZtMGHDGAtrv3WjqXzX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/qzo2OEM3ECLSvV6nruSWa2sDhlt.jpg","iso_639_1":"ka","iso_3166_1":"GE","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T06:19:49.081+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"La boda de Jenna y Lion propicia el tan deseado reencuentro entre Noah y Nick tiempo después de su ruptura. La incapacidad de Nick para perdonar a Noah se alza como una barrera insalvable. Él, heredero de las empresas de su abuelo y ella, empezando su vida laboral, se resisten a alimentar una llama que aún sigue viva. Pero una vez que sus caminos se han vuelto a cruzar, ¿será el amor más fuerte que el rencor? Secuela de \"Culpa tuya\"."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"È colpa nostra?","runtime":113,"tagline":"","homepage":"https://www.primevideo.com/detail/0PCRKKG8397FYGEC8X1RH994X0","overview":"Il matrimonio di Jenna e Lion costringe finalmente Noah e Nick a rivedersi dopo la rottura. L'incapacità di Nick di perdonare Noah diventa una barriera insormontabile. Lui, erede dell'azienda del nonno, e lei, all'inizio della sua vita professionale, cercano di non alimentare una fiamma ancora viva. Ma ora che le loro strade si incrociano di nuovo, l'amore sarà più forte del risentimento?"},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Our Fault","runtime":110,"tagline":"","homepage":"https://www.amazon.com/gp/video/detail/B0DZF95RTJ","overview":"Jenna and Lion's wedding brings about the long-awaited reunion between Noah and Nick after their breakup. Nick's inability to forgive Noah stands as an insurmountable barrier. He, heir to his grandfather's businesses, and she, starting her professional life, resist fueling a flame that's still alive. But now that their paths have crossed again, will love be stronger than resentment?"},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Nossa Culpa","runtime":115,"tagline":"Continuamos presos aos nossos nós ou enfrentamos a verdade?","homepage":"https://www.primevideo.com/detail/0PCRKKG8397FYGEC8X1RH994X0","overview":"O casamento de Jenna e Lion marca o tão esperado reencontro entre Noah e Nick após o término. A incapacidade de Nick de perdoar Noah é uma barreira intransponível. Ele, herdeiro dos negócios do avô, e ela, iniciando a vida profissional, evitam alimentar uma chama ainda acesa. Mas, agora que seus caminhos se cruzaram novamente, será o amor mais forte que o ressentimento?"},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"אשמתנו","runtime":0,"tagline":"","homepage":"https://www.primevideo.com/detail/0PCRKKG8397FYGEC8X1RH994X0","overview":"חתונתם של ג'נה וליאון מובילה לאיחוד המיוחל בין נואה לניק לראשונה מאז הפרידה שלהם. העובדה שניק לא מסוגל לסלוח לנואה ניצבת כמחסום בלתי עביר ביניהם. הוא יורש את עסקי סבו והיא בתחילת דרכה המקצועית. שניהם מנסים להתנגד לליבוי הלהבה שעדיין בוערת. אבל עכשיו, כשהדרכים שלהם שוב מצטלבות, האם האהבה תצליח לגבור על הטינה?"},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"คำขอโทษ 3","runtime":0,"tagline":"","homepage":"","overview":"งานแต่งงานของเจนน่าและไลอ้อนทำให้โนอาห์และนิคกลับมาพบกันอีกครั้งหลังจากเลิกรากันไปเนิ่นนาน การไม่ยอมให้อภัยของนิคกลายเป็นกำแพงที่ยากจะข้ามผ่าน เขาคือทายาทธุรกิจของคุณปู่ ส่วนเธอก็กำลังเริ่มต้นเส้นทางอาชีพของตัวเอง ทั้งคู่พยายามหักห้ามใจไม่ให้เปลวไฟของถ่านไฟเก่าที่ยังไม่มอดดับปะทุขึ้นอีกครั้ง แต่เมื่อเส้นทางชีวิตกลับมาบรรจบกันอีกครา ความรักจะเอาชนะความเคืองแค้นในใจได้หรือไม่"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"La relación entre Nick y Noah está pasando por su mejor momento. Se van a producir una serie de eventos para que ambos puedan comprender finalmente si de verdad están hechos el uno para el otro o, si de lo contrario, lo que más les conviene es seguir caminos separados."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"À contre-sens 3","runtime":0,"tagline":"","homepage":"","overview":"Le mariage de Jenna et Lion marque les retrouvailles entre Noah et Nick après leur rupture. L'incapacité de Nick à pardonner à Noah représente un obstacle difficile à surmonter. Lui, héritier des affaires de son grand-père, et elle, qui débute sa carrière, évitent de raviver la flamme entre eux. Mais, maintenant qu'ils se retrouvent, l'amour l'emportera-t-il sur le ressentiment ?"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"خطؤنا","runtime":112,"tagline":"","homepage":"https://www.primevideo.com/detail/Culpa-Nuestra/0PCRKKG8397FYGEC8X1RH994X0","overview":"يجمع زفاف \"جينا\" و\"ليون\" أخيراً بين \"نوا\" و\"نيك\" بعد فراق طويل. عدم قدرة \"نيك\" على مسامحة \"نوا\" يشكّل عائقاً لا يمكن تخطيه. هو وريث إمبراطورية جده التجارية وهي في بداية مسيرتها المهنية. كلاهما يحاول تجاهل الشرارة التي لا تزال مشتعلة. لكن بعدما تقاطعت دروبهما من جديد، هل سيكون الحب أقوى من الضغينة؟"},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Culpa nostra","runtime":0,"tagline":"","homepage":"","overview":"La boda de la Jenna i en Lion propicia l'esperat retrobament entre la Noah i en Nick després de la seva ruptura. La incapacitat d'en Nick de perdonar la Noah s'erigeix com una barrera infranquejable. Ell, hereu dels negocis del seu avi, i ella, als inicis de la seva carrera, es resisteixen a atiar una flama encara viva. Però ara que s'han retrobat, serà l'amor més fort que el ressentiment?"},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"我們的錯","runtime":0,"tagline":"","homepage":"","overview":"珍娜與萊恩的婚禮讓諾娃與尼克久別重逢。然而，尼克對她的傷痛仍難以釋懷，這道心牆成了他們最大的阻礙。如今他繼承了祖父的事業，而她才剛踏入職場。兩人都抗拒讓舊情復燃，但命運卻再次把他們推到同一條路上。愛情能否戰勝怨恨？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"خطؤنا","runtime":112,"tagline":"","homepage":"https://www.primevideo.com/detail/Culpa-Nuestra/0PCRKKG8397FYGEC8X1RH994X0","overview":"يجمع زفاف \"جينا\" و\"ليون\" أخيراً بين \"نوا\" و\"نيك\" بعد فراق طويل. عدم قدرة \"نيك\" على مسامحة \"نوا\" يشكّل عائقاً لا يمكن تخطيه. هو وريث إمبراطورية جده التجارية وهي في بداية مسيرتها المهنية. كلاهما يحاول تجاهل الشرارة التي لا تزال مشتعلة. لكن بعدما تقاطعت دروبهما من جديد، هل سيكون الحب أقوى من الضغينة؟"},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Jenna og Lions bryllup forårsager den længe ventede genforening mellem Noah og Nick. Nicks manglende evne til at tilgive Noah er en uoverkommelige barriere mellem dem. Han, arving til sin bedstefars firma, og hun, i begyndelse af sit arbejdsliv, modstår at genantænde den flamme, der stadig lever. Men nu krydses deres veje igen, så vil kærligheden være stærkere end bitterheden?"},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Naše vina","runtime":0,"tagline":"","homepage":"https://www.primevideo.com/detail/0PCRKKG8397FYGEC8X1RH994X0","overview":"Svatba Jenny a Liona přináší dlouho očekávané setkání Noah s Nickem, první od jejich rozchodu. Nick nedokáže Noah odpustit, což představuje nepřekonatelnou překážku. On je dědicem podniků svého dědečka, ona začíná svou profesní kariéru. Ti dva se brání rozdmýchat plamen, který mezi nimi stále hoří. Ale teď, když se jejich cesty znovu zkřížily, bude láska silnější než zášť?"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Culpa Nuestra - Unsere Schuld","runtime":113,"tagline":"","homepage":"https://www.amazon.de/dp/B0DZFXKN7D","overview":"Jennas und Lions Hochzeit bringt das langersehnte Wiedersehen von Noah und Nick mit sich. Doch Nicks Unvermögen, Noah zu verzeihen, bildet eine unüberwindbare Barriere. Er, der Erbe des großväterlichen Konzerns, und sie, gerade im Berufsleben angekommen, wollen das Feuer zwischen sich nicht anfachen. Doch jetzt, da ihre Wege sich wieder gekreuzt haben, wird die Liebe da stärker sein als der Groll?"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.primevideo.com/detail/0PCRKKG8397FYGEC8X1RH994X0","overview":"Ο γάμος της Τζένα και του Λίον φέρνει το πολυαναμενόμενο σμίξιμο της Νόα και του Νικ μετά τον χωρισμό τους. Η αδυναμία του Νικ να συγχωρήσει τη Νόα είναι ένα ανυπέρβλητο εμπόδιο. Εκείνος, κληρονόμος της επιχείρησης του παππού του κι εκείνη, που ξεκινά την επαγγελματική της ζωή, αντιστέκονται στο να τροφοδοτήσουν μια φλόγα που καίει ακόμη. Τώρα που ξανάσμιξαν, η αγάπη τους θα νικήσει την πικρία;"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Gure errua","runtime":0,"tagline":"","homepage":"https://www.primevideo.com/detail/0PCRKKG8397FYGEC8X1RH994X0","overview":"Jenna eta Lionen ezkontzan Noah eta Nick lehen aldiz elkartuko dira utzi zutenetik. Nicken ezintasuna Noah barkatzeko oztopo gaindiezina izango da. Nickek, bere aitonaren negozioa jarauntsi duenak, eta Noahk, bere bizitza profesionalari ekin dionak, bizirik jarraitzen duen sugarrari ihes egingo diote. Baina haien bideak berriro gurutzatu ostean, izango da maitasuna erresumina baino indartsuagoa?"},"name":"euskera","iso_639_1":"eu","iso_3166_1":"ES","english_name":"Basque"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.primevideo.com/detail/0PCRKKG8397FYGEC8X1RH994X0","overview":"Noah ja Nick kohtaavat ensimmäistä kertaa eronsa jälkeen Jennan ja Lionin häissä. Nickin kyvyttömyys antaa Noahille anteeksi on ylitsepääsemätön este. Hän on isänsä liiketoimien perijä, Noah aloittelee työuraansa. He yrittävät vältellä liekkiä, joka heidän välillään yhä leimuaa. Mutta nyt kun he taas kohtaavat, onko rakkaus väkevämpää kuin katkeruus?"},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"À contre-sens 3","runtime":0,"tagline":"","homepage":"https://www.primevideo.com/detail/0PCRKKG8397FYGEC8X1RH994X0","overview":"Le mariage de Jenna et Lion marque les retrouvailles de Noah et Nick. L'incapacité de Nick à pardonner Noah constitue un obstacle insurmontable. Héritier de la compagnie de son grand-père, Nick résiste à raviver la flamme qui brûle encore, tout comme Noah, qui commence sa vie professionnelle. Mais maintenant que leurs chemins se croisent à nouveau, l'amour sera-t-il plus fort que la rancœur?"},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Culpa nosa","runtime":0,"tagline":"","homepage":"https://www.primevideo.com/detail/0PCRKKG8397FYGEC8X1RH994X0","overview":"A voda de Jenna e Lion provoca o esperado reencontro de Noah e Nick trala súa ruptura. A incapacidade de Nick para perdoar a Noah é unha barreira infranqueable. El, herdeiro das empresas do seu avó, e ela, no inicio da súa vida profesional, resístense a alimentar unha chama que segue viva. Pero agora que os seus camiños se volveron cruzar, será o amor máis forte ca o rancor?"},"name":"Galego","iso_639_1":"gl","iso_3166_1":"ES","english_name":"Galician"},{"data":{"title":"आवर फ़ॉल्ट","runtime":0,"tagline":"","homepage":"https://www.primevideo.com/detail/0PCRKKG8397FYGEC8X1RH994X0","overview":"जेन्ना और लिओन की शादी, ब्रेकअप के बाद नोआह और निक के बीच लंबे समय से प्रतीक्षित पुनर्मिलन का कारण बनती है। निक की नोआह को माफ़ न कर पाने की असमर्थता बड़ी बाधा है। वह, जो अपने दादा के व्यवसाय का उत्तराधिकारी है, और वह, जो अपना पेशेवर जीवन शुरू कर रही है, उस आग को और भड़काने से बचते हैं जो अभी भी जल रही है। पर अब जब उनके रास्ते फिर से मिले हैं, तो क्या प्यार नाराज़गी से ज़्यादा मज़बूत होगा?"},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"A mi hibánk","runtime":0,"tagline":"","homepage":"https://www.primevideo.com/detail/0PCRKKG8397FYGEC8X1RH994X0","overview":"Jenna és Lion esküvőjén történik a rég várt találkozás Noah és Nick között a szakításuk után. De Nick képtelen megbocsátani Noah-nak, és ez leküzdhetetlen akadály számukra. Nick, aki nagyapja vállalkozásainak örököse, és Noah, aki most kezdi szakmai pályafutását, ellenállnak az újrakezdésnek. De vajon most, hogy útjaik megint keresztezik egymást, a szerelem erősebb lesz a neheztelésnél?"},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.primevideo.com/detail/0PCRKKG8397FYGEC8X1RH994X0","overview":"Pernikahan Jenna dan Lion mempertemukan kembali Noah dan Nick setelah mereka putus. Ketidakmampuan Nick memaafkan Noah menjadi penghalang yang tak bisa diatasi. Nick, pewaris bisnis kakeknya, dan Noah, yang baru memulai kehidupan profesionalnya, menolak api asmara yang belum padam. Namun, kini setelah mereka bertemu lagi, apakah cinta akan lebih kuat dari kebencian?"},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"Наша вина","runtime":0,"tagline":"","homepage":"","overview":"Спустя четыре года после расставания Ник и Ноа воссоединяются на свадьбе Лайона и Дженны, и возникает вопрос, сможет ли их любовь преодолеть злобу Ника."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"是我们的错","runtime":112,"tagline":"","homepage":"","overview":"尼克和诺亚的关系正处于最美好的时刻。然而，这对恋人似乎再也无法回到从前。一系列事件将接踵而至，让他们最终明白彼此是否真正适合对方。或者，相反地，他们会发现最好的选择是分道扬镳，即便要忘记如此深刻的爱或抹去烙印在心上的记忆是那么困难。爱并非总是足够，而原谅有时也不足以修复一切。他们能否放下过去，重新开始呢？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Nasza wina","runtime":0,"tagline":"","homepage":"","overview":"Na ślubie Jenny i Liona dochodzi do wyczekiwanego spotkania Noah i Nicka, pierwszego od ich zerwania. Nick wciąż nie potrafi wybaczyć Noah, co stanowi barierę nie do pokonania. On jest spadkobiercą firm dziadka, ona zaczyna karierę zawodową, a oboje opierają się rozpaleniu ognia, który wciąż płonie między nimi. Ale czy teraz, gdy ich drogi znów się spotkały, miłość okaże się silniejsza od urazy?"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"ჩვენი ბრალია","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"우리의 잘못","runtime":0,"tagline":"","homepage":"","overview":"헤어진 후 오랫동안 기다려온 노아와 닉은 예나와 라이온의 결혼식에서 재회한다. 노아를 용서하지 못하는 닉의 마음은 넘을 수 없는 장벽처럼 단단하다. 할아버지의 사업을 물려받은 닉과 사회생활을 시작한 노아는 아직 꺼지지 않은 불꽃에 다시 불붙는 것을 애써 피하려 한다. 하지만 두 사람의 길이 다시 만난 지금, 사랑이 원망보다 더 강해질 수 있을까?"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Bizim Hatamız","runtime":0,"tagline":"","homepage":"","overview":"Uzun zaman önce ayrılan Noah ile Nick, Jenna ile Lion'ın düğününde tekrar bir araya gelir. Nick'in Noah'yı affedememesini bir türlü aşamazlar. Büyükbabasının şirketlerinin vârisi olan Nick ve meslek hayatına yeni başlayan Noah, hâlâ sönmemiş bir ateşi harlamaktan imtina ederler. Yolları tekrar kesiştiğine göre, acaba aşk aradaki buzları eritebilecek midir?"},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Kesilapan Kita","runtime":0,"tagline":"","homepage":"","overview":"Perkahwinan Jenna dan Lion mempertemukan semula Noah dan Nick setelah berpisah. Namun, ketidakmampuan Nick memaafkan Noah jadi penghalang yang sukar ditembusi. Nick, pewaris perniagaan datuknya, dan Noah, yang baru memulakan kerjaya profesionalnya, cuba menahan diri daripada menghidupkan kembali api cinta menyala. Tapi setelah takdir menemukan mereka semula, adakah cinta lebih kuat daripada benci?"},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"私たちの過ち","runtime":0,"tagline":"","homepage":"","overview":"ジェナとライオンの結婚式で、ノアとニックは破局後久しぶりに再会。どうしてもノアを許せないニックの頑なさは大きな障壁となる。祖父の事業を継いだニックと社会人生活を始めたノアは、お互いへの気持ちを再燃させまいとするが、またしても交差する２人の道。愛は根深い怒りを乗り越えられるだろうか。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":113,"tagline":"\"Ik word helemaal gek bij jou, sproeten\"","homepage":"","overview":"Na hun relatiebreuk zien Noah en Nick elkaar eindelijk terug op de bruiloft van Jenna en Lion. Nick kan Noah maar niet vergeven. Het is hem, erfgenaam van het bedrijf van zijn grootvader, en haar, een groentje wat werk betreft, gelukt om de vonk tussen hen niet aan te wakkeren. Maar is hun liefde sterker dan hun wrok, nu ze elkaar weer zien?"},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"ಅವರ್ ಫಾಲ್ಟ್","runtime":0,"tagline":"","homepage":"","overview":"ನೋವಾ ಮತ್ತು ನಿಕ್ ಬೇರೆಯಾದ ನಂತರ ಈಗ ಜೆನ್ನ ಮತ್ತು ಲಯನ್‌ರ ವಿವಾಹದಲ್ಲಿ ಇವರ ಬಹುನಿರೀಕ್ಷಿತ ಪುನರ್ಮಿಲನವಾಗುವುದು. ನೋವಾಳನ್ನು ಕ್ಷಮಿಸಲಾಗದ ನಿಕ್‌ನ ಮನಸ್ಸು ಒಂದು ದುಸ್ತರ ತಡೆಗೋಡೆಯಾಗಿ ನಿಲ್ಲುವುದು. ತನ್ನ ಅಜ್ಜನ ವ್ಯವಹಾರಗಳಿಗೆ ಉತ್ತರಾಧಿಕಾರಿಯಾದ ಅವನು ಮತ್ತು ತನ್ನ ವೃತ್ತಿಪರ ಜೀವನವನ್ನು ಪ್ರಾರಂಭಿಸುತ್ತಿರುವ ಅವಳು, ಇಬ್ಬರೂ ಇನ್ನೂ ಜೀವಂತವಾಗಿರುವ ಕಿಡಿಯನ್ನು ಉತ್ತೇಜಿಸುವುದನ್ನು ವಿರೋಧಿಸುತ್ತಾರೆ. ಆದರೆ ಈಗ ಅವರ ಹಾದಿಗಳು ಮತ್ತೆ ಸೇರಿವೆ, ಪ್ರೀತಿ ಮನಸ್ತಾಪವನ್ನು ಮೀರುವುದೇ?"},"name":"?????","iso_639_1":"kn","iso_3166_1":"IN","english_name":"Kannada"},{"data":{"title":"是我们的错","runtime":0,"tagline":"","homepage":"","overview":"分手后的诺亚和尼克在珍娜和莱昂的婚礼上久别重逢。尼克始终无法原谅诺亚，这成了两人之间无法逾越的障碍。尼克继承了祖父的生意，诺亚则正在开始自己的职业生涯。他们苦苦压抑着，不让两人之间并未熄灭的爱火重燃。他们的人生道路却再一次相交。这一次，他们对彼此的爱是否能够战胜怨怼呢？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"ഔവർ ഫോൾട്ട്","runtime":0,"tagline":"","homepage":"","overview":"പിരിഞ്ഞതിനു ശേഷം നോഹയും നിക്കും വീണ്ടും ഒന്നിക്കാനുള്ള നീണ്ട കാത്തിരുപ്പിന് വിരാമമിടുകയാണ് ജെന്നയുടെയും ലയണിൻ്റെയും വിവാഹം. നോഹയ്ക്ക് മാപ്പുനൽകാൻ നിക്കിനാകാത്തത് വലിയൊരു തടസ്സമാണ്. തൻ്റെ മുത്തച്ഛൻ്റെ അനന്തരാവകാശിയായ അവനും പ്രൊഫഷണൽ ജീവിതം ആരംഭിക്കുന്ന അവളും, ഉള്ളിലിപ്പോഴും കെടാത്ത പ്രണയത്തിന് എണ്ണ പകരാതെ നോക്കുന്നു. അവരുടെ പാതകൾ വീണ്ടും സന്ധിക്കുമ്പോൾ പ്രണയം പിണക്കത്തെക്കാൾ ശക്തി പ്രാപിക്കുമോ?"},"name":"","iso_639_1":"ml","iso_3166_1":"IN","english_name":"Malayalam"},{"data":{"title":"Culpa Nossa","runtime":0,"tagline":"","homepage":"","overview":"O casamento de Jenna e Lion traz o tão esperado reencontro entre Noah e Nick após o seu término. A incapacidade de Nick de perdoar Noah é uma barreira intransponível. Ele, herdeiro dos negócios do avô, e ela, a começar a vida profissional, resistem a alimentar uma chama que ainda está viva. Mas, agora que os seus caminhos se cruzaram novamente, o amor será mais forte do que o ressentimento?"},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Păcatul nostru","runtime":0,"tagline":"","homepage":"","overview":"Noah și Nick se reîntâlnesc după mult timp de la despărțire la nunta lui Lion și a Jennei. Incapacitatea lui Nick de a o ierta pe Noah reprezintă o barieră insurmontabilă. El, moștenitor al afacerilor bunicului său, și ea, aflându-se la început de viață profesională, se opun să alimenteze o flacără încă vie. Va depăși dragostea lor resentimentele acum, că drumurile lor s-au intersectat din nou?"},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Jenna og Lions bryllup medfører den etterlengtede gjenforeningen mellom Nick og Noah etter bruddet deres. Det at Nick ikke kan tilgi Noah, står som en uoverkommelig barriere. Han, som er arving til bestefarens selskaper, og hun, som tar fatt på arbeidslivet, motstår å kaste bensin på et bål som fortsatt brenner. Men nå som veiene deres har krysset hverandre igjen, er kjærligheten større enn naget?"},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Jennas och Lions bröllop leder till den efterlängtade återföreningen mellan Noah och Nick efter deras uppbrott. Nicks oförmåga att förlåta Noah är ett hinder. Han, arvtagare till sin farfars företag, och hon, i början av sin karriär, försöker motstå att blåsa liv i en fortfarande brinnande låga. Men nu när deras vägar korsats igen, kommer kärleken att visa sig vara starkare än bitterheten?"},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"అవర్ ఫాల్ట్","runtime":0,"tagline":"","homepage":"","overview":"జెన్నా మరియు లియోన్‌ల పెళ్లి, ఎంతో కాలంగా ఎదురుచూస్తున్న విడిపోయిన నోవా, నిక్‌లను తిరిగి కలుపుతుంది. నోవాను క్షమించలేకపోవడం నిక్ అధిగమించలేని అడ్డంకిగా నిలుస్తుంది. అతను, తన తాత వ్యాపారాలకు వారసుడు, ఆమె, తన వృత్తి జీవితాన్ని ప్రారంభించి, ఇప్పటికీ సజీవంగా ఉన్న ప్రేమ బయటకి రాకుండా ప్రతిఘటిస్తుంది. కానీ ఇప్పుడు వారి మార్గాలు మళ్ళీ కలుసుకున్న తర్వాత, ప్రేమ పగ కంటే బలంగా ఉంటుందా?"},"name":"తెలుగు","iso_639_1":"te","iso_3166_1":"IN","english_name":"Telugu"},{"data":{"title":"அவர் ஃபால்ட்","runtime":0,"tagline":"","homepage":"","overview":"ஜென்னா, லயன் திருமண நிகழ்ச்சி, நீண்டகாலமாக எதிர்பார்க்கப்பட்ட நோவா, நிக் இடையே மறு இணைவை ஏற்படுத்துகிறது. நோவாவை மன்னிப்பதில் நிக்கின் இயலாமை, ஒரு கடக்க முடியாத தடையாக நிற்கிறது. தாத்தாவின் தொழில்களின் வாரிசான அவனும், தொழில் வாழ்க்கையைத் தொடங்கிய அவளும், இன்னும் தங்களுக்குள் எரியும் தீயை அடக்கி வைக்கின்றனர். ஆனால் அவர்கள் பாதை மீண்டும் சந்திக்கும்போது, காதல் மணக்கசப்பை விட வலிமையாகுமா?"},"name":"தமிழ்","iso_639_1":"ta","iso_3166_1":"IN","english_name":"Tamil"},{"data":{"title":"Наша провина","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Нашата вина","runtime":0,"tagline":"","homepage":"","overview":"Сватбата на Джена и Лайън става повод за дългоочакваната среща между Ноа и Ник след тяхната раздяла. Непрощаващото отношение на Ник към Ноа представлява непреодолима преграда. Той, наследник на семейния бизнес, и тя, която тепърва започва професионалния си път, се опитват да устоят на чувствата, които все още ги свързват. Но сега, след като отново са се срещнали, ще успее ли любовта да победи негодуванието?"},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Naša greška","runtime":0,"tagline":"","homepage":"","overview":"Veza Nicka i Noe dostiže vrhunac prije nego što se suoče s događajima koji testiraju da li im je suđeno da budu zajedno ili da se raziđu. Mogu li prevazići svoju prošlost uprkos snažnim osjećajima, ili ljubav i oprost nisu dovoljni?"},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Mūsų kaltė","runtime":0,"tagline":"","homepage":"","overview":"Santykiai tarp dviejų įsimylėjėlių išgyvena savo aukso amžių, tačiau netrukus viskas pasikeičia. Netikėti įvykiai ir išbandymai priverčia juos susimąstyti, ar jie tikrai skirti vienas kitam, ar vis dėlto geriau būtų eiti skirtingais keliais. Meilė ne visada pakankama, o atleidimas kartais negali ištaisyti praeities klaidų.  Ar jiems pavyks užmiršti skausmingus prisiminimus ir pradėti viską iš naujo? Ši istorija atskleidžia gilias emocijas, širdyje ištatuiruotus jausmus ir sudėtingus pasirinkimus, kurie kartais lemia visą gyvenimą."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Lỗi Của Chúng Ta","runtime":0,"tagline":"","homepage":"","overview":"Đám cưới của Jenna và Lion vô tình trở thành chất xúc tác cho cuộc hội ngộ định mệnh giữa Noah và Nick – hai người từng yêu nhau say đắm nhưng chia tay trong tổn thương. Nick, người thừa kế một đế chế kinh doanh lừng lẫy, vẫn chưa thể tha thứ cho quá khứ. Còn Noah, cô gái đang chập chững trên con đường sự nghiệp, cố gắng chôn giấu cảm xúc chưa từng nguôi. Khi ánh mắt họ chạm nhau lần nữa, quá khứ và hiện tại hòa vào nhau – liệu tình yêu có đủ sức xóa nhòa những vết thương cũ, hay hận thù sẽ lại chia cách họ một lần nữa?"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Najina krivda","runtime":0,"tagline":"","homepage":"","overview":"Poroka Jenne in Liona prinese dolgo pričakovano ponovno srečanje med Noah in Nickom po njunem razhodu. A Nickova nezmožnost, da bi Noahi odpustil, ostaja nepremostljiva ovira. On, dedič dedkovega poslovnega imperija, in ona, ki šele začenja svojo poklicno pot, se trudita zatreti iskrico, ki med njima še vedno tli. Toda zdaj, ko sta se njuni poti znova prekrižali, se poraja vprašanje - bo ljubezen močnejša od zamer?"},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"}],"reviews_tmdb":[],"recommendations":[{"id":608149,"adult":false,"title":"Flow","video":false,"overview":"A turbulent day in a life, painted by air.","genre_ids":[16],"media_type":"movie","popularity":0.4476,"vote_count":22,"poster_path":"/hw9D1abEQZSWWy3J9W6VsGzF5sw.jpg","release_date":"2019-12-05","vote_average":8.7,"backdrop_path":"/eMJbh6e2MiRmuV4RZgl3Lt7fwGH.jpg","original_title":"Flow","original_language":"xx"},{"id":957751,"adult":false,"title":"Flow","video":false,"overview":"Eight woman, one life. Short animation by Sumito Sakakibara. The 9th Japan Media Art Festival Animation Division Grand Prize Winner","genre_ids":[16],"media_type":"movie","popularity":0.1521,"vote_count":11,"poster_path":"/8fgSyUij9xz1cmse4GsSzixI9Rt.jpg","release_date":"2005-01-01","vote_average":9.7,"backdrop_path":null,"original_title":"Flow","original_language":"xx"},{"id":1280407,"adult":false,"title":"Flow","video":false,"overview":"","genre_ids":[18],"media_type":"movie","popularity":0.2449,"vote_count":30,"poster_path":"/iTBlHI0BkJ1u1ND3aLjYWaF7GYM.jpg","release_date":"2012-11-14","vote_average":9.3,"backdrop_path":"/g1wK1NW1lS2ZPSYbw4jtZtT8D91.jpg","original_title":"Flow","original_language":"en"},{"id":1165067,"adult":false,"title":"Cosmic Chaos","video":false,"overview":"Battles in virtual reality, survival in a post-apocalyptic wasteland, a Soviet spaceship giving a distress signal - Fantastic stories created with advanced special effects and passion.","genre_ids":[53,878],"media_type":"movie","popularity":1.2885,"vote_count":50,"poster_path":"/mClzWv7gBqgXfjZXp49Enyoex1v.jpg","release_date":"2023-08-03","vote_average":6,"backdrop_path":"/m2mzlsJjE3UAqeUB5fLUkpWg4Iq.jpg","original_title":"Cosmic Chaos","original_language":"en"},{"id":1313738,"adult":false,"title":"Old Man Junior","video":true,"overview":"Morbius Jr, now an OId Man, is nearing the end of life, when he finds the last hope for all Morbkind. However, as he fights to protect the future of Morbheads, he finds himself facing off against an unlikely of enemy... HIMSELF.","genre_ids":[],"media_type":"movie","popularity":0.185,"vote_count":63,"poster_path":"/hZKm5M7J1JUE2dpHeLgf736rzDT.jpg","release_date":"2024-07-06","vote_average":6.9,"backdrop_path":"/uL2J46FQMT895t4jMYJT1Pft7nj.jpg","original_title":"Old Man Junior","original_language":"en"},{"id":1083189,"adult":false,"title":"Man","video":false,"overview":"A worn-out, aging shearer who once rained king of the high country, gets on the gear to keep up his numbers. But when the drugs take over he must learn what it really means to be a man, before he loses so much more than his country pride -- MAN.","genre_ids":[18],"media_type":"movie","popularity":1.3822,"vote_count":17,"poster_path":null,"release_date":"2014-01-01","vote_average":6.8,"backdrop_path":null,"original_title":"Man","original_language":"en"},{"id":1085046,"adult":false,"title":"Shimmy: The First Monkey King","video":false,"overview":"Shimmy, a monkey newly discover superhero powers and learns how to control his extraordinary transformative abilities and prevent powerful demonic forces from sending the universe into chaos.","genre_ids":[16,12,28,35,14],"media_type":"movie","popularity":0.5366,"vote_count":40,"poster_path":"/bkaymv2mzOw8QdCZ9YllRYbXBb8.jpg","release_date":"2023-04-21","vote_average":5.9,"backdrop_path":"/tFLnWKhQEFcPidKOIm4STXAmk3g.jpg","original_title":"超级英雄美猴王：齐天儿","original_language":"zh"},{"id":1117006,"adult":false,"title":"Me contro Te: Il film - Vacanze in Transilvania","video":false,"overview":"","genre_ids":[10751,14],"media_type":"movie","popularity":0.4583,"vote_count":38,"poster_path":"/cFLK3rDmeoN9ovaqfkVTRlJS9Iw.jpg","release_date":"2023-10-19","vote_average":5.947,"backdrop_path":"/bwt6yG4gwjK3dgZZSCUWbYXQANs.jpg","original_title":"Me contro Te: Il film - Vacanze in Transilvania","original_language":"es"},{"id":420760,"adult":false,"title":"Ever After High: Dragon Games","video":false,"overview":"Dragons return to Ever After High, and so does the Evil Queen. When the most epic competition and evil scheme starts at Ever After High, Raven and Apple must let go of their story conflict and save their beloved school together.","genre_ids":[16,12,35,10751,14,10749],"media_type":"movie","popularity":0.4964,"vote_count":15,"poster_path":"/efi46Wk58PY9CldUphLgKZ8lXOp.jpg","release_date":"2016-01-29","vote_average":6.1,"backdrop_path":"/auFsEvA0zAQfjcRTyzD7jLTejxo.jpg","original_title":"Ever After High: Dragon Games","original_language":"en"},{"id":1333099,"adult":false,"title":"Dalia and the Red Book","video":false,"overview":"Dalia, the daughter of a famous writer who has recently died, inherits the legacy of finishing his book. To do this, Dalia will become part of the book and will come face to face with the characters who have taken the theme of the book in order to be the protagonists.","genre_ids":[12,18,14,16],"media_type":"movie","popularity":1.1145,"vote_count":30,"poster_path":"/brk5WOAEQWPcMLMsRrkPBtpVk3f.jpg","release_date":"2024-10-17","vote_average":7.3,"backdrop_path":"/585hAEHBMNqyCt3pswF5MjImBrR.jpg","original_title":"Dalia y el libro rojo","original_language":"es"},{"id":868848,"adult":false,"title":"13","video":false,"overview":"The film is a continuous time-lapse with multiple exposures of the sunset from the same angle and position on 16mm film. The shoot was done in a span of 5 years. The title 13 is because the time-lapse has a 13-second interval per frame.","genre_ids":[],"media_type":"movie","popularity":0.2157,"vote_count":2,"poster_path":null,"release_date":"2021-12-04","vote_average":10,"backdrop_path":null,"original_title":"13","original_language":"ja"},{"id":992190,"adult":false,"title":"Box","video":false,"overview":"A doomsday pepper is surprised to find a mysterious box appear in his living room with no trace as to how it could've gotten there.","genre_ids":[27],"media_type":"movie","popularity":0.0889,"vote_count":51,"poster_path":"/3VXkV5MYvhgqyyFgiKatSTgHxo0.jpg","release_date":"2022-06-23","vote_average":4.5,"backdrop_path":null,"original_title":"Box","original_language":"en"},{"id":757784,"adult":false,"title":"The great voyage of Captain Neptune","video":false,"overview":"Two madmen wish to avenge the historical Peruvian ship \"Monitor Huascar\" under the command of Capitain Grau: a hero, and a symbol of the 19th century war lost to Chile.","genre_ids":[18,35],"media_type":"movie","popularity":0.0865,"vote_count":2,"poster_path":"/a6d02VDym8nqRvWnjKyL0hD1Gp3.jpg","release_date":"1991-02-01","vote_average":6.5,"backdrop_path":null,"original_title":"El gran viaje del capitán Neptuno","original_language":"es"},{"id":689500,"adult":false,"title":"Six Hours: Surviving Typhoon Yolanda","video":false,"overview":"In the middle of a broadcast about Typhoon Yolanda's initial impact, reporter Jiggy Manicad was faced with the reality that he no longer had communication with his station. They were, for all intents and purposes, stranded in Tacloban. With little option, and his crew started the six hour walk to Alto, where the closest broadcast antenna was to be found. Letting the world know what was happening to was a priority, but they were driven by the need to let their families and friends know they were all still alive. Along the way, they encountered residents and victims of the massive typhoon, and with each step it became increasingly clear just how devastating this storm was. This was a storm that was going to change lives.","genre_ids":[99,18,36],"media_type":"movie","popularity":0.4105,"vote_count":1,"poster_path":"/eeSbsZDvYHugxL08YRrWNF1FpwV.jpg","release_date":"2014-12-23","vote_average":8.5,"backdrop_path":"/MmJlXi6qI0xQ1wGLwED2rB28qt.jpg","original_title":"Six Hours: Surviving Typhoon Yolanda","original_language":"en"},{"id":634333,"adult":false,"title":"F***/Off","video":false,"overview":"Two absolute strangers both desperately struggling to find themselves make a hilariously funny partnership for money. Their plan - a bank robbery! Meet Ah Lee, a well-educated middle-class professional who is deep in debt because of a so-called friend. Then there's PaPa, an inexperienced and very outdated crook who is heartbroken by the recent break-up with his girlfriend. When PaPa decides to teach Ah Lee the art of robbing a bank, the two men discover more than just a thing or two about themselves!","genre_ids":[35,18,80],"media_type":"movie","popularity":0.4741,"vote_count":2,"poster_path":"/tmfY7cSim67wzw52YWyPN9feaCd.jpg","release_date":"1998-02-28","vote_average":5.5,"backdrop_path":null,"original_title":"亞李．爸爸兩個大盜","original_language":"cn"},{"id":1209450,"adult":false,"title":"National Family","video":false,"overview":"Don Poli, the patriarch of a family embedded in politics, faces the change of party in his state - after a hundred years in power - losing all his privileges. Humiliated and angry, he threatens to disinherit his family and leave to rebuild his life. This forces his children (Kippy, Ramses and Belén) to take extreme measures to ensure their future, causing everything that could go wrong to turn out worse.","genre_ids":[35,28],"media_type":"movie","popularity":0.3595,"vote_count":90,"poster_path":"/oSAzrJ0AjFZLUCcHT8YAnuD7egp.jpg","release_date":"2023-12-28","vote_average":6.7,"backdrop_path":"/2qaFnZxMkj5nKz1MWinaVNfg7T7.jpg","original_title":"Familia Nacional","original_language":"es"},{"id":1020428,"adult":false,"title":"Inside Asda: Bigger, Better, Cheaper?","video":false,"overview":"The supermarket giant that rose high by taking prices low.","genre_ids":[99],"media_type":"movie","popularity":0.3581,"vote_count":128,"poster_path":"/k8B1JxJHyhLcKe5uGCKdE96DPps.jpg","release_date":"2020-01-06","vote_average":6.715,"backdrop_path":null,"original_title":"Inside Asda: Bigger, Better, Cheaper?","original_language":"en"},{"id":367413,"adult":false,"title":"Cipriana","video":false,"overview":"Traversing the tumultuous transitional period between childhood and the teenage years, Cipriana permeates a spirited combination of vulnerability, boldness and burgeoning sexual inquisitiveness.","genre_ids":[],"media_type":"movie","popularity":0.2051,"vote_count":5,"poster_path":"/tZh9xvLuUVzUFM69L8pSQrg5rGp.jpg","release_date":"2015-10-23","vote_average":3.4,"backdrop_path":"/dXGw9sIe0INvkaiCnMGBrsgwwto.jpg","original_title":"Cipriana","original_language":"es"},{"id":986206,"adult":false,"title":"Night Carnage","video":false,"overview":"A blogger who is also a werewolf meets a dashing playboy with a dark secret of his own. Starring Logan Andrews and Christian Howard.","genre_ids":[28,27,10749],"media_type":"movie","popularity":7.5075,"vote_count":63,"poster_path":"/w0wjPQKhlqisSbylf1sWZiNyc2h.jpg","release_date":"2025-07-29","vote_average":5.952,"backdrop_path":"/5xgxXZ9C8KZDg0xWbk6rX0XcO9T.jpg","original_title":"Night Carnage","original_language":"fr"}],"similar_content":[{"id":661539,"adult":false,"title":"A Complete Unknown","video":false,"overview":"New York, early 1960s. Against the backdrop of a vibrant music scene and tumultuous cultural upheaval, an enigmatic 19-year-old from Minnesota arrives in the West Village with his guitar and revolutionary talent, destined to change the course of American music.","genre_ids":[18,10402],"popularity":6.2729,"vote_count":1369,"poster_path":"/llWl3GtNoXosbvYboelmoT459NM.jpg","release_date":"2024-12-25","vote_average":7.081,"backdrop_path":"/kcCy5tKTe6WepVQ6SQaSewpmoCj.jpg","original_title":"A Complete Unknown","original_language":"en"},{"id":8417,"adult":false,"title":"Süss, the Jew","video":false,"overview":"Nazi historical drama about Duke Karl Alexander of Württemberg and his treasurer Süß Oppenheimer.","genre_ids":[18,36],"popularity":0.3031,"vote_count":45,"poster_path":"/3fN1p4OY7Mi0zXQqMJvCdhRwEYs.jpg","release_date":"1940-09-24","vote_average":4.3,"backdrop_path":"/4msV23h4lRFXQoOUUL8Oc0XTcxt.jpg","original_title":"Jud Süß","original_language":"de"},{"id":8434,"adult":false,"title":"Summer Things","video":false,"overview":"Two couple of friends, one very rich, the other almost homeless, decide to go on Holiday. Julie, a single mother, joins them too. Once at seaside, it starts a complicate love cross among them that will involve also a transsexual, a jealous brother, a Latin Lover and another nervous stressed couple. Not to mention about the daughter of one of them that is secretly in Chicago with one of her father's employees... At the end of the summer, all of them will join the same party...","genre_ids":[35,18,10749],"popularity":0.5262,"vote_count":102,"poster_path":"/laV4Xo5O1COZefAFPJLFZ28pkYS.jpg","release_date":"2002-03-04","vote_average":5.809,"backdrop_path":"/azkp4brPsmzJiyKw5ExkPDrVpWA.jpg","original_title":"Embrassez qui vous voudrez","original_language":"fr"},{"id":661436,"adult":false,"title":"An Accident","video":false,"overview":"In the 1980s, the building themes were transformed into bipolar moral dilemmas involving overly ambitious individuals who wanted to excel at any cost. The hero is the head of a demolition crew that demolishes large buildings, initially a sympathetic young man who, in the pursuit of career and accolades, begins to transgress the boundaries of what was then called socialist morality and legality. He gradually finds himself at odds with the principles of ordinary but honest people. The narrative's bland, proclamatory film is closely connected to its time of creation, and there are hardly any more timeless insights to be found.","genre_ids":[18],"popularity":0.2665,"vote_count":0,"poster_path":"/iFKRA8kCddfN0B23EXbSW3sOgI4.jpg","release_date":"1986-09-01","vote_average":0,"backdrop_path":null,"original_title":"Havárie","original_language":"cs"},{"id":8326,"adult":false,"title":"Holes","video":false,"overview":"After being wrongfully convicted for stealing a pair of shoes, Stanley Yelnats is sent away to Camp Green Lake, a boys detention facility where inmates are forced to dig holes all day in the hot desert sun as a form of character building. But Stanley and the other boys start to unravel a mystery, linked with the camps tough-as-nails warden —and possibly Stanley’s family itself.","genre_ids":[12,10751,18,35],"popularity":3.4761,"vote_count":1508,"poster_path":"/o2Dm2mcE1qW8vT0bpsJO5OMBbqa.jpg","release_date":"2003-04-18","vote_average":6.897,"backdrop_path":"/cVMK2k0Wbs8DV3IK5sS4ziVenrI.jpg","original_title":"Holes","original_language":"en"},{"id":8338,"adult":false,"title":"Blindness","video":false,"overview":"When a sudden plague of blindness devastates a city, a small group of the afflicted band together to triumphantly overcome the horrific conditions of their imposed quarantine.","genre_ids":[18,9648,878,53],"popularity":5.8895,"vote_count":1340,"poster_path":"/deBsx5IxyqCC217j3VY24TkkE0Z.jpg","release_date":"2008-05-14","vote_average":6.514,"backdrop_path":"/sN0czEtCT1jEFQVajWBsKwdFBKm.jpg","original_title":"Blindness","original_language":"en"},{"id":661475,"adult":false,"title":"Apinan vuosi","video":false,"overview":"A young student seeks direction in his life to counterbalance the studies through female adventures.","genre_ids":[18,35],"popularity":0.424,"vote_count":2,"poster_path":"/2OnmxCt66lXG1MuSky901gwGruq.jpg","release_date":"1983-11-11","vote_average":7,"backdrop_path":"/7XvomNV2M9UqZEa87IRk69F441R.jpg","original_title":"Apinan vuosi","original_language":"fi"},{"id":471103,"adult":false,"title":"The Fight for Rome II - The Betrayal","video":false,"overview":"The devious general Cethegus plays the Byzantine and Gothic forces against each other for his own gain.","genre_ids":[18,12,36],"popularity":0.2616,"vote_count":5,"poster_path":"/mSCCFODBAn6HE1fY3jbRegPJWZ0.jpg","release_date":"1969-02-21","vote_average":7,"backdrop_path":"/tM5nwmohCwKInwqbHyQ8WX9W75E.jpg","original_title":"Kampf um Rom II - Der Verrat","original_language":"de"},{"id":8619,"adult":false,"title":"Master and Commander: The Far Side of the World","video":false,"overview":"After an abrupt and violent encounter with a French warship inflicts severe damage upon his ship, a captain of the British Royal Navy begins a chase over two oceans to capture or destroy the enemy, though he must weigh his commitment to duty and ferocious pursuit of glory against the safety of his devoted crew, including the ship's thoughtful surgeon, his best friend.","genre_ids":[12,18,10752],"popularity":3.6584,"vote_count":3437,"poster_path":"/s1cVTQEZYn4nSjZLnFbzLP0j8y2.jpg","release_date":"2003-11-14","vote_average":7.181,"backdrop_path":"/zMHyNxNt4zhL939XX8QLBW3gWfu.jpg","original_title":"Master and Commander: The Far Side of the World","original_language":"en"},{"id":8649,"adult":false,"title":"Bringing Out the Dead","video":false,"overview":"Once called \"Father Frank\" for his efforts to rescue lives, Frank Pierce sees the ghosts of those he failed to save around every turn. He has tried everything he can to get fired, calling in sick, delaying taking calls where he might have to face one more victim he couldn't help, yet cannot quit the job on his own.","genre_ids":[18],"popularity":3.3849,"vote_count":1191,"poster_path":"/gE2Q8mL0m0EA6HakRyc92uzSPJn.jpg","release_date":"1999-10-22","vote_average":6.607,"backdrop_path":"/A1V1suhllQJ1CTrKpCulcM7mjyj.jpg","original_title":"Bringing Out the Dead","original_language":"en"},{"id":1460515,"adult":false,"title":"Out of Darkness","video":false,"overview":"How does a divorced, abused and suicidal woman become one of the most successful authors in history, redeeming marriages all over the globe? This incredible true and vulnerable story of God’s healing and redemption starts before Stormie Omartian’s successful book career. In 1970’s Hollywood, Stormie was a young and ambitious actress, navigating a path filled with career setbacks and a tumultuous marriage. Amidst her journey, she encountered Michael Omartian, a music producer who sparked her spiritual curiosity. As she grappled with accepting God’s unconditional love, Stormie was forced to confront her past traumas to break free from the darkness that consumed her.","genre_ids":[18],"popularity":0.1856,"vote_count":0,"poster_path":null,"release_date":"","vote_average":0,"backdrop_path":null,"original_title":"Out of Darkness","original_language":"en"},{"id":8680,"adult":false,"title":"The Shell Seekers","video":false,"overview":"Penelope Keeling, a sixty-four-year-old daughter of a famous artist, reflects on her life, and the fate and choices that defined it, when she arrives in the Mediterranean to stay with her headstrong daughter. Shifting through time, and falling into place like the pieces of a jigsaw, the truth of Penelope's rich, heartbreaking and surprising life unfolds.","genre_ids":[18,10749],"popularity":0.3819,"vote_count":7,"poster_path":"/y7oxk0TY47vpJ1v2kcnYak0GKkX.jpg","release_date":"2007-10-18","vote_average":6.9,"backdrop_path":"/3OqHYx2QlUQxbXx6TsCAenICQd7.jpg","original_title":"The Shell Seekers","original_language":"en"},{"id":471616,"adult":false,"title":"Indian Horse","video":false,"overview":"Follows the life of Native Canadian Saul Indian Horse as he survives residential school and life amongst the racism of the 1970s. A talented hockey player, Saul must find his own path as he battles stereotypes and alcoholism.","genre_ids":[18],"popularity":0.5887,"vote_count":76,"poster_path":"/6PRmK9svHolvZ2CLNoBkmViYlrB.jpg","release_date":"2018-04-13","vote_average":6.9,"backdrop_path":"/3An5TOYitpGnZWU3GhLGVKI4vcA.jpg","original_title":"Indian Horse","original_language":"en"},{"id":8856,"adult":false,"title":"The Karate Kid Part II","video":false,"overview":"Summoned by his dying father, Miyagi returns to his homeland of Okinawa, with Daniel, after a 40-year exile. There he must confront Yukie, the love of his youth, and Sato, his former best friend turned vengeful rival. Sato is bent on a fight to the death, even if it means the destruction of their village. Daniel finds his own love in Yukia's niece, Kumiko, and his own enemy in Sato's nephew, the vicious Chozen. Now, far away from the tournaments, cheering crowds and safety of home, Daniel will face his greatest challenge ever when the cost of honor is life itself.","genre_ids":[12,18,28,10749,10751],"popularity":3.4369,"vote_count":2415,"poster_path":"/k0OwgRR6PNu7h3SiqpCbRdZWNaG.jpg","release_date":"1986-06-18","vote_average":6.335,"backdrop_path":"/7rfcRXbFD0xr8NteNq1hwXUd4Af.jpg","original_title":"The Karate Kid Part II","original_language":"en"},{"id":8741,"adult":false,"title":"The Thin Red Line","video":false,"overview":"The story of a group of men, an Army Rifle company called C-for-Charlie, who change, suffer, and ultimately make essential discoveries about themselves during the fierce World War II battle of Guadalcanal. It follows their journey, from the surprise of an unopposed landing, through the bloody and exhausting battles that follow, to the ultimate departure of those who survived.","genre_ids":[18,36,10752],"popularity":4.1493,"vote_count":3221,"poster_path":"/seMydAaoxQP6F0xbE1jOcTmn5Jr.jpg","release_date":"1998-12-23","vote_average":7.445,"backdrop_path":"/hsDyfAk2ml82IrpPC4AHvxvuTsn.jpg","original_title":"The Thin Red Line","original_language":"en"},{"id":8827,"adult":false,"title":"99 Francs","video":false,"overview":"Paris, France, 2001. Octave Parango, a young advertiser working at the Ross & Witchcraft advertising agency, lives a suicidal existence, ruled by cynicism, irresponsibility and debauchery. The obstacles he will encounter in developing a campaign for a new yogurt brand will force him to face the meaning of his work and the way he manages his relationship with those who orbit around his egotistic lifestyle.","genre_ids":[18,35],"popularity":0.8294,"vote_count":779,"poster_path":"/8yj6tkyp7dvdzkkIasX2SUmZd81.jpg","release_date":"2007-09-26","vote_average":6.6,"backdrop_path":"/wHwpdFBkvHRKS1zXptaskCFJ8BK.jpg","original_title":"99 Francs","original_language":"fr"},{"id":8816,"adult":false,"title":"My Life as a Dog","video":false,"overview":"A boy, obsessed with comparing himself with those less fortunate, experiences a different life at the home of his aunt and uncle in 1959 Sweden.","genre_ids":[18,35],"popularity":1.1561,"vote_count":286,"poster_path":"/eVg9IsX2HtR1BNYH0UAhF4JPHi7.jpg","release_date":"1985-12-12","vote_average":7.212,"backdrop_path":"/zKqzUT0ZAljEYPLceye6ZT4H9By.jpg","original_title":"Mitt liv som hund","original_language":"sv"},{"id":277783,"adult":false,"title":"The Ski Bum","video":false,"overview":"A ski instructor tries to teach a bunch of insanely eccentric people how to ski while dealing with everyone wanting his attention.","genre_ids":[18,53],"popularity":0.3169,"vote_count":9,"poster_path":"/azlqAASgF9VLfaFD2x6pU1qbs8d.jpg","release_date":"1971-01-08","vote_average":4.333,"backdrop_path":null,"original_title":"The Ski Bum","original_language":"en"},{"id":9880,"adult":false,"title":"The Princess Diaries","video":false,"overview":"A socially awkward but very bright 15-year-old girl being raised by a single mom discovers that she is the princess of a small European country because of the recent death of her long-absent father, who, unknown to her, was the crown prince of Genovia. She must make a choice between continuing the life of a San Francisco teen or stepping up to the throne.","genre_ids":[35,10751,10749],"popularity":6.9723,"vote_count":5208,"poster_path":"/qSw4lzhDGeM5MjQc86BLzJALhBs.jpg","release_date":"2001-08-03","vote_average":6.963,"backdrop_path":"/ktPixrzD9Rbet7Co4uUWxyR9191.jpg","original_title":"The Princess Diaries","original_language":"en"},{"id":1068115,"adult":false,"title":"Kdo se bojí, utíká","video":false,"overview":"In a school somewhere in the border region, a young teacher is trying to integrate Romani children into the classroom. But their families remain suspicious of education. The filmmakers have chosen a largely romantic view that does not penetrate beneath the surface. They have included numerous folklore examples, acting as the most attractive element. The real problems can thus only b