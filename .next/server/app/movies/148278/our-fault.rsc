9:{"metadata":[["$","title","0",{"children":"Our Fault | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Jenna and Lion's wedding brings about the long-awaited reunion between Noah and Nick after their breakup. Nick's inability to forgive Noah stands as an insurmountable barrier. He, heir to his grandfather's businesses, and she, starting her professional life, resist fueling a flame that's still alive. But now that their paths have crossed again, will love be stronger than resentment?"}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148278/our-fault"}],["$","meta","5",{"property":"og:title","content":"Our Fault"}],["$","meta","6",{"property":"og:description","content":"Jenna and Lion's wedding brings about the long-awaited reunion between Noah and Nick after their breakup. Nick's inability to forgive Noah stands as an insurmountable barrier. He, heir to his grandfather's businesses, and she, starting her professional life, resist fueling a flame that's still alive. But now that their paths have crossed again, will love be stronger than resentment?"}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148278/our-fault"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/yzqHt4m1SeY9FbPrfZ0C2Hi9x1s.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Our Fault"}],["$","meta","12",{"name":"twitter:description","content":"Jenna and Lion's wedding brings about the long-awaited reunion between Noah and Nick after their breakup. Nick's inability to forgive Noah stands as an insurmountable barrier. He, heir to his grandfather's businesses, and she, starting her professional life, resist fueling a flame that's still alive. But now that their paths have crossed again, will love be stronger than resentment?"}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/yzqHt4m1SeY9FbPrfZ0C2Hi9x1s.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
