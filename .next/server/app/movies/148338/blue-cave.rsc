.238},{"width":2000,"height":3000,"file_path":"/32hWYgxMOudSgA6tR8nlVTUtoOi.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":5.238},{"width":2000,"height":3000,"file_path":"/yT7VYxdyAH7SCBnCwPBY2NqGDQr.jpg","iso_639_1":"pl","iso_3166_1":"PL","vote_count":2,"aspect_ratio":0.667,"vote_average":3.334},{"width":2000,"height":3000,"file_path":"/7KL4CkislzeVZ1miNkjdVGs6UoN.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":1476,"height":2197,"file_path":"/y4lOq1enSqlUGlODjzHNMSFiK70.jpg","iso_639_1":"ro","iso_3166_1":"RO","vote_count":1,"aspect_ratio":0.672,"vote_average":3.334},{"width":1707,"height":2560,"file_path":"/5zlbRu9X2FCSkDxV4ZhrPrJDgg8.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":2,"aspect_ratio":0.667,"vote_average":3.334},{"width":1706,"height":2560,"file_path":"/poe7ifFkIeSE3mCyFEIrpNeY3EW.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":4,"aspect_ratio":0.666,"vote_average":2.542},{"width":900,"height":1350,"file_path":"/zXlLAaBM3AWG1YBBteBCTiL03o3.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/dFaOOLyDleXg1S7VAJM32uCZtyJ.jpg","iso_639_1":"ar","iso_3166_1":"SA","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/alPdA3FAi6Atrioys4yxC3hr7V3.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/yy9wf0mKGUfcGblcyItFaD7VRZY.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/1aIw2DCgH3UwXfZrLGf51mtft3g.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/ezAZvfpYtcRVkQrzDyXEjnAyMGT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/9XgElBDBliYmvKIzsYus7OrOFxs.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1701,"height":2560,"file_path":"/70fTNEfa1BSfyGcKs7PZyjVea8A.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.664,"vote_average":0},{"width":718,"height":1024,"file_path":"/xHFzaCJUVOtPIZotU5JDqWEuzMm.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":0.701,"vote_average":0},{"width":2000,"height":3000,"file_path":"/vXgB76BGDUw96lhENTsVtQJiXNH.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/69zQPqavgtWhpvWS5dOU0sInjez.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/qYDeQ67c5GxMXmGop9GfCG5Ns0M.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":2029,"height":1140,"file_path":"/27OF511HkdPfEwnOZDmNedoWUou.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.78,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/4KnjBcvr3He1jrJNbNEISz59sAq.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/vSth4ghPLwuZ0geilirc303aB0c.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:06:42.124+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Blue Cave","runtime":88,"tagline":"","homepage":"","overview":"When Cem finds himself at the brink of losing the love of his life, Alara, he embarks on an expedition to the Blue Cave, Alara's most beloved archeological site, to feel close to her again."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Blue Cave","runtime":0,"tagline":"","homepage":"","overview":"Cem, ufficiale di marina, intraprende una spedizione verso il sito archeologico della Grotta Azzurra per sentirsi più vicino all’amore della sua vita, Alara. Il viaggio di Cem verso la Grotta Azzurra sarà rivelatore: immerso nei ricordi del loro amore, delle loro lotte, della loro passione e del loro dolore."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":88,"tagline":"Aşk sonsuzdur.","homepage":"","overview":"Deniz kuvvetlerinde komando olan Cem, hayatının aşkı Alara ile bir gün birlikte gideceklerine söz verdiği Mavi Mağara’ya ziyaret etmek için yolla çıkar. Alara ile aşklarının, mücadelelerinin, tutkularının ve acılarının anılarına boğulan Cem'in Mavi Mağara yolculuğu aydınlatıcı olacaktır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"A Caverna Azul","runtime":0,"tagline":"","homepage":"","overview":"Cem, um oficial da Marinha, embarca em uma expedição para o amor de sua vida, o sítio arqueológico mais amado de Alara, a Caverna Azul, para se sentir próximo dela. Envolto em memórias de seu amor, suas lutas, sua paixão e sua dor, a jornada de Cem até a Caverna Azul será esclarecedora."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"La cueva azul","runtime":0,"tagline":"","homepage":"","overview":"Cem, un soldado, encuentra a su media naranja cuando menos lo esperaba. Alara es una arqueóloga que se cruza en la vida del protagonista. Así, comenzará una apasionada historia de amor llena de contratiempos, aventuras y emotivas conversaciones."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"La Grotte Bleue","runtime":0,"tagline":"","homepage":"","overview":"Cem, commando dans la marine, se lance dans un périple pour se rendre à la Grotte Bleue. Il avait promis à Alara, son grand amour, qu’ils y iraient ensemble un jour. Ce voyage vers la Grotte Bleue s’avèrera éclairant pour Cem qui avance submergé par le souvenir de leur amour, leur passion, leurs disputes et leurs peines."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Błękitna jaskinia","runtime":0,"tagline":"","homepage":"","overview":"Kiedy Cem staje na krawędzi utraty miłości swojego życia, Alary, wyrusza na wyprawę do Błękitnej Jaskini, najbardziej ukochanego stanowiska archeologicznego Alary, aby znów poczuć z nią bliskość."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Die Blaue Höhle","runtime":88,"tagline":"","homepage":"","overview":"Marinesoldat Cem begibt sich auf eine Expedition zur Blauen Höhle, der archäologischen Lieblingsstätte seiner großen Liebe Alara, die sie irgendwann einmal gemeinsam besuchen wollten. Er hofft, sich ihr dadurch wieder ganz nah zu fühlen und gerät dabei in einen erhellenden Strudel aus Erinnerungen an ihre Liebe, aber auch an ihre Auseinandersetzungen, ihren Schmerz und ihre Leidenschaft."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"الكهف الازرق","runtime":0,"tagline":"","homepage":"","overview":"ينطلق الجندي البحري سيم في رحلة إلى \"الكهف الأزرق\" الذي وعد زوجته ألارا بزيارته. وتكشف الرحلة عن تفاصيل علاقتهما، وتؤكد على الحب الدائم بعد الموت"},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"La cueva azul","runtime":0,"tagline":"","homepage":"","overview":"Cem, un soldado, encuentra a su media naranja cuando menos lo esperaba. Alara es una arqueóloga que se cruza en la vida del protagonista. Así, comenzará una apasionada historia de amor llena de contratiempos, aventuras y emotivas conversaciones."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Cem is een soldaat bij de marine. Wanneer hij zijn vrouw Alara verliest aan kanker, begint hij een reis naar de “Blauwe Grot”, de plek waar hij beloofd heeft om op een dag zijn grote liefde voor haar te tonen. Cems reis naar de Blauwe Grot draait uit op een verrassende ontdekking die de details van zijn relatie met Alara onthult en bevestigt dat ware liefde eeuwig is."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"غار آبی","runtime":0,"tagline":"","homepage":"","overview":"وقتی جم خود را در آستانه از دست دادن عشق زندگی‌اش، آلارا، می‌بیند، سفری را به غار آبی، محبوب‌ترین مکان باستان‌شناسی آلارا، آغاز می‌کند تا دوباره حس نزدیکی به او را داشته باشد."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Peștera albastră","runtime":0,"tagline":"","homepage":"","overview":"Ofițerul de marină, Cem pornește într-o călătorie către cel mai îndrăgit sit arheologic al iubitei sale Alara, Peștera Albastră, pentru a se simți mai aproape de ea. Cuprins de amintirile despre dragostea lor, certurile, pasiunea și durerea lor, călătoria lui Cem către Peștera Albastră va fi una iluminatoare."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"ლურჯი მღვიმე","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Laivastoupseeri Cem lähtee matkalle Siniseen luolaan, elämänsä rakkauden Alaran rakastamaan arkeologiseen paikkaan, kokeakseen olevansa lähempänä häntä. Muistot heidän rakkaudestaan, intohimostaan ja tuskastaan valtaavat hänet. Cemin matkasta Siniseen luolaan tulee valaiseva."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Голубая пещера","runtime":0,"tagline":"","homepage":"","overview":"Джем уходит с работы и начинает жизнь с любимой Аларой. Но жестокость судьбы вскоре показала себя — девушка умирает от болезни. В горе Джем вспоминает, что когда-то обещал сходить с ней в Голубую пещеру, где та была в детстве. И путешествие в Голубую пещеру становится для него не только физическим, но и эмоциональным открытием, раскрывающим всю суть его отношений с Аларой."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Γαλάζια Σπηλιά","runtime":0,"tagline":"","homepage":"","overview":"Ο Τζεμ, ένας αξιωματικός του Ναυτικού, ξεκινά να επισκεφτεί τον αρχαιολογικό χώρο της Γαλάζιας Σπηλιάς που λάτρευε ο έρωτας της ζωής του, η Αλάρα, για να νιώσει ότι είναι κοντά της. Γεμάτος αναμνήσεις της αγάπης τους, των δυσκολιών τους, του πάθους τους και του πόνου τους, το ταξίδι του Τζεμ στη Γαλάζια Σπηλιά θα είναι αποκαλυπτικό."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"蓝洞生死恋","runtime":88,"tagline":"","homepage":"","overview":"　　当海军士兵 Cem (Kerem Bürsin) 的妻子 Alara (Devrim Özkan) 因癌症去世后，他开始前往“蓝洞”，他曾承诺有一天会在那里向她表达他的爱。Cem 前往蓝洞的旅程变成了一次意外的发现，揭示了他与 Alara 关系的细节，并再次证明了真爱是永恒的。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"블루 케이브","runtime":0,"tagline":"","homepage":"","overview":""},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Hang Xanh","runtime":0,"tagline":"","homepage":"","overview":"Blue Cave (2024) kể về Cem, một người lính hải quân, thực hiện lời hứa với vợ quá cố Alara bằng chuyến đi đến \"Hang Xanh\" – nơi lưu giữ những ký ức đẹp đẽ của họ. Trên hành trình, Cem hồi tưởng lại câu chuyện tình yêu sâu sắc và vượt thời gian, khẳng định rằng tình yêu thật sự không bao giờ phai nhạt, ngay cả sau cái chết."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Blue Cave","runtime":88,"tagline":"","homepage":"","overview":"Cem, en marinofficer, ger sig ut på en resa med destination Blå grottan. Grottan var Alaras, hans livs kärlek, mest älskade arkeologiska plats, och han reser för att känna sig närmre henne. Uppslukad av minnen av deras kärlek, deras svårigheter, deras passion och deras smärta, uppdagas verkligheten för Cem i och med resan till Blå grottan."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"}],"reviews_tmdb":[],"recommendations":[{"id":1073125,"adult":false,"title":"In Your Dreams","video":false,"overview":"You know the feeling. It feels like time slows down as your eyes meet a stranger’s. Then you walk pass each other, neither of you looking back. That’s what happened with Pelin and Engin. Lo and behold, they open their eyes in the same bed. And you may want to brace yourself for this one, as a two-year married couple! It must be a dream. No, a nightmare. But now, to wake up they must fall in love.","genre_ids":[10749,35,18],"media_type":"movie","popularity":3.0151,"vote_count":97,"poster_path":"/rZe2lT3G9C7JrwB7Avu22mVhqFw.jpg","release_date":"2023-02-03","vote_average":7.294,"backdrop_path":"/o9uMF84ZAGBqRxbliFCTgw0vQYv.jpg","original_title":"Rüyanda Görürsün","original_language":"tr"},{"id":1294949,"adult":false,"title":"Reinvented Mom","video":false,"overview":"Marina decides to take Patricia, her mother, to live with her, who believes that she should behave like the widow she is now. Living with Marina, he realizes that there are many things to do. Both find a new world to explore.","genre_ids":[35],"media_type":"movie","popularity":2.9192,"vote_count":30,"poster_path":"/9HOJUlJ0aZfLdsjgKIDjjc5FbUV.jpg","release_date":"2025-05-08","vote_average":8.6,"backdrop_path":"/rx7aw7NGnIuCYorPBWeNPrgOMAc.jpg","original_title":"Mamá Reinventada","original_language":"es"},{"id":1096812,"adult":false,"title":"Improvvisamente a Natale mi sposo","video":false,"overview":"","genre_ids":[35],"media_type":"movie","popularity":0.2313,"vote_count":36,"poster_path":"/jKCWln6xZTdCpwV6dwjxT7lc6WN.jpg","release_date":"2023-12-06","vote_average":5.417,"backdrop_path":"/w7pXigDTU4usY1RGT7EqI85NLU0.jpg","original_title":"Improvvisamente a Natale mi sposo","original_language":"it"},{"id":1198904,"adult":false,"title":"Atatürk II 1881 – 1919","video":false,"overview":"Mustafa Kemal had just begun his journey after proving himself in 1915 at the Gallipoli front. He would go on to face major battles on the eastern front against the Russians and later against the British in Syria, ultimately becoming the only Ottoman officer not to lose a battle during WW1. However, despite all his success, he would encounter an unexpected challenge upon his return to Istanbul.","genre_ids":[36,18,10752],"media_type":"movie","popularity":0.4045,"vote_count":18,"poster_path":"/mmUxzWaQp1HrdySFl7cIjPkms0E.jpg","release_date":"2024-01-04","vote_average":8.1,"backdrop_path":"/t5jXjGPzKke3AD8P98QUqPuFJpm.jpg","original_title":"Atatürk II 1881 – 1919","original_language":"tr"},{"id":1549551,"adult":false,"title":"Mr Dread","video":false,"overview":"Dehşet Engiz, a top hitman from a forbidden organization called Fedailer Ocağı, falls in love with Dr. Abide. This unprecedented feeling leads him to question the group's rules against love, potentially forcing him to choose between his duty and his newfound love for Abide, which could have heavy consequences for everyone.","genre_ids":[28,80,10749,12,53],"media_type":"movie","popularity":1.1489,"vote_count":5,"poster_path":"/deMhNYuqcA8HXRrilI9QIa4Nucd.jpg","release_date":"2025-10-30","vote_average":8.8,"backdrop_path":"/8iDHK0FctZVvpEjUpCz6iEXntNK.jpg","original_title":"Dehşet Bey","original_language":"tr"},{"id":1220635,"adult":false,"title":"Season of Love","video":false,"overview":"The paths of two former sweethearts unexpectedly cross years later as they grapple with their dreams and disappointments","genre_ids":[10749],"media_type":"movie","popularity":1.5511,"vote_count":3,"poster_path":"/mYus8GNVi8BYIubE5bsPkrz6u13.jpg","release_date":"2024-02-02","vote_average":6.3,"backdrop_path":"/leV0uuoYrvS402UfrzfJ6APQJmP.jpg","original_title":"Aşk Mevsimi","o