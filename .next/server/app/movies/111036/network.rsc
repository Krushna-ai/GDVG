9:{"metadata":[["$","title","0",{"children":"Network | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"When veteran anchorman Howard Beale is forced to retire his 25-year post because of his age, he announces to viewers that he will kill himself during his farewell broadcast. Network executives rethink their decision when his fanatical tirade results in a spike in ratings."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/111036/network"}],["$","meta","5",{"property":"og:title","content":"Network"}],["$","meta","6",{"property":"og:description","content":"When veteran anchorman Howard Beale is forced to retire his 25-year post because of his age, he announces to viewers that he will kill himself during his farewell broadcast. Network executives rethink their decision when his fanatical tirade results in a spike in ratings."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/111036/network"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/qZomlHsaALUtkFeMDwdYmwS2Pbo.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Network"}],["$","meta","12",{"name":"twitter:description","content":"When veteran anchorman Howard Beale is forced to retire his 25-year post because of his age, he announces to viewers that he will kill himself during his farewell broadcast. Network executives rethink their decision when his fanatical tirade results in a spike in ratings."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/qZomlHsaALUtkFeMDwdYmwS2Pbo.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}