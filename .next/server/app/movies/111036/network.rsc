tps://www.themoviedb.org/movie/10774-network/watch?locale=VA","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":0}]},"VE":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":4}],"link":"https://www.themoviedb.org/movie/10774-network/watch?locale=VE","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":4}],"flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":2}]},"YE":{"link":"https://www.themoviedb.org/movie/10774-network/watch?locale=YE","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1}]},"ZA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}],"link":"https://www.themoviedb.org/movie/10774-network/watch?locale=ZA","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}],"flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1}]},"ZM":{"link":"https://www.themoviedb.org/movie/10774-network/watch?locale=ZM","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1}]},"ZW":{"link":"https://www.themoviedb.org/movie/10774-network/watch?locale=ZW","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":2}]}}},"wikidata_id":"Q572165","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-20T22:15:59.011637+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":[{"data":{"title":"","runtime":122,"tagline":"Television will never be the same.","homepage":"","overview":"When veteran anchorman Howard Beale is forced to retire his 25-year post because of his age, he announces to viewers that he will kill himself during his farewell broadcast. Network executives rethink their decision when his fanatical tirade results in a spike in ratings."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":121,"tagline":"Nach diesem Film haben Sie keine Lust mehr zum Fernsehen.","homepage":"","overview":"Der langjährige Nachrichtensprecher Howard Beale soll wegen sinkender Quoten gefeuert werden. Vor laufender Kamera macht er sich in einem wütenden Ausbrucht Luft - und prompt jagt seine Rage die Ratings in die Höhe. Natürlich wird er sofort wieder eingestellt und als \"zorniger Prophet\" vermarktet. Doch was tun, sobald der Prophet keinen Profit mehr bringt? Es muss etwas geschehen! Am besten während einer Live-Sendung - vor Publikum."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Quinto potere","runtime":121,"tagline":"La televisione non sarà mai più la stessa.","homepage":"","overview":"Vincitore di 4 Oscar e di 4 Golden Globe nel 1977 - altri 11 premi e 19 nomination.Howard Beale è un commentatore televisivo con un larghissimo seguito; il suo indice di gradimento però è in discesa e i suoi capi decidono di licenziarlo. Howard allora dichiara davanti alle telecamere che si ucciderà: da quel momento ha un successo strepitoso, specie da quando, credendosi direttamente in contatto con Dio, diventa una sorta di profeta trascinatore."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Escândalo na TV","runtime":122,"tagline":"A televisão nunca mais será a mesma.","homepage":"","overview":"Quando o veterano pivot Howard Beale é forçado a reformar-se do seu posto de 25 anos devido à sua idade, anuncia aos telespectadores que se vai suicidar durante a sua emissão de despedida. Os executivos da estação repensam a sua decisão quando a sua tirada fanática resulta num pico de audiências."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Телесеть","runtime":121,"tagline":"","homepage":"","overview":"Постоянный «гвоздь программы» новостей телестанции UBS-TV Говард Били погорел: во время прямого эфира у него случился нервный срыв. По иронии, публичное бесчинство подняло его и без того баснословный рейтинг, к неожиданному ликованию боссов UBS. Как следствие, прославившись «безумным пророком прямого эфира», вскоре он превратился в пешку для безжалостного теленачальства, которое выдаивало из него сумасшедшие выходки при любом удобном случае. Само собой, когда «пророк» стал не в прок, с ним надо было срочно что-то решать, желательно перед камерой, и при полной аудитории."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Network : Main basse sur la télévision","runtime":121,"tagline":"La télévision ne sera plus jamais la même.","homepage":"","overview":"Au milieu des années 70, les informations à la télévision changent. Le journalisme perd en effet pied face au pouvoir de l'argent et le besoin croissant de divertissement. Une rédaction se bat alors pour maintenir son audience sans se compromettre."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Network, un mundo implacable","runtime":121,"tagline":"¡Desde los albores del tiempo América no ha experimentado un hombre como Howard Beale!","homepage":"","overview":"Tras 25 años trabajando en una cadena, el veterano presentador Howard Beale debe abandonar su puesto por el bajo nivel de audiencia. Su jefe y mejor amigo, Max Schumacher, le da dos semanas para despedirse de los espectadores. Beale, viudo y alcohólico, queda trastocado y decide anunciar durante una emisión que se suicidará en su último programa ante las cámaras. El hecho sin precedentes provoca una gran expectación y los propios compañeros tratarán de convertir la destrucción de este hombre en un negocio rentable."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"电视台风云","runtime":121,"tagline":"","homepage":"","overview":"这部由西德尼·吕美特执导、帕迪·查耶夫斯基执笔犀利剧本的媒体讽刺剧，犹如一剂X光，透视了企业主导下美国的腐朽灵魂，其对今日煽动性新闻循环的预见力惊人。在一家挣扎求存的电视网里，野心勃勃的高管戴安娜·克里斯滕森（费·唐纳薇 饰）偶然发现爆款——当心怀不满的新闻主播霍华德·比尔（彼得·芬奇 饰）脱离讲稿，变身愤怒的“狂人先知”，痛斥现代社会弊病。然而，她能否控制住他们在电波中掀起的这场民粹风暴？这部毫无保留的新好莱坞经典作品斩获四项奥斯卡奖（包括唐纳薇、芬奇与查耶夫斯基所获奖项），至今仍保持着无畏的幽默感与令人不安的现实意义。[标准收藏]"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Şebeke","runtime":0,"tagline":"Televizyon asla eskisi gibi olmayacak.","homepage":"","overview":"Şebeke, uzun yıllardır UBS Akşam Haberleri isimli programda haber spikerliği yapan Howard Beale’nin hikayesini konu alır. Beale’in ratingleri günden güne düşmektedir ve nihayetinde bir çalışma arkadaşından, iki hafta içerisinde işinden kovulacağını öğrenir. Bunu öğrendiğinde büyük bir depresyona giren adam, ertesi akşam canlı yayında, gelecek Salı günü canlı yayında intihar edeceğini anons eder. Haliyle bu şok duyurudan sonra işler fazlasıyla karışır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Hálózat","runtime":121,"tagline":"","homepage":"","overview":"A film egy amerikai tévécsatorna életébe nyújt bepillantást. Az egyik legnépszerűbb kommentátort, Howard Beale-t el akarják távolítani, mert esni kezdett a nézettsége. A kétségbeesett férfi élő adásban jelenti be, hogy öngyilkos lesz. Mivel ettől a nézettség látványosan megugrik, a csatorna vezetői elhatározzák, hogy kihasználják Beale hirtelen jött népszerűségét, és egy saját műsort adnak neki, amelyben szabadon átkozhatja a médiát."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Rețeaua","runtime":121,"tagline":"Televiziunea nu va mai fi niciodată la fel.","homepage":"","overview":"Peter Finch joacă rolul unui prezentator de știri care este concediat. Reacția lui la această decizie este să-și exprime furia în direct și să anunțe că, în cadrul ultimei emisiuni, peste două săptămâni, se va sinucide în direct. În paralel, filmul urmărește personajul lui Faye Dunaway, pe care dorința de a obține audiențe cât mai mari cu orice preț o împinge către decizii șocante și comportamente aberante."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Den aldrende nyhedsoplæser Howard Beale erfarer, at han kun har to uger tilbage på arbejdet grundet dalende seertal. I vrede og fuldskab annoncerer han, at han vil begå selvmord for åben skærm. Hvorfor ikke, nu hvor der ikke er nogen der lytter? Han må selvfølgelig trække ordene i sig igen, men nu har nyhedsredaktionen fået blod på tanden og øjner en publikumsmagnet i Howard Beale. I løbet af de næste uger opnår Beale heltestatus som en slags missionær og talerør, der siger ligeud, hvad folket mener om det amerikanske samfund og om verdenssituationen – direkte på tv! Men i en tid hvor der ikke er nogen skrupler, hvordan vil cheferne holde seertallene høje?"},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"רשת שידור","runtime":0,"tagline":"","homepage":"","overview":"חברת טלויזיה מנצלת בציניות מנחה טלוזיה לשעברומגלים דברים מטורפים על עולם הבידור בשביל רווח אישי."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":121,"tagline":"","homepage":"","overview":"De ouder wordende nieuwslezer Howard Beale van UBS wordt wegens tegenvallende kijkcijfers ontslagen. Hij reageert hierop door live op tv te verklaren on-air zelfmoord te zullen plegen. Hierdoor wordt Beale een grote tv-bekendheid, iets dat de met problemen kampende zender wel kan gebruiken."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Rede de Intrigas","runtime":121,"tagline":"A televisão nunca mais será a mesma.","homepage":"","overview":"Um locutor de noticiário de uma rede de televisão americana é demitido em razão da baixa audiência do programa. Ele então anuncia que irá cometer suicídio no ar. Por esta razão, os índices de audiência do programa voltam a crescer, ele passa a ser conhecido como o Profeta Louco, e é readmitido. Mas seu comportamento insano faz com que os responsáveis pela sua ascensão decidam detê-lo."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Το Δίκτυο","runtime":0,"tagline":"","homepage":"","overview":"Στο φιλμ έχουμε τέσσερις βασικούς χαρακτήρες σε διαφορετικά πόστα του συστήματος. Ο Χάουαρντ είναι ένας newscaster που χάνει την δημοτικότητα του και ως εκ τούτου, βλέπει την απόλυση του να έρχεται. Σε μια στιγμή απόλυτης ειλικρίνειας, λέει μερικές αλήθειες στην τελευταία του εμφάνιση. Τα νούμερα εκτινάσσονται, και ο Χάουαρντ παίρνει το δικό του σώου απο-καλύψεων”. Ο Μαξ είναι ο διευθυντής του τμήματος ειδήσεων του καναλιού. Άνθρωπος ρομαντικός, μα και χωμένος στα κόλπα της τηλεόρασης από τα γεννοφάσκια της. Προσπαθώντας να αντισταθεί στον απόλυτο εξευτελισμό του τμήματος του, θα χάσει την θέση του. Η Νταϊάνα είναι υπεύθυνη προγράμ-ματος. Σκοπός της είναι να πάρει κάθε τι αληθινό και να το εκμεταλλευτεί (βγάζοντας καλά φράγκα) έως ότου αυτό ξεφτίσει. Τέλος, ο Φρανκ είναι ένα διοικητικό στέλεχος της εταιρίας που έχει εξαγοράσει το κανάλι. Τα μόνα πράγματα που τον ενδιαφέρουν είναι να ανέβει στην κορυφή της διοίκησης και τα κέρδη!"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Sieć","runtime":121,"tagline":"","homepage":"","overview":"Howard Beale, prezenter wiadomości w telewizyjnej stacji UBS, dostaje wymówienie z pracy z powodu spadku oglądalności jego programu. W ostatnim swoim wejściu na antenę zamierza zapowiedzieć popełnienie samobójstwa, zmienia jednak plan i zamiast tego wykrzykuje do mikrofonu swoją opinię na temat sytuacji, jaka panuje w społeczeństwie amerykańskim. Widzowie są zachwyceni, a sieć telewizyjna zwiększa swoje dochody. Jednak wkrótce telewizyjny prorok staje się dla zwierzchników uciążliwy."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Televizní společnost","runtime":0,"tagline":"","homepage":"","overview":"Snímek Network, břitká satira na \"senzacechtivé zpravodajství\", se zdá být s každým uplynulým rokem aktuálnější než kdy dřív. Howard Beale, moderátorská hvězda televizní společnosti UBS, je poslán do důchodu, protože příliš zestárl. Beale nedokáže přenést přes srdce, že po pětadvaceti letech přijde o práci jenom kvůli věku. V dalších zprávách proto divákům oznámí, že během svého posledního vysílání spáchá sebevraždu. Šéf televizní stanice Frank Hackett chce Bealea na místě vyhodit, když se ale ukáže, že by UBS mohla dosáhnout v den Bealeovy smrti nejvyšší sledovanosti v historii, kariéristka Diana Christensenová šéfa přesvědčí, aby tohle osudové závěrečné vysílání pojali jako zvláštní událost. Beale se samozřejmě nakonec nezabije - ale začne nesouvisle hovořit o hrozném stavu světa a televize především. Díky tomu se z něj stane nejžhavější osobnost americké televize."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Телевизионна мрежа","runtime":120,"tagline":"","homepage":"","overview":"Големият проблем на нашата телевизия не се крие толкова в това, че подхранва насилието в реалността. По-страшното е, че тя ни прави безчувствени към това насилие, към порока и бруталността, убийствата и смъртта. Телевизията разруши човешката същност на индивида. Тя изгради нова реалност по свой образ и подобие и замести с нея истинската действителност."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"네트워크","runtime":0,"tagline":"","homepage":"","overview":"USB 방송국의 뉴스 앵커 하워드 빌은 과장된 풍자와 독설로 한때 높은 시청률로 인기를 누렸던 인물이다. 그러나 점차 시청률이 떨어지게 되자 방송국의 사장은 빌을 해고하려고 한다. 빌은 그의 직속 상사와 함께 술을 마시는 자리에서 방송 중 자살에 대한 농담을 나누고는 고별 방송에서 시청률 저하 때문에 자살하겠다고 한다. 빌은 방송에서 교체되었지만 가까스로 고별방송을 할 수 있도록 허락받고는 시청자들에게 자신의 처지를 솔직히 털어놓는다. 그의 솔직함에 시청자들이 반응을 보이기 시작하며 시청률이 급등하자 프로그램 기획자인 다이아나는 빌의 상품성을 꿰뚫고는 사장에게 빌을 해고해서는 안된다고 설득한다. 빌은 다시 방송을 하게 되지만 직업적 스트레스로 인한 정신병이 점점 심해져간다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Телемережа","runtime":0,"tagline":"","homepage":"","overview":"В основі фільму лежить історія вигаданої телекомпанії Union Broadcasting System (UBS) та її ведучого новин Говарда Біла. Біл сходить з розуму, проте UBS у гонитві за рейтингами продовжує випускати його передачу. Під час одного з випусків Біл несамовито кричить «Я злий, як собака, і більше не збираюся цього терпіти!» і закликає всіх глядачів покричати цю фразу. Люди по всій країні з вікон кричать те ж саме. UBS створює «Шоу Говарда Біла», позиціонуючи Біла як «божевільного пророка». Шоу моментально стає найпопулярнішою програмою."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"螢光幕後","runtime":0,"tagline":"薛尼盧梅執導，費唐娜薇、威廉荷頓、彼德芬治、勞勃杜瓦領銜主演。電視台為了拯救收視率不擇手段，除了將新聞節目綜藝化，更續聘精神異常的主播。","homepage":"","overview":"薛尼盧梅執導，費唐娜薇、威廉荷頓、彼德芬治、勞勃杜瓦領銜主演。電視台為了拯救收視率不擇手段，除了將新聞節目綜藝化，更續聘精神異常的主播。本片諷刺電視台無所不用其極鞏固收視率，即便影片已歷時30幾年，仍舊十分符合時下媒體現況。榮獲1976年奧斯卡金像獎最佳男女主角、最佳女配角、最佳原著劇本四項大獎。  1975年，紐約UBS電視台的王牌新聞主播霍華比爾（彼德芬治飾），受到妻子過世的打擊成天酗酒，使得收視率慘跌，電視台主管卻任由霍華在主持的新聞節目上大發憤世嫉俗言論，沒想到收視率大增，原本被革職的比爾因而繼續留任。然而，因為政治力量的介入，在一次的新聞節目中，比爾竟然險被刺殺…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Tittarsiffrorna sjunker för nyhetsuppläsaren Howard Beale och ledningen tänker sparka honom. Den förtvivlade Beale meddelar i direktsändning att han tänker ta livet av sig. Den ambitiösa journalisten Diana får idén till en ny show. Beales missnöjesprogram blir en jättesuccé. Men när han börjar attackera makten blir han farlig för bolaget."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"ネットワーク","runtime":0,"tagline":"","homepage":"","overview":"視聴率低下を気に悩んでノイローゼになった、ニュース番組の司会者ビール。しかし彼が番組中に自殺予告をしたことで、視聴率はどんどん上がっていき!? 大手テレビ局を舞台に悪戦苦闘する人間たちの姿を、社会派シドニー・ルメットが鋭く描く。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Kasvot kuvaruudussa","runtime":0,"tagline":"","homepage":"","overview":"Kymmenen Oscar-ehdokkuutta kerännyt Kasvot kuvaruudussa on satiiri tv-aseman uutisankkurista, joka nousee kansansuosikiksi ja profeetaksi omaperäisillä, tyytymättömillä puheillaan. Vuonna 1976 ensi-iltansa saanut, mutta yhä ajankohtainen elokuva kuvaa tv-julkisuuden ja katsojakilpailun kyynisiä lakeja. Elokuvan ohjasi Sidney Lumet.  Uutisankkuri Howard Beale siirretään 25 työvuoden jälkeen pois tehtävästään. Beale ryhtyy kuitenkin vihaiseen vastahyökkäykseen, mikä puhuttelee televisiouutisten latteisiin lauseisiin tylsistyneitä katsojia."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"","runtime":0,"tagline":"التلفاز لن يكون هو نفسه أبدا","homepage":"","overview":"عندما يُجبر المذيع المخضرم هوارد بيل على التقاعد من منصبه الذي استمر 25 عامًا بسبب عمره ، يعلن للمشاهدين أنه سيقتل نفسه أثناء بثه الوداعي. يعيد المسؤولون التنفيذيون للشبكة التفكير في قرارهم عندما تؤدي خطبه المتعصبة إلى ارتفاع في التقييمات."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"","runtime":121,"tagline":"","homepage":"","overview":"Keď moderátora správ Howarda Bealea kvôli jeho veku prinútia po 25 rokoch kariéry odísť do dôchodku, oznámi divákom, že počas svojho posledného vysielania spácha samovraždu. Keď však po jeho fanatickom vystúpení prudko stúpne sledovanosť, vedenie televízne siete si svoje rozhodnutie rozmyslí."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Apprenant son congédiement, un animateur-vedette se met en colère sur les ondes et s'attire la sympathie du public."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Poder que mata","runtime":122,"tagline":"","homepage":"","overview":""},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"螢光幕後","runtime":0,"tagline":"","homepage":"","overview":"薛尼盧梅執導，費唐娜薇、威廉荷頓、彼德芬治、勞勃杜瓦領銜主演。電視台為了拯救收視率不擇手段，除了將新聞節目綜藝化，更續聘精神異常的主播。本片諷刺電視台無所不用其極鞏固收視率，即便影片已歷時 30 幾年，仍舊十分符合時下媒體現況。榮獲 1976 年奧斯卡金像獎最佳男女主角、最佳女配角、最佳原著劇本四項大獎。\r 1975 年，紐約 UBS 電視台的王牌新聞主播霍華比爾（彼德芬治飾），受到妻子過世的打擊成天酗酒，使得收視率慘跌，電視台主管卻任由霍華在主持的新聞節目上大發憤世嫉俗言論，沒想到收視率大增，原本被革職的比爾因而繼續留任。然而，因為政治力量的介入，在一次的新聞節目中，比爾竟然險被刺殺…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Network","runtime":0,"tagline":"Des de les albors del temps Amèrica no ha experimentat un home com Howard Beale!","homepage":"","overview":"Després de 25 anys treballant en una cadena, el veterà presentador Howard Beale ha d'abandonar el càrrec pel baix nivell d'audiència. El seu cap i millor amic, Max Schumacher, li dóna dues setmanes per acomiadar-se dels espectadors. Beale, vidu i alcohòlic, queda trastocat i decideix anunciar durant una emissió que se suïcidarà al seu últim programa davant les càmeres. El fet sense precedents provoca una gran expectació i els mateixos companys intentaran convertir la destrucció d'aquest home en un negoci rendible."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"شبکه","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Mreža","runtime":0,"tagline":"","homepage":"","overview":"Kada dugogodišnjeg TV voditelja primoraju da napusti posao, on objavi gledateljima da će počiniti samoubojstvo u posljednjoj emisiji."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Televõrk","runtime":0,"tagline":"","homepage":"","overview":"UBS-i telekanali asepresident Diana Christensen on suurte reitingunumbrite nimel kõigeks valmis. Seetõttu kaotab uudisteankur Howard Beale oma töökoha, kuid reageerib sellele täiesti ettearvamatult, ähvardades end eetris ära tappa. Nii saab ta hoopiski oma saate, mis osutub edukaks ning Beale hakkab oma võimu televõrgus CCA telekompanii vastu kasutama, kui see aegamööda UBS-i jaama üle võtab"},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"მაუწყებლობა","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"เน็ทเวิร์ค","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"}],"reviews_tmdb":[{"id":"54afa1d99251414aee0015a0","url":"https://www.themoviedb.org/review/54afa1d99251414aee0015a0","author":"tmdb39513728","content":"$11","created_at":"2015-01-09T09:39:37.841Z","updated_at":"2021-06-23T15:57:31.572Z","author_details":{"name":"","rating":10,"username":"tmdb39513728","avatar_path":null}},{"id":"5e206ec40102c900133c5bcf","url":"https://www.themoviedb.org/review/5e206ec40102c900133c5bcf","author":"The Movie Diorama","content":"$12","created_at":"2020-01-16T14:10:12.827Z","updated_at":"2021-06-23T15:58:32.363Z","author_details":{"name":"The Movie Diorama","rating":9,"username":"themoviediorama","avatar_path":"/qSZuzbs51L4dOd0dP9fnSN2TWsM.jpg"}},{"id":"648af72042bf0100e49cdd94","url":"https://www.themoviedb.org/review/648af72042bf0100e49cdd94","author":"Ahmetaslan27","content":"$13","created_at":"2023-06-15T11:33:52.464Z","updated_at":"2023-06-15T11:33:52.545Z","author_details":{"name":"","rating":8,"username":"Ahmetaslan27","avatar_path":null}},{"id":"6585a0fc43cd54552a3c1261","url":"https://www.themoviedb.org/review/6585a0fc43cd54552a3c1261","author":"CinemaSerf","content":"$14","created_at":"2023-12-22T14:45:16.160Z","updated_at":"2023-12-22T14:45:16.269Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}},{"id":"66932c665fb1e85bfbe4f091","url":"https://www.themoviedb.org/review/66932c665fb1e85bfbe4f091","author":"Brent Marchant","content":"$15","created_at":"2024-07-14T01:39:50.273Z","updated_at":"2024-07-14T01:39:50.375Z","author_details":{"name":"Brent Marchant","rating":10,"username":"Brent_Marchant","avatar_path":null}}],"recommendations":[{"id":11139,"adult":false,"title":"Léolo","video":false,"overview":"The story of an imaginative boy who pretends he is the child of a sperm-laden Sicilian tomato upon which his mother accidentally fell.","genre_ids":[35,18,14],"media_type":"movie","popularity":0.6444,"vote_count":132,"poster_path":"/1HDTXmngKg6NHKGVnKADpxGPye5.jpg","release_date":"1992-09-16","vote_average":7.1,"backdrop_path":"/7v4l2FnrpreaV19gY4xYiuPDPL2.jpg","original_title":"Léolo","original_language":"fr"},{"id":11314,"adult":false,"title":"Koyaanisqatsi","video":false,"overview":"Takes us to locations all around the US and shows us the heavy toll that modern technology is having on humans and the earth. The visual tone poem contains neither dialogue nor a vocalized narration: its tone is set by the juxtaposition of images and the exceptional music by Philip Glass.","genre_ids":[99,10402],"media_type":"movie","popularity":2.0429,"vote_count":755,"poster_path":"/6zCNciRcob8lwuydVXgq0esla8L.jpg","release_date":"1983-04-27","vote_average":7.9,"backdrop_path":"/84E96lyR81OvUjCimcrfuzn9er5.jpg","original_title":"Koyaanisqatsi","original_language":"en"},{"id":982,"adult":false,"title":"The Manchurian Candidate","video":false,"overview":"Near the end of the Korean War, a platoon of U.S. soldiers is captured by communists and brainwashed. Following the war, the platoon is returned home, and Sergeant Raymond Shaw is lauded as a hero by the rest of his platoon. However, the platoon commander, Captain Bennett Marco, finds himself plagued by strange nightmares and soon races to uncover a terrible plot.","genre_ids":[53,18],"media_type":"movie","popularity":2.5861,"vote_count":785,"poster_path":"/2xQ856kd9hw6bB3OnusGyTvvkwB.jpg","release_date":"1962-10-24","vote_average":7.517,"backdrop_path":"/bbec0wDUaV8nQnQHC6Fb0fSYwNM.jpg","original_title":"The Manchurian Candidate","original_language":"en"},{"id":27029,"adult":false,"title":"The Nun's Story","video":false,"overview":"After leaving a wealthy Belgian family to become a nun, Sister Luke struggles with her devotion to her vows during crisis, disappointment, and World War II.","genre_ids":[18],"media_type":"movie","popularity":1.2747,"vote_count":195,"poster_path":"/4vNWFhPyjTehPpZsvTnTywwXSiF.jpg","release_date":"1959-06-18","vote_average":7.189,"backdrop_path":"/A4QIIp63nmjBlnNpo5rbgfhbsqw.jpg","original_title":"The Nun's Story","original_language":"en"},{"id":326382,"adult":false,"title":"Zama","video":false,"overview":"In a remote South American colony in the late 18th century, officer Zama of the Spanish crown waits in vain for a transfer to a more prestigious location. He suffers small humiliations and petty politicking as he increasingly succumbs to lust and paranoia.","genre_ids":[18,36],"media_type":"movie","popularity":2.5208,"vote_count":172,"poster_path":"/kpp9R6iYKSIXxfyW0feVYrk0jsg.jpg","release_date":"2017-09-28","vote_average":6.544,"backdrop_path":"/9JqIR7bBO0uofsJiONgYAX2yw1R.jpg","original_title":"Zama","original_language":"es"},{"id":167221,"adult":false,"title":"Long Live Freedom","video":false,"overview":"Elections are approaching and things don't look too good for the opposition. Their leader can't stand the pressure and disappears. To avoid a scandal, the upper echelons of the party concoct a risky plan: to replace him with his identical twin, a philosopher with BPD, whose eclectic ideas and direct approach unexpectedly make the party surge in the polls.","genre_ids":[35,18],"media_type":"movie","popularity":0.2883,"vote_count":207,"poster_path":"/e6UFJbhBG0sStPle9RoWC07s0K0.jpg","release_date":"2013-02-13","vote_average":6.8,"backdrop_path":"/5v2zW1RiHU4uPO2Mlfq6kYQCzhc.jpg","original_title":"Viva la libertà","original_language":"it"},{"id":406000,"adult":false,"title":"The Teacher","video":false,"overview":"The principal of an elementary school calls a special parents meeting after it’s alleged that the seemingly empathetic and kindly-looking teacher Mrs. Drazděchová uses her students to manipulate their parents.","genre_ids":[18,35],"media_type":"movie","popularity":0.5499,"vote_count":104,"poster_path":"/3d8KLjAoQsvd6Bw4noQwXhqu3m0.jpg","release_date":"2016-07-21","vote_average":6.875,"backdrop_path":"/jMwkHToxIE7ZsCJgopSX0YYG8c6.jpg","original_title":"Učiteľka","original_language":"sk"},{"id":22274,"adult":false,"title":"Quiet Chaos","video":false,"overview":"Pietro is a successful businessman with a wife and a daughter. One day he helps his brother save two women from drowning at the beach. When he returns home he finds that his wife has died. Now Pietro has to take care of his daughter, Claudia. When he drives her to school soon after, he decides to wait for her all day in front of the school, and soon that's what he does every day.","genre_ids":[10749,18],"media_type":"movie","popularity":0.5188,"vote_count":199,"poster_path":"/3wx2fd6UnFBQRKV6dTBKhRze4ep.jpg","release_date":"2008-02-08","vote_average":6.457,"backdrop_path":"/jilAAQ4NNFyna5wlgp5DFOJxr2w.jpg","original_title":"Caos calmo","original_language":"it"},{"id":45938,"adult":false,"title":"Sunday Bloody Sunday","video":false,"overview":"Recently divorced career woman Alex Greville begins a romantic relationship with glamorous mod artist Bob Elkin, fully aware that he's also intimately involved with middle-aged doctor Daniel Hirsh. For both Alex and Daniel, the younger man represents a break with their repressive pasts, and though both know that Bob is seeing both of them, neither is willing to let go of the youth and vitality he brings to their otherwise stable lives.","genre_ids":[18],"media_type":"movie","popularity":2.9625,"vote_count":134,"poster_path":"/7q1h3M1vDlsHDKRhoPOzKjmFCVq.jpg","release_date":"1971-07-01","vote_average":6.6,"backdrop_path":"/xkIaVZo98JFCteffdXRgZfcW5A.jpg","original_title":"Sunday Bloody Sunday","original_language":"en"},{"id":5767,"adult":false,"title":"Two for the Road","video":false,"overview":"Architect Mark Wallace and his wife, Joanna, travel to France to meet with an affluent client. While there, they reflect on their first decade of marriage -- memories of when they first met, of courtship, and of road trips through the French countryside. As flirtation and playful quarreling turn to boredom with the banality of married life, the Wallaces struggle to rekindle their passion, while mutual infidelity threatens to tear them apart.","genre_ids":[18,10749,35],"media_type":"movie","popularity":0.8765,"vote_count":261,"poster_path":"/f9GAaL5gXzSP8LhXJcAx8Remfy3.jpg","release_date":"1967-04-27","vote_average":7,"backdrop_path":"/mAZqXy8Ssigm1owFtwC70nT2RcB.jpg","original_title":"Two for the Road","original_language":"en"},{"id":4226,"adult":false,"title":"Shriek If You Know What I Did Last Friday the Thirteenth","video":false,"overview":"In this horror parody, a masked serial killer menaces the town of Bulimia Falls with various sharp objects. Attention-seeking television personality Hagitha Utslay is soon on the scene, reporting on the ever-growing body count. Former mall security guard Doughy shows up to protect the teenage population, but he's clearly not much help, allowing the murderer to pick off even more hapless kids as numerous scary movies are referenced.","genre_ids":[35],"media_type":"movie","popularity":1.271,"vote_count":322,"poster_path":"/vNZ4Dhoi5v9cb4VMvX28dV38nt5.jpg","release_date":"2000-10-17","vote_average":4.696,"backdrop_path":"/wjOC016WdJd6xCphiebKNYDuq4Q.jpg","original_title":"Shriek If You Know What I Did Last Friday the Thirteenth","original_language":"en"},{"id":37749,"adult":false,"title":"Looking for Mr. Goodbar","video":false,"overview":"A short, unhappy affair with a married man leads a dedicated schoolteacher into the alcohol-and-drug fueled underworld of singles’ bars, where she begins to engage in a pattern of dangerous sexual activity.","genre_ids":[18,80],"media_type":"movie","popularity":1.2098,"vote_count":124,"poster_path":"/j1qKNKRvDEhnl0PQS26PirNF81v.jpg","release_date":"1977-10-19","vote_average":6.363,"backdrop_path":"/mN6xN0rz7BqfgMHsGYnmvD4EXfG.jpg","original_title":"Looking for Mr. Goodbar","original_language":"en"},{"id":96821,"adult":false,"title":"Caesar Must Die","video":false,"overview":"Inmates at a prison in Rome rehearse for a performance of Shakespeare's Julius Caesar.","genre_ids":[18,99],"media_type":"movie","popularity":0.3377,"vote_count":158,"poster_path":"/jrtCezCf08Kuk1I9D14vy3ZmfA4.jpg","release_date":"2012-03-02","vote_average":7.2,"backdrop_path":"/1PvPjvtsSwj5TI5YNRukUbpHz7j.jpg","original_title":"Cesare deve morire","original_language":"it"},{"id":19846,"adult":false,"title":"The Interview","video":false,"overview":"A duel between a suspected murderer and a detective pressed by people who want results. But whose skin is really wanted?","genre_ids":[80,9648,18],"media_type":"movie","popularity":0.4402,"vote_count":160,"poster_path":"/yW462Tqs3pGcYFaNAAYlsfeDpcG.jpg","release_date":"1998-03-03","vote_average":6.8,"backdrop_path":"/66uTJMtGNExKm2gZdpVmMpTFdyY.jpg","original_title":"The Interview","original_language":"en"},{"id":29971,"adult":false,"title":"Nayakan","video":false,"overview":"Velu Naicker, who witnesses the brutal murder of his father, kills a corrupt policeman and escapes to Mumbai, only to become a gangster.","genre_ids":[18,80],"media_type":"movie","popularity":0.6691,"vote_count":88,"poster_path":"/hnCKKPG5VkUiGQV0DTniyMTEZsT.jpg","release_date":"1987-10-21","vote_average":7.8,"backdrop_path":"/u4iRTMD0oJPUP2kjmH3XIEhsDKF.jpg","original_title":"நாயகன்","original_language":"ta"},{"id":46027,"adult":false,"title":"Night Falls on Manhattan","video":false,"overview":"A newly elected District attorney finds himself in the middle of a police corruption investigation that may involve his father and his partner.","genre_ids":[18,80,53],"media_type":"movie","popularity":1.3119,"vote_count":134,"poster_path":"/sjvySDgeAOqrMmm965gdkqR5AML.jpg","release_date":"1997-03-21","vote_average":6.3,"backdrop_path":"/mBMlGgX74cd6g6OE2mM7CqrHyxE.jpg","original_title":"Night Falls on Manhattan","original_language":"en"},{"id":505,"adult":false,"title":"Johnny Handsome","video":false,"overview":"A career criminal who has been deformed since birth is given a new face by a kindly doctor and paroled from prison. It appears that he has gone straight, but he is really planning his revenge on the man who killed his mentor and sent him to prison.","genre_ids":[80,18,53],"media_type":"movie","popularity":1.4793,"vote_count":283,"poster_path":"/pxcYeiBirSsmfCDIIvxtVNAnf06.jpg","release_date":"1989-09-12","vote_average":6.3,"backdrop_path":"/3rJ0EjEh1nlXY8TlA2f26jlCoom.jpg","original_title":"Johnny Handsome","original_language":"en"},{"id":37258,"adult":false,"title":"Equus","video":false,"overview":"A psychiatrist, Martin Dysart, investigates the savage blinding of six horses with a metal spike in a stable in Hampshire, England. The atrocity was committed by an unassuming seventeen-year-old stable boy named Alan Strang, the only son of an opinionated but inwardly-timid father and a genteel, religious mother. As Dysart exposes the truths behind the boy's demons, he finds himself face-to-face with his own.","genre_ids":[18,9648,53],"media_type":"movie","popularity":0.9301,"vote_count":141,"poster_path":"/tGjbZqTaq73jcOrcYD3j0trMRKG.jpg","release_date":"1977-10-16","vote_average":7,"backdrop_path":"/2Oyu9SU0V4qBxHAlzKjFqjt9OxV.jpg","original_title":"Equus","original_language":"en"},{"id":401600,"adult":false,"title":"The Whiskey Bandit","video":false,"overview":"Between 1993 and 1999, one man robbed 29 financial institutions in Budapest. Banks, post offices and even travel agencies fell victim to his crime spree. The police had no leads and no hope of finding him during his six-year stint. The only clue left behind at the crime scenes was the distinct aroma of whiskey. The media christened him the “Whiskey Bandit”. Never physically harming anyone, many began to eagerly follow his escapades through the media. A Transylvanian immigrant, who also happened to be a goalie for one of the city's largest hockey teams, named Attila Ambrus, was finally identified as the “Whiskey Bandit”. The police had finally captured him... or so they thought.","genre_ids":[28,80],"media_type":"movie","popularity":0.6316,"vote_count":100,"poster_path":"/uaL59BF0jcHsvqxx3SSho3ZLAiY.jpg","release_date":"2017-11-23","vote_average":6.505,"backdrop_path":"/qLIcg7J94StYDFqTU5tPlQifNI.jpg","original_title":"A Viszkis","original_language":"hu"},{"id":70410,"adult":false,"title":"The Public Woman","video":false,"overview":"An inexperienced young actress is invited to play a role in a film based on Dostoyevsky's 'The Possessed'. The film director, a Czech immigrant in Paris, takes over her life, and in a short time she is unable to draw the line between acting and reality. She winds up playing a real-life role posing as the dead wife of another Czech immigrant, who is manipulated by the filmmaker into commiting a political assassination.","genre_ids":[18],"media_type":"movie","popularity":1.5177,"vote_count":55,"poster_path":"/5MXaIoOKGfxanGqxgrLgv0OtV39.jpg","release_date":"1984-06-16","vote_average":6,"backdrop_path":"/t28kCBe0hngvt4ViIsnrwNBrhq8.jpg","original_title":"La Femme publique","original_language":"fr"}],"similar_content":[{"id":164,"adult":false,"title":"Breakfast at Tiffany's","video":false,"overview":"Holly Golightly is an eccentric New York City playgirl determined to marry a Brazilian millionaire. But when young writer Paul Varjak moves into her apartment building, her past threatens to get in their way.","genre_ids":[35,10749,18],"popularity":4.1802,"vote_count":4421,"poster_path":"/79xm4gXw4l7A5D0XukUOJRocFYQ.jpg","release_date":"1961-10-06","vote_average":7.626,"backdrop_path":"/jXZ2tyJl44yKvh22I6ooQwU5rFM.jpg","original_title":"Breakfast at Tiffany's","original_language":"en"},{"id":166,"adult":false,"title":"The Party","video":false,"overview":"A thirteen-year-old French girl deals with moving to a new city and school in Paris, while at the same time her parents are getting a divorce.","genre_ids":[18,10749,35],"popularity":2.4087,"vote_count":1193,"poster_path":"/usGV1Q7KWR0Uq4dOIppGZ0ba8kz.jpg","release_date":"1980-12-17","vote_average":6.6,"backdrop_path":"/An4QeEvTDmWBnDmorMo0H8xxn6w.jpg","original_title":"La Boum","original_language":"fr"},{"id":167,"adult":false,"title":"K-PAX","video":false,"overview":"Prot is a patient at a mental hospital who claims to be from a far away planet. His psychiatrist tries to help him, only to begin to doubt his own explanations.","genre_ids":[878,18,9648],"popularity":4.1785,"vote_count":2664,"poster_path":"/tafXZX0I6rso7EyoEzfygfTqxq6.jpg","release_date":"2001-10-26","vote_average":7.204,"backdrop_path":"/m9ELo5SDNZvp7CGbSVIMYBeY8wl.jpg","original_title":"K-PAX","original_language":"en"},{"id":182,"adult":false,"title":"The Good German","video":false,"overview":"An American journalist arrives in Berlin just after the end of World War Two. He becomes involved in a murder mystery surrounding a dead GI who washes up at a lakeside mansion during the Potsdam negotiations between the Allied powers. Soon his investigation connects with his search for his married pre-war German lover.","genre_ids":[18,9648,10749,53,10752],"popularity":1.279,"vote_count":339,"poster_path":"/3LjHC2CWDkzoiPehf3GViujws0.jpg","release_date":"2006-12-15","vote_average":5.805,"backdrop_path":"/vr9xAWJeIkYJWAYmIov5WNHEAf6.jpg","original_title":"The Good German","original_language":"en"},{"id":186,"adult":false,"title":"Lucky Number Slevin","video":false,"overview":"Slevin is mistakenly put in the middle of a personal war between the city’s biggest criminal bosses. Under constant watch, Slevin must try not to get killed by an infamous assassin and come up with an idea of how to get out of his current dilemma.","genre_ids":[18,53,80,9648],"popularity":4.3595,"vote_count":4360,"poster_path":"/x21s3p5wPww534nYj1cWakTcqz4.jpg","release_date":"2006-02-24","vote_average":7.476,"backdrop_path":"/ShDHEWiJ4NL6ldn4W2m3bEkIBr.jpg","original_title":"Lucky Number Slevin","original_language":"en"},{"id":205,"adult":false,"title":"Hotel Rwanda","video":false,"overview":"Inspired by true events, this film takes place in Rwanda in the 1990s when more than a million Tutsis were killed in a genocide that went mostly unnoticed by the rest of the world. Hotel owner Paul Rusesabagina houses over a thousand refuges in his hotel in attempt to save their lives.","genre_ids":[18,36,10752],"popularity":3.5582,"vote_count":3090,"poster_path":"/p3pHw85UMZPegfMZBA6dZ06yarm.jpg","release_date":"2004-12-22","vote_average":7.7,"backdrop_path":"/jkvvXaN7FPVKGlk8oj9PL0FHNtj.jpg","original_title":"Hotel Rwanda","original_language":"en"},{"id":207,"adult":false,"title":"Dead Poets Society","video":false,"overview":"At an elite, old-fashioned boarding school in New England, a passionate English teacher inspires his students to rebel against convention and seize the potential of every day, courting the disdain of the stern headmaster.","genre_ids":[18],"popularity":12.214,"vote_count":12307,"poster_path":"/l5N