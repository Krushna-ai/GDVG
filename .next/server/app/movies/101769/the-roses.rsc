me":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"link":"https://www.themoviedb.org/movie/1267905-the-roses/watch?locale=US","rent":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":6},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"flatrate":[{"logo_path":"/bxBlRPEPpMVDc4jMhSrTf2339DW.jpg","provider_id":15,"provider_name":"Hulu","display_priority":8}]},"UY":{"link":"https://www.themoviedb.org/movie/1267905-the-roses/watch?locale=UY","flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":25}]},"VE":{"link":"https://www.themoviedb.org/movie/1267905-the-roses/watch?locale=VE","flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":1}]},"ZA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}],"link":"https://www.themoviedb.org/movie/1267905-the-roses/watch?locale=ZA","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}]}}},"wikidata_id":"Q126810973","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-11T22:26:34.684307+00:00","region":null,"main_poster":null,"images":null,"enriched_at":"2026-04-21T07:10:00.554+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":105,"tagline":"This marriage ain't big enough for the both of them.","homepage":"https://www.searchlightpictures.com/the-roses","overview":"Life seems easy for picture-perfect couple Ivy and Theo: successful careers, a loving marriage, great kids. But beneath the façade of their supposed ideal life, a storm is brewing – as Theo's career nosedives while Ivy's own ambitions take off, a tinderbox of fierce competition and hidden resentment ignites."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Супруги Роуз","runtime":0,"tagline":"«В любви и на войне все вредства хороши»","homepage":"","overview":"Образцовый брак и успешная карьера Айви и Тео лишь внешняя оболочка. Когда карьера Тео рушится, а успех Айви, наоборот, стремительно растёт, между ними вспыхивает ожесточённое соперничество, обнажающее глубокие обиды."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Os Roses: Até Que a Morte Os Separe","runtime":106,"tagline":"Tudo é válido quando o amor é uma guerra.","homepage":"https://tickets.disney.com.br/os-roses-ate-que-a-morte-os-separe","overview":"A vida parece fácil para o casal perfeito Ivy e Theo: carreiras de sucesso, um casamento repleto de amor, filhos maravilhosos... mas por trás da fachada de sua suposta vida ideal, uma tempestade está se formando. Enquanto a carreira de Theo despenca, as ambições de Ivy decolam, e assim, o pavio de uma bomba de competição feroz e ressentimentos escondidos se acende."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"La Guerre des Rose","runtime":105,"tagline":"Tout est juste quand l'amour est une guerre.","homepage":"","overview":"Ivy et Theo forment un couple parfait à qui tout réussit : des carrières couronnées de succès, un mariage épanoui, des enfants formidables... Mais sous les apparences de cette vie idéale, une tempête se prépare… Alors que la carrière de Theo s’écroule et que celle d’Ivy décolle, leurs ressentiments et leur rivalité jusque-là étouffés vont bientôt exploser."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"더 로즈: 완벽한 이혼","runtime":121,"tagline":"완벽한 이혼을 위하여, 치얼스!","homepage":"","overview":"모두가 부러워할 만큼 완벽해 보이는 부부 테오와 아이비. 하지만 잘나가던 건축가 테오는 커리어에 급브레이크가 걸리고, 반대로 셰프 아이비는 예상치 못한 성공을 거두며 두 사람 사이엔 점점 미묘한 틈이 생긴다. 이상적인 부부라는 이미지 뒤로는 커져가는 경쟁심과 긁힌 자존심, 꾹꾹 눌러온 감정들이 결국 터져버리고, 두 사람은 마침내 피할 수 없는 ‘이혼’이라는 위기를 마주하게 되는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Los Rose","runtime":0,"tagline":"En este matrimonio no hay espacio para los dos","homepage":"","overview":"La vida parece fácil para la pareja perfecta que forman Ivy y Theo: carreras de éxito, un matrimonio feliz y unos hijos estupendos. Pero detrás de la fachada de su supuesta vida ideal, se avecina una tormenta: la carrera de Theo se desploma mientras que las ambiciones de Ivy despegan, lo que desencadena una caja de Pandora de competitividad y resentimiento ocultos."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"I Roses","runtime":0,"tagline":"In questo matrimonio non c'è spazio per entrambi","homepage":"","overview":"La vita sembra facile per la coppia apparentemente perfetta Theo (Cumberbatch) e Ivy (Colman): carriere di successo, figli fantastici, una vita sessuale invidiabile. Ma sotto la facciata della famiglia perfetta si celano competizione e risentimenti, che si accendono quando i sogni professionali di Theo si infrangono."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Państwo Rose","runtime":0,"tagline":"","homepage":"","overview":"Życie pary jak z obrazka, Ivy i Theo, wydaje się łatwe: udane kariery, kochające małżeństwo, wspaniałe dzieci. Ale pod fasadą ich rzekomo idealnego życia zbiera się burza – gdy kariera Theo chyli się ku upadkowi, a ambicje Ivy rosną w siłę, rozpala się iskra zaciekłej rywalizacji i ukrytej urazy."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Die Rosenschlacht","runtime":105,"tagline":"Im Krieg und in der Liebe ist alles erlaubt.","homepage":"","overview":"Das Leben scheint einfach zu sein für das Bilderbuch-Paar Ivy und Theo: erfolgreiche Karrieren, eine liebevolle Ehe, tolle Kinder. Doch hinter der Fassade ihres vermeintlich idealen Lebens braut sich ein Sturm zusammen – als Theos Karriere einbricht, während Ivys eigene Ambitionen Fahrt aufnehmen, entzündet sich ein Pulverfass aus erbittertem Wettbewerb und verstecktem Groll."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Los Roses","runtime":0,"tagline":"En este matrimonio no hay espacio para los dos.","homepage":"","overview":"La vida parece fácil para la pareja ideal formada por Ivy y por Theo: carreras exitosas, un matrimonio feliz e hijos maravillosos. Pero bajo la fachada de su supuesta vida idílica, se avecina un revés que lo cambiará todo. Mientras la carrera de Theo se desploma, las ambiciones de Ivy despegan, esto hará encender una brecha de feroz competencia y un resentimiento oculto entre ellos."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Роузи","runtime":0,"tagline":"Цей шлюб затісний для них обох","homepage":"","overview":"На перший погляд, життя Айві та Тео — ідеальна картинка: успішна кар’єра, щасливий шлюб, чудові діти. Та за фасадом цієї бездоганної родинної ідилії зріє буря. У той час як професійне життя Тео стрімко йде на спад, амбіції Айві лише набирають обертів. Те, що здавалося партнерством, поступово перетворюється на арену мовчазного протистояння, де накопичені образи, ревнощі та суперництво стають вибухонебезпечною сумішшю."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Rat Roseovih","runtime":105,"tagline":"U ljubavi i ratu sve je dopušteno.","homepage":"","overview":"Život se čini lakim za savršeni par Ivy i Theo: uspješne karijere, brak pun ljubavi, sjajna djeca. Ali ispod njihovog navodno idealnog života, sprema se oluja – dok Theova karijera pada, a Ivyine vlastite ambicije uzlaze, rasplamsava se žarište žestoke konkurencije i skrivenog ogorčenja."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"ローズ家～崖っぷちの夫婦～","runtime":0,"tagline":"","homepage":"","overview":"絵に描いたような完璧なカップル、アイヴィとテオは、順風満帆な人生を送っているように見えた。輝かしいキャリア、愛に満ちた結婚生活、優秀な子供たち。だが、その裏側では家庭内戦争が始まろうとしていた。テオのキャリアが急降下する中、アイヴィは野心を露わにする。幸せな夫婦に秘められた競争心と不満が爆発する痛快ブラック・コメディ。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Hoa Hồng Có Gai","runtime":0,"tagline":"","homepage":"","overview":"Cuộc sống của Ivy và Theo tưởng chừng hoàn hảo: sự nghiệp thành công, hôn nhân hạnh phúc, con cái ngoan ngoãn. Nhưng đằng sau lớp vỏ của một gia đình lý tưởng ấy là cơn bão ngầm đang dần hình thành — khi sự nghiệp của Theo tuột dốc trong khi tham vọng của Ivy thăng hoa, thổi bùng lên ngọn lửa ganh đua và oán giận âm ỉ có thể"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"רוז נגד רוז","runtime":0,"tagline":"הנישואים האלה גדולים על שניהם.","homepage":"","overview":"החיים נראים פשוטים עבור הזוג המושלם לכאורה, אייבי ותיאו- קריירות מצליחות, נישואים אוהבים וילדים נהדרים.  אבל מתחת לחזות של חיי המשפחה האידיאליים, סדקים מתחילים להופיע כשהקריירה של תיאו מתרסקת באותה העת שחלומותיה של אייבי מתחילים להתגשם.  בעקבות כך, ניצתת מתיחות של תחרות עזה וטינה חבויה בין השניים."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"Täydellisen pariskunnan Ivyn ja Theon elämä vaikuttaa huolettomalta: on menestyksekkäät urat, rakkaudentäyteinen avioliitto ja mahtavat lapset. Mutta heidän päällepäin idyllisten kulissiensa takana muhii myrsky – kun Theon ura ajautuu syöksykierteeseen saman aikaan kun Ivyn unelmat lähtevät lentoon, armottoman kilpailun ja peitellyn kaunan alle kätkeytynyt ruutitynnyri räjähtää."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"กุ-หลาบ","runtime":0,"tagline":"","homepage":"","overview":"ชีวิตเหมือนจะเป็นเรื่องง่ายสำหรับคู่รักที่แสนจะสมบูรณ์แบบอย่าง ไอวี่ และ ธีโอ ทั้งความสำเร็จในเรื่องของอาชีพ, ชีวิตแต่งงานที่เต็มไปด้วยความรัก และลูก ๆ ที่แสนจะยอดเยี่ยม แต่ภายใต้โฉมหน้าชีวิตในอุดมคติของพวกเขานั้น พายุลูกใหญ่กำลังก่อตัวขึ้นอยู่ ในขณะที่อาชีพของ ธีโอ เริ่มดิ่งลงไป ความทะเยอทะยานของ ไอวี่ ก็พุ่งทะยานขึ้นไป และเชื้อไฟของการแข่งขันอันร้อนแร้งและความขุ่นเคืองใจที่เก็บซ้อนเอาไว้ก็ปะทุขึ้นมา"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Güller","runtime":0,"tagline":"Bu evlilik ikisine yetecek kadar büyük değil.","homepage":"","overview":"Ivy ve Theo, başarılı kariyerleri, mutlu evlilikleri ve harika çocuklarıyla ideal bir hayat sürüyor gibi görünmektedirler. Ancak Theo'nun kariyeri düşüşe geçerken Ivy'nin kendi hedefleri yükselişe geçince bu kusursuz görüntünün altında bir fırtına patlak veriyor. Kusursuz görünen çiftin çatırdayan ilişkisinde gizli rekabetler, bastırılmış öfkeler ve komik olduğu kadar keskin çatışmalar gün yüzüne çıkmaya başlar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Les Rose","runtime":105,"tagline":"Ce marriage n'est pas assez grand pour eux deux","homepage":"https://www.searchlightpicturesfilm.ca/lesrose/home/","overview":"Ivy et Theo forment un couple parfait à qui tout réussit : des carrières couronnées de succès, un mariage épanoui, des enfants formidables... Mais sous les apparences de cette vie idéale, une tempête se prépare… Alors que la carrière de Theo s’écroule et que celle d’Ivy décolle, leurs ressentiments et leur rivalité jusque-là étouffés vont bientôt exploser."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Roseovci","runtime":0,"tagline":"Toto manželstvo nie je dosť veľké pre oboch","homepage":"","overview":"Život dokonalého páru Ivy a Thea sa zdá byť úplne úžasný: úspešná kariéra, milujúce manželstvo, skvelé deti. Ale pod fasádou ich údajne ideálneho života sa schyľuje k búrke. Ako Theova kariéra upadá, zatiaľ čo Ivyine vlastné ambície sa rozbiehajú, v ich domove vzplanie oheň, ostrá konkurencia a skrytá zášť."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"玫瑰夫大戰玫瑰妻","runtime":105,"tagline":"","homepage":"","overview":"《非常外父生擒霍老爺》賣座導演 X《可憐的東西》金像級編劇幽默炮製，聯手金像級男神《奇異博士》班尼狄甘巴貝治尖鋭火拼《爭寵》金像影后奧利花高雯，擦出至強爆笑火花！艾菲（奧利花高雯 飾）與菲奧（班尼狄甘巴貝治 飾）是眾人心目中的「模範夫妻」，一家四口家庭生活看似甜甜蜜蜜，但一場令菲奧事業插水的意外，竟卻是艾菲事業起飛的契機！這對好勝夫妻分歧癒多，怨念積累癒深，「黴爆」夫大鬥「玫瑰」妻，相愛相殺之戰蓄勢待發！婚姻殿堂終須變成唇槍舌劍的戰場，最後搞到變質退場？愛過、忍過之後，唔通仲要死都唔放過對方？！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Vojna zakoncev Rose","runtime":0,"tagline":"Vse je dovoljeno, ko je ljubezen vojna.","homepage":"","overview":"Ivy in Theo imata vse - uspešni karieri, čudovite otroke, urejen dom in odnos ki navzven deluje brezhibno. A pod bleščečo površino se skriva tihi, a vse bolj silovit konflikt. Ko se Theova kariera začne rušiti medtem ko Ivy strmo napreduje, se med zakoncema začnejo pojavljati drobne razpoke, ki hitro prerastejo v odprto vojno. Na videz banalne nesoglasja o vzgoji, ambicijah in preteklih žrtvah prerastejo v duhovito temačno in čustveno intenzivno razgradnjo nekdaj ljubečega odnosa."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"玫瑰","runtime":105,"tagline":"","homepage":"","overview":"艾薇（奥利维娅·科尔曼 Olivia Colman 饰）和西奥（本尼迪克特·康伯巴奇 Benedict Cumberbatch 饰）是一对表面幸福、实则危机四伏的中产夫妻。 他们有钱、有貌、有小孩，人生完美无死角……直到现实开始崩坏。 他失势、她崛起；爱情不再对等，成就变成武器，婚姻成了战场。 当爱不再是羁绊，而是竞争，家不再安全而是战场，你该如何处理枕边人。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"All's fair when love is war","homepage":"","overview":"Livet verkar enkelt för det perfekta paret Ivy och Theo: framgångsrika karriärer, ett kärleksfullt äktenskap och fantastiska barn. Men bakom den perfekta fasaden döljer sig en begynnande storm. När Theos karriär störtdyker, börjar Ivys ambitioner att ta fart, vilket blir bränsle till en tärande konkurrens och underliggande bitterhet mellan dem."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Rózsák háborúja","runtime":0,"tagline":"","homepage":"","overview":"A történet középpontjában Ivy (Olivia Colman) és Theo Rose (Benedict Cumberbatch) állnak, akik látszólag tökéletes házasságban élnek: sikeres karrier, boldog család és irigylésre méltó élet. Azonban a felszín alatt feszültségek és elfojtott sérelmek húzódnak. Amikor Theo elveszíti állását, miközben Ivy karrierje szárnyalni kezd, a hatalmi egyensúly megbomlik, és a házaspár kapcsolata gyorsan romlásnak indul. A kezdeti nézeteltérések hamarosan pszichológiai hadviselésbe és érzelmi manipulációba torkollnak, amely során mindketten próbálják aláásni a másikat.  (Csillag Lajos)"},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Войната на Семейство Роуз","runtime":0,"tagline":"","homepage":"","overview":"На пръв поглед животът на Айви и Тео изглежда съвършен – успешни кариери, щастлив брак, прекрасни деца. Но зад тази привидна идилия се крие буря – докато кариерата на Тео се разпада, а амбициите на Айви растат, между тях се разгаря опасна смесица от конкуренция и натрупани обиди."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"Het leven van het perfecte koppel Ivy en Theo lijkt eenvoudig: een succesvolle carrière, een liefdevol huwelijk, geweldige kinderen. Onder de façade van hun zogenaamde ideale leven broeit echter een storm. Wanneer Theo's carrière keldert terwijl Ivy's eigen ambities een hoge vlucht nemen, ontstaat er een broeihaard van hevige concurrentie en verborgen wrok."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Rouzų šeimos karas","runtime":105,"tagline":"","homepage":"","overview":"Ivy Rose ir Teo Rose atrodo gyvenantys tobulą gyvenimą: sėkmingos karjeros, graži šeima, meilė vienas kitam. Tačiau po šiuo fasadu ima kauptis įtampa. Teo netenka darbo, o Ivy profesinė sėkmė ima kilti aukštyn. Tai sukelia tylų, bet pavojingą šeimos žemės drebėjimą – pavydas, nepasitenkinimas ir prislopinta neapykanta įžiebia konfliktą, kuris greitai perauga į atvirą karo zoną."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"Familia Rose","runtime":0,"tagline":"","homepage":"","overview":"Viața pare ușoară pentru Ivy și Theo care formează cuplul perfect: cariere de succes, o căsnicie iubitoare, copii grozavi. Însă, în culisele acestei vieți aparent ideale, are loc o furtună. Această comedie neagră și ironică prezintă concurența acerbă și resentimentele ascunse dintre cei doi într-un moment când cariera lui Theo se prăbușește iar ambițiile lui Ivy prind elan."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Rouzu ģimene","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Ρόουζ εναντίον Ρόουζ","runtime":0,"tagline":"","homepage":"","overview":"Η ζωή κυλάει αβίαστα για το φαινομενικά τέλειο ζευγάρι: Η Ivy και ο Theo έχουν επιτυχημένες καριέρες, έναν ζηλευτό γάμο και δύο φανταστικά παιδιά. Πίσω από την υποτιθέμενα άψογη ζωή, ο ουρανός φορτώνει σύννεφα και ετοιμάζεται για καταιγίδα, όταν η καριέρα του Theo καταποντίζεται, ενώ οι φιλοδοξίες της Ivy εκτοξεύονται. Ένα ναρκοπέδιο ανελέητου ανταγωνισμού και καταπιεσμένης μνησικακίας απλώνεται ανάμεσά τους."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"沒好婚姻","runtime":0,"tagline":"這次真的要讓你，愛到死去活來","homepage":"","overview":"一對看似愛情事業兩得意、人人稱羨的典範夫妻，正當一切看似「美好婚姻」的伴侶關係，命運卻來一個大反轉，讓原本意氣風發的丈夫「西奧」（班尼迪克康柏拜區 飾）事業碰上重大危機，家中的經濟開銷轉由原本為全職主婦的老婆「艾薇」（奧莉薇亞柯爾曼 飾）一肩扛起，沒想到艾薇的事業從此一飛衝天，而這也導致夫妻間開始產生嫌隙，婚姻也響起了警報，原形畢露的他們該如何圓場？抑或只能你死我活別無他法？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"როუზი როუზის წინააღმდეგ","runtime":0,"tagline":"","homepage":"","overview":"აივისა და თეოს იდეალური ქორწინება და წარმატებული კარიერა მხოლოდ ზედაპირულია. როდესაც თეოს კარიერა ინგრევა და აივის წარმატება იზრდება, მათ შორის მწარე მეტოქეობა იფეთქებს."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"عائلة روز","runtime":105,"tagline":"","homepage":"","overview":"تبدو الحياة سهلة للزوجين المثاليين \"آيفي\" و\"ثيو\": مسيرتان مهنيتان ناجحتان وزواج سعيد وأطفال رائعون. لكن خلف واجهة حياتهما التي يُفترض أنها مثالية، يلوح في الأفق صراع عاصف. خلال انهيار حياة \"ثيو\" المهنية بينما تتحقق طموحات \"آيفي\"، تشتعل نيران المنافسة الشرسة والاستياء المكبوت."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"Livet synes nemt for det billedskønne par Ivy og Theo: succesfulde karrierer, et kærligt ægteskab, fantastiske børn. Men under facaden af ​​deres formodede ideelle liv brygger en storm op – mens Theos karriere styrtdykker, mens Ivys egne ambitioner tager fart, blusser en fyrtøj af hård konkurrence og skjult bitterhed op."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Roseovi","runtime":0,"tagline":"","homepage":"","overview":"Život dokonalého páru Ivy a Thea se zdá být naprosto úžasným: úspěšná kariéra, milující manželství, skvělé děti. Ale pod fasádou jejich údajně ideálního života se schyluje k bouři. Jak Theova kariéra upadá, zatímco Ivyiny vlastní ambice se rozjíždějí, vzplane v jejich domově ohniště ostré konkurence a skryté zášti."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"عائلة روز","runtime":105,"tagline":"","homepage":"","overview":"تبدو الحياة سهلة للزوجين المثاليين \"آيفي\" و\"ثيو\": مسيرتان مهنيتان ناجحتان وزواج سعيد وأطفال رائعون. لكن خلف واجهة حياتهما التي يُفترض أنها مثالية، يلوح في الأفق صراع عاصف. خلال انهيار حياة \"ثيو\" المهنية بينما تتحقق طموحات \"آيفي\"، تشتعل نيران المنافسة الشرسة والاستياء المكبوت."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"玫瑰夫妇","runtime":0,"tagline":"","homepage":"","overview":"对于艾薇和西奥，这一对堪称完美的夫妻来说，生活似乎一帆风顺：事业成功、婚姻幸福、孩子优秀。但在他们看似理想的生活表象之下，一场风暴正在酝酿。当西奥的事业急转直下，而艾薇的抱负却开始腾飞时，在这部精彩辛辣的黑色喜剧中，激烈的竞争和隐藏的怨恨像火药桶一样被点燃。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Livet virker enkelt for det perfekte paret Ivy og Theo: vellykkede karrierer, et kjærlighetsfylt ekteskap, flotte barn. Men bak fasaden til deres tilsynelatende perfekte liv brygger det opp til storm. Idet Theos karriere får seg en støyt og Ivys egne ambisjoner oppfylles, antennes en kruttønne av brutal konkurranse og skjult nag i denne herlig beske og mørke komedien."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Um Casal (Im)perfeito","runtime":0,"tagline":"Vale tudo quando o amor está em guerra.","homepage":"","overview":"A vida parece fácil para Ivy e Theo, um casal ideal: carreiras de sucesso, um casamento feliz, filhos incríveis. Mas sob a fachada da sua suposta perfeição, fervilha uma tempestade. Quando a carreira de Theo desaba e as ambições de Ivy disparam, uma competição feroz e ressentimentos ocultos explodem nesta comédia sombria e deliciosamente sarcástica."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Роузови","runtime":0,"tagline":"","homepage":"","overview":"Живот делује лако за савршен пар, Ајви и Теа: успешне каријере, љубаван брак, сјајна деца. Али испод фасаде њиховог наводно идеалног живота, спрема се олуја – док Теова каријера нагло пропада, а Ајвине амбиције узлазе, распламсава се жар жестоке конкуренције и скривеног негодовања."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"رزها","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"}],"reviews_tmdb":[{"id":"68ad03179319c60dab5488cd","url":"https://www.themoviedb.org/review/68ad03179319c60dab5488cd","author":"Brent Marchant","content":"$11","created_at":"2025-08-26T00:43:03.850Z","updated_at":"2025-08-26T08:09:34.078Z","author_details":{"name":"Brent Marchant","rating":8,"username":"Brent_Marchant","avatar_path":null}},{"id":"68b9ae2f0338726d8c1f4189","url":"https://www.themoviedb.org/review/68b9ae2f0338726d8c1f4189","author":"CinemaSerf","content":"$12","created_at":"2025-09-04T15:20:15.508Z","updated_at":"2025-09-04T15:23:42.385Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":1205648,"adult":false,"title":"No One Will Know","video":false,"overview":"All begins in a rundown bar outside of Paris where a regular man realizes he has a winning lottery ticket only to be shot in a crime that needs to be quickly covered up.","genre_ids":[18,53],"media_type":"movie","popularity":1.161,"vote_count":35,"poster_path":"/dusHHiyU3UV4M5WZiUwecudCn25.jpg","release_date":"2025-08-27","vote_average":6.1,"backdrop_path":"/az1Okg0lODJSmGbk0nRxu2Ut0ol.jpg","original_title":"Le Roi Soleil","original_language":"fr"},{"id":392124,"adult":false,"title":"Right Here Right Now","video":false,"overview":"Nora is a bright young professional whose new job at a financial firm turns out to be a trial by fire when she learns that her bosses share a tumultuous history with her prickly mathematician father. Meanwhile, an interoffice romance with a competitive colleague leads to even more complications, leaving Nora to navigate a minefield of delicate relationships as she climbs the corporate ladder.","genre_ids":[18],"media_type":"movie","popularity":0.337,"vote_count":50,"poster_path":"/7huMqd0QJRrCBB3e22tYxkPMAR5.jpg","release_date":"2016-06-22","vote_average":5.1,"backdrop_path":"/zxBFZctwFvcfZAhHEyWiXSlUP7x.jpg","original_title":"Tout de suite maintenant","original_language":"fr"},{"id":665783,"adult":false,"title":"Dry Wind","video":false,"overview":"The area around Catalan in Brazil’s state of Goiás is dry, very dry. Sandro’s life here is somewhat monotonous. He works in a fertiliser factory, goes swimming and spends his evenings doing jigsaw puzzles of landscapes. When Maicon, a man straight out of a Tom of Finland illustration, shows up in their small town and flirts with Ricardo, Sandro’s burgeoning feelings of jealousy set a change in motion.","genre_ids":[18,14],"media_type":"movie","popularity":0.8097,"vote_count":31,"poster_path":"/oVp8VwxXVlq2z62PR5sqv4YkGHG.jpg","release_date":"2020-02-26","vote_average":6.4,"backdrop_path":"/4k5b00TYT0qz8c51BohmsJF83Lf.jpg","original_title":"Vento Seco","original_language":"pt"},{"id":1178602,"adult":false,"title":"Mirrors No. 3","video":false,"overview":"On a weekend trip to the countryside, Laura miraculously survives a car crash. Physically unhurt but deeply shaken, she is taken in by a local woman who witnessed the accident and now cares for Laura with motherly devotion. When her husband and adult son also give up their initial resistance to Laura's presence, the four of them slowly build up some family-like routine. But soon they can no longer ignore their past...","genre_ids":[18],"media_type":"movie","popularity":1.5882,"vote_count":26,"poster_path":"/eGIcN5rKzULEQAOQuNImOe2hK64.jpg","release_date":"2025-08-27","vote_average":6.6,"backdrop_path":"/d6LL0TqfX7BTR8OQ1YK8cxrou4c.jpg","original_title":"Miroirs No. 3","original_language":"de"},{"id":1144443,"adult":false,"title":"Follow My Voice","video":false,"overview":"After a health crisis that keeps her home, Klara does nothing but listen to her favorite radio show, Follow My Voice. But one day she wonders: is it possible to fall in love with someone she has only heard on the radio but never met? Could she really have feelings for Kang, the radio show host whose voice she has only heard once, and will she overcome her fears to step out into the world again?","genre_ids":[10749,18],"media_type":"movie","popularity":3.3647,"vote_count":52,"poster_path":"/kBd17L811S97JESH9ma1pPMO0o0.jpg","release_date":"2025-09-12","vote_average":7.365,"backdrop_path":"/vcrwsAYYYmVLX0c7iFqlV1pZRdT.jpg","original_title":"Sigue mi voz","original_language":"es"},{"id":1197122,"adult":false,"title":"Prime Rush","video":false,"overview":"The week after the French elections, the President must appoint his prime minister. In exchange for a higher position, ambitious young parliamentary attaché Nino is charged with persuading his longestranged father, a reclusive senator, to accept the post. But Lionel Perrin isn’t the only candidate for the coveted position, and in the race for power absolutely nothing is off-limits… Nino embarks on a high stakes adventure risking everything, his love life and political ambitions alike.","genre_ids":[35],"media_type":"movie","popularity":0.6038,"vote_count":11,"poster_path":"/lo3jHhGmOEZk7avUX1iZuRIfXAI.jpg","release_date":"2025-09-03","vote_average":5.3,"backdrop_path":"/vXpeiTvosY5kQIIrIGUTlbqYExM.jpg","original_title":"Fils de","original_language":"fr"},{"id":1294706,"adult":false,"title":"That Summer in Paris","video":false,"overview":"Paris, the 2024 Olympic Games. Blandine (30) arrives from Normandy to watch the swimming competitions. Disorientated by the hustle and bustle of the city where nothing seems to go her way, she navigates the chaos of Paris and an unexpected reunion.","genre_ids":[35,18],"media_type":"movie","popularity":2.0421,"vote_count":14,"poster_path":"/1z3jgsuyyudTPNvZMftK7FeHSDK.jpg","release_date":"2025-06-11","vote_average":6.179,"backdrop_path":"/iRAQwlMZ5L2TfQ4kx0YUg69VEdW.jpg","original_title":"Le Rendez-vous de l'été","original_language":"fr"},{"id":565085,"adult":false,"title":"The Broken Mirror","video":false,"overview":"Anne lives with her husband in Belgium where she works as a restorer of paintings. When she becomes pregnant, she finds herself remembering a picture she did some time ago and of which she has no memory, no recollection of what happened to it. It becomes her goal to discover and clarify the mystery behind this painting, at the same time she notices that a strange man is following all of her moves.","genre_ids":[18],"media_type":"movie","popularity":0.4233,"vote_count":7,"poster_path":"/jV3nDU5cYPfCWNzoQdSPPeil6hm.jpg","release_date":"1975-04-02","vote_average":6.857,"backdrop_path":"/vYjXEw9MVoQ6YOdhbKoQpKfAXIp.jpg","original_title":"Trompe l'œil","original_language":"fr"},{"id":71628,"adult":false,"title":"Roadkill","video":false,"overview":"Six young friends on a road trip in Ireland run afoul of gypsies who curse them for accidentally running down an old woman. The curse takes the form of a terrifying flying beast that tries killing them all.","genre_ids":[27,53,10770,28],"media_type":"movie","popularity":0.5918,"vote_count":69,"poster_path":"/6ZQUotw157KJDRLRKuxa42UYSqz.jpg","release_date":"2011-04-23","vote_average":5.623,"backdrop_path":"/F04DzuM2R72foaCUBnK7H8eYfH.jpg","original_title":"Roadkill","original_language":"en"},{"id":994052,"adult":false,"title":"Romance in Style","video":false,"overview":"Ella's unique designs inspire publishing mogul Derek to include plussized fashion in his magazine. It's not long before Derek realizes that Ella's influence reaches far beyond the catwalk.","genre_ids":[10770,35,10749],"media_type":"movie","popularity":0.4011,"vote_count":53,"poster_path":"/gYcVRws4Hu5B36ji7BheKDnSbfP.jpg","release_date":"2022-08-13","vote_average":6.462,"backdrop_path":"/aqzLTnllq30v17hTK7EeJ3FDQNH.jpg","original_title":"Romance in Style","original_language":"en"},{"id":1038392,"adult":false,"title":"The Conjuring: Last Rites","video":false,"overview":"Paranormal investigators Ed and Lorraine Warren take on one last terrifying case involving mysterious entities they must confront.","genre_ids":[27],"media_type":"movie","popularity":20.3643,"vote_count":1650,"poster_path":"/byWgphT74ClOVa8EOGzYDkl8DVL.jpg","release_date":"2025-09-03","vote_average":6.905,"backdrop_path":"/tcBX2dtkNozZ0uDLVaxXrE6rqyN.jpg","original_title":"The Conjuring: Last Rites","original_language":"en"},{"id":604079,"adult":false,"title":"The Long Walk","video":false,"overview":"In a dystopian near-future America, fifty teenage boys take part in a deadly annual walking contest, forced to maintain a minimum pace or be executed, until only one survivor remains.","genre_ids":[878,27,53],"media_type":"movie","popularity":13.5431,"vote_count":1168,"poster_path":"/wobVTa99eW0ht6c1rNNzLkazPtR.jpg","release_date":"2025-09-10","vote_average":6.949,"backdrop_path":"/o0Id62Wx3gjYMHunJV96WAOspN.jpg","original_title":"The Long Walk","original_language":"en"},{"id":4539,"adult":false,"title":"Hearts of Darkness: A Filmmaker's Apocalypse","video":false,"overview":"A chronicle of the production problems — including bad weather, actors' health, war near the filming locations, and more — which plagued the filming of Apocalypse Now, increasing costs and nearly destroying the life and career of Francis Ford Coppola.","genre_ids":[99],"media_type":"movie","popularity":1.1312,"vote_count":401,"poster_path":"/nVMCtL3r2nj4fySihDDvamaVkfx.jpg","release_date":"1991-11-27","vote_average":7.9,"backdrop_path":"/zmdxPaKFMu1dpBw78jsCMbpOxJo.jpg","original_title":"Hearts of Darkness: A Filmmaker's Apocalypse","original_language":"en"},{"id":1168806,"adult":false,"title":"Romeo Is Juliet","video":false,"overview":"After her audition as Juliet fails to impress, a young actress determined to act in the latest production of Shakespeare's play crossdresses and is unexpectedly chosen for the role of Romeo.","genre_ids":[35],"media_type":"movie","popularity":0.3209,"vote_count":80,"poster_path":"/gvGxnKFxPkJa0Y6reurTEhFiIby.jpg","release_date":"2024-02-14","vote_average":6.525,"backdrop_path":"/nnhFC47degHI9KhphapciWmzwKA.jpg","original_title":"Romeo è Giulietta","original_language":"it"},{"id":1245993,"adult":false,"title":"Caught Stealing","video":false,"overview":"Burned-out ex-baseball player Hank Thompson unexpectedly finds himself embroiled in a dangerous struggle for survival amidst the criminal underbelly of late 1990s New York City, forced to navigate a treacherous underworld he never imagined.","genre_ids":[80,53,35],"media_type":"movie","popularity":6.9881,"vote_count":765,"poster_path":"/cvda8s5J8YaHjTyEyXQpvD6f3iV.jpg","release_date":"2025-08-26","vote_average":6.913,"backdrop_path":"/41043LV7mfluH8iXEUPVseCDAv5.jpg","original_title":"Caught Stealing","original_language":"en"},{"id":67900,"adult":false,"title":"Scooby-Doo! Legend of the Phantosaur","video":false,"overview":"A relaxing spa getaway evolves into a prehistoric panic when Scooby-Doo and the gang uncover the horrible Phantosaur, an ancient legend come to life to protect hidden treasures buried in secret desert caves. But this scare-a-saurus doesn’t stand a chance with Shaggy around, after he finds his inner hero with the help of new-age hypnosis. Like, it makes him more brave and less hungry!","genre_ids":[16,9648,35,10751],"media_type":"movie","popul