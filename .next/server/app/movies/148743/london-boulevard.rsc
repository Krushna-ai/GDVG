riority":29}]},"SV":{"link":"https://www.themoviedb.org/movie/48838-london-boulevard/watch?locale=SV","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1},{"logo_path":"/h5DcR0J2EESLitnhR8xLG1QymTE.jpg","provider_id":531,"provider_name":"Paramount Plus","display_priority":24}]},"TR":{"buy":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":5}],"link":"https://www.themoviedb.org/movie/48838-london-boulevard/watch?locale=TR","rent":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":5}]},"UA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}],"link":"https://www.themoviedb.org/movie/48838-london-boulevard/watch?locale=UA","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}]},"US":{"buy":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":6},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"link":"https://www.themoviedb.org/movie/48838-london-boulevard/watch?locale=US","rent":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":6},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}]},"UY":{"link":"https://www.themoviedb.org/movie/48838-london-boulevard/watch?locale=UY","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1},{"logo_path":"/h5DcR0J2EESLitnhR8xLG1QymTE.jpg","provider_id":531,"provider_name":"Paramount Plus","display_priority":2}]},"VE":{"link":"https://www.themoviedb.org/movie/48838-london-boulevard/watch?locale=VE","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":2},{"logo_path":"/h5DcR0J2EESLitnhR8xLG1QymTE.jpg","provider_id":531,"provider_name":"Paramount Plus","display_priority":6}]}}},"wikidata_id":"Q164933","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-26T01:41:08.886186+00:00","region":null,"main_poster":null,"images":{"logos":[{"width":790,"height":224,"file_path":"/i9QtEFSXizRbhRgAjzjrF8IMlnz.png","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":3.527,"vote_average":3.334}],"posters":[{"width":800,"height":1200,"file_path":"/iFH4jIYubQeB2x6pFj6SYHdK74I.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":1000,"height":1500,"file_path":"/eL8j1FDljJNhkzW2YvBFvisc0GS.jpg","iso_639_1":"rn","iso_3166_1":"RN","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":1000,"height":1500,"file_path":"/sApl5kzekTYqD5Bn5hpi8zvJNET.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":1000,"height":1500,"file_p