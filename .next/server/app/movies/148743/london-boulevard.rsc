00,"file_path":"/rBkJpTc4boVl5sT59nEbtub5cJ3.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":713,"height":1000,"file_path":"/lBKXcEoSGxt8bznUgaAsN1b03lu.jpg","iso_639_1":"ko","iso_3166_1":"KR","vote_count":0,"aspect_ratio":0.713,"vote_average":0},{"width":1431,"height":2010,"file_path":"/giHPb0eVm8G2jJLspFa0jnki5a1.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.712,"vote_average":0},{"width":2000,"height":2857,"file_path":"/c0clAynoPHFaWHYOcBuGVA502ds.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":1000,"height":1440,"file_path":"/pyAWuHt1XAHITWJOWKFr10g6Od0.jpg","iso_639_1":"pl","iso_3166_1":"PL","vote_count":0,"aspect_ratio":0.694,"vote_average":0},{"width":2000,"height":2875,"file_path":"/saY4DJDfOJJc3MfkW9tUIuKgSrz.jpg","iso_639_1":"bg","iso_3166_1":"BG","vote_count":0,"aspect_ratio":0.696,"vote_average":0},{"width":506,"height":750,"file_path":"/bMzgX8aMRasZ79y03bwsJgXtTxx.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.675,"vote_average":0},{"width":960,"height":1440,"file_path":"/zIFPjKkszcgLACC75YfL68dfe9D.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/ogjKFg8EbXTH4xlXN42KElQuPVB.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/kuxLjp8ufk066O5YyNU116iVku7.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/sEcuz0c0SAON0MZnUasBu4Aqrgi.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/xEriXszDJ5N4t7MAADNGZvhd4rk.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/6Pv6InKaBYyJXLH9Qvc5MQ1nsFa.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/nSxm7hVo4MMWSQclJ9e0DuytkK4.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/jJlMD4ye2dQaHo4qAaN5yKYnSS4.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/j5iwlSL9FgHZCIXKzww5j6sFGz0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/ecc9qlH09Py4Uqk8inbpJTMYeuF.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/dclqFdfXRLX3Eoz4zPbP3Rkphta.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/59aOTZlzg8Ta7WXA7NZm1HLU98Q.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T04:41:04.772+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":103,"tagline":"Not every criminal wants to be one.","homepage":"http://www.ifcfilms.com/films/london-boulevard","overview":"A parolee falls for a reclusive movie star while trying to evade a ruthless gangster."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":103,"tagline":"Nicht jeder Kriminelle möchte einer sein.","homepage":"","overview":"London Boulevard basiert auf dem gleichnamigen Roman von Ken Bruen. Darin versucht der frisch aus dem Gefängnis entlassene Mitchell sein Leben endlich in geregelte und vor allem legale Bahnen zu führen. Er bekommt die Möglichkeit für die zurückgezogen lebende Star-Schauspielerin Charlotte als Bodyguard zu arbeiten. Während sich Mitchell und Charlotte langsam näher kommen, holt seine dunkle Vergangenheit den Ex-Häftling wieder ein. Sein früherer Boss und Gangster-Oberhaupt möchte seinen Soldaten wieder zu seinen kriminellen Ursprüngen zurückführen und hat noch die eine oder andere Schuld einzukassieren."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Londýnský gangster","runtime":103,"tagline":"Ne každý kriminálník chce být gangsterem.","homepage":"","overview":"Po třech letech strávených za mřížemi, Mitchel opouští věznici s dobrými úmysly. Ale když potká starého přítele Billyho, gangstera, který se zrovna ohlíží po nějaké práci, Mitchel se k němu připojí, výměnou za místo k bydlení. Když se znovu zaplete se svou minulostí, je vtažen do života Charlotty, filmové hvězdy, která se schovává před hordou fotografů a reportérů. Přitahován její krásou a zranitelností, rychle se ujímá role jejího ochránce. Začínají spolu plánovat nový život v Los Angeles, ale plány jim zkříží šéf gangu, Gant. Mitchelovi je jasné, že před Gantovým hněvem není v bezpečí nikdo z jeho blízkých a rozhoduje se vyřešit věci mezi nimi jednou provždy."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Телохранитель","runtime":100,"tagline":"Not every criminal wants to be one","homepage":"","overview":"Пытаясь покончить с криминальным прошлым Митч, знакомится с кинозвездой Шарлоттой, которая прячется в своем доме от толпы репортеров и фотографов. Красота и ранимость актрисы покоряют Митча, и он становится ее телохранителем, защищая Шарлотту от агрессивных папарацци, преследователей и прочих негодяев. Но преступный мир так легко его не отпустит…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Londra Bulvarı","runtime":0,"tagline":"","homepage":"","overview":"Hapisten yeni çıkmış olan Mitchel acımasız bir adam olmakla beraber hayatını bir düzene sokmak istemekte, doğru kadınla tanışıp evlenmek gibi hayaller de kurmakta olan garip bir adamdır. Hapisten çıkar çıkmaz kendisine usulsüz teklifler gelmeye başlar fakat o bu teklifleri reddeder. Tüm bu tekliflerin yerine ünlü bir oyuncunun çanta taşıyıcısı olmaya karar verir. Derken hayatının kadınıyla da tanışır Mitchel ama “geçmişi onun peşini bırakmaz”."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"London Boulevard","runtime":103,"tagline":"Tous les criminels ne veulent pas en être un.","homepage":"","overview":"Alors que Mitchel sort de prison plein de bonnes intentions, il tombe sur son vieil ami Billy, petit voyou à la recherche d’un complice, qu’il accepte d’aider en échange d’un toit. Incapable de rompre avec son passé, il fait la connaissance de Charlotte, une star de cinéma terrée dans un luxueux hôtel particulier pour échapper aux hordes de paparazzi. Sensible à la vulnérabilité de la séduisante jeune femme, Mitchel devient rapidement son garde personnel."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"伦敦大道","runtime":0,"tagline":"","homepage":"","overview":"哈德曼·米切尔是以前是一个混迹在街头的小痞子。在被警察逮到，并且判了几年徒刑之后，他决定重新做人，因为监狱的滋味他实在是受够了。刑满释放后，他换了手机，努力过着正常人的生活。不过，社会对于所谓的刑满释放人员并不是释放宽容，所以出狱之后的米切尔一样找不到工作。这个时候，他以前的那些狐朋狗友给他提供了一个挣钱的途径－－去给放高利贷的金主收钱。米切尔非常适合这个工作，因为他既诡计多端、出手又狠。但是想改邪归正的米切尔却并不是太愿意做这个工作。不过，米切尔也没有更好的出路，只好暂时干起了这种不道德的“工作”。米切尔是一个非常忠诚的朋友。是一个对情感很负责的男人。不久之后，好运降临到了他的头上，他被一个不愿意抛头露面的女明星雇佣做成了她的私人保镖。这个叫做艾思林的女明星聪慧而又富有、低调而又美丽。她不堪小报记者和狗仔队的困扰，所以雇佣了米切尔来给自己“清除麻烦”。很快，米切尔和艾思林坠入了爱河。他们俩的感情进展得很顺利，很快便一发不可收拾。就在米切尔憧憬未来的时候，他的过去找上了门来。实际上米切尔一直被自己的“过往”所困扰。他根本没有真正意义上地重新开始生活。街头的那些违法犯罪的事情：贩毒、赌博、斗殴一直跟随着他，直到现在。不幸的是，米切尔发现自己又莫名其妙地卷入了黑帮的矛盾中，这些矛盾直接威胁着他现在的生活，他能安然度过这些烦恼的事情并和艾思林生活在一起么？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Vietettyään kolme vuotta telkien takana, Mitchel vapautuu aikeenaan suunnata kaidalle polulle. Hän päätyy kuitenkin auttaman vanhaa kaveriaan Billyä erään keikan kanssa saadakseen vaihto palveluksena kämpän missä elää. Sotkuisen menneisyytensä seassa Mitchel tutustuu Charlotteen, arkaan näyttelijätähteen, joka on linnoittautunut huvilaansa piiloon julkisudelta. Pian Mitchel on omaksunut roolin tämän suojelijana niin paparazzeja, faneja kuin varkaitakin vastaan. Parin välille kehittyy pian luja side ja he alkavat suunnitella uutta alkua yhdessä rapakon takana. Mitchel on kuitenkin kiinnittänyt pahamaineisen rikollispomo Gantin huomion, ja tämä haluaa Mitchelin riveihinsä. Mitchelin kieltäydyttyä tarjouksesta, Gant kietoo Mitchelin kiristyksen ja murhaavien valheiden verkkoon, ja alkaa näyttää siltä että hän näkee Mitchelin ennemmin kuolleena kuin vapaana. Mitchelin on turvauduttava koviin otteisiin, tai kukaan heistä ei ole pian elävien kirjoissa."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"London Boulevard - Crime e Redenção","runtime":103,"tagline":"Nem todo criminoso quer ser um.","homepage":"","overview":"Um homem, acabado de sair da prisão, tenta não voltar á mesma vida que levava. Consegue arranjar um trabalho como segurança duma actriz que vive quase em reclusão."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Kåkfararen Mitchel har nyligen blivit utsläppt när han möter och förälskar sig i den blyga skådespelerskan Charlotte, vilket leder till att han hamnar i konflikt med en hänsynslös gangster."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"London Boulevard","runtime":103,"tagline":"Una rilettura riuscita di Viale del tramonto dal sapore quasi godardiano","homepage":"","overview":"Il film è basato su un romanzo di Ken Bruen e racconta di un criminale di South London che, uscito di prigione, cerca di cambiare vita lavorando come assistente e factotum per una giovane ed elusiva attrice."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":103,"tagline":"","homepage":"","overview":"Mitchel (Farrell) is een net vrijgelaten crimineel. Hij wil het criminele milieu graag achter zich laten. Dat lijkt te lukken als hij een baan aangeboden krijgt waarbij hij Charlotte (Knightley), een geïsoleerd levende jonge actrice, moet beschermen. Maar zijn verkeerde vrienden uit het verleden blijven maar bij hem aankloppen, en slepen hem mee in hun criminele activiteiten die steeds verder uit de hand lopen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":103,"tagline":"No todos los criminales quieren serlo.","homepage":"","overview":"Tras salir de la cárcel, un criminal del sur de Londres intenta olvidar su pasado y cambiar de vida; se convierte entonces en el protector de una joven actriz que tiene ciertos problemas. Debut en la dirección de William Monahan, guionista de Infiltrados (Martin Scorsese, 2006) y ganador del Oscar por ese mismo trabajo."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"London Boulevard","runtime":103,"tagline":"","homepage":"","overview":"Mitchell épp most szabadul a fegyházból, ahol az utóbbi három évet töltötte, a bejáratnál régi jóbarátja és bűntársa, Billy fogadja. London legrettegettebb emberének tiszteletére rendezett partira a keleti rész összes bűnözője meghívást kapott, ám Mitchell megváltozott a börtönévek alatt. Nem vágyik másra, mint egy tisztességes munkára, ami mellett nem kell aggódnia, hogy visszakerül a rácsok mögé. Sikerül is állást szereznie magának egy gyönyörű és híres színésznő testőreként, ám a londoni alvilág egyik vezetőjének más tervei vannak vele."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Londyński Bulwar","runtime":103,"tagline":"Miłośc nie jest pospolitym przestępstwem.","homepage":"","overview":"Mitchell (Colin Farrell) po trzech latach wychodzi z londyńskiego więzienia i próbuje zerwać z przestępczą przeszłością. Na jego drodze pojawia się samotna i piękna aktorka Charlotte (Keira Knightley), żyjąca w blasku fleszy paparazzich. Niełatwo im będzie zacząć nowe życie, zwłaszcza że o Mitcha wkrótce upomni się świat kryminalnego podziemia, z bezwzględnym gangsterem Gantem (Ray Winstone) na czele..."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":99,"tagline":"","homepage":"","overview":"At man ikke kan løbe fra sin fortid, må Michael sande, da han efter tre år i spjældet forsøger at lægge kriminaliteten bag sig. Han møder den feterede skuespillerinde Charlotte, som han beskytter mod paparazzi og andre ubehageligheder. Selvfølgelig kan de to ikke holde fingrene fra hinanden i det lange løb, men en hævngerrig mafiaboss forpurrer deres plan om at starte et nyt liv sammen i L.A."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"לונדון בולווארד","runtime":0,"tagline":"לא כל פושע רוצה להיות כזה.","homepage":"","overview":"אחרי שלוש שנים מאחורי הסורגים, מיטשל יוצא מהכלא וכולו כוונות טובות. אבל כשהחבר הותיק שלו פוגש אותו מיד לאחר השחרור, מיטשל מצטרף אליו בתמורה למקום מגורים בביתו. אז הוא פוגש את שארלוט, שחקנית מתבודדת באחוזתה, מסתתרת מהצלמים והכתבים הרבים הפוקדים את ביתה. פגיעותה ויופייה כובשים את ליבו ובמהרה הוא הופך להיות לשומר הראש שלה, אבל בלי לזנוח את תוכניותיו של חברו הפושע לשדוד את ביתה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":103,"tagline":"Όταν τους ανήκεις, υπάρχει μόνο μια διέξοδος.","homepage":"","overview":"Ο Μίτσελ είναι ένας πρώην κατάδικος από το Νότιο Λονδίνο, που αποζητά μια ευκαιρία για νέο ξεκίνημα. Αυτή θα του δοθεί όταν γίνεται σωματοφύλακας μιας νεαρής ηθοποιού, με την οποία θα ερωτευτούν."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"O Último Guarda-Costas","runtime":0,"tagline":"","homepage":"","overview":"Um criminoso ganha a liberdade e decide se afastar da vida do crime. Ele aceita trabalhar para uma atriz famosa que há anos não sai de sua mansão. No entanto, um poderoso mafioso obriga o ex-bandido a trabalhar para ele."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Булевард Лондон","runtime":104,"tagline":"Не всеки гангстер иска да е такъв.","homepage":"","overview":"Филмът разказва историята на престъпник от Южен Лондон, който наскоро излиза от затвора и започва работа при млада актриса, която живее уединено в имението си."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Охоронець","runtime":0,"tagline":"Не кожному злочинцю хочеться ним бути.","homepage":"","overview":"Історія про чоловіка, який нещодавно вийшов із в'язниці. Він береться охороняти молоду, красиву і шалено популярну акторку, яка веде усамітнений спосіб життя в своєму маєтку. Чоловік закохується, але йому ще доведеться зіткнутися з жорстоким гангстером."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"런던 블러바드","runtime":0,"tagline":"우연히.. 그러나 운명처럼...","homepage":"","overview":"교도소에서 나온 뒤 모든 것을 새롭게 시작하려는 미첼(콜린 파렐). 갱스터가 되지 않기 위해서라면 무슨 일이든 하려는 그가 소개받은 일은, 세상과 담을 쌓고 집 안에 숨어 지내는 여배우 샬롯(키이라 나이틀리)의 보디가드가 되는 것이었다. 그녀를 위해 막무가내인 파파라치를 막으면서 미첼과 샬롯은 단순한 보디 가드와 여배우 이상의 감정을 느끼게 된다.  한편 미첼의 실력을 탐내는 갱스터 보스는 새 출발하려는 그를 내버려두지 않고 범죄현장으로 유인하게 되고, 이제 그들 앞에 시작하기 위해선 끝을 맺어야 하는 운명의 격돌이 기다리고 있는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Londono bulvaras","runtime":0,"tagline":"","homepage":"","overview":"Bėgdamas nuo kriminalinės praeities Mičas susipažįsta su kino žvaigžde Šarlote, kuri slepiasi savo namuose nuo ją persekiojančios reporterių ir fotografų minios.  Merginos grožis ir pažeidžiamumas pavergia Mičą. Jis imasi ją saugoti nuo paparacių, persekiotojų ir kitokių niekšų. Nuo šiol jis Šarlotės asmens sargybinis.  Bet nusikalstamas pasaulis jo taip lengvai nepaleis..."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"倫敦大道","runtime":0,"tagline":"","homepage":"","overview":"本片根據Ken Bruen同名小說改編，由威廉姆‧莫納漢親自改編劇本。\r 　　米切爾（柯林·法瑞爾 Colin Farrell 飾）以前是個混跡在街頭的痞子，蹲了幾年牢被釋放後決定重新做人，但卻一直找不到工作。以前的那些朋友給他提供了一個替給放高利貸的金主收錢的工作，無可奈何的他只能接受。但不久後，他被一個不願意拋頭露面的女明星艾思林（凱拉·奈特莉 Keira Knightley）僱傭。艾思林不堪小報記者和狗仔隊的困擾，僱傭了米切爾來給自己「清除麻煩」。當艾思林漸漸瞭解切米爾的為人，兩人墜入了愛河。就在米切爾憧憬未來的時候，他的過去找上了門來。街頭的那些違法犯罪的事情一直跟隨著他。不幸的是，米切爾發現自己又莫名其妙地捲入了黑幫的矛盾中，這些矛盾直接威脅著他現在的生活，他能安然度過這些煩惱的事情並和艾思林生活在一起麼"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Đại Lộ Luân Đôn","runtime":0,"tagline":"","homepage":"","overview":"Dựa trên cuốn tiểu thuyết của nhà văn Ken Bruen, London Boulevard kể về tên tội phạm vừa mãn hạn từ vì tội hành hung ở ở South London. Cố gắng bỏ đi quá khứ để có thể sống một cuộc sống bình thường như bao người khác, nhân vật trung tâm của câu chuyện bắt đầu đi kiếm việc làm và sau đó trở thành một tên sai vặt bên cạnh cô diễn viên trẻ tuổi (Knightley).Công việc trong thế giới hào nhoáng đã chấm dứt những chuỗi ngày sống trong thế giới ngầm và bắt đầu cho một guồng quay mới với tiền bạc, xe cộ, tình yêu... Theo tờ Variety, bộ phim sẽ hoàn toàn lấy bối cảnh ở London với những cảnh quay rất chân thực và sống động.Sau khi giành Quả cầu vàng với bộ phim hài In Bruges, London Boulevard là dự án điện ảnh lớn đầu tiên của ..."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"ロンドン・ブルバード LAST BODYGUARD","runtime":104,"tagline":"たかが人生。今日までは、そう思っていた。","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"ლონდონის ბულვარი","runtime":0,"tagline":"","homepage":"","overview":"\"ლონდონის ბულვარი\" არის ისტორია ციხიდან ახალ გამოსულ მამაკაცზე, რომელსაც ახალგაზრდა კინოვარსკვლავი შეუყვარდება. მას ბოროტ ბანდებთან ბრძოლა უწევს."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Londonski bulvar","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"El Guardaespaldas 2","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"ยอดคนจริง ถิ่นลอนดอน","runtime":0,"tagline":"","homepage":"","overview":"ผู้ต้องขังที่ผ่านการพักโทษตกหลุมรักดาราหนังสันโดษในขณะที่พยายามหลบหนีจากอันธพาลไร้ความปราณี"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"倫敦大道","runtime":0,"tagline":"","homepage":"","overview":"本片根據 Ken Bruen 同名小説改編，由威廉姆‧莫納漢親自改編劇本。  米切爾（柯林·法瑞爾 Colin Farrell 飾）以前是個混跡在街頭的痞子，蹲了幾年牢被釋放後決定重新做人，但卻一直找不到工作。以前的那些朋友給他提供了一個替給放高利貸的金主收錢的工作，無可奈何的他只能接受。但不久後，他被一個不願意拋頭露面的女明星艾思林（凱拉·奈特莉 Keira Knightley）僱傭。艾思林不堪小報記者和狗仔隊的困擾，僱傭了米切爾來給自己「清除麻煩」。當艾思林漸漸瞭解切米爾的為人，兩人墜入了愛河。就在米切爾憧憬未來的時候，他的過去找上了門來。街頭的那些違法犯罪的事情一直跟隨著他。不幸的是，米切爾發現自己又莫名其妙地捲入了黑幫的矛盾中，這些矛盾直接威脅著他現在的生活，他能安然度過這些煩惱的事情並和艾思林生活在一起麼"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[{"id":"5ab8b79cc3a3680a3e02d742","url":"https://www.themoviedb.org/review/5ab8b79cc3a3680a3e02d742","author":"John Chard","content":"$11","created_at":"2018-03-26T09:04:28.439Z","updated_at":"2024-05-16T15:22:18.419Z","author_details":{"name":"","rating":null,"username":"John Chard","avatar_path":"/utEXl2EDiXBK6f41wCLsvprvMg4.jpg"}}],"recommendations":[{"id":33572,"adult":false,"title":"Lost and Found","video":false,"overview":"A magical tale of friendship and loneliness, which tells the story of a little boy who one day finds a penguin on his doorstep. Although at first he is unsure what to do, the boy becomes determined to help the penguin find his way back home... even if that means rowing all the way to the South Pole!","genre_ids":[10751,16],"media_type":"movie","popularity":0.5461,"vote_count":24,"poster_path":"/rNUDcAuNjB26oUeWjpBs8NBkwLe.jpg","release_date":"2008-12-24","vote_average":7.8,"backdrop_path":"/sBlWwZi1A7QLRFFZfYIgW9r2t2N.jpg","original_title":"Lost and Found","original_language":"en"},{"id":457243,"adult":false,"title":"The Long Dumb Road","video":false,"overview":"Two guys serendipitously meet at a time when they both find themselves at personal crossroads and decide to embark on an unplanned road trip across the American Southwest.","genre_ids":[35],"media_type":"movie","popularity":0.335,"vote_count":77,"poster_path":"/nGfKFEnKqSVaM0I2xxUnDeLx7t4.jpg","release_date":"2018-11-09","vote_average":5.6,"backdrop_path":"/urxxW3XsfmaURRefxALv6Wr7qHi.jpg","original_title":"The Long Dumb Road","original_language":"en"},{"id":14503,"adult":false,"title":"Bachelor Party 2: The Last Temptation","video":false,"overview":"Ron and Melinda may be happily engaged, but Melinda's scheming brother-in-law Todd doesn't like the thought of a new addition to the family business, so he plans to incriminate Ron at the ultimate bachelor bash in Miami Beach. Between Ron's party-hearty friends and Todd's tantalizing temptations, not to mention a sex addicts convention right in their hotel, it's an outrageously sinful celebration that you have to see to believe!","genre_ids":[35],"media_type":"movie","popularity":0.5703,"vote_count":62,"poster_path":"/5jYCn53G4oqNnGLh6TThQduJqxT.jpg","release_date":"2008-03-11","vote_average":4.694,"backdrop_path":"/hZh6UWL9QWx7MFlK5YeHmJdVN1q.jpg","original_title":"Bachelor Party 2: The Last Temptation","original_language":"en"},{"id":230274,"adult":false,"title":"Midnight Stallion","video":false,"overview":"Fifteen year old Megan Shephard and her parents will do anything to save their struggling farm. When they discover a wild stallion in a nearby forest they begin to wonder if this could be the answer to their prayers.","genre_ids":[10751,18],"media_type":"movie","popularity":0.3679,"vote_count":27,"poster_path":"/7hqU3At9FlNX6NuiAtiGfdVqFh0.jpg","release_date":"2013-05-04","vote_average":4.9,"backdrop_path":"/cBtazx2v3fCoCIQLwOUf37HVNqt.jpg","original_title":"Midnight Stallion","original_language":"en"},{"id":58084,"adult":false,"title":"Julia and Julia","video":false,"overview":"A grieving woman, haunted by the loss of her husband on their wedding day, suddenly finds herself slipping between two realities—one where she remains a widow and another where he is alive with their son. As she struggles to distinguish truth from illusion, she becomes entangled in love, betrayal, and mystery, questioning her sanity while searching for answers in a world that keeps shifting.","genre_ids":[18,14],"media_type":"movie","popularity":0.4149,"vote_count":21,"poster_path":"/6GPNV1piaFgYXduDIMc9FIMh7Dx.jpg","release_date":"1988-02-05","vote_average":4.9,"backdrop_path":"/xpolmIfROQAOyvlXm4WqhafXEpm.jpg","original_title":"Giulia e Giulia","original_language":"it"},{"id":52317,"adult":false,"title":"Mylène Farmer : Stade de France","video":true,"overview":"The Stade de France DVD follows the 2009 tour that was captured during performances at the Stade de France near Paris.","genre_ids":[10402],"media_type":"movie","popularity":0.1012,"vote_count":15,"poster_path":"/f75djgwk6IC9TMy8EG82vrqIoVB.jpg","release_date":"2010-04-12","vote_average":8.1,"backdrop_path":"/iQuifbChTmKN26eIDf49h8pTbIj.jpg","original_title":"Mylène Farmer : Stade de France","original_language":"fr"},{"id":718659,"adult":false,"title":"Sufiyum Sujatayum","video":false,"overview":"Dr. Rajeev and his wife SUJATA come from Dubai to participate in the last rituals of Sujata's friend and ex love affair who was a Sufi. The events which happen when they land in the village forms the rest of the plot.","genre_ids":[18,10749],"media_type":"movie","popularity":0.3038,"vote_count":16,"poster_path":"/5v32Sj1OwKLcFARvO1YBUF2FqTZ.jpg","release_date":"2020-07-03","vote_average":4.3,"backdrop_path":"/y24Sf4aManpX9HewtV9oOTMrdJ8.jpg","original_title":"സൂഫിയും സുജാതയും","original_language":"ml"},{"id":253129,"adult":false,"title":"London Kills Me","video":false,"overview":"For want of a nail a shoe was lost, for want of a shoe... a young man's life is almost lost, which is exactly what this film is all about: a man barely twenty who wants desperately to pull out of London's drug world by taking a job as a waiter in a 'normal' restaurant. But to do this he must come up with a \"sensible\" pair of shoes, an item that his homeless meanderings hasn't provided him.","genre_ids":[35,18],"media_type":"movie","popularity":0.3066,"vote_count":13,"poster_path":"/f5crZR8BcehJ8leebQrabEG1taP.jpg","release_date":"1991-12-13","vote_average":5.731,"backdrop_path":"/zJABA8SrHwRnQKqT1B5WlzXcqLt.jpg","original_title":"London Kills Me","original_language":"en"},{"id":52441,"adult":false,"title":"Parallel Life","video":false,"overview":"A young man finds out that he is living a completely identical life to another man who lived decades ago. And when his wife is murdered the same way as the previous man's, he decides to dig into the older case to find clues about who was the murderer this time.","genre_ids":[28,53,9648],"media_type":"movie","popularity":0.5965,"vote_count":31,"poster_path":"/vMDPANSDIa0CqWlNLZwUthozQQf.jpg","release_date":"2010-02-18","vote_average":6.194,"backdrop_path":"/9kNp2uECQCA1KyXCKaNcyb4gK3r.jpg","original_title":"평행이론","original_language":"ko"},{"id":45712,"adult":false,"title":"Gloria","video":false,"overview":"After serving a prison term for her boyfriend, a streetwise, middle-aged moll named Gloria stands up against the mobs, which is complicated by a six-year-old urchin with a will of his own, whom she reluctantly takes under her wing after his family has been gunned down.","genre_ids":[18,80,53],"media_type":"movie","popularity":0.983,"vote_count":128,"poster_path":"/1AKAfnT3nm7asU9qyNT6gtS1vbe.jpg","release_date":"1999-01-22","vote_average":5.754,"backdrop_path":"/6rlOgCIxCuJj1cmlPcaBekgQuRb.jpg","original_title":"Gloria","original_language":"en"},{"id":617710,"adult":false,"title":"You Will Die at Twenty","video":false,"overview":"Shortly after Muzamil was born, the village's holy man predicts that he will die at age 20. Muzamil's father can't stand the curse and leaves home. Sakina raises her son as a single mother, overly protective. One day, Muzamil turns 19.","genre_ids":[18],"media_type":"movie","popularity":0.1412,"vote_count":44,"poster_path":"/hZjpqUFs3ffevZoLJsvoutpEIrd.jpg","release_date":"2020-02-12","vote_average":7.068,"backdrop_path":"/bK2NadJBzYBLr0JZp5m7l1hU9Do.jpg","original_title":"ستموت في العشرين","original_language":"ar"},{"id":57521,"adult":false,"title":"Black Bread","video":false,"overview":"In the harsh post-war years' Catalan countryside, Andreu, a child that belongs to the losing side, finds the corpses of a man and his son in the forest. The authorities want his father to be made responsible of the deaths, but Andreu tries to help his father by finding out who truly killed them. In this search, Andreu develops a moral consciousness against a world of adults fed by lies. In order to survive, he betrays his own roots and ends up finding out the monster that lives within him.","genre_ids":[80,18],"media_type":"movie","popularity":3.0383,"vote_count":123,"poster_path":"/c8YTscygBsjiwwkX2jlROpCTeuf.jpg","release_date":"2010-10-10","vote_average":6.7,"backdrop_path":"/ywScdkxr19Gggsr3u9o0Ped0srS.jpg","original_title":"Pa Negre","original_language":"ca"},{"id":69225,"adult":false,"title":"Switch","video":false,"overview":"In Montreal, the unemployed fashion designer Sophie Malaterre is shown a website, switch.com, where it is possible to switch houses with a stranger for vacation. Sophie seeks an apartment in Paris nearby the Eiffel Tower that belongs to Bénédicte Serteaux and they change apartments. Sophie arrives in Paris on Saturday morning. The next morning, policemen break in the apartment and arrest Sophie while she is having a bath. Detective Damien Forgeat interrogates Sophie believing that she is Bénédicte and she learns that a beheaded body was found in her room and all evidence of her life has been deleted.","genre_ids":[80,28,53],"media_type":"movie","popularity":0.5323,"vote_count":116,"poster_path":"/nOroxNJftPkGLjordf8IcYkjjZb.jpg","release_date":"2011-06-06","vote_average":5.862,"backdrop_path":"/VYWo22N9BV49LqPdDEl9ZVoDzI.jpg","original_title":"Switch","original_language":"fr"},{"id":61999,"adult":false,"title":"Sara","video":false,"overview":"Sixteen-year-old Sara's father is a wealthy gangster and has a lot of enemies. Her father makes clear that whoever touches Sara will die and he looks for the right bodyguard to protect her.","genre_ids":[28,10749],"media_type":"movie","popularity":2.826,"vote_count":87,"poster_path":"/1ynxFhdoqI1bh1VaZsyMb705ZfQ.jpg","release_date":"1997-05-23","vote_average":6.69,"backdrop_path":"/pS8FXifwZyvZFZEOHGgJjjtOdfP.jpg","original_title":"Sara","original_language":"pl"},{"id":52761,"adult":false,"title":"Daisy Town","video":false,"overview":"When the members of a caravan of pioneers find a daisy growing in the middle of the desert they decide to stop there and to build their town on this very spot. Houses soon spring up like mushrooms, immediately followed by a bank, a saloon, a prison, etc. Daisy Town is born. Unfortunately a city does not go without its bad boys and the peaceful place is soon turned into a lawless place. To restore law and order, a lawman is needed. Lucky Luke, the cowboy who shoots faster than his shadow, will be this man: all the villains had better watch out!","genre_ids":[16,35,37],"media_type":"movie","popularity":1.9367,"vote_count":114,"poster_path":"/hKu2GtcbT95cH1O8BHbJOuIQgOu.jpg","release_date":"1971-11-01","vote_average":6.645,"backdrop_path":"/sBhNHGKJspWnvxOIBZ6d6D2by4X.jpg","original_title":"Daisy Town","original_language":"fr"},{"id":1304106,"adult":false,"title":"Blood Star","video":false,"overview":"A young woman is driving through the desert alone when she is drawn into a dangerous game of cat and mouse with a psychopathic Sheriff. The chase escalates to deadly levels, and she must use her street-smarts to turn the tables against him.","genre_ids":[53,27],"media_type":"movie","popularity":1.183,"vote_count":62,"poster_path":"/1luaxuRCI7X8mtNMKsQ4grBYICo.jpg","release_date":"2024-12-11","vote_average":5.581,"backdrop_path":"/cZZyqi78c9yQfUm1AwNwQMETy3Y.jpg","original_title":"Blood Star","original_language":"en"},{"id":666624,"adult":false,"title":"Security","video":false,"overview":"After the assault of a young woman in their seaside town, a security expert and his family get caught in a powerful riptide of secrets and lies.","genre_ids":[53],"media_type":"movie","popularity":0.6558,"vote_count":190,"poster_path":"/wLjN3vIw63GJ6m1J2fhGL3D2VXd.jpg","release_date":"2021-06-07","vote_average":5.529,"backdrop_path":"/syuRL8LkPz4HguGAxAwvUt3HWlK.jpg","original_title":"Security","original_language":"it"},{"id":10534,"adult":false,"title":"White Squall","video":false,"overview":"In 1960, a hardy group of prep school students boards an old-fashioned sailing ship. With Capt. Christopher Sheldon at the helm, the oceangoing voyage is intended to teach the boys fortitude and discipline. But the youthful crew are about to get some unexpected instruction in survival when they get caught in the clutches of a white squall storm.","genre_ids":[18,12],"media_type":"movie","popularity":1.46,"vote_count":395,"poster_path":"/muhTVa52IufjTaqNseXFQUAEuyG.jpg","release_date":"1996-02-02","vote_average":6.266,"backdrop_path":"/kpVQHZrBLUsB35S1pTbP8apgT5W.jpg","original_title":"White Squall","original_language":"en"},{"id":14396,"adult":false,"title":"Code Name: The Cleaner","video":false,"overview":"Cedric the Entertainer plays Jake, a seemingly regular guy who has no idea who he is after being hit over the head by mysterious assailants. When he finds himself entangled in a government conspiracy, Jake and his pursuers become convinced that he is an undercover agent.","genre_ids":[28,35,80],"media_type":"movie","popularity":0.6801,"vote_count":264,"poster_path":"/wSQkv51ygnds56lylNavYJzLmNZ.jpg","release_date":"2007-01-05","vote_average":5.17,"backdrop_path":"/cMMjICzBe5qTx1igspFYdX8B3o2.jpg","original_title":"Code Name: The Cleaner","original_language":"en"},{"id":38448,"adult":false,"title":"Ondine","video":false,"overview":"On the coast of Cork, Syracuse is a divorced fisherman who has stopped drinking. His precocious daughter Annie has failing kidneys. One day, he finds a nearly-drowned young woman in his net; she calls herself Ondine and wants no one to see her. He puts her up in an isolated cottage that was his mother's. Annie discovers Ondine's presence and believes she is a selkie, a seal that turns human while on land. Syracuse is afraid to hope again.","genre_ids":[18,10749],"media_type":"movie","popularity":1.3094,"vote_count":346,"poster_path":"/rQSQisWjIjXnGGenrpjG1GlQcRf.jpg","release_date":"2010-03-05","vote_average":6.383,"backdrop_path":"/9r4QZ0G7H2J3cy6yBZ3BN69lwwY.jpg","original_title":"Ondine","original_language":"en"}],"similar_content":[{"id":8059,"adult":false,"title":"Zeit der Fische","video":false,"overview":"","genre_ids":[18],"popularity":0.09,"vote_count":1,"poster_path":null,"release_date":"2007-10-26","vote_average":5,"backdrop_path":null,"original_title":"Zeit der Fische","original_language":"de"},{"id":8090,"adult":false,"title":"Untraceable","video":false,"overview":"Special Agent Jennifer Marsh works in an elite division of the FBI dedicated to fighting cybercrime. She thinks she has seen it all, until a particularly sadistic criminal arises on the Internet. This tech-savvy killer posts live feeds of his crimes on his website; the more hits the site gets, the faster the victim dies. Marsh and her team must find the elusive killer before time runs out.","genre_ids":[53,80,9648,18,27],"popularity":2.6372,"vote_count":969,"poster_path":"/ySUwDRDEn01lKIMPQorpFCMLWqE.jpg","release_date":"2008-01-22","vote_average":6.229,"backdrop_path":"/pPTNyx5xjYQ7WX05n3eRjmhGzdC.jpg","original_title":"Untraceable","original_language":"en"},{"id":8195,"adult":false,"title":"Ronin","video":false,"overview":"A briefcase with undisclosed contents – sought by Irish terrorists and the Russian mob – makes its way into criminals' hands. An Irish liaison assembles a squad of mercenaries, or 'ronin', and gives them the thorny task of recovering the case.","genre_ids":[28,53,80],"popularity":6.1822,"vote_count":2593,"poster_path":"/AirrhRJjHwytOV0pdLu7YZ4DEyr.jpg","release_date":"1998-09-25","vote_average":6.958,"backdrop_path":"/frqahc6v8wt0p2Zo3XKBu2dg73z.jpg","original_title":"Ronin","original_language":"en"},{"id":8456,"adult":false,"title":"Never Back Down","video":false,"overview":"Jake, full of anger after his father's death, is just starting to find a place for himself at his new Orlando high school - until Ryan, head of an underground MMA fight club, picks Jake out as a prime opponent. After being trounced by Ryan in front of the entire school, Jake begins training under the firm, moral guidance of a MMA master, where he learns how to fight... and how to avoid a fight. But it becomes obvious that a rematch will be inevitable if Jake wants to stop Ryan and his bullying, once and for all.","genre_ids":[18,28],"popularity":5.0896,"vote_count":2442,"poster_path":"/8oRUTyP1QAtGDMvRpKZyuyFPG0U.jpg","release_date":"2008-03-04","vote_average":6.8,"backdrop_path":"/h71xyiurUscD6uIPbECyso1Lwb9.jpg","original_title":"Never Back Down","original_language":"en"},{"id":8471,"adult":false,"title":"Far North","video":false,"overview":"In the arctic, as Saiva is being born, a shaman declares that she is evil and will bring harm to all who become involved with her. Saiva is cast out of her tribe of herders and grows up to live a nomadic existence with Anja, a young woman she adopts as an infant. Then Loki, an injured and starving soldier, stumbles into their isolated lives. The women nurse him back to health, but treachery, violence and doom await them all.","genre_ids":[18,53,10749,80],"popularity":0.3685,"vote_count":56,"poster_path":"/d31sugp9MHWv7YHGxgM5iYQVmXB.jpg","release_date":"2008-10-09","vote_average":5.991,"backdrop_path":"/rOzQTb1CWIiRlDk8ILMULOSuktG.jpg","original_title":"Far North","original_language":"en"},{"id":8557,"adult":false,"title":"True North","video":false,"overview":"The crew of a bankrupt Scottish trawler turn to smuggling illegal immigrants over the stormy waters of the North Sea.","genre_ids":[18],"popularity":0.1609,"vote_count":14,"poster_path":"/pquMZPfTw0EWbYhvx4jAqK5Via9.jpg","release_date":"2007-09-14","vote_average":6.429,"backdrop_path":"/qYpLRpVW1sK0OZE7UyEGxppfPUQ.jpg","original_title":"True North","original_language":"en"},{"id":8224,"adult":false,"title":"8MM","video":false,"overview":"A small, seemingly innocuous plastic reel of film leads surveillance specialist Tom Welles down an increasingly dark and frightening path. With the help of the streetwise Max, he relentlessly follows a bizarre trail of evidence to determine the fate of a complete stranger. As his work turns into obsession, he drifts farther and farther away from his wife, family and simple life as a small-town PI.","genre_ids":[53,80,9648],"popularity":4.573,"vote_count":2200,"poster_path":"/mhr9xRpjOBqlBjgDwtiOx6FsLvV.jpg","release_date":"1999-02-26","vote_average":6.47,"backdrop_path":"/eEP8pyCmldfbnml0SFMvPK7kE4x.jpg","original_title":"8MM","original_language":"en"},{"id":8268,"adult":false,"title":"Surviving with Wolves","video":false,"overview":"In 1942, the young Jewish girl Misha, her Russian mother Gerusha and her German father Reuven hide from the Germans in a small house in Ardennes, Belgium. Misha is very connected to her mother that advises her that if one day a person comes to her saying \"love of my life\", she would follow him or her without any question. When her parents are captured by the Nazis, Misha is delivered to a German family and the abusive matriarch gives a bad treatment to the girl. However, she finds support in the family of Ernest and his deranged wife Marthe that supplies groceries to foster family. Misha loves Ernest's dogs and the old man gives a compass to her and tells that her parents have been sent to East to forced labor. When the old couple is denounced for sheltering the girl and arrested by the Germans, Misha flees through the woods heading east. Along her journey seeking out her parents...","genre_ids":[18],"popularity":0.8255,"vote_count":80,"poster_path":"/vlcyVOnKEMzMMoTg8oAcPCyoiSg.jpg","release_date":"2007-11-21","vote_average":6.2,"backdrop_path":"/2v7CE53X4aXdtiU22SgSdq0Oha.jpg","original_title":"Survivre avec les loups","original_language":"fr"},{"id":8276,"adult":false,"title":"I've Loved You So Long","video":false,"overview":"A woman struggles to interact with her family and find her place in society after spending fifteen years in prison.","genre_ids":[18],"popularity":0.3843,"vote_count":231,"poster_path":"/14i0SnmWzgejS4ZRcBbzkvXD6dp.jpg","release_date":"2008-03-19","vote_average":7.264,"backdrop_path":"/y9Vcx8he3TErcPKSY56PX5tRMTl.jpg","original_title":"Il y a longtemps que je t'aime","original_language":"fr"},{"id":8291,"adult":false,"title":"Poetic Justice","video":false,"overview":"Still grieving after the murder of her boyfriend, hairdresser Justice writes poetry to deal with the pain of her loss. Unable to get to Oakland to attend a convention because of her broken-down car, Justice gets a lift with her friend, Iesha, and Iesha's postal worker boyfriend, Chicago. Along for the ride is Chicago's co-worker, Lucky, to whom Justice grows close after some initial problems. But is she ready to open her heart again?","genre_ids":[18,10749],"popularity":2.1418,"vote_count":270,"poster_path":"/fOtMHxhYaCQcu3dwWpg7lz4Bqo0.jpg","release_date":"1993-07-23","vote_average":6.785,"backdrop_path":"/lNvlerKoYwboltmK7hQfgxsYtNP.jpg","original_title":"Poetic Justice","original_language":"en"},{"id":8292,"adult":false,"title":"Four Brothers","video":false,"overview":"Four adopted brothers return to their Detroit hometown when their mother is murdered and vow to exact revenge on the killers.","genre_ids":[28,80],"popularity":5.1511,"vote_count":2328,"poster_path":"/8cO39cnWSZQi2ncPG5TxL3YRzKc.jpg","release_date":"2005-08-11","vote_average":6.805,"backdrop_path":"/2pITFeesu6aikrEknoH6bNXOdhk.jpg","original_title":"Four Brothers","original_language":"en"},{"id":8587,"adult":false,"title":"The Lion King","video":false,"overview":"Young lion prince Simba, eager to one day become king of the Pride Lands, grows up under the watchful eye of his father Mufasa; all the while his villainous uncle Scar conspires to take the throne for himself. Amid betrayal and tragedy, Simba must confront his past and find his rightful place in the Circle of Life.","genre_ids":[10751,16,18,12],"popularity":18.0402,"vote_count":19410,"poster_path":"/sKCr78MXSLixwmZ8DyJLrpMsd15.jpg","release_date":"1994-06-15","vote_average":8.252,"backdrop_path":"/6GF9uJs7AnbcJvyfoZyjZv063Oo.jpg","original_title":"The Lion King","original_language":"en"},{"id":8592,"adult":false,"title":"Dick Tracy","video":false,"overview":"The comic strip detective finds his life vastly complicated when Breathless Mahoney makes advances towards him while he is trying to battle Big Boy Caprice's united mob.","genre_ids":[12,35,80],"popularity":4.4372,"vote_count":1012,"poster_path":"/sjeP4bpgsUvAGE8oFcICy2GaHxw.jpg","release_date":"1990-04-05","vote_average":6.147,"backdrop_path":"/zkIMr5t0B95nZPhY4AvI4v3qYH.jpg","original_title":"Dick Tracy","original_language":"en"},{"id":8649,"adult":false,"title":"Bringing Out the Dead","video":false,"overview":"Once called \"Father Frank\" for his efforts to rescue lives, Frank Pierce sees the ghosts of those he failed to save around every turn. He has tried everything he can to get fired, calling in sick, delaying taking calls where he might have to face one more victim he couldn't help, yet cannot quit the job on his own.","genre_ids":[18],"popularity":3.6592,"vote_count":1191,"poster_path":"/gE2Q8mL0m0EA6HakRyc92uzSPJn.jpg","release_date":"1999-10-22","vote_average":6.607,"backdrop_path":"/A1V1suhllQJ1CTrKpCulcM7mjyj.jpg","original_title":"Bringing Out the Dead","original_language":"en"},{"id":8692,"adult":false,"title":"Cannibal Apocalypse","video":false,"overview":"Released from captivity in Vietnam, two American Army officers return to civilian life and discover they have acquired an insatiable taste for human flesh. A city is terrorised... as they stalk the inhabitants to satisfy their primitive appetites.","genre_ids":[27,80,53],"popularity":0.2161,"vote_count":103,"poster_path":"/tc15RXXTM5LDNvJy6vrJs5eKzaY.jpg","release_date":"1980-08-04","vote_average":5.486,"backdrop_path":"/ygAhmnjvrfCfP3HTeJEfqh1WyuK.jpg","original_title":"Apocalypse Domani","original_language":"it"},{"id":1259024,"adult":false,"title":"Good Bad Ugly","video":false,"overview":"AK, a powerful gangster, surrenders to the police, in hopes that his wife and son will live a peaceful life. When he is released 17 years later, he learns that his son is falsely accused of serious crimes. To protect him, he is forced to go back to his old ways, facing enemies, both old and new.","genre_ids":[28,80,35],"popularity":1.2523,"vote_count":28,"poster_path":"/8DbYYluzdiGDAZzsaP7DWGbwfLd.jpg","release_date":"2025-04-09","vote_average":5.9,"backdrop_path":"/5CtvMLmCdksbYqqQd812WYML2wJ.jpg","original_title":"குட் பேட் அக்லி","original_language":"ta"},{"id":8374,"adult":false,"title":"The Boondock Saints","video":false,"overview":"Tired of the crime overrunning the streets of Boston, Irish Catholic twin brothers Conner and Murphy are inspired by their faith to cleanse their hometown of evil with their own brand of zealous vigilante justice. As they hunt down and kill one notorious gangster after another, they become controversial folk heroes in the community. But Paul Smecker, an eccentric FBI agent, is fast closing in on their blood-soaked trail.","genre_ids":[28,53,80],"popularity":4.189,"vote_count":2615,"poster_path":"/wtLUmkWg41xFLpvmUWAN1mm65f6.jpg","release_date":"1999-01-22","vote_average":7.252,"backdrop_path":"/9DNDELpVxuLJWMoomgULhhZFoHR.jpg","original_title":"The Boondock Saints","original_language":"en"},{"id":8382,"adult":false,"title":"Today You Die","video":false,"overview":"A former thief who is trying to go straight seeks vengeance on those who framed him.","genre_ids":[28,80,12,53],"popularity":1.6619,"vote_count":121,"poster_path":"/fSL56vXRp4Qh23vXPiAhJMFKZgB.jpg","release_date":"2005-09-13","vote_average":4.3,"backdrop_path":"/9XpbzvX38LUi21QYvBlVyp3yBMv.jpg","original_title":"Today You Die","original_language":"en"},{"id":8398,"adult":false,"title":"The Hitcher","video":false,"overview":"While driving through the New Mexico Desert during a rainy night, college students Jim Halsey and his girlfriend Grace Andrews give a ride to a hitchhiker. While in their car, the stranger proves to be a psychopath threatening the young couple with a knife, but Jim successfully throws him out of the car. This sets off a chain of events that will change all of their lives forever.","genre_ids":[80,27,53],"popularity":1.5666,"vote_count":969,"poster_path":"/b3As3DylhyrL8xeGptElGnkfb42.jpg","release_date":"2007-01-19","vote_average":5.874,"backdrop_path":"/2w0uvzOXKyda8fW0IvkdGFFnJCq.jpg","original_title":"The Hitcher","original_language":"en"},{"id":8409,"adult":false,"title":"A Man Apart","video":false,"overview":"When Vetter's wife is killed in a botched hit organized by Diablo, he seeks revenge against those responsible. But in the process, Vetter and Hicks have to fight their way up the chain to get to Diablo but it's easier said than done when all Vetter can focus on is revenge.","genre_ids":[28,18,80],"popularity":2.6118,"vote_count":941,"poster_path":"/mgcGj39KYcyPx6zDiICHsPQNAJQ.jpg","release_date":"2003-04-04","vote_average":6.1,"backdrop_path":"/bPVCkI1NVHNuAdD9OB5NFHgOSXk.jpg","original_title":"A Man Apart","original_language":"en"}],"external_ids":{"imdb_id":"tt1213648","twitter_id":null,"facebook_id":null,"wikidata_id":"Q164933","instagram_id":null,"metacritic_id":"movie/london-boulevard","mydramalist_id":"199009","rotten_tomatoes_id":"m/london-boulevard"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148743,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"CZ","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2011-02-10T00:00:00.000Z","certification":"15+"}]},{"iso_3166_1":"DE","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2011-12-01T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"DK","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2011-05-24T00:00:00.000Z","certification":"15"}]},{"iso_3166_1":"FR","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2011-06-08T00:00:00.000Z","certification":"18"}]},{"iso_3166_1":"GB","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2010-11-10T00:00:00.000Z","certification":"18"}]},{"iso_3166_1":"GR","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2011-03-10T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"HU","release_dates":[{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":"2011-02-10T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"IE","release_dates":[{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":