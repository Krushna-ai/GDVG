5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Playing with Love\",\"description\":\"Laura and Fabrizio have been meeting every summer in the forest by her parent's summer home. Fabrizio is a solitary boy with only his dog for company; Laura a sweet but unconfident child. This summer new aspects enter into their story as both are growing up. Laura is falling in love with Fabrizio, while he displays a new sexual awareness of her masked by his malice. Things develop further when they meet Sylvia who, unlike the innocent Laura, is confident and assertive. Fabrizio develops a fascination with her, eventually bribing Laura to fetch her to the forest to join them in play.\",\"image\":\"https://image.tmdb.org/t/p/w500/nu5uj47KSF73VPEiIRYdPLJ96j7.jpg\",\"datePublished\":\"1977-05-17\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"IN\",\"inLanguage\":\"it\",\"genre\":[\"Drama\",null,null,null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.1,\"bestRating\":10,\"ratingCount\":84}}"}}],["$","$L10",null,{"initialDrama":{"id":"d3815db4-9012-4755-a29b-daa0e9a692c3","tmdb_id":46853,"imdb_id":"tt0076749","content_type":"movie","title":"Playing with Love","original_title":"Maladolescenza","overview":"Laura and Fabrizio have been meeting every summer in the forest by her parent's summer home. Fabrizio is a solitary boy with only his dog for company; Laura a sweet but unconfident child. This summer new aspects enter into their story as both are growing up. Laura is falling in love with Fabrizio, while he displays a new sexual awareness of her masked by his malice. Things develop further when they meet Sylvia who, unlike the innocent Laura, is confident and assertive. Fabrizio develops a fascination with her, eventually bribing Laura to fetch her to the forest to join them in play.","poster_path":"/nu5uj47KSF73VPEiIRYdPLJ96j7.jpg","backdrop_path":"/