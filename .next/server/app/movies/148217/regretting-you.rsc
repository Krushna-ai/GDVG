ge":0},{"width":1920,"height":1080,"file_path":"/wxsEyByDH3VlaVmqGz625rKd37T.jpg","iso_639_1":"he","iso_3166_1":"IL","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/4Uj8rA8EEujrnxBXuwmFId3tuUO.jpg","iso_639_1":"he","iso_3166_1":"IL","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/wCH9Efp189YNgxrl59BueeltS1q.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/lwX0pSA1StsV5PIDhsmnFDVBANJ.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/w1ub0ppyfbkGXamVNtiW8UWZc5l.jpg","iso_639_1":"he","iso_3166_1":"IL","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/5NoAxsjnnDgXasrAs5kW0EcsZ3U.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/cjS6zkSEmdlKqYIPUji8NzW3lQK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/3Pv06NnjDuKxKmRQXfzv08bcsfu.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/sc0KqE5JkQUXIha5sPCMnhQCOhh.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/aJU8L7iepIsJWPNN4KxL4vF52Rl.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1703,"height":958,"file_path":"/9FNhUpLdTyUdBIU03bLnUP6mPgr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2027,"height":1141,"file_path":"/1mONo3bekjZQpb1sCVoBLzG4kg6.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2048,"height":1152,"file_path":"/5nEMf65x7t0T3dZOPMGcDoc6Jf4.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3200,"height":1801,"file_path":"/l8UQfny1B88SlLJ8KtVX3eKQD6g.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3840,"height":2160,"file_path":"/s1BoBwNB9AgdpTt41duInZYF8Ob.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1404,"height":790,"file_path":"/61WqWW4N7tkAQ7fnWBgRBUNQe8J.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1408,"height":792,"file_path":"/dQW9kQWVtLWVo4A80OIyYv16cFM.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/nAoVsMC32pD5ymDHo3JLHIjk1Rx.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/p9fYIdBx7e1MteTGyxVNXxzg4Kl.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:44:58.159+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":116,"tagline":"Risk everything. Regret nothing.","homepage":"https://www.paramountpictures.com/movies/regretting-you","overview":"Morgan Grant and her daughter Clara explore what's left behind after a devastating accident reveals a shocking betrayal and forces them to confront family secrets, redefine love, and rediscover each other."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Cuộc Tình Vụng Trộm","runtime":0,"tagline":"","homepage":"","overview":"Jonah và Chris là hai người bạn thân. Jenny và Morgan là hai chị em ruột. Nếu Chris và Jenny luôn ồn ào nhiệt huyết thì Jonah và Morgan lại sâu lắng và kiệm lời. Sau buổi dạ hội cuối cấp, Morgan thông báo mình có thai với Chris. Và cũng vào ngày hôm ấy, Jonal nói lời chia tay Jenny và rời đi."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"A pesar de ti","runtime":0,"tagline":"","homepage":"","overview":"Morgan es una madre joven que intenta evitar que su hija Clara, de 16 años, cometa los mismos errores que ella, que se quedó embarazada y se casó demasiado joven, teniendo que aparcar sus propios sueños. La única persona que trae paz a la tensa relación madre-hija es Chris, su marido y padre de Clara. Pero esa paz se rompe cuando un trágico y extraño accidente trae desgarradoras consecuencias para ellas. Mientras lucha por reconstruir sus vidas, Morgan encuentra consuelo en la última persona que esperaba, mientras Clara se vuelve hacia el único chico que le han prohibido ver."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"Tout risquer. Ne rien regretter.","homepage":"","overview":"De Colleen Hoover, auteure à succès, voici une histoire qui saisit toute la magie d’un amour de jeunesse et vous la fait ressentir. Quand la vie de Clara bascule, elle ne s’attend pas à trouver l’amour… jusqu’à ce que Miller entre dans sa vie. Avec sa force tranquille et sa chaleur rassurante, il l’aide à retrouver la joie au milieu du chaos. Un récit tendre sur le premier amour, les secondes chances et ce lien unique qui illumine tout."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Se Não Fosse Você","runtime":116,"tagline":"Arrisque tudo. Não se arrependa de nada.","homepage":"https://paramountpictures.com.br/filmes/se-nao-fosse-voce","overview":"Morgan Grant e sua filha Clara precisam lidar com o que ficou após um acidente devastador revelar uma traição chocante e forçá-las a confrontar segredos da família, redefinir o amor e se redescobrir."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"All das Ungesagte zwischen uns - Regretting You","runtime":117,"tagline":"Riskiere alles, bereue nichts.","homepage":"https://constantin.film/kino/regretting-you/","overview":"Erzählt werden die parallel verlaufenden Geschichten einer jungen Mutter, Morgan Grant, und ihrer 16-jährigen Tochter Clara, deren Welt von einer verheerenden Familientragödie erschüttert wird. Mit Warmherzigkeit und Humor verknüpft dieses bewegende Drama Claras ergreifende Coming-of-Age-Geschichte mit Morgans emotionaler Reise, die mit Blick in ihre eigene Vergangenheit ihre Zukunft neu definiert."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Шкодуючи за тобою","runtime":0,"tagline":"Ризикуй усім. Не шкодуй ні про що.","homepage":"","overview":"Морґан Ґрант прагне вберегти доньку Клару від власних помилок юності, але дівчина відчайдушно шукає власний шлях. Трагедія, що назавжди змінює їхнє життя, ставить під загрозу крихкі стосунки в їхній родині. На тлі болю і нерозуміння мати знаходить розраду в давньому другові, а донька — у місцевому бунтарі. Таємниці та заборонені почуття загрожують роз’єднати сімʼю остаточно."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Сожалею о тебе","runtime":0,"tagline":"«Рискни всем. Ни о чём не жалей»","homepage":"","overview":"Морган и её 16-тилетняя дочь Клара больше всего хотят быть непохожими друг на друга. Мать боится, что дочь повторит её ошибки молодости. Дочь же, свободолюбивая и упрямая, идёт своим путём. В результате личной трагедии их мир рушится, и в поисках утешения мать сближается с давним другом, а Клара знакомится с местным сердцеедом и хулиганом."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"A pesar de ti","runtime":117,"tagline":"Arriésgalo todo. No te arrepientas de nada.","homepage":"","overview":"Morgan Grant y su hija Clara exploran lo que queda atrás después de un accidente devastador que revela una traición impactante y las obliga a enfrentar secretos familiares, redefinir el amor y redescubrirse mutuamente."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Gdyby nie ty","runtime":117,"tagline":"Zaryzykuj wszystko. Nie żałuj niczego.","homepage":"","overview":"Film opowiada historię Morgan Grant i jej nastoletniej córki Clary, których już i tak napięta relacja zostaje wystawiona na próbę po tragicznym wypadku, który ujawnił szokującą zdradę. W obliczu rodzinnych sekretów, które wychodzą na jaw, Morgan i Clara muszą zmierzyć się z przeszłością, poradzić sobie z żałobą i na nowo zdefiniować, czym są miłość i zaufanie — zarówno wobec siebie, jak i wobec innych."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Regretting You - Tutto quello che non ti ho detto","runtime":0,"tagline":"Rischia tutto. Non rimpiangere nulla.","homepage":"","overview":"Il racconto intenso e struggente di una madre, Morgan (Allison Williams), e di sua figlia Clara (Mckenna Grace), travolte da un tragico incidente che cambia per sempre le loro vite. Una verità sconvolgente viene a galla, e con essa il peso dei segreti, delle scelte mancate, delle parole mai dette. Mentre il dolore le mette di fronte a segreti di famiglia sepolti da tempo, madre e figlia si troveranno a ridefinire il senso dell’amore e a riscoprire il legame che le unisce."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"להתחרט עליך","runtime":0,"tagline":"כשהחיים מושכים אותך למטה, האהבה מרימה אותך למעלה.","homepage":"","overview":"סיפורן של מערכת היחסים בין אמא וביתה המתבגרת הנאלצות להתמודד עם סודות, אהבות ראשונות והזדמנויות שניות."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"愛．憾事","runtime":0,"tagline":"","homepage":"","overview":"《痛愛完成式》原著作者另一暢銷小説，精彩活現大銀幕。一宗牽涉兩條人命的嚴重交通意外，揭開了令人震驚的秘密；逼使一對母女，面對家族的傷痕，探索愛的定義，並重新認識彼此。《訪 。嚇》艾莉遜威廉絲、《捉鬼敢死隊：魅來世界》麥根娜姬絲、《荷裏活爛片王》戴夫法蘭高、《馴龍記》瑪森泰晤士、《狂野時速 8》史葛伊士活、以及《怪殺一夜情》維拉費哲蘿，為觀眾帶來一個關於悲劇後如何重啟人生的動人故事。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"只為你遺憾","runtime":0,"tagline":"","homepage":"","overview":"年輕母親摩根（愛莉森威廉絲 飾演）為了扶養16歲女兒克拉拉（麥肯娜葛瑞絲 飾演）暫時放下自身夢想，沒想到卻遭遇丈夫車禍身亡，讓本來就複雜的母女關係雪上加霜，兩人必須學習如何一同面對人生的難關。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"รอยรักปมร้าว","runtime":0,"tagline":"","homepage":"","overview":"เป็นเรื่องราวเกี่ยวกับความสัมพันธ์ของแม่และลูกสาวคือ มอร์แกน และ คลาร่า ที่ตึงเครียดอยู่แล้ว จนกระทั่ง คริส สามีของมอร์แกนและพ่อของคลาร่า ประสบอุบัติเหตุเสียชีวิตพร้อมกับ เจนนี่ น้องสาวของมอร์แกน ทำให้ความลับในอดีตถูกเปิดเผย และทั้งสองต้องเผชิญหน้ากับความจริงที่เจ็บปวด มอร์แกนหันไปหา โจนาห์ แฟนของเจนนี่ ในขณะที่คลาร่าหันไปหา มิลเลอร์ เด็กหนุ่มที่แม่เคยห้ามไว้"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Ainoastaan sinä","runtime":0,"tagline":"Kaikki peliin, älä kadu","homepage":"","overview":"Morgan Grant ja hänen 16-vuotiaan tyttären välit ovat jännitteiset. Morgan haluaa suojella tytärtään tekemästä samoja virheitä kuin hän itse: hankkiutua raskaaksi ja mennä naimisiin hyvin nuorena. Kun Perheen isä Chris, joka on toiminut välittäjänä äidin ja tyttären välillä, menehtyy yllättäen traagisessa onnettomuudessa, Morgan ja Clara joutuvat selvittämään Chrisin jäämistöä, joka paljastaa järkyttävän ja pitkäaikaisen petoksen sekä muitakin perheen salaisuuksia. Surun ja paljastusten keskellä äiti ja tytär ajautuvat yhä kauemmas toisistaan: Morgan etsii lohtua yllättävästä tahosta, kun taas Clara hakeutuu Millerin luo, jonka tapaamisen äiti on häneltä kieltänyt. Morgan ja Clara yrittävät määritellä rakkauden merkityksen uudelleen, sekä löytää yhteys toisiinsa elämän muuttavan tragedian varjossa.\r Elokuva perustuu  Colleen Hooverin samannimiseen menestysromaaniin (suom. Ainoastaan sinä) ."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Oduvijek Ti","runtime":0,"tagline":"Riskiraj sve, ne žali ni za čim.","homepage":"","overview":"Morgan Grant i njezina kći Clara istražuju što je ostalo iza razorne nesreće koja otkriva šokantnu izdaju i prisiljava ih da se suoče s obiteljskim tajnama, redefiniraju ljubav i ponovno otkriju jedno drugo."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"ვნანობ შენთან ყოფნას","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Elrontott életek","runtime":0,"tagline":"","homepage":"","overview":"A Regretting You Colleen Hoover azonos című regényén alapul. A történet Morgan Grant (Allison Williams) és tizenéves lánya, Clara (Mckenna Grace) feszült kapcsolatát mutatja be, amelyet tovább súlyosbít Morgan férjének, Chrisnek tragikus halála. A film bemutatja, hogyan próbálják meg együtt feldolgozni a veszteséget és újraépíteni életüket. A szereplőgárdában feltűnik még Dave Franco Jonah Sullivan és Mason Thames Miller Adams szerepében.  (Csillag Lajos)"},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Pişmanım Ama","runtime":116,"tagline":"","homepage":"","overview":"Genç anne Morgan Grant  ve ergenlik çağındaki kızı Clara'nın fırtınalı ilişkisine odaklanıyor. Morgan'ın eşi Chris'in trajik ölümü, ikiliyi hayatın zorluklarına birlikte göğüs germeye iter."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Sempre Tu","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Obžalovanje","runtime":0,"tagline":"Tvrgaj vse, ne obžaluj ničesar.","homepage":"","overview":"Morgan Grant je odločena, da bo preprečila, da bi njena hči Clara storila iste napake, kot jih je sama. S tem, ko je zanosila in se poročila prezgodaj, je Morgan svoje sanje postavila na čakanje. Clara noče slediti materinim stopinjam. Njena predvidljiva mama nima v sebi niti kančka spontanosti."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Премълчани истини","runtime":120,"tagline":"","homepage":"","overview":"Премълчани истини ни запознава с Морган (Алисън Уилямс) и Клара (Макена Грейс) – майка и дъщеря, свързани от общо минало и отчуждени от неизречени истини. Когато трагичен инцидент отнема най-близките им хора, двете трябва да се изправят пред последиците – не само от смъртта, но и от разкрития, които поставят под съмнение всичко, в което вярват. Разделени от стена от мълчание, разочарование и емоционални рани, Клара бяга от болката, а Морган се опитва да я защити, като премълчава истината. Но понякога мълчанието боли повече от думите, а прошката започва там, където свършва вината."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Ångrar dig","runtime":0,"tagline":"Riskera allt. Ångra inget.","homepage":"","overview":"Tillsammans står Morgan Grant och hennes dotter Clara kvar i spillrorna efter en förödande olycka som har avslöjat ett chockerande svek. Händelsen tvingar dem att konfrontera familjehemligheter, omdefiniera vad kärlek faktiskt är och återupptäcka relationen till varandra."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"리그레팅 유","runtime":0,"tagline":"","homepage":"","overview":"여자친구가 있는 학교 인기남 ‘밀러’를 좋아하는 고등학생 ‘클라라’는 자신을 과잉보호하는 엄마 ‘모건’ 대신 이모 ‘제니’에게 의지하며 연애 상담을 이어간다. 그러던 어느날, ‘클라라’가 가장 좋아하는 제니와 아빠 ‘크리스’가 같은 날 사고로 세상을 떠나게 되고 모건과 제니의 약혼자 ‘조나’는 둘 사이의 충격적 비밀을 알게되어 분개한다. ‘모건’과 ‘조나’는 충격받을 ‘클라라’를 위해 이 사실을 숨기면서도 분노를 참을 수 없어 떠난 두 사람의 흔적을 지우려고만 하고 그로 인해 상심한 ‘클라라’를 ‘밀러’가 위로하면서 둘은 서로 가까워지게 되는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":116,"tagline":"","homepage":"","overview":"Als er na een noodlottig ongeluk een schokkend verraad aan het licht komt, worden Morgan Grant en haar dochter Clara gedwongen familiegeheimen onder ogen te zien, liefde te herdefiniëren en elkaar te herontdekken."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"为你遗憾","runtime":0,"tagline":"","homepage":"","overview":"　　一宗牵涉两条人命的严重交通意外，揭开了令人震惊的秘密；一对母女被迫面对家族的伤痕，探索爱的定义，并重新认识彼此。  　　影片改编自《爱情，到此为止》原作者科琳·胡佛的同名畅销小说。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"On te regrette","runtime":0,"tagline":"","homepage":"","overview":"Morgan Grant et sa fille Clara explorent ce qui reste après un accident dévastateur qui révèle une trahison choquante et les force à affronter des secrets de famille, à redéfinir l'amour et à se redécouvrir."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Nelituju ničeho","runtime":0,"tagline":"Riskuj všechno. Ničeho nelituj.","homepage":"","overview":"S Morgan Grantovou se život nemazlí. Právě se dozvěděla, že její manžel a sestra zahynuli při autonehodě. Do pocitu nenahraditelné ztráty se vkrádá neodbytná otázka – proč a kam ti dva spolu nezvykle jeli v témže autě? Morganin švagr Jonah řekne slovo „nevěra“ jako první. Jakmile je to slovo venku, nedá se vzít zpátky a v Morgan se smutek mísí s pocitem zklamání a zloby, zvlášť když důkazů pro své podezření nachází čím dál víc. Její osmnáctiletá dcera Clara, která nic z toho netuší, si všímá, že máma netruchlí „správně“, a má pocit, že se jí hroutí svět – o jednoho rodiče právě přišla a s druhým neustále bojuje, protože se od sebe čím dál víc vzdalují. Aby unikla domácímu dusnu, začne randit se spolužákem Millerem. Tomu ale příliš nevyhovuje, že by měl být jen „hojivou mastí“ na Clařiny rány. Chce mnohem víc."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Neľutujem nič","runtime":116,"tagline":"Od autorky Končí sa to nami","homepage":"","overview":"Neľutujem nič je rovnomenná filmová adaptácia románu jednej z najobľúbenejších spisovateliek súčasnosti, Colleen Hoover. Ponúka romantický príbeh, ktorý rozpráva o bolestivej zrade, nepredstaviteľnej strate a láske, ktorá je tým najlepším liekom na oboje."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Nožēlojot tevi","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Dintotdeauna tu","runtime":116,"tagline":"Riscă totul. Nu regreta nimic.","homepage":"","overview":"Când viața te doboară, iubirea te ridică. „Dintotdeauna tu” urmărește relația tensionată dintre tânăra mamă Morgan Grant și fiica ei adolescentă, Clara, relație și mai mult zdruncinată de moartea tragică a soțului lui Morgan, Chris, care le obligă să facă față împreună încercărilor vieții."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Μετανιώνοντας για Σένα","runtime":0,"tagline":"Διακινδύνευσε τα πάντα, δεν μετάνιωσε για τίποτα","homepage":"","overview":"Ένα μοιραίο ατύχημα ανατρέπει τη ζωή της Morgan και της κόρης της, Clara. Η προδοσία που θα αποκαλυφθεί στην πορεία θα σταθεί η αφορμή να αντιμετωπίσουν βαθιά κρυμμένα οικογενειακά μυστικά, να επαναπροσδιορίσουν την αγάπη και να ανακαλύψουν ξανά η μία την άλλη."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"در حسرت تو","runtime":0,"tagline":"","homepage":"","overview":"یک مادر و دختر باید با آنچه پس از یک حادثهٔ ویرانگر باقی مانده کنار بیایند؛ حادثه‌ای که خیانتی تکان‌دهنده را برملا می‌کند و آن‌ها را وادار می‌سازد با رازهای خانوادگی روبه‌رو شوند، معنای عشق را از نو تعریف کنند و خودشان را دوباره پیدا کنند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Jei ne tu","runtime":0,"tagline":"","homepage":"","overview":"Bestsellerio autorės Colleen Hoover ekranizacija apie tai, kaip šeimos ramybė gali slysti tarp pirštų. Morgana ir jos dukra Klara visada gyveno skirtinguose pasauliuose. Viena – pareiginga, tvarkinga namų šeimininkė, kita – maištaujanti, trokštanti laisvės paauglė. Tačiau po netikėtos avarijos, vienu metu pražudžiusios Klaros tėvą ir tetą, jų gyvenimai susiduria su ilgai slėptos išdavystės pėdsakais.  „Jei ne tu“ – jautri, bet aštri drama apie tai, kaip sunku išsaugoti ryšį, kai subyra idealios šeimos mitas. Kai širdis dūžta, o artimiausi žmonės tampa svetimi, lieka tik vienas klausimas: ar įmanoma atleisti, jei nežinai – už ką?"},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Det var altid dig","runtime":111,"tagline":"","homepage":"","overview":"Da Claras verden vendes på hovedet, er kærlighed det sidste, hun forventer, men så forandrer Miller alt. Han hjælper hende med at finde glæden igen i en kærlig fortælling om den første kærlighed, nye chancer og et bånd, der gør alting klarere."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"}],"reviews_tmdb":[{"id":"68fe189b7e635775063bf91e","url":"https://www.themoviedb.org/review/68fe189b7e635775063bf91e","author":"CinemaSerf","content":"$11","created_at":"2025-10-26T12:48:27.187Z","updated_at":"2025-10-26T12:51:47.477Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[],"similar_content":[{"id":313219,"adult":false,"title":"Grasshopper","video":false,"overview":"Movie contains the stories of three people: Suzuki (Toma Ikuta), Kujira (Tadanobu Asano) and Semi (Ryosuke Yamada).  Suzuki is a former middle school teacher. His girlfriend was killed, which led him to quit his job and attempt to take revenge on her murderer. To do so, Suzuki has to infiltrate the underground world of criminals. Kujira is a contract killer for hire. He makes his targets fall into confusion and eventually commit suicide. Semi is a contract killer who uses the knife to take out his targets.","genre_ids":[80,53,28,18],"popularity":0.6663,"vote_count":15,"poster_path":"/h9YkeTwcSnep0ZvEA6U5KtqCzb5.jpg","release_date":"2015-11-07","vote_average":5.933,"backdrop_path":"/44L1vTmftGyK0aRtKFJMAMHsEc4.jpg","original_title":"グラスホッパー","original_language":"ja"},{"id":900783,"adult":false,"title":"The Kashmir Files","video":false,"overview":"Based on a true tragedy, the emotionally triggering film sheds light on the plight of Kashmiri Pandits (Hindus), a religious minority in the 1990s Kashmir valley, who were compelled to flee their homes by the Islamic militants.","genre_ids":[36,18],"popularity":0.5583,"vote_count":85,"poster_path":"/2VvjJFDBFYkVgr89BjqbUl26QyW.jpg","release_date":"2022-03-11","vote_average":7.012,"backdrop_path":"/o0lQnIaYo5N05mfsltdl3ZCAXpa.jpg","original_title":"द कश्मीर फ़ाइल्स","original_language":"hi"},{"id":1297367,"adult":false,"title":"Remotely Killed: Behind the Scenes of Murder","video":false,"overview":"This is the 58 minutes Hulu version which contains spoiler/reveals throughout the special.","genre_ids":[9648,18],"popularity":0.1713,"vote_count":1,"poster_path":"/5XzC8T56UFNmYFtijc6ModABdtr.jpg","release_date":"2020-07-26","vote_average":10,"backdrop_path":"/rflAJ2PnTpWPofpcivpZ45yJeyC.jpg","original_title":"リモートで殺される: 殺人の裏側編","original_language":"ja"},{"id":513340,"adult":false,"title":"Animals","video":false,"overview":"Longtime friends and party lovers Laura and Tyler navigate life and love in Dublin, Ireland but find themselves drifting apart when Laura becomes engaged.","genre_ids":[35,18],"popularity":0.5487,"vote_count":51,"poster_path":"/tQyvlLavdNz8xg1vn3Dt7ZC5SnK.jpg","release_date":"2019-08-02","vote_average":5.5,"backdrop_path":"/sNJ3fBAq37dcx3rbjrMuV8S7bkQ.jpg","original_title":"Animals","original_language":"en"},{"id":705394,"adult":false,"title":"Nástup","video":false,"overview":"\"The Rally\" is based on a communist writer Vaclav Řezáč's well-written novel of the same name","genre_ids":[18],"popularity":0.1393,"vote_count":4,"poster_path":null,"release_date":"1953-05-01","vote_average":4,"backdrop_path":null,"original_title":"Nástup","original_language":"cs"},{"id":1109146,"adult":false,"title":"Jump!","video":false,"overview":"Oscar and Teo (13 and 11 years old) are two brothers, very different from each other, who will have to face the loss of their mother, a scientist obsessed with wormholes.","genre_ids":[35,10751,878,18],"popularity":1.7271,"vote_count":50,"poster_path":"/r0Vi8FA4o5fxVG76WQF3WxKmgjR.jpg","release_date":"2023-09-01","vote_average":7.2,"backdrop_path":"/bvR4HcVVpZBtChDPJeGHOoiHGuR.jpg","original_title":"¡Salta!","original_language":"es"},{"id":513409,"adult":false,"title":"Earthquake Bird","video":false,"overview":"Tokyo, Japan, 1989. Lucy Fly, a foreigner who works as a translator, begins a passionate relationship with Teiji, a mysterious man obsessed with photography.","genre_ids":[18,9648,10749,53],"popularity":0.8414,"vote_count":459,"poster_path":"/oyKnosHXQ7kkhlGwqsWOvn4RgKR.jpg","release_date":"2019-11-01","vote_average":5.932,"backdrop_path":"/rhklsYtIITDOdFSmhx2fIH9m9Vn.jpg","original_title":"Earthquake Bird","original_language":"en"},{"id":513427,"adult":false,"title":"King Lear","video":false,"overview":"An aging King invites disaster, when he abdicates to his corrupt, toadying daughters, and rejects his loving and honest one.","genre_ids":[18,10770],"popularity":3.1971,"vote_count":102,"poster_path":"/dHd0YS1PGxjfZCVbYi9Hetg7zZd.jpg","release_date":"2018-05-28","vote_average":6.064,"backdrop_path":"/rxYjrlnDWTE8OdhthCfUrEHpUBe.jpg","original_title":"King Lear","original_language":"en"},{"id":48414,"adult":false,"title":"To the Sea","video":false,"overview":"Before leaving for Rome with his mother, five year old Natan  is taken by his father, Jorge, on an epic journey to the pristine Chinchorro reef off the coast of Mexico. As they fish, swim, and sail the turquoise waters of the open sea, Natan discovers the beauty of his Mayan heritage and learns to live in harmony with life above and below the surface, as the bond between father and son grows stronger before their inevitable farewell.","genre_ids":[99,10751,18],"popularity":2.2326,"vote_count":50,"poster_path":"/kakeJZOFUONyDFTLaSxfFJuAib1.jpg","release_date":"2010-02-01","vote_average":6.89,"backdrop_path":"/yg4DNTCX1Z8onZxNOAyX95gJB5c.jpg","original_title":"Alamar","original_language":"es"},{"id":313011,"adult":false,"title":"Diary of a Rapist","video":false,"overview":"This Italian film takes a chilling, nonexploitative look into the mind of a nice young man who compulsively rapes beautiful women. The rapes are graphically presented and may be disturbing to some viewers. Outwardly Luca seems to be a normal, quiet 20-year old. His mother is frequently gone. Trouble begins when Luca becomes obsessed with Valeria, the beauty who works in the next building. He begins spying on her, and then secretly filming her with his camcorder. He tries to get to know her, but she ignores him. Unable to stand her constant refusal, the frustrated young man accosts her on dark street and rapes her. The first rape was almost accidental; he encountered her on the street and he hurt her. Unfortunately, he liked the violence and begins raping every attractive woman he sees. He is particularly violent with Lorena, a jewelry saleswoman whom he beats up in a park before violating her.","genre_ids":[18],"popularity":0.2237,"vote_count":5,"poster_path":"/yIqoKoDkPZ51ZznBN7LDAfBe5xk.jpg","release_date":"1995-02-23","vote_average":4.2,"backdrop_path":"/8BxIcFWrHj9YelOunpu57ZCZFz4.jpg","original_title":"Cronaca di un amore violato","original_language":"it"},{"id":313091,"adult":false,"title":"Ah Pook Is Here.","video":false,"overview":"A disturbingly organic-looking figure speaks to us of life, politics and death as the symbol of the common man toils away. Written and narrated by William S. Burroughs.","genre_ids":[14,18,16],"popularity":0.1395,"vote_count":8,"poster_path":"/c1g0LrBdwQF6ugpfwz6visCV7uv.jpg","release_date":"1994-10-01","vote_average":5.9,"backdrop_path":"/9p2Zwp2Umh0ZCBCpi83LhL0ZuYf.jpg","original_title":"Ah Pook Is Here.","original_language":"en"},{"id":705730,"adult":false,"title":"This Madding Crowd","video":false,"overview":"","genre_ids":[35,18],"popularity":0.3252,"vote_count":0,"poster_path":"/qTGmX7SgkpS6Ns6fKcYJW3ntpzN.jpg","release_date":"1962-06-28","vote_average":0,"backdrop_path":null,"original_title":"青べか物語","original_language":"ja"},{"id":48697,"adult":false,"title":"Salomé","video":false,"overview":"Short film by Almodovar, which tells the origin of the veil. Abraham, walking with Isaac, meets Salomé, who dances and demands Isaac’s head. Isaac flees but is hypnotised and returned. Abraham, about to act, hears God reveal it was a test of temptation. Salomé is a divine figure, and Abraham is instructed to have women cover themselves as a sign of respect.","genre_ids":[18],"popularity":0.2681,"vote_count":26,"poster_path":"/fnwp6PeI4YU4sM0j4YUuZccumyC.jpg","release_date":"1978-01-01","vote_average":5.36,"backdrop_path":"/rXCZdBdwXp4BLMysPUpTTnJyd6k.jpg","original_title":"Salomé","original_language":"es"},{"id":705862,"adult":false,"title":"Red","video":false,"overview":"A married woman with a lovely daughter lives a carefree life, until she meets her ex-lover at a friend’s wedding. They haven’t seen each other in ten years, but they begin an affair.","genre_ids":[10749],"popularity":0.8326,"vote_count":97,"poster_path":"/4KykwGCfN45vPhuNUlpey3H1ev5.jpg","release_date":"2020-02-21","vote_average":4.7,"backdrop_path":"/wD9UaqaSEYqEPa1NSdowL40LI3a.jpg","original_title":"Red","original_language":"ja"},{"id":48819,"adult":false,"title":"The Bear","video":false,"overview":"A polar bear breaks out of his enclosure to bring a little girl's teddy bear back to her. While she cares for him, the bear takes her on a magical journey. Based on Raymond Briggs' best selling storybook, this enchanting animated tale is from the makers of The Snowman.","genre_ids":[16,35,18,10751,14,10770],"popularity":0.1913,"vote_count":11,"poster_path":"/g6MsFUSFwm1SvQp2hswxgRWpptR.jpg","release_date":"1998-12-25","vote_average":5.5,"backdrop_path":"/Aef44l3M5rHpUz2MQ1xzQIowd7.jpg","original_title":"The Bear","original_language":"en"},{"id":49022,"adult":false,"title":"Something Borrowed","video":false,"overview":"Though Rachel is a successful attorney and a loyal, generous friend, she is still single. After one drink too many at her 30th-birthday celebration, Rachel unexpectedly falls into bed with her longtime crush, Dex -- who happens to be engaged to her best friend, Darcy. Ramifications of the liaison threaten to destroy the women's lifelong friendship, while Ethan, Rachel's confidant, harbors a potentially explosive secret of his own.","genre_ids":[35,18,10749],"popularity":1.9746,"vote_count":1078,"poster_path":"/66VZu75VeLGc6tcAypqyGzWcPeN.jpg","release_date":"2011-05-05","vote_average":6.237,"backdrop_path":"/pKh2qMYoC5vXaRiU0qBK3IPXk76.jpg","original_title":"Something Borrowed","original_language":"en"},{"id":49046,"adult":false,"title":"All Quiet on the Western Front","video":false,"overview":"Paul Baumer and his friends Albert and Muller, egged on by romantic dreams of heroism, voluntarily enlist in the German army. Full of excitement and patriotic fervour, the boys enthusiastically march into a war they believe in. But once on the Western Front, they discover the soul-destroying horror of World War I.","genre_ids":[10752,36,18],"popularity":7.9517,"vote_count":4524,"poster_path":"/2IRjbi9cADuDMKmHdLK7LaqQDKA.jpg","release_date":"2022-10-07","vote_average":7.722,"backdrop_path":"/zbOlpFM306PHE7EP1OELCH5qSmS.jpg","original_title":"Im Westen nichts Neues","original_language":"de"},{"id":901426,"adult":false,"title":"The White Monkey","video":false,"overview":"Two 