5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Blade of Fury\",\"description\":\"Pei Xing, known as the Jackal, once traded lives for money without emotion. After witnessing the powerful crush those fighting for justice, his sense of righteousness awakens. Now, he seeks revenge, punishing the wicked while facing off against other skilled swordsmans.\",\"image\":\"https://image.tmdb.org/t/p/w500/utyfULeHcVAwyc3uAYMDpxeTLdN.jpg\",\"datePublished\":\"2024-09-28\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Adventure\",\"Action\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.6,\"bestRating\":10,\"ratingCount\":14}}"}}],["$","$L10",null,{"initialDrama":{"id":"81663c3f-69ce-497c-a9ec-03dbb688348f","tmdb_id":1360838,"imdb_id":"tt33318665","content_type":"movie","title":"Blade of Fury","original_title":"捉刀人","overview":"Pei Xing, known as the Jackal, once traded lives for money without emotion. After witnessing the powerful crush those fighting for justice, his sense of righteousness awakens. Now, he seeks revenge, punishing the wicked while facing off against other skilled swordsmans.","poster_path":"/utyfULeHcVAwyc3uAYMDpxeTLdN.jpg","backdrop_path":"/dTsVTo5zmh9yZFGg08LmXkmPkS7.jpg","release_date":"2024-09-28","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":12,"name":"Adventure"},{"id":28,"name":"Action"}],"popularity":2.9744,"vote_average":6.6,"vote_count":14,"runtime":90,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:52:09.76362+00:00","updated_at":"2026-03-01T20:51:47.947+00:00","tagline":"","homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":172414,"name":"Beijing iQIYI Science & Technology 北京爱奇艺科技 (iQIYI)","logo_path":"/fNxBFqWr7eWEgNeBDvvCxsSItXx.png","origin_country":"CN"}],"producti