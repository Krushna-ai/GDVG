average":0},{"width":400,"height":168,"file_path":"/l1ePyahahOnPNPraxh6S2tF6RKz.png","iso_639_1":"zh","vote_average":0}],"posters":[{"width":513,"height":770,"file_path":"/8BftBKoayme0sENlu906xopbEwu.jpg","iso_639_1":"zh","vote_average":0},{"width":1840,"height":2576,"file_path":"/54jgdAsLE8Qcr8yRtaBcOAreThx.jpg","iso_639_1":"zh","vote_average":0},{"width":2000,"height":3000,"file_path":"/pq2uxqvUc3OW5QttDYd6ZbvN9lF.jpg","iso_639_1":"zh","vote_average":0},{"width":2000,"height":3000,"file_path":"/utyfULeHcVAwyc3uAYMDpxeTLdN.jpg","iso_639_1":"en","vote_average":0},{"width":598,"height":900,"file_path":"/c9bJQ1hE0O2UgUo09Zyu0YL6Tlv.jpg","iso_639_1":"ko","vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/dTsVTo5zmh9yZFGg08LmXkmPkS7.jpg","iso_639_1":null,"vote_average":3.334},{"width":2160,"height":1215,"file_path":"/8P7PsPj63pTFc8nxIlUBJ7YjrRE.jpg","iso_639_1":null,"vote_average":3.334},{"width":1808,"height":1017,"file_path":"/i1B2on4hXlTAOjtKZI5j53GGx6G.jpg","iso_639_1":null,"vote_average":3.334},{"width":1323,"height":744,"file_path":"/lYznsRXqVHTE35FHoEakbMWJFDg.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T08:30:51.167+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Blade of Fury","runtime":90,"tagline":"","homepage":"","overview":"Pei Xing, known as the Jackal, once traded lives for money without emotion. After witnessing the powerful crush those fighting for justice, his sense of righteousness awakens. Now, he seeks revenge, punishing the wicked while facing off against other skilled swordsmans."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"捉刀人","runtime":90,"tagline":"捉刀办事 拿命换钱","homepage":"","overview":"捉刀人“豺狗”裴兴 以“打不死”著称，原本冷血麻木拿命换钱的他，见证了一个个坚守正义的人被强权抹杀后，心中侠义逐渐被唤醒，他决定以牙还牙，而复仇之路上要严惩恶人外，还不得不与各路武力超群的捉刀人一决高下。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"捉刀人","runtime":0,"tagline":"","homepage":"","overview":"捉刀人“豺狗”裴興 以“打不死”著稱，原本冷血麻木拿命換錢的他，見證了一個個堅守正義的人被強權抹殺後，心中俠義逐漸被喚醒，他決定以牙還牙，而復仇之路上要嚴懲惡人外，還不得不與各路武力超群的捉刀人一決高下。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"捉刀人","runtime":0,"tagline":"","homepage":"","overview":"捉刀人“豺狗”裴興以“打不死”著稱，原本冷血麻木拿命換錢的他，見證了一個個堅守正義的人被強權抹殺後，心中俠義逐漸被喚醒，他決定以牙還牙，而複仇之路上要嚴懲惡人外，還不得不與各路武力超群的捉刀人一決高下。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"착도인","runtime":0,"tagline":"","homepage":"","overview":"자칼로 알려진 페이 싱은 한때 아무런 감정 없이 돈을 위해 생명을 거래했다. 그러나 정의를 위해 싸우는 이들이 권력자들에게 짓밟히는 것을 목격한 후, 그의 정의감이 깨어난다. 이제 그는 악을 처단하며 복수를 다짐하고, 다른 실력 있는 검객들과 대결을 벌인다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"ดาบคลั่ง","runtime":0,"tagline":"","homepage":"","overview":"\"ดาบคลั่ง\" ได้รับการอัปเกรดแล้ว นักดาบ \"หมาจิ้งจอก\" เผยซิ่ง (รับบทโดย ชื่อเสี่ยวหลง) มีชื่อเสียงเลื่องลือว่า \"ฆ่าไม่ตาย\" เขาเป็นนักฆ่าเลือดเย็นและเย็นชาที่ฆ่าเพียงเพื่อเงิน หลังจากเห็นผู้ที่ยืนหยัดเพื่อความยุติธรรมถูกกำจัดโดยผู้มีอำนาจ ความเป็นอัศวินที่แฝงอยู่ของเขาค่อย ๆ ตื่นขึ้นและเขาตัดสินใจที่จะตอบโต้ในลักษณะเดียวกัน บนเส้นทางแห่งการแก้แค้นเพื่อลงโทษผู้กระทำความชั่ว เขายังต้องแข่งขันกับนักดาบที่มีทักษะสูงหลายคนด้วย"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"تیغه خشم","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Người Tìm Đao","runtime":0,"tagline":"","homepage":"","overview":"IP \"Tróc Đao Nhân\" được nâng cấp toàn diện! Tróc đao nhân \"lang sói\" Bùi Hưng (do Thích Tiểu Long thủ vai) nổi tiếng vì \"đánh không chết\". Ban đầu, anh ta là kẻ máu lạnh, vô cảm, dùng mạng sống để đổi lấy tiền bạc. Nhưng sau khi chứng kiến từng người bảo vệ chính nghĩa bị quyền lực đàn áp, tinh thần hiệp nghĩa trong anh dần được đánh thức. Anh quyết định ăn miếng trả miếng. Trên con đường trả thù, ngoài việc trừng trị những kẻ ác, anh còn phải đối đầu với nhiều Tróc đao nhân có võ công siêu phàm."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Blade of Fury","runtime":0,"tagline":"","homepage":"","overview":"ei Xing a initialement échangé sa vie contre de l'argent en tant que chasseur de primes, mais après avoir été témoin du meurtre de personnes qui défendaient la justice, il s'est progressivement réveillé et a décidé de riposter."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Blade of Fury","runtime":0,"tagline":"","homepage":"","overview":"El cazador de cuchillos Pei Xing cambió en un principio su vida por dinero como cazarrecompensas, pero tras presenciar el asesinato de personas que defendían la justicia, fue despertando poco a poco y decidió contraatacar."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"}],"reviews_tmdb":[],"recommendations":[{"id":919207,"adult":false,"title":"12.12: The Day","video":false,"overview":"After the assassination of President Park, martial law has been declared. A coup d'état bursts out by Defense Security Commander Chun Doo-gwang and a private band of officers following him. Capital Defense Commander Lee Tae-shin, an obstinate soldier who believes the military should not take political actions, fights against Chun Doo-gwang to stop him. The conflict between the two grows while military leaders are holding their decision and Defense Minister is gone. In the midst of chaos, the spring of Seoul that everyone longed for heads to unexpected direction.","genre_ids":[18,53,28,10752,36,80],"media_type":"movie","popularity":2.899,"vote_count":142,"poster_path":"/vy14tKxsbJYdDyFl6kQuVkK2s44.jpg","release_date":"2023-11-22","vote_average":7.489,"backdrop_path":"/yOn8w3aGd6Rf9JYki7XaC9ZiyDg.jpg","original_title":"서울의 봄","original_language":"ko"},{"id":272430,"adult":false,"title":"Decotora Gal 3: Sena","video":false,"overview":"Sena has had a care-free deco-truck business, but one day, she receives a strange request by a cheap hoodlum, Takizawa, to carry a blind stripper, Azumi, to a certain location. She reluctantly accepts it, but yakuza members begin a persistent search for Takizawa, who turns out to have stolen their company’s money. Here comes the long-awaited new deco-truck series featuring the idol, Saori Hara, rolling down the highway on a ton of love, action, and steam!","genre_ids":[35,28],"media_type":"movie","popularity":0.5396,"vote_count":5,"poster_path":"/6Vb2OolA0VLVUV7rfzUfDFNxZRY.jpg","release_date":"2010-07-01","vote_average":6.1,"backdrop_path":"/cMfQYGNp7aAy6x5zSTF3jcb1Q7g.jpg","original_title":"デコトラギャル・瀬菜","original_language":"ja"},{"id":1813,"adult":false,"title":"The Devil's Advocate","video":false,"overview":"Aspiring Florida defense lawyer Kevin Lomax accepts a job at a New York law firm. With the stakes getting higher every case, Kevin quickly learns that his boss has something far more evil planned.","genre_ids":[18,9648,27],"media_type":"movie","popularity":9.2367,"vote_count":6614,"poster_path":"/5ZzBGpxy55OQzHxKVY11IpY6a0o.jpg","release_date":"1997-10-17","vote_average":7.467,"backdrop_path":"/bHjrGR0Fzn4QEBhvjiwdyMPaYVH.jpg","original_title":"The Devil's Advocate","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":29.5562,"vote_count":26800,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.902,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":21.4528,"vote_count":11363,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.036,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":297222,"adult":false,"title":"PK","video":false,"overview":"A stranger in the city asks questions no one has asked before. Known only by his initials, the man's innocent questions and childlike curiosity take him on a journey of love, laughter and letting go.","genre_ids":[35,18,878],"media_type":"movie","popularity":5.6684,"vote_count":1118,"poster_path":"/z2x2Y4tncefsIU7h82gmUM5vnBJ.jpg","release_date":"2014-12-18","vote_average":7.707,"backdrop_path":"/gxfvtq5eYiClS2X7hxAAPBNrbWA.jpg","original_title":"पीके","original_language":"hi"},{"id":9502,"adult":false,"title":"Kung Fu Panda","video":false,"overview":"Chosen by prophecy but doubted by all, Po is an unlikely Dragon Warrior—a clumsy panda thrust into the world of kung fu as a deadly enemy threatens the Valley of Peace. Guided by Master Shifu and the Furious Five, Po must embrace who he is to unlock the power that no scroll can teach.","genre_ids":[16,10751,35,28],"media_type":"movie","popularity":12.9153,"vote_count":12396,"poster_path":"/wWt4JYXTg5Wr3xBW2phBrMKgp3x.jpg","release_date":"2008-06-04","vote_average":7.314,"backdrop_path":"/qdthf9WrRDSaIkGVQGhhJ9pz1hn.jpg","original_title":"Kung Fu Panda","original_language":"en"},{"id":680,"adult":false,"title":"Pulp Fiction","video":false,"overview":"A burger-loving hit man, his philosophical partner, a drug-addled gangster's moll and a washed-up boxer converge in this sprawling, comedic crime caper. Their adventures unfurl in three stories that ingeniously trip back and forth in time.","genre_ids":[53,80,35],"media_type":"movie","popularity":23.9216,"vote_count":29708,"poster_path":"/vQWk5YBFWF4bZaofAbv0tShwBvQ.jpg","release_date":"1994-09-10","vote_average":8.5,"backdrop_path":"/96hiUXEuYsu4tcnvlaY8tEMFM0m.jpg","original_title":"Pulp Fiction","original_language":"en"},{"id":389,"adult":false,"title":"12 Angry Men","video":false,"overview":"The defense and the prosecution have rested and the jury is filing into the jury room to decide if a young Spanish-American is guilty or innocent of murdering his father. What begins as an open and shut case soon becomes a mini-drama of each of the jurors' prejudices and preconceptions about the trial, the accused, and each other.","genre_ids":[18],"media_type":"movie","popularity":10.8187,"vote_count":9751,"poster_path":"/ow3wq89wM8qd5X7hWKxiRfsFf9C.jpg","release_date":"1957-04-10","vote_average":8.556,"backdrop_path":"/w4bTBXcqXc2TUyS5Fc4h67uWbPn.jpg","original_title":"12 Angry Men","original_language":"en"},{"id":11324,"adult":false,"title":"Shutter Island","video":false,"overview":"World War II soldier-turned-U.S. Marshal Teddy Daniels investigates the disappearance of a patient from a hospital for the criminally insane, but his efforts are compromised by troubling visions and a mysterious doctor.","genre_ids":[18,53,9648],"media_type":"movie","popularity":15.0553,"vote_count":25436,"poster_path":"/nrmXQ0zcZUL8jFLrakWc90IR8z9.jpg","release_date":"2010-02-14","vote_average":8.2,"backdrop_path":"/8xt8AMb1OKC63AdhNSaYBWxB4Iq.jpg","original_title":"Shutter Island","original_language":"en"},{"id":93456,"adult":false,"title":"Despicable Me 2","video":false,"overview":"Gru is recruited by the Anti-Villain League to help deal with a powerful new super criminal.","genre_ids":[16,35,10751],"media_type":"movie","popularity":7.5099,"vote_count":11843,"poster_path":"/5Fh4NdoEnCjCK9wLjdJ9DJNFl2b.jpg","release_date":"2013-06-26","vote_average":6.942,"backdrop_path":"/fOipappvgVtUbbHOtmCkHzcwJjC.jpg","orig