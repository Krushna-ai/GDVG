atio":0.667,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/ljDBlVJXicjh3TwsECxQwY6Ts3l.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":2,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/g6pNnKmvTkNlEvn0ScwstYvhFE.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/mR616oz4oGmhaRrDfqALmtwae8o.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":2560,"height":1440,"file_path":"/bEjdGHTjKEHFq3z4g606kldLDk.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/2AlVaQDH67RgulE2AqXBSPr2POF.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/phjtKO7T7cgqKWDPBpH3m89WETb.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/35s0I0u24VG562xA4DprCyl2Rqm.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/mNVlXEBp0VS8OSlTgawOWgtcjtC.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/xXvCVMKdIYmHgysV8mm9Ini4OWK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1500,"height":844,"file_path":"/gLFvlEEKuFdJu57VpCvtcP5KkWJ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3840,"height":2160,"file_path":"/587hNfZjXpH14xVVClMXvXXUcnH.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/12QYvcCcv97QZ3UyeNCMAr70dzE.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/zBKfE3WDNrgR1irmLYUisq0pgXT.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/asIAUutQN7tQGJs6tQG7miq10nJ.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/uKdXbJjAMikaP5DFvrU82vWN6FH.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/qG6tZ5jSjSYWQaRr2SZ1aIEdeqD.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/8be1PGtBQe8OFUTWldGgZ9ygdQt.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/eg0UOUJEheKxqnpzGMzKnk5AGUT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/2N9RZ1PJG6KcPP6UlXOfGHijpZJ.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/eGOrZ3xtTPVFIrBsanCHj7g5O3b.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/xHFVWeIiMm5B40K02GTW6zO99bE.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/kRoQ2XAQOufWlqFG73sfsQ9Qlv0.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1444,"height":812,"file_path":"/94bnq8tqQI8O9isFRJlnZXf4Cmh.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1444,"height":812,"file_path":"/3VL3ULQCUgCe76H7AAdTyOyKAS1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1444,"height":812,"file_path":"/tgR5nMPXM2Bqn9KZx7NmiNh70IM.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1444,"height":812,"file_path":"/kxoRRY3DIGI1ksHka4knsPfi0yW.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T04:10:40.349+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Orphanage","runtime":105,"tagline":"A tale of love. A story of horror.","homepage":"","overview":"A woman brings her family back to her childhood home, which used to be an orphanage, intent on reopening it. Before long, her son starts to communicate with a new invisible friend."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Das Waisenhaus","runtime":102,"tagline":"","homepage":"","overview":"In einem spanischen Waisenhaus geschahen zu Zeiten Francos allerlei schreckliche Dinge. Nun will die tatkräftige Laura das Heim, den Ort ihrer Jugend, wiedereröffnen, um so unter anderem Spielkameraden für ihren sensiblen Sohn zu finden. Dieser findet auch schnell Anschluss. Allerdings bleibt zunächst fraglich, ob es sich dabei um reale Kinder oder eher um übernatürliche Wesen handelt. Als Lauras Sohn spurlos verschwindet, sieht sich Laura gezwungen, sich ihren eigenen Dämonen der Vergangenheit zu stellen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"The Orphanage","runtime":105,"tagline":"Non bisogna vedere per credere, ma credere per vedere","homepage":"","overview":"Dei bambini stanno giocando. Sono gli ospiti di un orfanotrofio e una di loro, Laura, sta per andarsene perché adottata. Divenuta adulta Laura torna in quel luogo con il marito Carlos. Vuole farlo divenire un istituto accogliente per bambini bisognosi di cure come Simon, il piccolo che ha adottato. Il bambino è affetto dall'HIV e non gli resta molto da vivere. Simon ha degli amici immaginari che però lasciano anche impronte sul terreno. Laura cerca di assecondarlo ma non riesce a togliersi di dosso la paura. Finché un giorno giunge un'anziana assistente sociale che consegna un dossier sul piccolo. La stessa donna sarà sorpresa una notte ad aggirarsi nei pressi del magazzino degli attrezzi. Qualche tempo dopo Simon, che ha scoperto la malattia di cui è affetto, scompare nel corso di una festa. Laura precipita nell'abisso dell'angoscia."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Yetimhane","runtime":0,"tagline":"Bir aşk masalı. Bir vahşet hikayesi.","homepage":"","overview":"Yıllar önce deniz kenarındaki bir yetimhanede büyüyen ve yıllar sonra bu yetimhaneyi tekrar ele alıp yine bir yuvaya dönüştürme planı olan bir kadın var. Tabi bir de Simon isminde bir çocukları var ki yanaklarını sıkasınız gelir. Fakat her şey iyi güzel derken sevimli ufaklığımız Simon, evin içinde kendine hayali arkadaşlar ediniyor ve olaylar tamamen farklılaşıyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Sirotčinec","runtime":100,"tagline":"Mrtvé děti si chtějí hrát…","homepage":"","overview":"Laura vyrůstala v sirotčinci na mořském pobřeží a po třiceti letech se spolu s manželem a synem vrací do míst dětství. Ráda by znovu otevřela opuštěný ústav jako domov pro postižené děti. Její syn se však na novém místě začíná chovat zvláštně a Laura se pomalu přesvědčuje, že starý dům má své hrůzostrašné tajemství, o kterém neměla ani potuchy!"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"L'Orphelinat","runtime":106,"tagline":"Ne racontez pas la fin...","homepage":"","overview":"Laura a passé son enfance dans un orphelinat entourée d'autres enfants qu'elle aimait comme ses frères et sœurs. Adulte, elle retourne sur les lieux avec son mari et son fils de sept ans, Simon, avec l'intention de restaurer la vieille maison. La demeure réveille l'imagination de Simon, qui commence à se livrer à d'étranges jeux avec \"ses amis\"... Troublée, Laura se laisse alors aspirer dans l'univers de Simon, convaincue qu'un mystère longtemps refoulé est tapi dans l'orphelinat..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":102,"tagline":"Un cuento de amor. Una historia de terror.","homepage":"","overview":"Laura regresa con su familia al orfanato en el que creció de niña, con la intenció de abrir una residencia para niños discapacitados. El nuevo entorno despierta la imaginació de su hijo, que comienza a dejarse llevar por juegos de fantasía cada vez más intensos. Éstos van inquietando a Laura cada vez más, hasta el punto en el que llega a pensar que hay algo en la casa que está amenazando a su familia. A ella le ocurre algo extraordinario y, a pesar de que es una mujer con unos principios muy claros, su universo se tambalea poniendo en duda todo aquello en lo que creía..."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"O Orfanato","runtime":100,"tagline":"Uma história de amor e horror.","homepage":"","overview":"Laura passou os anos mais felizes da sua infância num orfanato. Agora, trinta anos depois, ela comprou o velho prédio e mudou-se com o seu marido, Carlos, e o seu filho Simon, a fim de instalar ali um lar-abrigo para crianças deficientes. Mas a nova casa desperta a imaginação de Simon e o rapaz começa a contar um emaranhado de histórias fantásticas e de jogos pouco inocentes que começa a perturbar Laura."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Приют","runtime":0,"tagline":"","homepage":"","overview":"Самые счастливые годы Лаура провела в сиротском приюте на побережье. Любимые воспитатели заменили ей родителей, а друзья — братьев и сестер. Через тридцать лет Лаура возвращается в дом своего детства с мужем и семилетним сыном. Она мечтает восстановить его и открыть для новых маленьких посетителей. Однако героиню поразили перемены, произошедшие с ее собственным сыном.Из милого мальчика он превратился в маленького монстра с жестокими фантазиями и опасными играми. Она уверена, что во всем виноват старый дом, таящий скрытую угрозу. Постепенно картины прошлого всплывают в памяти Лауры и открывают ей страшную истину…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Árvaház","runtime":0,"tagline":"","homepage":"http://www.clubcultura.com/clubcine/clubcineastas/","overview":"Laura árvaházban nőtt fel. Harminc évvel később a férjével és a hétéves kisfiával visszatér az ódon, elhagyott épületbe. Szeretné felújíttatni a régi házat, ahol fogyatékos gyerekeket gondoznának. A sajátos környezet megmozgatja a kis Simon fantáziáját. Különösen, amikor elmondja, hogy kapcsolatba került egy szellemfiúval. Laura férje, Carlos szerint fia csupán így akarja felhívni magára a figyelmet. Az asszonyt nyugtalanítja Simon és Tomás kapcsolata, saját régi, felkavaró emlékei is előtörnek. Közeleg a megnyitó napja, Laura pedig egyre inkább úgy érzi, hogy veszélyben a családja."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Sirotinec","runtime":0,"tagline":"","homepage":"","overview":"Laura stravila najstastnejsie roky svojho detstva v sirotinci na morskom pobrezi, spolu s vychovavatelmi a spolubyvajucimi, ktory ju milovali ako vlastnu sestru. Po 30-tich rokoch sa spolu s manzelom Carlosom a ich syno Simonom vracia na toto miesto. Chce si splnit svoj sen, zrekonstruovat a znovu otvorit opusteny sirotinec ako domov pre postihnute deti. Nove zahadne prostredie vzbudi v sedemrocnom Simonovi predstavivost a v chlapcovej mysli sa zacinaju spriadat fantazijne predstavy. S bliziacim sa dnom otvorenia noveho domova narasta aj napatie v rodine. Carlos zacina byt skepticky a neveri Simonovym predstavam. Laura sa vsak pomaly presviedca, ze nieco tajomne a strasidelne sa nachadza v starom dome, nieco cakajuce na vhodnu prilezitost sposobit hrozostrasnu tragediu ich rodine."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"孤堡惊情","runtime":105,"tagline":"","homepage":"","overview":"　　劳拉自幼在孤儿院中长大，一大群小朋友天天玩着“一二三，回头看”的游戏，十分友爱。30年后，结婚成家的劳拉带着丈夫和儿子再次来到这座海岸边上的荒废已久的孤儿院，为了重温童年时温暖的回忆以及帮助更多的孤儿，他们决定重建这里。然而7岁的儿子西蒙自从搬来这屋子就开始变得不对劲，他幻想出三个不存在的小朋友嬉戏。劳拉和丈夫担心这个收养又同时患有艾滋病的儿子，劳拉的过度担心让儿子反感。他们一直不相信那些幻觉的真实性，直到一天西蒙失踪了。长达9个月的调查，劳拉开始相信鬼魂的存在，并且发现事情与自己童年时的一位护理员有关，她沉下心来，陪伴这些“孩子们”玩游戏，希望能救出西蒙。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"Laura en haar gezin keren terug naar het weeshuis waar Laura het gelukkigste deel van haar jeugd heeft doorgebracht. Met haar terugkeer heropent ze het weeshuis om zo kansarme kinderen te kunnen helpen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Barnhemmet","runtime":106,"tagline":"","homepage":"","overview":"Efter trettio år återvänder Laura tillsammans med sin make och deras 7-årige son Simón, till det hus hon växte upp i. Laura drivs av drömmen att restaurera den sedan länge övergivna byggnaden, och slå upp dess portar för handikappade barn. Men det nya hemmet och dess mystiska omgivningar väcker liv i Simóns fantasi och pojken börjar spinna ett nät av otroliga sagor och inte helt oskyldiga lekar."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Børnehjemmet","runtime":106,"tagline":"","homepage":"","overview":"Som barn tilbragte Laura seks lykkelige år på et hyggeligt børnehjem ved havet. 30 år efter flytter hun sammen med sin mand, lægen Carlos, og deres søn, den 7-årige Simon, tilbage til stedet - for at genetablere huset som et hjem for handicappede børn. Det nye hjem og de mystiske omgivelser sætter Simons fantasi i gang, og inden længe lever han i en faretruende fantasiverden befolket af spøgelser og nervepirrende reminiscenser af fortidige ugerninger. Gennem Simons fortællinger bliver Laura gradvist konfronteret med en forfærdelig hemmelighed fra sin barndom på børnehjemmet, og da Simon en dag forsvinder, udviskes grænserne mellem fantasi og virkelighed for alvor."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Sierociniec","runtime":0,"tagline":"","homepage":"","overview":"Laura spędziła dzieciństwo dorastając w sierocińcu, otoczona troskliwą opieką wychowawców i przyjaźnią dzieci, które były dla niej niczym bracia i siostry. Teraz, jako trzydziestoletnia kobieta, wraca w \"rodzinne\" strony wraz z mężem Carlosem i siedmioletnim synkiem, Simonem. Jej marzeniem jest ponowne otwarcie porzuconego przytułku i stworzenie ośrodka dla dzieci niepełnosprawnych."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Το Ορφανοτροφείο","runtime":0,"tagline":"","homepage":"","overview":"Η Λόρα έχει μεγαλώσει σε ορφανοτροφείο. Είχε μια πολύ ευτυχισμένη παιδική ηλικία και πολύ καλές σχέσεις με τα υπόλοιπα παιδιά, τα οποία και θεωρούσε αδέλφια της. Τριάντα χρόνια μετά, αυτή και ο άντρας της, μαζί με τον γιο τους Σιμόν θα μετακομίσουν στο σπίτι αυτό στο οποίο η Λόρα είχε μεγαλώσει. Θα αποφασίσει να μετατρέψει το εγκαταλελειμμένο σπίτι σε ορφανοτροφείο για παιδιά με ειδικές ανάγκες. Το σπίτι όμως θα ξυπνήσει στον Σιμόν περίεργα συναισθήματα: θα αρχίσει να έχει φανταστικούς φίλους και να παίζει φανταστικά παιχνίδια. Όλα αυτά θα φέρουν στην επιφάνεια καλά κρυμμένες αναμνήσεις από την παιδική ηλικία της Λόρα, το παιδί της θα αρχίσει να συμπεριφέρεται παράξενα και αυτό που κάποτε της φαινόταν ένα ειδυλλιακό σπίτι, θα εξελιχτεί σε εφιάλτη."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"永遠のこどもたち","runtime":0,"tagline":"ホラー,ドラマ","homepage":"","overview":"孤児院で育ったラウラ(ベレン・ルエダ)は、長らく閉鎖されていたその孤児院を買い取り、障害を持つ子どもたちのホームとして再建しようと夫のカルロス(フェルナンド・カヨ)、息子のシモン(ロジェール・プリンセプ)とともに移り住んでいた。だが、シモンは遊び相手のいない寂しさから空想上の友だちを作って遊ぶようになり、その姿にラウラは不安を覚える。そして入園希望者を集めたパーティーの日、シモンはこつ然と姿を消してしまい……。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"בית היתומים","runtime":0,"tagline":"","homepage":"","overview":"קרלוס ולורה מגדלים את בנם המאומץ סימון בבית ששימש כבית יתומים, אותו מקום שבו לורה היתומה גדלה בילדותה. סימון טוען שיש לו חמישה חברים בלתי נראים. לורה מחליטה לפתוח מחדש את הבית כבית יתומים. עד מהרה היא מתחילה לחשוד שחבריו הבלתי נראים של סימון הם לא לגמרי פרי דמיונו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"O Orfanato","runtime":105,"tagline":"Um conto de amor. Uma história de horror.","homepage":"","overview":"Laura (Belén Rueda) passou os anos mais felizes de sua vida em um orfanato, onde recebeu os cuidados de uma equipe e de outros companheiros órfãos, a quem considerava como se fossem seus irmãos e irmãs verdadeiros. Agora, 30 anos depois, ela retornou ao local com seu marido Carlos (Fernando Cayo) e seu filho Simón (Roger Príncep), de 7 anos. Ela deseja restaurar e reabrir o orfanato, que está abandonado há vários anos. O local logo desperta a imaginação de Simón, que passa a criar contos fantásticos. Entretanto à medida que os contos ficam mais estranhos Laura começa a desconfiar que há algo à espreita na casa."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"오퍼나지: 비밀의계단","runtime":0,"tagline":"30년간 감춰진 슬픈 비밀이 깨어난다!!","homepage":"","overview":"로라, 카를로스 부부와 아들 시몬은 과거 고아원이었던 대저택으로 이사를 온다. 이 고아원에서 어린시절을 보낸 로라는 병에 걸린 시몬의 건강을 돌보기 위해 외딴 바닷가에 위치한 이곳을 고집했다.  하지만 이사온지 얼마 안돼서 시몬은 이 집에 친구들이 있다며 놀러 다닌다. 더구나 친구들로부터 자신은 입양된 아이고, 곧 죽을 것이라고 들었다며 괴로워한다. 로라는 출생의 비밀을 알아버린 시몬에게 놀라워하지만, 친구들이 있다는 소리는 말도 안 되는 아이의 장난으로 여긴다.  그러던 어느 날, 시몬의 기분 전환을 위해 동네 사람들과 파티를 열게 되는데 그 파티에서 시몬은 사라지고 만다. 시간은 점점 흐르고, 모두가 시몬이 죽었다고 생각하는 가운데 로라는 시몬이 말했던 보이지 않는 친구들의 존재가 자신의 과거와 모종의 관계가 있음을 깨닫게 되는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Сиропиталището","runtime":0,"tagline":"","homepage":"","overview":"Лаура и Карлос са съпрузи, които живеят заедно с осиновения си син Симон в отдалечена къща, която преди години е била използвана като сиропиталище. След като научава, че Симон има петима нови приятели, които никой не е виждал до момента, Лаура е убедена, че това е просто част от неговото детско въображение. Но нещата започват да се променят когато Лаура отваря отново вратите на старото сиропиталище с надеждата да помогне на други осиротели деца. По време на партито за отбелязване на първия работен ден младата майка многократно забелязва мистериозно дете с маска, което никой не може да разпознае. Малко по-късно същия ден тя с ужас научава, че Симон е изчезнал безследно. Оставена без друг избор и след като започва ясно да усеща чуждо присъствие в къщата си Лаура се свързва с екип парапсихолози, чиято задача е да разгадаят мистерията и да открият местонахождението на Симон. Комедия"},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"The Orphanage","runtime":106,"tagline":"","homepage":"","overview":"Laura velger det gamle barnehjemmet der hun selv vokste opp når hun skal starte et hjem for utviklingshemmede barn. Men straks familien flytter inn, får sønnen Simon mange usynlige venner, venner som leker skattejakt uten at han egentlig vil det og forteller ham at han snart skal dø!"},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"","runtime":100,"tagline":"Un cuento de amor. Una historia de terror.","homepage":"","overview":"Laura regresa con su familia al orfanato en el que creció de niña, con la intención de abrir una residencia para niños discapacitados. El nuevo entorno despierta la imaginación de su hijo, que comienza a dejarse llevar por juegos de fantasía cada vez más intensos. Éstos van inquietando a Laura cada vez más, hasta el punto en el que llega a pensar que hay algo en la casa que está amenazando a su familia. A ella le ocurre algo extraordinario y, a pesar de que es una mujer con unos principios muy claros, su universo se tambalea poniendo en duda todo aquello en lo que creía..."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Prieglauda","runtime":0,"tagline":"","homepage":"","overview":"Praėjus 30 metų po siaubingų įvykių niekam nenaudojamą ir merdėjantį pastatą nusprenžia įsigyti čia \"gražiausius\" vaikystės metus praleidusi Laura, kuri kartu su vyru Karlosu ketina atidaryti sveikatingumo centrą neįgaliems vaikams. Keisčiausi dalykai prasideda, kai jų sūnus Simonas suranda paslaptingų draugų, kurių daugiau niekas kitas negali matyti ir girdėti. Vieną dieną Simonas kažkur paslaptingai pradingsta. Aplinkinėse gyvenvietėse greitai pasklinda gandas, kad berniuką pagrobė nuolat čia besišlaistanti moteris. Laura nujaučia, kad tai gali būti dėl skaudžios praeities nerimstančių sielų žiaurus kerštas. Mama stengiasi desperatiškai ir pasiaukojančiai ieškoti įvaikinto sūnaus, bet vis labiau įsitikina, kad į šį reikalą gali būti įsipainiojusios neįveikiamos antgamtinės jėgos. Nebūtais mistiniais dalykais netikintis Karlosas pradeda abejoti savo žmonos psichologine būsena."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"靈異孤兒院","runtime":0,"tagline":"相信，就會看見！","homepage":"","overview":"蘿拉與丈夫及七歲兒子西蒙，住進一所無人居住的孤兒院，想要重建這個荒廢已久的家園，即使這幢大宅不時傳出詭異聲響，蘿拉卻從來不以為意。直到某日，蘿拉發現西蒙交了五個「看不見」的新朋友，各種離奇的恐怖事件接連發生，包含一個頭戴恐怖面罩的怪異小孩跟著西蒙回家，或是曾闖入她家的詭異女人，某天竟橫死在她的面前。  驚覺此地內情並不單純之際，西蒙卻在此時離奇失蹤了，心急如焚的蘿拉四處尋找西蒙，卻意外在孤兒院裡挖掘出一批屍骨。究竟這所孤兒院有什麼不為人知的過去？當她更加深入探詢，這才赫然發現，在這神秘的孤兒院哩，住的並不只有他們一家人…。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"قصة حب. قصة رعب.","homepage":"","overview":"امرأة تعيد عائلتها إلى منزل طفولتها ، الذي كان دارًا للأيتام ، عازمًا على إعادة فتحه. لم يمض وقت طويل حتى بدأ ابنها في التواصل مع صديق جديد غير مرئي."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Cô Nhi Viện","runtime":0,"tagline":"","homepage":"","overview":"Sau nhiều năm xa cách, một người đàn bà nọ quyết định trở về nơi cô lớn lên, đó là một trại trẻ mồ côi xưa ven bờ biển. Và cũng từ lúc đó, đứa con nuôi của cô bắt đầu kết bạn với những đứa trẻ...vô hình"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"L'orfenat","runtime":0,"tagline":"","homepage":"","overview":"La Laura és una dona que retorna amb la seva família a l'orfenat on va créixer amb la intenció de remodelar-lo i obrir una residència per a nens amb síndrome de Down. Una vegada al lloc, el petit Simón, fill adoptiu de la Laura i que a més és portador de VIH, comença a deixar-se dur per uns estranys jocs que generen a la seva mare una gran inquietud, ja que aviat deixaran de ser una diversió per a convertir-se en una amenaça."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"凶宅兒魂","runtime":0,"tagline":"","homepage":"","overview":"自小被父母拋棄的羅拉（伯蓮露達 飾），於海邊的孤兒院裡渡過童年，老師和同學均對她寵愛有加，令她自長大以來，對此地心存著一份濃厚情意結。三十年後，羅拉與丈夫（費拿度卡路 飾）及七歲兒子西門（羅渣賓修 飾）再次回到這裡，欲重建這所荒廢已久的孤兒院，羅拉怎也沒想到，西門在這裡認識了六名新朋友而自此失蹤──孤兒院隱藏著一股不可思議的靈異力量，竟然與羅拉的過去緊緊相連！心碎的羅拉為了找回兒子蹤影，不惜一切闖越神秘凶間……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Simon ဆိုတဲ့ ၇နှစ်အရွယ်ကောင်လေးကို သူ့မိဘတွေက ကမ်းခြေတစ်ခုနားမှာ ရှိတဲ့ အိမ်ကြီးတစ်အိမ်ကို ခေါ်လာပြီး မကြာခင် တခြားကလေးတွေကိုမွေးစား ဖို့လည်း စီစဉ်နေကြပါတယ် Laura သားလေးက Simon အဖော်မဲ့နေလို့ စိတ်ကူးယဉ်သူငယ်ချင်းတွေအကြောင်း ပြောပြီး အမြဲကစားနေတာကြောင့် စိတ်ပူနေ ပါတယ် ဒါမဲ့ မွေးစားကလေးတွေရောက်လာရင် အဆင်ပြေမှာပါလို့ တွေးထားရင်း သူတို့တကယ်ရောက်လာတဲ့နေ့မှာပဲ Simon က အိမ်ထဲမှာပဲပျောက်သွားပါ တယ် ဒါနဲ့ Laura နဲ့သူ့ယောက်ျားတို့ လိုက်ရှာပေမဲ့ဘယ်လိုမှမတွေ့ပါဘူး ကလေးလေးဘယ်လိုပျောက်သွားလဲ သူတို့ ဘယ်လိုပြန်ခေါ်ကြမလဲ"},"name":"","iso_639_1":"my","iso_3166_1":"MY","english_name":"Burmese"},{"data":{"title":"Притулок","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"สถานรับเลี้ยงผี","runtime":0,"tagline":"","homepage":"","overview":"พ่อแม่ลูกที่ย้ายมาอยู่ในคฤหาสน์หลังใหญ่ที่เคยเป็นสถานเลี้ยงเด็กกำพร้าเก่ามาก่อน โดยที่พวกเขามีเหตุผลบางอย่างที่ต้องย้ายเข้ามา แต่แล้วหลังจากที่เขาอยู่ไปได้ไม่นาน ลูกชายคนเดียวของเขา ไซม่อน ก็หายตัวไปอย่างลึกลับ และไม่ว่าจะตามหายังไงก็หาไม่เจอ โดยแม่ของไซม่อนเสียใจอย่างมาก และเชื่ออย่างสุดใจว่า สิ่งที่จับตัวลูกของเธอไป ก็คือ วิญญาณของเด็กกำพร้าที่สิงอยู่ในบ้านหลังนี้ เธอจึงตัดสินใจสืบหาความจริงด้วยตัวเอง เกี่ยวกับความจริงของสถานรับเลี้ยงแห่งนี้ และเธอก็ได้พบคำตอบที่ทั้งน่าเศร้าและกระตุกขวัญในเวลาเดียวกัน !"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Orfelinatul","runtime":0,"tagline":"","homepage":"","overview":"Laura are parte de cea mai fericită zi din viața ei când reușește să cumpere și să redeschidă orfelinatul în care a crescut. Femeia descoperă că locul are un efect pozitiv asupra fiului ei: imaginația lui este tot mai dezvoltată. Dar, curând, își dă seama că jocurile pe care le joacă cu prietenul lui invizibil sunt dovada unei prezențe malefice. Când întâmplările din orfelinat amenință siguranța familiei, Laura cheamă o echipă de parapsihologi pentru a descoperi sursa acestora."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Orpokoti","runtime":107,"tagline":"","homepage":"","overview":"Laura palaa lapsuutensa orpokotiin miehensä ja 7-vuotiaan poikansa kanssa. Uuden kodin salaperäinen ympäristö herättää pojan mielikuvituksen ja hän alkaa rakentaa omaa mielikuvitusmaailmaansa ei-niin-viattomine leikkeineen. Maailmaa, joka huolestuttaa Lauraa ja herättää hänessä kauan sitten unohdettuja ja ahdistavia muistoja. Pikkuhiljaa hän vakuuttuu, että vanhassa talossa piileskelee jotain kaameaa, joka haluaa vahingoittaa hänen perhettään. Ja juuri silloin Simon katoaa…"},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Sirotište","runtime":0,"tagline":"Priča o ljubavi. Priča o užasu.","homepage":"","overview":"Laura se s obitelji vraća u svoju nekadašnju kuću, koja je nekad bila sirotište, s namjerom da je ponovno otvori. No ubrzo njezin sin počinje komunicirati s novim, nevidljivim prijateljem, što vodi ka uznemirujućim otkrićima i napetim trenucima koji će promijeniti njihove živote."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"}],"reviews_tmdb":[],"recommendations":[{"id":52274,"adult":false,"title":"Julia's Eyes","video":false,"overview":"Julia, a woman suffering from a degenerative sight disease, finds her blind sister Sara hung in a basement. Despite all signs pointing to suicide, Julia decides to investigate what she intuitively feels is a murder case.","genre_ids":[27,53],"media_type":"movie","popularity":1.1593,"vote_count":842,"poster_path":"/p9HqHVdW9oedgRMyZkBov8hDQiW.jpg","release_date":"2010-08-16","vote_average":6.656,"backdrop_path":"/18xaRN1i08zqDJWsVPpSYHLIvGL.jpg","original_title":"Los ojos de Julia","original_language":"es"},{"id":8329,"adult":false,"title":"[REC]","video":false,"overview":"A television reporter and cameraman follow emergency workers into a dark apartment building and are quickly locked inside with something terrifying.","genre_ids":[27,9648],"media_type":"movie","popularity":3.7446,"vote_count":4768,"poster_path":"/hgyJR4sgMsee6xMFM3xYiG6cDCh.jpg","release_date":"2007-11-23","vote_average":7.22,"backdrop_path":"/xfrguTH6maYiGsC8FXiQ9N3lZXw.jpg","original_title":"[REC]","original_language":"es"},{"id":575361,"adult":false,"title":"Queen of Spades: Through the Looking Glass","video":false,"overview":"The sinister ghost of the Queen of Spades is out for blood, her victims the students of an old boarding school shrouded in gloomy rumors.  Exploring the school’s abandoned wing, the teenagers discover a mirror covered in mysterious drawings.  Facing it, they playfully recite an incantation which renders their innermost desires a reality - at the expense of nothing less than their souls.","genre_ids":[27,53],"media_type":"movie","popularity":0.8649,"vote_count":179,"poster_path":"/drZ7hFMRXKYWTGd8dw9syuZeIO8.jpg","release_date":"2019-03-14","vote_average":7,"backdrop_path":"/ystlIBV89gqnbMe92xTxKSKeucV.jpg","original_title":"Пиковая дама: Зазеркалье","original_language":"ru"},{"id":1933,"adult":false,"title":"The Others","video":false,"overview":"Grace is a religious woman who lives in an old house kept dark because her two children, Anne and Nicholas, have a rare sensitivity to light. When the family begins to suspect the house is haunted, Grace fights to protect her children at any cost in the face of strange events and disturbing visions.","genre_ids":[27,9648,53],"media_type":"movie","popularity":7.0107,"vote_count":7020,"poster_path":"/p8g1vlTvpM6nr2hMMiZ1fUlKF0D.jpg","release_date":"2001-08-02","vote_average":7.618,"backdrop_path":"/rbBe9WQ1OqCxzgwskOTnaY6JdUA.jpg","original_title":"The Others","original_language":"en"},{"id":1913,"adult":false,"title":"The Sea Inside","video":false,"overview":"Ramón Sampedro is a ship mechanic and part-time poet left a quadriplegic following a diving accident. Ramón fought for 30 years for the legal right to end his own life. He develops close relationships with his long-term lawyer Julia and his friend Rosa, who tries to convince him that his life is worth living. Despite his situation, Ramón manages to inspire those around him to live life to the fullest.","genre_ids":[18],"media_type":"movie","popularity":2.7533,"vote_count":990,"poster_path":"/mQW1JJKCUg02cmWBzr9JFu9vM1V.jpg","release_date":"2004-09-03","vote_average":7.57,"backdrop_path":"/7XmDhCTkce5GH8KCdbMoTZdxn1p.jpg","original_title":"Mar adentro","original_language":"es"},{"id":10611,"adult":false,"title":"Barbershop","video":false,"overview":"A day in the life of a barbershop on the south side of Chicago. Calvin, who inherited the struggling business from his deceased father, views the shop as nothing but a burden and waste of his time. After selling the shop to a local loan shark, Calvin slowly begins to see his father's vision and legacy and struggles with the notion that he just sold it out.","genre_ids":[35,18],"media_type":"movie","popularity":2.6115,"vote_count":521,"poster_path":"/up8cEgEsl2Dq5Djb9lMZYBK0s84.jpg","release_date":"2002-04-01","vote_average":6.395,"backdrop_path":"/zsbmsV4XHyJqG5fD7Vdw4NZbT2Y.jpg","original_title":"Barbershop","original_language":"en"},{"id":15764,"adult":false,"title":"Sophie's Choice","video":false,"overview":"Stingo, a young writer, moves to Brooklyn in 1947 to begin work on his first novel. As he becomes friendly with Sophie and her lover Nathan, he learns that she is a Holocaust survivor. Flashbacks reveal her harrowing story, from pre-war prosperity to Auschwitz. In the present, Sophie and Nathan's relationship increasingly unravels as Stingo grows closer to Sophie and Nathan's fragile mental state becomes ever more apparent.","genre_ids":[18,10749,10752],"media_type":"movie","popularity":2.54,"vote_count":915,"poster_path":"/rZDPbPTFwuKgr5b9jixGFNYkGYt.jpg","release_date":"1982-12-08","vote_average":7.326,"backdrop_path":"/uiUpvnv8zgA2pm1J7tT8DPLxh84.jpg","original_title":"Sophie's Choice","original_language":"en"},{"id":507505,"adult":false,"title":"El Angel","video":false,"overview":"Buenos Aires, Argentina, 1971. Carlos Robledo Puch is a 19-year-old boy with an angelic face, but a vocational thief as well, who acts ruthlessly, without remorse. When he meets Ramón, they follow together a dark path of crime and death.","genre_ids":[18,80],"media_type":"movie","popularity":0.6879,"vote_count":569,"poster_path":"/hKtxOC2Mx9v4vx5TNJprzrFiy7.jpg","release_date":"2018-08-09","vote_average":7.4,"backdrop_path":"/gRxlzFYDKdzNnhu8OFIKm3i9b6f.jpg","original_title":"El Ángel","original_language":"es"},{"id":364116,"adult":false,"title":"The Other Side of the Door","video":false,"overview":"Grieving over the loss of her son, a mother struggles with her feelings for her daughter and her husband. She seeks out a ritual that allows her say goodbye to her dead child, opening the veil between the world of the dead and the living. Her daughter becomes the focus of terror. She must now protect against the evil that was once her beloved son.","genre_ids":[27,53],"media_type":"movie","popularity":1.3152,"vote_count":881,"poster_path":"/z5HubVaGLp1EXQbEXhg6hbEYee9.jpg","release_date":"2016-02-25","vote_average":5.561,"backdrop_path":"/k6OumxPkrJ4KuirkOU0Gw1KhzdM.jpg","original_title":"The Other Side of the Door","original_language":"en"},{"id":47886,"adult":false,"title":"Pieces","video":false,"overview":"A frustrated Boston detective searches for the maniac responsible for mutilating a number of university coeds.","genre_ids":[27,53],"media_type":"movie","popularity":1.3644,"vote_count":281,"poster_path":"/pYviMR1o0g8VMUZJK5WTvnZBS2g.jpg","release_date":"1982-08-23","vote_average":5.923,"backdrop_path":"/2ToE0hZaf16U4cM0D84L4DzQnSx.jpg","original_title":"Mil gritos tiene la noche","original_language":"es"},{"id":82779,"adult":false,"title":"El señor fotógrafo","video":false,"overview":"Cantinflas, a traveling photographer, is captured by some gangsters while trying to get some flowers for his girlfriend. The gangsters have confused him with the assistant of Dr. Penongo, a scientist who has discovered the formula of a new atomic bomb. Meanwhile, Penongo has suffered a car accident and has lost his memory ...","genre_ids":[35,53],"media_type":"movie","popularity":0.4305,"vote_count":76,"poster_path":"/rGmP5zYLDi7fokr1ndIomoqDVDl.jpg","release_date":"1953-09-02","vote_average":8.2,"backdrop_path":"/sKAQmYZjCJAsg44WoctIGbo70oM.jpg","original_title":"El señor fotógrafo","original_language":"es"},{"id":396810,"adult":false,"title":"The Last Word","video":false,"overview":"A retired businesswoman – who tries to control everything around her – decides to write her own obituary. A young journalist takes up the task of finding out the truth, and the result is a life-altering friendship.","genre_ids":[35,18],"media_type":"movie","popularity":2.1944,"vote_count":371,"poster_path":"/zvwBd0nsW5OqTs4ndEJLQY62leF.jpg","release_date":"2017-03-03","vote_average":6.613,"backdrop_path":"/sEqSMNIkxizIHW8kWKoikVYWeXF.jpg","original_title":"The Last Word","original_language":"en"},{"id":300601,"adult":false,"title":"It's Now or Never","video":false,"overview":"Narrates the preparation for a wedding of a Spanish couple in which everything goes wrong.","genre_ids":[35],"media_type":"movie","popularity":0.4243,"vote_count":183,"poster_path":"/u0spUWBehJTLqchm9oZpR0m9aDK.jpg","release_date":"2015-06-19","vote_average":5.5,"backdrop_path":"/fdJh9wgbCZWeSESTHOpX5b1B6c1.jpg","original_title":"Ahora o nunca","original_language":"es"},{"id":242606,"adult":false,"title":"Keep Watching","video":false,"overview":"A family imprisoned by intruders is forced to play a terrifying game of \"Kill, Or Be Killed\". As the night unfolds, the game's mysterious rules become clear, and the family realizes their nightmare is being streamed live to riveted viewers all over the world, who are compelled to KEEP WATCHING... not knowing if what they're seeing is real, or staged.","genre_ids":[53,27,18],"media_type":"movie","popularity":0.4761,"vote_count":293,"poster_path":"/wHsHaYUbLJNSt8T8QcFgZqy7Om.jpg","release_date":"2017-05-04","vote_average":5.051,"backdrop_path":"/u0SmCStAg5GS8Pis36RsoailrRG.jpg","original_title":"Keep Watching","original_language":"en"},{"id":35640,"adult":false,"title":"Spanish Movie","video":false,"overview":"Large doses of humor, ingenious nods to Spain's most recent national cinema, an artistic cast highly linked to comedy and a high reserve of surprises constitute the ingredients of this crazy comedy: Spanish Movie.","genre_ids":[35],"media_type":"movie","popularity":0.812,"vote_count":188,"poster_path":"/uUW7KgUKBi83kU0tlBJLYwdY4ZR.jpg","release_date":"2009-12-03","vote_average":4.995,"backdrop_path":"/cmz40N9zZWsmCJ2vSlDaCKWeqlt.jpg","original_title":"Spanish Movie","original_language":"es"},{"id":312827,"adult":false,"title":"The Nightmare","video":false,"overview":"Eight people experience sleep paralysis, a condition which leaves them unable to move, speak or react.","genre_ids":[27,99],"media_type":"movie","popularity":0.4546,"vote_count":285,"poster_path":"/ldof0L20WKBt4H6GKQ6aSHSmsk5.jpg","release_date":"2015-06-05","vote_average":5.479,"backdrop_path":"/3il3btGQIhX4PbpKaABOiWfvpzD.jpg","original_title":"The Nightmare","original_language":"en"},{"id":15774,"adult":false,"title":"Swades","video":false,"overview":"A successful Indian scientist returns home to his village to take his nanny back to America with him, and in the process rediscovers his roots.","genre_ids":[18],"media_type":"movie","popularity":0.9988,"vote_count":369,"poster_path":"/yUSL24kpHc9Nls4Pohia4shgcIM.jpg","release_date":"2004-12-17","vote_average":7.316,"backdrop_path":"/AmRfsOyEXpVhnaYXZMoDlZd9Siq.jpg","original_title":"स्वदेस","original_language":"hi"},{"id":13551,"adult":false,"title":"The Dead Girl","video":false,"overview":"The clues to a young woman's death come together as the lives of seemingly unrelated women begin to intersect.","genre_ids":[9648,18,80,53],"media_type":"movie","popularity":0.7171,"vote_count":243,"poster_path":"/wBIn93ZY0Qd3BafjSJYvqgAZu88.jpg","release_date":"2006-11-07","vote_average":6.012,"backdrop_path":"/20z5l7CEwg8aXcHhxfgk2qxlv1f.jpg","original_title":"The Dead Girl","original_language":"en"},{"id":814312,"adult":false,"title":"Maixabel","video":false,"overview":"In the year 2000, Maixabel Lasa’s husband, Juan Maria Jauregi, was killed by ETA. Eleven years later, she receives an incredible request: one of the men who killed Juan wants to meet with her in the Nanclares de la Oca prison in Araba (Spain), where he is serving his sentence after breaking ties with the terrorist group.  Despite her reservations and her immense pain, Maixabel Lasa agrees to meet face to face with those who ended the life of the person who had been her companion since she was 16 years old. ‘Everyone deserves a second chance’, she said, when asked why she was willing to confront the man who killed her husband.","genre_ids":[18],"media_type":"movie","popularity":0.4521,"vote_count":131,"poster_path":"/7lOcGma9G2yak5qB6ITwg3j0PDm.jpg","release_date":"2021-09-24","vote_average":7.034,"backdrop_path":"/7P8MrCJfAeKrzbfrv5AEU1tvJfE.jpg","original_title":"Maixabel","original_language":"es"},{"id":13825,"adult":false,"title":"The Lazarus Project","video":false,"overview":"After Ben Garvey foolishly turned back to crime, he thought his life was over when he was sentenced to death by lethal injection. But his death sentence isn't quite what it seems, as Ben regains consciousness near an eerie psychiatric ward, where he's told he's been hired as the groundskeeper. With the state of his soul in question, and the love for his wife and daughter all the more real and powerful, Ben must figure out if he's truly cheated death, or if he's become part of something far more sinister.","genre_ids":[18,53],"media_type":"movie","popularity":2.2085,"vote_count":385,"poster_path":"/qxf1AkFJskLrBM2WGwf8FpGcbiu.jpg","release_date":"2008-10-24","vote_average":5.969,"backdrop_path":"/g3aLgQI4aw7aCucYSqXM4CzNYMu.jpg","original_title":"The Lazarus Project","original_language":"en"}],"similar_content":[{"id":8060,"adult":false,"title":"Married Life","video":false,"overview":"A very gentle middle-aged man is married, but when he falls in love with another woman, he decides that to divorce his wife would humiliate her too much – so instead he decides to kill her.","genre_ids":[80,18,10749],"popularity":0.7751,"vote_count":170,"poster_path":"/AdJKmRh3AKX5CVCdwdw1dNTqEJ8.jpg","release_date":"2008-03-28","vote_average":5.753,"backdrop_path":"/fvIj8fo9j6DifyMWopHevGVhFUQ.jpg","original_title":"Married Life","original_language":"en"},{"id":470918,"adult":false,"title":"Beast","video":false,"overview":"A troubled woman living in an isolated community finds herself pulled between the control of her oppressive family and the allure of a secretive outsider suspected of a series of brutal murders.","genre_ids":[9648,80,18],"popularity":0.9469,"vote_count":326,"poster_path":"/kZdncyp1IKhEqwv5zdmUpK5Dc7S.jpg","release_date":"2018-04-18","vote_average":6.5,"backdrop_path":"/t3W767pq9rUdMXxVGzWVt2hs1Hs.jpg","original_title":"Beast","original_language":"en"},{"id":1067283,"adult":false,"title":"Still Meadows","video":false,"overview":"Washed-up horror novelist Owen Slater has hit rock bottom following his exploitation of a family's tragedy in one of his best-selling novels. But, when paranormal investigator Jack Grady recruits him for his subsequent investigation in the town of Still Meadows (the setting of Owen's book) Owen sees this as the perfect opportunity to redeem himself.","genre_ids":[27,53],"popularity":0.7835,"vote_count":0,"poster_path":"/4HbnJaIT5iQGydEni9wmnTE7v4p.jpg","release_date":"2012-05-05","vote_average":0,"backdrop_path":null,"original_title":"Still Meadows","original_language":"en"},{"id":1258917,"adult":false,"title":"Runaway","video":false,"overview":"In a poignant bid to break free from the confines of their impoverished provincial existence, five determined youths set out on a journey fueled by dreams of a better life. However, their aspirations are brutally shattered when they unwittingly fall prey to the sinister clutches of a ruthless child labor camp lurking within the bustling streets of Metro Manila. Exploited by a heartless syndicate, their innocence is ruthlessly exploited for profit.","genre_ids":[18],"popularity":0.1353,"vote_count":0,"poster_path":"/9vKIK3m1hvzuwrE0pZ5DkpRRk4b.jpg","release_date":"2024-03-13","vote_average":0,"backdrop_path":"/xLDhVqg0Kpx3M5PTQ8qKnYyTh4H.jpg","original_title":"Layas","original_language":"en"},{"id":8434,"adult":false,"title":"Summer Things","video":false,"overview":"Two couple of friends, one very rich, the other almost homeless, decide to go on Holiday. Julie, a single mother, joins them too. Once at seaside, it starts a complicate love cross among them that will involve also a transsexual, a jealous brother, a Latin Lover and another nervous stressed couple. Not to mention about the daughter of one of them that is secretly in Chicago with one of her father's employees... At the end of the summer, all of them will join the same party...","genre_ids":[35,18,10749],"popularity":0.4514,"vote_count":102,"poster_path":"/laV4Xo5O1COZefAFPJLFZ28pkYS.jpg","release_date":"2002-03-04","vote_average":5.809,"backdrop_path":"/azkp4brPsmzJiyKw5ExkPDrVpWA.jpg","original_title":"Embrassez qui vous voudrez","original_language":"fr"},{"id":8343,"adult":false,"title":"Badland","video":false,"overview":"Jerry (Jamie Draven) was an idealist when he served in the first Gulf War. But when he was later deployed to Iraq, Jerry was an older man, a father of three and embittered by broken promises and unfulfilled desires. When Jerry returns from Iraq he has been transformed by horrors that cannot be forgiven. He lives a life of poverty, his children afraid of him and his wife, Nora (Vinessa Shaw), unsympathetic and unhappy. When Jerry discovers that Nora has betrayed him, his anger and despair drive him to commit an act so heinous and irreversible that nothing he had experienced in combat could have prepared him for.","genre_ids":[18],"popularity":0.3717,"vote_count":12,"poster_path":"/yndr9Ze8TtEGkb2n5QA0egMN04a.jpg","release_date":"2007-11-30","vote_average":6,"backdrop_path":"/yMgiZ7gKHCLxWHmr8LMn3i64ehO.jpg","original_title":"Badland","original_language":"en"},{"id":1259417,"adult":false,"title":"Campton Manor","video":false,"overview":"An author tries to investigate a decades old mystery and finds himself stuck in his own ghost story.","genre_ids":[27,9648,53],"popularity":0.3031,"vote_count":7,"poster_path":"/4kNStbGiTHGFemAMaOLfUi9WSVO.jpg","release_date":"2024-05-07","vote_average":6.1,"backdrop_path":"/qzAHUTbNO0pamHja4c3OVmfPFV9.jpg","original_title":"Campton Manor","original_language":"en"},{"id":471689,"adult":false,"title":"Everything Is Free","video":false,"overview":"Ivan is a US painter residing in Colombia. His best friend, Christian, and younger brother, Cole, come to visit. Somewhere along the way, Ivan and Cole hit it off although Cole is not gay. Will older brother Christian be okay with that?","genre_ids":[35,18,10749],"popularity":0.5802,"vote_count":26,"poster_path":"/u1GV3ULs7i4LnetwweOxesXkfaK.jpg","release_date":"2017-09-03","vote_average":5.1,"backdrop_path":"/nyi66GPJnN1Q93iOzwmk5oftPze.jpg","original_title":"Everything Is Free","original_language":"en"},{"id":277956,"adult":false,"title":"The Children Nobody Wanted","video":false,"overview":"True story of Tom Butterfield and his crusade to provide family life for homeless children, becoming not only the first bachelor caretaker, but the youngest single adult to become a legal foster parent in the state of Missouri.","genre_ids":[18,10770],"popularity":0.3082,"vote_count":8,"poster_path":"/xakbOnPcOwhjakkVIIsQHvFHOLa.jpg","release_date":"1981-12-05","vote_average":5.5,"backdrop_path":null,"original_title":"The Children Nobody Wanted","original_language":"en"},{"id":471469,"adult":false,"title":"Anando Brahma","video":false,"overview":"An NRI enlists the help of his cop-friend to sell off his ancestral home, but later hears rumours of it being haunted. Unwilling to let go of the property at a throwaway price, he asks a team of four quirky guys to spend a night in the house and prove that it isn’t a ghost den.","genre_ids":[35,27,53],"popularity":0.1968,"vote_count":11,"poster_path":"/v2WyGlUieUZF7EoDjUwSfy16NSs.jpg","release_date":"2017-08-18","vote_average":6.636,"backdrop_path":"/bTAn4aI8qOSdqy9z9qg92Jl39ok.jpg","original_title":"ఆనందో బ్రహ్మ","original_language":"te"},{"id":9042,"adult":false,"title":"The Cave","video":false,"overview":"After a group of biologists discovers a huge network of unexplored caves in Romania and, believing it to be an undisturbed eco-system that has produced a new species, they hire the best American team of underwater cave explorers in the world. While exploring deeper into the underwater caves, a rockslide blocks their exit, and they soon discover a larger carnivorous creature has added them to its food chain.","genre_ids":[28,12,27,53],"popularity":3.5321,"vote_count":1004,"poster_path":"/q7eyZY2Akj68ivnRZ86OduCUexy.jpg","release_date":"2005-08-26","vote_average":5.444,"backdrop_path":"/hHhZBHknSjrtSnIEVqQtAjMBNu9.jpg","original_title":"The Cave","original_language":"en"},{"id":9339,"adult":false,"title":"Click","video":false,"overview":"A married workaholic, Michael Newman doesn't have time for his wife and children, not if he's to impress his ungrateful boss and earn a well-deserved promotion. So when he meets Morty, a loopy sales clerk, he gets the answer to his prayers: a magical remote that allows him to bypass life's little distractions with increasingly hysterical results.","genre_ids":[35,18,14],"popularity":6.4365,"vote_count":7437,"poster_path":"/oL0k5JA53PyoHSZqKb3cNkhwBCE.jpg","release_date":"2006-06-23","vote_average":6.3,"backdrop_path":"/h30q7IXCmlgR1wKLnp9LttH6BCG.jpg","original_title":"Click","original_language":"en"},{"id":9266,"adult":false,"title":"Blue Crush","video":false,"overview":"Nothing gets between Anne Marie and her board. Living in a beach shack with three roommates, she is up before dawn every morning to conquer the waves and count the days until the Pipe Masters competition. Having transplanted herself to Hawaii with no one's blessing but her own, Anne Marie finds all she needs in the adrenaline-charged surf scene - until pro quarterback Matt Tollman comes along...","genre_ids":[12,10749,18],"popularity":1.1008,"vote_count":561,"poster_path":"/iZSw0JVG0cIFuZoTHuQU3nmGT4k.jpg","release_date":"2002-08-16","vote_average":5.987,"backdrop_path":"/xsVMKdSndUKid3Xm3Tudf5bcOlv.jpg","original_title":"Blue Crush","original_language":"en"},{"id":9315,"adult":false,"title":"Flightplan","video":false,"overview":"Flying at 40,000 feet in a state-of-the art aircraft that she helped design, Kyle Pratt's 6-year-old daughter Julia vanishes without a trace. Or did she? No one on the plane believes Julia was ever onboard. And now Kyle, desperate and alone, can only count on her own wits to unravel the mystery and save her daughter.","genre_ids":[53,18,9648],"popularity":3.3539,"vote_count":2900,"poster_path":"/oNjZFzbe7PfF3TxztNHDkinOPyB.jpg","release_date":"2005-09-22","vote_average":6.451,"backdrop_path":"/59vrJSluVcM4bs9nnGMYnXX569o.jpg","original_title":"Flightplan","original_language":"en"},{"id":9003,"adult":false,"title":"Hellraiser","video":false,"overview":"A hedonistic man finds a mysterious puzzle box that summons a group of gruesome beings known as the Cenobites. These otherworldly entities open the doors to a dominion where pain and pleasure are indivisible.","genre_ids":[27,53],"popularity":4.4073,"vote_count":2803,"poster_path":"/3Z0oPHyLnk3Vx6ZMC1MiVwIrKhO.jpg","release_date":"1987-09-11","vote_average":6.877,"backdrop_path":"/j4irvwRLITgGr6vcP8NIKCUA67y.jpg","original_title":"Hellraiser","original_language":"en"},{"id":278102,"adult":false,"title":"The Shadow Within","video":false,"overview":"Little Maurice Dumont lives with his mother in a village in the mountains. His twin brother Jacques died at birth. But Maurice told that he could speak with Jacques. The doctor, Dr. Prevost and her husband, who teaches at the local school, are of the opinion that his mother's strict upbringing is not good for Maurice. One day, they discover strange injuries on him. At the same time some women of the village plan to use Maurice's ability to communicate with the dead to contact their dead relatives. But this is not a good idea ...","genre_ids":[53,27],"popularity":0.1921,"vote_count":11,"poster_path":"/nIqGCTwDPA5G77el5TiEyFaOnex.jpg","release_date":"2007-11-15","vote_average":5,"backdrop_path":null,"original_title":"The Shadow Within","original_language":"en"},{"id":9378,"adult":false,"title":"Thir13en Ghosts","video":false,"overview":"Arthur and his two children inherit his uncle's estate: a glass house that serves as a prison to twelve ghosts. When the family, accompanied by a nanny and an attorney, enter the house they find themselves trapped inside an evil machine 'designed by the Devil and powered by the dead' to open the Eye of Hell. Aided by a ghost hunter and his rival, a ghost rights activist out to set the ghosts free, the group must do what they can to get out of the house alive.","genre_ids":[27,53],"popularity":6.0218,"vote_count":2316,"poster_path":"/6yrrddjIjx0ElCRZp5pTZeqrj3k.jpg","release_date":"2001-10-26","vote_average":6.285,"backdrop_path":"/mUffUjlJ007XAzdogdZqhaqSp4O.jpg","original_title":"Thir13en Ghosts","original_language":"en"},{"id":9392,"adult":false,"title":"The Descent","video":false,"overview":"After a personal tragedy, Sarah joins her friends on a caving expedition in the Appalachian Mountains. But when a rockfall traps them deep underground, their adventure turns into a nightmare. As they search for a way out, the group discovers they are not alone—lurking in the darkness are savage, cave-dwelling creatures. With rising tension and dwindling trust, the women must fight to survive against both the predators and each other.","genre_ids":[12,27],"popularity":5.2614,"vote_count":4287,"poster_path":"/mxFPI4KYBk5ri9cPteIS8jiDFgj.jpg","release_date":"2005-07-08","vote_average":6.978,"backdrop_path":"/