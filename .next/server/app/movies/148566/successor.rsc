9:{"metadata":[["$","title","0",{"children":"Successor | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Ma Chenggang, a wealthy man in Xihong City, worries that his eldest son is too spoiled to succeed him. Determined to raise a capable successor, he takes an unconventional approach. They conceal their wealth, moving the family to a dilapidated neighborhood, and maintain an illusion of poverty, so that his son could develop qualities such as hard work, knowledge, careful budgeting, physical fitness, and perseverance."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148566/successor"}],["$","meta","5",{"property":"og:title","content":"Successor"}],["$","meta","6",{"property":"og:description","content":"Ma Chenggang, a wealthy man in Xihong City, worries that his eldest son is too spoiled to succeed him. Determined to raise a capable successor, he takes an unconventional approach. They conceal their wealth, moving the family to a dilapidated neighborhood, and maintain an illusion of poverty, so that his son could develop qualities such as hard work, knowledge, careful budgeting, physical fitness, and perseverance."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148566/successor"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/jqGZEk4sLGGmIXBDQzxTuT1lZx2.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Successor"}],["$","meta","12",{"name":"twitter:description","content":"Ma Chenggang, a wealthy man in Xihong City, worries that his eldest son is too spoiled to succeed him. Determined to raise a capable successor, he takes an unconventional approach. They conceal their wealth, moving the family to a dilapidated neighborhood, and maintain an illusion of poverty, so that his son could develop qualities such as hard work, knowledge, careful budgeting, physical fitness, and perseverance."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/jqGZEk4sLGGmIXBDQzxTuT1lZx2.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
