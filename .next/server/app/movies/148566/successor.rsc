5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Successor\",\"description\":\"Ma Chenggang, a wealthy man in Xihong City, worries that his eldest son is too spoiled to succeed him. Determined to raise a capable successor, he takes an unconventional approach. They conceal their wealth, moving the family to a dilapidated neighborhood, and maintain an illusion of poverty, so that his son could develop qualities such as hard work, knowledge, careful budgeting, physical fitness, and perseverance.\",\"image\":\"https://image.tmdb.org/t/p/w500/jqGZEk4sLGGmIXBDQzxTuT1lZx2.jpg\",\"datePublished\":\"2024-07-13\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Comedy\",null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.97,\"bestRating\":10,\"ratingCount\":82}}"}}],["$","$L10",null,{"initialDrama":{"id":"bb99bc1c-613f-488b-96d6-e934db8406f6","tmdb_id":1299537,"imdb_id":"tt32613601","content_type":"movie","title":"Successor","original_title":"抓娃娃","overview":"Ma Chenggang, a wealthy man in Xihong City, worries that his eldest son is too spoiled to succeed him. Determined to raise a capable successor, he takes an unconventional approach. They conceal their wealth, moving the family to a dilapidated neighborhood, and maintain an illusion of poverty, so that his son could develop qualities such as hard work, knowledge, careful budgeting, physical fitness, and perseverance.","poster_path":"/jqGZEk4sLGGmIXBDQzxTuT1lZx2.jpg","backdrop_path":"/9ir1UZYWBZBkgCoRUIV0ffk43Xe.jpg","release_date":"2024-07-13","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":35,"name":"Comedy"},"comedy film","drama film"],"popularity":2.5657,"vote_average":6.97,"vote_count":82,"runtime":133,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-25T23:51:09.14