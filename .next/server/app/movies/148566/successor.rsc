tG.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/v7Nv37i7YO2zegP0gor3lnadDdD.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/9ir1UZYWBZBkgCoRUIV0ffk43Xe.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/j96cyZKY8PWAY6cUDnEUAvf2KZv.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/gEJFnQ5u1FadQW5u1DWb7VjblxF.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/1VRIWknrPIRHGKtL4CXY9W3qv8U.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2160,"height":1214,"file_path":"/a6tpfh8MLtGc5PRNeQZTw1CozfF.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0}]},"enriched_at":"2026-04-21T08:40:32.078+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"抓娃娃","runtime":133,"tagline":"","homepage":"","overview":"困苦的爹，辛劳的妈，破烂的院子，破碎的他。西虹市做大做强的路上怎么把老马家落下了？！  “汤里没油，兜里没子”的马成钢（沈腾 饰）和春兰（马丽 饰），赶驴打工，家徒四壁，而儿子马继业（肖帛辰 饰）则是他们逆天改命的唯一希望。小马很争气，年年好成绩，一点不娇气，意志贼坚毅。但随着小马一天天长大，他却逐渐发现身边的人们都越来越不对劲……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Successor","runtime":133,"tagline":"","homepage":"","overview":"Ma Chenggang, a wealthy man in Xihong City, worries that his eldest son is too spoiled to succeed him. Determined to raise a capable successor, he takes an unconventional approach. They conceal their wealth, moving the family to a dilapidated neighborhood, and maintain an illusion of poverty, so that his son could develop qualities such as hard work, knowledge, careful budgeting, physical fitness, and perseverance."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"抓娃娃","runtime":0,"tagline":"","homepage":"","overview":"極速笑破 23 億票房必睇喜劇！俗語話「窮人生仔正 Poor Guy」，但竟然有對富爸媽話「生仔窮養先最乖」！？白手興家的鉅富商人馬成鋼（沈騰 飾）與老婆春蘭（馬麗 飾）為了磨練兒子馬繼業成才，決定從小窮養教仔。兩人不惜扮成辛勤打工、家徒四壁的窮等人家，更暗中建立一支教育專家團隊，全天候 24 小時潛伏兒子的日常生活，無孔不入地悉心栽培他。除了要拆解育兒路上的一個個炸彈，還要避免兒子識破真相，夫婦二人奇招百出，引爆不少荒誕笑料！隨著兒子慢慢長大，他逐漸發現身邊的人和事彷彿被一股超自然力量操控…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"抓娃娃","runtime":133,"tagline":"","homepage":"","overview":"困苦的爹，辛勞的媽，破爛的院子，破碎的他。西虹市做大做強的路上怎麼把老馬家落下了？！“湯裡沒油，口袋沒子”的馬成鋼（沈騰 飾）和春蘭（馬麗 飾），趕驢打工，家徒四壁，而兒子馬繼業（肖帛辰 飾）則是他們逆天改命的唯一希望。小馬很爭氣，年年好成績，一點不嬌氣，意志賊堅毅。但隨著小馬（史彭元 飾）一天天長大，他卻逐漸發現身邊的人們都越來越不對勁……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Миллиардер из трущоб","runtime":133,"tagline":"","homepage":"","overview":"Бедная семья переезжает из деревни в город, чтобы начать новую жизнь и поставить сына на ноги. Мальчик хорошо учится и старается изо всех сил, чтобы не разочаровать родителей, но со временем понимает, что с его родными что-то не так."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Successor","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"}],"reviews_tmdb":[],"recommendations":[{"id":1274925,"adult":false,"title":"Upstream","video":false,"overview":"A moment of impulsiveness turns Gao Zhilei into a \"stay-at-home\" individual, but he never expected his life to take a turn in the opposite direction. A series of changes compel him to take on his responsibilities as the head of the family. When life's burdens hit hard, he must confront himself and start anew.","genre_ids":[18],"media_type":"movie","popularity":1.3404,"vote_count":45,"poster_path":"/mxgOFXxwi2AkCEZbr795aQJYNKX.jpg","release_date":"2024-08-03","vote_average":6.833,"backdrop_path":"/fL1taHfNljQnbXTr6fbmrCnrCnt.jpg","original_title":"逆行人生","original_language":"zh"},{"id":67342,"adult":false,"title":"Mr. Vampire","video":false,"overview":"After the planned reburial of a village elder goes awry and the corpse resurrects into a hopping vampire, a Taoist priest and his two disciples attempt to stop him.","genre_ids":[28,35,27],"media_type":"movie","popularity":2.2545,"vote_count":132,"poster_path":"/9PxDXGCOsGiuoi0frojdErKflNX.jpg","release_date":"1985-11-07","vote_average":6.9,"backdrop_path":"/cg7EbS8B0bPMOFljWnhy3DaSdgy.jpg","original_title":"殭屍先生","original_language":"cn"},{"id":1112175,"adult":false,"title":"Never Say Never","video":false,"overview":"A former boxing champion takes decides to break a few rules and train orphans from China's remote countryside in order to give them a future.","genre_ids":[18,28],"media_type":"movie","popularity":0.7747,"vote_count":40,"poster_path":"/xj8JmcJhqShEm5pdBCpOevAjFzE.jpg","release_date":"2023-07-06","vote_average":7.25,"backdrop_path":"/ab0nzZxCQgIKN9qKcUvcTsId728.jpg","original_title":"八角笼中","original_language":"zh"},{"id":1197437,"adult":false,"title":"The Hutong Cowboy","video":false,"overview":"Zhang Beijing loss his face at his son’s engagement party. After that he refunds the sense of purpose by helping Liu Angxi, a screenwriter of the Beidiao Neighbour's talk show. However, he was pushed into the limelight after being used as material by Liu Angxi, and their friendship broke down","genre_ids":[18,35],"media_type":"movie","popularity":0.5102,"vote_count":13,"poster_path":"/rwMjHwItj3Dl4iJuGzvuY0bRrLo.jpg","release_date":"2024-10-01","vote_average":5.769,"backdrop_path":"/aVN85JU72T4np67TY3kTwtcvBAs.jpg","original_title":"爆款好人","original_language":"zh"},{"id":1255065,"adult":false,"title":"Crisis Negotiators","video":false,"overview":"Negotiator expert Cheuk Man Wai unexpectedly becomes the prime suspect in a murder case. Forced into a corner, he occupies the police station, taking officers hostage, and demands negotiations with the former negotiator Tse Ka Chun. With Tse's expertise in psychological manipulation and Check's exceptional skills, they engage in a battle of wits. As the verbal sparring deepens, their positions and mindsets gradually change.","genre_ids":[28,80,9648,53],"media_type":"movie","popularity":0.7168,"vote_count":26,"poster_path":"/3nBr1HD711Zo8pBFr5ZUDQ4Wyql.jpg","release_date":"2024-05-24","vote_average":7,"backdrop_path":"/6NDYDhszKSHdAXDY2IG3nBXSQp8.jpg","original_title":"談判專家","original_language":"cn"},{"id":1047884,"adult":false,"title":"Family Matters","video":false,"overview":"Elder sister, Spring, seeks her origins before heading to university, Autumn, the mother, grapples with conceiving a child through artificial insemination, Summer, the younger brother, tries to engage with a paternal figure he barely knows just before his military service, and Winter, the father, desperately tries to change his fate as problems mount up.","genre_ids":[18,10751],"media_type":"movie","popularity":1.8508,"vote_count":1,"poster_path":"/nmTk4v2f6d2Bgeiq049xSMV0Dgt.jpg","release_date":"2025-09-12","vote_average":7,"backdrop_path":"/bA8FtjVOQGfHoUZpK4wnOMlKSr3.jpg","original_title":"我家的事","original_language":"zh"},{"id":713262,"adult":false,"title":"Pai Gu","video":false,"overview":"Documentary following Pai Gu, a junior high school graduate from Jiangxi Province. He sells pirated DVDs of \"artistic films\" in Shenzhen to make a living.","genre_ids":[99],"media_type":"movie","popularity":0.1806,"vote_count":4,"poster_path":"/i3IF8036ln2xwmbEZ84nmUfFqm9.jpg","release_date":"2005-02-03","vote_average":7,"backdrop_path":"/iY4prc72LCWCKyRrSoDyDEFR2gg.jpg","original_title":"排骨","original_language":"zh"},{"id":1361968,"adult":false,"title":"Charge Forward","video":false,"overview":"Yang Gensi leads his team at the Chosin Reservoir to repel eight waves of attacks from the U.S. Marine Corps. With ammunition running low and few men left, he must make sacrifices to defend their position.","genre_ids":[10752,36],"media_type":"movie","popularity":0.4446,"vote_count":3,"poster_path":"/pUZcTBZqYwrI4MAsU61ixr0n4B4.jpg","release_date":"2024-09-27","vote_average":7.3,"backdrop_path":"/cyjclBNKKONwEZ0uVf2vijPeuEW.jpg","original_title":"冲锋","original_language":"zh"},{"id":1171525,"adult":false,"title":"Borrowed Time","video":false,"overview":"A late summer typhoon looms as Ting's wedding approaches. Urged on by her mother, Ting sets out from Guangzhou to Hong Kong to look for her father who has been absent for 20 years. On her trip, Ting's vague memories from the past come back to her. An unexpected encounter leads Ting to find out the truth of her family. She gets in touch with an old friend, Yuseng. They spend a night together at Yuseng's place, both feeling as if they were in a dream, searching for the lost time.","genre_ids":[18],"media_type":"movie","popularity":0.2092,"vote_count":5,"poster_path":"/acNhqh3vBUaxc6jHqHYYZkhXAOX.jpg","release_date":"2024-08-19","vote_average":7.4,"backdrop_path":"/rsNOk8w62cXMDGdDDAYj2DGr8nN.jpg","original_title":"人海同游","original_language":"zh"},{"id":45380,"adult":false,"title":"Crazy Stone","video":false,"overview":"Three thieves try to steal a valuable jade that is tightly guarded by a security chief. But the security guards are not the only obstacle these thieves are facing. An extremely unlucky internationally known master thief is also trying to get a hand on this piece of precious jade. What would be the final destination of this piece of crazy stone?","genre_ids":[28,35],"media_type":"movie","popularity":0.5789,"vote_count":139,"poster_path":"/4NVNv2sQKZKb1HtGExUqp3Ukd7f.jpg","release_date":"2006-06-30","vote_average":7.612,"backdrop_path":"/8xzVdkNPNbqT6kJA6IHaRKFpt0B.jpg","original_title":"疯狂的石头","original_language":"zh"},{"id":441531,"adult":false,"title":"Shock Wave","video":false,"overview":"When a terrorist who specializes in explosives takes hold of an underground tunnel, he threatens to kill hostages if his demands are not met.","genre_ids":[28,80,12,53],"media_type":"movie","popularity":1.3893,"vote_count":199,"poster_path":"/l4G4M6V9UrNRdbcsbnMmEZUyBGw.jpg","release_date":"2017-04-20","vote_average":6.683,"backdrop_path":"/QlbpTZRlH0eEhjWsNrBWJtfIYI.jpg","original_title":"拆彈專家","original_language":"cn"},{"id":1228891,"adult":false,"title":"Pegasus 2","video":false,"overview":"The former champion driver Zhang Chi became a driving school instructor in troubled times, living a life of relying on his reputation to make ends meet. Unexpectedly, pie in the sky falls, and the director of Laotoule Automobile Factor, who is on the verge of suspending production, offers to sponsor Zhang Chi to form a team to compete in the last Bayinbrook Rally.","genre_ids":[18,35,12],"media_type":"movie","popularity":4.6952,"vote_count":84,"poster_path":"/wGPHkBmLYtdjJpPW6ewxtejLrbd.jpg","release_date":"2024-02-10","vote_average":7.2,"backdrop_path":"/ch8rKF1a5WXFDcxi2AKfmnaMBk7.jpg","original_title":"飞驰人生2","original_language":"zh"},{"id":758891,"adult":false,"title":"Hi, Mom","video":false,"overview":"Devastated after her mom's serious accident and grief-stricken because she hasn't become the daughter she wanted to be for her mother, Jia Xiaoling finds herself transported back in time to the year 1981, where she meets her young mother before she was her mom.","genre_ids":[18,35,14],"media_type":"movie","popularity":1.7692,"vote_count":165,"poster_path":"/31W7qLEMqQKgdCeCtV9EbVi3bwG.jpg","release_date":"2021-02-12","vote_average":7.021,"backdrop_path":"/cTD9U4QLJHEL75ee1NoqIIeBc1y.jpg","original_title":"你好，李焕英","original_language":"zh"},{"id":1103621,"adult":false,"title":"How to Make Millions Before Grandma Dies","video":false,"overview":"M, a university dropout low on money and luck, volunteers to take care of his terminally ill grandmother, in the hope of pocketing an inheritance.","genre_ids":[18],"media_type":"movie","popularity":4.0637,"vote_count":366,"poster_path":"/9Xa0Grd2jq2lM2gqcoTB4F9TjMd.jpg","release_date":"2024-04-04","vote_average":8.108,"backdrop_path":"/3kvS6Ws5usxSk1wIbKZ7YPug2V2.jpg","original_title":"หลานม่า","original_language":"th"},{"id":529862,"adult":false,"title":"Brittany Runs a Marathon","video":false,"overview":"Hilarious and outgoing, Brittany Forgler, is everybody’s best friend ― except her own. Her partying, underemployment and toxic relationships are catching up with her. She receives a startling wake-up call when a visit to the doctor reveals how unhealthy she is. Motivated to lose weight, but too broke for a gym and too proud to ask for help, Brit is at a loss, until her neighbor pushes her to run one sweaty block. Soon, she sets an almost unthinkable goal: the New York City Marathon.","genre_ids":[35,18],"media_type":"movie","popularity":1.4107,"vote_count":504,"poster_path":"/aSWePCEtLpNdD7ykW6OuZqvVhyn.jpg","release_date":"2019-08-23","vote_average":6.616,"backdrop_path":"/zVBsGrA8MIx7DNeo33Ll86dKzZU.jpg","original_title":"Brittany Runs a Marathon","original_language":"en"},{"id":1249423,"adult":false,"title":"Black Dog","video":false,"overview":"On the edge of the Gobi desert in Northwest China, Lang returns to his hometown after being released from jail. While working for the local dog patrol team to clear the town of stray dogs before the Olympic Games, he strikes up an unlikely connection with a black dog. These two lonely souls embark on a journey together.","genre_ids":[18],"media_type":"movie","popularity":3.1354,"vote_count":203,"poster_path":"/dWssO0oGC6b3PtN5uarGuVp66Uv.jpg","release_date":"2024-06-15","vote_average":7.19,"backdrop_path":"/70OLwlzUhlZ8JNX4SFo5xHbX3d1.jpg","original_title":"狗阵","original_language":"zh"},{"id":6620,"adult":false,"title":"Sabrina","video":false,"overview":"After her return from school in Paris, a playboy finally takes notice of his family's chauffeur's daughter Sabrina, who's long had a crush on him, but he questions his more serious brother's motives when he warns against getting involved with her.","genre_ids":[35,10749,18],"media_type":"movie","popularity":5.8464,"vote_count":1334,"poster_path":"/e1Po9NDrH7IJZhv89467gJH5FS0.jpg","release_date":"1954-09-01","vote_average":7.5,"backdrop_path":"/oXTzokKufEGDcX7q5Cwoxlhmqxx.jpg","original_title":"Sabrina","original_language":"en"},{"id":586810,"adult":false,"title":"Mars Express","video":false,"overview":"In 2200, private detective Aline Ruby and her android partner Carlos Rivera are hired by a wealthy businessman to track down a notorious hacker. On Mars, they descend deep into the underbelly of the planet's capital city where they uncover a darker story of brain farms, political corruption, and a missing girl who holds a secret about the robots that threatens to change the face of the universe.","genre_ids":[16,878,28,9648],"media_type":"movie","popularity":3.0072,"vote_count":491,"poster_path":"/g8rUn0khoYB3G4gPPGTF1Xv9Olu.jpg","release_date":"2023-11-22","vote_average":7.459,"backdrop_path":"/yIOw17XdfsoCaydtrkzlZBCcHk6.jpg","original_title":"Mars Express","original_language":"fr"},{"id":1244492,"adult":false,"title":"Look Back","video":false,"overview":"Popular, outgoing Fujino is celebrated by her classmates for her funny comics in the class newspaper. One day, her teacher asks her to share the space with Kyomoto, a truant recluse whose beautiful artwork sparks a competitive fervor in Fujino. What starts as jealousy transforms when Fujino realizes their shared passion for drawing.","genre_ids":[16,18],"media_type":"movie","popularity":4.8427,"vote_count":494,"poster_path":"/4f2EcNkp1Mvp9wE5w7HKxcmACWg.jpg","release_date":"2024-06-28","vote_average":8.079,"backdrop_path":"/2okfik8YwzSfdETpT5cUClSiGFO.jpg","original_title":"ルックバック","original_language":"ja"},{"id":51608,"adult":false,"title":"The Man from Nowhere","video":false,"overview":"A reclusive pawnshop owner goes on a brutal rampage to rescue a young girl kidnapped by a criminal organization.","genre_ids":[28,53,80],"media_type":"movie","popularity":4.0028,"vote_count":1446,"poster_path":"/ld19CFIo27t41JXSGZdaPMUGTxh.jpg","release_date":"2010-08-04","vote_average":7.699,"backdrop_path":"/nxX9nFLDSytqfd2EaitMPa1nDRE.jpg","original_title":"아저씨","original_language":"ko"}],"similar_content":[{"id":56123,"adult":false,"title":"The Banquet","video":false,"overview":"Developer Tsang Siu Chi and his agent have bought two of a group of four properties. Rival developer Boss Hung has secured the other two. Both aim to buy all four so they can knock them down and build hotels.","genre_ids":[35],"popularity":1.8117,"vote_count":16,"poster_path":"/brEMFRhFRXmkVzKJWhQIsby8dQc.jpg","release_date":"1991-11-30","vote_average":5.6,"backdrop_path":"/nNhkcgBg6kHcfEMJDdNipU3Lywn.jpg","original_title":"豪門夜宴","original_language":"cn"},{"id":1374564,"adult":false,"title":"稲垣家の喪主","video":false,"overview":"","genre_ids":[10770,10751,35],"popularity":0.2899,"vote_count":0,"poster_path":"/s0amDMEjKxYG47zbAfqr2ZZ6oT7.jpg","release_date":"2017-03-18","vote_average":0,"backdrop_path":"/cE5DN1AXqMmHJ1nDRG9m3XCglQj.jpg","original_title":"稲垣家の喪主","original_language":"ja"},{"id":483066,"adult":false,"title":"Senior Year","video":false,"overview":"An in-depth portrayal of the university exam preparation that Chinese students undergo during their senior year of high school. For many students this exam is a ticket to a better life, so the stakes are high.","genre_ids":[99],"popularity":0.0368,"vote_count":6,"poster_path":"/fmkqaK1oFMauTHiiZpFCL56vVRK.jpg","release_date":"2005-10-31","vote_average":6.5,"backdrop_path":null,"original_title":"高三","original_language":"zh"},{"id":8046,"adult":false,"title":"Gigli","video":false,"overview":"Gigli is ordered to kidnap the psychologically challenged younger brother of a powerful federal prosecutor. When plans go awry, Gigli's boss sends in Ricki, a gorgeous free-spirited female gangster who has her own set of orders to assist with the kidnapping. But Gigli begins falling for the decidedly unavailable Ricki, which could be a hazard to his occupation.","genre_ids":[35,80,18,10749],"popularity":2.2604,"vote_count":488,"poster_path":"/qOhAK3WDqdeVTIE59loXvEGU7Lu.jpg","release_date":"2003-08-01","vote_average":4.019,"backdrop_path":"/ciIVYsDU4F4nCfrE6j6d1kCfStU.jpg","original_title":"Gigli","original_language":"en"},{"id":8048,"adult":false,"title":"When Women Lost Their Tails","video":false,"overview":"Filli and the cavemen from \"When Women Had Tails\" are living a carefree life inside a dinosaur skeleton. But when conman Ham introduces them to the concept of currency and economics, their lives fall apart. On top of that, Filli starts to fall in love with Ham.","genre_ids":[35],"popularity":0.1923,"vote_count":7,"poster_path":"/lVxKkEWXNQMiQQvdjPgBDNp6yar.jpg","release_date":"1972-02-24","vote_average":3.071,"backdrop_path":"/i4indchrng9E9Q4kNgRWL9Z4rmc.jpg","original_title":"Quando le donne persero la coda","original_language":"it"},{"id":8049,"adult":false,"title":"The Grocer's Son","video":false,"overview":"Antoine Sforza, a thirty-year-old young man, left his village ten years before in order to start a new life in the big city, but now that his father, a traveling grocer, is in hospital after a stroke, he more or less reluctantly accepts to come back to replace him in his daily rounds.","genre_ids":[18,35],"popularity":0.1737,"vote_count":49,"poster_path":"/1sHrsllHOtr1voW5Pc8dNOQIiN.jpg","release_date":"2007-06-15","vote_average":6.48,"backdrop_path":"/los2ehK8gvPdL0E7JWWIAJG7pMh.jpg","original_title":"Le Fils de l'épicier","original_language":"fr"},{"id":277270,"adult":false,"title":"To Cross the Rubicon","video":false,"overview":"Kendall (Patricia Royce) just got dumped by her boyfriend, David (J.D. Souther). But it's nothing that a much younger rock musician -- and the advice of her best friend (and David's ex-), Claire (Lorraine Devon) -- couldn't fix. Only problem is, Claire and David have rekindled their lost romance. Now, Claire and Kendall's friendship is put to the ultimate test as they try to help each other decipher men and love in this romantic comedy.","genre_ids":[10749,35],"popularity":0.2814,"vote_count":3,"poster_path":null,"release_date":"1991-01-01","vote_average":6.3,"backdrop_path":null,"original_title":"To Cross the Rubicon","original_language":"en"},{"id":8056,"adult":false,"title":"Train of Life","video":false,"overview":"In 1941, the inhabitants of a small Jewish village in Central Europe organize a fake deportation train so that they can escape the Nazis and flee to Palestine.","genre_ids":[18,35,10752],"popularity":0.9227,"vote_count":291,"poster_path":"/anUwgyVrC7kUwN5OliazbC5qBfr.jpg","release_date":"1998-09-16","vote_average":7.337,"backdrop_path":"/7QDnuj2T6CCY5wOSnKfYH7cIb6M.jpg","original_title":"Train de vie","original_language":"fr"},{"id":8057,"adult":false,"title":"Love Kills","video":false,"overview":"A masseur gets mixed up in the family plots at the mansion of a recently deceased Beverly Hills millionaire.","genre_ids":[35,10749,53],"popularity":0.3333,"vote_count":3,"poster_path":"/yBKzziT9YH5wy9danl5DUstuCEh.jpg","release_date":"1999-10-04","vote_average":2,"backdrop_path":null,"original_title":"Love Kills","original_language":"en"},{"id":8067,"adult":false,"title":"A Life Less Ordinary","video":false,"overview":"A couple of angels, O'Reilly and Jackson, are sent to Earth to make sure that their next supervised love-connection succeeds. They follow Celine, a spoiled rich girl who has just accidentally shot a suitor and, due to a misunderstanding, is kidnapped by janitor Robert. Although Celine quickly frees herself, she stays with Robert for thrills. O'Reilly and Jackson pursue, hoping to unite the prospective lovers.","genre_ids":[14,35,10749],"popularity":1.015,"vote_count":483,"poster_path":"/tk7WNEwLZepFU2yPIIkRuQOO0Q9.jpg","release_date":"1997-10-24","vote_average":6.127,"backdrop_path":"/78fqm4OGHe4a1Sl1WhX12pV8Ocr.jpg","original_title":"A Life Less Ordinary","original_language":"en"},{"id":470686,"adult":false,"title":"Mais n'te promène donc pas toute nue","video":false,"overview":"A deputy with higher political aspirations is annoyed that, as visitors come to see him, his wife insists on staying in her nightie because it is such a hot day.","genre_ids":[35],"popularity":0.2271,"vote_count":1,"poster_path":"/sVIpz838y7ldLs1tjvGsZZQDKfB.jpg","release_date":"1936-01-01","vote_average":4,"backdrop_path":"/xV4QGOY9LB9mIFQDxrES93M2gmT.jpg","original_title":"Mais n'te promène donc pas toute nue","original_language":"fr"},{"id":277296,"adult":false,"title":"Vice and Virtue","video":false,"overview":"1944 : Occupied France. Juliette (Vice) is Wehrmacht General Bamberg's mistress and enjoys a privileged life. Her younger sister  Justine (Virtue) is about to marry Jean who is in the Resistance and come to Juliette for help. Both sisters end up at \"la Commanderie\", where Juliette becomes SS Colonel Schonberg's mistress and Justine is detained with other pretty girls who must satisfy the sexual needs of high-ranking nazi officials. Inspired by \"Justine ou les infortunes de la vertu\" by the marquis de Sade","genre_ids":[18,35],"popularity":0.1858,"vote_count":14,"poster_path":"/4s6aUGjsjP3FkiC98HzWmXvA0FR.jpg","release_date":"1963-03-01","vote_average":5.4,"backdrop_path":"/zK30zKTI5QqXK43GGO73NH3d72m.jpg","original_title":"Le Vice et la Vertu","original_language":"fr"},{"id":277299,"adult":false,"title":"A Hole in One","video":false,"overview":"A gangster makes an employee pose as a doctor to prevent his troubled girlfriend from getting a lobotomy.","genre_ids":[35],"popularity":0.3062,"vote_count":4,"poster_path":"/cRLjEfAeLHUAAwzhzEfOxe7vuID.jpg","release_date":"2004-05-02","vote_average":4.5,"backdrop_path":null,"original_title":"A Hole in One","original_language":"en"},{"id":470703,"adult":false,"title":"Body Jack: Sublime Separation","video":false,"overview":"A high schooler fulfills a lifelong fantasy after a high-tech device lets him slip into the body of his childhood crush's best friend.","genre_ids":[16,35],"popularity":0.5371,"vote_count":5,"poster_path":"/yEzTCkU2eURPpxXBTFp6rHmkVJ5.jpg","release_date":"1987-01-28","vote_average":4.4,"backdrop_path":"/tq7zViUEXnVzMfaYEeVEE0zuZT3.jpg","original_title":"ボディジャック 楽しい幽体離脱","original_language":"ja"},{"id":1066928,"adult":false,"title":"Cheeseburger","video":false,"overview":"After a night of partying, Sean awakens to find that his cheeseburger from the night before has gone missing, so he reluctantly voyages with his stoner friend, Frankie to search for a suitable replacement; and that's when it all comes crashing down on the pair.","genre_ids":[35,80,53],"popularity":0.2525,"vote_count":0,"poster_path":"/wPbvmvxBSSip7inLCY0PKrIgRdU.jpg","release_date":"2010-12-10","vote_average":0,"backdrop_path":null,"original_title":"Cheeseburger","original_language":"en"},{"id":1066938,"adult":false,"title":"Natchan's Little Secret","video":false,"overview":"When three drag queens, Virgin, Moririn, and Zubuko, learn that their mentor and former drag queen, Natchan, has died suddenly, they take it upon themselves to keep the secret of her sexuality from her bereaved family.","genre_ids":[18,35],"popularity":0.219,"vote_count":1,"poster_path":"/dkDYzmrotdodevB4MQt40UEzUPj.jpg","release_date":"2023-01-13","vote_average":6.5,"backdrop_path":"/koqzwvlGRdVoeDtSBBue5zh2DjE.jpg","original_title":"ひみつのなっちゃん。","original_language":"ja"}],"external_ids":{"imdb_id":"tt32613601","twitter_id":null,"facebook_id":null,"wikidata_id":"Q126942991","instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148566,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack"