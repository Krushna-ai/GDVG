39_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/cjoPJg7Y4rVdqeWDHPEFVToK1bd.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1712,"height":964,"file_path":"/lg58nvHYW015WjWXEfpA61dt7wT.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":1.776,"vote_average":0}]},"enriched_at":"2026-02-24T22:47:32.111+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":107,"tagline":"Ready. Set. Panic.","homepage":"","overview":"A detective from Hong Kong teams up with an American gambler to battle against a notorious Chinese criminal."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Skiptrace - Missione Hong Kong","runtime":120,"tagline":"Pronti. Partenza. Panico.","homepage":"","overview":"Uno degli ultimi buoni poliziotti in giro per Hong Kong, il detective Bennie Chan, è da oltre un decennio sulle tracce del pericoloso boss Victor Wong. Quando la figlia acquisita Samantha si mette nei guai con la gang di Wong, Bennie non può far altro che rivolgersi all'unica persona che può aiutarlo: il truffaldino americano Connor Wattss, a sua volta in fuga dalla banda e da uno spietato killer russo. L'improbabile coppia intraprenderà insieme un'esilarante ma pericolosa avventura che li porterà dalle dune del deserto del Gobi alle guglie rocciose dei monti Huangshan."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Jue Di Tao Wang","runtime":107,"tagline":"","homepage":"","overview":"Een van de weinige goede agenten die er nog te vinden zijn, Bennie Black, zit al meer dan een decennium achter de gevaarlijke misdaadbaas Victor Wong aan. Wanneer zijn jonge nichtje Samantha problemen krijgt met het misdaadsyndicaat van Wong, moet hij de enige man die haar kan helpen opsporen: de Amerikaanse gokker Connor Watts."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Отпетые напарники","runtime":107,"tagline":"Коп и бандос. Крутой попадос","homepage":"","overview":"Чтобы обезвредить преступный синдикат и спасти свою племянницу, самый честный коп должен взять в напарники красавчика-афериста. Они полные противоположности, но у них одна опасная миссия. Они в бегах, но им не избежать друг друга."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":108,"tagline":"","homepage":"","overview":"Hong Kong-politimanden Bennie Chan (spillet af Jackie Chan) har i over ti år forsøgt at fange gangsteren Victor Wong, men har manglet beviser for at den respekterede forretningsmand i virkeligheden er forbryder. Da Bennies niece Samantha bliver rodet ud i problemer med Wong, må Bennie opspore den eneste der kan hjælpe hende og få Victor Wong ned med nakken, den amerikanske ludoman Connor Watts. Han har ved et uheld overværet et mord, og kan bruges som vidne mod Wong. Chan finder Watts - og de ryger ud på et farefuldt eventyr. Kan Bennie holde Watts i live?"},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"השגחה צמודה","runtime":0,"tagline":"מוכנים. היכון. הכנסו לפניקה.","homepage":"","overview":"בני צ'אן הוא אחד השוטרים הטובים היחידים שנשארו במשטרת הונג קונג. משימת חייו היא לרדוף את הפושע הערמומי ויקטור וונג. כאשר האחיינית שלו מסתבכת עם כנופייתו של וונג, הוא נחלץ לעזרתה ומאחד עם כוחות עם שותף לא שגרתי - מהמר אמריקאי פטפטן שהסתבך עם העולם התחתון."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Atrapa a un ladrón","runtime":107,"tagline":"Un Film de Renny Harlin","homepage":"","overview":"El detective de Hong Kong Bennie Black (Chan) ha estado siguiendo durante décadas a un conocido jefe de la delincuencia, Victor Wong. Cuando la joven sobrina de Bennie, Samantha, se mete en problemas con el sindicato del crimen de Wong, Bennie deberá localizar a la única persona que podrá ayudarlo: el jugador estadounidense Connor Watts (Johnny Knoxville). (FILMAFFINITY)"},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Una Pareja Dispareja","runtime":0,"tagline":"","homepage":"","overview":"El detective de Hong Kong Bennie Black ha estado siguiendo durante décadas a un conocido jefe de la delincuencia, Victor Wong. Cuando la joven sobrina de Bennie, Samantha, se mete en problemas con el sindicato del crimen de Wong, Bennie deberá localizar a la única persona que podrá ayudarlo: el jugador estadounidense Connor Watts."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"绝地逃亡","runtime":111,"tagline":"","homepage":"","overview":"香港探员陈港生（成龙饰）跟踪黑道老大维克多·王（赵文瑄饰）长达十数年，为搜集他犯罪证据而被卷入一场“计中计”中，还将自己的侄女白舒（范冰冰饰）牵扯进来。在这场被中国特警、维克多·王、俄罗斯黑帮三面夹攻的“绝地逃亡”中，班尼结识了共患难的最佳拍档康纳（约翰尼·诺克斯维尔饰），一位正被维克多·王和俄国杀手追捕逃命的美国赌博高手，三人最终将怎样结束这场冒险变得扑朔迷离。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Skiptrace","runtime":111,"tagline":"Auf die Plätze! Fertig! Panik!","homepage":"","overview":"Schon seit mehr als zehn Jahren versucht Bennie Chan (Jackie Chan), ein Ermittler aus Hong Kong, den berüchtigten Gangsterboss Victor Wong (Winston Chao) dingfest zu machen. Als sich seine Patentochter Samantha (Bingbing Fan) dann auch noch Probleme mit Wongs Gangsterbande einhandelt, spürt Chan am anderen Ende der Welt den Verantwortlichen auf: den amerikanischen Glücksspieler Connor Watts (Johnny Knoxville). Mit ihm an der Hand könnte Chan aber nicht nur Samatha retten, sondern auch endlich den langjährigen Gegenspieler zu Fall bringen, denn der Glücksspieler hat belastende Informationen über den Verbrecherboss. Jetzt muss der Ermittler Watts nur noch rechtzeitig zurück in seine Heimat bringen. Ein Wettlauf gegen die Zeit beginnt, der das ungleiche Paar quer über den Globus führt..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"스킵트레이스: 합동수사","runtime":107,"tagline":"러시아, 몽골, 중국, 홍콩, 마카오까지! 성룡, 고생길이 또 열렸다!","homepage":"","overview":"파트너의 복수를 위해 악명 높은 범죄 조직 두목을 쫓는 홍콩 경찰 베니 챈(성룡).  우연한 사건으로 파트너의 딸 사만다(판빙빙)가 범죄 조직의 함정에 빠지게 되고  그녀를 지키기 위해서는 미국에서 넘어온 전문 도박꾼 코너 왓츠(조니 녹스빌)를 러시아에서 생포해와야만 하는데…  대륙을 가로지르는 유쾌하고 화끈한 모험이 시작된다!"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Дим да ни няма","runtime":107,"tagline":"Готови. На старта. Паникьосвайте се.","homepage":"","overview":"Повече от десетилетие детективът Бени Чан е по следите на опасен мафиотски бос. Когато младата племенница на Блек, Саманта, попада в ръцете на престъпния синдикат, единственият, който може да помогне на Бени е бъбривият американски комарджия Конър Уотс. Надпреварвайки се с времето, двамата трябва да избягат от преследващите ги мафиоти и да спасят Саманта. Но дали ще успеят..."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Spašavaj se tko može","runtime":0,"tagline":"Detektiv iz Hong Konga i američki kockar suprotstavljaju se moćnom kineskom kriminalcu","homepage":"","overview":"Detektiv iz Hong Konga, Bennie Chan desetljećima prati notornog kineskog kriminalca Victora Wonga. Kada Bennijeva nećakinja upadne u nevolje s Wongovim kriminalcima, Bennie će morati pronaći jedinog čovjeka koji mu može pomoći: američkog kockara Connora Wattsa."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"La Filature","runtime":107,"tagline":"","homepage":"","overview":"Pour arrêter le patron de la pègre qui a tué son partenaire et enlevé la fille de celui-ci, un policier de Hong Kong fait équipe avec un Américain accro au jeu et futé."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Οι Σαματατζήδες","runtime":0,"tagline":"","homepage":"","overview":"Ο Ντετέκτιβ Bennie Chan (Jackie Chan) της αστυνομίας του Hong Kong προσπαθεί εδώ και 10 χρόνια να συλλάβει το διαβόητο άρχοντα του οργανωμένου εγκλήματος Victor Wong. Όταν η νεαρή ανηψιά του Samantha μπλέκεται με τη συμμορία του Victor, ο Bennie πρέπει να βρει το μοναδικό άνθρωπο που μπορεί να το βοηθήσει. Το μικροαπατεώνα και τζογαδόρο Connor Watts. Με τα χρονικά περιθώρια να στενεύουν, ο Bennie πρέπει να φέρει τον Connor στο Hong Kong και ξεκινάει για το αταίριαστο δίδυμο μια διασκεδαστική περιπέτεια από τα χιονισμένα βουνά της Μογγολίας μέχρι τις αχανείς εκτάσεις της ερήμου Gobi."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Fora do Rumo","runtime":107,"tagline":"Eles estão prontos para o caos.","homepage":"","overview":"Um policial honesto de Hong Kong que vê sua sobrinha se envolver em problemas com um criminoso que seu tio persegue há anos. O policial então é forçado a rastrear a única pessoa que pode ajudá-lo a resgatar sua sobrinha, um americano canastrão viciado em jogos de cartas e levá-lo para a China."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Detektiv z Hongkongu","runtime":107,"tagline":"","homepage":"","overview":"Detektiv Benny Black dostane za úkol najít amerického gamblera, který utíká před svými věřiteli.  Když jej najde, zjistí, že Američan je velmi upovídaný a někdy tak trochu kecá.  Jeho úkolem je však co nejdříve dostat Američana do Hong Kongu.  Cestou se z obou mužů stávají nečekaní partneři a společně naplánují, jak zničit největšího hongkongského zločince."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Detectivul, mafia și cartoforul","runtime":108,"tagline":"","homepage":"","overview":"Skiptrace e povestea lui Bennie Chan, un detectiv din Hong Kong care e pe urmele infamului șef al mafiei Victor Wong de peste un deceniu. Când nepoata lui Bennie, Samantha, intră în belele cu sindicatul crimei condus de Wong, Bennie se decide să-l găsească pe cel din cauza căruia a ajuns Samantha în această situație. Acesta e nimeni altul decât șmechreașul cartofor Connor Watts .  Dar Bennie descoperă repede că, dacă îl aduce pe Connor înapoi în Hong Kong va rezolva mai mult decât problemele nepoatei sale; Connor știe lucruri despre Victor Wong care, odată expuse, l-ar arunca pentru totdeauna după gratii pe omul de afaceri corupt.  Pornind într-o cursă contracronometru ca să-l predea pe Connor în Hong Kong, cei doi parteneri improbabili au parte de o aventură pe cât de incitantă, pe atât de periculoasă, care înconjoară tot globul, din munții Mongoliei până în deșertul Gobi."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Hongkongilaisetsivä Bennie Chan on yrittänyt napata pahamaineista rikospomoa, Victor Wongia jo vuosikausia. Kun Wongin käskyläiset alkavat kiusata Bennien sukulaistyttöä Samanthaa, on Bennien etsittävä käsiinsä ainoa mies, joka häntä voi auttaa: paljon ja nopeasti puhuva amerikkalainen uhkapeluri Connor Watts. Connorin löydyttyä epätodennäköinen taistelupari aloittaa viihdyttävän ja vaarallisen seikkailun Mongolian lumisilta vuorilta Gobin autiomaan hiekkadyyneille."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Dorwać Wattsa","runtime":107,"tagline":"","homepage":"","overview":"Detektyw Bennie Black (Jackie Chan) od lat depcze po piętach szefowi chińskiej mafii Victorowi Wongowi. Kiedy jednak mafia grozi jego pięknej siostrzenicy Bai, misja Blacka nabiera zdecydowanie bardziej osobistego charakteru. By uratować dziewczynę, detektyw musi wytropić i sprowadzić do Hong Kongu amerykańskiego hazardzistę Connora Wattsa (Johnny Knoxville). Wyrusza więc w niebezpieczną i obfitującą w zabawne przygody wyprawę, która wiodła będzie przez ośnieżone góry Mongolii po smagane wiatrem wydmy pustyni Gobi."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Відчайдушні напарники","runtime":107,"tagline":"Коп і бандос — крутий попандос","homepage":"","overview":"Щоб знешкодити злочинний синдикат і врятувати свою племінницю найчесніший коп повинен взяти в напарники красеня-афериста. Вони повні протилежності, але у них одна небезпечна місія. Вони в бігах, але їм не уникнути один одного."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Salva-te Se Puderes","runtime":107,"tagline":"Eles estão prontos para o caos","homepage":"","overview":"SALVA-TE SE PUDERES conta a história de Bennie Chan, um detetive de Hong Kong que está há mais de uma década no encalço de Victor Wong, o infame Senhor do Crime. Quando Samantha, a afilhada de Bennie, arranja problemas com uma das organizações criminosas de Wong, ele vai ter de encontrar o homem responsável por causar esta situação: o matreiro jogador americano Connor Watts. Bennie rapidamente descobre que Connor sabe mais do que ele pensava. Para além de poder ser a chave para o salvamento de Samantha, o americano está também na posse de informações sobre Victor Wong que, se divulgadas, podem finalmente trazer o empresário corrupto face a face com a justiça. À medida que Bennie tenta desesperadamente regressar a Hong Kong com Connor, este improvável duo embarca numa divertida e perigosa aventura que os leva desde as montanhas da Mongólia até ao Deserto de Gobi."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Skiptrace - A zűrös páros","runtime":0,"tagline":"","homepage":"","overview":"Bennie Chan hongkongi nyomozó nagyon szeretné elkapni a kínai gengszterfőnököt, Victor Wongot. Amikor keresztlánya is belekeveredik a maffia ügyeibe, Bennie Chan szövetkezik azzal az amerikai szerencsejátékossal, aki miatt ez megtörténhetett. Együtt készülnek leszámolni a hírhedt maffiafőnökkel."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Toz Ol","runtime":0,"tagline":"Yerlerinize. Hazır. Panikleyin.","homepage":"","overview":"Hong Kong’lu bir dedektif olan Bennie Chan, 10 yılı aşkın müddettir kötü ünüyle çevreye korku saçan mafya öncüsü Victor Wong’un peşindedir. Chan’in talihsiz yeğeninin başı bir gün Wong’un mafyası ile derde girer ve işlenen bir cinayette çok ehemmiyetli bir şahit olan Amerikalı kumarbaz Connor Watts’ı bulması gerekir. Birbirine tamamiyle tam ters bu iki karakter bir araya geldiğinde ise eğlenceli bir serüven başlayacaktır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"คู่ใหญ่สั่งมาฟัด","runtime":0,"tagline":"","homepage":"","overview":"คู่ใหญ่สั่งมาฟัด เล่าเรื่องของ เบนนี่ ชาน (เฉินหลง Jackie Chan) สายสืบชาวฮ่องกงที่กำลังตามล่าหัวหน้าแก๊งมาเฟียนามว่าวิคเตอร์ หว่อง (วินสตันส เชา Winston Chao) มานานกว่าทศวรรษ เมื่อหลานสาวของเขา ซาแมนธา (ฟ่านปิงปิง Fan BingBing) ต้องไปพัวพันกับองค์กรมาเฟียของหว่อง ซึ่งคนที่มีหลักฐานสามารถสาวถึงตัวเจ้าพ่อได้ นั่นคือนักพนันชาวอเมริกันจอมปากมาก คอนเนอร์ วัตส์(จอห์นนี่ น็อกซ์วิลล์ Johnny Knoxville) แต่ดันโดนแกงค์มาเฟียจับไป รัสเซีย ซึ่งเขาต้องการจะกลับ มาเก๊า ดังนั้นเบนนี่ จึงตามไปช่วยเหลือ คอนเนอร์ เพื่อเป็นพยานลากคอวิคเตอร์มาลงโทษ และช่วยเหลือซาแมนธาให้ได้ ภารกิจฟัด พ่วงความมันข้ามพรมแดนตั้งแต่เทือกเขาในมองโกเลียจนถึงทะเลทรายโกบี เรื่อยมาถึง มาเก๊า จึงอุบัติขึ้น"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"絕地逃亡","runtime":0,"tagline":"","homepage":"","overview":"香港探員陳港生（成龍飾）跟蹤黑道老大維克多•王（趙文瑄飾）長達十數年，為搜集他犯罪證據而被捲入一場“計中計”中，還將自己的侄女白舒（範冰冰飾）牽扯進來。在這場被中國特警、維克多•王、俄羅斯黑幫三面夾攻的“絕地逃亡”中，班尼結識了共患難的最佳拍檔康納（約翰尼•諾克斯維爾飾），一位正被維克多•王和俄國殺手追捕逃命的美國賭博高手，三人最終將怎樣結束這場冒險變得撲朔迷離。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Hongkong-polisen Bennie har jagat den farliga gangsterbossen Victor Wong i över ett decennium. När Bennies guddotter Samantha hamnar i problem med Wongs brottssyndikat måste han leta upp den enda man som kan hjälpa henne: den munvige amerikanske skojaren Connor. Det omaka paret ger sig ut på ett hisnande roligt actionäventyr från Gobiöknens vindpinade sanddynor, till Huangshans vassa bergsspiror."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"スキップ・トレース","runtime":0,"tagline":"","homepage":"","overview":"香港警察の刑事ベニーは黒社会の大物ウォンを追う中で同僚ヤンを殺され、そのひとり娘サマンサの後見人になる。9年後、強引な捜査が問題視されたベニーは停職処分を受けるが、マカオのカジノで働くサマンサを騙して荒稼ぎした米国人詐欺師ワッツを捕まえんとロシアへ。実はワッツはウォン逮捕を可能にする重要人物であると同時に、数々の犯罪組織に命を狙われていた。ベニーとワッツは、中国を横切るルートで香港に向かう。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"絕地逃亡","runtime":0,"tagline":"","homepage":"","overview":"香港探員陳港生（成龍飾）跟蹤黑道老大維克多•王（趙文瑄飾）長達十數年，為蒐集他犯罪證據而被捲入一場“計中計”中，還將自己的侄女白舒（範冰冰飾）牽扯進來。在這場被中國特警、維克多•王、俄羅斯黑幫三面夾攻的“絕地逃亡”中，班尼結識了共患難的最佳拍檔康納（約翰尼•諾克斯維爾飾），一位正被維克多•王和俄國殺手追捕逃命的美國賭博高手，三人最終將怎樣結束這場冒險變得撲朔迷離。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Les 2 de pique","runtime":107,"tagline":"Prêt. Prêt. Panique.","homepage":"","overview":"Pour arrêter le patron de la pègre qui a tué son partenaire et enlevé la fille de celui-ci, un policier de Hong Kong fait équipe avec un Américain accro au jeu et futé."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Detektív z Hongkongu","runtime":0,"tagline":"","homepage":"","overview":"Detektív Benny Black dostane za úlohu nájsť amerického gamblera, ktorý uteká pred svojimi veriteľmi. Keď ho nájde, zistí, že Američan je veľmi ukecaný a niekedy tak trochu kecá. Jeho úlohou je však, čo najskôr dostať Američana do Hong Kongu. Cestou sa z oboch mužov stávajú nečakaní partneri a spoločne naplánujú, ako zničiť najväčšieho hongkongského zločinca."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"تقفي الأثر","runtime":0,"tagline":"","homepage":"","overview":"تدور أحداث الفيلم حول المحقق بيني بلاك (جاكي شان) من هونج كونج الذي تتورط ابنة أحد أشقائه في مشاكل مع عصابات سيئة السمعة، والرجل الوحيد الذي سيتمكن من مساعدة بلاك هو المقامر الأمريكي كونور واتس (جوني نوكسفيل) الذي يتكلم بسرعة فائقة ويتصرف بتهور شديد، ويدخلا في سباق مع الزمن."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Tẩu Thoát Ngoạn Mục","runtime":0,"tagline":"","homepage":"","overview":"Một thám tử từ Hồng Kông hợp tác với một con bạc người Mỹ để chiến đấu chống lại một tên tội phạm khét tiếng người Trung Quốc."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"}],"reviews_tmdb":[{"id":"581cf88d925141370f0013d8","url":"https://www.themoviedb.org/review/581cf88d925141370f0013d8","author":"Reno","content":"$11","created_at":"2016-11-04T21:07:25.022Z","updated_at":"2024-05-16T15:18:31.501Z","author_details":{"name":"Reno","rating":4,"username":"Rangan","avatar_path":"/6ZpVUJzqXMzH35VprEtnX0sNI3.jpg"}}],"recommendations":[{"id":377447,"adult":false,"title":"Railroad Tigers","video":false,"overview":"A railroad worker in China in 1941 leads a team of freedom fighters against the Japanese in order to get food for the poor.","genre_ids":[28,12,35,10751,10752],"media_type":"movie","popularity":1.5863,"vote_count":148,"poster_path":"/1aSkP9geZCbqIoxjF7Jy9dT8UfY.jpg","release_date":"2016-12-23","vote_average":6.071,"backdrop_path":"/ygcbiJgTQMjnoSLyzKLmzR7u3gN.jpg","original_title":"铁道飞虎","original_language":"zh"},{"id":360339,"adult":false,"title":"Eden","video":false,"overview":"After their plane crashes off the coast of a deserted Pacific island, the surviving members of an American soccer team find themselves in the most dire of circumstances with limited resources, dwindling food supply and no rescue coming any time soon.  Team spirit evaporates as disagreements cause the group to separate into factions - a violent one lead by an unbalanced ruler, and a compassionate one led by a selfless player.","genre_ids":[53,18],"media_type":"movie","popularity":1.2094,"vote_count":66,"poster_path":"/nVtCuhdg1mYjMMFdUKqijgrAWAS.jpg","release_date":"2015-09-18","vote_average":5.1,"backdrop_path":"/xlkojbJMcuEPoZlBEciH36wQcze.jpg","original_title":"Eden","original_language":"en"},{"id":501591,"adult":false,"title":"Born a King","video":false,"overview":"A coming-of-age story set in 1919 about 14 year old Faisal, an Arab prince who is dispatched from the deserts of Arabia to London by his warrior father, Prince Abd Al-Aziz, on a high stakes diplomatic mission to secure the formation of his country.","genre_ids":[18,36],"media_type":"movie","popularity":0.6349,"vote_count":22,"poster_path":"/hx3aLmbP9mBDaS5gQpO1fssMOC6.jpg","release_date":"2019-04-25","vote_average":7.4,"backdrop_path":"/6JRaX5GAHkhi4zORy4LdWkT5xra.jpg","original_title":"ولد ملكًا","original_language":"ar"},{"id":397074,"adult":false,"title":"My Name Is Bernadette","video":false,"overview":"Between February and July 1858, in the Massabielle cave, the Virgin appeared eighteen times to Bernadette Soubirous, a miserable little girl from Lourdes. A true revolution in the heart of the Second Empire that shakes the established order by his universal message of love and prayer.","genre_ids":[18],"media_type":"movie","popularity":0.4795,"vote_count":22,"poster_path":"/rOk6PCpKKoN9XQW84yR9YuSVpbA.jpg","release_date":"2011-11-30","vote_average":7.455,"backdrop_path":"/aCm0uFKkHTYnKAdZhBzfeBomw4a.jpg","original_title":"Je m'appelle Bernadette","original_language":"fr"},{"id":17821,"adult":false,"title":"Crossworlds","video":false,"overview":"College good guy Joe is drawn into a battle to save the world from arch-enemy Ferris. Joe's heirloom pendant just happens to be the key to the staff that opens doors to the Crossworlds. When Laura shows up to check on the key and Ferris' goons begin their assaults, they run to semi-retired adventurer A.T. for help and guidance.","genre_ids":[28,878,35],"media_type":"movie","popularity":0.5895,"vote_count":60,"poster_path":"/A2aqbMX7EoYg23NfD6lCusZrZyR.jpg","release_date":"1996-02-14","vote_average":5.075,"backdrop_path":"/jtgge9V7Z71cDRkQKTIGcdwd2By.jpg","original_title":"Crossworlds","original_language":"en"},{"id":303601,"adult":false,"title":"Naughty & Nice","video":false,"overview":"A cynical radio host is banished to Colorado, where he has an on-air spat with a hopeless romantic. Soon, their antagonistic relationship sparks the interest of the whole town.","genre_ids":[10749,10770],"media_type":"movie","popularity":2.2151,"vote_count":51,"poster_path":"/rKEge46QIXAzZiclJbMI4UEF69F.jpg","release_date":"2014-11-09","vote_average":6.176,"backdrop_path":"/Ww7giejmMP9S1WOOdS0NWGW1Pw.jpg","original_title":"Naughty & Nice","original_language":"en"},{"id":299078,"adult":false,"title":"SpongeBob's Frozen Face-Off","video":true,"overview":"All of Bikini Bottom enters a sleigh race to win $1 million. While racing, they are attacked by the abominable snow mollusk. Plankton takes advantage of everyone being gone to steal the Krabby Patty secret formula.","genre_ids":[10751,16,35,10770],"media_type":"movie","popularity":0.289,"vote_count":16,"poster_path":"/boX9veaa90RtaFcdGSsAkzD0U5y.jpg","release_date":"2012-01-03","vote_average":6.6,"backdrop_path":"/kXBm2RTGCF9NnD3LAUy3HcoG8hf.jpg","original_title":"SpongeBob's Frozen Face-Off","original_language":"en"},{"id":406099,"adult":false,"title":"For a Few Bullets","video":false,"overview":"When a professional thief sees his lifetime goal of being the best potentially realized in stealing a rare artifact, he finds himself entangled in a worldwide plot involving the Soviets, the Japanese and a band of outsiders.  It’s up to him and a special agent to save the world!","genre_ids":[35,9648,28,10749,12],"media_type":"movie","popularity":0.6891,"vote_count":13,"poster_path":"/f5Pw0FNhwTWb2UeN2oHFnUWjOup.jpg","release_date":"2016-07-15","vote_average":4.462,"backdrop_path":"/76xUS3khhScOef2odo1wvPbAMuS.jpg","original_title":"快手枪手快枪手","original_language":"zh"},{"id":225086,"adult":false,"title":"Aura: Koga Maryuin's Last War","video":false,"overview":"Satou Ichirou once called himself 'Maryuuin Kouga' and behaved as if he were a hero in a fantasy world. His strange behavior caused his classmates to bully him and he left the school. At his new school, he tries to behave like a normal boy, but one day he meets a girl who cosplays with a blue cape. She calls herself \"a researcher traveling from the outer world to search for the 'Dragon Terminal'\". At first, Ichirou rejects the girl, Satou Ryouko, because her behavior reminds him of his embarrassing past, but he changes his mind after seeing her getting bullied. In order to bring Ryouko back to real life, Ichirou accepts her and his past and begins the final battle as Maryuuin Kouga.","genre_ids":[16,35,18,14,10749],"media_type":"movie","popularity":1.4706,"vote_count":47,"poster_path":"/gYS6tflgvQDc7N0E1RTDQRpq5d.jpg","release_date":"2013-04-13","vote_average":6.4,"backdrop_path":"/iIME6qijTI7r0Nn8YtG73dqu1v8.jpg","original_title":"AURA ～魔竜院光牙最後の闘い～","original_language":"ja"},{"id":467796,"adult":false,"title":"How to Break Up with Your Douchebag","video":false,"overview":"This comedy takes its cue from such female-centered films as \"Bridesmaids\" and \"Trainwreck.\" Pic centers on a woman who makes a living from breaking up couples and decides to take on the task of splitting up her sister's relationship with her jerk of a boyfriend.","genre_ids":[35,10749],"media_type":"movie","popularity":0.3424,"vote_count":80,"poster_path":"/arpcxmLCXyYQWfb1MuMDfl2Dhuo.jpg","release_date":"2017-10-13","vote_average":6.838,"backdrop_path":"/tXrq2AME5M7f91jsJJbecFxqPod.jpg","original_title":"Cómo cortar a tu patán","original_language":"es"},{"id":633908,"adult":false,"title":"The Stand In","video":false,"overview":"When ordered to serve a year in rehab, actress Candy hires her on-set stand-in to take her place. The unassuming woman flips the script and steals her identity, career and boyfriend in this hilarious comedy about trading places.","genre_ids":[35],"media_type":"movie","popularity":0.9629,"vote_count":118,"poster_path":"/twQeFldoNaDnMYXmZNXpm3NHlhP.jpg","release_date":"2020-12-03","vote_average":5.271,"backdrop_path":"/t4V82jen6LKBjs8WMuMpGxbtFgJ.jpg","original_title":"The Stand In","original_language":"en"},{"id":13554,"adult":false,"title":"Eight Men Out","video":false,"overview":"Buck Weaver and Hap Felsch are young idealistic players on the Chicago White Sox, a pennant-winning team owned by Charles Comiskey -  a penny-pinching, hands-on manager who underpays his players and treats them with disdain. And when gamblers and hustlers discover that Comiskey's demoralized players are ripe for a money-making scheme, one by one the team members agree to throw the World Series. But when the White Sox are defeated, a couple of sports writers smell a fix and a national scandal explodes, ripping the cover off America's favorite pastime.","genre_ids":[18,36],"media_type":"movie","popularity":0.8342,"vote_count":264,"poster_path":"/9nh0w2C9h9KfJb0OsVg65O65b5s.jpg","release_date":"1988-09-02","vote_average":6.86,"backdrop_path":"/6v594uUI5VOBjdlxiV0d6EOjvW.jpg","original_title":"Eight Men Out","original_language":"en"},{"id":222216,"adult":false,"title":"Special ID","video":false,"overview":"A career-long undercover Hong Kong cop is sent to Mainland China when his former protégé becomes the primary suspect in a murder.","genre_ids":[18,28,80],"media_type":"movie","popularity":0.9545,"vote_count":172,"poster_path":"/1JmlCQWg1mdQTUMgJQsH7XHcXpA.jpg","release_date":"2013-10-17","vote_average":6,"backdrop_path":"/ofFQoVSgGsgTuQ919v8ipOE4nFV.jpg","original_title":"特殊身份","original_language":"cn"},{"id":287904,"adult":false,"title":"The Last Face","video":false,"overview":"Miguel, a heroic Spanish doctor, puts himself in harm's way to deliver medical treatment to the victims of military uprisings in Africa.","genre_ids":[18],"media_type":"movie","popularity":1.1027,"vote_count":206,"poster_path":"/egOM3BJgA44fR6YdiQJD51iQ4On.jpg","release_date":"2017-01-11","vote_average":5.5,"backdrop_path":"/ua9cbCID72c1ViGWdfAzr1nTWu7.jpg","original_title":"The Last Face","original_language":"en"},{"id":257648,"adult":false,"title":"The White Haired Witch of Lunar Kingdom","video":false,"overview":"In the twilight of the Ming Dynasty, the Imperial court is plagued by corruption as tyrants rule over the land. With the Manchurians preying on a weakened empire, war is imminent. To save the victims from their suffering, sorceress Jade Raksha fights the soldiers that oppress people for their own gain. As payback, local government officials decide to pin the murder of Governor Zhuo Zhonglian on Jade, turning her and the members of her cult into wanted fugitives for a crime they didn't commit.","genre_ids":[14],"media_type":"movie","popularity":1.0778,"vote_count":113,"poster_path":"/2fzybbRNycYYqujAtLKHsf9UUmn.jpg","release_date":"2014-02-14","vote_average":6.345,"backdrop_path":"/pEFHDd5NmaRcynE4rNAfynYjiiQ.jpg","original_title":"白发魔女传之明月天国","original_language":"zh"},{"id":300168,"adult":false,"title":"Dragon Blade","video":false,"overview":"Huo An, the commander of the Protection Squad of the Western Regions, was framed by evil forces and becomes enslaved. On the other hand, a Roman general escapes to China after rescuing the Prince. The heroic duo meet in the Western Desert and a thrilling story unfolds.","genre_ids":[12,36,28,14],"media_type":"movie","popularity":3.5564,"vote_count":616,"poster_path":"/m5yyMErIDbdzVLIDXVBG6EzM1oF.jpg","release_date":"2015-02-19","vote_average":6.4,"backdrop_path":"/rnNkUJlo03a8D0utxiOrADstaMT.jpg","original_title":"天將雄師","original_language":"zh"},{"id":377587,"adult":false,"title":"Meet the Blacks","video":false,"overview":"As Carl Black gets the opportunity to move his family out of Chicago in hope of a better life, their arrival in Beverly Hills is timed with that city's annual purge, where all crime is legal for twelve hours.","genre_ids":[35],"media_type":"movie","popularity":0.8418,"vote_count":314,"poster_path":"/4pemUf5lKEzgxGebxxMVKL5NHSW.jpg","release_date":"2016-04-01","vote_average":4.742,"backdrop_path":"/bJKd2F0fzOIzoMHe4TaaYHvZfWe.jpg","original_title":"Meet the Blacks","original_language":"en"},{"id":200823,"adult":false,"title":"Fonzy","video":false,"overview":"Set in Paris, a man working in fish delivery becomes involved in a legal battle with his sperm donations.","genre_ids":[35],"media_type":"movie","popularity":3.4529,"vote_count":236,"poster_path":"/u5GZFcA1KgwU5yudqBp7htPLrUH.jpg","release_date":"2013-10-30","vote_average":5.3,"backdrop_path":"/yZrNQoWCPTy4JFLJxtMoeimvOo3.jpg","original_title":"Fonzy","original_language":"fr"},{"id":10642,"adult":false,"title":"Loser","video":false,"overview":"On a university scholarship, a good natured student from the midwest gets a crash course in city life while dealing with three evil roommates. He befriends a virtually homeless college student whom he falls for, but she's dating a nasty professor.","genre_ids":[35,10749],"media_type":"movie","popularity":3.7264,"vote_count":470,"poster_path":"/nOqWmYfgvpUA6gZjvdB0Cg24kA4.jpg","release_date":"2000-07-21","vote_average":5.4,"backdrop_path":"/r80VehB1GzdOReLSgr0N4iWo5id.jpg","original_title":"Loser","original_language":"en"},{"id":273641,"adult":false,"title":"Jackass Presents: Bad Grandpa .5","video":false,"overview":"Bad Grandpa .5 gives you a whole new perspective on the world of Irving Zisman with bonus scenes and pranks also featuring Spike Jonze as \"Gloria\" and Catherine Keener as Irving's wife \"Ellie\", plus a look at the evolution of Johnny Knoxville's naughty alter-ego, the makeup effects, and a behind-the-scenes peek at the idiocy it takes to make a hidden camera movie in public.","genre_ids":[35],"media_type":"movie","popularity":0.6066,"vote_count":266,"poster_path":"/4FBfykfsiFHp3EPlG1rH7S5XwF3.jpg","release_date":"2014-06-03","vote_average":5.9,"backdrop_path":"/kUjVIyeSLL7FxKEvUWPB6oNpbvD.jpg","original_title":"Jackass Presents: Bad Grandpa .5","original_language":"en"}],"similar_content":[{"id":48677,"adult":false,"title":"Cloak & Dagger","video":false,"overview":"Davey Osborne is an average 11-year-old boy with an overactive imagination. He spends his days playing video games and pretending to be a spy with his imaginary father-figure, Jack Flack - a substitute for his real father, who is struggling with the recent death of Davey's mother. However, fantasy becomes reality for Davey after he witnesses the murder of an FBI agent, who in his dying breath, gives Davey a mysterious video game cartridge called Cloak & Dagger, which in actuality contains top-secret government information. With the help of his younger friend Kim, the tech savvy Morris, and even a little help from his fictional secret agent mentor, Davey must stay one step ahead of pursuers as he tries to survive a real-life game of espionage in the streets of San Antonio, Texas.","genre_ids":[12,28,10751],"popularity":0.7618,"vote_count":155,"poster_path":"/b7jSCsjZccAwj4nrGXj8XPRAcAc.jpg","release_date":"1984-06-01","vote_average":6.3,"backdrop_path":"/eF765MoTYrRiXSda5xHVXrFeeQm.jpg","original_title":"Cloak & Dagger","original_language":"en"},{"id":513285,"adult":false,"title":"Trouble Is My Business","video":false,"overview":"Private eye Roland Drake cracks cases and romances femme fatales in 1940's Los Angeles while corrupt cop Det Barry Tate rules the city. A tale told in the classic style of film noir. Drake has fallen on hard times in a harsh world. He has been evicted from his office and disgraced by a missing persons case. Ruined in the public eye and with the police. it seems like it's all over for Roland Drake. Then, redemption walks in - with curves. The owner of those curves is a sexy, dark haired beauty named Katherine Montemar. She wants his help. The chemistry is immediate and her concern for the disappearance of her family members pulls him into her case - and into bed.","genre_ids":[12,9648,10749,53],"popularity":0.1878,"vote_count":20,"poster_path":"/2o4z89Q6YsEniOboIvRDKVNnuPw.jpg","release_date":"2018-04-03","vote_average":4.6,"backdrop_path":"/pPKAcvCYcQWx4slftwnAssvEuBw.jpg","original_title":"Trouble Is My Business","original_language":"en"},{"id":48482,"adult":false,"title":"Thief of Hearts","video":false,"overview":"A woman trapped in a boring marriage begins an affair with a handsome man who seems able to read her mind. She doesn't know that he has broken into her house and read her diaries, where she has recorded her deepest thoughts and fantasies.","genre_ids":[80,18,53],"popularity":0.6662,"vote_count":43,"poster_path":"/be08f4q9Doq5HvHgBCS5NzQ6jja.jpg","release_date":"1984-10-19","vote_average":5.3,"backdrop_path":"/amvcq28G3gPqZxkqoa6Q62j1Ma8.jpg","original_title":"Thief of Hearts","original_language":"en"},{"id":48492,"adult":false,"title":"Detective Dee and the Mystery of the Phantom Flame","video":false,"overview":"When the future empress Wu Zetian's two courtiers die in a mysterious fire, she gets Di Renjie, a former detective and rebel, released from prison to solve the mystery of the fire.","genre_ids":[28,12,18,9648],"popularity":1.4789,"vote_count":425,"poster_path":"/qWOBV05kNeLyaiA31DFkZlMpta5.jpg","release_date":"2010-09-18","vote_average":6.5,"backdrop_path":"/af3gx7Tuu08pf8ioJU0ok6r407J.jpg","original_title":"狄仁傑之通天帝國","original_language":"zh"},{"id":48756,"adult":false,"title":"Come Clean","video":false,"overview":"The Hardys wish to have a quiet evening in their apartment, but are interrupted when the Laurels pay a visit. Stan and Ollie go out for ice cream, and manage to prevent a shrewish woman from committing suicide on the way back home. The woman is ungrateful and makes threats against the them unless they look after her. They spend a chaotic evening trying to keep her hidden from their wives.","genre_ids":[35],"popularity":0.4274,"vote_count":47,"poster_path":"/5xI2S8EPNYFgNURL0L4jD1C8fa1.jpg","release_date":"1931-09-02","vote_average":7.181,"backdrop_path":"/pEPa57kuxFIq2GKLNNSEA6cY86O.jpg","original_title":"Come Clean","original_language":"en"},{"id":49009,"adult":false,"title":"The Way Back","video":false,"overview":"A small band of multicultural convicts stages a daring escape from a WWII-era Siberian gulag, and embarks on a treacherous journey across five countries in a desperate race for freedom and survival.","genre_ids":[18,12,36],"popularity":2.5382,"vote_count":1716,"poster_path":"/xQ6hxfpD5XQGJz0ekVle5zegam7.jpg","release_date":"2010-11-22","vote_average":7,"backdrop_path":"/jcQfgcq1j7Vit4wQ54niXiLfvE8.jpg","original_title":"The Way Back","original_language":"en"},{"id":49049,"adult":false,"title":"Dredd","video":false,"overview":"In the future, America is a dystopian wasteland. The latest scourge is Ma-Ma, a prostitute-turned-drug pusher with a dangerous new drug and aims to take over the city. The only possibility of stopping her is an elite group of urban police called Judges, who combine the duties of judge, jury and executioner to deliver a brutal brand of swift justice. But even the top-ranking Judge, Dredd, discovers that taking down Ma-Ma isn’t as easy as it seems in this explosive adaptation of the hugely popular comic series.","genre_ids":[28,878],"popularity":5.7209,"vote_count":5418,"poster_path":"/wLx65gtGVnUFCxceHWGszcruCZj.jpg","release_date":"2012-09-07","vote_average":6.857,"backdrop_path":"/jUqDBi02CDjqrroC3Zl8hroBbSr.jpg","original_title":"Dredd","original_language":"en"},{"id":313616,"adult":false,"title":"McDull: Me & My Mum","video":false,"overview":"As a child, Bobby Mak was known as Mcdull. Although Mcdull wasn‘t the sharpest tool in the shed, his mother was a different story. Her astounding intelligence and resourcefulness enabled her to, for example, simultaneously run more than six businesses from a space of less than 100 square feet. Mcdull and his mother lived together happily during Mcdull‘s childhood, but things began to change as Mcdull got older. A distance that never existed before began to grow between him and his mother…","genre_ids":[35,16,18],"popularity":0.3399,"vote_count":10,"poster_path":"/jDfqnGYrdo2AZlrhAWxL3GMtfQp.jpg","release_date":"2014-10-01","vote_average":7.5,"backdrop_path":"/h5E3kAVoVq3Qdzp6aiYQOOvmCcO.jpg","original_title":"麥兜．我和我媽媽","original_language":"zh"},{"id":48895,"adult":false,"title":"To Catch a Virgin Ghost","video":false,"overview":"Seok-tae runs away with a huge diamond of his gang and comes to Sisily, a peaceful village. Yang-e runs after him to get the diamond back and finds Seok-tae's trail in Sisily. But all the town people lie about everything. These people turn out to be scarier than a ghost!","genre_ids":[35,27],"popularity":3.2175,"vote_count":30,"poster_path":"/higMXZsQdHRm8OgO7aZrBdidpMY.jpg","release_date":"2004-08-13","vote_average":7.133,"backdrop_path":"/xmZKufznNkBSfkFq8aYrmDCkxhG.jpg","original_title":"시실리 2km","original_language":"ko"},{"id":49239,"adult":false,"title":"The Boxer's Omen","video":false,"overview":"After his brother was crippled in the ring by a cheating Thai boxer,  Chan Hung goes to Thailand to avenge his brother, and finds the key to an omen which may release their family from an ancient curse. He is then caught up in a spiraling web of fate, Buddhist curses, and black magic.","genre_ids":[27,14,28],"popularity":1.0175,"vote_count":77,"poster_path":"/tIOUIqHvjFyv80NoEIuIJxmr8VA.jpg","release_date":"1983-10-23","vote_average":6.494,"backdrop_path":"/rHPyhAfz1hTmZfiLYN3bP01ou30.jpg","original_title":"魔","original_language":"cn"},{"id":49172,"adult":false,"title":"Public Enemies","video":false,"overview":"Ma Barker and her sons rob banks, shoot people and wind up at the top of the FBI's Most Wanted list in the 1930s.","genre_ids":[18,80],"popularity":0.6197,"vote_count":15,