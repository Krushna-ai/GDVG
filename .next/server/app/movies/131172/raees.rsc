ity":2},{"logo_path":"/dpR8r13zWDeUR0QkzWidrdMxa56.jpg","provider_id":1796,"provider_name":"Netflix Standard with Ads","display_priority":154}]},"UY":{"link":"https://www.themoviedb.org/movie/363343/watch?locale=UY","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"VE":{"link":"https://www.themoviedb.org/movie/363343/watch?locale=VE","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"YE":{"link":"https://www.themoviedb.org/movie/363343/watch?locale=YE","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}],"link":"https://www.themoviedb.org/movie/363343/watch?locale=ZA","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}],"flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZM":{"link":"https://www.themoviedb.org/movie/363343/watch?locale=ZM","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZW":{"link":"https://www.themoviedb.org/movie/363343/watch?locale=ZW","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":4}]}}},"wikidata_id":"Q19833751","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-22T21:58:40.148993+00:00","region":null,"main_poster":null,"images":null,"enriched_at":"2026-04-21T05:17:34.673+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Raees","runtime":143,"tagline":"","homepage":"http://www.redchillies.com/movies/raees.aspx","overview":"Set in the early ’80s and ’90s in Gujarat, India, ‘Raees’ is a fictitious story of a crime lord named Raees, who builds an entire empire from scratch, and a police officer who is determined to bring him down."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Raees","runtime":142,"tagline":"Le cerveau de Baniye et le courage de Miyanbhai.","homepage":"","overview":"Dans le Gujarat des années 80, Raees, chef de la Mafia, fait fortune dans le trafic d'alcool de contrebande en dépit de la prohibition toujours active dans l'état. Son ascension fulgurante et ses relations en font l'homme le plus puissant du Gujarat. Autant aimé que redouté, Raees est un visionnaire qui ne laisse personne se mettre au travers de son chemin. Personne. Jusqu’à l'arrivée de l'inspecteur Majmudar."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Raees","runtime":143,"tagline":"","homepage":"","overview":"Da ragazzo di strada, Raees diventa il signore del contrabbando nel Gujarat negli anni ’80, ma tenta di bilanciare la sua attività criminale aiutando il prossimo."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"رئيس","runtime":143,"tagline":"","homepage":"","overview":"بعدما ارتقى \"رئيس\" ليصبح زعيم إمبراطورية تهريب الكحوليات في \"غوجارات\" في الثمانينيّات، يحاول أن يوازن بين حياة الجريمة ومساعدة أهل مدينته."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Raees","runtime":0,"tagline":"","homepage":"","overview":"Az alkohol és az illegális kábítószerek tilalmának idején Gujaratban, a film végig kíséri egy a kegyetlen és egyben okos csempész (Raees) életpályáját, miként került a csúcsra majd bukott el...."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Reyis","runtime":0,"tagline":"","homepage":"","overview":"Cesur bir polisin kendini kovalayan zalim fakat akıllı bir suçludan kendini korumasının anlatıldığı ve Başrollerinde Shah Rukh Khan, Nawazuddin Siddiqui, Mahira Khan'ın yer aldığı 2016 Hint filmi: Hindistan’ın sahil eyaleti Gucerat’da zararlı maddelerin kullanımı yasaklanmıştır. Ayrıca bu ani karar ile fuhuş da bu bölgede yasal değildir. Bu işler ile uğraşan çeteler ve mafyalar bu karardan hoşnut olmazlar. Bu konunun çıkmasında payı büyük olan bir polis memurunu hedef alırlar. İsyancı halk ve mafyaların gazabından kurtulmaya çalışan polis memurunun yaşadığı aksiyon dolu maceralar.."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Raees","runtime":161,"tagline":"","homepage":"","overview":"Raees to film o przemytnikach alkoholu w objętym prohibicją Gudźaracie. Shah Rukh wcieli się w rolę gangstera, a partnerować mu będą pakistańska aktorka Mahira Khan oraz Nawazuddin Siddiqui, który zagra policjanta."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Raees","runtime":0,"tagline":"","homepage":"","overview":"Gujarat, in den 1980ern: In dem indischen Staat verbietet das Prohibitionsgesetz den Konsum von Alkohol. Auf Verkauf und Herstellung steht sogar die Todesstrafe. Trotzdem, das illegale Alkoholgeschäft boomt wie eh und je und der scharfsinnige Schmuggler und Impresario Raees nutzt die Stunde, um sein eigenes Imperium zu errichten. Doch Ruhm und Erfolg scheinen bedroht, denn schon bald kommen die Behörden Raees' Schmugglerring auf die Schliche und der unbeirrbare Polizist Majmudar hat es zu seiner Lebensaufgabe gemacht, das illegale Treiben in Gujarat ein für alle Male zu eliminieren."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"금단의 비즈니스","runtime":155,"tagline":"","homepage":"","overview":"거리의 소년에서 1980년대 구자라트 지역 최고의 주류 밀매업자가 된 라이스. 지역 주민들을 지속적으로 도우며 범죄자로서의 삶에 매몰되지 않으려 한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"枭雄","runtime":0,"tagline":"","homepage":"","overview":"讲述了20世纪80年代印度古吉拉特邦的故事：一个叫做Raees的男人白手起家，建立起一个商业帝国。他坚信经商高于一切，甚至比信仰更加重要。在影片中，你可以看到为了利益大打出手、陷害算计的场面。不老男神沙鲁克汗的演出就决定了打斗戏的精彩绝伦。不同之处在于，Raees并不是一个帮派大佬，而更像一个歌舞团经理人，靠着无与伦比的商业头脑和一往无前的毅力为自己赢得名望和地位，以及一位美人。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Богатей","runtime":143,"tagline":"","homepage":"","overview":"Для жестокого и умного бутлегера наступают тяжелые времена, когда храбрый полицейский начинает преследовать его."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Богати","runtime":143,"tagline":"","homepage":"","overview":"За жесток и безскрупулен контрабандист настъпват тежки времена, когато смел полицай започва да го преследва."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"寶萊塢之一代梟雄","runtime":0,"tagline":"","homepage":"","overview":"寶萊塢天王沙魯克罕與印度導演勞胡多拉奇亞合作的《寶萊塢之一代梟雄》中，飾演白手起家的商人，靠著精明的頭腦與勇氣，建立起龐大的私酒帝國，成為萬人之上的黑道首領，就在人生達到高峰時，過去的新仇舊恨卻一觸即發。寶萊塢不可少的華麗群舞場景，這回更結合炫目槍戰，絕對令人大呼過癮。  八○年代印度古吉拉特省，因禁酒令帶來豐厚的賣酒利益，成了黑道份子競相爭奪的市場。瑞茲從小深受母親影響，立志要做一名成功的商人，有著精明的頭腦與無比的勇氣，他很快就受到大哥的賞識，進而想開創屬於自己的事業。為達目的，瑞茲捲入了派系鬥爭，一步步建立起自己的走私帝國，也順利娶妻生子，就在他的人生似乎達到高峰時，一路向上爬所埋下的新仇舊恨，讓他成為黑白兩道不容的眼中釘，他必須在現實跟原則之間，決定自己的命運。  沙魯克罕精湛詮釋在法律與道德間掙扎的黑道大哥，也讓全片充滿戲劇張力。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Raees","runtime":143,"tagline":"","homepage":"","overview":"Depois que o esperto garoto Raees cresce e se torna o rei do contrabando de Gujarat nos anos 1980, ele tenta equilibrar sua vida de crimes ajudando outras pessoas."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Raees","runtime":161,"tagline":"","homepage":"","overview":"In een alcoholvrije staat heeft een slimme en wrede drankhandelaar het monopolie, totdat hij gedwarsboomd wordt door een politieagent. Boos vanwege zijn terugval in rijkdom, neemt hij wraak door een groep mensen voor zich te winnen om uiteindelijk weer op de zwarte markt te floreren."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Ραΐς","runtime":143,"tagline":"","homepage":"","overview":"Η ταινία Raees λέγεται ότι βασίζεται στη ζωή του κακοποιού Abdul Latif, αλλά, οι δημιουργοί της ταινίας το αρνήθηκαν, λέγοντας ότι η ταινία είναι καθαρά προϊόν φαντασίας. Ο Raees, από την πόλη Fatehpur, της πολιτείας Γκουτζαράτ εμπλέκεται σε παράνομο εμπόριο ποτών σε πολύ νεαρή ηλικία. Μαζί με τον φίλο του, τον Sadiq, ο Raees εργάζεται για τον περιβόητο γκάνγκστερ Jairaj, που διακινεί λαθραία αλκοόλ δωροδοκώντας την αστυνομία. Αν και είναι λαθρέμπορος, ζει με τη φιλοσοφία, όπως του την δίδαξε η μητέρα του, ότι κάθε επάγγελμα είναι καλό, και καμία θρησκεία δεν είναι μεγαλύτερη από οποιοδήποτε επάγγελμα αρκεί να μην προκαλεί καμία βλάβη σε κανέναν. Αποφασίζει να χωρίσει τον δρόμο του με τον Jairaj και να στήσει την δική του επιχείρηση. Συναντά τον αδερφό Musa και τον Nawab στη Βομβάη, και με τη βοήθειά τους θα αρχίσει την επιχείρηση λαθρεμπορίου του. Εν τω μεταξύ, ένας τίμιος αστυνομικός, ο J. Α Majmudar, θέλει να βάλει ένα τέλος σ αυτό το παράνομο εμπόριο οινοπνευματωδών ποτών"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Raees","runtime":0,"tagline":"","homepage":"","overview":"Ambientada durante las décadas de los 80 y 90 en Gujarat, sigue la historia del hombre que construyó un imperio del crimen a partir de la nada, convirtiéndose en el hombre más poderoso del estado."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"ראיס","runtime":0,"tagline":"ראיס","homepage":"","overview":"סיפורו של \"ראיס\", מלך הסחר הלא חוקי באלכוהול במדינת גוג'ראט שבמערב הודו בשנות ה-80 וה-90 של המאה ה-20. הסרט מספר על הקשרים השונים שבנה ועל העלייה המטאורית שלו כאחד שבנה אימפריה שלמה מאפס עד שהפך לאיש החזק ביותר במדינה. הוא זכה לפופולריות רבה ולאמון הציבור על ידי כך שהפגין כשרון יזמי, נחישות בלתי מוגבלת להשגת יעדיו, ולמרבה האירוניה גם לב זהב. במהלך כל אותה תקופה הוא ביטל וניטרל כל התנגדות שעלתה בדרכו תוך כדי שימוש ברעיונות ניהול מהפכניים שלא נשמעו מעולם בתקופתו. היחיד שנלחם בו ללא פשרות הוא מאג'מודאר, קצין משטרה בכיר שתפקידו היה למגר את הפשיעה במדינה. המאבק הסוער בין השניים הוא הנדבך המרכזי בסרט. סיפורו של ראיס מבוסס ככל הנראה על סיפור חייו של עבדל לטיף, איש העולם התחתון של גוג'ראט, אם כי יוצרי הסרט טענו כי מדובר בסיפור בדיוני לחלוטין ואינו מבוסס על אף אדם."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Đại Ca Raees","runtime":0,"tagline":"","homepage":"","overview":"Đại Ca Raees, lấy bối cảnh vào những năm đầu thập niên 80 và 90 ở bang Gujarat, Ấn Độ. Phim kể về Raees, một người xây dựng cả một đế chế từ đôi bàn tay trắng. Anh dùng sự nhanh nhạy và sử dụng các mối quan hệ của mình trở thành người đàn ông quyền lực."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Raees","runtime":0,"tagline":"","homepage":"","overview":"Durante la década de los ochenta, el astuto Raees se convierte en el rey del contrabando en Gujarat y, para equilibrar su vida criminal, ayuda a la gente."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Raees","runtime":143,"tagline":"","homepage":"","overview":"După ce ajunge dintr-un copil șmecher regele contrabandei cu alcool în Gujarat-ul anilor '80, Raees încearcă să-și spele păcatele vieții de infractor ajutându-și poporul."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"رئيس","runtime":143,"tagline":"","homepage":"","overview":"بعدما ارتقى \"رئيس\" ليصبح زعيم إمبراطورية تهريب الكحوليات في \"غوجارات\" في الثمانينيّات، يحاول أن يوازن بين حياة الجريمة ومساعدة أهل مدينته."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"Raees","runtime":143,"tagline":"","homepage":"","overview":"Quando se torna no rei do contrabando de Gujarate nos anos 80, Raees tenta equilibrar a sua atividade criminosa com a tentativa de ajudar a sua gente."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Raees","runtime":143,"tagline":"","homepage":"","overview":"Das Straßenkind Raees steigt in den 80er Jahren zum Schmuggelkönig Gujarats auf und versucht, sein kriminelles Leben und seine Hilfsbereitschaft in Einklang zu bringen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"Raees","runtime":143,"tagline":"","homepage":"","overview":"Das Straßenkind Raees steigt in den 80er Jahren zum Schmuggelkönig Gujarats auf und versucht, sein kriminelles Leben und seine Hilfsbereitschaft in Einklang zu bringen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"CH","english_name":"German"},{"data":{"title":"私酒梟雄","runtime":143,"tagline":"","homepage":"","overview":"滿有江湖智慧的瑞伊斯在 1980 年代崛起，成為古吉拉特邦的走私大王后，藉努力協助同胞來平衡自己的犯罪生活。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"瑞艾斯","runtime":143,"tagline":"","homepage":"","overview":"20 世纪 80 年代，浪迹街头的小伙子瑞艾斯成长为古吉拉特私酒贩子中的龙头老大，试图通过帮助自己人来平衡他的犯罪生涯。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"ライース","runtime":143,"tagline":"","homepage":"","overview":"1980年代のインド、ライースは裏社会で生き抜く術を学び、酒の密売でのし上がる。違法なビジネスに手を染める一方、庶民の味方として人々に支持されてゆく。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"ไรส์","runtime":143,"tagline":"","homepage":"","overview":"จากเด็กข้างถนน เรอีสเติบโตกลายเป็นราชาแห่งการค้าของเถื่อนคุชราตในทศวรรษที่ 1980 ระหว่างนั้นเขาพยายามถ่วงสมดุลระหว่างอาชีพอาชญากรรมและการช่วยเหลือผู้คน"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Raees","runtime":143,"tagline":"","homepage":"","overview":"Drengen Raees er god til at begå sig og bliver Gujarats konge af spritsmugleri i 1980'erne. Han prøver at forene sit kriminelle liv med at hjælpe sit folk."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Raees","runtime":143,"tagline":"","homepage":"","overview":"När gatusmarta Raees blir Gujarats bootlegkung på 1980-talet försöker han hitta balansen mellan sin kriminella livsstil och att hjälpa sitt folk."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Raees","runtime":143,"tagline":"","homepage":"","overview":"Katujen kasvatti Raeesista tulee Gujaratin piratismikuningas 1980-luvulla, mutta rikolliselämää tasapainottaakseen hän yrittää auttaa kansaansa."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Raees","runtime":143,"tagline":"","homepage":"","overview":"In de jaren 80 wordt de jonge, streetwise Raees de grootste dranksmokkelaar van Gujarat. Hij probeert zijn misdadige levensstijl te compenseren door mensen te helpen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"Raees","runtime":143,"tagline":"","homepage":"","overview":"Etter at gatesmarte Raees har steget i gradene og blitt Gujarats smuglerspritkonge på 1980-tallet, prøver han å oppveie kriminelle handlinger med å hjelpe folket sitt."},"name":"Bokmål","iso_639_1":"nb","iso_3166_1":"NO","english_name":"Norwegian Bokmål"},{"data":{"title":"Raees","runtime":143,"tagline":"","homepage":"","overview":"Etter at gatesmarte Raees har steget i gradene og blitt Gujarats smuglerspritkonge på 1980-tallet, prøver han å oppveie kriminelle handlinger med å hjelpe folket sitt."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Raees","runtime":143,"tagline":"","homepage":"","overview":"Etter at gatesmarte Raees har steget i gradene og blitt Gujarats smuglerspritkonge på 1980-tallet, prøver han å oppveie kriminelle handlinger med å hjelpe folket sitt."},"name":"","iso_639_1":"nn","iso_3166_1":"NN","english_name":"Norwegian Nynorsk"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"}],"reviews_tmdb":[],"recommendations":[{"id":413543,"adult":false,"title":"Dear Zindagi","video":false,"overview":"An unconventional thinker helps a budding cinematographer gain a new perspective on life.","genre_ids":[18,10749],"media_type":"movie","popularity":0.643,"vote_count":251,"poster_path":"/oUg0N2isgZ5rrxdXnsemcKolfKZ.jpg","release_date":"2016-11-23","vote_average":7.022,"backdrop_path":"/d2plahqbICvNTAvhk2lM0HojJGG.jpg","original_title":"Dear Zindagi","original_language":"hi"},{"id":412090,"adult":false,"title":"Jolly LLB 2","video":false,"overview":"A blunt, abrasive and yet oddly compassionate Jagdishwar Mishra aka Jolly, a small-time struggling lawyer who moves from Kanpur to the city of Nawabs to pursue his dream of becoming a big-time lawyer.","genre_ids":[35,80],"media_type":"movie","popularity":0.4691,"vote_count":153,"poster_path":"/n9MjoGmaYagaaETCQP0S6Ch3JLH.jpg","release_date":"2017-02-09","vote_average":6.902,"backdrop_path":"/qXWNHWxWoSz6FNFlSKAtZIKPyy6.jpg","original_title":"जॉली एलएलबी 2","original_language":"hi"},{"id":403867,"adult":false,"title":"Kaabil","video":false,"overview":"Rohan is a kind, happy young man who has been blind since birth and works as a voice-over artist for a living. Through friends, he meets Supriya, a working woman who is also blind, but proudly independent. The two start liking each other and get married. Rohan toughest journey starts in his quest of vengeance for Supriya's indirect murderers.","genre_ids":[28,53,18],"media_type":"movie","popularity":0.5875,"vote_count":142,"poster_path":"/ojs8b5N2BgFYoHCSb6vu0egZb6v.jpg","release_date":"2017-01-25","vote_average":6.866,"backdrop_path":"/zqRGIqDKoNZfj0XvkuX7hNJWq7D.jpg","original_title":"काबिल","original_language":"hi"},{"id":31524,"adult":false,"title":"Sarfarosh","video":false,"overview":"When terrorists kill a cop's brother and disable his father, he fights back against the smuggling of guns and drugs which plagues his country.","genre_ids":[28,18],"media_type":"movie","popularity":0.5432,"vote_count":102,"poster_path":"/i6XJCzajVcnfh5ljAn7AGub5vih.jpg","release_date":"1999-04-30","vote_average":6.765,"backdrop_path":"/zQwmXzP0isT4qAKVu47X4HrSecA.jpg","original_title":"सरफरोश","original_language":"hi"},{"id":127501,"adult":false,"title":"Barfi!","video":false,"overview":"The heartwarming tale of Barfi, a charming deaf-mute young man from 1970s Darjeeling, and two unalike women who can't help but fall for him.","genre_ids":[18,10749,35],"media_type":"movie","popularity":0.7576,"vote_count":356,"poster_path":"/5cJIx2zKjDoUtPSliou23xsReb1.jpg","release_date":"2012-09-13","vote_average":7.6,"backdrop_path":"/dVUBKQMehxVnEQMpcOPw3OQqNMF.jpg","original_title":"बर्फी!","original_language":"hi"},{"id":614179,"adult":false,"title":"Coolie No. 1","video":false,"overview":"Insulted by Rosario, a rich businessman, Jai Kishen a Matchmaker teaches him a lesson by getting his daughter married to Raju, a Coolie, who poses to be a millionaire. They sense something fishy and Raju's deceptions are discovered. In an attempt to cover it up, he cooks up a story of having a filthy rich twin. One lie leads to another and things start to go awry culminating in a comedy of errors.","genre_ids":[35,18],"media_type":"movie","popularity":0.3693,"vote_count":71,"poster_path":"/ahkaPWW2SU9AaDhpD31phQKhTtT.jpg","release_date":"2020-12-25","vote_average":5.197,"backdrop_path":"/x8yGoWB87AoRCHMX6TSICpG05jC.jpg","original_title":"Coolie No. 1","original_language":"hi"},{"id":441906,"adult":false,"title":"Jab Harry Met Sejal","video":false,"overview":"Haunted by the memories of home he once knew, a middle-aged tour guide unconsciously embarks on a journey to find self.","genre_ids":[35,18,10749],"media_type":"movie","popularity":0.5475,"vote_count":204,"poster_path":"/yraJilUVLSd6BmQ4f1YtJGmcNkf.jpg","release_date":"2017-08-04","vote_average":6.412,"backdrop_path":"/h3EJkzZNvFf3W8JlFokx4MLRPdv.jpg","original_title":"जब हैरी मेट सेजल","original_language":"hi"},{"id":177358,"adult":false,"title":"Jolly LLB","video":false,"overview":"Wanting to earn fame and fortune, a small time lawyer files a PIL for an infamous hit-and-run, and thus learns what it really is like to be a lawyer.","genre_ids":[35,18],"media_type":"movie","popularity":0.3908,"vote_count":135,"poster_path":"/zmh8eBq0MdwqHl7NMyVOnAhNu7I.jpg","release_date":"2013-03-15","vote_average":7.078,"backdrop_path":"/ouuG2SxecRBS3TmxlzGpuYlTDCP.jpg","original_title":"जॉली एलएलबी","original_language":"hi"},{"id":13194,"adult":false,"title":"Highlander: The Search for Vengeance","video":false,"overview":"Colin MacLeod hunts for the man responsible for the death of his love. He chases the immortal Marcus Octavius across centuries as his quest threatens to take over his life and heart. In his quest, he meets a woman who reminds him of his slain beauty. But it's his final battle with Marcus that will decide not only his fate, but also the fate of everyone in the world.","genre_ids":[28,16,14,878],"media_type":"movie","popularity":1.7205,"vote_count":132,"poster_path":"/f4htbMf2LORgMjKn0litcUFWuWY.jpg","release_date":"2007-06-05","vote_average":7.129,"backdrop_path":"/K7hP2K921lnIr7MPoviMY0LfNP.jpg","original_title":"Highlander: The Search for Vengeance","original_language":"ja"},{"id":13986,"adult":false,"title":"Dil To Pagal Hai","video":false,"overview":"Rahul, the director of a successful dance troupe, considers Nisha his best friend, though secretly, she is madly in love with him. He then falls for Pooja, who is engaged to Ajay.","genre_ids":[18,10749,35],"media_type":"movie","popularity":1.1926,"vote_count":183,"poster_path":"/HKUrZZbXnwCM4129fPlgHEg0eG.jpg","release_date":"1997-10-30","vote_average":6.855,"backdrop_path":"/2hzAcCYXTYP29NEmnYQHqL9ksiZ.jpg","original_title":"दिल तो पागल है","original_language":"hi"},{"id":391629,"adult":false,"title":"Baaghi","video":false,"overview":"Ronny is a rebellious man, who falls in love with Sia but circumstances separate them. Years later, Ronny learns that Sia is abducted by a martial arts champion, Raghav.","genre_ids":[28,53,10749,12],"media_type":"movie","popularity":0.9977,"vote_count":140,"poster_path":"/4IEqNeF3PzL06Y2YKsvi4uMGJ1q.jpg","release_date":"2016-04-29","vote_average":6.4,"backdrop_path":"/sM6P9HR36glkzk02A9vGfr3x1Qs.jpg","original_title":"बाघी","original_language":"hi"},{"id":491625,"adult":false,"title":"Gully Boy","video":false,"overview":"A coming-of-age story based on the lives of street rappers in Mumbai.","genre_ids":[18,10402],"media_type":"movie","popularity":0.7211,"vote_count":204,"poster_path":"/4RE7TD5TqEXbPKyUHcn7CSeMlrJ.jpg","release_date":"2019-02-14","vote_average":7.316,"backdrop_path":"/gcZbciueHH7WmD03GcVZX7LYqmR.jpg","original_title":"गल्ली बॉय","original_language":"hi"},{"id":381418,"adult":false,"title":"Sanam Teri Kasam","video":false,"overview":"Tough ex-convict Inder and traditional mousy Saraswati fall in love and get married, but a tragedy changes their lives forever. The film is a modern rendition of the legends of Shiva-Sati and the novel \"Love Story\" by Eric Segal.","genre_ids":[18,10749],"media_type":"movie","popularity":1.1356,"vote_count":136,"poster_path":"/3jKqSy87GVUsXdhwhcO7O1UqrjO.jpg","release_date":"2016-02-05","vote_average":7.857,"backdrop_path":"/4qifcARBYMzaKgIeaPNTYXLikXd.jpg","original_title":"सनम तेरी कसम","original_language":"hi"},{"id":41109,"adult":false,"title":"Don 2","video":false,"overview":"Having conquered the Asian underworld, crime boss Don sets in motion a plan that will give him dominion over Europe.","genre_ids":[28,53],"media_type":"movie","popularity":1.0106,"vote_count":258,"poster_path":"/2gBM8c36HIwn4vc2UuMeliqiCKY.jpg","release_date":"2011-12-23","vote_average":6.9,"backdrop_path":"/tbavvYay6BvqEyz0iBgsPUy3oE1.jpg","original_title":"Don 2","original_language":"hi"},{"id":24696,"adult":false,"title":"Tom and Jerry: A Nutcracker Tale","video":false,"overview":"Christmas is never so spirited as when Tom and Jerry lock horns for the holidays in their new original movie--Tom & Jerry: A Nutcracker Tale In an empty opera house, Jerry wishes for a chance to perform -- and magically his dream comes true. The little mouse is whisked away to an enchanted kingdom where anything is possible: candy forests, singing snowflakes, even the toys spring to life! Jerry has a great time with his new friends, and when Jerry dances with the music box ballerina, he is as happy as happy can be. Unfortunately, alley cats led by Tom crash Jerry's party, kidnap the music box ballerina and wreak havoc in the holiday kingdom. It's up to Jerry to set things right -- and with help from a fellow mouse named Tuffy and more newfound friends, Jerry just may win the day!","genre_ids":[16,35,10751],"media_type":"movie","popularity":1.0862,"vote_count":164,"poster_path":"/a9klAPAt6SdGuAyh4zMOveYXyg0.jpg","release_date":"2007-10-02","vote_average":6.8,"backdrop_path":"/7YbVGZaxJWipyqgPOzJxjtUrwLA.jpg","original_title":"Tom and Jerry: A Nutcracker Tale","original_language":"en"},{"id":377985,"adult":false,"title":"Fan","video":false,"overview":"A man who bears a striking resemblance to a renowned movie star becomes an obsessive fan, but when his fierce love is spurned by the star, he decides to destroy the star's life and reputation.","genre_ids":[28,12,53],"media_type":"movie","popularity":3.9878,"vote_count":262,"poster_path":"/ukMYsujfyWhSeIBAc9hGEFEkrJD.jpg","release_date":"2016-04-14","vote_average":6.284,"backdrop_path":"/3jsXJRxDr2rDItjeOtFcVcSvaHH.jpg","original_title":"Fan","original_language":"hi"},{"id":14395,"adult":false,"title":"Kabhi Alvida Naa Kehna","video":false,"overview":"Dev and Maya are both married to different people. Settled into a life of domestic ritual, and convinced that they are happy in their respective relationships, they still yearn for something deeper and more meaningful, which is precisely what they find in each other.","genre_ids":[18,10749],"media_type":"movie","popularity":0.7648,"vote_count":224,"poster_path":"/lwgH4S0km8lD7rk5qy78EKW8YEn.jpg","release_date":"2006-08-11","vote_average":6.379,"backdrop_path":"/qRbAsojp77pkKYatbFGG7oIOa0P.jpg","original_title":"कभी अलविदा ना कहना","original_language":"hi"},{"id":376812,"adult":false,"title":"Sultan","video":false,"overview":"The ageing wrestler Sultan Ali Khan decides to try his luck on the mat again; to do this, he wants to represent his country at the Olympic Games, but first has to overcome personal issues.","genre_ids":[18,28,10749],"media_type":"movie","popularity":1.1194,"vote_count":251,"poster_path":"/vPTYtKuV8X5uUd3SqnzO14W6Dti.jpg","release_date":"2016-07-06","vote_average":6.898,"backdrop_path":"/74bUfGDD0kJ53M334vQcbJRzsI8.jpg","original_title":"सुल्तान","original_language":"hi"},{"id":17501,"adult":false,"title":"Don","video":false,"overview":"DCP DeSilva sees a way to bring to justice the feared head of a criminal empire by recruiting a man named Vijay, who looks exactly like the crime boss. The ruse works too well, and soon Vijay finds his life in danger when DeSilva, the only one who knows his true identity, dies.","genre_ids":[28,18,53],"media_type":"movie","popularity":1.2103,"vote_count":294,"poster_path":"/4HyRXNJ4U3H5yP9XjeTGWtlUlJN.jpg","release_date":"2006-10-20","vote_average":6.886,"backdrop_path":"/edCPKBBiWwiLnvMyDwpDeEHL0Oz.jpg","original_title":"डॉन","original_language":"hi"},{"id":61134,"adult":false,"title":"Atacama's 33","video":false,"overview":"A team of Chilean miners are trapped underground for months and hold out for a miraculous rescue.","genre_ids":[18],"media_type":"movie","popularity":0.3554,"vote_count":111,"poster_path":"/nvlHmxCupDKxQuS773wCGK