e,"title":"Gran Torino","video":false,"overview":"Disgruntled Korean War veteran Walt Kowalski sets out to reform his neighbor, Thao Lor, a Hmong teenager who tried to steal Kowalski's prized possession: a 1972 Gran Torino.","genre_ids":[18],"media_type":"movie","popularity":5.4912,"vote_count":11362,"poster_path":"/zUybYvxWdAJy5hhYovsXtHSWI1l.jpg","release_date":"2008-12-12","vote_average":7.987,"backdrop_path":"/1uyDZmTjUQsbflqfkUJZvAGV3bv.jpg","original_title":"Gran Torino","original_language":"en"},{"id":475557,"adult":false,"title":"Joker","video":false,"overview":"During the 1980s, a failed stand-up comedian is driven insane and turns to a life of crime and chaos in Gotham City while becoming an infamous psychopathic crime figure.","genre_ids":[80,53,18],"media_type":"movie","popularity":19.3785,"vote_count":27337,"poster_path":"/udDclJoHjfjb8Ekgsd4FDteOkCU.jpg","release_date":"2019-10-01","vote_average":8.128,"backdrop_path":"/hO7KbdvGOtDdeg0W4Y5nKEHeDDh.jpg","original_title":"Joker","original_language":"en"}],"similar_content":[{"id":48691,"adult":false,"title":"Goodbye Uncle Tom","video":false,"overview":"Two documentary filmmakers go back in time to the pre-Civil War American South, to film the slave trade.","genre_ids":[18,80,27],"popularity":1.4479,"vote_count":70,"poster_path":"/nLw410E9rnJw13kufNgOtjiGvGk.jpg","release_date":"1971-09-23","vote_average":6.6,"backdrop_path":"/qMYvxKZ4ocJbU32bZvFVft7ZjJz.jpg","original_title":"Addio zio Tom","original_language":"it"},{"id":48693,"adult":false,"title":"The Mother and the Whore","video":false,"overview":"Aimless young Alexandre juggles his relationships with his girlfriend, Marie, and a casual lover named Veronika. Marie becomes increasingly jealous of Alexandre's fling with Veronika and as the trio continues their unsustainable affair, the emotional stakes get higher, leading to conflict and unhappiness.","genre_ids":[18,10749],"popularity":1.279,"vote_count":196,"poster_path":"/jHRORDfipbTd3d7NPsKt4jotOwW.jpg","release_date":"1973-05-01","vote_average":7.3,"backdrop_path":"/d7f7Dq0I5SuevNHVqLwInQq3EBr.jpg","original_title":"La Maman et la Putain","original_language":"fr"},{"id":48601,"adult":false,"title":"Clement","video":false,"overview":"Benoit turns 13 and develops an intense crush on his godmother, Marion. As they lie on beaches in the summer, she humors him by talking about the mysteries of women.","genre_ids":[18,10749],"popularity":2.6228,"vote_count":17,"poster_path":"/vwdZpyozXuTYw9ZD3slaxp1He1c.jpg","release_date":"2001-06-06","vote_average":4.7,"backdrop_path":"/v6K1L9hFG0hotpVBf3FCYFFMuPP.jpg","original_title":"Clément","original_language":"fr"},{"id":513409,"adult":false,"title":"Earthquake Bird","video":false,"overview":"Tokyo, Japan, 1989. Lucy Fly, a foreigner who works as a translator, begins a passionate relationship with Teiji, a mysterious man obsessed with photography.","genre_ids":[18,9648,10749,53],"popularity":0.8414,"vote_count":460,"poster_path":"/oyKnosHXQ7kkhlGwqsWOvn4RgKR.jpg","release_date":"2019-11-01","vote_average":5.932,"backdrop_path":"/rhklsYtIITDOdFSmhx2fIH9m9Vn.jpg","original_title":"Earthquake Bird","original_language":"en"},{"id":313011,"adult":false,"title":"Diary of a Rapist","video":false,"overview":"This Italian film takes a chilling, nonexploitative look into the mind of a nice young man who compulsively rapes beautiful women. The rapes are graphically presented and may be disturbing to some viewers. Outwardly Luca seems to be a normal, quiet 20-year old. His mother is frequently gone. Trouble begins when Luca becomes obsessed with Valeria, the beauty who works in the next building. He begins spying on her, and then secretly filming her with his camcorder. He tries to get to know her, but she ignores him. Unable to stand her constant refusal, the frustrated young man accosts her on dark street and rapes her. The first rape was almost accidental; he encountered her on the street and he hurt her. Unfortunately, he liked the violence and begins raping every attractive woman he sees. He is particularly violent with Lorena, a jewelry saleswoman whom he beats up in a park before violating her.","genre_ids":[18],"popularity":0.2237,"vote_count":5,"poster_path":"/yIqoKoDkPZ51ZznBN7LDAfBe5xk.jpg","release_date":"1995-02-23","vote_average":4.2,"backdrop_path":"/8BxIcFWrHj9YelOunpu57ZCZFz4.jpg","original_title":"Cronaca di un amore violato","original_language":"it"},{"id":48482,"adult":false,"title":"Thief of Hearts","video":false,"overview":"A woman trapped in a boring marriage begins an affair with a handsome man who seems able to read her mind. She doesn't know that he has broken into her house and read her diaries, where she has recorded her deepest thoughts and fantasies.","genre_ids":[80,18,53],"popularity":0.6662,"vote_count":43,"poster_path":"/be08f4q9Doq5HvHgBCS5NzQ6jja.jpg","release_date":"1984-10-19","vote_average":5.3,"backdrop_path":"/amvcq28G3gPqZxkqoa6Q62j1Ma8.jpg","original_title":"Thief of Hearts","original_language":"en"},{"id":48773,"adult":false,"title":"Game of Death II","video":false,"overview":"In this dark tale of revenge, Bruce Lee \"returns\" as Billy Lo, whose best friend Chin Ku dies of a sudden illness. But suspicion of foul play arises when a gang tries to steal Ku's coffin at the funeral using a helicopter. When Lo's younger brother Lo hears about the incident, he leaves his Buddhist master to investigate the truth. His trail soon leads him to the Castle of Death, the last place Chin Ku was seen alive. There, he meets and befriends an unlikely ally--a cruel and merciless martial arts expert  who is also the tower's master. But when the master dies under mysterious circumstances, Lo ends up dueling with someone far more terrifying.","genre_ids":[18,28],"popularity":1.6758,"vote_count":182,"poster_path":"/lVL0oX4ZA2owOtQwTsmbw92lhCp.jpg","release_date":"1981-03-21","vote_average":5.7,"backdrop_path":"/kKCA2KS9ShIQwOnK8ef6A4T2Zem.jpg","original_title":"死亡塔","original_language":"cn"},{"id":48831,"adult":false,"title":"My Night at Maud's","video":false,"overview":"The Catholic Jean-Louis runs into an old friend, the Marxist Vidal, in Clermont-Ferrand around Christmas. Vidal introduces Jean-Louis to the modestly libertine, recently divorced Maud and the three engage in conversation on religion, atheism, love, morality and Blaise Pascal's life and writings on philosophy, faith and mathematics. Jean-Louis ends up spending a night at Maud's. Jean-Louis' Catholic views on marriage, fidelity and obligation make his situation a dilemma, as he has already, at the very beginning of the film, proclaimed his love for a young woman whom, however, he has never yet spoken to.","genre_ids":[10749,35,18],"popularity":0.8282,"vote_count":348,"poster_path":"/9usKgth3ROn4LwPQ7tTvxKnpBGL.jpg","release_date":"1969-06-04","vote_average":7.7,"backdrop_path":"/zNMMKmyZ2W5viK2iqbsRfaQIa2u.jpg","original_title":"Ma nuit chez Maud","original_language":"fr"},{"id":49028,"adult":false,"title":"Rakht Charitra","video":false,"overview":"Based on the life of Paritala Ravindra, the film follows his life from just a college student to being a politician in the state of Andhra Pradesh.","genre_ids":[28,80,18],"popularity":0.3286,"vote_count":24,"poster_path":"/cPFW3LMUKUNfj5jaPJVPXZP5U06.jpg","release_date":"2010-10-21","vote_average":6.9,"backdrop_path":"/wniroOh9ZfNOrcdbS9pCHOTt5a6.jpg","original_title":"रखता चरित्र","original_language":"hi"},{"id":49031,"adult":false,"title":"Duet","video":false,"overview":"Two musical brothers look for love, only to have their quest end in tragedy for one.","genre_ids":[10751,35,18],"popularity":0.2818,"vote_count":6,"poster_path":"/4Ew2KerQE5FN19xYUrzIbNhomnH.jpg","release_date":"1994-05-20","vote_average":6.6,"backdrop_path":"/t40JgbArOwvz1mxBkqDBqsjbbNu.jpg","original_title":"டூயட்","original_language":"ta"},{"id":48926,"adult":false,"title":"Sangam","video":false,"overview":"An air force pilot, upon returning home from war after being assumed dead, weds the woman he had long loved, unaware that she had been planning to marry his best friend.","genre_ids":[10749,18,10402],"popularity":0.5621,"vote_count":18,"poster_path":"/kSTQfpeRgubMad65TYbZjmHjrrk.jpg","release_date":"1964-06-18","vote_average":7.3,"backdrop_path":"/bOwjgqQYgh8tkWanOecPIiE79Ks.jpg","original_title":"संगम","original_language":"hi"},{"id":313313,"adult":false,"title":"Duel with the Devils","video":false,"overview":"As the daughter of the Chinese police chief, Angela secretly dresses up as a man to use her kung fu on Japanese troublemakers.","genre_ids":[18,28],"popularity":0.2845,"vote_count":8,"poster_path":"/8qg0V16g4DrMnxC5rKxmQRr8A9J.jpg","release_date":"1977-09-10","vote_average":4,"backdrop_path":null,"original_title":"決閉太陽塔","original_language":"zh"},{"id":313663,"adult":false,"title":"Maratabat","video":false,"overview":"When the people of Maratabat finally realize that their time under the corrupt politician clan of the Abubakars has to come to an end— a series of violent acts occur one after another. The people rally behind another clan –the Mahardikas – to end the violence and place a new leader in their region. Will the Mahardikas choose a path of violence or peace? Will it be for honor or will it be for pride?","genre_ids":[28,18],"popularity":0.2651,"vote_count":1,"poster_path":"/lLI7VBKh8GmpwqAiX5KHDZtVaPJ.jpg","release_date":"2014-12-17","vote_average":10,"backdrop_path":null,"original_title":"Maratabat","original_language":"tl"},{"id":49096,"adult":false,"title":"Empire of Passion","video":false,"overview":"In a small Japanese village at the end of the 19th century, a rickshaw driver's wife takes on a much younger lover and the two conspire to murder him.","genre_ids":[18,10749,27],"popularity":1.1658,"vote_count":130,"poster_path":"/glnY93uAWkTe4SBAng0j7wZlrxa.jpg","release_date":"1978-09-06","vote_average":6.85,"backdrop_path":"/8aad9uv6zD4D5f17ClfhNC29t6.jpg","original_title":"愛の亡霊","original_language":"ja"},{"id":313698,"adult":false,"title":"Storyteller","video":false,"overview":"A loose adaption of Bára Nesvadbová's novel of the same name. A novel that lacks a dramatic line and concentrates on the flow of emotions and feelings of two injured and beloved women, two women that the aging lothario Mára came between. The theme of the entire book is the degree and limit of love, a right and ability to love several people simultaneously while hurting them at the same time. Written by Czech Film Center","genre_ids":[10749,18],"popularity":0.1915,"vote_count":5,"poster_path":"/fzAQnEvoFCh9fAUdLjTSlq0F519.jpg","release_date":"2014-11-06","vote_average":4.2,"backdrop_path":"/eRivki8IC9o2fsrkZtqx5XaDkwO.jpg","original_title":"Pohádkář","original_language":"cs"},{"id":49207,"adult":false,"title":"R","video":false,"overview":"The R of the title stands for the young protagonist, Rune, fearlessly played by Pilou Asbæk. Imprisoned for violent assault, he's a cocky, good-looking young man placed in the hardcore ward, where his survival depends on quickly learning the prison's parallel world of rules, honor, and obligations. R also stands for Rachid, a young Muslim prisoner who becomes Rune's friend and accomplice, defying the rigid racial stratifications among the inmates.","genre_ids":[80,18],"popularity":0.4179,"vote_count":236,"poster_path":"/jxMgFBcEkBPhoikocUBqXS3i6TP.jpg","release_date":"2010-04-22","vote_average":6.833,"backdrop_path":"/gd4JXEnL3SAff3qth6Qx3ZNh3NO.jpg","original_title":"R","original_language":"da"},{"id":1298092,"adult":false,"title":"Lockdown","video":true,"overview":"During a national emergency, Anita finds herself isolated at home while facing personal challenges. As she adapts to the new reality, an unexpected situation tests her resilience and changes her perspective on life.","genre_ids":[18,53],"popularity":0.6169,"vote_count":1,"poster_path":"/upUB6qQVrAQ3jUUSUkDFOfGFdQn.jpg","release_date":"2026-01-30","vote_average":7,"backdrop_path":null,"original_title":"Lockdown","original_language":"ta"},{"id":514185,"adult":false,"title":"Savage Youth","video":false,"overview":"Horrorcore hip-hop, drugs, and the lives of six troubled teens collide in a decaying, racially-divided town. While Elena and aspiring rapper Jason fall into a turbulent relationship, Gabe, an earnest young man frustrated with his position in life, begins slinging drugs.","genre_ids":[80,18],"popularity":0.2213,"vote_count":18,"poster_path":"/vbc9BzgBLUmb8HEALCuAhswNVbx.jpg","release_date":"2018-01-22","vote_average":5.611,"backdrop_path":"/jv0ZLckBz36IRgFgJBBia3egTQP.jpg","original_title":"Savage Youth","original_language":"en"},{"id":49342,"adult":false,"title":"On the Edge","video":false,"overview":"Three flatmates in Mexico City face uncertainties: Lucía who has a great job as an art director for TV commercials is abusing alcohol and cocaine. She risks losing her job, going to prison for assault, and she's woefully in love with a bullfighter who may be two-timing her. Carmen, an artist without income, can be manic - snorting lots of cocaine and hanging out with a gay man and a transvestite. What's her future? Hanna contemplates divorce from Abraham, a wealthy momma's boy, and she's disoriented by feelings of attraction to Sandra, a customer at her jewelry store. Can any of these poor little rich girls sort things out in a world of excess?","genre_ids":[18],"popularity":0.7052,"vote_count":27,"poster_path":"/mAkPHmxhYS4pLqB4CIfFhPGmzK6.jpg","release_date":"2006-11-24","vote_average":4.704,"backdrop_path":"/prZ5zyNozcjyN2VygercT0IApWF.jpg","original_title":"Así del precipicio","original_language":"es"},{"id":314030,"adult":false,"title":"Kiss Her Goodbye","video":false,"overview":"In this tense psychological drama, an emotionally unstable young woman and her brother drift from town to town. When a sympathetic motel maid takes pity on the girl -- and becomes romantically involved with her brother -- it could inadvertently spell doom for all of them.","genre_ids":[18],"popularity":0.2396,"vote_count":5,"poster_path":"/rDuwQDT4fF1ruy6qmt0WQXtBcXU.jpg","release_date":"1959-01-01","vote_average":5.4,"backdrop_path":null,"original_title":"Kiss Her Goodbye","original_language":"en"}],"external_ids":{"imdb_id":"tt0077740","twitter_id":null,"facebook_id":null,"wikidata_id":"Q950142","instagram_id":null,"metacritic_id":"movie/insiang-1976","mydramalist_id":"187734","rotten_tomatoes_id":"m/insiang_2007"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148363,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"CA","release_dates":[{"note":"Toronto International Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"1983-09-09T00:00:00.000Z","certification":""}]},{"iso_3166_1":"FR","release_dates":[{"note":"Cannes Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"1978-05-16T00:00:00.000Z","certification":""},{"note":"Cannes Film Festival (4K Restoration)","type":1,"iso_639_1":"","descriptors":[],"release_date":"2015-05-16T00:00:00.000Z","certification":""}]},{"iso_3166_1":"PH","release_dates":[{"note":"Metro Manila Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"1976-12-25T00:00:00.000Z","certification":""},{"note":"Cínemalaya Philippine Independent Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2012-07-27T00:00:00.000Z","certification":""},{"note":"World Premieres Film Festival (4K Restoration)","type":1,"iso_639_1":"","descriptors":[],"release_date":"2015-06-24T00:00:00.000Z","certification":""},{"note":"QCinema International Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2019-10-14T00:00:00.000Z","certification":""}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on