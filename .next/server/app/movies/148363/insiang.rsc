:null,"vote_count":2,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/l3Ivdu1FiRRn7UWM4mxs2La44qr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/aeSw8GNzL52Q0zUf8CAdMVMvvJK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/2jszHkRpzO6Z3gS0IvIBue0VHHE.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/n6tX7rQvK8PfaVpMt7i8owegSVR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/oB4kTWwj51u9csYSfUZaZ8xHnDQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/7HH43lRrf0vJXNxBeZMfC3Ab2js.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/jyCQIk1et2f1oLV4RBaVMt5Rt51.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/m0u0xY3XpEwS5Dr93VnuBY5q16o.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/kPnuLhdAvJDtNW39cxfIvuz47kL.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/ivf8wqBwmH0aglM42udeyi43fCE.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:04:58.172+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":95,"tagline":"","homepage":"","overview":"A story about the life of a young girl living with her mother in the slums of Manila, which becomes unbearable when her mother's young boyfriend moves in with them."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Insiang habite un bidonville de Manille avec sa mère, la tyrannique Tonya. Elle se démène corps et âme pour survivre dans ce quartier où chômage et alcoolisme font partie intégrante du quotidien. Un jour, Tonya ramène chez elles son nouvel amant, Dado, le caïd du quartier, en âge d’être son fils. Ce dernier tombe rapidement sous le charme de sa nouvelle « belle-fille »…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Инсиянг","runtime":94,"tagline":"","homepage":"","overview":"Действието във филма протича в бедняшките квартали на Манила. Красиво момиче изнасилено от любовника на майка си, измисля хитроумен план за отмъщение."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Das Mädchen Insiang","runtime":90,"tagline":"","homepage":"","overview":"Die junge Frau Insiang lebt mit ihrer Mutter Tonja in trostlosen Verhältnissen in Manila. Einzig die Liebe zu ihrem Freund Bebot gibt ihr Hoffnung. Als sie von Dado, dem Freund ihrer Mutter, vergewaltigt wird, sucht sie Hilfe bei Bebot, der jedoch ihre Hilflosigkeit nur ausnutzt. Ihre Mutter glaubt ihr zwar, meint aber Insiang habe selbst Schuld, da sie Dado schöne Augen gemacht habe. Insiang fängt an einen Racheplan für Dado, Bebot und Tonja zu schmieden."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"인시앙","runtime":0,"tagline":"","homepage":"","overview":"필리핀 영화 최초로 칸영화제에 초청된 문제작. 인시앙은 엄마의 학대와 애인의 배신을 견디며 살아간다. 마을 건달인 다도가 그녀를 차지하기 위해 엄마와 동거를 시작하고, 결국 그녀를 겁탈하지만 엄마는 오히려 인시앙을 비난한다. 이제 순수했던 인시앙의 예측불가한 복수가 시작된다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"英湘","runtime":95,"tagline":"","homepage":"","overview":"一名被母亲的新男友强奸的年轻女子找到了复仇的新方法。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Инсианг","runtime":0,"tagline":"","homepage":"","overview":"Действие фильма происходит в трущобах филиппинской Манилы. Красивую девушку насилует любовник её матери, и девушка придумывает хитрый план мести."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Pierwszy filipiński film wyświetlany na festiwalu w Cannes, wyreżyserowany prze legendę kina z tego kraju - Lino Brockę. Insiang jest ubogą nastolatką zgwałconą przez kochanka swojej matki. Pomimo poinformowania o tym incydencie, nie spotyka się ze współczuciem ani pomocą. Poprzysięga więc zemstę na tych, którzy zniszczyli jej życie."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":94,"tagline":"","homepage":"","overview":"Insiang é a filha explorada da favela que suporta abusos de todos ao seu redor: seu namorado insensível, sua mãe harpia e o amante mais jovem e desprezível de sua mãe. Mas depois de ser estuprada por ele, a timidez de Insiang se transforma em determinação para se vingar."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"}],"reviews_tmdb":[],"recommendations":[{"id":49964,"adult":false,"title":"Where Is The Friend's House?","video":false,"overview":"An 8-year-old boy must return his friend's notebook he took by mistake, lest his friend be punished by expulsion from school.","genre_ids":[18,12],"media_type":"movie","popularity":1.1505,"vote_count":422,"poster_path":"/2rTW4s1kgvoqVs0Kv8ARle1SrkF.jpg","release_date":"1987-07-01","vote_average":7.892,"backdrop_path":"/ylBiGZhgBsly0frseG2PvqoYM4o.jpg","original_title":"خانه‌ی دوست کجاست؟","original_language":"fa"},{"id":2593,"adult":false,"title":"The Fire Within","video":false,"overview":"Depressed Alain Leroy leaves the clinic where he was detoxified. He meets friends, acquaintances and women, trying to find a reason to continue living.","genre_ids":[18],"media_type":"movie","popularity":0.6267,"vote_count":239,"poster_path":"/9iHsReoh2VuHihDmNXgLXCi18rR.jpg","release_date":"1963-10-15","vote_average":7.6,"backdrop_path":"/aHMsHOCPSVD4Mv5rLf5k4JetPAv.jpg","original_title":"Le Feu follet","original_language":"fr"},{"id":19204,"adult":false,"title":"The Beyond","video":false,"overview":"A young woman inherits an old hotel in Louisiana where, following a series of supernatural \"accidents\", she learns that the building was built over one of the entrances to Hell.","genre_ids":[27],"media_type":"movie","popularity":1.4261,"vote_count":651,"poster_path":"/kMSZHq9VYQV1FCbM8nz2zrZShzx.jpg","release_date":"1981-04-22","vote_average":6.916,"backdrop_path":"/ysCpbgA1zxOmkb1IWKzwhTxDxk3.jpg","original_title":"...E tu vivrai nel terrore! L'aldilà","original_language":"it"},{"id":52103,"adult":false,"title":"Pickpocket","video":false,"overview":"A small town pickpocket whose friends have moved on to higher trades finds himself bitter and unable to adapt.","genre_ids":[18],"media_type":"movie","popularity":0.7133,"vote_count":120,"poster_path":"/cAhJeNYIARl0T6mHISxfiWThvIT.jpg","release_date":"1997-08-01","vote_average":7.2,"backdrop_path":"/92wIfI4yh0Sh7YVx82Iy0ogeD6E.jpg","original_title":"小武","original_language":"zh"},{"id":56126,"adult":false,"title":"Batch '81","video":false,"overview":"Sid Lucero, a 21-year old pre-Med student, is an aspiring neophyte of the Alpha Kappa Omega fraternity. Over a six-month initiation period, he and six other neophytes are subjected to severe physical and psychological torture in and outside the fraternity house.","genre_ids":[18,53],"media_type":"movie","popularity":0.5366,"vote_count":18,"poster_path":"/lTz0Zq9RNZTV4CPbg6Bpvee66VU.jpg","release_date":"1982-11-18","vote_average":5.6,"backdrop_path":"/dw1Q06oqvoL77ZIhsRBmfOCAHIk.jpg","original_title":"ΑΚΩ 81","original_language":"tl"},{"id":90826,"adult":false,"title":"All Nothing","video":false,"overview":"An illustration of beings in a world where countless plant and animal species rapidly become extinct, and resources run dry due to greed. However, it is possible to avoid disaster by conserving and sharing what we have.","genre_ids":[16],"media_type":"movie","popularity":0.2123,"vote_count":14,"poster_path":null,"release_date":"1978-01-01","vote_average":6.1,"backdrop_path":"/rIuHYFURdzPnBYK6jHeyDBlD3t8.jpg","original_title":"Tout rien","original_language":"fr"},{"id":21484,"adult":false,"title":"Possession","video":false,"overview":"A young woman left her family for an unspecified reason. The husband determines to find out the truth and starts following his wife. At first, he suspects that a man is involved. But gradually, he finds out more and more strange behaviors and bizarre incidents that indicate something more than a possessed love affair.","genre_ids":[27],"media_type":"movie","popularity":7.7098,"vote_count":1277,"poster_path":"/lUFZsUuJ0YyhBXH8D2BFUd6wODm.jpg","release_date":"1981-05-27","vote_average":7.331,"backdrop_path":"/dHvNDVe4gdyp3QxAzX5yaWnoaEB.jpg","original_title":"Possession","original_language":"en"},{"id":374720,"adult":false,"title":"Dunkirk","video":false,"overview":"The story of the miraculous evacuation of Allied soldiers from Belgium, Britain, Canada and France, who were cut off and surrounded by the German army from the beaches and harbour of Dunkirk between May 26th and June 4th 1940 during World War II.","genre_ids":[10752,28,18],"media_type":"movie","popularity":9.2176,"vote_count":17333,"poster_path":"/b4Oe15CGLL61Ped0RAS9JpqdmCt.jpg","release_date":"2017-07-19","vote_average":7.449,"backdrop_path":"/ddIkmH3TpR6XSc47jj0BrGK5Rbz.jpg","original_title":"Dunkirk","original_language":"en"},{"id":680,"adult":false,"title":"Pulp Fiction","video":false,"overview":"A burger-loving hit man, his philosophical partner, a drug-addled gangster's moll and a washed-up boxer converge in this sprawling, comedic crime caper. Their adventures unfurl in three stories that ingeniously trip back and forth in time.","genre_ids":[53,80,35],"media_type":"movie","popularity":25.4546,"vote_count":29734,"poster_path":"/vQWk5YBFWF4bZaofAbv0tShwBvQ.jpg","release_date":"1994-09-10","vote_average":8.486,"backdrop_path":"/96hiUXEuYsu4tcnvlaY8tEMFM0m.jpg","original_title":"Pulp Fiction","original_language":"en"},{"id":98,"adult":false,"title":"Gladiator","video":false,"overview":"After the death of Emperor Marcus Aurelius, his devious son takes power and demotes Maximus, one of Rome's most capable generals who Marcus preferred. Eventually, Maximus is forced to become a gladiator and battle to the death against other men for the amusement of paying audiences.","genre_ids":[28,18,12],"media_type":"movie","popularity":15.3337,"vote_count":20539,"poster_path":"/ty8TGRuvJLPUmAR1H1nRIsgwvim.jpg","release_date":"2000-05-04","vote_average":8.222,"backdrop_path":"/jhk6D8pim3yaByu1801kMoxXFaX.jpg","original_title":"Gladiator","original_language":"en"},{"id":155,"adult":false,"title":"The Dark Knight","video":false,"overview":"Batman raises the stakes in his war on crime. With the help of Lt. Jim Gordon and District Attorney Harvey Dent, Batman sets out to dismantle the remaining criminal organizations that plague the streets. The partnership proves to be effective, but they soon find themselves prey to a reign of chaos unleashed by a rising criminal mastermind known to the terrified citizens of Gotham as the Joker.","genre_ids":[28,80,53],"media_type":"movie","popularity":31.0957,"vote_count":35224,"poster_path":"/qJ2tW6WMUDux911r6m7haRef0WH.jpg","release_date":"2008-07-16","vote_average":8.526,"backdrop_path":"/dqK9Hag1054tghRQSqLSfrkvQnA.jpg","original_title":"The Dark Knight","original_language":"en"},{"id":11324,"adult":false,"title":"Shutter Island","video":false,"overview":"World War II soldier-turned-U.S. Marshal Teddy Daniels investigates the disappearance of a patient from a hospital for the criminally insane, but his efforts are compromised by troubling visions and a mysterious doctor.","genre_ids":[18,53,9648],"media_type":"movie","popularity":15.5164,"vote_count":25456,"poster_path":"/nrmXQ0zcZUL8jFLrakWc90IR8z9.jpg","release_date":"2010-02-14","vote_average":8.2,"backdrop_path":"/8xt8AMb1OKC63AdhNSaYBWxB4Iq.jpg","original_title":"Shutter Island","original_language":"en"},{"id":389,"adult":false,"title":"12 Angry Men","video":false,"overview":"The defense and the prosecution have rested and the jury is filing into the jury room to decide if a young Spanish-American is guilty or innocent of murdering his father. What begins as an open and shut case soon becomes a mini-drama of each of the jurors' prejudices and preconceptions about the trial, the accused, and each other.","genre_ids":[18],"media_type":"movie","popularity":13.1707,"vote_count":9764,"poster_path":"/ow3wq89wM8qd5X7hWKxiRfsFf9C.jpg","release_date":"1957-04-10","vote_average":8.556,"backdrop_path":"/w4bTBXcqXc2TUyS5Fc4h67uWbPn.jpg","original_title":"12 Angry Men","original_language":"en"},{"id":14,"adult":false,"title":"American Beauty","video":false,"overview":"Lester Burnham, a depressed suburban father in a mid-life crisis, decides to turn his hectic life around after developing an infatuation with his daughter's attractive friend.","genre_ids":[18],"media_type":"movie","popularity":11.2252,"vote_count":12825,"poster_path":"/wby9315QzVKdW9BonAefg8jGTTb.jpg","release_date":"1999-09-15","vote_average":8.002,"backdrop_path":"/2ndw55F40IkALzWyjCCza3M6nqM.jpg","original_title":"American Beauty","original_language":"en"},{"id":239,"adult":false,"title":"Some Like It Hot","video":false,"overview":"In Prohibition-era Chicago, musicians Joe and Jerry witness a mob hit, and flee the state in an all-female band disguised as Josephine and Daphne, but further complications set in.","genre_ids":[35,10749,80],"media_type":"movie","popularity":3.8469,"vote_count":3787,"poster_path":"/hVIKyTK13AvOG