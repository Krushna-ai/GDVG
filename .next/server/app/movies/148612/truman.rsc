"display_priority":33},{"logo_path":"/j7D006Uy3UWwZ6G0xH6BMgIWTzH.jpg","provider_id":212,"provider_name":"Hoopla","display_priority":34},{"logo_path":"/vLZKlXUNDcZR7ilvfY9Wr9k80FZ.jpg","provider_id":538,"provider_name":"Plex","display_priority":126},{"logo_path":"/27WMfRN7pQE3j5Khm8fPM7vYyLV.jpg","provider_id":2077,"provider_name":"Plex Channel","display_priority":127},{"logo_path":"/pSUa7lMYLoQAU00ikXoHxmOfTZ9.jpg","provider_id":2409,"provider_name":"Fawesome","display_priority":145}],"link":"https://www.themoviedb.org/movie/341744-truman/watch?locale=US","rent":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":6}],"flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":9,"provider_name":"Amazon Prime Video","display_priority":5},{"logo_path":"/8aBqoNeGGr0oSA85iopgNZUOTOc.jpg","provider_id":2100,"provider_name":"Amazon Prime Video with Ads","display_priority":204}]},"UY":{"link":"https://www.themoviedb.org/movie/341744-truman/watch?locale=UY","flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":25}]},"VE":{"link":"https://www.themoviedb.org/movie/341744-truman/watch?locale=VE","flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":1}]}}},"wikidata_id":"Q21034423","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-26T00:25:31.008321+00:00","region":null,"main_poster":null,"images":{"logos":[{"width":1547,"height":462,"file_path":"/8p7zIdMzi564XWMOl9nOh1YLmod.png","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":3.348,"vote_average":0},{"width":625,"height":101,"file_path":"/urEMex5zsZY6WBmrqB9BOZysE6.png","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":6.188,"vote_average":0}],"posters":[{"width":1400,"height":2100,"file_path":"/n