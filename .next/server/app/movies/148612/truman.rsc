EwhVuifN.jpg","iso_639_1":"fi","iso_3166_1":"FI","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/mDl2XRUxGnAvnAGznmV14FLB8ZP.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/5WqwNsKa9WqaWFe131NZooSXxDW.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/vqNxnIQTxmZrnfSmABkckGWuvIx.jpg","iso_639_1":"sv","iso_3166_1":"SE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/udH69CzIHwvCtQwxA3yL7n373ju.jpg","iso_639_1":"ro","iso_3166_1":"RO","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":600,"height":900,"file_path":"/swNtDyP81Ju6SZEWa3Y0pX2tZnN.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1080,"height":1620,"file_path":"/8Ta7Sjm2UqG6WFF4QhtmIGJ8d6E.jpg","iso_639_1":"uk","iso_3166_1":"UA","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1527,"height":2174,"file_path":"/iMoNuT9DYp15OWXbZvbU4e9ydo8.jpg","iso_639_1":"hu","iso_3166_1":"HU","vote_count":0,"aspect_ratio":0.702,"vote_average":0}],"backdrops":[{"width":1600,"height":900,"file_path":"/iUAFLqAj7p1v8zkOReyd7tjSLDg.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/lv1TvjyBH6Whq0ScDRPmr90lSLt.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/gfXdgIy0hIAewJZaRmlREKKQfdO.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T04:05:35.909+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":105,"tagline":"Los mejores amigos son para siempre","homepage":"https://imposiblefilms.net/truman","overview":"Tomás, que vive en Canadá, viaja a Madrid, España, para visitar a su viejo amigo Julián. Ambos, acompañados por Truman, el fiel perro de Julián, compartirán durante apenas unos días muchos pequeños momentos sorprendentes y emotivos, desencadenados por la dura situación que Julián está viviendo."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":105,"tagline":"Friendship is what matters in life","homepage":"","overview":"Tomás, who lives in Canada, travels to Madrid, Spain, to visit his old friend Julián. Both of them, accompanied by Truman, Julián's faithful dog, will share many surprising and emotional little moments, triggered by the hard situation Julián is going through, for just a few days."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Freunde fürs Leben","runtime":105,"tagline":"","homepage":"http://www.stadtgame.de/news/freunde-fuers-leben","overview":"In ihrer Kindheit waren die Freunde Julián und Tomás einst unzertrennlich. Irgendwann haben sich die beiden dann allerdings weitestgehend aus den Augen verloren. Während der geschiedene Julián in Spanien geblieben ist und dort die Hochs und Tiefs einer Schauspielkarriere durchlebt hat, ist der Lehrer Tomás nach Kanada ausgewandert, wo er sich eine beschauliche Existenz mitsamt Job, Frau und Kindern aufgebaut hat. Als sich die beiden Männer eines Tages jedoch in Madrid wiedersehen, lebt ihre Freundschaft sofort wieder auf, so als wäre sie nie eingeschlafen. Gemeinsam verbringen die Zwei in der Stadt ein paar wundervolle Tage voller nostalgischer Erinnerungen und unvergesslicher Erlebnisse – immer in dem Wissen, dass dies wohl ihr letztes Wiedersehen sein wird, da Julián Krebs im Endstadium hat."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"טרומן","runtime":105,"tagline":"חברים עד הסוף","homepage":"","overview":"חוליאן שחקן תיאטרון מוערך, גר במדריד עם כלבו הנאמן טרומן ומתמודד עם רגעים קשים בחייו. כאשר חברו הטוב תומאס, המתגורר בקנדה, מחליט לבקר אותו במפתיע לארבעה ימים, שני חברי הילדות, המכירים זה את זה עשרות שנים, משלימים פערים בזמן קצר וחולקים רגעים מרגשים וקרובים. במהלך הזמן שלהם יחדיו יבינו השניים שהביקור הנוכחי יהיה כנראה מפגשם האחרון."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"Ο Ζουλιάν και ο Τομάς, φίλοι από παιδιά, βρίσκονται ξανά μαζί, έπειτα από πολλά χρόνια που είχαν να ιδωθούν.  Χωρισμένοι τόσο καιρό από έναν ολόκληρο Ατλαντικό ωκεανό, οι δύο φίλοι έφτιαξαν τη ζωή τους σε διαφορετικές ηπείρους, αλλά τώρα μοιάζουν σαν να μη χώρισαν ποτέ.  Οι δυο τους θα περάσουν αξέχαστες ημέρες παρέα: γελώντας, αναπολώντας, κλαίγοντας.  Και ο λόγος είναι ότι αυτή τους η συνάντηση μέλει να είναι η τελευταία."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"特鲁曼","runtime":105,"tagline":"","homepage":"","overview":"死期在自己選擇下到來， 荷利安最放不下是老狗Truman，告別從Truman 開始。遠方的死黨托馬士驚聞噩耗飛奔馬德里，四天任務，本來遊說荷利安繼續治療，但一開始荷利安便去跟醫生道別，再去面試狗狗領養人，還為Truman 將痛失愛主做心理諮詢。死亡是契機，他看懂了身邊人，包括尷尬遇上的朋友、不曉得父親將死的兒子。托馬士默默守望立場變軟，溫暖友情這一刻比死重要。坦然處理死亡，淚中不忘人生的歡喜，兩主角入戲得像真知己，雙雙獲封聖塞巴斯蒂安電影節影帝。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"Dois amigos de infância, separados por um oceano, se encontram depois de muitos anos. Eles passam uns dias juntos, lembrando os velhos tempos e grande amizade que se manteve com os anos, tornando-os inesquecíveis, devido o seu reencontro ser também o último adeus."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"Julian, un madrilène, reçoit la visite inattendue de son ami Tomas qui vit au Canada. Ils sont loin de se douter qu’ils vont passer avec Truman, le chien fidèle de Julian, des moments émouvants et surprenants…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Truman: un vero amico è per sempre","runtime":105,"tagline":"","homepage":"","overview":"Julián e Tomás, due vecchi amici, si rivedono dopo un lungo periodo in cui si erano persi di vista. Nonostante il tempo trascorso, per loro è come se gli anni non fossero mai passati. Insieme al fedele amico a quattro zampe Truman, vivono alcuni giorni indimenticabili tra risate e ricordi. Ma anche pianti, dal momento che il loro incontro è un addio, teso ad accettare come la morte faccia parte della vita."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"Truman, Arjantin ve İspanya sinemasının iki ünlü aktörünü buluşturan, mizah ile dramı başarıyla harmanlayan, dostluk örneği bir film… Kanser tedavisine son vermeye karar veren Julian, ölüme kendini hazırlamıştır. Sadık köpeği Truman ile birlikte yaşayan Julian’ı Kanada’da yaşayan arkadaşı Tomas ziyaret eder. Tomas’ın gelme nedeni Julian’ı kararından vazgeçirmektir. İki eski dost, Truman’ı sahiplenecek bir aile ararlar. Julian’ın oğlunu ziyaret etmek için Amsterdam’a giderler. Birlikte daha pek çok şey yapacaklardır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Труман","runtime":105,"tagline":"Приятелството е това, което има значение в живота","homepage":"","overview":"Хулиан неочаквано е посетен от приятеля си Томас, живеещ в Канада. През 4 наситени с преживявания дни двамата, придружени от кучето на Хулиан – Труман, споделят емоционални моменти."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"El Julián rep la visita inesperada del seu amic Tomás, que viu al Canadà. Tots dos amics, amb el Truman, el seu gos fidel, compartiran al llarg de quatre intensos dies moments emotius i sorprenents provocats per la difícil situació que viu el Julián."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"Julian és Tomas gyerekkori barátok, akik évek óta nem látták egymást: életüket távoli kontinenseken, az Atlanti-óceán két partján élték. Mikor újra találkoznak, olyan, mintha soha nem szakadtak volna el. Együtt töltenek néhány felejthetetlen napot: nevetnek, emlékeznek, sírnak. Találkozásuk egyben búcsú is."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Truman - venner for livet","runtime":105,"tagline":"","homepage":"","overview":"Tomás er bosat i Canada, men tager som en overraskelse til Madrid for at besøge sin bedste og ældste ven Julián, som bor sammen med sin trofaste følgesvend: hunden Truman. Julián er en mand, der ved, hvad han vil, og på grund af sit stålsatte sind kommer både han og Tomás i situationer, som er følelsesmæssigt overvældende, men som samtidigt skaber minder for livet. Denne tragikomiske historie sætter fokus på venskabet, og hvordan det bringer både glædelige og sørgelige stunder med sig. Og hvordan afsluttes et besøg og et liv sammen på bedste vis, når man ved, det er sidste gang, man ses?"},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"https://tydzienkinahiszpanskiego.com/2017/02/14/truman/","overview":"Przyjaciele z młodości, Julián i Tomás, spotykają się po wielu latach jako dojrzali mężczyźni. Julián jest argentyńskim aktorem, który musiał opuścić swoją ojczyznę. Mieszka w Hiszpanii. Przechodzi najtrudniejszy okres swojego życia. Jedynym jego kompanem jest wierny pies, Truman, który nie opuszcza swojego pana na krok. Tomás jest matematykiem, pracuje na uniwersytecie w Kanadzie. Przyjaciele spotykają się w Madrycie, gdzie chcą spędzić razem kilka fantastycznych dni. Wiedzą, że to ich ostatnie spotkanie."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"트루만","runtime":105,"tagline":"","homepage":"","overview":"여러 해 동안 헤어져 지낸 어린 시절의 두 친구. 둘은 함께 웃고 추억을 떠올리고 눈물을 흘리면서 잊지 못할 며칠을 보낸 후, 작별을 고한다. 우정과 사랑의 비가이자, 죽음을 삶의 일부로 받아들이는 용기를 유머러스하고 정직하게 그린 초상화다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"人狗情未了","runtime":105,"tagline":"","homepage":"","overview":"這是一部友情題材的劇情片，描述一名男子居住在馬德裏，大清早醒來，一開門卻遇見熟面孔，而且是遠從加拿大專程前來拜訪的老朋友，意外造訪，短暫停留四天。老友原本打算説服男子重視生命，改變他拒絕接受化學治療的態度。但是，四天的相處，他們都知道也都相信，平衡陪伴、坦言與尊重，永遠是朋友之間最重要的。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"只想陪著你","runtime":105,"tagline":"","homepage":"","overview":"這是一部友情題材的劇情片，描述一名男子居住在馬德里，大清早醒來，一開門卻遇見熟面孔，而且是遠從加拿大專程前來拜訪的老朋友，意外造訪，短暫停留四天。老友原本打算說服男子重視生命，改變他拒絕接受化學治療的態度。但是，四天的相處，他們都知道也都相信，平衡陪伴、坦言與尊重，永遠是朋友之間最重要的。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Una sonrisa a la vida","runtime":105,"tagline":"Se puede perder todo menos los amigos","homepage":"","overview":"Tomás, que vive en Canadá, viaja a Madrid, España, para visitar a su viejo amigo Julián. Ambos, acompañados por Truman, el fiel perro de Julián, compartirán durante apenas unos días muchos pequeños momentos sorprendentes y emotivos, desencadenados por la dura situación que Julián está viviendo."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"Julián is een acteur en levensgenieter die de vijftig is gepasseerd. Hij is terminaal ziek en accepteert dat sterven deel uitmaakt van het leven, daarom organiseert hij zijn laatste afscheid. Zijn jeugdvriend Tomás komt hem uit Canada bezoeken, ze hebben elkaar in jaren niet gezien."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Paras ystäväni Truman","runtime":105,"tagline":"","homepage":"","overview":""},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Vänner för livet","runtime":105,"tagline":"","homepage":"","overview":"Julián bor i Barcelona med sin boxer Truman och gör sitt yttersta för att hålla humöret uppe trots att han är dödssjuk i cancer. När barndomskompisen Tomás korsar hela jordklotet för att återse Julián efter många år isär, får de en sista chans att återuppta den vänskap som nästan gått förlorad. Det blir fyra dagar som Julián inte hade kunnat leva utan och som Tomás aldrig kommer att glömma."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Трумэн","runtime":105,"tagline":"","homepage":"","overview":"К Хулиану неожиданно из Канады приезжает друг Томас после того, как узнаёт, что тот решает не продолжать борьбу с раком. Двое друзей, вместе с собакой Хулиана по кличке Трумэн, переживают четыре насыщенных дня."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Trumanas","runtime":105,"tagline":"","homepage":"","overview":"Chulianas ir Tomas po daugelio metų susitinka praleisti kelių dienų, tačiau jų pasimatymas tampa ir atsisveikinimu. Chulianui diagnozuota paskutinė vėžio stadija. Jis nutaria nesigydyti, o sutvarkyti visus svarbiausius reikalus: išdalyti savo nuosavybę, surengti savo paties laidotuves ir, svarbiausia, surasti naujus namus savo mylimam šuniui Trumanui. Šis filmas – draugystės ir meilės elegija. Šmaikštus ir nuoširdus drąsos susitaikyti su artėjančia mirtimi portretas."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Трумен","runtime":0,"tagline":"","homepage":"","overview":"До Хуліана несподівано приїздить друг з Канади Томас, коли дізнається, що той вирішує облишити свою боротьбу з раком. Двоє друзів, разом із собакою Хуліана по кличці Трумен, переживають чотири насичених дні."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"}],"reviews_tmdb":[{"id":"56cdf05d92514152ab00017b","url":"https://www.themoviedb.org/review/56cdf05d92514152ab00017b","author":"Reno","content":"$11","created_at":"2016-02-24T18:03:09.912Z","updated_at":"2024-05-16T15:18:28.626Z","author_details":{"name":"Reno","rating":7,"username":"Rangan","avatar_path":"/6ZpVUJzqXMzH35VprEtnX0sNI3.jpg"}}],"recommendations":[{"id":413043,"adult":false,"title":"Safari","video":false,"overview":"Africa. In the wild expanses, where bush-bucks, impalas, zebras, gnus and other creatures graze by the thousands, they are on holiday. German and Austrian hunting tourists drive through the bush, lie in wait, stalk their prey. They shoot, sob with excitement and pose before the animals they have bagged. A vacation movie about killing, a movie about human nature.","genre_ids":[99],"media_type":"movie","popularity":0.2841,"vote_count":31,"poster_path":"/tK7DoH4plUvVkToGZZDFMbLfmFy.jpg","release_date":"2016-09-16","vote_average":6.5,"backdrop_path":"/aq9vkM7Iar3PFzpwoiewI9KELNn.jpg","original_title":"Safari","original_language":"de"},{"id":248927,"adult":false,"title":"En un lugar de la Manga","video":false,"overview":"","genre_ids":[35],"media_type":"movie","popularity":0.1302,"vote_count":16,"poster_path":"/HPpyQEJCkU3YX0asfUI9SEvIzl.jpg","release_date":"1970-10-12","vote_average":4.6,"backdrop_path":null,"original_title":"En un lugar de la Manga","original_language":"es"},{"id":54677,"adult":false,"title":"Four Days in October","video":false,"overview":"When the night of October 16, 2004 came to a merciful end, the Curse of the Bambino was alive and well. The vaunted Yankee lineup, led by A-Rod, Jeter, and Sheffield, had just extended their ALCS lead to three games to none, pounding out 19 runs against their hated rivals. The next night, in Game 4, the Yankees took a 4-3 lead into the bottom of the ninth inning, then turned the game over to Mariano Rivera, the best relief pitcher in postseason history, to secure yet another trip to the World Series. But after a walk and a hard-fought stolen base, the cold October winds of change began to blow. Over four consecutive days and nights, this unlikely group of Red Sox miraculously won four straight games to overcome the inevitability of their destiny. Major League Baseball Productions will produce a film in \"real-time\" that takes an in-depth look at the 96 hours that brought salvation to Red Sox Nation and made baseball history in the process.","genre_ids":[99],"media_type":"movie","popularity":0.349,"vote_count":18,"poster_path":"/o49Y11zT4B68iXdWIXq3jSHQsGa.jpg","release_date":"2010-10-05","vote_average":6.5,"backdrop_path":"/dyvxwzAZ3Fo2DZu9nGrYWd3L9I9.jpg","original_title":"Four Days in October","original_language":"en"},{"id":64340,"adult":false,"title":"A Witch's Way of Love","video":false,"overview":"Michael Firch is very skilled in computers and he goes to Paris to meet very important persons to discuss a contract. Michael was born on a special astral date. On arriving in Paris, he meets Morgane and her son. Morgane is a witch, she is beautiful, she is good and she needs Michael to save her son from evil powers. Molok is a sorcerer and he opposes Morgana's plan.","genre_ids":[12,35,14,10749],"media_type":"movie","popularity":0.2821,"vote_count":92,"poster_path":"/azNil7xE2srTzvKYY6wnAf6o9M6.jpg","release_date":"1997-03-19","vote_average":5.2,"backdrop_path":"/tu1Yzp1pw52EvM8Gn97M7voULjk.jpg","original_title":"Un amour de sorcière","original_language":"fr"},{"id":374452,"adult":false,"title":"Sieranevada","video":false,"overview":"Back from a professional trip to Paris, a neurologist at the pinnacle of his career has to pick up his wife so that they can attend a family meal to commemorate his father, who died a year before. At his mother's flat, the guests are waiting for the priest to arrive while arguing about all kinds of things connected and unconnected with the world’s events and wars.","genre_ids":[18],"media_type":"movie","popularity":2.9699,"vote_count":102,"poster_path":"/q48ZKaoCQg5nVJvfXBRzMTl38Fa.jpg","release_date":"2016-08-03","vote_average":6.725,"backdrop_path":"/dFiyjd2FTjKipUlNMcSe7h8IpOJ.jpg","original_title":"Sieranevada","original_language":"ro"},{"id":300601,"adult":false,"title":"It's Now or Never","video":false,"overview":"Narrates the preparation for a wedding of a Spanish couple in which everything goes wrong.","genre_ids":[35],"media_type":"movie","popularity":0.4243,"vote_count":183,"poster_path":"/u0spUWBehJTLqchm9oZpR0m9aDK.jpg","release_date":"2015-06-19","vote_average":5.5,"backdrop_path":"/fdJh9wgbCZWeSESTHOpX5b1B6c1.jpg","original_title":"Ahora o nunca","original_language":"es"},{"id":57052,"adult":false,"title":"The Right Distance","video":false,"overview":"The arrival of an attractive young teacher in a small town in the Po valley disturbs the drowsy life of the place, leading eventually to a murder.","genre_ids":[18,9648],"media_type":"movie","popularity":0.2281,"vote_count":70,"poster_path":"/4ZySEbzk0dQ3wsytqg9nItn8jlq.jpg","release_date":"2007-10-19","vote_average":6.9,"backdrop_path":"/pGj2RcsnY2zTexFdiTrqNnodSjU.jpg","original_title":"La giusta distanza","original_language":"it"},{"id":436827,"adult":false,"title":"Getaway Plan","video":false,"overview":"A thief expert with blowtorch is hired by a group of the Russian mob for a bank assault.","genre_ids":[28,53],"media_type":"movie","popularity":0.5363,"vote_count":95,"poster_path":"/y94HULDnIszOyMPM1fJzgkFYtEn.jpg","release_date":"2017-04-28","vote_average":5.537,"backdrop_path":"/hdw85gmgQnfsgoAd3d3MtunyBEA.jpg","original_title":"Plan de fuga","original_language":"es"},{"id":391617,"adult":false,"title":"Kóblic","video":false,"overview":"Colonia Helena, Argentina. The mysterious Tomás Kóblic, a former Navy pilot, works as a fumigator while dealing with his dark past and the intrigues of the corrupt police commissioner…","genre_ids":[18,53],"media_type":"movie","popularity":1.4127,"vote_count":77,"poster_path":"/aTpSCZ8VaqSyUkI3PhEQIHnYzbC.jpg","release_date":"2016-04-14","vote_average":5.961,"backdrop_path":"/dKAudJwmkENqL1FZYP9351rItZs.jpg","original_title":"Kóblic","original_language":"es"},{"id":389044,"adult":false,"title":"The Together Project","video":false,"overview":"Samir, a lanky crane operator in Montreuil, falls madly for Agathe. As master swimmer at the pool Thorez he decides to take swimming lessons with her. But the lie does not last three lessons - Agathe hate liars. Chosen to represent the Seine-Saint-Denis, Agathe flies to Iceland for the 10th Congress of the International Masters Swimming. Samir has no choice but to fly in turn also.","genre_ids":[18,35,10749],"media_type":"movie","popularity":0.2421,"vote_count":97,"poster_path":"/boN4R7vdMzfs6QYV9CWI2ZEOV3f.jpg","release_date":"2016-06-29","vote_average":5.9,"backdrop_path":"/46hp8s3IN8SjR8K4ukrWr32gQu5.jpg","original_title":"L'Effet aquatique","original_language":"fr"},{"id":13495,"adult":false,"title":"Captain Alatriste: The Spanish Musketeer","video":false,"overview":"In 17th century Spain Diego Alatriste, a brave and heroic soldier, is fighting in his King's army in the Flandes region. His best mate, Balboa, falls in a trap and, near to death, asks Diego to look after his son and teach him to be a soldier.","genre_ids":[28],"media_type":"movie","popularity":2.9069,"vote_count":246,"poster_path":"/hQ4b8dXp0uCqslHm0jOvjw4BNUe.jpg","release_date":"2006-09-01","vote_average":5.9,"backdrop_path":"/eqpkycxmFt6ETn9XuE6dT1ldCdi.jpg","original_title":"Alatriste","original_language":"es"},{"id":56399,"adult":false,"title":"August Vacation","video":false,"overview":"Like every August, journalist Sandro, his family and acquaintances vacation on the island of Ventotene. This time, however, they find out the house next door has been rented to a lower middle class family, whose crass nature and values soon clash with their own intellectual and progressive background.","genre_ids":[35,18],"media_type":"movie","popularity":0.1942,"vote_count":136,"poster_path":"/4Z0006tsCju5lqQJjb4kAsaXlhx.jpg","release_date":"1996-04-05","vote_average":6.8,"backdrop_path":"/rFWtYr9q6Hu3f0yZskWPRhssdDr.jpg","original_title":"Ferie d'agosto","original_language":"it"},{"id":296313,"adult":false,"title":"Men & Chicken","video":false,"overview":"Men & Chicken is a black comedy about two outcast brothers who, by getting to know their unknown family, discover a horrible truth about themselves and their relatives.","genre_ids":[35,18],"media_type":"movie","popularity":0.5075,"vote_count":245,"poster_path":"/6lZ1EjOoWJiZaGJe38052Hmt73l.jpg","release_date":"2015-02-05","vote_average":6.5,"backdrop_path":"/coAxeGkmdEXhsbSdpSsjg0i4cRn.jpg","original_title":"Mænd & høns","original_language":"da"},{"id":111479,"adult":false,"title":"CBGB","video":false,"overview":"A look at New York's dynamic punk rock scene through the lens of the ground-breaking Lower East Side club started by eccentric Hilly Kristal in 1973 which launched thousands of bands.","genre_ids":[18,10402],"media_type":"movie","popularity":0.8816,"vote_count":195,"poster_path":"/9xHdRPamTjLG4bosURJju6UYCHp.jpg","release_date":"2013-10-11","vote_average":6.328,"backdrop_path":"/tQbRiVWlznLEr7P6DIFrSvqgYE5.jpg","original_title":"CBGB","original_language":"en"},{"id":352025,"adult":false,"title":"Un + une","video":false,"overview":"A successful film composer falls in love when he travels to India to work on a Bollywood retelling of Romeo and Juliet.","genre_ids":[35,10749,18],"media_type":"movie","popularity":0.4326,"vote_count":197,"poster_path":"/1FAZpAfBsBtkAxUGkskXf4pTEUu.jpg","release_date":"2015-12-09","vote_average":5.8,"backdrop_path":"/hpg9P374zpTPqEdQ7157Hj1JL6t.jpg","original_title":"Un + une","original_language":"fr"},{"id":13926,"adult":false,"title":"Red's Dream","video":false,"overview":"Life as the sole sale item in the clearance corner of Eben's Bikes can get lonely. So Red, a unicycle, dreams up a clown owner and his own juggling act that steals the show. But all too soon, the applause turns into the sound of rainfall, as reality rushes back. Red must resign himself to sitting in the corner and await his fate.","genre_ids":[16,10751],"media_type":"movie","popularity":0.4888,"vote_count":353,"poster_path":"/ebPNnYqoEYntnrGdwtmppvBRHpu.jpg","release_date":"1987-07-10","vote_average":6.15,"backdrop_path":"/dxNJOGKmFRkTw9PATxvKhjlIHuP.jpg","original_title":"Red's Dream","original_language":"en"},{"id":325346,"adult":false,"title":"The Hollars","video":false,"overview":"Aspiring New York City artist John Hollar returns to his Middle America hometown on the eve of his mother’s brain surgery. Joined by his girlfriend, eight months pregnant with their first child, John is forced to navigate the crazy world he left behind.","genre_ids":[35,18,10749],"media_type":"movie","popularity":0.9288,"vote_count":327,"poster_path":"/9ybRAn6AoSuyMjfqbhgosdye2R5.jpg","release_date":"2016-08-25","vote_average":6.309,"backdrop_path":"/g302LRf1Gx3fQgq7IR8I6ITyVTi.jpg","original_title":"The Hollars","original_language":"en"},{"id":438634,"adult":false,"title":"Summer 1993","video":false,"overview":"After her mother's death, six-year-old Frida is sent to her uncle's family to live with them in the countryside. But Frida finds it hard to forget her mother and adapt to her new life.","genre_ids":[18],"media_type":"movie","popularity":0.3886,"vote_count":219,"poster_path":"/krdSl7IpDb9c31CXrzA5yfP1oYM.jpg","release_date":"2017-03-24","vote_average":7.05,"backdrop_path":"/29w1pHpc2HgihUfJwJUA5zFNkRT.jpg","original_title":"Estiu 1993","original_language":"ca"},{"id":351454,"adult":false,"title":"Neruda","video":false,"overview":"It’s 1948 and the Cold War has arrived in Chile. In the Congress, prominent Communist Senator and popular poet Pablo Neruda accuses the government of betraying the Party and is stripped of his parliamentary immunity by President González Videla. The Chief of Investigative Police instructs inspector Óscar Peluchonneau to arrest the poet. Neruda tries to escape from the country with his wife, the painter Delia del Carril, but they are forced to go underground.","genre_ids":[18],"media_type":"movie","popularity":2.899,"vote_count":276,"poster_path":"/7WwGjSjEEyP7NrgrI97o3mCezvL.jpg","release_date":"2016-08-11","vote_average":6.279,"backdrop_path":"/xZmLlXi7WYE42He0TWsK0891ACM.jpg","original_title":"Neruda","original_language":"es"},{"id":540709,"adult":false,"title":"Ema","video":false,"overview":"Ema is a magnetic and impulsive dancer in a reggaeton troupe. Her toxic marriage to choreographer Gastón is beyond repair, following a decision to give up on their adopted child Polo. She sets out on a mission to get him back, not caring who she’ll need to fight, seduce or destroy to make it happen.","genre_ids":[18],"media_type":"movie","popularity":0.5775,"vote_count":245,"poster_path":"/9p78EwUeo7NkFFCIBzU8jwxC867.jpg","release_date":"2019-09-26","vote_average":6.727,"backdrop_path":"/ks7PNbmkcxBoSLxF4bBbqiEofHP.jpg","original_title":"Ema","original_language":"es"}],"similar_content":[{"id":64,"adult":false,"title":"Talk to Her","video":false,"overview":"Two men share an odd friendship while they care for two women who are both in deep comas.","genre_ids":[18,10749],"popularity":1.2447,"vote_count":1408,"poster_path":"/fWDbQlOWOqjR5jZm98KjGyYmUOw.jpg","release_date":"2002-03-15","vote_average":7.58,"backdrop_path":"/9aCRXFWT1rd1nZDcEtWILKb2Sap.jpg","original_title":"Hable con ella","original_language":"es"},{"id":99,"adult":false,"title":"All About My Mother","video":false,"overview":"Following the tragic death of her teenage son, Manuela travels from Madrid to Barcelona in an attempt to contact the long-estranged father the boy never knew. She reunites with an old friend, an outspoken transgender sex worker, and befriends a troubled actress and a pregnant, HIV-positive nun.","genre_ids":[35,18],"p