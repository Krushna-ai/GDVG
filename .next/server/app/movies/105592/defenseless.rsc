,"translations":[{"data":{"title":"Defenseless","runtime":23,"tagline":"Why bother having a family?","homepage":"","overview":"A teenage girl in transition relies on people in the Twitter world to supplement the love and attention she doesn't receive from her family."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[{"id":989589,"adult":false,"title":"The Settlers","video":false,"overview":"Chile, early 20th century. José Menéndez, a wealthy landowner, hires three horsemen to mark out the perimeter of his extensive property and open a route to the Atlantic Ocean across vast Patagonia.","genre_ids":[18,37],"popularity":0.5758,"vote_count":145,"poster_path":"/1IwpJK6AyUmdJRnphBQFBLwVfRd.jpg","release_date":"2023-10-11","vote_average":6.8,"backdrop_path":"/kPFmVuiLK2Nkalhohsj3t7ph4aI.jpg","original_title":"Los colonos","original_language":"es"},{"id":462613,"adult":false,"title":"The Pugilist","video":false,"overview":"After his eldest son is murdered in a gangland hit, an absentee father desperately tries to protect what’s left of the shattered family he abandoned.","genre_ids":[18,80],"popularity":0.5083,"vote_count":5,"poster_path":"/yWFYOfUfoHs6HXomcgQM1IgBGBs.jpg","release_date":"2017-06-28","vote_average":6.8,"backdrop_path":"/s03W37zkC2XNQILnwqe5okZFdIh.jpg","original_title":"The Pugilist","original_language":"en"},{"id":853646,"adult":false,"title":"The Railway and the Girl","video":false,"overview":"The short film shot within the movie \"Ritual\" (2000)","genre_ids":[18],"popularity":0.2882,"vote_count":0,"poster_path":"/aaGCXW15Q9XIf7nWMWIJI1KqtQM.jpg","release_date":"2003-07-24","vote_average":0,"backdrop_path":null,"original_title":"鉄道と少女","original_language":"ja"},{"id":853655,"adult":false,"title":"Article 12","video":false,"overview":"A young Colombian woman confronts her father and best friend, who resist her taking to the streets to protest for fear of the repression and violence that is taking place in the streets.","genre_ids":[18],"popularity":0.566,"vote_count":0,"poster_path":"/pMGEQsbSYbrRYnEvVPESRlOJgGV.jpg","release_date":"2021-07-20","vote_average":0,"backdrop_path":null,"original_title":"Artículo 12","original_language":"es"},{"id":853662,"adult":false,"title":"Jaguar Man","video":false,"overview":"Two moments in the life of Pedro. First in 1997, he lives with his family in Rio de Janeiro and works at Gás do Brasil, a company that is undergoing a tough restructuring process, with layoffs and early retirements. Soon, privatization will come. In the second moment, two years later, Pedro lives retired in his hometown Barbosa, in the company of his childhood memories, his dog and his girlfriend. By interweaving these two moments in time, we put ourselves in Pedro's skin and experience his fears and delights.","genre_ids":[18],"popularity":0.1755,"vote_count":4,"poster_path":"/bEdbdPiipYf3SgmC0kjECGn7IoR.jpg","release_date":"2021-08-26","vote_average":4.2,"backdrop_path":"/syd9HgwwgAKSNiGYVLqooKb95Bl.jpg","original_title":"Homem Onça","original_language":"pt"},{"id":853665,"adult":false,"title":"The Fascist Jew","video":false,"overview":"Oberdan Rossi is half Jewish and a fascist. After coming back from the Ethiopian war, he becomes disillusioned and works as a journalist.","genre_ids":[18],"popularity":0.1361,"vote_count":2,"poster_path":"/rQRyAmYLU8q82ZwiIvnEl6Ocf9M.jpg","release_date":"1980-09-02","vote_average":2,"backdrop_path":null,"original_title":"L’ebreo fascista","original_language":"it"},{"id":1451309,"adult":false,"title":"De Grey, un Récit romanesque","video":false,"overview":"An elderly woman would like some company as her son is off venturing foreign lands and seducing women from lands afar. Her resident priest who seems to live in the same château as her does not agree and seems to have preconceptions and superstitions as to a family curse.","genre_ids":[18,10770],"popularity":0.1402,"vote_count":0,"poster_path":"/ph1IRlGgnV6awsL5kNd5IckXcGr.jpg","release_date":"1976-03-20","vote_average":0,"backdrop_path":"/Y6RTF7DS0uX4pAUSI3l5mBOthv.jpg","original_title":"De Grey, un Récit romanesque","original_language":"fr"},{"id":271223,"adult":false,"title":"The Plague","video":false,"overview":"A nurse in the Red Crescent (the Turkish equivalent of the Red Cross) fights to save the populace during a plague.","genre_ids":[18],"popularity":0.6068,"vote_count":1,"poster_path":"/y5wJXWk6aBg1rhkXZnqlTYer10Y.jpg","release_date":"1954-01-01","vote_average":6,"backdrop_path":null,"original_title":"Salgin","original_language":"en"},{"id":271231,"adult":false,"title":"The Land","video":false,"overview":"The film deals with the harsh realities of village life and the problems of landholding The film, in an almost documentary style.","genre_ids":[18],"popularity":1.0847,"vote_count":0,"poster_path":"/p0LkUTw4cABSnYASLrqO6AsY2Sg.jpg","release_date":"1952-01-01","vote_average":0,"backdrop_path":"/cNFPWAOT5eQE5FhEfG6PrPuxfqR.jpg","original_title":"Toprak","original_language":"tr"},{"id":271233,"adult":false,"title":"The Tailor's Wife","video":false,"overview":"","genre_ids":[18],"popularity":0.252,"vote_count":8,"poster_path":"/ypb28SgcQIel7IpHVya4U02464y.jpg","release_date":"2014-05-14","vote_average":4,"backdrop_path":"/40xH3EuP1YAZPc4spoL8rHN3DRG.jpg","original_title":"La moglie del sarto","original_language":"it"},{"id":271242,"adult":false,"title":"The Good Life","video":false,"overview":"Christopher Nolen's \"The Good Life\" is the story of Jacques and Marianne Vandelay, a highly successful African American couple. They are happy but both are keeping dark secrets from each other.","genre_ids":[18,10749],"popularity":0.1278,"vote_count":4,"poster_path":"/amknoAbm9p5QNATZey2Ax1PxZb2.jpg","release_date":"2012-07-23","vote_average":4,"backdrop_path":"/2PVXmXTfbxtwXwzRA3GGwiLK9PJ.jpg","original_title":"The Good Life","original_language":"en"},{"id":1057453,"adult":false,"title":"惹是生非","video":false,"overview":"","genre_ids":[18],"popularity":0.1609,"vote_count":1,"poster_path":"/eMtsHGyeL6OV4k5egzy8H07EbQK.jpg","release_date":"1997-01-01","vote_average":7,"backdrop_path":null,"original_title":"惹是生非","original_language":"zh"},{"id":853667,"adult":false,"title":"Knitting","video":false,"overview":"Five brothers end up being raised by their older brother after their mother's death. One day, as adults, they receive the news that a comatose man in an ICU could be their father. In the hospital's waiting room, the brothers immerse themselves in their conflicts and memories, and through the knitting learned in childhood.","genre_ids":[18],"popularity":1.4851,"vote_count":3,"poster_path":"/ekluxY0UmBcOPJa72qi29uU8atK.jpg","release_date":"2021-08-13","vote_average":3,"backdrop_path":"/8Oq42VsNujzytarlBW8pS548jQ7.jpg","original_title":"O Novelo","original_language":"pt"},{"id":853671,"adult":false,"title":"Weltschmerz","video":false,"overview":"\"Weltschmerz\" is an emotionally-charged, character-driven short drama about a concentration camp prisoner who has just failed in an escape attempt and is now in the hands of a seasoned SS Officer, who will make an example out of her before her execution in front of the entire camp. Meanwhile, at a German creek, two children live in their own world of innocence.","genre_ids":[10752,18],"popularity":0.1552,"vote_count":0,"poster_path":null,"release_date":"2018-12-12","vote_average":0,"backdrop_path":null,"original_title":"Weltschmerz","original_language":"en"},{"id":853689,"adult":false,"title":"Hole Sister","video":false,"overview":"Na-yeong and Jeong-woo starts their honeymoon. Both of them are excitemed to live together. Then Min-joo, a housewarming guest, comes to visit. Min-joo, Na-yeong's younger sister, starts to seduce Jeong-woo, who showed a crush on her when Na-yeong fell asleep drunk after drinking together. Jeong-woo accepts Min-joo without even thinking about it, and continues his close love without Na-yeong knowing it.","genre_ids":[18,10749],"popularity":0.6549,"vote_count":0,"poster_path":"/2BjVuaTmjOfyxvG8YIKFAaTpjB6.jpg","release_date":"2021-04-02","vote_average":0,"backdrop_path":"/x3Md4dugUv8uGy8DOhORnxcNaUN.jpg","original_title":"구멍동생","original_language":"ko"}],"external_ids":{"imdb_id":null,"twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":105592,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"TH","release_dates":[{"note":"Film Exhibition","type":2,"iso_639_1":"th","descriptors":[],"release_date":"2024-06-29T00:00:00.000Z","certification":""}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikidata_metadata":{},"mood_tags":null,"trope_tags":null,"vibe_description":null,"ai_enriched_at":null,"ai_enrichment_version":0}}]]
