9:{"metadata":[["$","title","0",{"children":"My Neighbor Totoro | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Two sisters move to the country with their father in order to be closer to their hospitalized mother, and discover the surrounding trees are inhabited by Totoros, magical spirits of the forest. When the youngest runs away from home, the older sister seeks help from the spirits to find her."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/110271/my-neighbor-totoro"}],["$","meta","5",{"property":"og:title","content":"My Neighbor Totoro"}],["$","meta","6",{"property":"og:description","content":"Two sisters move to the country with their father in order to be closer to their hospitalized mother, and discover the surrounding trees are inhabited by Totoros, magical spirits of the forest. When the youngest runs away from home, the older sister seeks help from the spirits to find her."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/110271/my-neighbor-totoro"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/rtGDOeG9LzoerkDGZF9dnVeLppL.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"My Neighbor Totoro"}],["$","meta","12",{"name":"twitter:description","content":"Two sisters move to the country with their father in order to be closer to their hospitalized mother, and discover the surrounding trees are inhabited by Totoros, magical spirits of the forest. When the youngest runs away from home, the older sister seeks help from the spirits to find her."}],["$","meta","13",{"name":"twitter:image","content":"https://ima