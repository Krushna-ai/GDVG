5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Art of the Devil 2\",\"description\":\"A beautiful teacher is wronged by six of her students. Calling on demons and forces of black magic, she extracts an ultra-gruesome retribution against each of them.\",\"image\":\"https://image.tmdb.org/t/p/w500/fdS7qZFeayKtqEBKRnIFd3SudkG.jpg\",\"datePublished\":\"2005-12-01\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"TH\",\"inLanguage\":\"th\",\"genre\":[\"horror film\",\"Horror\",\"Thriller\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.73,\"bestRating\":10,\"ratingCount\":124}}"}}],["$","$L10",null,{"initialDrama":{"id":"fa8dfae8-5af3-4d80-a9a8-75e79b8ab4a0","tmdb_id":44935,"imdb_id":"tt0756222","content_type":"movie","title":"Art of the Devil 2","original_title":"ลองของ","overview":"A beautiful teacher is wronged by six of her students. Calling on demons and forces of black magic, she extracts an ultra-gruesome retribution against each of them.","poster_path":"/fdS7qZFeayKtqEBKRnIFd3SudkG.jpg","backdrop_path":"/x7rTIi9QJDZ6B228IZwjad62RhT.jpg","release_date":"2005-12-01","first_air_date":null,"status":"published","original_language":"th","origin_country":["TH"],"genres":[{"name":"horror film"},{"id":27,"name":"Horror"},{"id":53,"name":"Thriller"},"horror film"],"popularity":2.7917,"vote_average":6.73,"vote_count":124,"runtime":102,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:53:14.844091+00:00","updated_at":"2026-02-21T14:02:48.541+00:00","tagline":"The Devil never leaves You Alive.","homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":1241,"name":"Five Star Production","logo_path":"/m0pcwdXt4FgzaBtoSMfXoNucgoz.png","origin_country":"TH"}],"production_countries":[{"name":"Thailand","iso_3166_1":"TH"}],"spoken_languages":[{"name":"ภาษาไทย","iso_639_1":"th","english_name":"Thai"}],"netwo