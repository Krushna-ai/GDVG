_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":2400,"height":1350,"file_path":"/ow48jX9c1JIUmg018py8MkuHkFw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":2400,"height":1350,"file_path":"/1rUAkICkaFRTmskpJKsYVQ2Mdne.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":2400,"height":1350,"file_path":"/g2uNUqJ21E4gdoBuPP5zeCcBGtg.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/cFw9RiGHaZhGYOPr6pmTQ54UOjM.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":2.278},{"width":1920,"height":1080,"file_path":"/DtQEs6pe4VkMpeTE5vX2za8JeQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/opFEmCZcqQr15zILBgT5ntJcRCR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/luOoKayzC0DFGg3AMVKKAELpq5m.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/4MZ2ECpetslSsdQQDYTk0mqkBVI.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":0.166},{"width":2000,"height":1125,"file_path":"/60DPPmXNO2a1bJJVqTNN7vvBLj.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/5atDJHPu6TjPn9ZzaPg07cvvj6X.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/e0Uzon5lrtpbkTngGjJvb3oN0Q6.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/kzgvbeEj0gBGhWBEHaxnsTza60d.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:50:32.507+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Nine Queens","runtime":114,"tagline":"If you think you've got it figured out... you've been conned.","homepage":"","overview":"Two con artists try to swindle a stamp collector by selling him a sheet of counterfeit rare stamps, the \"nine queens\"."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Nine Queens","runtime":107,"tagline":"","homepage":"","overview":"Der scheinbar etwas tapsige Trickbetrüger Juan schließt sich dem alten Hasen Marcos an, um an Geld zu kommen. Gemeinsam legen Sie alte Damen und verwirrte Kellner aufs Kreuz. Doch als sich die Chance auf einen großen Coup bietet, ist schnell nicht mehr klar, wer hier wen abzockt ..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Nove regine","runtime":0,"tagline":"","homepage":"","overview":"Marcos e Juan, due piccoli truffatori, si conoscono per caso quando il primo salva il secondo durante un maldestro tentativo di truffa in un negozio. Divengono soci in affari e quando vengono incaricati di vendere una serie contraffatta di francobolli rarissimi, noti come \"Le nove regine\", prezioso reperto della Germania 1920, Marcos e Juan capiscono che si tratta del loro colpo grosso. Ma non sono i soli..."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Les Neuf Reines","runtime":115,"tagline":"Neufs timbres, deux amateurs et une anarque royale","homepage":"","overview":"Juan et Marcos, deux petits arnaqueurs sympathiques mais sans envergure de Buenos Aires, se rencontrent au moment où ils s'apprêtent à commettre un même cambriolage. Durant vingt-quatre heures, ils s'associent pour voler une planche de neuf timbres rarissimes appelés les Nueve Reinas. Ils espèrent ainsi les revendre à un collectionneur vénézuélien. Pour mener à bien leur affaire, ils font appel à Valeria, la séduisante soeur de Marcos."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":114,"tagline":"Si crees que lo tienes claro... te han timado.","homepage":"","overview":"Buenos Aires. Juan y Marcos son dos estafadores que están a punto de dar el golpe de sus vidas, el que puede convertirles, al fin, en millonarios. Sólo disponen de 24 horas, pero si lo planifican todo al detalle, nada puede salir mal... o eso creen."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Nove Rainhas","runtime":114,"tagline":"","homepage":"","overview":"A história de Nove Rainhas, passada na Buenos Aires dos dias atuais, começa numa madrugada e termina na manhã do dia seguinte. Nestas 24 horas ou pouco mais, Marcos (Ricardo Darín) e Juan (Gaston Pauls), seus protagonistas, passarão pela maior aventura de suas vidas, algo que Marcos insiste em chamar de \"uma oportunidade em um milhão\". Estes dois golpistas de segunda, que habitualmente \"trabalhavam\" por alguns poucos pesos, se conhecem por acaso numa certa madrugada e, de repente, tornam-se sócios numa negociação multimilionária envolvendo uma série falsificada de selos raríssimos, conhecidos como as \"Nove Rainhas\". O negócio deve ser realizado imediatamente, custe o que custar, uma vez que o milionário espanhol interessado nos selos deixará a cidade na manhã seguinte. Marcos conta com a ajuda de sua irmã, Valeria (Leticia Bredice), que trabalha no hotel onde o espanhol está hospedado, mas questões familiares pendentes azedam a relação dos irmãos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"A kilenc királynő","runtime":0,"tagline":"","homepage":"","overview":"A történet egy benzinkútnál kezdődik, ahol Juan, a kisstílű bűnöző épp a pénztárost vágja át. Juan még újonc, akiről senki sem gondolná, hogy szélhámos - ezért jön jól Marcosnak, a tapasztalt csalónak. Marcos egy nagyobb balhén töri a fejét: egy hamisított bélyegsorozatot, a \"Kilenc királynőt\" jó pénzért el akarja passzolni egy üzletembernek. Az akcióban segítségükre van Marcos szexi nővére, Valeria is. A következő huszonnégy órában a rablótrió eszeveszett hajszába kezd, és a történet percről percre újabb fordulatot vesz... mindenki mindenkit átvág, és a néző sem tudja, hihet-e még a szemének."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Девять королев","runtime":0,"tagline":"","homepage":"","overview":"Однажды рано утром Маркос, который обманывает каждого, включая своих родных сестру Валерию и брата Федерико, замечает Хуана — ребяческого и приятного мошенника, когда тот успешно осуществлял изменение счета на кассе.  Хуана поймали, так как он пытался проделать это же самое жульничество и на следующем счете. Маркос вступает в разговор, представившись полицейским, и выводит Хуана из магазина.  Но как только они оказываются на улице, коварный Маркос открывает себя совсем с другой стороны, он оказывается жуликом, но с игрой намного более высоких ставок.  Объяснив Хуану, что не может работать без напарника (предыдущий пропал неделю назад), Маркос приглашает его стать своим партнером по преступлениям, которого он давно искал, и предлагает давать ему уроки по проведению преступлений.  Хуан принимает предложение, потому что он очень нуждается в деньгах. Но они договариваются о сотрудничестве пока только на один день — попробовать."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Dokuz Kraliçe","runtime":0,"tagline":"","homepage":"","overview":"Hayatta hiçbir şey ilk bakışta zannedildiği gibi değildir. Bu bazen iyi bazen kötü de olabilir elbette. Film, hileli oyunlarla gelişen insan aklını kışkırtan çağrışımlar yüklü bir kurguya sahip. Juan ve Marcos dolandırıcılık yapmaktadırlar. Görünüşte Juan daha az tecrübeli gibidir. Bunu fark eden Marcos, onun zor bir durumdan çıkmasına destek olur. Ona bir teklifte bulunur. Bir gün boyunca birlikte bir sürü dümen çevireceklerdir. Yalnız her ikisini de tanıyan esrarengiz Sandler'la umulmadık karşılaşmaları, daha farklı bir boyutta uzlaşmaya yönlendirir onları. Artık ortak bir hedefe odaklanarak pek çok ganimet elde edilecek kârlı bir işbirliğine girerler. Yalnız yalan kavramı bütün dengeleri sürekli sarsan bir unsur olarak dikilir orta yerde."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"9 Βασίλισσες","runtime":115,"tagline":"","homepage":"","overview":"Δυο μικροαπατεώνες στο Μπουένος Άιρες έχουν 24 ώρες στη διάθεσή τους για να πουλήσουν σ' έναν πλούσιο συλλέκτη 9 σπάνια γραμματόσημα, που είναι στην πραγματικότητα πλαστογραφημένα. Έχουν όμως να αντιμετωπίσουν απρόοπτες αναποδιές, όπως και τη μεταξύ τους έλλειψη εμπιστοσύνης, αφού συνεχώς ο ένας πάει να ρίξει τον άλλον."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"תשע מלכות","runtime":0,"tagline":"","homepage":"","overview":"שני אמני זיוף מנסים לעשות מכה על ידי מכירת גיליון מזויף של בול נדיר, המכונה \"תשע מלכות\". הסיפור מתחיל כאשר מרקוס קולט את חואן בתרגיל מוצלח לגניבת הכסף מהקופה, בעקבות זאת גורר אותו מרקוס החוצה מן החנות. מכאן חוברים השניים לתרגיל ההונאה הגדול, שיסתיים בדרך מפתיעה שאף אחד לא יצפה לה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Nove Rainhas","runtime":114,"tagline":"Pegajoso & Quadrado.","homepage":"","overview":"A história de Nove Rainhas, passada na Buenos Aires dos dias atuais, começa numa madrugada e termina na manhã do dia seguinte. Nestas 24 horas ou pouco mais, Marcos e Juan, seus protagonistas, passarão pela maior aventura de suas vidas, algo que Marcos insiste em chamar de \"uma oportunidade em um milhão\". Estes dois golpistas de segunda, que habitualmente \"trabalhavam\" por alguns poucos pesos, se conhecem por acaso numa certa madrugada e, de repente, tornam-se sócios numa negociação multimilionária envolvendo uma série falsificada de selos raríssimos, conhecidos como as \"Nove Rainhas\". O negócio deve ser realizado imediatamente, custe o que custar, uma vez que o milionário espanhol interessado nos selos deixará a cidade na manhã seguinte. Marcos conta com a ajuda de sua irmã, Valeria, que trabalha no hotel onde o espanhol está hospedado, mas questões familiares pendentes azedam a relação dos irmãos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":110,"tagline":"","homepage":"","overview":"Twee oplichters verkopen vervalste postzegels voor veel geld, maar het wordt stressvol als de zus van een van de bedriegers erbij betrokken raakt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Devět královen","runtime":109,"tagline":"Vytvořili svět přesvědčivější než je sama skutečnost","homepage":"","overview":"Juan se jednoho rána pokusí nemotorně uplatnit stejný podvod na dvě různé pokladní v samoobsluze. Když je odhalen, ujme se ho muž, který ho celou dobu tajně pozoroval. Marcos  se však za policistu pouze vydává: ve skutečnosti je zkušeným podvodníkem, jenž si nevinně vyhlížejícího mladíka vytipoval jako svého nového komplice. Juan se pod Marcosovým vedením rychle vypracuje v mistra přetvářky, který umí šikovně manipulovat s city svých bližních a vymámit na nich prakticky libovolnou částku. Před sehranou dvojicí je teď úkol ukrást a výhodně prodat vzácný aršík devíti známek z období Výmarské republiky nazvaný „Devět královen“. Tu vlastní ostražitá dáma jménem Berta. Špičkoví podvodníci rozjíždějí smrtonosně elegantní hru, v níž neváhají překvapovat jeden druhého. Kromě pravých známek je však ve hře i jejich dokonalá kopie z padělatelské dílny Bertina bratra Sandlera."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Дев'ять королев","runtime":0,"tagline":"","homepage":"","overview":"Випадково зустрічаються два шахрая – молодий і настирний Хуан і досвідчений Маркос. Маркосу конче потрібен партнер для грандіозної афери, а Хуану потрібні гроші, щоб звільнити батька зі в'язниці. Разом вони планують зробити одну дуже прибуткову справу, що стосується рідкісної колекції марок \"Дев'ять королев\". Але все пішло не за планом – їх підставили і тепер, щоб виплутатися, їм доведеться імпровізувати..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Deväť kráľovien","runtime":0,"tagline":"","homepage":"","overview":"Juan sa jedného rána pokúsi nemotorne uplatniť rovnaký podvod na dve rôzne pokladníčky v samoobsluhe. Keď je odhalený, ujme sa ho muž, ktorý ho celý čas tajne pozoroval. Marcos sa však za policajta iba vydáva: v skutočnosti je skúseným podvodníkom, ktorý si nevinne vyzerajúceho mladíka vytipoval ako svojho nového komplica. Juan sa pod Marcosovým vedením rýchlo vypracuje v majstra pretvárky, ktorý vie šikovne manipulovať s citmi svojich blížnych a vymámiť na nich prakticky ľubovoľnú čiastku. Pred zohranou dvojicou je teraz úloha ukradnúť a výhodne predať vzácnu zbierku deviatich známok z obdobia Weimarskej republiky nazvanú \"Deväť kráľovien\". Tú vlastní ostražitá dáma menom Berta. Špičkoví podvodníci rozbiehajú smrtonosne elegantnú hru, v ktorej neváhajú prekvapovať jeden druhého. Okrem pravých známok je však v hre aj ich dokonalá kópia z falšovateľskej dielne Bertinho brata Sandlera."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Девет краљица","runtime":0,"tagline":"","homepage":"","overview":"Двојица превараната упознају се при покушају пљачке исте продавнице. Искуснији Маркус упошљава Жуана за свог партнера и они крећу у неколико мањих подухвата у којима тестирају одважност овог другог. Коначно се одлучују на велику акцију- смишљају план како украсти сет скупоцених марака, познатијих као 9 краљица..."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Dziewięć Królowych","runtime":0,"tagline":"","homepage":"","overview":"Współczesne Buenos Aires. Dwaj oszuści, Marcos i Juan, mają zrealizować plan sędziwego fałszerza, który chce sprzedać serię podrobionych przez siebie cennych znaczków o nazwie Dziewięć Królowych. Nabywcą falsyfikatów miałby być skompromitowany polityk Gandolfo, który następnego dnia wyjeżdża za granicę. Kiedy Marcos i Juan umawiają się z nim na przekazanie pieniędzy, złodzieje kradną im teczkę ze znaczkami. Nie chcąc stracić okazji do zarobienia dużej gotówki, oszuści postanawiają wejść w posiadanie oryginalnych egzemplarzy."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":114,"tagline":"","homepage":"","overview":"Buenos Aires. Juan y Marcos son dos estafadores de poca monta, uno joven y un veterano en el arte del timpo, que casualmente se ven envueltos en un asunto que les puede hacer millonarios: tienen menos de un día para hacer una estafa que no puede fallar."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"九个皇后","runtime":0,"tagline":"","homepage":"","overview":"　《九个皇后》(Nine Queens)是阿根廷导演Fabian Bielinsky初试啼声即一鸣惊人的黑色喜剧。故事以老千马可(Marco)和菜鸟胡安(Juan)两个金光党在便利商店中的初识为起点，马可提议两人搭挡作案强过一人单打独斗，因为马可，胡安被卷入一桩贩卖古董邮票Nine Queens的交易行为中，进而无意间卷入了马可的家族遗产纷争之中，爱上了马可的妹妹……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"아홉 여왕들","runtime":0,"tagline":"","homepage":"","overview":""},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"NINE QUEENS 華麗なる詐欺師たち","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"九個皇后","runtime":0,"tagline":"","homepage":"","overview":"《九個皇后》(Nine Queens) 是阿根廷導演 Fabian Bielinsky 初試啼聲即一鳴驚人的黑色喜劇。故事以老千馬可 (Marco) 和菜鳥胡安 (Juan) 兩個金光黨在便利商店中的初識為起點，馬可提議兩人搭擋作案強過一人單打獨鬥，因為馬可，胡安被捲入一樁販賣古董郵票 Nine Queens 的交易行為中，進而無意間捲入了馬可的家族遺產紛爭之中，愛上了馬可的妹妹……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":440374,"adult":false,"title":"The Summit","video":false,"overview":"At a summit for Latin American presidents in Chile where the region's geopolitical strategies and alliances are in discussion, Argentine president Hernán Blanco endures political and family drama that will force him to face his own demons.","genre_ids":[18,53],"media_type":"movie","popularity":0.6584,"vote_count":139,"poster_path":"/gy2fvMbEuR1uJYGpM7oJ91HFRgl.jpg","release_date":"2017-08-17","vote_average":5.892,"backdrop_path":"/mu3q8eeDc2NH112sKQbmrJFe0Vs.jpg","original_title":"La cordillera","original_language":"es"},{"id":78237,"adult":false,"title":"On Probation","video":false,"overview":"Mariano is a psychologist who must fulfill community service after losing a lawsuit by a traffic accident. He is forced to provide therapeutic support to Alfredo, a policeman depressed over his wife cheating on him. Mariano is then accidentally involved in a double homicide investigation being conducted by Alfredo.","genre_ids":[9648,80,28,18,53],"media_type":"movie","popularity":0.321,"vote_count":131,"poster_path":"/ZZ00teEWJMPEAqSYJ6xIxNTu4q.jpg","release_date":"2005-09-29","vote_average":7.5,"backdrop_path":"/q2ZFyrDHq7vDk0buN4DE9ch6HQ6.jpg","original_title":"Tiempo de valientes","original_language":"es"},{"id":13653,"adult":false,"title":"The Aura","video":false,"overview":"A quiet, epileptic taxidermist plans the perfect crime. All he needs is the right opportunity. An accident, perhaps…","genre_ids":[18,53],"media_type":"movie","popularity":1.0693,"vote_count":218,"poster_path":"/waaFS27AOSt2JvKMZyFi9m7uGKY.jpg","release_date":"2005-09-15","vote_average":6.968,"backdrop_path":"/fvl1geY63c1xoa6r6iRPARGJdJY.jpg","original_title":"El aura","original_language":"es"},{"id":19460,"adult":false,"title":"Son of the Bride","video":false,"overview":"At age 42, Rafael Belvedere is having a crisis. He lives in the shadow of his father, he feels guilty about rarely visiting his aging mother, his ex-wife says he doesn't spend enough time with their daughter and he has yet to make a commitment to his girlfriend. At his lowest point, a minor heart attack reunites him with Juan Carlos, a childhood friend, who helps Rafael to reconstruct his past.","genre_ids":[35,18,10749],"media_type":"movie","popularity":0.3666,"vote_count":226,"poster_path":"/zXInKuQ8FW18Ko8CtY9V30qhz1P.jpg","release_date":"2001-08-16","vote_average":7.5,"backdrop_path":"/kPRHoq1g68O5qawcnrB1c4LeO4I.jpg","original_title":"El hijo de la novia","original_language":"es"},{"id":15321,"adult":false,"title":"Twin Town","video":false,"overview":"Jeremy and Julian Lewis, the \"Lewis Twins\", are two unruly brothers who terrorise the city of Swansea from the caravan park where they live with their family. When their father, Fatty, is injured while working on a roof for local kingpin Bryn Cartwright, they try in vain to claim compensation. Thus begins a campaign of terror, which local policemen Terry and Grayo are ill-equipped to prevent, involved as they are in a drugs deal with Cartwright.","genre_ids":[35,18],"media_type":"movie","popularity":0.4108,"vote_count":81,"poster_path":"/b9rf32Mq0bQ0pJ3EZ5ghY52J4tS.jpg","release_date":"1997-04-11","vote_average":6.2,"backdrop_path":"/8IVxmM6ZXdYjJnxJEM2f3KOjQc4.jpg","original_title":"Twin Town","original_language":"en"},{"id":44516,"adult":false,"title":"Same Love, Same Rain","video":false,"overview":"Jorge is a writer for a left-leaning Buenos Aires magazine that's at odds with the country's military dictatorship. He meets lovely and intelligent actress Laura and begins an on-and-off romance that will continue for the next two decades. Fearful of commitment, Jorge initially moves on from her and his fortunes suffer, but the situation changes when he and Laura renew their acquaintance. Meanwhile, the country undergoes a political transformation.","genre_ids":[35,10749],"media_type":"movie","popularity":0.1722,"vote_count":66,"poster_path":"/qSeUv634CRFlHsmdXcUCQkcxqAt.jpg","release_date":"1999-09-16","vote_average":6.742,"backdrop_path":"/yroH7saHnyQZLaLXIBq3yhFRvul.jpg","original_title":"El mismo amor, la misma lluvia","original_language":"es"},{"id":12527,"adult":false,"title":"Strawberry and Chocolate","video":false,"overview":"In 1979 Cuba, flamboyant gay artist Diego attempts to seduce  straitlaced David, an idealistic young communist, and fails dismally. But David conspires to be \"friends\" with Diego so he can monitor the artist's subversive life for the state. As Diego and David discuss politics, individuality and personal expression in Castro's Cuba, a genuine friendship develops between the two.","genre_ids":[35,18],"media_type":"movie","popularity":0.6522,"vote_count":82,"poster_path":"/8riS2hGneWg78MHuhP7NqvLERRy.jpg","release_date":"1993-12-01","vote_average":7,"backdrop_path":"/kTlrvY35ldGN0yReCu59DfQdlcp.jpg","original_title":"Fresa y chocolate","original_language":"es"},{"id":13074,"adult":false,"title":"Resurrecting the Champ","video":false,"overview":"Up-and-coming sports reporter rescues a homeless man (\"Champ\") only to discover that he is, in fact, a boxing legend believed to have passed away. What begins as an opportunity to resurrect Champ's story and escape the shadow of his father's success becomes a personal journey as the ambitious reporter reexamines his own life and his relationship with his family.","genre_ids":[18],"media_type":"movie","popularity":0.9919,"vote_count":260,"poster_path":"/rJKTZf2QIhUwvqsfkher1JlLCdZ.jpg","release_date":"2007-06-14","vote_average":6.315,"backdrop_path":"/6NLpgjJYXVOCfQgNhE1cgWT7z7k.jpg","original_title":"Resurrecting the Champ","original_language":"en"},{"id":179988,"adult":false,"title":"Trapped, the Crimson Bat","video":false,"overview":"Oichi may have met her match as she vies against the evil beauty that has set her sights on destroying her. She must face numerous other challenges before confronting her greatest rival. While longing to live and love like other women, she realizes that she can never have a normal life, her sword which she holds on to like a security blanket will always come between her and such a life...","genre_ids":[12,18,28],"media_type":"movie","popularity":0.3327,"vote_count":9,"poster_path":"/dZIZa2BLPBxe8gXNbucuuiirbFf.jpg","release_date":"1969-06-21","vote_average":6.4,"backdrop_path":"/hGfy79vK9yzRwuLkN8NuUtd6OEz.jpg","original_title":"めくらのお市　地獄肌","original_language":"ja"},{"id":127449,"adult":false,"title":"The Truce","video":false,"overview":"A man has to come to terms with his wasted youth, estranged family and grim prospects for the future.","genre_ids":[10749,18],"media_type":"movie","popularity":0.3736,"vote_count":20,"poster_path":"/1R0I3Jm91smJnt84HEJTg61cAKP.jpg","release_date":"1974-08-01","vote_average":7.375,"backdrop_path":"/oJDuXOSfoQlNW4N9QXz6s8gOFfh.jpg","original_title":"La tregua","original_language":"es"},{"id":90171,"adult":false,"title":"Cenizas del paraíso","video":false,"overview":"A judge falls from the roof of the Federal Courthouse. A woman is murdered. Between them and the three sons of the judge there is a connection that will be investigated by a woman judge who is determined to discover the truth.","genre_ids":[80,18,9648,53],"media_type":"movie","popularity":0.2837,"vote_count":24,"poster_path":"/d0r5mYcglrJ0GM4Gsb4liCZ3Fwr.jpg","release_date":"1997-08-07","vote_average":6.75,"backdrop_path":"/zAioXoqvQa8zWPa1XeHJWi1Tggr.jpg","original_title":"Cenizas del paraíso","original_language":"es"},{"id":1003716,"adult":false,"title":"From.Beyond","video":false,"overview":"A kaleidoscopic vision portraying mankind’s first meeting with alien life, told through faux archival footage combined with practical FX, miniatures and old school in-camera trickery.","genre_ids":[27,878],"media_type":"movie","popularity":0.3422,"vote_count":8,"poster_path":"/bMNRDeYv4iAIKaCMSwGMNS8tAIN.jpg","release_date":"2022-07-19","vote_average":6.3,"backdrop_path":"/bxjpNz17NBdjyMhDbt7fhY0uXPO.jpg","original_title":"From.Beyond","original_language":"en"},{"id":440689,"adult":false,"title":"Heart of a Lion","video":false,"overview":"After she loses her mobile phone, a lawyer receives a call from the person who found it. They talk and hit it off very quickly. But she's in shock when she sees that he's very short.","genre_ids":[35,10749],"media_type":"movie","popularity":0.2595,"vote_count":13,"poster_path":"/ifCfsG3QTVxH8Mk3ItTJXRgHl3P.jpg","release_date":"2015-03-26","vote_average":5.7,"backdrop_path":"/nLwXg0ZMo1jCNWPeuCOlEUu9Fmg.jpg","original_title":"Corazón de León","original_language":"es"},{"id":57598,"adult":false,"title":"Die Nachrichten","video":false,"overview":"Jan Landers made it: Grown up in East Berlin, he quickly made his career after the turnaround: from the weatherman of a local station to the newsreader in Hamburg.","genre_ids":[],"media_type":"movie","popularity":0.2004,"vote_count":3,"poster_path":"/lEESLnlTCGteLXNbCqpo4T0unv.jpg","release_date":"2005-10-03","vote_average":3,"backdrop_path":null,"original_title":"Die Nachrichten","original_language":"de"},{"id":1926,"adult":false,"title":"September 11","video":false,"overview":"An anthology of short films inspired by the events of the September 11 World Trade Center attacks.","genre_ids":[18],"media_type":"movie","popularity":0.8026,"vote_count":118,"poster_path":"/gbOFmoHalRCZgePhSJLH1ChIn2q.jpg","release_date":"2002-09-04","vote_average":6.432,"backdrop_path":"/mpCIVcb4ywBGU6K0Qt1DCIcKoJp.jpg","original_title":"11’09”01 - September 11","original_language":"fr"},{"id":67884,"adult":false,"title":"Chinese Take-Away","video":false,"overview":"A comedy that chronicles a chance encounter between Robert and a Chinese named Jun who wanders lost through the city of Buenos Aires in search of his uncle after being assaulted by a taxi driver and his henchmen.","genre_ids":[35],"media_type":"movie","popularity":0.631,"vote_count":429,"poster_path":"/wSrMT1YrcMH4NdzH7IdJaQzgzJc.jpg","release_date":"2011-03-24","vote_average":7.239,"backdrop_path":"/fqRJLbbakXAT88XTBVz0no4xavg.jpg","original_title":"Un cuento chino","original_language":"es"},{"id":37691,"adult":false,"title":"Bread and Roses","video":false,"overview":"Maya is a quick-witted young woman who comes over the Mexican border without papers and makes her way to the LA home of her older sister Rosa. Rosa gets Maya a job as a janitor: a non-union janitorial service has the contract, the foul-mouthed supervisor can fire workers on a whim, and the service-workers' union has assigned organizer Sam Shapiro to bring its \"justice for janitors\" campaign to the building. Sam finds Maya a willing listener, she's also attracted to him. Rosa resists, she has an ailing husband to consider. The workers try for public support; management intimidates workers to divide and conquer. Rosa and Maya as well as workers and management may be set to collide.","genre_ids":[35,18],"media_type":"movie","popularity":0.6876,"vote_count":131,"poster_path":"/aNk0yx0xRcs66OdByiy2pJaFhI6.jpg","release_date":"2000-09-14","vote_average":6.3,"backdrop_path":"/qcgd7d97vnEOZr9dmNJDtjc7HMb.jpg","original_title":"Bread and Roses","original_language":"en"},{"id":725649,"adult":false,"title":"Dogwashers","video":false,"overview":"When a narco past his prime refuses to pay a debt to an upstart, only a secret stash of money can save his men. But guess what the gardener just found?","genre_ids":[35,18,80],"media_type":"movie","popularity":0.3854,"vote_count":50,"poster_path":"/uEilmHRJ2YElyZ9kSjrTUjEnTkt.jpg","release_date":"2020-10-09","vote_average":6.6,"backdrop_path":"/4s8Lg26MmF3SwZHJKhJQS8WBeez.jpg","original_title":"Lavaperros","original_language":"es"},{"id":76013,"adult":false,"title":"No Rest for the Wicked","video":false,"overview":"Madrid, the beginning of the century. One day, the police inspector Santos Trinidad coming home very drunk, is involved in a triple murder. But there is a witness who managed to escape and that could incriminate him. Santos undertakes an investigation to locate and eliminate the witness. Meanwhile, Chacón a judge in charge of investigating the triple murder, meticulously advances in the search for the murderer. Santos and Chacon soon discover that what seemed a simple case of drug trafficking is actually something far more dangerous.","genre_ids":[53],"media_type":"movie","popularity":0.4987,"vote_count":142,"poster_path":"/d3DI1iu6IYuw3fpOQ83ijKG9e3A.jpg","release_date":"2011-09-16","vote_average":5.926,"backdrop_path":"/hvE9ZNH1tTOe2QpTogFhqk8MwD4.jpg","original_title":"No habrá paz para los malvados","original_language":"es"},{"id":341744,"adult":false,"title":"Truman","video":false,"overview":"Tomás, who lives in Canada, travels to Madrid, Spain, to visit his old friend Julián. Both of them, accompanied by Truman, Julián's faithful dog, will share many surprising and emotional little moments, triggered by the hard situation Julián is going through, for just a few days.","genre_ids":[18,35],"media_type":"movie","popularity":3.0612,"vote_count":391,"poster_path":"/p4MFl06ePJGKMIF7zFCJhex95Vi.jpg","release_date":"2015-09-24","vote_average":7.019,"backdrop_path":"/iUAFLqAj7p1v8zkOReyd7tjSLDg.jpg","original_title":"Truman","original_language":"es"}],"similar_content":[{"id":1066235,"adult":false,"title":"Durham Place","video":false,"overview":"Four friends at the start of the 2020 Pandemic attempt to pull off a $500,000 Heist in the Suburbs.","genre_ids":[53,28],"popularity":0.1518,"vote_count":0,"poster_path":"/xBdcxfTWSNypC7clDIcisCZXXHI.jpg","release_date":"2023-04-28","vote_average":0,"backdrop_path":"/mdZIsV3ZFAac9y2WVZrPNj6YRJJ.jpg","original_title":"Durham Place","original_language":"en"},{"id":277633,"adult":false,"title":"Blind Vengeance","video":false,"overview":"A man seeks revenge on the white supremacists acquitted in the murder of his son","genre_ids":[18,80,10770],"popularity":0.2735,"vote_count":1,"poster_path":"/8nb3VoDMIf9xwR04DeSlqxwMiHF.jpg","release_date":"1990-08-22","vote_average":1,"backdrop_path":null,"original_title":"Blind Vengeance","original_language":"en"},{"id":1460419,"adult":false,"title":"Appetite","video":false,"overview":"Appetite is a psychological horror-thriller that explores the dark intersection of desire, power, and primal instinct.","genre_ids":[27,53],"popularity":0.2204,"vote_count":0,"poster_path":"/fGSa8732SG8epk8ioePJAYGHT5g.jpg","release_date":"","vote_average":0,"backdrop_path":null,"original_title":"Appetite","original_language":"en"},{"id":8426,"adult":false,"title":"Swallowtail Butterfly","video":false,"overview":"The struggles of a group of outcasts living in \"Yentown\", in an alternate-future Japan.","genre_ids":[18,80,10402,878],"popularity":1.0754,"vote_count":96,"poster_path":"/wbHrboUJnLFvAG5eiB9LJaErjPn.jpg","release_date":"1996-09-14","vote_average":7.422,"backdrop_path":"/1u0ivjKCXZULqQTUZiVjZOjkEiO.jpg","original_title":"スワロウテイル","original_language":"ja"},{"id":8436,"adult":false,"title":"The Page Turner","video":false,"overview":"Mélanie Prouvost, a ten-year-old butcher's daughter, is a gifted pianist. That is why she and her parents decide that she sit for the Conservatory entrance exam. Although Mélanie is very likely to be admitted, she unfortunately gets distracted by the president of the jury's offhand attitude and she fails. Ten years later, Mélanie becomes her page turner, waiting patiently for her revenge.","genre_ids":[18,10402,53],"popularity":0.4427,"vote_count":145,"poster_path":"/lBomGoLZKklJWb5hMvcy44WbUsd.jpg","release_date":"2006-08-09","vote_average":6.521,"backdrop_path":"/uyZMq9VTihrWBVXzIQUkB8P8Nnq.jpg","original_title":"La Tourneuse de pages","original_language":"fr"},{"id":8337,"adu