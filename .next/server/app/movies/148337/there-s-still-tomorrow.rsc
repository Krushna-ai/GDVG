swcCqWxf2qGyZknS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":1.434},{"width":3840,"height":2160,"file_path":"/dzRt6lEF0ivFjPeUSkZWiSkKvBj.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/btjo4fMYhuFmFvjTis0cnHbEalh.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1476,"height":830,"file_path":"/clcppGPPmO6GflJTZAS0xVeDRK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":1280,"height":720,"file_path":"/ogXwAU4NQBnxyxPNrdx6EuuexKR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1376,"height":774,"file_path":"/n9X5yJMb0yqOrsF2cyW2tMnGYfl.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/cs1FUCDes6yXTordE6GYrQpKQon.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1476,"height":830,"file_path":"/hstAzXL8gHnmks3Wi3OU9w6Z0QD.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/8XLSBil0EOVPwOFN8P6CxA0nwa5.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/6Z4vTbcLCo6TR1cUa45CKRajOMv.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/v4x3oD4wDZ7J9ye4b1BTYdl2W9l.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/trlAbTTXhuiOrOh8Hfs35HsCySO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/dzxAERV5bUpxkZyJHBfumJo7IN.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/1NRgE1yTC6tsAOCT7HfBdrOgWZO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/6cxWJA0ihv23aPIU1bX3COnsJSY.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:53:14.273+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":118,"tagline":"","homepage":"https://www.visiondistribution.it/film/ce-ancora-domani/","overview":"È primavera e tutta la famiglia è in fermento per l'imminente fidanzamento dell'amata primogenita Marcella (Romana Maggiora Vergano), che, dal canto suo, spera solo di sposarsi in fretta con un bravo ragazzo di ceto borghese, Giulio (Francesco Centorame), e liberarsi finalmente di quella famiglia imbarazzante."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"There's Still Tomorrow","runtime":118,"tagline":"","homepage":"","overview":"In postwar Rome, a working-class woman dreams of a better future for herself and her daughter while facing abuse at the hands of her domineering husband. When a mysterious letter arrives, she discovers the courage to change the circumstances of her life."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Siempre nos quedará mañana","runtime":118,"tagline":"","homepage":"","overview":"Es primavera y toda la familia está alborotada por el inminente compromiso de la querida hija mayor, Marcella, quien, por su parte, sólo espera casarse rápidamente con un simpático chico de clase media, Giulio, y librarse por fin de esa incómoda familia."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Il reste encore demain","runtime":0,"tagline":"","homepage":"","overview":"Mariée à Ivano, Delia, mère de trois enfants, vit à Rome dans la seconde moitié des années 40. La ville est alors partagée entre l’espoir né de la Libération et les difficultés matérielles engendrées par la guerre qui vient à peine de s’achever. Face à son mari autoritaire et violent, Delia ne trouve du réconfort qu’auprès de son amie Marisa avec qui elle partage des moments de légèreté et des confidences intimes. Leur routine morose prend fin au printemps, lorsque toute la famille en émoi s’apprête à célébrer les fiançailles imminentes de leur fille aînée, Marcella. Mais l’arrivée d’une lettre mystérieuse va tout bouleverser et pousser Delia à trouver le courage d’imaginer un avenir meilleur, et pas seulement pour elle-même."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"C'è ancora domani","runtime":118,"tagline":"","homepage":"","overview":"Delia is een typische huisvrouw in het naoorlogse Italië, wier familie in rep en roer is over de aanstaande verloving van de geliefde eerstgeborene Marcella. De komst van een mysterieuze brief zal Delia echter de moed aanwakkeren om haar gewelddadige echtgenoot onder ogen te zien en zich een betere toekomst voor te stellen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Још увек постоји сутра","runtime":0,"tagline":"","homepage":"","overview":"Делија је типична домаћица у послератној Италији, чија је породица у превирању због предстојећих веридби вољене прворођене Марчеле. Међутим, долазак мистериозног писма ће запалити Делијину храброст да се суочи са својим насилним мужем и замисли бољу будућност."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"هنوزم فردایی هست","runtime":0,"tagline":"","homepage":"","overview":"دلیا یک زن خانه‌دار معمولی در ایتالیای پس از جنگ است که خانواده‌اش در گیر و دار نامزدی قریب‌الوقوع فرزند اول محبوبش مارسلاست. با این حال، رسیدن یک نامه مرموز، شجاعت دلیا برای رویارویی با شوهر بدزبانش و تصور آینده‌ای بهتر را شعله‌ور می‌کند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"还有明天","runtime":0,"tagline":"","homepage":"","overview":"1946年5月的罗马被二战留下的贫困、街头游荡的盟军民兵，以及6月2日至3日的国体公投所激发的变革愿望撕裂。女主角迪莉娅是虐待狂伊万诺的妻子，也是三个孩子的母亲，其中包括十几岁的玛塞拉。在处理家庭事务的间隙，她照顾闷闷不乐的岳父奥托里诺，偶尔还要去城里的一些商店打工。这个女人在这艰难的生活中也有几个盟友：爱她的机械师尼诺；玛丽莎，一位机智乐观的朋友；还有威廉，想要帮助她的非裔美国士兵。迪莉娅的生活被玛塞拉与朱利奥的订婚打乱。朱利奥来自一个富裕的家庭，他们的收入主要源于经营的酒吧。然而迪莉娅很快意识到，若红事确定，她的女儿将走向与她相似的痛苦婚姻。因此，在威廉的帮助下，她设法炸毁了准女婿的酒吧，迫使他们家离开罗马。尽管马塞拉陷入绝望，但迪莉娅知道她做了正确的事。在邮寄给她的第一张选民卡的鼓励下，她决心反击。6月2日，决定国家命运的时刻到来。迪莉娅想要参加，并找借口逃离丈夫，但岳父却突然去世。好在这并未阻碍她作为女性第一次参与投票。可她丢失的选民卡却接二连三被丈夫和绝望中的女儿找到。她必须在其中周旋，确保能为自己、孩子和国家的未来做出正确的选择。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Morgen ist auch noch ein Tag","runtime":118,"tagline":"","homepage":"","overview":"Im Italien der Nachkriegszeit ist die Familie der typischen Hausfrau Delia in Aufruhr wegen der bevorstehenden Verlobung der geliebten Erstgeborenen Marcella. Der Eingang eines mysteriösen Briefes wird Delia jedoch den Mut geben, sich ihrem misshandelnden Ehemann zu stellen und sich eine bessere Zukunft vorzustellen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Всегда есть завтра","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"我們還有明天","runtime":118,"tagline":"她期待一個更美好的未來…","homepage":"https://www.swtwn.com/filmsdetail/2024/ThereisStillTomorrow/intro.html","overview":"二戰後，忙於照顧家庭和工作的黛莉亞與大男人丈夫伊凡、難搞的公公與三個孩子同住；春天來臨，渴望逃離原生家庭的大女兒瑪莎拉準備嫁給富家子朱利歐。而黛莉亞一生只願女兒能嫁個好人家，但一封神秘信函卻激發她推翻計劃，期盼自己和女兒都能擁有更美好的未來……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Det finns alltid en morgondag","runtime":0,"tagline":"","homepage":"","overview":"Delia kämpar för att få tillvaron att gå ihop i en stad som gläds över att kriget är slut men dras med sviterna. Hon sköter hushållet och håller ordning på barnen, samtidigt som hon parerar slagen från sin lynniga make och blir utskälld av sin sängbundne svärfar. Enda nöjet är att hinna med ett snabbt bloss i bästa väninnans marknadsstånd. Delia drömmer om en bättre framtid för sin dotter Marcella, men förlovningen med den välbeställde Giulio oroar henne. På ytan ser allt ut som vanligt, men det är kanske inte som det verkar, och allt förändras med ankomsten av ett mystiskt brev."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Jutro będzie nasze","runtime":0,"tagline":"","homepage":"https://gutekfilm.pl/jutro-bedzie-nasze-paola-cortellesi","overview":"W powojennych Włoszech rodzina typowej gospodyni domowej Delii jest w chaosie z powodu zbliżających się zaręczyn ukochanej pierworodnej Marcelli. Nadejście tajemniczego listu sprawi jednak, że Delia odważy się stawić czoła znęcającemu się nad nią mężowi i wyobrazić sobie lepszą przyszłość."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"CH","english_name":"German"},{"data":{"title":"우리에게는 아직 내일이 있다","runtime":119,"tagline":"동화보다 아름다운 엔딩을 꿈꾸다","homepage":"","overview":"나라의 운명이 걸린 국민투표로 소란한 1946년 이탈리아. 과거에 없던 투표권이 생겼지만 여전히 발언권은 없는 산투치 가문의 며느리 델리아는 오늘도 딸 마르첼라의 결혼식 준비에 한창이다. 그러던 어느 날 델리아 앞으로 의문의 편지가 도착하고 델리아는 난생처음 비밀스러운 계획을 세우는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"מחר יום חדש","runtime":118,"tagline":"","homepage":"","overview":"דליה חיה ברומא של סוף שנות הארבעים – עיר שנקרעת בין אופטימיות ורצון לעתיד טוב יותר,  וזיכרונות המלחמה שזה עתה הסתיימה – עם בעלה איוואנו, שלושת ילדיהם, ואביו הנרגן של בעלה. איוואנו הוא בעל מחמיר וקפדן, אביו תובעני לא פחות, אבל יש לה חברה טובה לחלוק איתה רגעים של קלילות, ובנוסף, בתה הבכורה עומדת להינשא. דליה מקבלת את גורלה, את הטוב עם הרע, עד שיום בהיר אחד, מכתב מסתורי מגיע בדואר..."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Πάντα Υπάρχει Το Αύριο","runtime":118,"tagline":"","homepage":"","overview":"Η Ντέλια και ο Ιβάνο ζουν με τα παιδιά τους και τον άρρωστο πατέρα του Ιβάνο στη Ρώμη. Είναι 1946 και οι άνθρωποι στην πόλη προσπαθούν να ισορροπήσουν ανάμεσα στους σπόρους της ελευθερίας και τα ελλείμματα του παρελθόντος. Η Ντέλια είναι ο τύπος της γυναίκας-φροντίστριας που έχει μάθει να ζει με τον τυραννικό άντρα της. Η οικογένεια είναι ενθουσιασμένη με τον επικείμενο αρραβώνα της κόρης τους. Όμως όλα αλλάζουν όταν η Ντέλια λαμβάνει ένα μυστηριώδες γράμμα που την κάνει να ανακτήσει το κουράγιο της και να διεκδικήσει μια καλύτερη ζωή."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Sempre ens quedarà demà","runtime":0,"tagline":"","homepage":"","overview":"Roma, any 1946. La Dèlia té tres fills i està casada amb el malhumorat Ivano, que no la tracta gaire bé. Després de la guerra, tots dos lluiten per tirar endavant la família amb diversos treballs mal pagats. Fins que un dia reben una notícia meravellosa: la filla gran acaba de comprometre’s amb un noi de bona família."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Ainda Temos o Amanhã","runtime":0,"tagline":"","homepage":"","overview":"Roma pós-guerra nos anos 40, dividida entre o otimismo da libertação e as misérias, vive Delia, uma mulher dedicada, esposa de Ivano e mãe de três filhos. Enquanto seu marido Ivano age como o chefe autoritário da família, Delia encontra consolo em sua amiga Marisa. A família se prepara para o noivado da filha mais velha, Marcella, que vê no casamento uma saída para uma vida melhor. No entanto, a chegada de uma carta misteriosa dá a Delia a coragem para questionar seu destino e de sua família e, talvez, encontrar sua própria liberdade."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Miénk lesz a holnap","runtime":0,"tagline":"","homepage":"","overview":"Delia, háromgyermekes anya az 1940-es évek második felében Rómában él. A város a felszabadulásból fakadó remény és az éppen csak véget ért háború okozta anyagi nehézségek között vergődik.  A tekintélyelvű és erőszakos férjével, Ivanoval szemben Delia csak barátnőjében, Marisában talál vigaszt, akivel megosztja a könnyed pillanatok és a bizalmas beszélgetések pillanatait.  A komor hétköznapok tavasszal érnek véget, amikor az egész család a legidősebb lány, Marcella közelgő eljegyzésének megünneplésére készül.  Ám egy titokzatos levél érkezése mindent a feje tetejére állít, és arra sarkallja Deliát, hogy bátorságot merítsen egy jobb jövő elképzeléséhez, és ne csak saját maga számára."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Siempre nos quedará mañana","runtime":0,"tagline":"","homepage":"","overview":"Es primavera y toda la familia está alborotada por el inminente compromiso de la querida hija mayor, Marcella, quien, por su parte, sólo espera casarse rápidamente con un simpático chico de clase media, Giulio, y librarse por fin de esa incómoda familia."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Jutri je še en dan","runtime":0,"tagline":"","homepage":"","overview":"Delia je žena in mati treh otrok v povojnem Rimu. Ko ne gospodinji nasilnemu možu in ne skrbi za sitnega tasta, hiti med priložnostnimi deli. Edino uteho ji prinašata klepet s prijateljico in hčerina zaroka s prijetnim mladeničem iz premožne družine. Svojo usodo sprejema brez pritoževanja – dokler nekega dne ne prispe skrivnostno pismo..."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Je tu ještě zítřek","runtime":118,"tagline":"","homepage":"","overview":"V poválečném Římě, městě, které se potácí mezi znovunabytou svobodou a nepříjemnými dozvuky války, žije Delia. Zdá se, že je smířená s tradiční rolí ženy a matky. Její muž Ivano je neoddiskutovatelným pánem domu. Všechno se ale změní s příchodem tajemného dopisu, který probudí Deliino odhodlání vzepřít se konvencím a zajistit si lepší život."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Viltingas rytojus","runtime":118,"tagline":"","homepage":"","overview":"Delija – eilinė tradicinės pokario italų šeimos motina: augina tris vaikus, prižiūri namus, slaugo ligotą uošvį ir tyliai kenčia į smurtą linkusio sutuoktinio Ivano išpuolius. Nors ir atrodo susitaikiusi su likimu, iš tikrųjų giliai širdyje Delija puoselėja viltį, kad gyvenimas gali būti kitoks.\r Greičiausią pokytį į šeimą žada atnešti jos vyriausios duktės Marčelos santuoka su Džiulijumi. Prakutusio baro savininko sūnus atkakliai siekia Marčelos rankos, o ir mergina jam neabejinga. Tačiau Delija greitai pamato, kad Džiulijus yra pernelyg panašus tiek į savo paties tėvą, tiek į jos vyrą Ivaną. Tvirtai apsisprendusi neleisti, kad mylima duktė kartotų jos pačios klaidas ir pakliūtų į nelaimingos santuokos spąstus, Delija pasiryžta padaryti bet ką, kad užkirstų tam kelią."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"E și mâine o zi","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"明天還有夢","runtime":0,"tagline":"","homepage":"","overview":"黛莉亞本以為披上嫁衣、育女生兒是女人的大志，但人生從不如童話保證是 happily ever after。時為二戰後物資匱乏、女性地位依然低下的羅馬，對內照料恃老揩油的「父權癌」老爺、看顧家中稚子已經心很累，對外還要東奔西跑兼職養家，把每分錢上繳給一言不合兜巴星的躁狂丈夫，心底自是懼怕女兒他日重蹈悲劇輪迴。人生剩下黑白色之際，一封神秘來信忽爾出現眼前，令噤聲已久的黛莉亞對明日重燃希望…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Homme on ka päev","runtime":0,"tagline":"","homepage":"","overview":"Kevad 1946, suur sõda Euroopas on just lõppenud ja liitlaste sõjaväelased tiirutavad Rooma tänavatel. Loo peategelaseks on klassikalise itaalia perekonna pereema Delia, kes on abielus vägivaldse mehe Ivanoga ja kodus sirguvad kolm last. Lastest vanim, tütar Marcella on värskelt armunud ning peab mehele mineku plaane. Delia õlul on uskumatult palju, aga ta kannatab kõik raskused vapralt ära. Väikseid rõõme ta päevades pakuvad lapsed, sõbranna Marisa ja autoremondimees Nino."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"まだ明日がある","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Vēl būs rītdiena","runtime":0,"tagline":"","homepage":"","overview":"1946. gada maijs Romā. Pilsēta pamazām atkopjas no Otrā pasaules kara postījumiem. Delija ir precējusies ar varmāku Ivano. Viņa paklausīgi paveic visus mājas darbus, rūpējas par trīs bērniem un piepelnās zemi atalgotos darbos. Vienīgais prieks dzīvē ir draudzība ar asprātīgo, drosmīgo Marisu un saskarsmes mirkļi ar jaunības dienu mīlestību, auto mehāniķi Nino. Visu pārvērš kāda noslēpumaina vēstule."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Vi har stadig i morgen","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"}],"reviews_tmdb":[{"id":"66320f14470ead0128106cde","url":"https://www.themoviedb.org/review/66320f14470ead0128106cde","author":"CinemaSerf","content":"$11","created_at":"2024-05-01T09:44:52.295Z","updated_at":"2024-05-01T21:59:26.019Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}},{"id":"67f8e8a87f70ac1a21d93a69","url":"https://www.themoviedb.org/review/67f8e8a87f70ac1a21d93a69","author":"Brent Marchant","content":"$12","created_at":"2025-04-11T10:02:16.981Z","updated_at":"2025-04-11T10:02:17.064Z","author_details":{"name":"Brent Marchant","rating":6,"username":"Brent_Marchant","avatar_path":null}}],"recommendations":[{"id":970348,"adult":false,"title":"The Old Oak","video":false,"overview":"A pub landlord in a previously thriving mining community struggles to hold onto his pub. Meanwhile, tensions rise in the town when Syrian refugees are placed in the empty houses in the community.","genre_ids":[18],"media_type":"movie","popularity":0.8812,"vote_count":384,"poster_path":"/xN293BKB0MDqpILmLCtGGYxQXKW.jpg","release_date":"2023-09-29","vote_average":7.208,"backdrop_path":"/H8YE8DDrnvr869RgCqLvhfcUFM.jpg","original_title":"The Old Oak","original_language":"en"},{"id":1044648,"adult":false,"title":"Nuovo Olimpo","video":false,"overview":"In 1970s Rome, a casual encounter between Enea and Pietro at a movie theater turns into an unforgettable romance — until destiny pulls them apart.","genre_ids":[10749,18],"media_type":"movie","popularity":0.6717,"vote_count":219,"poster_path":"/3nx8pSvAARYOLlZ2MNBlH7vW9jv.jpg","release_date":"2023-11-01","vote_average":6.952,"backdrop_path":"/7zmauCUkwjq9wBWBY1IoV5mi8ju.jpg","original_title":"Nuovo Olimpo","original_language":"it"},{"id":837335,"adult":false,"title":"La Chimera","video":false,"overview":"Just out of jail, rumpled English archaeologist Arthur reconnects with his wayward crew of tombaroli accomplices – a happy-go-lucky collective of itinerant grave-robbers who survive by looting Etruscan tombs and fencing the ancient treasures they dig up.","genre_ids":[18,14,35],"media_type":"movie","popularity":1.7955,"vote_count":546,"poster_path":"/dV6SYHmmFLXQU7oKRfK4pOFCX6M.jpg","release_date":"2023-10-12","vote_average":7.3,"backdrop_path":"/210V8lN8FL3F4dXjpvjZSlEKykD.jpg","original_title":"La chimera","original_language":"it"},{"id":1080936,"adult":false,"title":"The Last Time We Were Children","video":false,"overview":"Rome, summer 1943. Four children play war while the bombs of real war explode around them.  Italo is the rich son of the Federal, Cosimo has his father in confinement and an atavistic hunger, Vanda is an orphan and a believer, Riccardo comes from a wealthy Jewish family.  They are different but they don't know it and between them \"the greatest friendship in the world\" is born, impervious to the divisions of history that bloodies Europe.  But on October 16 the Jewish boy is taken away by the Germans together with over a thousand people from the Ghetto.  Thanks to Italo's father Federale, the three friends believe they know where he is and, to honor the \"spit pact\", decide to leave in secret to convince the Germans to free their friend.  Yet another imaginative mission becomes reality, the three children travel alone in an Italy exhausted by war, among disbanded soldiers, deserters, occupying German troops, exhausted and hungry populations.","genre_ids":[18,35,12],"media_type":"movie","popularity":0.4192,"vote_count":132,"poster_path":"/xcqZ0x2PwXx9B7a4Kk3LFdineoO.jpg","release_date":"2023-10-12","vote_average":7.053,"backdrop_path":"/yaEUCwcNhd7lZl73BBliqtIhWTv.jpg","original_title":"L'ultima volta che siamo stati bambini","original_language":"it"},{"id":1128668,"adult":false,"title":"Santocielo","video":false,"overview":"In paradise, a group gathers to discuss why people still act selfishly, even though Jesus sacrificed himself for them 2,000 years ago. As a result, a new Messiah is sent to Earth to address the issue.","genre_ids":[35,14],"media_type":"movie","popularity":0.6871,"vote_count":171,"poster_path":"/dLDyJunOnqwCdQesG6mvCWCWCEs.jpg","release_date":"2023-12-14","vote_average":5.918,"backdrop_path":"/8mXqTjyxfC9iA5KEkwU0Aq6DCtx.jpg","original_title":"Santocielo","original_language":"it"},{"id":1111796,"adult":false,"title":"Il migliore dei mondi","video":false,"overview":"A middle-aged man dissatisfied with the present state of things finds himself in a parallel universe where all technology is stuck in the 1990s.","genre_ids":[35,878],"media_type":"movie","popularity":0.3774,"vote_count":206,"poster_path":"/40Qa8ldgA8sdsjmaoA0fDG5XsjC.jpg","release_date":"2023-11-17","vote_average":6.231,"backdrop_path":"/upRgSHsTtktUuC3NlikqE6Rw56.jpg","original_title":"Il migliore dei mondi","original_language":"it"},{"id":1206163,"adult":false,"title":"Ilary Blasi: The One and Only","video":false,"overview":"In this documentary, Ilary Blasi shares the emotional and powerful story of the much-discussed end of her marriage.","genre_ids":[99],"media_type":"movie","popularity":0.8007,"vote_count":76,"poster_path":"/5tAN9qy8d1cqDTwLFAhiRJc7q00.jpg","release_date":"2023-11-24","vote_average":5.697,"backdrop_path":"/rf3SfnneQlK1bNDDQ4NXhXTW7pQ.jpg","original_title":"Unica","original_language":"it"},{"id":1047016,"adult":false,"title":"The Commander","video":false,"overview":"One dark night during the early phases of WWII, the Italian Royal Navy submarine Cappellini sinks an armed merchant ship sailing with lights out. At that moment, its commander Salvatore Todaro makes a decision that was destined to go down in history: to save the 26 shipwrecked Belgians who otherwise would have drowned in the middle of the Atlantic Ocean and disembark them at the nearest safe harbor. To make room for them on board his submarine, he is forced to navigate on the surface of the water for three days, visible to the enemy forces and endangering his life and that of his men.","genre_ids":[10752,36,18],"media_type":"movie","popularity":0.5857,"vote_count":210,"poster_path":"/yyTsyp5EwmLQTIU38nFKo4fEx46.jpg","release_date":"2023-10-31","vote_average":6.929,"backdrop_path":"/73YLfUGooIzp94Bpd9CjJRYCxmX.jpg","original_title":"Comandante","original_language":"it"},{"id":1109306,"adult":false,"title":"A World Apart","video":false,"overview":"Elementary school teacher Michele Cortese is about to start a whole new life. After 40 years of teaching in the metropolitan Roman jungle, he had to move to a village in Central Italy, to teach in a tiny school with just a few children aged 7-10. Struggling to overcome his urban inadequacy, he finds a friendly face in vice-principal Agnese and gradually manages to fit in, thanks to her and their spirited pupils. As everything seems to be falling into place, unwelcome news comes through: the school has failed to meet its student quota for the next year and will soon be shut for good.","genre_ids":[35],"media_type":"movie","popularity":0.4557,"vote_count":206,"poster_path":"/9Laozh4nmOZkmf3meyjPb2IYAdL.jpg","release_date":"2024-03-28","vote_average":6.5,"backdrop_path":"/2CtKnSi5SQ3aZc9Af25bsVv6Rcu.jpg","original_title":"Un mondo a parte","original_language":"it"},{"id":1000862,"adult":false,"title":"The Good Teacher","video":false,"overview":"Julien, a young teacher, is wrongfully accused of sexual misconduct by a teenage girl from his class. As he faces mounting pressures from the girl’s older brother and her classmates, the situation spirals out of control. Allegations spread, the entire school is thrown into turmoil, and the teacher has to fight to clear his name.","genre_ids":[18,53],"media_type":"movie","popularity":1.1139,"vote_count":305,"poster_path":"/haqfplSRnIwO8ha5tKOxwnG1sxP.jpg","release_date":"2024-03-27","vote_average":6.323,"backdrop_path":"/1SO3YnpeZB4kSBpv4IgT88dBiE8.jpg","original_title":"Pas de vagues","original_language":"fr"},{"id":937746,"adult":false,"title":"Io Capitano","video":false,"overview":"Longing for a brighter future, two Senegalese teenagers embark on a journey from West Africa to Italy. However, between their dreams and reality lies a labyrinth of checkpoints, the Sahara Desert, and the vast waters of the Mediterranean.","genre_ids":[12,18],"media_type":"movie","popularity":1.2623,"vote_count":798,"poster_path":"/kGlZFwUQI5gAUdySNFfqGIkAF9n.jpg","release_date":"2023-09-07","vote_average":7.796,"backdrop_path":"/rniS6AOKTOr5PV7Xok6m7QSzlXg.jpg","original_title":"Io capitano","original_language":"it"},{"id":994108,"adult":false,"title":"All of Us Strangers","video":false,"overview":"One night in his near-empty tower block in contemporary London, Adam has a chance encounter with a mysterious neighbor Harry, which punctures the rhythm of his everyday life.","genre_ids":[10749,18,14],"media_type":"movie","popularity":3.3882,"vote_count":971,"poster_path":"/aviJMFZSnnCAsCVyJGaPNx4Ef3i.jpg","release_date":"2023-12-22","vote_average":7.395,"backdrop_path":"/8yjHiSuSEhzR916LcIecuQ8tETG.jpg","original_title":"All of Us Strangers","original_language":"en"},{"id":834141,"adult":false,"title":"The Shadow of the Day","video":false,"overview":"Italy, after the promulgation of the racial laws (1938). Luciano, a Fascist-abiding restaurateur, nonetheless believes he can still live by his own rules inside his business. However, everything changes when Anna, a girl with a dangerous secret, starts to work at his restaurant.","genre_ids":[18,36,10749],"media_type":"movie","popularity":0.4326,"vote_count":112,"poster_path":"/sshAibeaoefsi5q4wvxT7qTJI5R.jpg","release_date":"2022-02-24","vote_average":6.415,"backdrop_path":"/78KHXujggntUnAK8kvOBQtEem43.jpg","original_title":"L'ombra del giorno","original_language":"it"},{"id":1018728,"adult":false,"title":"Latin for All","video":false,"overview":"Delphine, a disillusioned humanities teacher, makes an agreement with her students : they leave her in peace, as they get A+ grades. But these excellent results turn into a nightmare when the class is qualified for the Latin World Championships, in Naples.","genre_ids":[35],"media_type":"movie","popularity":3.3253,"vote_count":68,"poster_path":"/A2jR6cmMum0cn53ZxQHFFewzqdW.jpg","release_date":"2024-03-20","vote_average":5.1,"backdrop_path":"/es42GOqfcaUgF1duI81ZsMdHjvU.jpg","original_title":"Bis Repetita","original_language":"fr"},{"id":824003,"adult":false,"title":"Diabolik: Who Are You?","video":false,"overview":"Captured by a ruthless gang of bank robbers, foes Diabolik and Ginko find themselves facing certain death. While Eva Kant and Altea forge an unlikely alliance to rescue their lovers, Diabolik reveals his mysterious past to the Inspector.","genre_ids":[80,28,9648,53],"media_type":"movie","popularity":1.4649,"vote_count":157,"poster_path":"/1DAXwi4y941ryPoGbzUlFEEiPAo.jpg","release_date":"2023-11-30","vote_average":6.354,"backdrop_path":"/hLYH6wbi3Mgscdv2KuYcTdWGlUV.jpg","original_title":"Diabolik - Chi sei?","original_language":"it"},{"id":930564,"adult":false,"title":"Saltburn","video":false,"overview":"Struggling to find his place at Oxford University, student Oliver Quick finds himself drawn into the world of the charming and aristocratic Felix Catton, who invites him to Saltburn, his eccentric family's sprawling estate, for a summer never to be forgotten.","genre_ids":[18,35,53],"media_type":"movie","popularity":6.7298,"vote_count":2815,"poster_path":"/zGTfMwG112BC66mpaveVxoWPOaB.jpg","release_date":"2023-11-16","vote_average":6.965,"backdrop_path":"/bAtFhmRHp0f6aHqj1UGTZoPcmQo.jpg","original_title":"Saltburn","original_language":"en"},{"id":859235,"adult":false,"title":"Coup de Chance","video":false,"overview":"Fanny and Jean have everything of an ideal couple: fulfilled in their professional life, they live in a magnificent apartment in the beautiful districts of Paris and seem to be in love as on the first day. But when Fanny crosses, by chance, Alain, a former high school friend, she is immediately capsized. They see each other again very quickly and get closer and closer.","genre_ids":[18],"media_type":"movie","popularity":1.3541,"vote_count":425,"poster_path":"/cvejKWAstLqgUmC4N8P81CyhJdI.jpg","release_date":"2023-09-15","vote_average":6.165,"backdrop_path":"/xSIJy4vPKpo2uw6q7HNBhIvQaj6.jpg","original_title":"Coup de chance","original_language":"fr"},{"id":753342,"adult":false,"title":"Napoleon","video":false,"overview":"An epic that details the checkered rise and fall of French Emperor Napoleon Bonaparte and his relentless journey to power through the prism of his addictive, volatile relationship with his wife, Josephine.","genre_ids":[36,10752,10749],"media_type":"movie","popularity":6.5956,"vote_count":2998,"poster_path":"/ytFOXyghxLzAM4KZyazDdEkM66q.jpg","release_date":"2023-11-22","vote_average":6.3,"backdrop_path":"/33pMXav77ICRnceEBLhL8lXTywv.jpg","original_title":"Napoleon","original_language":"en"},{"id":508883,"adult":false,"title":"The Boy and the Heron","video":false,"overview":"While the Second World War rages, the teenage Mahito, haunted by his mother's tragic death, is relocated from Tokyo to the serene rural home of his new stepmother Natsuko, a woman who bears a striking resemblance to the boy's mother. As he tries to adjust, this strange new world grows even stranger following the appearance of a persistent gray heron, who perplexes and bedevils Mahito, dubbing him the \"long-awaited one.\"","genre_ids":[16,12,14,18,10751],"media_type":"movie","popularity":6.3942,"vote_count":2531,"poster_path":"/f4oZTcfGrVTXKTWg157AwikXqmP.jpg","release_date":"2023-07-14","vote_average":7.403,"backdrop_path":"/75nSb1fbWooipwcSU5bUttiOriI.jpg","original_title":"君たちはどう生きるか","original_language":"ja"},{"id":1021803,"adult":false,"title":"Adagio","video":false,"overview":"Tangled up with blackmail and crooked cops, the son of a former gangster seeks out his father's old friends, who risk everything to save him.","genre_ids":[80,53,28],"media_type":"movie","popularity":0.491,"vote_count":270,"poster_path":"/x9kLSGl1q6T4IKjXpJ8I6O8U873.jpg","release_date":"2023-12-14","vote_average":6.631,"backdrop_path":"/p3ptZJtmzjpE9jvvi4NzJvuWALp.jpg","original_title":"Adagio","original_language":"it"}],"similar_content":[{"id":8316,"adult":false,"title":"The Countess","video":false,"overview":"Kingdom of Hungary, 17th century. As she gets older, powerful Countess Erzsébet Báthory (1560-1614), blinded by the passion that she feels for a younger man, succumbs to the mad delusion that blood will keep her young and beautiful forever.","genre_ids":[18,36,53,9648,27],"popularity":0.8342,"vote_count":179,"poster_path":"/nnksbKPiwDZS5x9O64OU94hJ15g.jpg","release_date":"2009-03-13","vote_average":5.907,"backdrop_path":"/w1kShva9ltxozY2UePgBjXjedvI.jpg","original_title":"The Countess","original_language":"en"},{"id":8391,"adult":false,"title":"When Night Is Falling","video":false,"overview":"Camille is a professor at a Protestant college and is in a long-term relationship with Martin, a respected minister and fellow professor. When Camille meets Petra, a bold and flamboyant performer in a circus troupe, she is inexplicably drawn. Pursuing Petra, Camille throws her whole conservative life into disarray.","genre_ids":[18,10749],"popularity":0.7213,"vote_count":88,"poster_path":"/6Ac5GLwJ01uli5mCXqXwquR36Y1.jpg","release_date":"1995-02-01","vote_average":6.261,"backdrop_path":"/5CCPKLWg0YWajQEXWYeY2w5c8qS.jpg","original_title":"When Night Is Falling","original_language":"en"},{"id":277617,"adult":false,"title":"Koma","video":false,"overview":"Kawase explores the fragile and often tense history between Korea and Japan through the relationship that develops between a third generation Korean-Japanese man, who unexpectedly visits the small and quiet village of Koma, and a Japanese woman, a somewhat mysterious inhabitant of the village.","genre_ids":[18],"popularity":0.4171,"vote_count":0,"poster_path":"/8umyF52LbvvsGSMNpYVMQX3yG2C.jpg","release_date":"2009-11-12","vote_average":0,"backdrop_path":null,"original_title":"狛","original_language":"ja"},{"id":8427,"adult":false,"title":"I Spy","video":false,"overview":"When the Switchblade, the most sophisticated prototype stealth fighter created yet, is stolen from the U.S. government, one of the United States' top spies, Alex Scott, is called to action. What he doesn't expect is to get teamed up with a cocky civilian, World Class Boxing Champion Kelly Robinson, on a dangerous top secret espionage mission. Their assignment: using equal parts skill and humor, catch Arnold Gundars, one of the world's most successful arms dealers.","genre_ids":[28,12,35,53],"popularity":4.7686,"vote_count":1008,"poster_path":"/hmjCMtkeqxruMVocq7iwMx899xi.jpg","release_date":"2002-10-31","vote_average":5.4,"backdrop_path":"/qwGkQpQbDXuHDOq909RQmJPENwN.jpg","original_title":"I Spy","original_language":"en"},{"id":277534,"adult":false,"title":"Carlotta","video":false,"overview":"How many working class Balmain boys grow up to be showgirls? Not just any showgirl but a household name, a legend of Kings Cross, a daytime TV star, and a symbol of generational change.","genre_ids":[10770,18],"popularity":0.3344,"vote_count":11,"poster_path":"/1KKXue0FWl0zI3fnevGNqmSaGae.jpg","release_date":"2014-06-19","vote_average":4.7,"backdrop_path":"/zK2IRQC7uSrtd81W7UULQjsx9qO.jpg","original_title":"Carlotta","original_language":"en"},{"id":277542,"adult":false,"title":"Perfect Lover","video":false,"overview":"In a futuristic world where women run the show, a shy plastics designer buys a female robot, so he gains confidence and becomes a ladies' man.","genre_ids":[878,35],"popularity":0.328,"vote_count":3,"poster_path":"/gyrOXxrPL6i08UAjkDUbnV5hS3d.jpg","release_date":"2001-01-20","vote_average":2,"backdrop_path":null,"original_title":"Perfect Lover","original_language":"en"},{"id":8351,"adult":false,"title":"Beautiful Memories","video":false,"overview":"Although barely 30, Claire believes she is showing the first symptoms of Alzheimer's disease, a condition from which her mother has recently died. Her sister, Nathalie, is certain that her memory loss, caused by a lightning strike, is temporary. In the clinic where she is being treated, Claire is attracted to Philippe, a man who is still traumatized after a car accident in which his wife and child were both killed. In spite of their personal tragedies, Claire and Philippe fall in love. When Philippe recovers, Claire moves into his home. Then Claire's condition takes a turn for the worse.","genre_ids":[10749,18],"popularity":0.3112,"vote_count":66,"poster_path":"/9HnNGkpeGf8Wj0HPd1JFnnqFpp.jpg","release_date":"2001-08-24","vote_average":6.9,"backdrop_path":"/8pfnGW6rPtN4f5HmZKs8h1Yv4IH.jpg","original_title":"Se souvenir des belles choses","original_language":"fr"},{"id":8357,"adult":false,"title":"What the #$*! Do We (K)now!?","video":false,"overview":"Amanda is a divorced woman who makes a living as a photographer. During the Fall of the year Amanda begins to see the world in new and different ways when she begins to question her role in life, her relationships with her career and men and what it all means. As the layers to her everyday experiences fall away insertions in the story with scientists, and philosophers and religious leaders impart information directly to an off-screen interviewer about academic issues, and Amanda begins to understand the basis to the quantum world beneath. During her epiphany as she considers the Great Questions raised by the host of inserted thinkers, she slowly comprehends the various inspirations and begins to see the world in a new way.","genre_ids":[99,35,18],"popularity":0.4826,"vote_count":126,"poster_path":"/ghoM9gorKvgAcqkSJ6TDQcsObWN.jpg","release_date":"2004-04-23","vote_average":5.099,"backdrop_path":"/8UbudSoPEbbCUGDnj56TbDK0jYy.jpg","original_title":"What the #$*! Do We (K)now!?","original_language":"en"},{"id":8359,"adult":false,"title":"Kit Kittredge: An American Girl","video":false,"overview":"The Great Depression hits home for nine year old Kit Kittredge when her dad loses his business and leaves to find work. Oscar nominee Abigail Breslin stars as Kit, leading a splendid cast in the first ever \"American Girl\" theatrical movie. In order to keep their home, Kit and her mother must take in boarders - paying house - guests who turn out to be full of fascinating stories. When mother's lockbox containing all their money is stolen, Kit's new hobo friend Will is the prime suspect. Kit refuses to believe that Will would steal, and her efforts to sniff out the real story get her and friends into big trouble. The police say the robbery was an inside job, committed by someone they know. So if it wasn't Will, then who did it.","genre_ids":[10751,35,18,9648],"popularity":0.6749,"vote_count":137,"poster_path":"/niHi0hJSryO5DpSVNCMASc3EELc.jpg","release_date":"2008-07-02","vote_average":6.5,"backdrop_path":"/vstpnfQNVyilkmXjmCzfIVwGwjg.jpg","original_title":"Kit Kittredge: An American Girl","original_language":"en"},{"id":471130,"adult":false,"title":"The Interview","video":false,"overview":"Henry Czerny plays American journalist Michael Coleman, a strung-out expatriate writing for a Brazilian newspaper. His professional obsession is Father Stephen Louis, a mildly popular and charismatic priest who has been the major political opponent of the greedy and ruthless landowners of the Bahia region. Mysteriously, the usually outspoken Father Louis has been silent for three months. With the Brazilian Congress about to vote on a major land-redistribution bill that could potentially tip the balance of power even further, Father Louis’s support of the peasants and his condemnation of the landowners is more important than ever. Coleman sets out alone for the politically unstable Bahia region to capture a highly anticipated interview with the elusive priest.","genre_ids":[18],"popularity":0.2446,"vote_count":3,"poster_path":"/pkVpIcoPb8nrcadhjCa4h1Ywmcy.jpg","release_date":"1995-09-10","vote_average":2.333,"backdrop_path":"/fIQ0F6BJO0ZVvTAkmaeN4A0wPae.jpg","original_title":"Jenipapo","original_language":"pt"},{"id":8438,"adult":false,"title":"Murder in the First","video":false,"overview":"A young, inexperienced public defender is assigned to defend an inmate accused of committing murder while behind bars.","genre_ids":[80,18],"popularity":1.143,"vote_count":597,"poster_path":"/duUpJUmuz82OKMwGnKc8sCV7emS.jpg","release_date":"1995-01-20","vote_average":7.148,"backdrop_path":"/8uw6OCa4ofQ6A9xz5ldtgnEVPDr.jpg","original_title":"Murder in the First","original_language":"en"},{"id":277673,"adult":false,"title":"Pauline Alone","video":false,"overview":"A woman tries to connect with people she's never met.","genre_ids":[35],"popularity":1.758,"vote_count":4,"poster_path":"/aCvI4H0fCLcq9Y4gQQOQg5rfx1K.jpg","release_date":"2014-06-19","vote_average":5,"backdrop_path":null,"original_title":"Pauline Alone","original_language":"en"},{"id":277687,"adult":false,"title":"The Midnight Swim","video":false,"overview":"Spirit Lake is unusually deep. No diver has ever managed to find the bottom. When Dr. Amelia Brooks disappears during a deep-water dive, her three daughters travel home. They find themselves unable to let go and become drawn into the mysteries of the lake.","genre_ids":[18,9648,27],"popularity":0.2569,"vote_count":36,"poster_path":"/uw53wv8RxN1BcNHzAiODxWtXOEH.jpg","release_date":"2015-06-26","vote_average":5,"backdrop_path":"/yZdHep2iChFJYaAbKqZt31OgEA8.jpg","original_title":"The Midnight Swim","original_language":"en"},{"id":277690,"adult":false,"title":"Yasmine","video":false,"overview":"Yasmine, a high school student from Brunei, fed up with studying and her strict father, decides to learn silat, a martial art practiced in Southeast Asia, after a boy displays his own knowledge of silat in order to impress her.","genre_ids":[18,28],"popularity":0.1587,"vote_count":8,"poster_path":"/mIc30cgSPATaF0bPNT10zT21gdO.jpg","release_date":"2014-08-16","vote_average":6.75,"backdrop_path":"/nwcXG0QnS5aeJDYQ7ozTDVeiL8V.jpg","original_title":"Yasmine","original_language":"ms"},{"id":8656,"adult":false,"title":"Deep Impact","video":false,"overview":"A seven-mile-wide space rock is hurtling toward Earth, threatening to obliterate the planet. Now, it's up to the president of the United States to save the world. He appoints a tough-as-nails veteran astronaut to lead a joint American-Russian crew into space to destroy the comet before impact. Meanwhile, an enterprising reporter uses her smarts to uncover the scoop of the century.","genre_ids":[28,18,878],"popularity":4.7039,"vote_count":3238,"poster_path":"/a3vQS7JKqlOb3MdVJHuTCP9s7Mg.jpg","release_date":"1998-05-08","vote_average":6.2,"backdrop_path":"/pWmJBkdb0EMb3PSd2f9wjza0krb.jpg","original_title":"Deep Impact","original_language":"en"},{"id":277712,"adult":false,"title":"Two Women","video":false,"overview":"A headstrong young woman is married to land baron. Her feelings for her son's tutor becomes a complex web of unrequited love.","genre_ids":[10749,18],"popularity":0.8502,"vote_count":14,"poster_path":"/q0uEDP7BTjsF4DrrrYLIvLinlrL.jpg","release_date":"2014-11-23","vote_average":6.4,"backdrop_path":"/cbSfIgVMD6pjWVfYbV7Tls0G2Yt.jpg","original_title":"Две женщины","original_language":"ru"},{"id":471339,"adult":false,"title":"Hayflower, Quiltshoe and the Rubens Brothers","video":false,"overview":"When Kattilakoski family goes on a week-long Summer vacation to a rented cottage, the local police constables Bigbelly and Stronglass are joyful. Finally one week of peace! Their joy doubles when they win a rent-free summer cottage for one week. What they don't know is, that these two cottages are next to each other! When the truth comes out, the constables are forced to masquerade themselves to remain incognito. Unfortunately their alter egos, artistic Rubens brothers, become an instant hit for Mother Kattilakoski. Hayflower and Quiltshoe have instant doubts about Rubens; they must be escaped bandits instead. The girls set to prove their theory.","genre_ids":[35,10751],"popularity":0.1792,"vote_count":4,"poster_path":"/rYZczng7wwlaEjBRGrTQxaXDE4h.jpg","release_date":"2017-11-24","vote_average":6,"backdrop_path":"/y13a1PGUFO4haQTGYvdkXUHzShF.jpg","original_title":"Heinähattu, Vilttitossu ja Rubensin veljekset","original_language":"fi"},{"id":8665,"adult":false,"title":"K-19: The Widowmaker","video":false,"overview":"When Russia's first nuclear submarine malfunctions on its maiden voyage, the crew must race to save the ship and prevent a nuclear disaster.","genre_ids":[18,36,53,9648,10752],"popularity":1.8733,"vote_count":1135,"poster_path":"/vImR0HQkJs7Xs2qgdXEUDeX49m0.jpg","release_date":"2002-07-19","vote_average":6.5,"backdrop_path":"/puleizXkdZrYW9641MZHj7IhAY4.jpg","original_title":"K-19: The Widowmaker","original_language":"en"},{"id":8675,"adult":false,"title":"Orgazmo","video":false,"overview":"A devout Mormon living in L.A. becomes a pornographic actor after his martial arts moves impress a big-time director.","genre_ids":[35],"popularity":1.1831,"vote_count":470,"poster_path":"/irvFBOc33CHsioU6hqcu8ExymEa.jpg","release_date":"1998-07-02","vote_average":6.113,"backdrop_path":"/bFCJcJ8Grp12Fkeh0X4oUcoV5uR.jpg","original_title":"Orgazmo","original_language":"en"},{"id":661932,"adult":false,"title":"Honey Cigar","video":false,"overview":"Paris, 1993. Selma, 17, lives in a bourgeois and secular Berber family. When she meets and is strongly attracted to Julien, a dashing young man, she realizes for the first time the heavy rules of her patriarchal family and how they affect her intimacy. As Islamism takes over her country of origin and her family crumbles, Selma discovers the power of her own desire. She must resist and fight. Through the strength of her people, she starts walking down the path of what it means to become a free woman.","genre_ids":[18],"popularity":0.1734,"vote_count":35,"poster_path":"/eUVcN17LXxVUeLkgWHj8FIWnq2B.jpg","release_date":"2020-09-02","vote_average":5.7,"backdrop_path":"/tLmr7yhyfybVniH8LZGYeEDkaLf.jpg","original_title":"Cigare au miel","original_language":"fr"}],"external_ids":{"imdb_id":"tt21800162","twitter_id":null,"facebook_id":null,"wikidata_id":"Q123179308","instagram_id":null,"metacritic_id":"movie/theres-still-tomorrow","mydramalist_id":"373583","rotten_tomatoes_id":"m/theres_still_tomorrow"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148337,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_receptio