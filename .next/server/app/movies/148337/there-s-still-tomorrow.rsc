9:{"metadata":[["$","title","0",{"children":"There's Still Tomorrow | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"In postwar Rome, a working-class woman dreams of a better future for herself and her daughter while facing abuse at the hands of her domineering husband. When a mysterious letter arrives, she discovers the courage to change the circumstances of her life."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148337/there-s-still-tomorrow"}],["$","meta","5",{"property":"og:title","content":"There's Still Tomorrow"}],["$","meta","6",{"property":"og:description","content":"In postwar Rome, a working-class woman dreams of a better future for herself and her daughter while facing abuse at the hands of her domineering husband. When a mysterious letter arrives, she discovers the courage to change the circumstances of her life."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148337/there-s-still-tomorrow"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/4Hi7yjiQjokEDStT1MOj5rPgRfW.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"There's Still Tomorrow"}],["$","meta","12",{"name":"twitter:description","content":"In postwar Rome, a working-class woman dreams of a better future for herself and her daughter while facing abuse at the hands of her domineering husband. When a mysterious letter arrives, she discovers the courage to change the circumstances of her life."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/4Hi7yjiQjokEDStT1MOj5rPgRfW.jpg"}],["$","link","14",{"rel":"icon","