y":3}]},"UG":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":13}],"link":"https://www.themoviedb.org/movie/1495-kingdom-of-heaven/watch?locale=UG","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":13}]},"US":{"buy":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":6},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"link":"https://www.themoviedb.org/movie/1495-kingdom-of-heaven/watch?locale=US","rent":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":6},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"flatrate":[{"logo_path":"/1C5EVCWyQD798CE1DFfcm6oAbxP.jpg","provider_id":1855,"provider_name":"Starz Apple TV Channel","display_priority":19}]},"UY":{"link":"https://www.themoviedb.org/movie/1495-kingdom-of-heaven/watch?locale=UY","flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":25}]},"VE":{"buy":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3}],"link":"https://www.themoviedb.org/movie/1495-kingdom-of-heaven/watch?locale=VE","rent":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3}],"flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":1}]},"ZA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3}],"link":"https://www.themoviedb.org/movie/1495-kingdom-of-heaven/watch?locale=ZA","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3}]}}},"wikidata_id":"Q207698","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-09T22:47:20.945767+00:00","region":null,"main_poster":null,"images":null,"enriched_at":"2026-02-22T20:07:00.372+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":144,"tagline":"Be without fear in the face of your enemies. Safeguard the helpless, and do no wrong","homepage":"","overview":"After his wife dies, a blacksmith named Balian is thrust into royalty, political intrigue and bloody holy wars during the Crusades."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Königreich der Himmel","runtime":144,"tagline":"Sprich stets die Wahrheit, auch wenn dies den eigenen Tod bedeutet, beschütze die Wehrlosen, tue kein Unrecht, dies sei dein Eid!","homepage":"http://www.kingdomofheavendvd.com/","overview":"Ende des 12. Jahrhunderts zur Zeit der Kreuzzüge: Der junge Schmied Balian tritt widerwillig eine gefährliche Reise an und folgt seinem Vater und geachteten Kreuzritter Godfrey in das Heilige Land, um dort in seine Fußstapfen zu treten und dessen Vision von Frieden in die Tat umzusetzen. Als Diener des von Intriganten umgebenen Königs Baldwin IV findet er sich mitten im Strudel des Krieges und einer unglücklichen Liebe zu Prinzessin Sybilla wieder. Zum Ritter geschlagen wird er dank seines Mutes zu einem ehrbaren Verfechter des Friedens zwischen den unterschiedlichen Religionen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":144,"tagline":"Soit sans crainte face à tes ennemis !","homepage":"","overview":"Balian le forgeron découvre que son père est un seigneur Croisé, peu avant que celui-ci ne meure et que ses terres à Jérusalem ne lui reviennent. Parti sur place, il se range au côté des fidèles du roi Baudoin, qui tentent de maintenir un équilibre fragile entre les Croisés et les troupes de Saladin. Mais le roi est mourant et puissants sont ceux qui s'opposent à lui et à la paix."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Le crociate - Kingdom of Heaven","runtime":144,"tagline":"Non avere timore innanzi ai tuoi nemici, salvaguarda gli indifesi e non fare torti.","homepage":"","overview":"Balian è un maniscalco che ha perso la famiglia e che ha rischiato di perdere anche la fede. Le guerre di religione che sconvolgono la remota Terra Santa gli sembrano lontane anni luce. Ma il destino bussa alla porta di Balian sotto le spoglie di un grande cavaliere, Godfrey di Ibelin..."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Mennyei királyság","runtime":144,"tagline":"","homepage":"","overview":"Balian, a hitét vesztett patkolókovács származása ellenére a Szentföldre utazik, ahol akaratlanul is a háború középpontjába kerül. Ám Jeruzsálem hamis csillogása, a lovagok, Tiberias és Guy de Lusignan ármánykodása közepette beleszeret a szépséges hercegnőbe, majd vezéralakja lesz az eseményeknek. Végül minden bátorságát és tudását összeszedve megpróbálja megvédeni a várost a legendás Szaladin hatalmas seregével szemben."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"El reino de los cielos","runtime":144,"tagline":"No muestres miedo frente a tus enemigos. Protege a los desamparados y no hagas mal","homepage":"","overview":"Balián de Ibelín viaja a Jerusalén durante las cruzadas del siglo XII, donde será el defensor de su pueblo."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Царство небесное","runtime":144,"tagline":"Не бойтесь своих врагов. Защищайте беспомощных и не делайте зла.","homepage":"","overview":"Юный оружейник Бэлиан вынужден бежать со своей родины. Он присоединяется к отряду крестоносцев, которым руководит его отец. Но, в одной из битв, отец получает тяжёлую рану и перед смертью присваивает своему сыну сан рыцаря, и тот клянётся в верности королю Иерусалима."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Království nebeské","runtime":190,"tagline":"Historický velkofilm o válce církví.","homepage":"","overview":"Kovář Balian sotva pohřbil ženu a dítě, když ho vyhledá baron Godfrey z Ibelinu, prozradí mu, že je jeho otcem, a zve ho k sobě do Svaté země. Mladého vdovce nabídka neláká, ale nakonec jej okolnosti přinutí, aby ji přijal. Godfrey však ještě před odplutím zemře, Balian složí rytířskou přísahu a jako baron z Ibelinu odjíždí do Jeruzalémského království. Zde se do něho zamiluje jeruzalémská princezna Sibylla, vdaná za zrádného rytíře Guye de Lusignan. Okolnosti, rytířská čest a slib ochraňovat bezbranné donutí mladého muže, aby se postavil do čela obránců Jeruzaléma proti Saladinovu vojsku."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"天国王朝","runtime":0,"tagline":"","homepage":"","overview":"------12世纪，巴里安(奥兰多·布鲁姆饰)是一个法国小铁匠，在妻子自杀后不情愿地加入了十字军。当他随着十字军东征来到耶路撒冷后，深深地被当地陌生而奇特的文化吸引，巴里安甚至爱上了公主希比拉。但是萨拉丁率领的撒拉森骑士很快来袭，他们发誓要夺回心中的圣地，一场惊心动魄又野蛮残酷的战争即将展开…… 奥兰多布鲁饰演贝里昂，一名失去家人和几乎丧失信仰的铁匠，在圣地发生的宗教大战似乎距离他很遥远，但他被命运逼入这个戏剧场景。他在中世纪神秘且复杂汹涌的耶路撒冷，陷入爱河，成为一名领袖，最后用全部的勇气和高超技艺悍卫整个城市不被悲剧摧毁。 命运要贝里昂成为一名骑士，再也不能自外于这场战争，高佛瑞（连恩尼逊饰演）是一位十字军战士，短暂从在东方的战场返回老家法国，透露说原来他是贝里昂的父亲，高佛瑞展现给他真正的骑士精神，并带他上路，越过大陆，抵达传说中的圣城。 这时的耶路撒冷正僵持在一种脆弱、一触即发的和平状态，由开明的基督教君王巴特文在幕僚提贝里尔斯（杰若米艾朗饰演），以及以骑士风范著称的回教优秀军队领导人撒拉丁（哈珊码索饰演）帮助下，勉力维持。但巴特文的日子所剩无多，并承受著十字军们的狂热、贪婪、嫉妒等人性弱点，和平摇摇欲坠。 包括高佛瑞在内的一群骑士，和巴特文国王一样有著王者天下的和平愿景，他们宣誓用生命来效忠这份荣誉。高佛瑞将宝剑传给儿子的同时，也等于递交给他这份誓言，要保护无助的人、捍卫和平、为文化和宗教上的和谐努力，成就天国一样的乐土帝国。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Cennet'in Krallığı","runtime":0,"tagline":"","homepage":"","overview":"Gladyatör'ün yönetmeni Ridley Scott'tan cesaret, tutku ve macera dolu, destansı bir yolculuğa hazır olun. Ortaçağ Kudüs'ünün entrika ve şaşaasının ortasında Orlando Bloom her şeyini kaybetmiş biriyken, şeref ve cesareti kendisini ziyarete gelen yürekli bir misafirde bulan genç Fransız Balian rolüyle göz dolduruyor. Yaşanan yenilgilere rağmen Balian, halkını kurtarmak ve gerçek bir şövalye olmak için ezici kuvvetlerle savaşır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Kingdom of Heaven - taivas maan päällä","runtime":144,"tagline":"","homepage":"","overview":"Vaatimaton ranskalainen seppä Balian menettää perheensä ja on vähällä menettää uskonsakin. Kaukaisella pyhällä maalla riehuvat uskonsodat tuntuvat kaukaiselta mutta kiehtovalla tavalla dramaattiselta. Kohtalo kutsuu Balianin suurelle matkalle, kun Godfrey Ibeliniläinen tulee käymään kotona idän ristiretkiltään."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Reino dos Céus","runtime":144,"tagline":"Não tenhas medo perante os teus inimigos.","homepage":"","overview":"Balian, um jovem ferreiro de luto pela morte da sua mulher e do seu filho, é encontrado por Godfrey de Ibelin, um cavaleiro do Reino de Jerusalém que lhe revela ser seu pai e oferece-lhe uma vida nova na Cidade Santa. Ao chegar, herda os bens paternos e esforça-se por auxiliar o rei cristão Balduíno IV, que está doente com lepra, a manter uma periclitante paz com os muçulmanos, liderados pelo sultão Saladino de Damasco."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Kingdom of Heaven","runtime":144,"tagline":"","homepage":"","overview":"Balian, een jonge Franse smid, rouwt om het verlies van zijn vrouw en zijn jonge zoon. Hij krijgt bezoek van Godfrey of Ibelin  - een baron van de koning van Jeruzalem, die zeer vastberaden is om vrede in het Beloofde Land te behouden. Hij is op zoek naar de rouwende Balian, zijn buitenechtelijke zoon.  Balian laat zijn verdriet voor wat het is en vergezelt Godfrey op zijn heilige missie. Wanneer zijn vader voortijdig overlijdt, erft Balian grond en een eigen titel in Jeruzalem, een stad waarin Christenen, Moslims en Joden vreedzaam samengeleefd hebben gedurende de korte wapenstilstand tussen de 2e en 3e Kruistocht.  In Jeruzalem wordt Balian verliefd op de mysterieuze zus van de koning, prinses Sibylla en zal Balian uitgroeien tot een van de meest eervolle en heldhaftigste ridders, die zijn volk moet beschermen tegen overweldigende krachten."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Królestwo niebieskie","runtime":145,"tagline":"Nie okazuj strachu w obliczu swoich wrogów. Chroń bezbronnych, i nigdy się nie cofaj.","homepage":"","overview":"Akcja filmu toczy się w czasach wypraw krzyżowych. Po stracie żony i syna, kowal Balian traci także wiarę w Boga. Jego życie zmieniają jednak odwiedziny słynnego rycerza, Godfryda z Ibelinu, ojca Baliana. Obaj wyruszają w drogę do Ziemi Świętej, w której panuje chwilowy rozejm między chrześcijanami i muzułmanami. Podczas tej podróży, pod wpływem ojca, Balian przeistacza się w prawdziwego rycerza. W Jerozolimie spotyka go jednak kolejna tragedia..."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Kráľovstvo nebeské","runtime":144,"tagline":"","homepage":"","overview":"Kováč Balian ovdovie, keď sa jeho manželka po smrti ich dieťaťa zabije. Zlomeného mladíka navštívi križiacky veterán Godfrey a prizná sa, že je jeho otec. Pokúša sa so synom zblížiť a ponúkne mu spoluúčasť na križiackej výprave. Godfreya pri obrane syna zrania a ešte pred príchodom do Jeruzalema zraneniam podľahne. Pred smrťou stihne dať synovi morálne rady a pasuje ho za rytiera. Osirelý Balian prichádza do Svätej zeme, ujíma sa svojho majetku a pôdy po otcovi a spozná krásnu Sibyllu. V Jeruzaleme pod panovaním čestného kráľa Balduina je obdobie krehkého mieru medzi kresťanmi a moslimskými saracénmi. Ten podkopáva chamtivý Reynald spolu s bojovným Guyom de Lusignanom. Po smrti Balduina sa práve de Lusignan stáva panovníkom Jeruzalema a vyhlási saracénom vojnu. Tých vedie Saladin a s prevahou križiakov na vojnovom poli poráža. Posledným obrancom mesta sa stáva Balian..."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"","runtime":144,"tagline":"","homepage":"","overview":"Balian en ung smed som efter att ha förlorat allt, söker heder och ära i det medeltida Jerusalem. Han lockas till den heliga staden av sin far och bestämmer sig för att beskydda den bräcklige kung Balduin mot dennes motståndare Saladin. Mot alla odds och mot överväldigande krafter slåss Balian för att rädda sitt folk och för att fullfölja sitt öde som en sann riddare."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Небесно царство","runtime":139,"tagline":"Не се страхувай при вида на враговете.","homepage":"","overview":"Филмът ни отвежда в далечния 12 век по времето на Кръстоносните походи. Балиан е ковач, който е изгубил семейството си и почти е загубил вярата си. Съдбата изправя на пътя му един велик рицар – Годфри, кръстоносец, завърнал се у дома след битка в Изтока. Годфри разкрива на Балиан, че е негов роден баща и му показва истинското значение на думата „рицар”. Двамата се отправят на пътешествие към светите места. В битка обаче Годфри е убит, а Балиан продължава към Иерусалим, за да се закълне във вярност към краля. Там той се влюбва в сестрата на краля Сибила, но така си спечелва смъртен враг - съпруга  ѝ."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":144,"tagline":"","homepage":"","overview":"Midt i det middelalderske Jerusalems pomp og prakt og intriger finner vi Balian, en ung franskmann som har mistet alt, men finner ære og frelse på en farlig ferd. Med elendige odds kjemper Balian mot en overlegen fiende for å redde folket sitt og leve opp til sin skjebne som en ekte ridder."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"","runtime":144,"tagline":"","homepage":"","overview":"Frankrig år 1186. Den unge franske smed Balian bliver opsøgt af ridderen Godfrey, der fortæller, at han er Balians far. Sammen tager de til Jerusalem, hvor Godfrey har fået et stort landområde af kongen af Jerusalem. Da Godfrey dør, overtager Balian området og tjener kongen af Jerusalem, men katastrofen lurer i horisonten, da kongen er syg, og stridigheder mellem korsridderne er ved at sprænge den spinkle våbenhvile, som de kristne har med den frygtede arabiske leder Saladin."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Το Βασίλειο των Ουρανών","runtime":144,"tagline":"Βγες χωρίς φόβο στο πρόσωπο των εχθρών σου. Προστάτεψε τους αβοήθητους και μην κάνεις λάθος.","homepage":"","overview":"Πίσω στο 1186 ο κόσμος είναι πολύ διαφορετικός από αυτόν που γνωρίζουμε σήμερα. Η «ιερή πόλη» Ιερουσαλήμ έχει καταληφθεί από τους Χριστιανούς από το 1099 με την πρώτη σταυροφορία. Η συνύπαρξη με τους πολυπληθέστερους Άραβες, μετά και την αποτυχημένη δεύτερη σταυροφορία είναι εύθραυστη. Το \"Λατινικό Βασίλειο της Ιερουσαλήμ\" διοικείται από τον άρρωστο βασιλιά Βαλδουίνο τον 4ο και τους συμβούλους του. Στην κρίσιμη αυτή περίοδο ο ιππότης Γοδεφρείγος του Ιμπελέν επιστρέφει στην πατρίδα του με μια ομάδα σταυροφόρων, για να στρατολογήσει νέους φιλόδοξους μαχητές για την υπεράσπιση των Αγίων Τόπων. Παράλληλα όμως αναζητά -και τελικά βρίσκει στη Γαλλία- το νόθο γιο του, τον Μπαλιάν ο οποίος έχει μόλις χάσει τη γυναίκα του. Ο Μπαλιάν, ανεπιθύμητος πλέον στο χωριό του, θα δεχτεί να ακολουθήσει τον πατέρα του πίσω στην ένδοξη Ιερή Πόλη."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"ממלכת גן עדן","runtime":0,"tagline":"","homepage":"","overview":"שלהי הממלכה הצלבנית הראשונה בארץ ישראל ונפילתה, דרך סיפורה של אחת הדמויות המרכזיות בתקופה.  באליאן הוא נפח פשוט בכפר נידח בצרפת, ששרוי באבל כבד לאחר מות בנו והתאבדות אשתו. גודפרי, אציל צלבני שחזר מארץ הקודש, מגלה לבאליאן שהוא אביו האמיתי, ומציע לו להצטרף אל הכוחות הצלבניים בארץ הקודש. לאחר התלבטות באליאן מחליט לצאת לירושלים, כדי לגאול את נשמתו המיוסרת.  בארץ הקודש שמו יוצא לפניו כאציל טוב לב לנתיניו, ואביר אמיץ הנאמן למלך ולשלום בין הצלבנים למוסלמים. שרשרת ארועים מציבה את באליאן בפני הכרעה הרת גורל, בין צו מצפונו כאדם לבין חובותיו למלך ולממלכה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"킹덤 오브 헤븐","runtime":137,"tagline":"리들리 스콧이 창조한 새로운 신화","homepage":"","overview":"전쟁으로 가족을 잃고 깊은 슬픔에 잠겨있는 프랑스의 젊은 대장장이 발리안에게 부상당한 십자군 기사 고프리가 찾아온다. 무언가 비밀을 품고 있는 듯한 그의 정체는 바로 발리안의 아버지. 발리안에게 숨겨진 전사의 자질을 꿰뚫어본 고프리는 자신과 함께 떠날 것을 제안하고, 발리안은 성스러운 도시를 지키기 위한 영예로운 여정을 시작한다. 발리안은 고프리로부터 여러 가지 검술과 전술 등을 배우며 용맹한 전사로 거듭난다. 그리고 고프리가 죽기 직전 수여한 작위를 받아 정식기사가 되어 성스러운 도시 예루살렘의 국왕 볼드윈 4세에 대한 충성을 서약하는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Cruzada","runtime":144,"tagline":"Não tenha medo diante de seus inimigos.  Proteja os indefesos e não faça nada errado.","homepage":"","overview":"Ainda em luto pela repentina morte de sua esposa, o ferreiro Balian junta-se ao seu distante pai, Baron Godfrey, nas cruzadas a caminho de Jerusalém. Após uma jornada muito difícil até à cidade santa, o jovem valente entra no séquito do rei leproso Balduíno IV, que deseja lutar contra os muçulmanos para seu próprio ganho político e pessoal."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Царство небесне","runtime":0,"tagline":"","homepage":"","overview":"У 1184 році Готфрид, барон Ібелінский, повертається на свої рідні землі в Південній Франції, щоб відшукати свого незаконнонародженого сина, якого ніколи не бачив. Готфрид знаходить його: це коваль Баліан, який тільки що пережив тяжке нещастя: його дружина наклала на себе руки після того, як їх дитина померла відразу після народження. Барон просить у сина вибачення і запрошує його йти за ним на Святу землю разом з його загоном хрестоносців."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Regatul Cerului","runtime":139,"tagline":"","homepage":"","overview":"Orlando Bloom îl interpretează pe Balian, un fierar care își pierde familia și e la un pas să-și piardă și credința. Războaiele religioase care au loc în Țara Făgăduinței, îi par îndepărtate, însă este atras în acea dramă imensă. În mijlocul fastului și intrigilor Ierusalimului medieval, el se îndrăgostește, devine un lider și, într-un final, își folosește tot curajul și abilitățile pentru a apăra orașul. Destinul îi bate la ușă lui Balian sub forma unui cavaler măreț, Godfrey of Ibelin, un cruciat ce s-a întors pentru scurt timp în Franța de la luptele din Est. Godfrey dezvăluie că e tatăl lui Balian și îi arată ce înseamnă cu adevărat să fii cavaler. Apoi, îl duce într-o călătorie peste continente, în legendarul Oraș Sfânt."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Debesu valstība","runtime":144,"tagline":"","homepage":"","overview":"Jaunais franču kalējs Balians ir spiests bēgt no savas dzimtenes un pievienoties krustnešu pulkam, kuru vada viņa tēvs. Drīz vien viņš iegūst bruņinieka titulu un stājas tēva vietā, kļūstot par prasmīgu karavadoni."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"キングダム・オブ・ヘブン","runtime":0,"tagline":"","homepage":"","overview":"12世紀。妻子を亡くして生きる目的を失ったフランスの鍛冶職人バリアンだが、彼の親と名乗り出たイベリンの領主、騎士ゴッドフリーに誘われ、ともにエルサレムへ出発。道中、ある事件で命を落としたゴッドフリーは騎士の称号をバリアンに譲り、エルサレムに平和と愛に満ちた国家を築くよう息子に託す。バリアンが若きエルサレム王ボードワン4世やその妹シビラ姫と出会う一方、キリスト教徒とイスラム教徒の対立は激化していく。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Dangaus karalystė","runtime":144,"tagline":"","homepage":"","overview":"Jaunas ginklakalys Balianas priverstas bėgti iš savo gimtinės. Jis prisideda prie kryžiuočių riterių būrio, kuriam vadovauja jo tėvas. Tačiau viename mūšyje tėvas sunkiai sužeidžiamas ir prieš mirtį spėja paskelbti savo sūnų riteriu. Šis prisiekia ištikimybę Jeruzalės karaliui. Balianas netrunka pagarsėti kaip narsus ir patyręs kovotojas. Išvaizdus ir garbingas jaunas vyras atkreipia karaliaus sesers gražuolės Sibilės dėmesį. Jis pelno nuostabios moters palankumą, tačiau įsigyja mirtiną priešą – juo tampa kilmingasis Gajus de Lusinjanas, Sibilės vyras, tamplierių ordino riterių vadas. Pavydo apakintas Gajus su savo negailestingais riteriais užpuola musulmonų karavaną, kurį ginti pavesta drąsiajam Balianui, ir taip išprovokuoja karą su šimtus kartų didesne galingojo Egipto valdovo Saladino kariuomene."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"王者天下","runtime":0,"tagline":"","homepage":"","overview":"奧蘭多布魯飾演貝里昂，一名失去家人和幾乎喪失信仰的鐵匠，在聖地發生的宗教大戰似乎距離他很遙遠，但他被命運逼入這個戲劇場景。他在中世紀神秘且複雜洶湧的耶路撒冷，陷入愛河，成為一名領袖，最後用全部的勇氣和高超技藝悍衛整個城市不被悲劇摧毀。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"El regne del cel","runtime":0,"tagline":"","homepage":"","overview":"El segle XII, en plena època de les Croades, el cavaller Godfrey d'Ibelin, compromès amb el manteniment de la pau a Terra Santa, emprèn la recerca de Balian, el seu fill il·legítim. Balian, que viu a França i treballa de ferrer, acaba de perdre la dona i el fill. Com que no té res a perdre, s'uneix a la missió del seu pare i marxa a Jerusalem. Un cop allà i després que Godfrey mor, Balian hereta la seva terra i el títol de cavaller i esdevindrà un heroi."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"天國驕雄","runtime":194,"tagline":"為愛 頂天立地 憑勇氣 成就傳奇","homepage":"","overview":"奧蘭多布魯飾演貝里昂，一名失去家人和幾乎喪失信仰的鐵匠，在聖地發生的宗教大戰似乎距離他很遙遠，但他被命運逼入這個戲劇場景。他在中世紀神秘且複雜洶湧的耶路撒冷，陷入愛河，成為一名領袖，最後用全部的勇氣和高超技藝悍衞整個城市不被悲劇摧毀。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Cruzada","runtime":0,"tagline":"Lucha por lo que crees.","homepage":"","overview":"Balian de Ibelin, un herrero francés se convierte en caballero durante las Cruzadas. En Tierra Santa, lucha por la paz y la justicia en medio del conflicto entre cristianos y musulmanes por el control de Jerusalén. Una historia épica de coraje, redención y sacrificio en medio del caos de la guerra."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Vương Quốc Thiên Đường","runtime":0,"tagline":"","homepage":"","overview":"Trận chiến vĩ đại thành Jerusalem trước quân đội của Vua Ai Cập Saladin được ghi vào lịch sử như một trận chiến của những người sùng đạo bảo vệ vương quốc thiên đàng linh thiêng của họ. Bộ phim các bạn sắp xem sẽ tái hiện lịch sử hùng tráng với những đại cảnh hành động ấn tượng của trận đại chiến lịch sử. Nhân vật chính là chàng thợ rèn Balian quả cảm, được số mệnh dẫn lối trở thành người lãnh đạo quân đội Jerusalem..."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"قلمرو بهشت","runtime":0,"tagline":"","homepage":"","overview":"قرن دوازدهم، بالیان (اورلاندو بلوم) در دوره جنگ‌های صلیبی به اورشلیم می رود، و در آنجا به تنها رهبر مردم برای دفاع از شهر، در برابر نیروهای صلاح الدین تبدیل میشود."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"مملكة الجَنَّة","runtime":0,"tagline":"كن دون خوف في مواجهة أعدائك. حماية الضعفاء، وتفعل أي خطأ","homepage":"","overview":"بعد وفاة زوجته ، انغمس حداد يُدعى باليان في الملوك والمؤامرات السياسية والحروب المقدسة الدموية خلال الحروب الصليبية."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"มหาศึกกู้แผ่นดิน","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Kraljevstvo nebesko","runtime":0,"tagline":"Nakon gubitka žene mladi kovač odlazi u Jeruzalem kako bi ponovno otkrio vjeru.","homepage":"","overview":"Srednjovjekovna Francuska 1184. godine. Markantni Balian (O. Bloom) mladi je kovač koji nakon tragične smrti djeteta i samoubojstva supruge dozna da je njegov pravi otac utjecajni križarski plemić Godfrey od Ibelina (L. Neeson). Prisiljen zbog ubojstva svećenika pobjeći, Balian se pridruži ocu te s njim krene na dugo putovanje prema Messini. Uči rukovati mačem i boriti se, te naposljetku primi i titulu križarskog viteza. Godfrey je u jednom sukobu smrtno ranjen, a posljednja mu je želja da Balian u pratnji njegova odanog pomoćnika Hospitalera (D. Thewlis) ode u Jeruzalem."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Le royaume des cieux","runtime":144,"tagline":"À genoux devant son roi. Debout devant l'ennemi.","homepage":"","overview":"Balian le forgeron découvre que son père est un seigneur Croisé, peu avant que celui-ci ne meure et que ses terres à Jérusalem ne lui reviennent. Parti sur place, il se range au côté des fidèles du roi Baudoin, qui tentent de maintenir un équilibre fragile entre les Croisés et les troupes de Saladin. Mais le roi est mourant et puissants sont ceux qui s'opposent à lui et à la paix."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Небеско краљевство","runtime":0,"tagline":"","homepage":"","overview":"Након што му жена умре, ковач по имену Балијан бива гурнут у племство, политичке интриге и крваве свете ратове током крсташких ратова."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Taevane kuningriik","runtime":0,"tagline":"","homepage":"","overview":"\"Taevane Kuningriik\" on eepiline seiklus tavalisest mehest (Orlando Bloom), kes leiab ennast paisatuna aastakümne pikkusesse sõtta. Võõrana, võõral maal teenib ta sealset kuningat, langeb keelatud armastusse kuningannaga ja tõuseb rüütelkonda. Ta peab kaitsma Jeruusalemma inimesi ülekaaluliste vägede eest, püüdes saavutada samal ajal ka rahu."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"ზეციური სამეფო","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"}],"reviews_tmdb":[{"id":"5baaa15492514150ff009293","url":"https://www.themoviedb.org/review/5baaa15492514150ff009293","author":"Wuchak","content":"$11","created_at":"2018-09-25T20:57:56.450Z","updated_at":"2021-06-23T15:58:12.812Z","author_details":{"name":"","rating":6,"username":"Wuchak","avatar_path":"/4KVM1VkqmXLOuwj1jjaSdxbvBDk.jpg"}},{"id":"65d4f3be1d3563017c1f9414","url":"https://www.themoviedb.org/review/65d4f3be1d3563017c1f9414","author":"BornKnight","content":"One of the most hated movies by Ridley Scott, that shows the difference of what versions and cuts can have on a movie. This movie have a Theatrical version (144 min.) a Director's Cut (189 min.) and Director's Cut Roadshow Version (194 min.) (that I watched years after watching  the theatrical on cinema). \r\n\r\nThe movie is loosely based on the story of Balian I of Ibelin (originally a noble of French or Italy, but portraited as his son in this movie and epoch) travels to Jerusalem during the Crusades of the 12th century, and there he finds himself as the defender of the city and its people.\r\n\r\nA tale of noble actions and ideals on the 2nd Crusade among equally noblesse and troubled people. It is not totally historically accurate (let's say 50%) but is one of the most impressive movies about the crusade with all the desert, sun and bloody scenes than you can imagine (and a fictional end).\r\n\r\nOriginally a 7.0 raised up to a 7.8 out of 10.0 in this version B+ (not sure if this is the version that Netflix have).","created_at":"2024-02-20T18:47:26.978Z","updated_at":"2024-02-20T18:47:27.120Z","author_details":{"name":"","rating":8,"username":"BornKnight","avatar_path":null}}],"recommendations":[{"id":1966,"adult":false,"title":"Alexander","video":false,"overview":"Alexander, the King of Macedonia, leads his legions against the giant Persian Empire. After defeating the Persians, he leads his army across the then known world, venturing farther than any westerner had ever gone, all the way to India.","genre_ids":[10752,36,28,12,18,10749],"media_type":"movie","popularity":4.4186,"vote_count":3451,"poster_path":"/jrwQu72sGwGqwE8Ijne89PSIvhp.jpg","release_date":"2004-11-21","vote_average":6,"backdrop_path":"/h21dxRjtR7xOhyZljtSYeTETCht.jpg","original_title":"Alexander","original_language":"en"},{"id":9477,"adult":false,"title":"King Arthur","video":false,"overview":"The story of the Arthurian legend, based on the 'Sarmatian hypothesis' which contends that the legend has a historical nucleus in the Sarmatian heavy cavalry troops stationed in Britain, and that the Roman-British military commander, Lucius Artorius Castus is the historical person behind the legend.","genre_ids":[12,10752,36,28,18],"media_type":"movie","popularity":3.7639,"vote_count":2873,"poster_path":"/iKLZEAnjzr51Ij7TJtNejc5CN3i.jpg","release_date":"2004-07-07","vote_average":6.297,"backdrop_path":"/zmtOyU6pE6PbyMJiNqiISMOIRS5.jpg","original_title":"King Arthur","original_language":"en"},{"id":20662,"adult":false,"title":"Robin Hood","video":false,"overview":"When soldier Robin happens upon the dying Robert of Loxley, he promises to return the man's sword to his family in Nottingham. There, he assumes Robert's identity; romances his widow, Marion; and draws the ire of the town's sheriff and King John's henchman, Godfrey.","genre_ids":[28,12,36],"media_type":"movie","popularity":4.646,"vote_count":4927,"poster_path":"/9NS5QGOfck24yL3bZqWeW06PgPC.jpg","release_date":"2010-05-12","vote_average":6.394,"backdrop_path":"/gOi18HJqiuOYoXMH4CgpFnTHgUJ.jpg","original_title":"Robin Hood","original_language":"en"},{"id":12113,"adult":false,"title":"Body of Lies","video":false,"overview":"The CIA’s hunt is on for the mastermind of a wave of terrorist attacks. Roger Ferris is the agency’s man on the ground, moving from place to place, scrambling to stay ahead of ever-shifting events. An eye in the sky – a satellite link – watches Ferris.  At the other end of that real-time link is the CIA’s Ed Hoffman, strategizing events from thousands of miles away. And as Ferris nears the target, he discovers trust can be just as dangerous as it is necessary for survival.","genre_ids":[28,18,53],"media_type":"movie","popularity":2.3941,"vote_count":3249,"poster_path":"/rNEZug6er0bIj9LVN2JaQig6oZy.jpg","release_date":"2008-10-09","vote_average":6.629,"backdrop_path":"/6ghc2ySuEnTW8h3YgZZufk2SOTv.jpg","original_title":"Body of Lies","original_language":"en"},{"id":3131,"adult":false,"title":"Gangs of New York","video":false,"overview":"In early 1860s New York, Irish immigrant Amsterdam Vallon is released from prison and returns to the Five Points, seeking revenge against his father's killer, William Cutting, a powerful anti-immigrant gang leader. He knows that revenge can only be attained by infiltrating Cutting's inner circle. Vallon's journey becomes a fight for personal survival and to find a place for the Irish people.","genre_ids":[18,36,80],"media_type":"movie","popularity":5.9404,"vote_count":7073,"poster_path":"/lemqKtcCuAano5aqrzxYiKC8kkn.jpg","release_date":"2002-12-14","vote_average":7.313,"backdrop_path":"/ykqSwE2vUrcocu4w9e99bxLBrXd.jpg","original_title":"Gangs of New York","original_language":"en"},{"id":52451,"adult":false,"title":"The Three Musketeers","video":false,"overview":"The hot-headed young D'Artagnan along with three former legendary but now down on their luck Musketeers must unite and defeat a beautiful double agent and her villainous employer from seizing the French throne and engulfing Europe in war.","genre_ids":[12,28,53],"media_type":"movie","popularity":4.9301,"vote_count":2741,"poster_path":"/woCADkkDIIKrOMEokbFOEsAYtUa.jpg","release_date":"2011-08-31","vote_average":5.802,"backdrop_path":"/gxInxrSdEDUA5J3DT2wTj9vQIXr.jpg","original_title":"The Three Musketeers","original_language":"en"},{"id":11184,"adult":false,"title":"Kinsey","video":false,"overview":"Kinsey is a portrait of researcher Alfred Kinsey, driven to uncover the most private secrets of a nation. What begins for Kinsey as a scientific endeavor soon takes on an intensely personal relevance, ultimately becoming an unexpected journey into the mystery of human behavior.","genre_ids":[18],"media_type":"movie","popularity":1.3785,"vote_count":506,"poster_path":"/cODCjWNRcZkwe4ONQs1GzRqYtRb.jpg","release_date":"2004-09-04","vote_average":6.607,"backdrop_path":"/yA7MG24LZCtQhsKXhqJ5TfbjFoI.jpg","original_title":"Kinsey","original_language":"en"},{"id":31169,"adult":false,"title":"The Courageous Heart of Irena Sendler","video":false,"overview":"Irena Sendler is a Catholic social worker who has sympathized with the Jews since her childhood, when her physician father died of typhus contracted while treating poor Jewish patients. When she initially proposes saving Jewish children from the Warsaw Ghetto, her idea is met with skepticism by fellow workers, her parish priest, and even her own mother Janina.","genre_ids":[18,10752],"media_type":"movie","popularity":0.8248,"vote_count":120,"poster_path":"/jfvvws0sCNbNNxY9llsBqmeERxv.jpg","release_date":"2009-04-19","vote_average":7.258,"backdrop_path":"/3pJ2BuyO8HpKFdVshE3rNkBlf4f.jpg","original_title":"The Courageous Heart of Irena Sendler","original_language":"en"},{"id":17080,"adult":false,"title":"Pistvakt","video":false,"overview":"Three middle aged brothers is living home in a Godforsaken skiing resort in the northernmost part of Sweden and sees their life change when their father dies, and the mother going off on a holiday to Spain.","genre_ids":[35],"media_type":"movie","popularity":0.1878,"vote_count":20,"poster_path":"/bxPLC78UuxEupYBaYExukKjnFus.jpg","release_date":"2005-10-07","vote_average":5.3,"backdrop_path":"/k6UxLbK1Ls3YPjAfUGLsCRNvcYy.jpg","original_title":"Pistvakt","original_language":"sv"},{"id":23759,"adult":false,"title":"Centurion","video":false,"overview":"Britain, A.D. 117. Quintus Dias, the sole survivor of a Pictish raid on a Roman frontier fort, marches north with General Virilus' legendary Ninth Legion, under orders to wipe the Picts from the face of the Earth and destroy their leader, Gorlacon.","genre_ids":[12,28,18],"media_type":"movie","popularity":3.8474,"vote_count":1530,"poster_path":"/9ZdfrcP2QCqoRSk7JF06tDWtrhP.jpg","release_date":"2010-02-15","vote_average":6.2,"backdrop_path":"/idcccRSENk7fv4aRMHo7BY6jHoo.jpg","original_title":"Centurion","original_language":"en"},{"id":205,"adult":false,"title":"Hotel Rwanda","video":false,"overview":"Inspired by true events, this film takes place in Rwanda in the 1990s when more than a million Tutsis were killed in a genocide that went mostly unnoticed by the rest of the world. Hotel owner Paul Rusesabagina houses over a thousand refuges in his hotel in attempt to save their lives.","genre_ids":[18,36,10752],"media_type":"movie","popularity":3.0368,"vote_count":3094,"poster_path":"/p3pHw85UMZPegfMZBA6dZ06yarm.jpg","release_date":"2004-12-22","vote_average":7.715,"backdrop_path":"/jkvvXaN7FPVKGlk8oj9PL0FHNtj.jpg","original_title":"Hotel Rwanda","original_language":"en"},{"id":1023,"adult":false,"title":"Adam's Apples","video":false,"overview":"A neo-nazi sentenced to community service at a church clashes with the blindly devotional priest.","genre_ids":[18,35,80],"media_type":"movie","popularity":1.6394,"vote_count":768,"poster_path":"/kBP0xOOaAT9rmJZGVxrolRk87AR.jpg","release_date":"2005-04-15","vote_average":7.452,"backdrop_path":"/iVnsOj0MtVE1lzfillNAPqCdhpR.jpg","original_title":"Adams æbler","original_language":"da"},{"id":2253,"adult":false,"title":"Valkyrie","video":false,"overview":"Wounded in Africa during World War II, Nazi Col. Claus von Stauffenberg returns to his native Germany and joins the Resistance in a daring plan to create a shadow government and assassinate Adolf Hitler. When events unfold so that he becomes a central player, he finds himself tasked with both leading the coup and personally killing the Führer.","genre_ids":[18,53,10752],"media_type":"movie","popularity":3.8364,"vote_count":3989,"poster_path":"/8eoRtXswC8IQDsqW7iJWO56NhAv.jpg","release_date":"2008-12-25","vote_average":6.95,"backdrop_path":"/6ypfd9wGd7bmtmukzbPZfcaCMsO.jpg","original_title":"Valkyrie","original_language":"en"},{"id":7270,"adult":false,"title":"Matchstick Men","video":false,"overview":"A phobic con artist and his protege are on the verge of pulling off a lucrative swindle when the con artist's teenage daughter arrives unexpectedly.","genre_ids":[35,18,80,53],"media_type":"movie","popularity":4.2123,"vote_count":1918,"post