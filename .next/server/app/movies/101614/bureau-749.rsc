MgjgDXMqbTJPXcbJz9y0Zq84.jpg","iso_639_1":"zh","vote_average":0.166},{"width":2000,"height":2719,"file_path":"/ajzbZyNWc2BbT3X6yUApL4B2uZP.jpg","iso_639_1":"zh","vote_average":0.166},{"width":2000,"height":3000,"file_path":"/fjJ0fD0xtjHMv06JGWVVKcAqAqN.jpg","iso_639_1":"zh","vote_average":0.166},{"width":1000,"height":1500,"file_path":"/flykCMw22y6yv8vKnBjmsW3pneo.jpg","iso_639_1":"en","vote_average":0},{"width":832,"height":1248,"file_path":"/epIjkKoEkmBYeQQ5WTn10WPspT.jpg","iso_639_1":null,"vote_average":0},{"width":2000,"height":3000,"file_path":"/uXQm8PKup6FxXkrd9kPyD2asCZs.jpg","iso_639_1":"es","vote_average":0},{"width":1333,"height":2000,"file_path":"/euBufDUJwqlmTRzXdP1DDyl1RNp.jpg","iso_639_1":"de","vote_average":0}],"backdrops":[{"width":2855,"height":1606,"file_path":"/lf8IZ86ajGpgbuyHCZrXUeAMmvy.jpg","iso_639_1":null,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/tQMlHruS4pU2PKLf9CgWwkFR399.jpg","iso_639_1":null,"vote_average":0},{"width":2876,"height":1618,"file_path":"/u25K9i2Bo8BMlZHrrnXNlPTft1G.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/3xChb12zcUb7jzd5k0ruEOK2eAS.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/hFZ5oQjZrpANm4J9lCJp4EnuME3.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T06:10:37.466+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":123,"tagline":"生而不同 敢为不同","homepage":"","overview":"　　电影《749局》是导演陆川编剧并执导的最新力作，讲述了一个少年成长冒险的热血故事。影片灵感源于导演陆川军校毕业后在749局的工作经历，有着悬疑紧张的冒险故事，热血澎湃的动作场面，少年成长的故事内核，以及浪漫的情节元素，并集结了一批国内演技出众的青年演员，是一部商业类型与情感元素并重的影片，也是他致敬自己少年和那一代人的一部少年气十足的作品。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"749 Bureau","runtime":0,"tagline":"","homepage":"","overview":"L’histoire d’un jeune homme qui est entraîné dans un mystérieux bureau de lutte contre le crime au moment même où une catastrophe est déclenchée par des créatures inconnues se propageant à travers le monde."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Bureau 749","runtime":123,"tagline":"","homepage":"","overview":"A traumatized young man with physical abnormalities is forced to join a mysterious bureau to confront a disaster spreading across the earth caused by an unknown creature. He embarks on an adventure uncovering mysteries about his life."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"749 局","runtime":0,"tagline":"","homepage":"","overview":"電影《749 局》是導演陸川編劇並執導的最新力作，講述了一個少年成長冒險的熱血故事。影片靈感源於導演陸川軍校畢業後在 749 局的工作經歷，有著懸疑緊張的冒險故事，熱血澎湃的動作場面，少年成長的故事內核，以及浪漫的情節元素，並集結了一批國內演技出眾的青年演員，是一部商業類型與情感元素並重的影片，也是他致敬自己少年和那一代人的一部少年氣十足的作品。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"749局","runtime":0,"tagline":"","homepage":"","overview":"故事發生在近未來，因為未知神秘生物的出現，導致整個城市面臨前所未有的危機。一樁被隱藏多年的秘密計畫浮出水面，少年馬山被帶入749局，進入層層迷宮，開啟一趟冒險之旅，並在這趟旅程中完成了一次自我的成長與救贖。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Cục 749","runtime":0,"tagline":"","homepage":"","overview":"Một chàng trai trẻ bị tổn thương với những bất thường về thể chất buộc phải gia nhập một văn phòng bí ẩn để đối mặt với thảm họa lan rộng khắp trái đất do một sinh vật vô danh gây ra. Anh dấn thân vào một cuộc phiêu lưu khám phá những bí ẩn về cuộc đời mình."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Бюро 749","runtime":0,"tagline":"","homepage":"","overview":"Недалекое будущее. На людей нападают неизвестно откуда взявшиеся жуткие чудовища, но, оказывается, на этот случай был разработан специальный план, державшийся в строжайшей тайне. Парень Ма Шань попадает в бюро 749, где готовят бойцов, которые будут сражаться с чудовищами."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Bureau 749","runtime":0,"tagline":"","homepage":"","overview":"En un futuro próximo, la Tierra enfrenta un desastre catastrófico causado por una criatura desconocida. Ma Shan, un joven marginado se une a la misteriosa Oficina 749 para enfrentar la crisis."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"oficina 749","runtime":0,"tagline":"atrévete a ser diferente","homepage":"","overview":"En un futuro próximo, la Tierra enfrenta un desastre catastrófico causado por una criatura desconocida. Ma Shan, un joven marginado se une a la misteriosa Oficina 749 para enfrentar la crisis."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Bureau 749","runtime":0,"tagline":"","homepage":"","overview":"Un tânăr traumatizat, marcat de anomalii fizice, este obligat să se alăture unui birou misterios pentru a înfrunta un dezastru care se răspândește pe Pământ, provocat de o creatură necunoscută. În această misiune, pornește într-o aventură în care începe să descopere mistere legate chiar de propria lui viață."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Traumatizovaný mladý muž s fyzickými abnormalitami je donucen vstoupit do tajemné organizace, aby čelil katastrofě, která se šíří po celé Zemi a je způsobena neznámým tvorem. Vydává se na dobrodružství, během kterého odhaluje tajemství svého života."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Secret Division 749","runtime":0,"tagline":"","homepage":"","overview":"Ein traumatisierter junger Mann mit körperlichen Fehlbildungen wird gezwungen, sich einer mysteriösen Behörde anzuschließen, um eine Katastrophe zu bekämpfen, die sich über die Erde ausbreitet und von einem unbekannten Wesen verursacht wird. Er begibt sich auf ein Abenteuer, das ihn die Geheimnisse seines Lebens aufdecken lässt."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Destruição Iminente","runtime":112,"tagline":"","homepage":"","overview":"Ao retornar, ele descobre que o Bureau pretende usá-lo como cobaia em testes perigosos. O objetivo é conter uma névoa misteriosa que está surgindo do subsolo e ameaçando a cidade de Hong Kong. No desenrolar da história, Ma Shan descobre uma conexão telepática com os alienígenas e se vê diante de um dilema moral: lidar com seu passado e sua humanidade ou usar seus dons para impedir uma catástrofe global."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"749국","runtime":0,"tagline":"","homepage":"","overview":"신체적 이상을 지닌 트라우마를 가진 청년이 미지의 생명체가 일으킨 지구 전역으로 퍼져가는 재앙에 맞서기 위해 신비한 기관에 강제 합류하게 된다. 그는 자신의 삶에 얽힌 수수께끼를 풀어나가는 모험을 시작한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"}],"reviews_tmdb":[],"recommendations":[{"id":1272440,"adult":false,"title":"Tiger Wolf Rabbit","video":false,"overview":"Three parents who have lost their children are involved with each other because of a deal; they have no soul in their eyes and hatred in their hearts, and each of them, with their own purposes, set out on the road of seeking revenge for their children, and staged a bizarre and dangerous killing in the barren land.","genre_ids":[18,80],"media_type":"movie","popularity":0.8348,"vote_count":16,"poster_path":"/9hFTG1bkdhJjiDRA6pfiYUB0YNP.jpg","release_date":"2024-10-01","vote_average":6.875,"backdrop_path":"/hx02n1Xe6DQGvgKZaA5FbG4d31y.jpg","original_title":"浴火之路","original_language":"zh"},{"id":19995,"adult":false,"title":"Avatar","video":false,"overview":"In the 22nd century, a paraplegic Marine is dispatched to the moon Pandora on a unique mission, but becomes torn between following orders and protecting an alien civilization.","genre_ids":[28,12,14,878],"media_type":"movie","popularity":37.3012,"vote_count":33495,"poster_path":"/gKY6q7SjCkAU6FqvqWybDYgUKIF.jpg","release_date":"2009-12-16","vote_average":7.6,"backdrop_path":"/vL5LR6WdxWPjLPFRLe133jXWsh5.jpg","original_title":"Avatar","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":22.369,"vote_count":11381,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":150540,"adult":false,"title":"Inside Out","video":false,"overview":"When 11-year-old Riley moves to a new city, her Emotions team up to help her through the transition. Joy, Fear, Anger, Disgust and Sadness work together, but when Joy and Sadness get lost, they must journey through unfamiliar places to get back home.","genre_ids":[16,10751,12,18,35],"media_type":"movie","popularity":15.6045,"vote_count":23184,"poster_path":"/2H1TmgdfNtsKlU9jKdeNyYL5y8T.jpg","release_date":"2015-06-17","vote_average":7.909,"backdrop_path":"/jJKZaTBNenlFclQyjrnvzkRmvWE.jpg","original_title":"Inside Out","original_language":"en"},{"id":9502,"adult":false,"title":"Kung Fu Panda","video":false,"overview":"Chosen by prophecy but doubted by all, Po is an unlikely Dragon Warrior—a clumsy panda thrust into the world of kung fu as a deadly enemy threatens the Valley of Peace. Guided by Master Shifu and the Furious Five, Po must embrace who he is to unlock the power that no scroll can teach.","genre_ids":[16,10751,35,28],"media_type":"movie","popularity":13.4344,"vote_count":12406,"poster_path":"/wWt4JYXTg5Wr3xBW2phBrMKgp3x.jpg","release_date":"2008-06-04","vote_average":7.315,"backdrop_path":"/qdthf9WrRDSaIkGVQGhhJ9pz1hn.jpg","original_title":"Kung Fu Panda","original_language":"en"},{"id":337401,"adult":false,"title":"Mulan","video":false,"overview":"When the Emperor of China issues a decree that one man per family must serve in the Imperial Chinese Army to defend the country from Huns, Hua Mulan, the eldest daughter of an honored warrior, steps in to take the place of her ailing father. She is spirited, determined and quick on her feet. Disguised as a man by the name of Hua Jun, she is tested every step of the way and must harness her innermost strength and embrace her true potential.","genre_ids":[12,14,28],"media_type":"movie","popularity":6.6237,"vote_count":6967,"poster_path":"/aKx1ARwG55zZ0GpRvU2WrGrCG9o.jpg","release_date":"2020-09-04","vote_average":6.837,"backdrop_path":"/zMrk2G3XsnfYKiIp1NEfdtvDyBH.jpg","original_title":"Mulan","original_language":"en"},{"id":767,"adult":false,"title":"Harry Potter and the Half-Blood Prince","video":false,"overview":"As Lord Voldemort tightens his grip on both the Muggle and wizarding worlds, Hogwarts is no longer a safe haven. Harry suspects perils may even lie within the castle, but Dumbledore is more intent upon preparing him for the final battle fast approaching. Together they work to find the key to unlock Voldemorts defenses and to this end, Dumbledore recruits his old friend and colleague Horace Slughorn, whom he believes holds crucial information. Even as the decisive showdown looms, romance blossoms for Harry, Ron, Hermione and their classmates. Love is in the air, but danger lies ahead and Hogwarts may never be the same again.","genre_ids":[12,14],"media_type":"movie","popularity":15.9292,"vote_count":20510,"poster_path":"/z7uo9zmQdQwU5ZJHFpv2Upl30i1.jpg","release_date":"2009-07-15","vote_average":7.681,"backdrop_path":"/ze6Mx4QE5mQVXRYmG2flncqqle4.jpg","original_title":"Harry Potter and the Half-Blood Prince","original_language":"en"},{"id":673,"adult":false,"title":"Harry Potter and the Prisoner of Azkaban","video":false,"overview":"Year three at Hogwarts means new fun and challenges as Harry learns the delicate art of approaching a Hippogriff, transforming shape-shifting Boggarts into hilarity and even turning back time. But the term also brings danger: soul-sucking Dementors hover over the school, an ally of the accursed He-Who-Cannot-Be-Named lurks within the castle walls, and fearsome wizard Sirius Black escapes Azkaban. And Harry will confront them all.","genre_ids":[12,14],"media_type":"movie","popularity":17.306,"vote_count":22856,"poster_path":"/aWxwnYoe8p2d2fcxOqtvAtJ72Rw.jpg","release_date":"2004-05-31","vote_average":8.009,"backdrop_path":"/vbk5CfaAHOjQPSAcYm6AoRRz2Af.jpg","original_title":"Harry Potter and the Prisoner of Azkaban","original_language":"en"},{"id":436969,"adult":false,"title":"The Suicide Squad","video":false,"overview":"Supervillains Harley Quinn, Bloodsport, Peacemaker and a collection of nutty cons at Belle Reve prison join the super-secret, super-shady Task Force X as they are dropped off at the remote, enemy-infused island of Corto Maltese.","genre_ids":[28,35,12],"media_type":"movie","popularity":12.3652,"vote_count":9398,"poster_path":"/q61qEyssk2ku3okWICKArlAdhBn.jpg","release_date":"2021-07-28","vote_average":7.468,"backdrop_path":"/jlGmlFOcfo8n5tURmhC7YVd4Iyy.jpg","original_title":"The Suicide Squad","original_language":"en"},{"id":508442,"adult":false,"title":"Soul","video":false,"overview":"Joe Gardner is a middle school teacher with a love for jazz music. After a successful audition at the Half Note Club, he suddenly gets into an accident that separates his soul from his body and is transported to the You Seminar, a center in which souls develop and gain passions before being transported to a newborn child. Joe must enlist help from the other souls-in-training, like 22, a soul who has spent eons in the You Seminar, in order to get back to Earth.","genre_ids":[16,10751,35,14,18,10402],"media_type":"movie","popularity":11.3593,"vote_count":11201,"poster_path":"/6jmppcaubzLF8wkXM36ganVISCo.jpg","release_date":"2020-12-25","vote_average":8.097,"backdrop_path":"/rQaHA74pevnGsxcKGaoZVGWe9TC.jpg","original_title":"Soul","original_language":"en"},{"id":566525,"adult":false,"title":"Shang-Chi and the Legend of the Ten Rings","video":false,"overview":"Shang-Chi must confront the past he thought he left behind when he is drawn into the web of the mysterious Ten Rings organization.","genre_ids":[28,12,14],"media_type":"movie","popularity":12.8124,"vote_count":10200,"poster_path":"/d08HqqeBQSwN8i8MEvpsZ8Cb438.jpg","release_date":"2021-09-01","vote_average":7.496,"backdrop_path":"/fJbWgOb9pSQXihM9m10bRvl2dJ8.jpg","original_title":"Shang-Chi and the Legend of the Ten Rings","original_language":"en"},{"id":264660,"adult":false,"title":"Ex Machina","video":false,"overview":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl.","genre_ids":[18,878],"media_type":"movie","popularity":8.5844,"vote_count":14039,"poster_path":"/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg","release_date":"2015-01-21","vote_average":7.573,"backdrop_path":"/uqOuJ50EtTj7kkDIXP8LCg7G45D.jpg","original_title":"Ex Machina","original_language":"en"},{"id":266856,"adult":false,"title":"The Theory of Everything","video":false,"overview":"The Theory of Everything is the extraordinary story of one of the world’s greatest living minds, the renowned astrophysicist Stephen Hawking, who falls deeply in love with fellow Cambridge student Jane Wilde.","genre_ids":[18,10749],"media_type":"movie","popularity":3.0983,"vote_count":10991,"poster_path":"/kJuL37NTE51zVP3eG5aGMyKAIlh.jpg","release_date":"2014-11-07","vote_average":7.835,"backdrop_path":"/ke3lanTAgCqPMpOyutIfXzYih2s.jpg","original_title":"The Theory of Everything","original_language":"en"},{"id":718930,"adult":false,"title":"Bullet Train","video":false,"overview":"Unlucky assassin Ladybug is determined to do his job peacefully after one too many gigs gone off the rails. Fate, however, may have other plans, as Ladybug's latest mission puts him on a collision course with lethal adversaries from around the globe—all with connected, yet conflicting, objectives—on the world's fastest train.","genre_ids":[28,35,53],"media_type":"movie","popularity":12.4624,"vote_count":7280,"poster_path":"/j8szC8OgrejDQjjMKSVXyaAjw3V.jpg","release_date":"2022-08-03","vote_average":7.413,"backdrop_path":"/y2Ca1neKke2mGPMaHzlCNDVZqsK.jpg","original_title":"Bullet Train","original_language":"en"},{"id":62764,"adult":false,"title":"Mirror Mirror","video":false,"overview":"After she spends all her money, an evil enchantress queen schemes to marry a handsome, wealthy prince. There's just one problem - he's in love with a beautiful princess, Snow White. Now, joined by seven rebellious dwarves, Snow White launches an epic battle of good vs. evil...","genre_ids":[12,35,10751,14],"media_type":"movie","popularity":3.4862,"vote_count":3252,"poster_path":"/4xiB9KTg6wCaA2OJw4pT44MJaau.jpg","release_date":"2012-03-15","vote_average":5.9,"backdrop_path":"/5YoGHani2oaNxRhFlqvnvoQsmBY.jpg","original_title":"Mirror Mirror","original_language":"en"},{"id":632357,"adult":false,"title":"The Unholy","video":false,"overview":"Alice is a young hearing-impaired girl who, after a supposed visitation from the Virgin Mary, is inexplicably able to hear, speak and heal the sick. As word spreads and people from near and far flock to witness her miracles, a disgraced journalist hoping to revive his career visits the small New England town to investigate. When terrifying events begin to happen all around, he starts to question if these phenomena are the works of the Virgin Mary or something much more sinister.","genre_ids":[27,9648],"media_type":"movie","popularity":2.6702,"vote_count":2238,"poster_path":"/bShgiEQoPnWdw4LBrYT5u18JF34.jpg","release_date":"2021-03-31","vote_average":6.561,"backdrop_path":"/wwFBRyekDcKXJwP0mImRJjAnudL.jpg","original_title":"The Unholy","original_language":"en"},{"id":565770,"adult":false,"title":"Blue Beetle","video":false,"overview":"Recent college grad Jaime Reyes returns home full of aspirations for his future, only to find that home is not quite as he left it. As he searches to find his purpose in the world, fate intervenes when Jaime unexpectedly finds himself in possession of an ancient relic of alien biotechnology: the Scarab.","genre_ids":[28,878,12],"media_type":"movie","popularity":6.1521,"vote_count":3023,"poster_path":"/mXLOHHc1Zeuwsl4xYKjKh2280oL.jpg","release_date":"2023-08-16","vote_average":6.647,"backdrop_path":"/3H9NA1KWEQN0ItL3Wl3SFZYP6yV.jpg","original_title":"Blue Beetle","original_language":"en"},{"id":337404,"adult":false,"title":"Cruella","video":false,"overview":"In 1970s London amidst the punk rock revolution, a young grifter named Estella is determined to make a name for herself with her designs. She befriends a pair of young thieves who appreciate her appetite for mischief, and together they are able to build a life for themselves on the London streets. One day, Estella’s flair for fashion catches the eye of the Baroness von Hellman, a fashion legend who is devastatingly chic and terrifyingly haute. But their relationship sets in motion a course of events and revelations that will cause Estella to embrace her wicked side and become the raucous, fashionable and revenge-bent Cruella.","genre_ids":[35,80,12],"med