9:{"metadata":[["$","title","0",{"children":"The Lord of the Rings: The Return of the King | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"As armies mass for a final battle that will decide the fate of the world--and powerful, ancient forces of Light and Dark compete to determine the outcome--one member of the Fellowship of the Ring is revealed as the noble heir to the throne of the Kings of Men. Yet, the sole hope for triumph over evil lies with a brave hobbit, Frodo, who, accompanied by his loyal friend Sam and the hideous, wretched Gollum, ventures deep into the very dark heart of Mordor on his seemingly impossible quest to destroy the Ring of Power.​"}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/100344/the-lord-of-the-rings-the-return-of-the-king"}],["$","meta","5",{"property":"og:title","content":"The Lord of the Rings: The Return of the King"}],["$","meta","6",{"property":"og:description","content":"As armies mass for a final battle that will decide the fate of the world--and powerful, ancient forces of Light and Dark compete to determine the outcome--one member of the Fellowship of the Ring is revealed as the noble heir to the throne of the Kings of Men. Yet, the sole hope for triumph over evil lies with a brave hobbit, Frodo, who, accompanied by his loyal friend Sam and the hideous, wretched Gollum, ventures deep into the very dark heart of Mordor on his seemingly impossible quest to destroy the Ring of Power.​"}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/100344/the-lord-of-the-rings-the-return-of-the-king"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/rCzpDGLbOoPwLjy3OAm5NUPOTrC.jpg"}],["$","meta","9",{"property":"og:type","content":"video.