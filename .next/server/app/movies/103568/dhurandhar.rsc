.334},{"width":2153,"height":1211,"file_path":"/4DfxcN4w0FuYZHQ3JAHzpHWia1U.jpg","iso_639_1":null,"vote_average":2.278},{"width":1599,"height":900,"file_path":"/t9hqmlzJyq4F9j70dAzEHuSfHpN.jpg","iso_639_1":null,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/3GGum7CC3Nof0XcoqozMbCKxFb9.jpg","iso_639_1":"en","vote_average":1.75},{"width":1920,"height":1080,"file_path":"/bByN0GAwcuBzWqn6JUO9fuFwI5F.jpg","iso_639_1":"hi","vote_average":1.444},{"width":2180,"height":1226,"file_path":"/yRYgvo2crAeHzqKwXMVtEaDx7Qq.jpg","iso_639_1":null,"vote_average":1.222},{"width":2171,"height":1221,"file_path":"/44vAkiq5KwVyQmP3GW9hqwUpJ1K.jpg","iso_639_1":null,"vote_average":0},{"width":2180,"height":1226,"file_path":"/kiEz0fvjqEI5QgH6j3PIAABR8Yv.jpg","iso_639_1":null,"vote_average":0},{"width":2003,"height":1127,"file_path":"/pA097xlFayEAOEZswdWeSwlg4b9.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T06:11:35.744+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Dhurandhar","runtime":212,"tagline":"","homepage":"","overview":"A mysterious traveler slips into the heart of Karachi's underbelly and rises through its ranks with lethal precision, only to tear the notorious ISI-Underworld nexus apart from within."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"Dhurandhar","runtime":212,"tagline":"","homepage":"","overview":"Dhurandhar spielt in der Welt des indischen Geheimdienstes und folgt einem Geheimagenten auf einer hochriskanten Mission, die auf historischen Ereignissen basiert. Der Film verbindet rasante Actionsequenzen, Shakespeare'sche Verratstaten und komplexe Spionagetechniken und konzentriert sich dabei auf das Leben unbekannter Männer."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"征服者","runtime":0,"tagline":"","homepage":"","overview":"2000年代初，一名卧底特务潜入喀拉蚩的黑社会，打进权力核心，只为从内部瓦解暴力网络。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"征服者","runtime":205,"tagline":"","homepage":"","overview":"2000年代初，一名卧底特务潜入喀拉蚩的黑社会，打进权力核心，只为从内部瓦解暴力网络。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Dhurandhar","runtime":0,"tagline":"","homepage":"","overview":"No início da década de 2000, um policial se infiltra nas gangues do submundo criminoso de Karachi para desmantelar um grupo violento."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Специалист","runtime":212,"tagline":"","homepage":"","overview":"Секретный агент Аджит Довал выполняет опасную миссию, связанную с геополитическими конфликтами."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"黑境行者","runtime":0,"tagline":"","homepage":"","overview":"2000年代初，一名卧底特务潜入喀拉蚩的黑社会，打进权力核心，只为从内部瓦解暴力网络。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Dhurandhar","runtime":212,"tagline":"","homepage":"","overview":"Un mystérieux voyageur s'infiltre au cœur des bas-fonds de Karachi et gravit les échelons avec une précision mortelle, dans le seul but de détruire de l'intérieur le célèbre réseau ISI-Underworld."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Dhurandhar","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"ปฏิบัติการกล้าสนั่นเมือง","runtime":0,"tagline":"","homepage":"","overview":"ในช่วงต้นทศวรรษ 2000 เจ้าหน้าที่นอกเครื่องแบบแฝงตัวเข้าไปในโลกใต้ดินของเมืองการาจี และแทรกซึมเข้าไปในกลุ่มแกนนำ เพื่อทำลายเครือข่ายอาชญากรรมที่โหดร้ายจากภายใน"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Patriotismo","runtime":0,"tagline":"","homepage":"","overview":"En la India, el inframundo criminal se despliega con toda su crudeza. Entre traiciones al estilo shakesperiano y complejas operaciones de espionaje, el patriotismo se pone a prueba hasta el límite."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Дхурандхар","runtime":0,"tagline":"","homepage":"","overview":"В началото на 2000-те, индийски агент под прикритие се инфилтрира в подземния свят на Карачи, прониквайки във вътрешния му кръг, за да разбие насилствената мрежа отвътре."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"1999-ben az IC-814-es gép eltérítése és a 2001-es parlamenti támadás után Ajay Sanyal, az indiai hírszerzési hivatal vezetője egy elháríthatatlan küldetést tervezett a pakisztáni terrorhálózat megsértésére és megbénítására. A terv része volt a beépülés a karacsi alvilági maffiába. Sanyal egy 20 éves pandzsábi fiút választott ki a feladatra, akit bosszúból elkövetett bűncselekményért tartottak fogva."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"دوراندر","runtime":0,"tagline":"","homepage":"","overview":"مسافری مرموز به اعماق دنیای زیرزمینی کراچی نفوذ می‌کند و با دقتی مرگبار پله‌پله در سلسله مراتب آن بالا می‌رود؛ اما در نهایت از درون، پیوند بدنام میان سازمان اطلاعاتی آی‌اس‌آی و مافیای زیرزمینی را از هم می‌پاشد."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"قوي البنية","runtime":0,"tagline":"","homepage":"","overview":"في مطلع الألفية الجديدة، يتسلل عميل متخفٍّ إلى عالم الجريمة في \"كراتشي\"، مخترقًا دوائر العصابات المتناحرة فيه للإطاحة بشبكة وحشية من الداخل."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"தமிழ்","iso_639_1":"ta","iso_3166_1":"IN","english_name":"Tamil"},{"data":{"title":"قوي البنية","runtime":214,"tagline":"","homepage":"","overview":"تدور احداث الفيلم في مطلع الألفية الجديدة يتسلل عميل متخف إلى عالم الجريمة في كراتشي مخترقا دوائر العصابات المتناحرة فيه للإطاحة بشبكة وحشية من الداخل."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"두란다르","runtime":0,"tagline":"","homepage":"","overview":"1999년 12월 30일, 인도 외무부 장관 데바브라트 카푸르와 정보국의 국장인 아제이 산얄(M. 마다반)은 인도 항공기를 납치한 테러범인 자후르 미스트리와 협상을 벌여 세 명의 테러범들을 석방하고 칸다하르에 억류된 승객들의 목숨을 대가로 1천만 달러의 몸값을 지불한다.\r R&AW의 특별 비서관 K.S. 불라르는 파키스탄의 테러 조직에 침투하자는 산얄의 제안을 거부하지만, 장관인 데바브라트는 2001년 인도 의회의 공격 이후 산얄의 비밀 작전인 \"두란다르 작전\"을 승인하게 되는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"}],"reviews_tmdb":[{"id":"693a96ba71b6ceb822cdf232","url":"https://www.themoviedb.org/review/693a96ba71b6ceb822cdf232","author":"solstafir7","content":"I liked Dhurandhar.\r\n\r\nIt's not phenomenal or so, but definitely not a lot to complain about. It is a testosterone trip to an extent, but I'm not complaining. Those who are complaining are not really the target audience, it seems.\r\n\r\nTowards the end, there are some risky bets and plot armour, but it's a film, not a documentary. It could have benefited from a somewhat better runtime. 3.5 hrs is long. It dials up the violence meter for mainstream Bollywood, but nothing too shocking and not too much of it either.\r\n\r\nRanveer is actually more vulnerable, more grounded, except when he's not. Then he's just Tommy Vercetty. Given that Aditya is just 42, I do see early GTA could be part of his college years.","created_at":"2025-12-11T10:02:34.531Z","updated_at":"2025-12-11T15:22:49.618Z","author_details":{"name":"","rating":7,"username":"solstafir7","avatar_path":null}}],"recommendations":[],"similar_content":[{"id":1451134,"adult":false,"title":"The Coder","video":false,"overview":"In the midst of a catastrophic software crisis at a crypto startup, CTO Mary must race against time to save her company — and her sanity.","genre_ids":[53],"popularity":0.1487,"vote_count":0,"poster_path":"/oxV1KhTq0yfxdDXtOzBCqPNWyLV.jpg","release_date":"2024-12-07","vote_average":0,"backdrop_path":null,"original_title":"The Coder","original_language":"en"},{"id":1451516,"adult":false,"title":"Secret Dinner","video":false,"overview":"Four friends drowning in debt come up with an unusual solution: hosting a secret dinner through JantarSecreto.com. But a poorly planned joke turns into a nightmarish reality when a forbidden menu attracts guests willing to go to extreme lengths. Trapped in a spiral of macabre decisions, they soon realize just how far they’re willing to go to survive.","genre_ids":[53,27,80,35],"popularity":0.221,"vote_count":1,"poster_path":"/3MGs9wF0ZOZcD0080iu9C8qCfWS.jpg","release_date":"2024-12-16","vote_average":10,"backdrop_path":null,"original_title":"Jantar Secreto","original_language":"pt"},{"id":10083,"adult":false,"title":"No Way Out","video":false,"overview":"Navy Lt. Tom Farrell meets a young woman, Susan Atwell , and they share a passionate fling. Farrell then finds out that his superior, Defense Secretary David Brice, is also romantically involved with Atwell. When the young woman turns up dead, Farrell is put in charge of the murder investigation. He begins to uncover shocking clues about the case, but when details of his encounter with Susan surface, he becomes a suspect as well.","genre_ids":[53,18],"popularity":2.7709,"vote_count":781,"poster_path":"/93CzsBvRhg035yvQosRtSsTL19v.jpg","release_date":"1987-08-14","vote_average":6.86,"backdrop_path":"/9F6zZuETJWUtkcSEnOc0JLqBHAK.jpg","original_title":"No Way Out","original_language":"en"},{"id":10090,"adult":false,"title":"Reno 911!: Miami","video":false,"overview":"A rag-tag team of Reno cops are called in to save the day after a terrorist attack disrupts a national police convention in Miami Beach during spring break. Based on the Comedy Central series.","genre_ids":[28,35,80],"popularity":0.9275,"vote_count":265,"poster_path":"/l9v3nqTU4Gj2zuASGDLJX4YD8ma.jpg","release_date":"2007-02-23","vote_average":5.775,"backdrop_path":"/tNCBhUrlskXHvp7JozWUmVKeuP0.jpg","original_title":"Reno 911!: Miami","original_language":"en"},{"id":1259540,"adult":false,"title":"I Have Sinned","video":false,"overview":"Pablo confesses a crime to Anders, who has a hidden agenda.","genre_ids":[53,18,35],"popularity":0.3075,"vote_count":1,"poster_path":"/9MBlw9Y9lUAOEmpwKtevCcrVsUL.jpg","release_date":"2023-12-28","vote_average":6,"backdrop_path":"/i0rFqnhRdy11qDFhpIojbvcAO8S.jpg","original_title":"Jag har syndat","original_language":"sv"},{"id":661950,"adult":false,"title":"Alone","video":false,"overview":"When an outbreak hits, Aidan barricades himself inside his apartment and starts rationing food. His complex is overrun by infected Screamers, and with the world falling apart into chaos, he is left completely alone fighting for his life.","genre_ids":[27,53],"popularity":1.2463,"vote_count":199,"poster_path":"/lkXD1W3pC64KXfZjHhHydd7DvNy.jpg","release_date":"2020-10-23","vote_average":5.9,"backdrop_path":"/E4LyJkTj66ourla5lD3Oal9imh.jpg","original_title":"Alone","original_language":"en"},{"id":10355,"adult":false,"title":"Shiri","video":false,"overview":"North Korea's 8th Special Forces hijack a shipment of CTX, a potent new liquid explosive, and threatens South Korea as part of a plot to re-unify the two countries. Ryu and Lee, special agents of O.P.,  South Korea's secret intelligence service, attempt to track down the terrorists and find the CTX. Meanwhile Hee, the 8th's ultra-bad female sniper, resurfaces to wreak havoc and haunt Ryu.","genre_ids":[28,12,18,53],"popularity":1.3481,"vote_count":182,"poster_path":"/7rmye0ThMHMT2VhZj7zdyCcHQVe.jpg","release_date":"1999-02-13","vote_average":6.42,"backdrop_path":"/kwZvgDGG0gZdhOuV0fjEm32PYep.jpg","original_title":"쉬리","original_language":"ko"},{"id":10370,"adult":false,"title":"Premutos: The Fallen Angel","video":false,"overview":"Premutos is the first of the fallen Angels, even before Lucifer. His Goal is to rule the world, the living and the dead. His son should pave the way for him and appears arbitrary throughout human history and is then recognized as some kind of monster. In the present time, a young man living in Germany begins to suffer from visionary flashbacks - of the lives he lived in the past as Premutos' son! He remembers how he appeared in the middle age, when mankind suffered from pestilence and during WWII in Russia. On his (earthly) father's birthday, a case containing some strange old book and a yellow potion is found in their garden, which was hidden by some peasant in 1943, who experimented with witchery in order to re-animate his deceased wife. Whe the young man gets in touch with the book and some of the yellow potion, he mutates into a monster and awakens an army of zombies, ready to bring back the fallen Angel Premutos and to disturb the little birthday party","genre_ids":[27,35,28],"popularity":0.312,"vote_count":38,"poster_path":"/1KzZKWIGKS30GvtX88BpCPzcWAJ.jpg","release_date":"1997-03-24","vote_average":5.1,"backdrop_path":"/kN2I71yfFRuE8UX7JOelo8jmHX4.jpg","original_title":"Premutos - Der gefallene Engel","original_language":"de"},{"id":10281,"adult":false,"title":"Friday the 13th Part VII: The New Blood","video":false,"overview":"Tina Shepard, a telekinetic teenage girl, accidentally unchains Jason from his watery grave, allowing him to go on another killing spree in the area.","genre_ids":[27,53],"popularity":2.1823,"vote_count":1180,"poster_path":"/rUzk9Qnyz2FZGxHMBrq6DYIQZkO.jpg","release_date":"1988-05-13","vote_average":5.5,"backdrop_path":"/roHX6N0VkySKBlramHUw1zdMQHB.jpg","original_title":"Friday the 13th Part VII: The New Blood","original_language":"en"},{"id":10303,"adult":false,"title":"The Jewel of the Nile","video":false,"overview":"Joan Wilder is thrust back into a world of murder, chases, foreign intrigue... and love. This time out she's duped by a duplicitous Arab dignitary who brings her to the Middle East, ostensibly to write a book about his life. Of course, he's up to no good, and Joan is just another pawn in his wicked game. But Jack Colton and his sidekick Ralph show up to help our intrepid heroine save the day.","genre_ids":[12,28,35,10749],"popularity":2.5112,"vote_count":1243,"poster_path":"/6VjsIhnIcrz2XdQVHdsMj5DdSa1.jpg","release_date":"1985-08-01","vote_average":6.209,"backdrop_path":"/7Crr6NUGAhfLM2ybjcq1dtN8YUl.jpg","original_title":"The Jewel of the Nile","original_language":"en"},{"id":10160,"adult":false,"title":"A Nightmare on Elm Street: The Dream Child","video":false,"overview":"The pregnant Alice finds Freddy Krueger striking through the sleeping mind of her unborn child, hoping to be reborn into the real world.","genre_ids":[27,53],"popularity":3.5318,"vote_count":1392,"poster_path":"/kizvpgXQfrAgN8FhOd87LbKk6kO.jpg","release_date":"1989-08-11","vote_average":5.4,"backdrop_path":"/mYsUWQoOYme8T6OELieOuHM08PH.jpg","original_title":"A Nightmare on Elm Street: The Dream Child","original_language":"en"},{"id":10167,"adult":false,"title":"Half Past Dead","video":false,"overview":"A man goes undercover in a hi-tech prison to find out information to help prosecute those who killed his wife. While there, he stumbles onto a plot involving a death-row inmate and his $200 million stash of gold.","genre_ids":[80,28,53],"popularity":1.4004,"vote_count":381,"poster_path":"/fJhudecoqyoZLoCwAZvqNPd7MK5.jpg","release_date":"2002-11-15","vote_average":5.1,"backdrop_path":"/kn2DrfbjYWyNAXlYjCIhQPOTEYd.jpg","original_title":"Half Past Dead","original_language":"en"},{"id":662025,"adult":false,"title":"Eudaimonia","video":false,"overview":"One night Leonardo, a young concierge working in a suburban hotel, receives a visit from a mysterious couple looking for a place to stay. The boy will soon discover that love can hide a dark side.","genre_ids":[53,9648],"popularity":0.3877,"vote_count":1,"poster_path":"/10iSaxVszJ8jzBm0TMv06AqLBQ.jpg","release_date":"2018-07-05","vote_average":5,"backdrop_path":"/5zj9853Pi4KWVB2TJt0wtxHe5zv.jpg","original_title":"Eudaimonia","original_language":"it"},{"id":10226,"adult":false,"title":"High Tension","video":false,"overview":"Best friends Marie and Alexia decide to spend a quiet weekend at Alexia's parents' secluded farmhouse. But on the night of their arrival, the girls' idyllic getaway turns into an endless night of horror.","genre_ids":[27,53,9648],"popularity":4.4644,"vote_count":1430,"poster_path":"/vKeFa7CqSxmWsQDjHP6SJXKoDbj.jpg","release_date":"2003-06-18","vote_average":6.8,"backdrop_path":"/ecn4qv1SzQaZ8jMyPPs307UqKxa.jpg","original_title":"Haute tension","original_language":"fr"},{"id":278632,"adult":false,"title":"Julia","video":false,"overview":"After suffering a brutal trauma, Julia uses an unorthodox form of therapy to restore herself.","genre_ids":[53,27],"popularity":0.4782,"vote_count":79,"poster_path":"/56W0KP6xEpvAjVf3Ofc0yyhfuNk.jpg","release_date":"2015-01-03","vote_average":4.842,"backdrop_path":"/t6izyY62fQei8QTtSeDFaPG2haO.jpg","original_title":"Julia","original_language":"en"},{"id":10359,"adult":false,"title":"Resurrection","video":false,"overview":"A jaded homicide detective has been put on the case of a ruthless killer in the city of Chicago, who leaves a trail of horribly mutilated and dismembered corpses along with perversely ironic biblical quotes.","genre_ids":[80,9648,27],"popularity":1.0205,"vote_count":300,"poster_path":"/2j6cMHN1Mx1u8S897VVhO7wSrce.jpg","release_date":"1999-06-05","vote_average":6.113,"backdrop_path":"/deqB89VLPy9WJzGrb51tU1DyuhN.jpg","original_title":"Resurrection","original_language":"en"},{"id":471317,"adult":false,"title":"One Less God","video":false,"overview":"In 2008, a band of young Islamic militants from Pakistan lands in Mumbai, their primary target, the iconic Taj Mahal hotel. With Indian forces unable to regain control, for 4 days the guests must battle to survive as the terrorists seek to drive them from hiding. The harrowing events that follow will come to be known as India's 9/11 and one of the most audacious terrorist attacks in history. Yet more than a tale of monsters and men, this is a story of our shared humanity at the dark crossroads to which we have now stumbled. Inspired by true events.","genre_ids":[80,28,18,53],"popularity":0.1871,"vote_count":13,"poster_path":"/zdRBRzaU8YgrKQxPwGkAU1qaRkh.jpg","release_date":"2017-10-06","vote_average":6.154,"backdrop_path":"/vFb6Ot5iR5454vNB5duNoCdcA55.jpg","original_title":"One Less God","original_language":"en"},{"id":1460572,"adult":false,"title":"Blessed: Live, Laugh,Run!","video":false,"overview":"When Ashley, a poor college student, takes a nanny job in rural Indiana, she's kidnapped by a family forcing young women to bear children. Nomi, a survivor of assault seeking an abortion, unknowingly steps into the same family's trap.","genre_ids":[27,53],"popularity":0.4446,"vote_count":0,"poster_path":"/zaMgsbXT66MkAulxuINyXwdqZz8.jpg","release_date":"2026-01-14","vote_average":0,"backdrop_path":"/xLOTS1Jdn9KRcBdJuSI67KHt9rk.jpg","original_title":"Blessed: Live, Laugh,Run!","original_language":"en"},{"id":279087,"adult":false,"title":"Specter","video":false,"overview":"The town of Midground is threatened by a tsunami caused by a massive earthquake in the North Pacific Ocean. After other unexplainable events transpire, Chase Lombardi and friends are forced to discover whether they are experiencing a natural phenomenon or something else all together.","genre_ids":[53,27,878],"popularity":1.4292,"vote_count":10,"poster_path":"/je0498EYKg39euyvu0ZvRmD8jhk.jpg","release_date":"2014-09-09","vote_average":3.6,"backdrop_path":"/u5qbQIk9SxvVFz3hiBGbbvJnT59.jpg","original_title":"Specter","original_language":"en"},{"id":10629,"adult":false,"title":"Veronica Guerin","video":false,"overview":"In this true story, Veronica Guerin is an investigative reporter for an Irish newspaper. As the drug trade begins to bleed into the mainstream, Guerin decides to take on and expose those responsible. Beginning at the bottom with addicts, Guerin then gets in touch with John Traynor, a paranoid informant. Not without some prodding, Traynor leads her to John Gilligan, the ruthless head of the operation, who does not take kindly to Guerin's nosing.","genre_ids":[18,80,53],"popularity":3.5731,"vote_count":327,"poster_path":"/1aJYz1YjcZggKsTJhCcYJ3adtcm.jpg","release_date":"2003-07-11","vote_average":6.7,"backdrop_path":"/pku59jhFJGLqrFIP0m1ITyqfQcB.jpg","original_title":"Veronica Guerin","original_language":"en"}],"external_ids":{"imdb_id":"tt33014583","twitter_id":null,"facebook_id":null,"wikidata_id":"Q135230927","instagram_id":null,"rotten_tomatoes_id":"m/dhurandhar"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":103568,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AU","release_dates":[{"note":"","type":2,"iso_639_1":"hi","descriptors":[],"release_date":"2025-12-05T00:00:00.000Z","certification":"R 18+"}]},{"iso_3166_1":"AW","release_dates":[{"note":"","type":2,"iso_639_1":"","descriptors":[],"release_date":"2025-12-05T00:00:00.000Z","certification":""}]},{"iso_3166_1":"CA","release_dates":[{"note":"","type":2,"iso_639_1":"hi","descriptors":[],"release_date":"2025-12-05T00:00:00.000Z","certification":"18A"}]},{"iso_3166_1":"DE","release_dates":[{"note":"","type":2,"iso_639_1":"hi","descriptors":[],"release_date":"2025-12-05T00:00:00.000Z","certification":"18"}]},{"iso_3166_1":"FR","release_dates":[{"note":"","type":2,"iso_639_1":"","descriptors":[],"release_date":"2025-12-05T00:00:00.000Z","certification":"18"}]},{"iso_3166_1":"GB","release_dates":[{"note":"","type":2,"iso_639_1":"hi","descriptors":