5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Homo Argentum\",\"description\":\"The film consists of 16 shorts that explore, with humor and social criticism, the characteristics of the Argentine identity.\",\"image\":\"https://image.tmdb.org/t/p/w500/21WlZtv1GZgiD2qAVHOkg63LRmU.jpg\",\"datePublished\":\"2025-08-14\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"AR\",\"inLanguage\":\"es\",\"genre\":[\"Comedy\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.6,\"bestRating\":10,\"ratingCount\":63}}"}}],["$","$L10",null,{"initialDrama":{"id":"63cbcdbf-c186-4809-b6b9-b538d6ebe3fb","tmdb_id":1471345,"imdb_id":"tt34996428","content_type":"movie","title":"Homo Argentum","original_title":"Homo Argentum","overview":"The film consists of 16 shorts that explore, with humor and social criticism, the characteristics of the Argentine identity.","poster_path":"/21WlZtv1GZgiD2qAVHOkg63LRmU.jpg","backdrop_path":"/2fwoBrUYMK0PZVaFqesx2CoRF6H.jpg","release_date":"2025-08-14","first_air_date":null,"status":"published","original_language":"es","origin_country":["AR"],"genres":[{"id":35,"name":"Comedy"},"anthology"],"popularity":5.1605,"vote_average":5.6,"vote_count":63,"runtime":98,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-25T23:36:59.986592+00:00","updated_at":"2026-02-25T23:36:59.804+00:00","tagline":null,"homepage":null,"budget":0,"revenue":16870,"production_companies":[{"id":22031,"name":"Televisión Abierta","logo_path":null,"origin_country":"AR"},{"id":167704,"name":"Star Original Productions","logo_path":"/eVTzWqrkdybUTGGBFl3gTq0NlRm.png","origin_country":""},{"id":34259,"name":"Pampa Films","logo_path":"/qUcQmkCRJA3jjxqZBlJybWRmTsI.png","origin_country":"AR"},{"id":6458,"name":"INCAA","logo_path":"/eT4oMUK7ODM0vvZue8yq3Ojwqf8.png","origin_country":"AR"},{"id":58393,"name":"Gloriamundi Producciones","logo_path":"