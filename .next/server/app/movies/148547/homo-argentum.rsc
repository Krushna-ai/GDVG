"aspect_ratio":0.674,"vote_average":1.222},{"width":593,"height":824,"file_path":"/j7ecdUdWaFQjfyXMuJdYWRwXhmU.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":1,"aspect_ratio":0.72,"vote_average":0.166},{"width":593,"height":824,"file_path":"/qMUWt6t97bLNR2A1FnoonpsmLI3.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.72,"vote_average":0},{"width":593,"height":824,"file_path":"/7WtOgW25a1QHWBUeNo8JPWjAqqy.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.72,"vote_average":0},{"width":1000,"height":1500,"file_path":"/2e42S3YdogOioFVhHJrQdAinmTN.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1362,"height":2000,"file_path":"/9VwlKIa7JnUuiASDUx49maHsPIn.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":0.681,"vote_average":0},{"width":1240,"height":1772,"file_path":"/muhQrfX6j8PpQOI5r1tZQCFV1od.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.7,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/2fwoBrUYMK0PZVaFqesx2CoRF6H.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/sX49tzlvB36YyKQYyuAL272lWXz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1290,"height":726,"file_path":"/5BOAj1c5WoRRyKtLwHQlvmucXDA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.777,"vote_average":0.166},{"width":2160,"height":1215,"file_path":"/mHt5tbIg4YiNPvv1C4crQNtvZ0D.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/foNyL3kav5NxPCy5muFaoASOfUr.jpg","iso_639_1":"es","iso_3166_1":"MX","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:42:12.673+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":98,"tagline":"","homepage":"","overview":"La película consta de 16 mini películas que exploran, con humor y critica social, las características de la identidad argentina."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Homo Argentum","runtime":98,"tagline":"","homepage":"","overview":"The film consists of 16 shorts that explore, with humor and social criticism, the characteristics of the Argentine identity."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":110,"tagline":"","homepage":"","overview":"El film está compuesto por 16 mini películas cuya duración varía entre 1 y 12 minutos, todas protagonizadas por Guillermo Francella en muy diferentes roles. Cada una es autónoma, pero la suma de todas ellas construye una reflexión sobre el presente en tono de comedia, con una aguda crítica social."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Homo Argentum","runtime":110,"tagline":"","homepage":"","overview":"Film składa się z 16 minifilmów, z których każdy trwa od jednej do dwunastu minut. W każdym z nich Guillermo Francella wciela się w bardzo odmienne role. Każdy z nich jest osobnym dziełem, ale suma wszystkich tworzy komediową refleksję na temat współczesności, z ostrą krytyką społeczną."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Homo Sapiens?","runtime":98,"tagline":"","homepage":"","overview":"«Noi raccontiamo le contraddizioni, i desideri, le frustrazioni, le emergenze, la paranoia e gli egoismi generati dalla nostra vita sociale che, se portati alla luce, aprono profondi dilemmi morali». Così descrivono il loro nuovo film Mariano Cohn e Gastón Duprat, gli autori di Il cittadino illustre, Il mio capolavoro e Finale a sorpresa, che questa volta raccontano a tutto tondo l’uomo argentino (o meglio, l’uomo porteño, l’argentino di città, quello che vive soprattutto a Buenos Aires). Ironia sulfurea, battute, gag che non risparmiano nessuno per i sedici personaggi incarnati da Guillermo Francella, notissima star argentina interprete di Il mio capolavoro e Il clan di Pablo Trapero. Ricchi e accattoni, vanitosi e umili, arroganti e timidi: non si salva nessuno dalla satira che ricorda i celeberrimi “mostri” della commedia all’italiana a episodi."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":98,"tagline":"","homepage":"","overview":"Comédia argentina que reúne 16 histórias curtas e independentes protagonizadas por Guillermo Francella. A obra usa humor e ironia para fazer uma crítica social à realidade argentina, explorando aspectos da cultura nacional, como hipocrisia, dependência familiar, violência e desencanto."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Аргентинец","runtime":0,"tagline":"","homepage":"","overview":"История о жителях большого города, чьи поступки и убеждения вступают в противоречие с реальностью повседневной жизни."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"}],"reviews_tmdb":[],"recommendations":[{"id":1193155,"adult":false,"title":"XMAS","video":false,"overview":"A  young woman finds herself in a fight for survival against an evil maniac with an unlikely motive.","genre_ids":[27,18],"media_type":"movie","popularity":0.1363,"vote_count":12,"poster_path":"/aCM4XviJp8WrAtGQWFQdIFf80Dc.jpg","release_date":"2023-12-23","vote_average":7.667,"backdrop_path":"/bI5xaCf3yt1kJiEsDebSIHo2wXW.jpg","original_title":"XMAS","original_language":"en"},{"id":1099088,"adult":false,"title":"Rewind 2: 1996","video":false,"overview":"When Marty's car is stolen, he sets out on a mission to find it; however, he soon realizes that the person who stole it is much more dangerous than he thinks.","genre_ids":[27,35],"media_type":"movie","popularity":0.1715,"vote_count":13,"poster_path":"/6OaIG3MlMjdDuOrnHQ1bsiUGNFa.jpg","release_date":"2022-12-23","vote_average":3.538,"backdrop_path":"/2dvJYzfe7ZKcPbJKX9W6afuSOaI.jpg","original_title":"Rewind 2: 1996","original_language":"en"},{"id":294601,"adult":false,"title":"Turma da Mônica em Cine Gibi 7: Bagunça Animal","video":false,"overview":"Trying to escape his bath, Monicão ends up hiding in the movie theater. Mônica can't find her pet in the dark, so she asks Franjinha to play some short films that might lure the dog out of hiding.","genre_ids":[16,10751,35],"media_type":"movie","popularity":0.3816,"vote_count":14,"poster_path":"/3ngZmhOXj6zN2P4RnN0rpvzAMFS.jpg","release_date":"2014-09-13","vote_average":7,"backdrop_path":"/wrT9VYE20JpHGCq9TJDKniAI6Pe.jpg","original_title":"Turma da Mônica em Cine Gibi 7: Bagunça Animal","original_language":"pt"},{"id":1099086,"adult":false,"title":"Rewind 1984","video":false,"overview":"After going on a killing spree in 1984, the legend of the Pumpkin Man returns once again to slay more victims 30 years later.","genre_ids":[27,35],"media_type":"movie","popularity":0.5493,"vote_count":9,"poster_path":"/zEkO2Cz5OPQlUHOXr00jlmbjzzE.jpg","release_date":"2022-06-24","vote_average":3.556,"backdrop_path":"/mqnzuxvPDJNzhVcjzGYBnLC5v7L.jpg","original_title":"Rewind 1984","original_language":"en"},{"id":1402613,"adult":false,"title":"Mahou Shoujo Sonico Magica","video":true,"overview":"This is an April Fool's joke by Nitroplus. On 01.04.2011, an official website for Mahou Shoujo Sonico Magika, a parody of SoniComi (a game by Nitroplus), was opened with the announcement of it being a TV anime. On the same day, the opening video for the so called TV anime was released on YouTube by NitroPlusChannel. This opening is essentially the entire anime. The title is a clear reference to Mahou Shoujo Madoka Magika, a TV anime which screenplay was written by a Nitroplus staffer Urobuchi Gen, who also got credited for screenplay for this anime on the official page. No screenplay was ever written, of course.","genre_ids":[16],"media_type":"movie","popularity":0.0622,"vote_count":5,"poster_path":"/aJ5s5JWEsG4F3pnBsKbjvKGhFhZ.jpg","release_date":"2011-04-01","vote_average":6,"backdrop_path":null,"original_title":"魔法少女そにこ☆マギカ PUELLA MAGI SONICO MAGICA","original_language":"ja"},{"id":642488,"adult":false,"title":"Mickey's Safety Club: Street Safe, Street Smart","video":false,"overview":"Mickey and his friends take a close look at important street safety situations and tips.","genre_ids":[10751,16,35,10402,10770],"media_type":"movie","popularity":0.3439,"vote_count":38,"poster_path":"/4pfoP47sMClmkXwYYaUfb8gl08T.jpg","release_date":"1989-09-01","vote_average":9.3,"backdrop_path":null,"original_title":"Mickey's Safety Club: Street Safe, Street Smart","original_language":"en"},{"id":234266,"adult":false,"title":"Kill!","video":false,"overview":"Interpol investigates the freelance killings of drug and porn peddlers.","genre_ids":[80,28,53],"media_type":"movie","popularity":1.666,"vote_count":34,"poster_path":"/zpBvlQ2JulMfTZW9hgKBg7pqZ0R.jpg","release_date":"1971-12-10","vote_average":5.971,"backdrop_path":"/20L6TORieCpdzPfVGhkumKSuZsK.jpg","original_title":"Kill!","original_language":"en"},{"id":1078760,"adult":false,"title":"1","video":false,"overview":"","genre_ids":[18],"media_type":"movie","popularity":0.0816,"vote_count":57,"poster_path":"/tBtqPlPcPPMbJB6hat5lyVaXVVd.jpg","release_date":"2021-08-28","vote_average":6.6,"backdrop_path":null,"original_title":"1","original_language":"ja"},{"id":22719,"adult":false,"title":"Rune Klan: Går large","video":false,"overview":"Rune is not a fan of traditional classic magic shows where you wear a tuxedo, top hat and take yourself very seriously. Paradoxically, Rune has been heavily inspired by the big Las Vegas shows with big props, but that's where the party stops... It's still Rune Klan. The show is called “Rune Klan Goes Large” and that's exactly what he does - magnifies it all up! Rune toured with “Going Large” in 2007.",