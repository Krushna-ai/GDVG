5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Closing the Ring\",\"description\":\"During the 1940s, a group of young men go off to war, leaving behind Ethel Ann, who is in love with one of them, Teddy. In modern-day Belfast, a man named Jimmy endeavors to return a ring found in the wreckage of a crashed plane. He travels to Michigan, where the grown Ethel Ann, who married another man after Teddy was killed in battle, now lives. Ethel Ann must decide whether to go with Jimmy to meet the soldier who last saw Teddy alive.\",\"image\":\"https://image.tmdb.org/t/p/w500/rsQp6ZlVN9DFj6wcxDcwgpFrOaH.jpg\",\"datePublished\":\"2007-09-14\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CA\",\"inLanguage\":\"en\",\"genre\":[\"war film\",\"romance film\",\"drama film\",\"Drama\",\"Romance\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.1,\"bestRating\":10,\"ratingCount\":105}}"}}],["$","$L10",null,{"initialDrama":{"id":"543a529b-0c1b-4009-8b47-5f46709bd16c","tmdb_id":13957,"imdb_id":"tt0488380","content_type":"movie","title":"Closing the Ring","original_title":"Closing the Ring","overview":"During the 1940s, a group of young men go off to war, leaving behind Ethel Ann, who is in love with one of them, Teddy. In modern-day Belfast, a man named Jimmy endeavors to return a ring found in the wreckage of a crashed plane. He travels to Michigan, where the grown Ethel Ann, who married another man after Teddy was killed in battle, now lives. Ethel Ann must decide whether to go with Jimmy to meet the soldier who last saw Teddy alive.","poster_path":"/rsQp6ZlVN9DFj6wcxDcwgpFrOaH.jpg","backdrop_path":"/A4NwKb8kS2VV4Nnai1cv6eBhK5H.jpg","release_date":"2007-09-14","first_air_date":null,"status":"published","original_language":"en","origin_country":["CA","US","GB"],"genres":[{"name":"war film"},{"name":"romance film"},{"name":"drama film"},{"id":18,"name":"