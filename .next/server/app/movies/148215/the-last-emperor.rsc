e":0.166},{"width":3840,"height":2159,"file_path":"/a4reO9Q8NjjHxwGtQiIObZtGrOn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.779,"vote_average":0.166},{"width":3840,"height":2159,"file_path":"/kVz2N9PyIac8a1s5fePOQe8BCxq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.779,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/gf4pyT1TEmmw5B8AmD5ekwVOOmL.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":2000,"height":1125,"file_path":"/x3MTpyeWVxFNWTdU8uljlymoiw8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/xp2ehN6aHh0Ra2UTMxm238ClBKJ.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3000,"height":1688,"file_path":"/eOtjMbTJ9J9LvUJDNRBg1KCUJot.jpg","iso_639_1":"sv","iso_3166_1":"SE","vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1280,"height":720,"file_path":"/xkRtaImeOOit9uIw59P1oO9kgr8.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/pvItOrleoxP8c6DqiL9MNOdGkxQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/blASnd3qBJPB3qsmbZrLlUCIjhc.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/uddhpKu2XwGX8ZpOkFuv3ixzocY.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/1zBi20b6htCVtXC0A15RUOEBHUD.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:44:49.735+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":163,"tagline":"1500 slaves. 353,260,000 royal subjects. Warlords. Concubines. And 2 wives. He was the loneliest boy in the world.","homepage":"","overview":"A dramatic history of Pu Yi, the last of the Emperors of China, from his lofty birth and brief reign in the Forbidden City, the object of worship by half a billion people; through his abdication, his decline and dissolute lifestyle; his exploitation by the invading Japanese, and finally to his obscure existence as just another peasant worker in the People's Republic."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Der letzte Kaiser","runtime":156,"tagline":"","homepage":"","overview":"Monumentalfilm über das Leben des letzten Kaisers der chinesischen Qin-Dynastie. Bertolucci zeichnet das Leben von Pu-Yi nach, der mit nur zwei Jahren zum letzten chinesischen Kaiser gekrönt, mit fünf Jahren entmachtet und später verstoßen wurde. Der Film wurde 1987 mit insgesamt neun Oscars ausgezeichnet."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Az utolsó császár","runtime":0,"tagline":"","homepage":"","overview":"1950-ben a kínai-szovjet határállomásra beragasztott ablakú szerelvény gördül be: háborús bûnösöket szállítanak haza. Közöttük van Pu Ji, az utolsó kínai császár, aki uralkodói pályáját a japán bábállam, Mandzsuko névleges uraként fejezte be. Mivel kevés jóra számíthat, a mosdóban fölvágja az ereit - de balszerencséjére megmentik, és egy ideológiai átnevelõtáborba viszik. Ott kezd neki önéletrajzának, amelybõl kalandos és vadregényes életút rajzolódik ki. 1908-ban vitték a Tiltott Városba a haldokló császárné parancsára, s hamarosan - még kisgyermekként - õ lesz az új uralkodó. Eunuchok serege neveli, s mivel nem léphet ki a palotából, semmit nem tud a világról - arra is csak évek elmúltával jön rá, hogy becsapták: minden pompa és alázat ellenére Kínában már köztársaság van. Ettõl fogva erõt vesz rajta a vágy, és mindenáron ki akar törni aranykalitkájából. Mikor a japánok felajánlják neki a megszállt Mandzsúria trónját, nincs ereje visszautasítani, s ezzel végképp tönkreteszi életét."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"L'ultimo imperatore","runtime":160,"tagline":"Era il Signore dei Diecimila Anni, l'assoluto monarca della Cina. Era nato per regnare su un mondo di antiche tradizioni. Niente lo aveva preparato per il nostro mondo in evoluzione.","homepage":"","overview":"Manciuria, confine tra Unione Sovietica e Cina, anno 1950. Un treno militare proveniente dalla Russia sovietica e carico di criminali di guerra accusati di aver collaborato con l'invasore giapponese durante la guerra fa il suo arrivo in un avamposto della Repubblica Popolare Cinese. Tra i prigionieri vi è Aisin Gioro Pu Yi, l'ultimo e ormai ex imperatore cinese: non si distingue per nulla dagli altri prigionieri, e i soldati lo trattano con la stessa durezza che riservano agli altri ostaggi. Facendo drammaticamente i conti con un avvenire nei panni di un carcerato senza importanza e prospettive, peraltro alla totale mercé di un feroce e onnipotente regime comunista, tenta il suicidio tagliandosi le vene e immergendole nell'acqua calda di uno squallido gabinetto. Mentre i guardiani tentano di sfondare la porta, intuendo il sospetto, la mente del moribondo inizia a rievocare la sua vita fin dal primo ricordo d'infanzia."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Последний император","runtime":163,"tagline":"","homepage":"","overview":"В 1908 год, империя Цин. Трёхлетний Пуи становится императором Поднебесной. К императору-ребенку относятся как к божеству. Он может делать все, кроме одного - покидать пределы дворца. До Запретного города не долетает ветер перемен, сотрясающий мир за его стенами. Но жизнь последнего императора Китая оказывается частью великой истории XX века."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":160,"tagline":"","homepage":"","overview":"Peking, 1908. De driejarige Pu Yi wordt op de Drakentroon geplaatst als 'Heer van Tienduizend Jaren', keizer van bijna de helft van de toenmalige wereldbevolking. Ondanks dat is hij het eenzaamste jongetje van de wereld."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Le Dernier Empereur","runtime":156,"tagline":"Il restera à jamais comme... Le Dernier Empereur","homepage":"","overview":"L'évocation, presque aux dimensions de la Chine, de la vie du dernier empereur Pu Yi. De 1908, où il monte à trois ans sur le trône impérial à 1967, la fin de sa vie où il devient jardinier du parc botanique de Pékin, en passant par la révolution chinoise durant laquelle il est rééduqué."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"O Último Imperador","runtime":163,"tagline":"Ele era governante absoluto, num mundo de tradição, mas o mundo dele está prestes a mudar.","homepage":"","overview":"Herdeiro de uma tradição milenar, Pu Yi, foi o último Imperador da China, viu a sua vida irreversivelmente alterada por duas guerras mundiais e grandes mudanças políticas. Guiado pelo seu mentor inglês, é forçado a deixar as muralhas do seu palácio imenso e encontrar forças para construir uma nova vida num estranho mundo que sempre quis ver, mas nunca conheceu."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"末代皇帝","runtime":0,"tagline":"一生 打从披上龙袍的那一刻 就身不由己","homepage":"","overview":"溥仪三岁登基，年幼的他眼中只有大臣身上的一只蝈蝈，江山在他心中只是一个不明所以的名词。长大了，他以为可以变革，却被太监一把火烧了朝廷账本。他以为自己是大清江山的主人……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"El último emperador","runtime":163,"tagline":"1500 esclavos. 353,260,000 súbditos reales. Señores de la guerra. Concubinas. Y 2 esposas. Era el chico más solitario del mundo.","homepage":"","overview":"Pekín, 1908. China se encuentra en plena decadencia. Puyi, un niño de tres años, es arrancado de los brazos de su madre. En medio de la noche es conducido hasta la Ciudad Prohibida, donde es coronado emperador, aunque tendrá que vivir recluido dentro de ese recinto inaccesible."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Den siste kejsaren","runtime":0,"tagline":"","homepage":"","overview":"Berättelsen om den siste kejsaren av Kina – Puyi. Tillfångatagen av röda armén som krigsbrottsling sitter Puyi i fängelset, och ser tillbaka på sitt liv. Kantat av den förbjudna stadens flärd, tumultartat härskande, och den stora kinesiska revolutionen. Den siste kejsaren var den första utländska filmen som fick tillstånd att filmas inne i Den förbjudna staden, och vann nio Oscarstatyetter 1988 för bland annat bästa film, bästa regi och bästa manus."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Viimeinen keisari","runtime":0,"tagline":"","homepage":"","overview":"Kiinan viimeisen keisatin elämäntarina upeasti kuvitettuna. Hänet oli kasvatettu hallitsemaan ikivanhojen traditioiden mukaan, eikä kukaan ollut valmistanut häntä kohtaamaan muuttuvaa maailmaa. Hän nousee valtaistuimelle kolmevuotiaana ja tulee hallitsemaan satoja miljoonia kiinalaisia. Pu Yin elämä alkaa kuin satu tuhansine palvelijoineen ja loistavin rituaalein. Mutta kun Kiina joutuu 1900-luvulla väkivaltaisiin muutoksiin ja sisällissota johtaa keisarikunnan tuhoon, hän päätyy puutarhuriksi Pekingin puistoon."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Ostatni cesarz","runtime":0,"tagline":"","homepage":"","overview":"Rok 1950. Po nieudanym samobójstwie, w czasie śledztwa były cesarz Chin Pu Yi opowiada historię swojego burzliwego życia. Wszystko rozpoczyna się w 1908 roku, kiedy trzyletni Pu Yi trafia do Zakazanego Miasta, siedziby chińskich cesarzy, by objąć tron władcy. Jest ostatnim z dynastii Ching, panującej od trzech tysięcy lat. Już trzy lata później monarchia staje się republiką, a władza Pu Yi ogranicza się do Zakazanego Miasta. Młody władca dorasta w zamkniętym świecie. W 1929 roku na dwór przybywa angielski nauczyciel by przekazać wiedzę o świecie młodemu Pu Yi..."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Den sidste kejser","runtime":218,"tagline":"","homepage":"","overview":"Historien handler om Puyi, den sidste kejser af Kina. Man følger hans liv fra fødsel, da han bliver kejser som 3-årig og hersker over en halv milliard mennesker, da han bliver fængslet under den japanske invasion og til sidst i hans liv, hvor han blot er gartner."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Son İmparator","runtime":0,"tagline":"","homepage":"","overview":"Sinema tarihinin en çok ödül alan, en geniş kadrolu filmlerinin başında gelen Son İmparator destansı bir öyküdür: 2 yaşında tahta çıkan Çin'in son imparatoru Pi Yi'nin gözünden 60 yılın öyküsü. Çekimi 2,5 yıl süren, 19 binden fazla kişinin rol aldığı film çok şık ve estetik bir görkemli yapımdır. Bertolucci sinemasının izlerini de taşır: Yasak Kent'in avlusunda binlerce figuranla çekilen sahnelerden ipek çarşafların altında belli belirsiz sevişen üç bedene kadar...  Son İmparator aynı zamanda Bertolucci'nin Oryantal Üçlemesi'nin ilk filmidir. Bu seri daha sonraki yıllarda çekeceği Çölde Çay ve Küçük Buda ile tamamlanır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Ο Τελευταίος Αυτοκράτορας","runtime":163,"tagline":"","homepage":"","overview":"Πεκίνο, 1908. Ένα αγόρι τριών ετών αφαρπάζεται από τη μητέρα του και μεταφέρεται μέσα στη νύχτα στην Απαγορευμένη Πόλη, στην καρδιά της Αρχαίας Κίνας. Το όνομά του είναι Που Γι. Μερικές μέρες αργότερα, αναλαμβάνει τον θρόνο και γίνεται «Ο Άρχοντας των 10 Χιλιάδων Ετών», «ο Γιος των Ουρανών», εξουσιαστής σχεδόν του μισού πληθυσμού της Γης. Το 1912, η Κίνα γίνεται δημοκρατία και τα 3.000 χιλιάδες χρόνια της μοναρχίας φτάνουν στο τέλος τους. Αλλά η σημαντικότερη εξέλιξη είναι αυτή της δεκαετίας του 1930, όπου την ιαπωνική εισβολή στη Μαντζουρία ακολουθεί η επανάσταση του Μάο."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Poslední císař","runtime":0,"tagline":"","homepage":"","overview":"Ve svých třech letech se stal císařem poloviny lidstva. Byl to poslední čínský císař. Za pomoci svého skotského učitele (Peter O'Toole) poznal nutnost rychlých reforem ve své říši. Bylo už pozdě. V roce 1924 byl vyhnán z bran \"Zakázaného města\", pak přišla II.světová válka s Japonskou okupací a po ní rudý komunistický režim se svou kulturní revolucí. Na sklonku svého života si mohl koupit vstupenku do císařského paláce, aby mohl spatřit \"Dračí trůn\". Musel zaplatit za to, aby mohl vidět svou vlastní \"židli\". Jeden z nejslavnějších filmů všech dob."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"ラストエンペラー","runtime":0,"tagline":"余は天の子である。余の支配は1万年におよび、望むことは全てかなえられる。","homepage":"","overview":"1950年。第二次世界大戦の終結による満州国の崩壊と国共内戦の終結により、共産主義国である中華人民共和国の一都市となったハルビン駅の構内。5年間にわたるソビエト連邦での抑留を解かれ、中華人民共和国に送還された「戦犯」達がごった返す中で、列から外れた1人の男が洗面所で自殺を試みる。男は監視人の手により一命を取り留めるものの、薄れ行く意識の中で幼い日々の頃を思い出していた。この男こそ清朝最後の皇帝にして満州国の皇帝、「ラスト・エンペラー」と呼ばれた愛新覚羅溥儀その人であった。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Ultimul împărat","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"הקיסר האחרון","runtime":0,"tagline":"","homepage":"","overview":"סרטו רחב היריעה של הבמאי האיטלקי ברנרדו ברטולוצ'י (חולמים) אשר זכה בתשעה פרסי אוסקר בשנת 1988, ביניהם הסרט הטוב ביותר והבמאי הטוב ביותר. הסרט מביא את סיפורו של קיסר סין האחרון פו-יי, שעלה לגדולה בתפקיד המלוכה בגיל שלוש ופינה את הכיסא בגיל שש. הסרט ממשיך ועוקב אחר גורלו ההפכפך של הילד שהובטח לו גן של שושנים, עד מותו כגנן בשנת 1967, עקב המהפכה התרבותית בסין. הסרט כולל צילומים נדירים מן העיר האסורה. עם סקמוטו ריוצ'י (עיני נחש), ג'ון לונה (ניצוד), ג'ואן צ'ן (פיתויו של נזיר), פיטר אוטול (סופרגירל). הסרט זכה לפרסים רבים ברחבי העולם ביניהם פרס גלובוס הזהב ופרס BAFTA היוקרתי."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"마지막 황제","runtime":162,"tagline":"비운의 황제 푸이의 자전적 영화","homepage":"","overview":"1950년, 44세의 푸이는 소련군의 감시 아래 중국인 800명과 함께 조국으로 돌아가는 동안 자기 비판의 생애를 기록하며 황제였던 과거를 회상한다. 1906년 자식이 없는 광서제의 뒤를 이어 황제가 된 4살의 푸이는 즉위 3년째에 발발한 신해 혁명으로 궁중 생활의 마지막을 맞는다. 자금성에서 연금 생활을 하며 결혼을 하고 시대 상황을 깨달은 푸이는 영국인 가정교사의 영향으로 유학의 꿈을 가진다. 그러나 1924년의 군사 쿠데타로 일본으로 도피한 푸이는 유학의 꿈을 상실한 채 일본 특무기간원의 감언에 넘어가 만주국의 집정이 되고 2년 후에는 황제로 등극하게 되는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Останній Імператор","runtime":0,"tagline":"","homepage":"","overview":"В основу сюжету покладена біографія імператора Пуї — останнього володара Китаю, який у 1908 році зійшов на трон країни з мільярдним населенням на початку свого життєвого шляху, у віці трьох років, а закінчив його в’язнем та вигнанцем ..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"L'últim emperador","runtime":0,"tagline":"1500 esclaus. 353260000 súbdits reals. Senyors de la guerra. Concubines. I 2 esposes. Era el noi més solitari del món.","homepage":"","overview":"Pequín, 1908. Pu Yi, un nen de tres anys, és designat emperador i no podrà sortir de la ciutat prohibida on viurà rodejat d'una cort sumptuosa. Pu Yi té un preceptor, l'escocès Reginald Johnston, que arriba a ser el seu millor amic. El 1922 Pu Yi es casa amb Wang Jung i agafa una concubina. Al cap de dos anys, Beny Yu Hsiang pren el poder i expulsa Pu Yi de la ciutat prohibida. El 1932 accepta ser l'emperador titella de Manxukuo, ex-Manxúria, envaïda pels japonesos. Al final de la guerra és jutjat com a criminal de guerra."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"O Último Imperador","runtime":163,"tagline":"Ele foi o senhor de dez mil anos, o monarca absoluto da China. Ele nasceu para governar um mundo de tradição antiga. Nada o preparou para nosso mundo de mudanças.","homepage":"","overview":"A saga de Pu Yi, o último imperador da China, que foi declarado imperador com apenas três anos e viveu enclausurado na Cidade Proibida até ser deposto pelo governo revolucionário, enfrentando então o mundo pela primeira vez quando tinha 24 anos. Neste período se tornou um playboy, mas logo teria um papel político quando se tornou um pseudo-imperador da Manchúria, quando esta foi invadida pelo Japão. Aprisionado pelos soviéticos, foi devolvido à China como prisioneiro político em 1950. É exatamente neste período que o filme começa, mas logo retorna a 1908, o ano em que se tornou imperador."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Последният император","runtime":163,"tagline":"","homepage":"","overview":"Награденият с девет Оскара исторически филм на Бернардо Бертолучи разказва истинската история на последния император на Китай, Пуи. За основа на сценария е послужила автобиографичната книга написана от самия Пуи, а в главните роли се превъплъщават Джон Лоун, Джоан Чен и Рик Йънг. Филмът обхваща както годините в които Пуи управлява Китай и е обект на възхищение от страна на милиарди хора, така и неговото изпълнено с предизвикателства детство. Освен с аристократичното си потекло и отношението му относно нахлуващите японски сили Пуи става известен и с разпуснатия си начин на живот и упадъка, който започва да го заобикаля. Филмът на Бертолучи също така разглежда и този период от живота на Пуи в който той живее и се прехранва като обикновен селски работник. За работата си по \"Последният император\" Бернардо Бертолучи получи \"Оскар\" в категорията \"Най-добър режисьор\"."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Paskutinis imperatorius","runtime":0,"tagline":"","homepage":"","overview":"Genialiojo italų kino režisieriaus Bernardo Bertolučio („Paskutinis tango Paryžiuje\", „Svajotojai\", „Pavogtas grožis\") epinėje juostoje pasakojama dramatiška paskutiniojo Kinijos Imperatoriaus Pu Yi gyvenimo istorija. Vos trejų metų sulaukusiam vaikui atiteko garbingiausias titulas, sostas, turtai, valdžia. 1908-aisiais metais niekas nė neįtarė, kad mažasis Imperatorius bus paskutinysis galingos ir senos dinastijos, tūkstančius metų valdžiusios Kiniją, sosto paveldėtojas..."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Poslednji kineski car","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Den siste keiseren","runtime":0,"tagline":"","homepage":"","overview":"Han var arvtageren til det tusenårige riket. Han var født til å herske i tråd med urgamle tradisjoner, men ingen forberedte ham på en verden i forandring. Tre år gammel bestiger Pu Yi Dragetronen for å bli keiser over flere hundre millioner kinesere. Hans liv begynner som et eventyr i “Den forbudte by” med tusenvis av tjenere, prakt og overflod, og gjenklangen av ritualer lyder i byens isolat. Han bevitner og deltar i forandringenes voldsomme stormer som blåser over Kina på 1900-tallet. Han er marionettkeiser og fange hos japanerne under den andre verdenskrigen. Han utsettes for Mao Tse Tungs maktovertagelse og kulturrevolusjonens voldsomheter, for til slutt å ende opp som gartner i en av Pekings parker."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"El último emperador","runtime":0,"tagline":"","homepage":"","overview":"Pekín, 1908. China se encuentra en plena decadencia. Pu Yi, un niño de tres años, es arrancado de los brazos de su madre, en medio de la noche, y conducido hasta la Ciudad Prohibida, donde es coronado emperador, pero tendrá que vivir recluido dentro de este recinto inaccesible."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"آخرین امپراتور","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Posljednji kineski car","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Le Dernier Empereur","runtime":0,"tagline":"","homepage":"","overview":"En 1908, le petit Pu Yi, âgé de trois ans, lointain parent de l'impératrice douairière, est choisi par elle pour lui succéder. Trois ans plus tard, il doit abdiquer par suite de la révolution de Sun Yat Sen qui établit la première république de Chine. Il est cependant autorisé à rester comme figure symbolique dans la Cité interdite, palais traditionnel de l'empereur à Pékin. Chassé en 1924, il s'établit à Tientsin sous la protection des Japonais qui en font un souverain fantoche lorsqu'ils prennent le contrôle de la Mandchourie en 1931. Après la guerre, Pu Yi devient le prisonnier des communistes chinois qui le soumettent à une rééducation."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Viimane keiser","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"末代皇帝","runtime":0,"tagline":"","homepage":"","overview":"溥儀（尊龍 飾）的一生在電影中娓娓道來。他從三歲起登基，年幼的眼光中只有大臣身上的一隻蟈蟈，江山在他心中只是一個不明所以的名詞。長大了，他以為可以變革，卻被太監一把燒了朝廷帳本。他以為是大清江山的主人，卻做了日本人的傀儡。 　　  解放後，他坐上了從俄國回來的火車，身邊是押送監視他的解放軍。他猜測自己難逃一死，便躲在狹小的衛生間裡，割脈自殺。然而他沒有死在火車上，命運的嘲笑還在等著他。文革的風風雨雨，在他身上留下了斑斑傷痕。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"末代皇帝溥儀","runtime":0,"tagline":"","homepage":"","overview":"溥儀(尊龍 飾)從童年登基，歷經清末，民國、偽滿洲、共產黨執政，時代更迭，戰火紛飛，他如同傀儡一般，被權力捉弄擺佈。時代浪潮席捲而來不容喘息，個人在其中難以自主顛沛流離，故而音樂也時而恢宏，時而低迷，將幾十年歷史鬧劇終結於在無盡的傷感欷歔之中。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Апошні імператар","runtime":0,"tagline":"","homepage":"","overview":"Паміраючы, старая імператрыца Паднябеснай вырашае, што наступным імператарам і «Сынам Неба» стане трохгадовы Пу-І, якога забіраюць з роднага дому ад матулі і адвозяць у Забаронены горад. А па-за межамі Забароненага гораду Кітай становіцца Народнаю Рэспублікаю, аднак унутры імператарскага палацу ўсё па-ранейшаму: імператара-дзіця абагаўляюць, яму дазваляюцца любыя забавы, але ён не мае ніякай улады і становіцца закладнікам ва ўласным палацы. Кім стане дарослы Пу-І?"},"name":"беларуская мова","iso_639_1":"be","iso_3166_1":"BY","english_name":"Belarusian"},{"data":{"title":"Hoàng Đế Cuối Cùng","runtime":0,"tagline":"","homepage":"","overview":"Bernardo Bertolucci là đạo diễn người Ý, ảnh hưởng của Trào lưu Tân hiện thực quá mạnh mẽ nên phim của Bertolucci cũng mang hơi hướng đặc tính của lối làm phim thuộc Trào lưu này. Ông sử dụng nhiều cảnh đặc tả, góc máy đuổi bắt hoặc đón sẵn chờ nhân vật trung tâm xuất hiện. Không tô vẽ hào quang, cốt cách cho nhân vật mà để cho mọi sự tự nhiên được diễn ra... Bộ phim đã giành tổng cộng 9 giải Oscar, bao gồm cả giải Phim hay nhất và Đạo diễn xuất sắc nhất. Đây là một bộ phim hi hữu khi giành chiến thắng ở tất cả 9 hạng mục mà nó được đề cử. Đồng thời phim cũng đoạt giải BAFTA Phim hay nhất và Quả cầu Vàng ở hạng mục Phim chính kịch xuất sắc nhất."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"كان رب العشرة آلاف سنة ، الملك المطلق للصين. وُلِد ليحكم عالمًا من التقاليد القديمة. لم يعده شيء لعالم التغيير لدينا.","homepage":"","overview":"تاريخ درامي لـ Pu Yi ، آخر أباطرة الصين ، منذ ولادته النبيلة وحكمه القصير في المدينة المحرمة ، موضع عبادة نصف مليار شخص ؛ من خلال تنازله وانحطاطه وأسلوب حياته الفاسد. استغلاله من قبل الغزاة اليابانيين ، وأخيرا إلى وجوده الغامض كمجرد عامل فلاح آخر في الجمهورية الشعبية."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"จักรพรรดิโลกไม่ลืม","runtime":0,"tagline":"","homepage":"","overview":"จักรพรรดิโลกไม่ลืม (The Last Emperor) ภาพยนตร์ชีวประวัติของจักรพรรดิผู่อี๋ [or, ปูยี] [Puyi] จักรพรรดิพระองค์สุดท้ายของจีน เนื้อหาหลักของภาพยนตร์จะเกี่ยวข้องกับจักรพรรดิผู๋อี้โดยตรงตั้งแต่สิ้น สมัยการปกครองของสูสีไทเฮาช่วงผู๋อี้ขึ้นครองราชย์ ช่วงชีวิตวัยเด็กที่ต้องอาศัยอยู่ในเขตพระราชวังต้องห้าม ช่วงที่ปกครองแมนจูกัว จวบจนบั้นปลายชีวิตของจักรพรรดิผู๋อี้ที่อาศัยอยู่เยี้ยงสามัญชน"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Zadnji kitajski cesar","runtime":0,"tagline":"Epsko delo Bernarda Bertoluccija je osvojilo devet oskarjev.","homepage":"","overview":"Zgodba govori o življenju zadnjega kitajskega cesarja Pu Jija, ki so ga kronali pri komaj treh letih. Leta 1950 je Pu Ji že pet let v zaporu, kamor ga je zaprla Rdeča armada med sovjetsko invazijo Mandžurije. Pu Ji se v zaporu spominja svojega odraščanja v razkošju Prepovedanega mesta. Imel je vse, kar si je zaželel, toda bil zaprt na dvoru in ni poznal zunanjega sveta. Ko je Kitajska postala republika, je Pu Ji prenehal biti cesar. Čeprav je poskušal reformirati Prepovedano mesto, so ga iz palače sčasoma izgnali. Tedaj se je predal dekadentnemu načinu življenja. Stopil je tudi na stran Japonske. Komunistični režim ga je rehabilitiral, ko je opustil simpatije do japonskega agresorja. Po revoluciji se je Pu Jijev svet dramatično porušil vase. Končal je kot navaden kmečki delavec v Ljudski republiki."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"უკანასკნელი იმპერატორი","runtime":0,"tagline":"","homepage":"","overview":"პუ-ის დრამატული ისტორია, ჩინეთის უკანასკნელი იმპერატორი,დიდი ქვეყნის უკანასკნელი იმპერატორის ისტორია.გარე სამყაროდან იზოლირებული, ის მუდამ მიისწრაფოდა დახურული ქალაქიდან. მას მთელი გზის გავლა მოუწია მწვერვალიდან უფსკრულამდე."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"}],"reviews_tmdb":[{"id":"64b4c09923d2780107314c2a","url":"https://www.themoviedb.org/review/64b4c09923d2780107314c2a","author":"CinemaSerf","content":"$11","created_at":"2023-07-17T04:16:25.768Z","updated_at":"2023-07-17T04:16:25.858Z","author_details":{"name":"CinemaSerf","rating":8,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":10141,"adult":false,"title":"Dirty Rotten Scoundrels","video":false,"overview":"Con artist Lawrence Jamieson is a longtime resident of a luxurious coastal resort, where he enjoys the lavish fruits of his deceptions -- that is, until a competitor, Freddy Benson, shows up. When the new guy's lowbrow tactics impinge on his own sophisticated work and believing him to be the infamous conman 'The Jackal', Lawrence resolves to get rid of him. Confident of his own duplicitous talents, he challenges Freddy to a winner-takes-all competition: whoever swindles their latest mark, American heiress Janet Colgate, out of $50,000 first can stay, while the other must leave town.","genre_ids":[35,80],"media_type":"movie","popularity":2.2538,"vote_count":981,"poster_path":"/3176xH21fSetstKpEtAD1giHbyT.jpg","release_date":"1988-12-14","vote_average":7.1,"backdrop_path":"/mFV1JHptSBFX4x1K1Qz4Zqb4MwB.jpg","original_title":"Dirty Rotten Scoundrels","original_language":"en"},{"id":10780,"adult":false,"title":"Overboard","video":false,"overview":"Heiress Joanna Stayton hires carpenter Dean Proffitt to build a closet on her yacht—and refuses to pay him for the project when it's done. But after Joanna accidentally falls overboard and loses her memory, Dean sees an opportunity to get even.","genre_ids":[35,10749],"media_type":"movie","popularity":3.6667,"vote_count":948,"poster_path":"/v9MVFgUTvNRXmm2WWOzST6UXb5x.jpg","release_date":"1987-12-16","vote_average":6.807,"backdrop_path":"/dZSQv9Lz5pab3pOnVvd3yjC1N0K.jpg","original_title":"Overboard","original_language":"en"},{"id":3870,"adult":false,"title":"1900","video":false,"overview":"The epic tale of a class struggle in twentieth century Italy, as seen through the eyes of two childhood friends on opposing sides.","genre_ids":[18,36],"media_type":"movie","popularity":1.5693,"vote_count":667,"poster_path":"/deWzfCC59tmtEQvKSmflDe14FvR.jpg","release_date":"1976-08-28","vote_average":7.798,"backdrop_path":"/x5948QrtMqvnf2OBP9ESpdmONQa.jpg","original_title":"Novecento","original_language":"it"},{"id":10047,"adult":false,"title":"The Messenger: The Story of Joan of Arc","video":false,"overview":"In 1429, a French teenager stood before her King with a message she claimed came from God; that she would defeat the world's greatest army and liberate her country from its political and religious turmoil. As she reclaims God's diminished kingdom, this courageous young woman has various amazing victories until her violent and untimely death.","genre_ids":[12,18,28,36,10752],"media_type":"movie","popularity":2.9284,"vote_count":1564,"poster_path":"/lFzOGA2LPdOfQyhEiY74uDf2WKa.jpg","release_date":"1999-10-27","vote_average":6.403,"backdrop_path":"/iW2ZLRkKJvFuI6ZkSchk5f8kCPc.jpg","original_title":"Joan of Arc","original_language":"en"},{"id":25793,"adult":false,"title":"Precious","video":false,"overview":"In Harlem in 1987, Claireece \"Precious\" Jones is a 16-year-old African American girl born into a life no one would want. She's pregnant for the second time by her absent father, and at home she must wait hand and foot on her mother, an angry woman who abuses her emotionally and physically. School is chaotic and Precious has reached the ninth grade with good marks and a secret – she can't read.","genre_ids":[18],"media_type":"movie","popularity":5.1406,"vote_count":1738,"poster_path":"/d4ltLIDbvZskSwbzXqi0Hfv5ma4.jpg","release_date":"2009-11-06","vote_average":7.317,"backdrop_path":"/81ME78JndOYu7IluTi1rxh0cLY2.jpg","original_title":"Precious","original_language":"en"},{"id":9941,"adult":false,"title":"Down and Out in Beverly Hills","video":false,"overview":"Beverly Hills couple Barbara and Dave Whiteman find their lives altered by the arrival of a vagrant who tries to drown himself in their swimming pool.","genre_ids":[35],"media_type":"movie","popularity":0.6895,"vote_count":274,"poster_path":"/5bfbUsKcJD4HHFmlTcpHBI2wR2k.jpg","release_date":"1986-01-31","vote_average":5.905,"backdrop_path":"/g6VLgLRtdY334NO0VWlIo1Wckw8.jpg","original_title":"Down and Out in Beverly Hills","original_language":"en"},{"id":5001,"adult":false,"title":"Before Night Falls","video":false,"overview":"Spanning several decades, this powerful biopic offers a glimpse into the life of famed Cuban poet and novelist Reinaldo Arenas, an artist who was vilified for his homosexuality in Fidel Castro's Cuba.","genre_ids":[18],"media_type":"movie","popularity":0.9805,"vote_count":296,"poster_path":"/kb2dqj73cfmt6qHAh1ySIlVm6v0.jpg","release_date":"2000-09-03","vote_average":6.63,"backdrop_path":"/euDDsCiURZDuhJccrkM1bAJbb8r.jpg","original_title":"Before Night Falls","original_language":"en"},{"id":33078,"adult":false,"title":"A Zed & Two Noughts","video":false,"overview":"Identical twin zoologists lose their wives in a car crash caused by a white swan. They become obsessed with the death and decay of animals, and develop a strange and unusual relationship with the driver of the car, a woman who is now an amputee.","genre_ids":[35,18],"media_type":"movie","popularity":0.5264,"vote_count":174,"poster_path":"/55eiU0JNfNRqWbpabsf6NukntI2.jpg","release_date":"1985-10-04","vote_average":7.014,"backdrop_path":"/7NVTbSEsUYxAzv0prODP7OCzuPl.jpg","original_title":"A Zed & Two Noughts","original_language":"en"},{"id":160068,"adult":false,"title":"Gloria","video":false,"overview":"Gloria is a 58-year-old divorcée. Her children have all left home but she has no desire to spend her days and nights alone. Determined to defy old age and loneliness, she rushes headlong into a whirl of singles’ parties on the hunt for instant gratification – which only leads to repeated disappointment and enduring emptiness. But when Gloria meets Rodolfo, an ex-naval officer seven years her senior, she begins to imagine the possibility of a permanent relationship.","genre_ids":[35,18],"media_type":"movie","popularity":0.6791,"vote_count":200,"poster_path":"/t1copJu3ecVx7zVCBA1o6z02WcZ.jpg","release_date":"2013-05-08","vote_average":6.615,"backdrop_path":"/xqc5l6CCOBqni0gT9J2nvodhCD.jpg","original_title":"Gloria","original_language":"es"},{"id":21345,"adult":false,"title":"City of Life and Death","video":false,"overview":"In 1937, during the height of the Second Sino-Japanese War, the Imperial Japanese Army has just captured Nanjing, then-capital of the Republic of China. What followed was known as the Nanking Massacre, or the Rape of Nanking, a six week period wherein tens of thousands of Chinese soldiers and civilians were killed.","genre_ids":[18,36,10752],"media_type":"movie","popularity":1.6684,"vote_count":234,"poster_path":"/xY6OUM2aRCmmq1ySTg2eu5rVmcq.jpg","release_date":"2009-04-22","vote_average":7.412,"backdrop_path":"/bt2ncrRtVwOLw30fUn31eDCbE0o.jpg","original_title":"南京!南京!","original_language":"zh"},{"id":12921,"adult":false,"title":"Strange Brew","video":false,"overview":"Something is rotten at the Elsinore Brewery. Bob and Doug McKenzie (as seen on SCTV) help the orphan Pam regain the brewery founded by her recently-deceased father. But to do so, they must confront the suspicious Brewmeister Smith and two teams of vicious hockey players.","genre_ids":[35,80,878],"media_type":"movie","popularity":0.8457,"vote_count":214,"poster_path":"/rScplcvRHX7o7XK88SFb5mddo8y.jpg","release_date":"1983-08-26","vote_average":6.005,"backdrop_path":"/y5yCGyPKS0gk5IOne2y1FYuzJQm.jpg","original_title":"Strange Brew","original_language":"en"},{"id":47985,"adult":false,"title":"Assa","video":false,"overview":"ASSA is set in Crimea during the winter in the mid eighties. A young musician (Bananan) falls for mobster's (Krymov) young mistress (Alika). The parallel story line involves an 18th century assassination plot.","genre_ids":[80,18,10749,10402],"media_type":"movie","popularity":0.8321,"vote_count":73,"poster_path":"/5fl1UIUaWK8KouCOUwN506ys5VP.jpg","release_date":"1987-11-01","vote_average":6.863,"backdrop_path":"/hgrGSKszm4GOLDMBzOMr3m52WqY.jpg","original_title":"Асса","original_language":"ru"},{"id":31650,"adult":false,"title":"Someone to Watch Over Me","video":false,"overview":"Claire Gregory, an upper class New York personality, witnesses a murder in a luxurious nightclub. Detective Mike Keegan, recently promoted, is assigned to protect her.","genre_ids":[18,10749,53],"media_type":"movie","popularity":1.0274,"vote_count":206,"poster_path":"/7Vqw29y8pkoHaVtwkQcQhBK9oTY.jpg","release_date":"1987-10-09","vote_average":5.8,"backdrop_path":"/4lCritA97pEdHCTEerfrkv3BMDH.jpg","original_title":"Someone to Watch Over Me","original_language":"en"},{"id":1782,"adult":false,"title":"Afterwards","video":false,"overview":"Newly divorced lawyer Nathan Del Amico is shaken up after he meets a doctor who claims that he can sense when select people are about to die. Though he doesn't believe the doctor, events in Nathan's life slowly make him think he's not long for this world.","genre_ids":[18,9648,53],"media_type":"movie","popularity":3.0059,"vote_count":142,"poster_path":"/byElFR4rU7aU8FQoorVNmIxCSUV.jpg","release_date":"2008-10-01","vote_average":5.488,"backdrop_path":"/k2UCLlYQIy0nj2M8jtSwAHW442u.jpg","original_title":"Afterwards","original_language":"en"},{"id":42788,"adult":false,"title":"Before the Revolution","video":false,"overview":"The study of a youth on the edge of adulthood and his aunt, ten years older. Fabrizio is passionate, idealistic, influenced by Cesare, a teacher and Marxist, engaged to the lovely but bourgeois Clelia, and stung by the drowning of his mercurial friend Agostino, a possible suicide. Gina is herself a bundle of nervous energy, alternately sweet, seductive, poetic, distracted, and unhinged. They begin a love affair after Agostino's funeral, then Gina confuses Fabrizio by sleeping with a stranger. Their visits to Cesare and then to Puck, one of Gina's older friends, a landowner losing his land, dramatize contrasting images of Italy's future. Their own futures are bleak.","genre_ids":[10749,18],"media_type":"movie","popularity":0.5185,"vote_count":117,"poster_path":"/eonuTTUGbxVurkBgC1KLJ00QIvR.jpg","release_date":"1964-05-13","vote_average":7.043,"backdrop_path":"/br2P3BpVJHbtGWRiWiaPNSbTjlB.jpg","original_title":"Prima della rivoluzione","original_language":"it"},{"id":9409,"adult":false,"title":"Another Stakeout","video":false,"overview":"A pair of immature detectives are joined by a pesky assistant district attorney in staking out a lakeside home where an important Mafia trial witness is believed to be heading.","genre_ids":[35,80,28],"media_type":"movie","popularity":0.931,"vote_count":242,"poster_path":"/hBItFUmCrRS1mel0TM69ymBD79k.jpg","release_date":"1993-07-22","vote_average":5.444,"backdrop_path":"/eBA3K1Vdh1UuagOu6KMzPrxw7EU.jpg","original_title":"Another Stakeout","original_language":"en"},{"id":57970,"adult":false,"title":"Le vie del Signore sono finite","video":false,"overview":"Set in Italy during the 1920s, a barber is in a wheelchair because of a psychosomatic illness after he lost the woman he loves.","genre_ids":[35],"media_type":"movie","popularity":0.2494,"vote_count":101,"poster_path":"/hdDWKSbC3aBsmgUCirpZWWUFLR3.jpg","release_date":"1987-12-19","vote_average":7.3,"backdrop_path":"/oYwf9zduUYaKpOOA4ieVKqwfN7j.jpg","original_title":"Le vie del Signore sono finite","original_language":"it"},{"id":44737,"adult":false,"title":"Babies","video":false,"overview":"A non-narrated documentary following the lovesome lives of four infants from birth to their first birthday. The babies featured are two from rural areas: Ponijao from Opuwo, Namibia, and Bayar from Bayanchandmani, Mongolia, as well as two from urban areas: Mari from Tokyo, Japan, and Hattie from San Francisco, USA.","genre_ids":[99],"media_type":"movie","popularity":0.5585,"vote_count":142,"poster_path":"/zfXmRDjbMewZWAIGfKwMG5xjxzj.jpg","release_date":"2010-05-07","vote_average":6.972,"backdrop_path":"/m5InPcwZSJx1J49XSKl1WEB4JCd.jpg","original_title":"Bébés","original_language":"fr"},{"id":11532,"adult":false,"title":"The Emerald Forest","video":false,"overview":"For ten years, engineer Bill Markham has searched tirelessly for his son Tommy who disappeared from the edge of the Brazilian rainforest. Miraculously, he finds the boy living among the reclusive Amazon tribe who adopted him. And that's when Bill's adventure truly begins. For his son is now a grown tribesman who moves skillfully through this beautiful-but-dangerous terrain, fearful only of those who would exploit it. And as Bill attempts to \"rescue\" him from the savagery of the untamed jungle, Tommy challenges Bill's idea of true civilization and his notions about who needs rescuing.","genre_ids":[28,12,18],"media_type":"movie","popularity":1.0392,"vote_count":257,"poster_path":"/fdRlqPnPFaPyQqS3KiBLJwWQPBe.jpg","release_date":"1985-06-22","vote_average":6.63,"backdrop_path":"/xF0EBIwwNd62WkbDiHVZDElNg9s.jpg","original_title":"The Emerald Forest","original_language":"en"},{"id":49850,"adult":false,"title":"A Quiet Life","video":false,"overview":"The story of a man who murdered thirty-two people, gained power, and then got afraid because too many people wanted to kill him. One August morning, he disappeared. For fifteen years, everyone believed him dead.","genre_ids":[18,53],"media_type":"movie","popularity":0.3581,"vote_count":163,"poster_path":"/jE2b7aojjGkLdzPZFbseyeBoMRD.jpg","release_date":"2010-11-05","vote_average":6.528,"backdrop_path":"/hUxJZfAlejUX373zcargLE4qizT.jpg","original_title":"Una vita tranquilla","original_language":"it"}],"similar_content":[{"id":1502116,"adult":false,"title":"24 Flavors","video":false,"overview":"After years abroad, April returns to her homeland, discovering her divorced parents rekindling old ties. Memories of her extreme self-harm resurface as she grapples with her father's infidelity. Facing the impending demolition of the tea shop, April must decide between taking her mother Qiaozhen abroad or supporting her desire to continue the business. Struggling Yongtang silently raises funds for Qiaozhen's shop reopening, inadvertently falling into a scam. April also encounters her resilient half-sister Xiaojing. Amidst the challenges, she begins to reclaim the life, time, and self-reflection she had long avoided.","genre_ids":[18,10751],"popularity":0.1892,"vote_count":0,"poster_path":"/qmjW4BwHnuUJYccNGTP50ni9fMk.jpg","release_date":"2024-11-14","vote_average":0,"backdrop_path":null,"original_title":"二十四味","original_language":"zh"},{"id":1297367,"adult":false,"title":"Remotely Killed: Behind the Scenes of Murder","video":false,"overview":"This is the 58 minutes Hulu version which contains spoiler/reveals throughout the special.","genre_ids":[9648,18],"popularity":0.1713,"vote_count":1,"poster_path":"/5XzC8T56UFNmYFtijc6ModABdtr.jpg","release_date":"2020-07-26","vote_average":10,"backdrop_path":"/rflAJ2PnTpWPofpcivpZ45yJeyC.jpg","original_title":"リモートで殺される: 殺人の裏側編","original_language":"ja"},{"id":48399,"adult":false,"title":"Let Us Live","video":false,"overview":"When a confused eyewitness identifies New York City cabbie Brick Tennant as a killer, he is sentenced to death for a murder that he wasn't involved in. Though no one is willing to listen to the innocent prisoner's pleas for freedom, Brick's faithful fiancée, Mary, knows that her lover is innocent because she was with him when the crime was committed. As the scheduled execution draws ever nearer, Mary begins to investigate the murder herself.","genre_ids":[80,18,53],"popularity":0.4607,"vote_count":12,"poster_path":"/cJcFtZHx7pKzdJeYxtwprCdPLkT.jpg","release_date":"1939-03-29","vote_average":6.8,"backdrop_path":"/7MaD3E28H2zgfU0wZDutzo0nQCB.jpg","original_title":"Let Us Live","original_language":"en"},{"id":312973,"adult":false,"title":"The Man Who Lived at the Ritz","video":false,"overview":"In this drama, an American art student is trapped amidst the political turmoil of war-torn Europe while visiting Paris and staying at the fabulous Ritz hotel. Rather than cope constructively with it all, the fellow opts to ignore it and continue living the high-life for as long as possible.","genre_ids":[10770,18,10752],"popularity":0.2564,"vote_count":3,"poster_path":"/yBi5sr7MI2zhWME61IesOFPVc77.jpg","release_date":"1988-11-28","vote_average":3.333,"backdrop_path":null,"original_title":"The Man Who Lived at the Ritz","original_language":"en"},{"id":900858,"adult":false,"title":"Disrupt","video":false,"overview":"When a burglary goes wrong, a meth addict must choose between his family or his next fix.","genre_ids":[18],"popularity":1.547,"vote_count":0,"poster_path":"/eO99VWbkRsusxgHfffpSdjL5rON.jpg","release_date":"2021-11-06","vote_average":0,"backdrop_path":"/fzKh3i0BC2RAhzSnR2jpZbYjY1d.jpg","original_title":"Disrupt","original_language":"en"},{"id":48620,"adult":false,"title":"The Mighty Macs","video":false,"overview":"In 1971, Cathy Rush becomes the head basketball coach at a tiny, all-girls Catholic college. Though her team has no gym and no uniforms — and the school itself is in danger of being sold — Rush looks to steer her girls to their first national championship.","genre_ids":[18],"popularity":0.5635,"vote_count":42,"poster_path":"/frNp8Rmkr8wBDyKrZ89gYvrtxBa.jpg","release_date":"2011-10-21","vote_average":5.2,"backdrop_path":"/lGWT72QzlEkICmYXw3nNjoLtNcZ.jpg","original_title":"The Mighty Macs","original_language":"en"},{"id":313057,"adult":false,"title":"Mugaldekoak","video":false,"overview":"Mugaldekoak is set in the early 40s, when, on this side of the border, the wounds of the Civil War were still open and, on the other, they were living under occupation by the German Army. The tale revolves around the Comète Network, an initiative developed during World War II on the border with Navarre: the clandestine evacuation of British pilots brought down in enemy territory.","genre_ids":[18,10752,10770],"popularity":2.0273,"vote_count":0,"poster_path":"/wb2aBfpFV1E8XizZNCzqyvWgSoX.jpg","release_date":"2010-04-14","vote_average":0,"backdrop_path":null,"original_title":"Mugaldekoak","original_language":"eu"},{"id":705485,"adult":false,"title":"Kunstkammer","video":false,"overview":"","genre_ids":[99,18],"popularity":1.4644,"vote_count":1,"poster_path":null,"release_date":"2014-06-12","vote_average":5,"backdrop_path":null,"original_title":"Kunstkammer","original_language":"es"},{"id":48412,"adult":false,"title":"Battle of the Coral Sea","video":false,"overview":"A US submarine and its crew are captured by the Japanese on the eve of a major WWII battle.","genre_ids":[10752,18,10749],"popularity":0.3527,"vote_count":21,"poster_path":"/5lays4bkpjNRS2pS419DF5ALHOU.jpg","release_date":"1959-11-01","vote_average":5.6,"backdrop_path":"/9ZTF03EQ4Pw4mr1ThQavqC7EBb6.jpg","original_title":"Battle of the Coral Sea","original_language":"en"},{"id":513514,"adult":false,"title":"Lev Yashin. The Dream Goalkeeper","video":false,"overview":"An ordinary working class boy, like all his peers, he played football day and night and dreamed of being a striker. But no matter which team he played for - in the yard, at the factory, or in the army - he was inevitably put in goal.","genre_ids":[18],"popularity":1.2294,"vote_count":126,"poster_path":"/hyHpcCdxwmMjelSuWxsFhPMUZMz.jpg","release_date":"2019-11-28","vote_average":7.5,"backdrop_path":"/yz6NmXRYwoO5VXd1LScZkYdgMxN.jpg","original_title":"Лев Яшин. Вратарь моей мечты","original_language":"ru"},{"id":48467,"adult":false,"title":"The Mountain of the Lord","video":false,"overview":"Recounts the 40-year history of building the Salt Lake Temple, shown as if recounted by Wilford Woodruff to a young reporter. It portrays the pioneers' dedication to temple worship.","genre_ids":[36,18,10751,99],"popularity":0.2735,"vote_count":9,"poster_path":"/2Lbeld2zqewPBpO6l2xGRMciHG5.jpg","release_date":"1993-03-01","vote_average":7.9,"backdrop_path":null,"original_title":"The Mountain of the Lord","original_language":"en"},{"id":48485,"adult":false,"title":"Nostradamus","video":false,"overview":"A dramatic retelling of the life of Michel de Nostredame, from his early work as a plague doctor to his time at the court of Catherine de Medici, after he became famed for his prophetic almanacs. Stars Rutger Hauer and Julia Ormond.","genre_ids":[18,36],"popularity":0.4822,"vote_count":74,"poster_path":"/kbjPR7FoKUUv4uR4dwzO7ce4aTx.jpg","release_date":"1994-08-18","vote_average":5.7,"backdrop_path":"/pTlT8oJnNiJUlgwxijhJMdACC7i.jpg","original_title":"Nostradamus","original_language":"en"},{"id":313074,"adult":false,"title":"Sword of Vengeance","video":false,"overview":"Returning to his homeland after years of slavery, a Norman prince seeks revenge on his father's  murderer – his ruthless uncle, Earl Durant. Gaining the trust of a band of exiled farmers, he leads them into battle against Durant, exploiting them in his inexorable quest for vengeance. As one by one they are slaughtered in the brutal battle, will the prince sacrifice everything an everyone to fulfil his quest for blood?","genre_ids":[36],"popularity":0.5273,"vote_count":90,"poster_path":"/jzGCV0V4B5L0VgmAYGMawqaIhha.jpg","release_date":"2015-06-07","vote_average":4.8,"backdrop_path":"/jcaN0lHWmY8PPdFumbDAGMDOsjJ.jpg","original_title":"Sword of Vengeance","original_language":"en"},{"id":313080,"adult":false,"title":"The Ponzi Scheme","video":false,"overview":"Ponzi, from his arrival in Boston in 1903, to hi death in Rio in 1949. He made himself famous in inventing the first fraud of modern times on a large scale, and inspired Bernard Madoff.","genre_ids":[36,18],"popularity":0.249,"vote_count":2,"poster_path":"/d6QrglHhOknYkwXjfGXUhonN3Oz.jpg","release_date":"2014-02-14","vote_average":7.8,"backdrop_path":"/n1DfrIwuSzs8jyzMPzRQeYAh5a8.jpg","original_title":"Le système de Ponzi","original_language":"fr"},{"id":1109402,"adult":false,"title":"Her Body","video":false,"overview":"A Czech high diver's Olympic dreams are shattered when she suffers a devastating injury while training. Forced to leave the sport she loves, she follows a photographer friend into the world of nude modeling, ultimately reinventing herself as an adult film actress. Inspired by the true story of diving champion Andrea Absolonová.","genre_ids":[18],"popularity":1.6021,"vote_count":39,"poster_path":"/foNYeBzrTpz94Sg9yV6hGMsax8A.jpg","release_date":"2023-11-16","vote_average":6,"backdrop_path":"/ffOxfVhSMcHiM26kWFQ9Lto4v6s.jpg","original_title":"Její tělo","original_language":"cs"},{"id":48764,"adult":false,"title":"The Trial of Joan of Arc","video":false,"overview":"Rouen, Normandy, 1431, during the Hundred Years' War. After being captured by French soldiers from an opposing faction, Joan of Arc, the Maid of Orléans, is unjustly tried by an ecclesiastical court overseen by her English enemies.","genre_ids":[18,36],"popularity":0.3783,"vote_count":147,"poster_path":"/gHb9UUow3j25sMCb3wDIZatfIg1.jpg","release_date":"1963-02-13","vote_average":7.19,"backdrop_path":"/kpjWEZvoMhiinhDArNJ31VXvgh5.jpg","original_title":"Procès de Jeanne d'Arc","original_language":"fr"},{"id":49006,"adult":false,"title":"Frozen Flashes","video":false,"overview":"In November of 1939, the British consulate in Norway receives documents saying that the Nazis are conducting secret rocket research in Peenemünde. But the British doubt the authenticity of the so called \"Oslo report\". Thus, the Germans continue their experiments unimpeded. At the same time, resistance groups from France, England, Poland, and Germany try to find and to sabotage the secret Nazi research base. When the first \"V 2\" rocket is successfully launched, the Allied commanders finally become interested in the \"Oslo report\".","genre_ids":[18,10752,53],"popularity":0.463,"vote_count":3,"poster_path":"/9mPtBGZKp8ntkdVxcrmmxFHHfHe.jpg","release_date":"1967-04-13","vote_average":7.3,"backdrop_path":"/whYhT1hRhiZg2VdTc49UScCPK8n.jpg","original_title":"Die gefrorenen Blitze","original_language":"de"},{"id":49009,"adult":false,"title":"The Way Back","video":false,"overview":"A small band of multicultural convicts stages a daring escape from a WWII-era Siberian gulag, and embarks on a treacherous journey across five countries in a desperate race for freedom and survival.","genre_ids":[18,12,36],"popularity":2.5382,"vote_count":1716,"poster_path":"/xQ6hxfpD5XQGJz0ekVle5zegam7.jpg","release_date":"2010-11-22","vote_average":7,"backdrop_path":"/jcQfgcq1j7Vit4wQ54niXiLfvE8.jpg","original_title":"The Way Back","original_language":"en"},{"id":49032,"adult":false,"title":"Iruvar","video":false,"overview":"A fictionalized account of the lives of 1980s Tamil Nadu political icons M. G. Ramachandran and M. Karunanidhi, continuing the tryst between Tamil cinema and Dravidian politics.","genre_ids":[36,18],"popularity":0.9535,"vote_count":51,"poster_path":"/meBNe0IHOhYNjNna2YlxXQ3iwvL.jpg","release_date":"1997-01-14","vote_average":7.422,"backdrop_path":"/zGl6uKZ1MSw8rSdvFHmnFCXnBTH.jpg","original_title":"இருவர்","original_language":"ta"},{"id":49046,"adult":false,"title":"All Quiet on the Western Front","video":false,"overview":"Paul Baumer and his friends Albert and Muller, egged on by romantic dreams of heroism, voluntarily enlist in the German army. Full of excitement and patriotic fervour, the boys enthusiastically march into a war they believe in. But once on the Western Front, they discover the soul-dest