5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Grandmaster\",\"description\":\"Ip Man's peaceful life in Foshan changes after Gong Yutian seeks an heir for his family in Southern China. Ip Man then meets Gong Er who challenges him for the sake of regaining her family's honor. After the Second Sino-Japanese War, Ip Man moves to Hong Kong and struggles to provide for his family. In the mean time, Gong Er chooses the path of vengeance after her father was killed by Ma San.\",\"image\":\"https://image.tmdb.org/t/p/w500/ydBVVIscL6TsX5hYztA5YpBCwJ3.jpg\",\"datePublished\":\"2013-01-10\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"zh\",\"genre\":[\"biographical film\",\"martial arts film\",\"drama film\",\"action film\",\"Action\",\"Drama\",\"History\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.62,\"bestRating\":10,\"ratingCount\":964}}"}}],["$","$L10",null,{"initialDrama":{"id":"3a826e87-70da-4e7a-83a9-b8aa791f472e","tmdb_id":44865,"imdb_id":"tt1462900","content_type":"movie","title":"The Grandmaster","original_title":"一代宗師","overview":"Ip Man's peaceful life in Foshan changes after Gong Yutian seeks an heir for his family in Southern China. Ip Man then meets Gong Er who challenges him for the sake of regaining her family's honor. After the Second Sino-Japanese War, Ip Man moves to Hong Kong and struggles to provide for his family. In the mean time, Gong Er chooses the path of vengeance after her father was killed by Ma San.","poster_path":"/ydBVVIscL6TsX5hYztA5YpBCwJ3.jpg","backdrop_path":"/H4mLTEtxBpjuMRNyL0MVqw1EdN.jpg","release_date":"2013-01-10","first_air_date":null,"status":"published","original_language":"zh","origin_country":["HK"],"genres":[{"name":"biographical film"},{"name":"martial arts film"},{"name":"drama film"},{"name":"action film"},{"id":28,"name":"Action"},{"id":18,"name":"Drama"},{"id":36,"name":"History"}],"popularity":4.1647,"vote_average":6.62,"vote_count":964,"runtime":130,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-11T21:59:39.881949+00:00","updated_at":"2026-03-15T20:55:34.011+00:00","tagline":"In Martial Arts there is no right or wrong, only the last man standing.","homepage":null,"budget":38600000,"revenue":64076736,"production_companies":[{"id":5686,"name":"Sil-Metropole Organisation","logo_path":"/o4aETXAP9HxOSRbGDWgBfkSzSJw.png","origin_country":"HK"},{"id":13184,"name":"Annapurna Pictures","logo_path":"/pfUB1a62jSMIqp4Xmaq6z2cgW0B.png","origin_country":"US"},{"id":539,"name":"Block 2 Pictures","logo_path":"/iPLtePguIzOPNtAWfTxWLXb2O11.png","origin_country":"HK"},{"id":540,"name":"Jet Tone Production","logo_path":"/gqx0uCS4P0hEgaDl61TfKODIwMe.png","origin_country":"HK"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":null,"in_production":false,"tmdb_status":"Released","content_rating":null,"keywords":[{"id":779,"name":"martial arts"},{"id":780,"name":"kung fu"},{"id":5565,"name":"biography"},{"id":185466,"name":"kung fu master"},{"id":256330,"name":"mischievous"},{"id":325856,"name":"vibrant"}],"alternative_titles":null,"videos":[{"id":"660740e5d5191f014b2fb008","key":"SI9_cWD3nyg","name":"THE GRANDMASTER | According to RZA","site":"YouTube","size":1080,"type":"Featurette","official":true,"iso_639_1":"en","iso_3166_1":"US","published_at":"2017-03-27T16:57:45.000Z"},{"id":"660740cba894d60130620083","key":"X1NEo9kgBF0","name":"THE GRANDMASTER | What Makes A Martial Artist?","site":"YouTube","size":1080,"type":"Featurette","official":true,"iso_639_1":"en","iso_3166_1":"US","published_at":"2017-03-27T16:57:44.000Z"},{"id":"660740de021cee016347f6f7","key":"P-8shuZKkqM","name":"THE GRANDMASTER | From Ip Man to Bruce Lee","site":"YouTube","size":1080,"type":"Featurette","official":true,"iso_639_1":"en","iso_3166_1":"US","published_at":"2017-03-27T16:57:44.000Z"},{"id":"660740c3021