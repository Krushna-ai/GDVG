},"ZW":{"link":"https://www.themoviedb.org/movie/1303236/watch?locale=ZW","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":4}]}}},"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/gaNsN1ojr3mhFBUexBpA4gJ7ejs.jpg","images":{"logos":[{"width":1069,"height":505,"file_path":"/2zLH3jv3cFDqDP5ihrhXs6FwlA9.png","iso_639_1":"zh","vote_average":0},{"width":362,"height":53,"file_path":"/xhocJ6WwhboBUvRzg7qFnOOdzT8.png","iso_639_1":"th","vote_average":0},{"width":812,"height":391,"file_path":"/5ZLtOBTur60flDeBiOX7Q1KXdUa.png","iso_639_1":"pt","vote_average":0}],"posters":[{"width":1000,"height":1500,"file_path":"/gaNsN1ojr3mhFBUexBpA4gJ7ejs.jpg","iso_639_1":"zh","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/2wkjPNIjmh5fEat7PmgA5eNtNIW.jpg","iso_639_1":"zh","vote_average":1.75},{"width":897,"height":1346,"file_path":"/rJnpwN59avSW5vOu9BPiReHkQl4.jpg","iso_639_1":"zh","vote_average":1.75},{"width":2000,"height":3000,"file_path":"/vqLsnK3WEPTxXhdajIorg3URRfk.jpg","iso_639_1":"zh","vote_average":0},{"width":898,"height":1346,"file_path":"/d5MC21pPLRLFde1ivgJxED0sTVV.jpg","iso_639_1":"pt","vote_average":0},{"width":898,"height":1346,"file_path":"/bAnA6uaSMGIYlY9mj8rtjft2GZc.jpg","iso_639_1":null,"vote_average":0},{"width":718,"height":1024,"file_path":"/u7SDfZMf624JOpU3rhdSgvwPiWR.jpg","iso_639_1":null,"vote_average":0},{"width":2000,"height":3000,"file_path":"/q3gDVzE2YZOTeb2CM0waSbBjc3b.jpg","iso_639_1":"ko","vote_average":0}],"backdrops":[{"width":1380,"height":776,"file_path":"/cBBIk8jCSt6vIVJkaCwjjDLSMKH.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/gcNPp7K1rQmRhHg2UHEQtLFYTRa.jpg","iso_639_1":null,"vote_average":3.334},{"width":1515,"height":853,"file_path":"/SdQT0VMHTNZ78piTQgrkwYOtGV.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/tZ3IoBhMlpxVd5sW3eCGZ3Uoudp.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/y0eVEz4O8pKFyx6qDTF0Z4GaUly.jpg","iso_639_1":"zh","vote_average":0},{"width":1280,"height":720,"file_path":"/geH69TFuIP3Hb0KSbmH3Qmly7b6.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T05:33:37.464+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":131,"tagline":"","homepage":"","overview":"麥可Michael哥（王陽明 飾）回來了，他「跟天借膽」 ，帶著瘋蠍子（張懷秋 飾）想拿下頂莊、北城、北館，在貴董（高捷 飾）、哈達（太保 飾）、勇桑（蔡振南 飾）的眼皮子底下賣藥，甚至想仗著自己幾分交情，拉攏勇桑的二把手清楓（孫鵬 飾），沒想到被打得灰頭土臉， 卻在這時，他看不上眼的土狗們阿猛（施名帥 飾）、阿慶（鄭人碩 飾）、宗保（張再興 飾），竟然能闖入仁哥（王識賢 飾）、憨春（陳萬號 飾）的賭場，搶下巨款，還活著回來，讓他又驚又喜。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"GATAO: Like Father Like Son","runtime":131,"tagline":"","homepage":"https://www.netflix.com/title/82045318","overview":"Michael and his right-hand man Scorpion, who find themselves embroiled in their father Ko's turf war against rival gangs in Taipei, setting off a conflict between old and new generations of gangsters. The film is the latest installment in the Gatao franchise, following the narrative of a young successor trying to expand his power while navigating the volatile underworld."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"角头：大桥头","runtime":131,"tagline":"","homepage":"","overview":"一句大佬牌桌的轻佻玩笑，让大桥头二代麦克愤而掀桌宣战，却教大桥头角头Ko桑陷入两难。而无端卷入这场四帮混战的，还有三个底层求生的土狗帮无名小卒。为了帮弟弟筹贷款，不惜铤而走险做起卖药生意，到头来却身不由己赌上性命。角头宇宙来到第四部，时间溯回世界之初，新老面孔齐聚一堂，摊开一幅江湖黑帮的岁月群像。血气火拼分毫不减，再奏响内敛情深的父子哀歌。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"เจ้าพ่อ: เชื้อร้ายไม่ทิ้งแถว","runtime":0,"tagline":"","homepage":"","overview":"ไมเคิล พ่อค้ายาเสพติดที่ทะเยอทะยาน และพี่น้องอย่างเฮียแมงป่อง ต้องเข้าไปพัวพันในสงครามช่วงชิงอาณาเขตของผู้เป็นพ่อ เมื่อบรรดาแก๊งคู่อริเปิดฉากแย่งชิงอำนาจในเมืองติงจวง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"가타오: 부전자전","runtime":131,"tagline":"","homepage":"","overview":"마이클과 그의 오른팔 스콜피온은 아버지 코가 타이베이에서 라이벌 갱단을 상대로 벌이는 세력 다툼에 휘말리게 되면서 구세대와 신세대 갱단 간의 갈등을 촉발합니다. 이 영화는 가타오 시리즈의 최신작으로, 젊은 후계자가 불안정한 암흑 세계를 헤쳐나가며 권력을 확장하려는 이야기를 담고 있습니다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Gatao: Tal Pai, Tal Filho","runtime":131,"tagline":"","homepage":"","overview":"O traficante Michael e seu braço direito, Scorpion, se envolvem na guerra territorial de seu pai, Ko, contra gangues rivais em Taipei, desencadeando um conflito entre velhas e novas gerações de gângsteres. O filme é o mais recente da franquia Gatao, seguindo a narrativa de um jovem sucessor que tenta expandir seu poder enquanto navega pelo submundo volátil."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Đầu Đảng Giang Hồ 4: Đại Kiểu Đầu","runtime":0,"tagline":"","homepage":"","overview":"Tay buôn thuốc tham vọng Michael và người anh Bò Cạp bất ngờ bị cuốn vào cuộc chiến giành địa bàn của bố họ khi các băng đảng đối địch cạnh tranh ở khu Đỉnh Trang."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":131,"tagline":"","homepage":"","overview":"Michael, le prince de la drogue, et Scorpion s'emparent des territoires des anciens, tandis que la tornade des familles de gangs entraîne trois moins que rien qui tentent de survivre. On ne sait jamais qui sera touché par la réalité à travers l'alternance des générations ?"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Гатао: Какъвто бащата, такъв синът","runtime":0,"tagline":"","homepage":"","overview":"Принцовете на дрогата, Майкъл и \"Скорпион\", завземат териториите на древните(по-възрастните).\r Семействата на бандите са въвлечени в спиралата на насилието."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Gatao: Like Father Like Son","runtime":0,"tagline":"","homepage":"","overview":"Prințul Drogurilor, Michael, și Scorpion cuceresc teritoriile bătrânilor. În vârtejul acesta de violență între familii de gangsteri, trei nimeni încearcă să supraviețuiască. Cine va fi mușcat de realitate în acest joc al generațiilor?"},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Gatao: Like Father Like Son","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"角頭－大橋頭","runtime":0,"tagline":"","homepage":"","overview":"麥可 Michael 哥（王陽明 飾）回來了，他「跟天借膽」 ，帶著瘋蠍子（張懷秋 飾）想拿下頂莊、北城、北館，在貴董（高捷 飾）、哈達（太保 飾）、勇桑（蔡振南 飾）的眼皮子底下賣藥，甚至想仗著自己幾分交情，拉攏勇桑的二把手清楓（孫鵬 飾），沒想到被打得灰頭土臉， 卻在這時，他看不上眼的土狗們阿猛（施名帥 飾）、阿慶（鄭人碩 飾）、宗保（張再興 飾），竟然能闖入仁哥（王識賢 飾）、憨春（陳萬號 飾）的賭場，搶下鉅款，還活著回來，讓他又驚又喜。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":131,"tagline":"","homepage":"","overview":"マイケルと右腕のスコーピオンは、父であるコーが台北でライバル組織と繰り広げる縄張り争いに巻き込まれ、新旧のギャング間の抗争が勃発する。本作は「ガタオ」シリーズの最新作で、不安定な裏社会を駆け抜けながら権力拡大を目指す若き後継者の物語を描いている。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":131,"tagline":"","homepage":"","overview":"Michael dan tangan kanannya, Scorpion, terlibat dalam perebutan wilayah kekuasaan ayah mereka, Ko, melawan geng-geng saingan di Taipei, yang memicu konflik antara generasi gangster lama dan baru. Film ini merupakan seri terbaru dari waralaba Gatao, mengikuti narasi seorang penerus muda yang mencoba memperluas kekuasaannya sambil menjelajahi dunia bawah yang penuh gejolak."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"","runtime":131,"tagline":"","homepage":"","overview":"Michael ve sağ kolu Akrep, kendilerini Taipei'deki rakip çetelere karşı babaları Ko'nun bölge savaşına karışmış halde bulurlar ve bu da eski ve yeni nesil gangsterler arasında bir çatışmaya yol açar. Film, Gatao serisinin son filmi olup, istikrarsız yeraltı dünyasında yolunu bulmaya çalışan genç bir halefin hikayesini konu alıyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"}],"reviews_tmdb":[],"recommendations":[{"id":1276073,"adult":false,"title":"Bullet Train Explosion","video":false,"overview":"When panic erupts on a Tokyo-bound bullet train that will explode if it slows below 100 kph, authorities race against time to save everyone on board.","genre_ids":[28,53,80,18],"media_type":"movie","popularity":3.2262,"vote_count":292,"poster_path":"/jmzxlDBwgvRbpPJzNQwizyn9UEn.jpg","release_date":"2025-04-23","vote_average":6.851,"backdrop_path":"/zHP9pMtYuMZBluNZNBP9i5fX2US.jpg","original_title":"新幹線大爆破","original_language":"ja"},{"id":890322,"adult":false,"title":"Love Like the Falling Petals","video":false,"overview":"Haruto Asakura falls in love with hairdresser Misaki Ariake and asks her out. Watching Misaki Ariake work hard to achieve what she wants, Haruto Asakura, who almost gave up his dream to become a photographer, begins to pursue his dream again, but Misaki Ariake is diagnosed with a disease that ages her 10x faster than normal.","genre_ids":[18,10749],"media_type":"movie","popularity":1.6065,"vote_count":99,"poster_path":"/8m2xnZAnMuydc87KCLS2gnUmidh.jpg","release_date":"2022-03-24","vote_average":7.99,"backdrop_path":"/hX9KuZQjZXrleVALumaNb6HJJ6M.jpg","original_title":"桜のような僕の恋人","original_language":"ja"},{"id":991898,"adult":false,"title":"Lost in Forest","video":false,"overview":"Asheng, once a gang member of the Zhongshan District, was sent to jail for 12 years after saving his friend Shaou. He is released and returns to Linsen North Road, his old turf, finding it familiar yet perplexing after being away for so many years. Shaou is now a mob boss with his own turf. When the son of Seagull’s patron, Mr. Xiao, is murdered, the evidence points to up-and-coming mobster Monkey. Shauo tries to ambush Monkey and fails, getting shot by the drugged up gangster instead. Asheng, who initially refused to help Shaou, is now filled with rage and decides to avenge his friend.","genre_ids":[28,80,18],"media_type":"movie","popularity":0.4135,"vote_count":3,"poster_path":"/7bcN5BUDsiNrRWu7pF5EeGAXqzU.jpg","release_date":"2023-01-13","vote_average":5.7,"backdrop_path":"/r7e472rOcx59GpPoT3gKM6hQ2UV.jpg","original_title":"山中森林","original_language":"zh"},{"id":1153714,"adult":false,"title":"Death of a Unicorn","video":false,"overview":"A father and daughter accidentally hit and kill a unicorn while en route to a weekend retreat, where his billionaire boss seeks to exploit the creature’s miraculous curative properties.","genre_ids":[27,14,35],"media_type":"movie","popularity":5.5661,"vote_count":736,"poster_path":"/xWlF2i51zUq7BUq4iJte1g9NyIM.jpg","release_date":"2025-03-27","vote_average":6.394,"backdrop_path":"/4rLaMBcCJ1pMq72vCulBMPsbAyh.jpg","original_title":"Death of a Unicorn","original_language":"en"},{"id":986056,"adult":false,"title":"Thunderbolts*","video":false,"overview":"After finding themselves ensnared in a death trap, seven disillusioned castoffs must embark on a dangerous mission that will force them to confront the darkest corners of their pasts.","genre_ids":[28,878,12],"media_type":"movie","popularity":17.7086,"vote_count":3219,"poster_path":"/hqcexYHbiTBfDIdDWxrxPtVndBX.jpg","release_date":"2025-04-30","vote_average":7.3,"backdrop_path":"/jYCyTdPfgT01IOJWDnnetr9RDX6.jpg","original_title":"Thunderbolts*","original_language":"en"},{"id":18,"adult":false,"title":"The Fifth Element","video":false,"overview":"In 2257, a taxi driver is unintentionally given the task of saving a young girl who is part of the key that will ensure the survival of humanity.","genre_ids":[878,28,12],"media_type":"movie","popularity":12.4182,"vote_count":11455,"poster_p