o_639_1":"en","vote_average":2.278},{"width":2000,"height":2964,"file_path":"/8LeqWRwPXsKxsgdPUxG9ELDxPvr.jpg","iso_639_1":"en","vote_average":1.222},{"width":2000,"height":3000,"file_path":"/8wLl2hicM6dI34OJ30ry1CKLN2D.jpg","iso_639_1":"en","vote_average":0.166},{"width":1476,"height":2197,"file_path":"/mfmw1VX1KXU2VtcvcRZOoDdPKaH.jpg","iso_639_1":"ro","vote_average":0},{"width":2000,"height":2964,"file_path":"/q0TgVS4Zzu2Z4yjGJM2HxwHJ8cH.jpg","iso_639_1":null,"vote_average":0},{"width":2000,"height":2964,"file_path":"/a8lVi8yscBYsoFQs5nVOjXm2USz.jpg","iso_639_1":"ru","vote_average":0},{"width":2000,"height":3000,"file_path":"/fG2rcf2bmpGdQZucEXdLNxfZRAz.jpg","iso_639_1":"ru","vote_average":0},{"width":2000,"height":2964,"file_path":"/isU1MgAH60dhazqXBwj3d2c4qBv.jpg","iso_639_1":"fa","vote_average":0},{"width":1024,"height":1433,"file_path":"/79UAwZXaUyvz7cBuwipboj5BTBz.jpg","iso_639_1":"es","vote_average":0},{"width":1000,"height":1500,"file_path":"/qOB8fScJGUjKXKtRBW3VFg080ia.jpg","iso_639_1":"es","vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/6RnV2BIPzB6qZStmFyUnWuDkEp6.jpg","iso_639_1":null,"vote_average":3.334},{"width":3730,"height":2098,"file_path":"/c5HfaZXhXCv1jwWBYuyD8xPOW3M.jpg","iso_639_1":null,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/cYEp7xxp1MrEkCPGDP7jE2Ny6H9.jpg","iso_639_1":null,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/a3bAi97mvFrX6iCCBeXiqRzwGHa.jpg","iso_639_1":null,"vote_average":1.222},{"width":1964,"height":1105,"file_path":"/riRr7Ij3RGMpEhLLPCOnqdDmkOv.jpg","iso_639_1":null,"vote_average":1.222},{"width":2000,"height":1125,"file_path":"/t0VS1n2VThZ32U3o6zyHktJ22OF.jpg","iso_639_1":null,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/xjs6Z4K2odOO64SBdo8IUZOSRwO.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/cJ8imdeWn6gm8VlqL6wI5NeGoh.jpg","iso_639_1":"en","vote_average":0}]},"enriched_at":"2026-04-21T03:52:42.205+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":109,"tagline":"","homepage":"","overview":"The incredible, untold true story of how a group of prisoners attempt a seemingly impossible escape from the first Nazi death camp in order to provide the first eyewitness account of the Holocaust."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"The World Will Tremble","runtime":109,"tagline":"","homepage":"","overview":"Po południu 19 stycznia 1942 r. W pierwszym nazistowskim obozie śmierci potajemnie zbudowanym w Polsce grupa polskich żydowskich więźniów próbuje coś nie do pomyślenia. Utrzymywani w niewoli jako Gravediggers, zmuszeni do zakopania ciał mężczyzn, kobiet i dzieci zamordowanych w furgonetkach gazowych, decydują się na odważną ucieczkę. Nawet po tym, jak stracili rodziny, zakopując je własnymi rękami, są zdeterminowani, aby uciec, nie dla siebie, ale powiadomić świat o tym, co się dzieje. Korzystając z skradzionego odłamka szkła, więźniowie Solomon Wiener i Michael Podchlebnik rozdzierają ciężarówkę transportową i wtargną do lasu. Uciekając ze strzelanin i ścigających nazistowskich strażników, Salomon i Michael przemierzają szalejącą rzeką, obok niemieckich żołnierzy i polskiej policji, zanim staną się pierwszymi mężczyznami, którzy uciekli z nazistowskiego obozu śmierci, tworząc pierwszą relację na świecie o Holokauście."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"The World Will Tremble","runtime":109,"tagline":"","homepage":"","overview":"Het ongelooflijke, nooit eerder vertelde, waargebeurde verhaal over een groep gevangenen die een schijnbaar onmogelijke ontsnappingspoging doen uit het eerste naziconcentratiekamp. Zo willen ze het eerste ooggetuigenverslag van de Holocaust schrijven."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"La impactante historia real de Michał Podchlebnik y Solomon Weiner, dos prisioneros que se convirtieron en los primeros en escapar del campo de exterminio de Chełmno en enero de 1942, y que valientemente dieron testimonio de los horrores perpetrados por el régimen alemán. De los más de 320.000 judíos enviados a Chełmno, solo sobrevivieron cuatro: dos de ellos fueron Weiner y Podchlebnik, que lo arriesgaron todo para sacar a la luz la verdad. Situado cerca de Łódź, Chełmno fue uno de los seis campos de exterminio creados exclusivamente para el asesinato en masa durante la Segunda Guerra Mundial."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Thế Giới Hiểm Nguy","runtime":0,"tagline":"","homepage":"","overview":"Bộ phim dựa trên câu chuyện có thật đầy kinh ngạc về một nhóm tù nhân trong Thế chiến thứ hai, những người đã thực hiện một cuộc trốn thoát tưởng chừng bất khả thi khỏi trại hủy diệt Chełmno - trại tử thần đầu tiên của Đức Quốc xã - nhằm cung cấp bằng chứng trực tiếp đầu tiên về Holocaust (Cuộc diệt chủng Do Thái).phim xoay quanh Solomon Wiener (Oliver Jackson-Cohen) và Michael Podchlebnik (Jeremy Neumark Jones), hai tù nhân tại trại Chełmno, nơi hàng ngàn người, chủ yếu là người Do Thái, bị sát hại dã man bằng cách ngạt khí trong các xe tải. Họ chứng kiến những cảnh tượng kinh hoàng: những con người bị giết chết bằng khí độc, tiếng hét của các nạn nhân khi họ ngạt thở, và những thi thể bị chôn vùi trong các hố chôn tập thể. Trước thực tại rằng cái chết là không thể tránh khỏi nếu ở lại, nhóm tù nhân, bao gồm cả Solomon và Michael, quyết định lên kế hoạch trốn thoát để cảnh báo thế giới về những gì đang xảy ra."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Lumea se va cutremura","runtime":0,"tagline":"","homepage":"","overview":"Povestea adevărată incredibilă, nespusă, despre cum un grup de prizonieri încearcă o evadare aparent imposibilă din primul lagăr de exterminare nazist pentru a oferi prima relatare a Holocaustului."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Neuvěřitelný, dosud nevyprávěný skutečný příběh o tom, jak se skupina vězňů pokusila o zdánlivě nemožný útěk z prvního nacistického tábora smrti, aby poskytla první očité svědectví o holocaustu."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"העולם ירעד","runtime":109,"tagline":"","homepage":"","overview":"אחר הצהריים של 19 בינואר 1942, במחנה ההשמדה הנאצי הראשון שנבנה בחשאי בפולין, קבוצה של אסירים יהודים פולנים מנסים את הבלתי מתקבל על הדעת. כשהם בשבי כחפרים, נאלצים לקבור את גופותיהם של גברים, נשים וילדים שנרצחו בטנדרי גז, הם מחליטים לפתוח בבריחה נועזת. גם לאחר שאיבדו את משפחותיהם, קברו אותן במו ידיהם, הם נחושים לברוח, לא למען עצמם, אלא להתריע בפני העולם על המתרחש."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Мир содрогнётся","runtime":0,"tagline":"","homepage":"","overview":"В основе фильма реальная история побега из лагеря смерти Хелмно во время Второй мировой войны. 19 января 1942 года в первом нацистском лагере смерти, тайно построенном в Польше, группа польских еврейских заключенных пытается совершить нечто невообразимое. Герои, захваченные в плен как могильщики, вынуждены хоронить тела мужчин, женщин и детей, убитых в газовых камерах, и они решаются на дерзкий побег. Даже после угрозы похоронить свои семьи собственными руками они полны решимости бежать — не ради себя, а чтобы предупредить мир о том, что происходит. Используя украденный осколок стекла, заключенные Соломон и Михал сбегают в лес. Преследуемые нацистскими пограничниками, герои пересекают бурную реку, убегают от немецких солдат и польских полицейских, становясь первыми беженцами из нацистского лагеря смерти и первыми в мире очевидцами Холокоста."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"世界将颤抖","runtime":0,"tagline":"","homepage":"","overview":"　　这是一个令人难以置信的、不为人知的真实故事，讲述了一群囚犯如何试图从第一个纳粹死亡集中营中看似不可能的逃脱，以提供大屠杀的第一视角描述。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Neverjetna, še neizpovedana resnična zgodba o tem, kako skupina zapornikov poskuša na videz nemogoč pobeg iz prvega nacističnega taborišča smrti, da bi svetu posredovala prvo pričevanje o holokavstu."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"جهان خواهد لرزید","runtime":0,"tagline":"","homepage":"","overview":"فیلم براساس داستانی واقعی روایت شده و در مورد گروهی از زندانیان است که تلاش می‌کنند در طول جنگ جهانی دوم از نخستین اردوگاه مرگ نازی‌ها فرار کنند. ماجرایی به‌ظاهر غیرممکن که هدفش افشای جنایات هولوکاست برای جهانیان بود و ..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"O Mundo Vai Tremer","runtime":0,"tagline":"","homepage":"","overview":"A incrível e não contada história real de como um grupo de prisioneiros tenta uma fuga aparentemente impossível do primeiro campo de extermínio nazista para fornecer o primeiro relato de testemunha ocular do Holocausto."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Світ здригнеться","runtime":0,"tagline":"","homepage":"","overview":"Дія фільму відбувається під час Другої світової війни. Молодого єврея разом з іншими людьми привозять у табір смерті Хелмно. Це територія, де щодня вбивають сотні людей. Хлопця відразу відділяють від інших. Його ставлять у групу, яка прибирає речі загиблих, копає ями і виконує накази охоронців. Усі навколо мовчать. Ніхто не дивиться в очі. Розмови можуть коштувати життя. У таборі хлопець знайомиться з кількома іншими в’язнями, які вже давно там. Деякі з них задумали втечу. Вони говорять про це мало і обережно.\r У кожного є своє завдання - хтось спостерігає за графіком охорони, хтось запам’ятовує розташування інструментів і дверей. Хлопець теж починає потроху втягуватись у цей план.  Побут у таборі дуже важкий. Їжу дають один раз на день. Будь-яке відхилення від правил карається жорстко. Люди бояться навіть озирнутися зайвий раз. Але ті, хто бере участь у підготовці, поводяться як звичайно. План формується повільно, шматками, через погляди, короткі фрази і мовчазну згоду."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"더 월드 윌 트렘블","runtime":0,"tagline":"","homepage":"","overview":"나치 최초의 죽음의 수용소에서 탈출을 시도한 수감자들의 믿기 어려운, 알려지지 않은 실화. 홀로코스트에 대한 최초의 목격자 증언을 전하기 위한, 불가능해 보이는 탈출 시도."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"La resistencia invisible","runtime":0,"tagline":"","homepage":"","overview":"La impactante historia real de Michał Podchlebnik y Solomon Weiner, dos prisioneros que se convirtieron en los primeros en escapar del campo de exterminio de Chełmno en enero de 1942, y que valientemente dieron testimonio de los horrores perpetrados por el régimen alemán. De los más de 320.000 judíos enviados a Chełmno, solo sobrevivieron cuatro: dos de ellos fueron Weiner y Podchlebnik, que lo arriesgaron todo para sacar a la luz la verdad. Situado cerca de Łódź, Chełmno fue uno de los seis campos de exterminio creados exclusivamente para el asesinato en masa durante la Segunda Guerra Mundial."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"}],"reviews_tmdb":[{"id":"68234b2a4b49537fd2a16787","url":"https://www.themoviedb.org/review/68234b2a4b49537fd2a16787","author":"Brent Marchant","content":"$11","created_at":"2025-05-13T13:37:46.460Z","updated_at":"2025-05-13T13:37:46.724Z","author_details":{"name":"Brent Marchant","rating":6,"username":"Brent_Marchant","avatar_path":null}}],"recommendations":[{"id":1278656,"adult":false,"title":"Liza: A Truly Terrific Absolutely True Story","video":false,"overview":"Rich with archival gems and Liza Minnelli’s own point of view, Bruce David Klein's luminous documentary celebrates a young entertainer full of boundless raw talent and the deep, creative relationships with her mentors and influences.","genre_ids":[99,10402],"media_type":"movie","popularity":0.5709,"vote_count":15,"poster_path":"/xQG9oxaSe7BVOIlp4MvAgqyGW7p.jpg","release_date":"2025-01-24","vote_average":8,"backdrop_path":"/sTQjMTGFJzRDyajlqjIMpiEL8TU.jpg","original_title":"Liza: A Truly Terrific Absolutely True Story","original_language":"en"},{"id":1058128,"adult":false,"title":"The Astronaut Lovers","video":false,"overview":"Pedro travels from Spain to Argentina for a vacation at his uncle's home, where he meets Maxi again, a childhood friend. Maxi is surprised when he finds out Pedro is gay. When Maxi finds his ex-girlfriend is also there, he asks Pedro to pretend to be his boyfriend to win her back. Pedro accepts the game, unaware of the dangers of playing with love.","genre_ids":[35,18,10749],"media_type":"movie","popularity":1.001,"vote_count":56,"poster_path":"/hyu2nt255VLL4RgGCAtcDK8RLv3.jpg","release_date":"2024-06-20","vote_average":8.214,"backdrop_path":"/9unmtNASKsj8OmPWQ2VQCcCWF00.jpg","original_title":"Los amantes astronautas","original_language":"es"},{"id":1386047,"adult":false,"title":"My Partners","video":false,"overview":"Three Estonian and German couples explore polyamory, confronting ego, desire, and insecurity while redefining love. Guided by mentors, psychologists, shamans, and dancers, they navigate years of sexual freedom and emotional struggle under filmmaker Eva Kübar’s patient lens. After a decade together, Riita and Taavi open their relationship and join a camp where unconventional practices test their limits. Marianne and Sven attempt to save their marriage for their children, though Marianne’s bond with her lover Kay complicates her promise to stay faithful. For Kay’s wife Beate, Marianne’s presence becomes both a threat and an opportunity for growth.","genre_ids":[99],"media_type":"movie","popularity":0.5071,"vote_count":3,"poster_path":"/7JdFCKQQp5ee21ggDKOAUwziXDg.jpg","release_date":"2025-03-14","vote_average":8.7,"backdrop_path":"/z0e0NLYTw1scnuKkrqTO2F9dqgl.jpg","original_title":"Minu kallimad","original_language":"et"},{"id":30388,"adult":false,"title":"Reykjavik Whale Watching Massacre","video":false,"overview":"An epic tale about a group of whale watchers, whose ship breaks down and they get picked up by a whale fisher vessel. The Fishbillies on the vessel has just gone bust, and everything goes out of control.","genre_ids":[35,27],"media_type":"movie","popularity":0.227,"vote_count":59,"poster_path":"/n6RoIohCmo2xfBVG855fUq9REw4.jpg","release_date":"2009-09-04","vote_average":4.475,"backdrop_path":"/6z1DNOKDfi9awlrILIn0xWm1vcQ.jpg","original_title":"Reykjavik Whale Watching Massacre","original_language":"en"},{"id":1233575,"adult":false,"title":"Black Bag","video":false,"overview":"When intelligence agent Kathryn Woodhouse is suspected of betraying the nation, her husband – also a legendary agent – faces the ultimate test of whether to be loyal to his marriage, or his country.","genre_ids":[18,9648,53],"media_type":"movie","popularity":5.9531,"vote_count":1113,"poster_path":"/hHPovtU4b96LHcoeEwRkGHI5btw.jpg","release_date":"2025-03-12","vote_average":6.342,"backdrop_path":"/gxO51FVgADhYGGnnRPIlutVqb30.jpg","original_title":"Black Bag","original_language":"en"},{"id":1165067,"adult":false,"title":"Cosmic Chaos","video":false,"overview":"Battles in virtual reality, survival in a post-apocalyptic wasteland, a Soviet spaceship giving a distress signal - Fantastic stories created with advanced special effects and passion.","genre_ids":[53,878],"media_type":"movie","popularity":1.5069,"vote_count":50,"poster_path":"/mClzWv7gBqgXfjZXp49Enyoex1v.jpg","release_date":"2023-08-03","vote_average":6,"backdrop_path":"/m2mzlsJjE3UAqeUB5fLUkpWg4Iq.jpg","original_title":"Cosmic Chaos","original_language":"en"},{"id":44446,"adult":false,"title":"Angelique and the Sultan","video":false,"overview":"Angélique is in a North African Muslim kingdom where she is now part of the Sultan's harem. She refuses to be bedded as her captors try to beat sense into her. She finally decides to escape with the help of two Christian prisoners.","genre_ids":[12,10749,36],"media_type":"movie","popularity":0.9233,"vote_count":118,"poster_path":"/mqENboMTcwRg09lm6wO1eyPaWgJ.jpg","release_date":"1968-03-13","vote_average":6.347,"backdrop_path":"/wthhvdweznzC1hKWaQtxlTfgJOv.jpg","original_title":"Angélique et le Sultan","original_language":"fr"},{"id":245700,"adult":false,"title":"Mr. Turner","video":false,"overview":"Eccentric British painter J.M.W. Turner  lives his last 25 years with gusto and secretly becomes involved with a seaside landlady, while his faithful housekeeper bears an unrequited love for him.","genre_ids":[36,18],"media_type":"movie","popularity":1.3856,"vote_count":575,"poster_path":"/rnVhl1PFSOoW5c6UhZJZt5TV98p.jpg","release_date":"2014-10-31","vote_average":6.538,"backdrop_path":"/74IaLYwgko2nTLj8Gz9ukQ4RIvC.jpg","original_title":"Mr. Turner","original_language":"en"},{"id":1008409,"adult":false,"title":"The Bikeriders","video":false,"overview":"After a chance encounter, headstrong Kathy is drawn to Benny, member of Midwestern motorcycle club the Vandals. As the club transforms into a dangerous underworld of violence, Benny must choose between Kathy and his loyalty to the club.","genre_ids":[80,18],"media_type":"movie","popularity":4.5711,"vote_count":1073,"poster_path":"/ApMuukdDAOR2rgaFDZIcjfigi64.jpg","release_date":"2024-06-19","vote_average":6.678,"backdrop_path":"/kwGvFyRtGSSm8AFfnRNXoZTQmJj.jpg","original_title":"The Bikeriders","original_language":"en"},{"id":972614,"adult":false,"title":"Knox Goes Away","video":false,"overview":"A contract killer, after being diagnosed with a fast-moving form of dementia, is presented with the opportunity to redeem himself by saving the life of his estranged adult son. But to do so, he must race against the police closing in on him as well as the ticking clock of his own rapidly deteriorating mind.","genre_ids":[28,80,53],"media_type":"movie","popularity":2.1231,"vote_count":464,"poster_path":"/w39qKYjltCix18BwtoZ1e45usdb.jpg","release_date":"2024-03-15","vote_average":6.969,"backdrop_path":"/2NPhBHfzhEmXl8csQ2dKmoxfj5e.jpg","original_title":"Knox Goes Away","original_language":"en"},{"id":1039690,"adult":false,"title":"Desperation Road","video":false,"overview":"Ex-con Russell Gaines is attempting to rebuild his life with the help of his father, Mitchell. However, the arrival of Maben sends his new life into chaos, leading the pair to go on the run - as their violent pasts catch up to them, the pair must learn to trust each other if they hope to live out the rest of their days.","genre_ids":[53,28,80,18],"media_type":"movie","popularity":1.7028,"vote_count":152,"poster_path":"/tPyj6Gii1HrnzCbJXEF7JdSFkQ8.jpg","release_date":"2023-10-19","vote_average":6.658,"backdrop_path":"/vGyWFIyTN3U7SvbnT0BWQvXXzM5.jpg","original_title":"Desperation Road","original_language":"en"},{"id":1058647,"adult":false,"title":"The Deepest Breath","video":false,"overview":"Bonded by their love of freediving, a record-setting champion and a heroic safety diver try to make history with a remarkable feat, ready to risk it all.","genre_ids":[99],"media_type":"movie","popularity":0.6886,"vote_count":172,"poster_path":"/4gKAn4npGEBi0HZAbwFZ77reLBR.jpg","release_date":"2023-01-21","vote_average":7.596,"backdrop_path":"/8J0gmuwmq8z7TI4YuWDTclHoB75.jpg","original_title":"The Deepest Breath","original_language":"en"},{"id":989672,"adult":false,"title":"Just the Two of Us","video":false,"overview":"When Blanche meets Grégoire, she thinks she has found the one. The ties that bind them grow quickly, and a passionate affair ensues. Together, they relocate. For Blanche, far from her family, from her twin sister, Rose, a new life begins. But little by little, she finds herself caught in the grip of a deeply possessive and dangerous man.","genre_ids":[53,18,10749],"media_type":"movie","popularity":0.8034,"vote_count":323,"poster_path":"/bMYUYy5rR08Zh3pAmmWMH2gsrZV.jpg","release_date":"2023-05-24","vote_average":6.952,"backdrop_path":"/81xLmjnYHgmumzZJc4z4JCK6tWa.jpg","original_title":"L'Amour et les Forêts","original_language":"fr"},{"id":946706,"adult":false,"title":"Lost & Found","video":false,"overview":"Mario, a worker in \"lost and found\" department, finds a suitcase with a dead baby inside.","genre_ids":[9648,53],"media_type":"movie","popularity":0.3837,"vote_count":133,"poster_path":"/7hrSRxsd7nZ7Myg7SpvxJ7EWItO.jpg","release_date":"2022-09-30","vote_average":6.06,"backdrop_path":"/5s7zDN0nAuio5eMcWqsrsB2ibjK.jpg","original_title":"Objetos","original_language":"es"},{"id":1373723,"adult":false,"title":"The Codes of War","video":false,"overview":"War stories about family, ethics and honor include the true story of two U.S. Marines who in a span of six seconds, must stand their ground to stop a suicide truck bomb, a Navy Corpsman who attempts to hold on to his humanity, and a WW2 soldier who gets separated from his squad and is forced to re-evaluate his code.","genre_ids":[28,10752],"media_type":"movie","popularity":1.8275,"vote_count":62,"poster_path":"/oXeiQAfRK90pxxhP5iKPXQqAIN1.jpg","release_date":"2025-03-20","vote_average":6.2,"backdrop_path":"/ibF5XVxTzf1ayzZrmiJqgeQ39Qk.jpg","original_title":"The Codes of War","original_language":"en"},{"id":1043905,"adult":false,"title":"Dirty Angels","video":false,"overview":"During the United States' 2021 withdrawal from Afghanistan, a group of female soldiers posing as medical relief are sent back in to rescue a group of kidnapped teenagers caught between ISIS and the Taliban.","genre_ids":[18,53,10752],"media_type":"movie","popularity":4.7115,"vote_count":363,"poster_path":"/1y3