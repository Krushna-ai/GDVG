/2F9ehnivU8zvKZf17UWpE7RjYxx.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T06:49:57.979+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":106,"tagline":"","homepage":"","overview":"Janice's steamy obsession to imitate Lexi propels them to campus stardom. But dark secrets blur the lines between authenticity and seductive deception."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Janice's stomende obsessie om Lexi te imiteren brengt hen naar het sterrendom op de campus. Maar duistere geheimen vervagen de grenzen tussen authenticiteit en verleidelijk bedrog."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"床位","runtime":0,"tagline":"","homepage":"","overview":"珍妮丝对模仿莱克西的炽热痴迷促使她们在校园内一举成名。然而，深藏不露的秘密模糊了真实本我和诱人欺骗之间的界限。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Съквартирантка","runtime":106,"tagline":"","homepage":"","overview":"Страхотната мания на Джанис да имитира Лекси ги тласка към славата на колежа.  Но тъмните тайни размиват границите между автентичността и съблазнителната измама."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"그녀의 유혹","runtime":0,"tagline":"힘든 시기 만나게 된 룸메이트와의 운명적인 사랑, 집착과 욕망이 뒤섞인 그녀들의 사랑 이야기","homepage":"","overview":"곤혹스러운 상황에서 자신을 구해주었던 렉시와 룸메이트가 된 제니스. 그녀의 렉시를 향한 동경심은 우울하고 소심했던 생활에서 벗어날 수 있는 원동력이 된다. 그들의 뜨거운 우정은 점차 렉시를 향한 제니스의 집착으로 번져가고, 둘의 비슷해진 모습이 화제가 되어 이전과는 전혀 다른 일상을 맞이한다. 그러나 서서히 드러난 그녀들의 화려한 일상에 숨겨져 있던 서로의 비밀로 인해 예측할 수 없는 일들에 휩싸이게 되는데···"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Bedspacer: Sündiger Campus","runtime":106,"tagline":"","homepage":"","overview":"Als die geheimnisumwitterte Janice die Highschool wechselt, ist sie anfangs Außenseiterin. Bis die neue Zimmergenossin Lexi in ihr Leben tritt. Die beiden werden Freunde. Sie überschreiten immer mehr Grenzen, haben ausschweifenden Sex, nehmen Drogen. Doch bald zeigt sich, dass Janice Lexis Identität stehlen will."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":106,"tagline":"","homepage":"","overview":"L'obsession vaporeuse de Janice pour l'imitation de Lexi la propulse au rang de star du campus. Mais de sombres secrets brouillent les frontières entre l'authenticité et la tromperie séduisante."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"}],"reviews_tmdb":[],"recommendations":[{"id":213867,"adult":false,"title":"Loveblind","video":false,"overview":"A highly stylized morality play presented as an erotic drama.","genre_ids":[18,10749],"media_type":"movie","popularity":0.2965,"vote_count":4,"poster_path":"/tD4A540xzMBWxHLDJrosNN6o33D.jpg","release_date":"2000-01-25","vote_average":3.5,"backdrop_path":null,"original_title":"Loveblind","original_language":"en"},{"id":37770,"adult":false,"title":"Fantozzi to the Rescue","video":false,"overview":"Fantozzi is now retired but continues to go to the office where it is held up as a fine example of employees intending to do career.","genre_ids":[35],"media_type":"movie","popularity":0.3302,"vote_count":356,"poster_path":"/jJWsCKzOtDHqoRQlW6S8j5a29eX.jpg","release_date":"1990-12-21","vote_average":6.049,"backdrop_path":"/2jeuM7yHUcXF7WUubnuJO4tXosT.jpg","original_title":"Fantozzi alla riscossa","original_language":"it"},{"id":4481,"adult":false,"title":"Manon of the Spring","video":false,"overview":"In this, the sequel to Jean de Florette, Manon has grown into a beautiful young shepherdess living in the idyllic Provencal countryside. She plots vengeance on the