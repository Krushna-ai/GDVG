.","genre_ids":[18],"popularity":0.3349,"vote_count":4,"poster_path":"/xVtQhvCoWm31YlV2X29oipFYfgi.jpg","release_date":"2021-04-16","vote_average":6.2,"backdrop_path":"/bcq3NNEwXeRFvBFtI9kTfXFlJw8.jpg","original_title":"Beast Beast","original_language":"en"},{"id":462677,"adult":false,"title":"Doraemon: Nobita's Great Adventure in the Antarctic Kachi Kochi","video":false,"overview":"Doraemon and Nobita discover a mysterious golden ring far beneath the ice in Antarctica, leading them to uncover an ancient, ruined city.","genre_ids":[16,12,14,10751],"popularity":1.617,"vote_count":101,"poster_path":"/hcydn0Lr3DAixZFOaUmjoqoIFU6.jpg","release_date":"2017-03-04","vote_average":6.5,"backdrop_path":"/3W2I33pTXWMiH8py382Zg86OB9Q.jpg","original_title":"映画ドラえもん のび太の南極カチコチ大冒険","original_language":"ja"},{"id":462645,"adult":false,"title":"Dearest Jane","video":false,"overview":"A young girl learn to accept love and change, after being sent to live with her uncle in Indiana.","genre_ids":[18,10749],"popularity":0.922,"vote_count":6,"poster_path":"/x74uQ0IixD6Kdyu8zOzp6s6gdeu.jpg","release_date":"2015-03-01","vote_average":4.167,"backdrop_path":null,"original_title":"Dearest Jane","original_language":"en"},{"id":858017,"adult":false,"title":"I Saw the TV Glow","video":false,"overview":"Teenager Owen is just trying to make it through life in the suburbs when his classmate Maddy introduces him to a mysterious TV show — a vision of a supernatural world beneath their own. In the pale glow of the television, Owen’s view of reality begins to crack.","genre_ids":[18,27],"popularity":3.8609,"vote_count":625,"poster_path":"/hS4GYkYpN1rfl4GIxyc02sCyfAj.jpg","release_date":"2024-05-03","vote_average":6.1,"backdrop_path":"/jKulL2hdp5S7dVbpoItAtdCyzXI.jpg","original_title":"I Saw the TV Glow","original_language":"en"},{"id":274601,"adult":false,"title":"Sunset Limousine","video":false,"overview":"Alan O'Black is a comic who wants to hit it big. But his endless attempts at stardom have worn down his relationship with his ex-girlfriend, Julie. Thinking she'll give him another chance if he gets a real job, Alan gets a gig as a limo driver, which promptly lands him in a slew of trouble when he meets and gets involved in the hijinks of a crooked entrepreneur, Bradley Coleman.","genre_ids":[10770,35],"popularity":0.3776,"vote_count":7,"poster_path":"/fBlBhrTQxRy6JgF3b9KLgnWww9j.jpg","release_date":"1983-10-12","vote_average":4,"backdrop_path":null,"original_title":"Sunset Limousine","original_language":"en"},{"id":1062807,"adult":false,"title":"SPY x FAMILY CODE: White","video":false,"overview":"While under the guise of taking his family on a weekend winter getaway, Loid's attempt to make progress on his current mission Operation Strix proves difficult when Anya mistakenly gets involved and triggers events that threaten world peace.","genre_ids":[16,35,12,28],"popularity":5.0115,"vote_count":610,"poster_path":"/xlIQf4y9eB14iYzNN142tROIWON.jpg","release_date":"2023-12-22","vote_average":7.1,"backdrop_path":"/zVDJ4cRgSpHlILSm7kGiklHQ6O7.jpg","original_title":"劇場版 SPY×FAMILY CODE: White","original_language":"ja"},{"id":3176,"adult":false,"title":"Battle Royale","video":false,"overview":"In the future, the Japanese government captures a class of ninth-grade students and forces them to kill each other under the revolutionary \"Battle Royale\" act.","genre_ids":[18,53,28],"popularity":4.7403,"vote_count":3730,"poster_path":"/aLGKAQKgzWpJ6egyWzzC11jXBRJ.jpg","release_date":"2000-12-16","vote_average":7.3,"backdrop_path":"/amBvmIshdsSkOtvVIgxl7YSQ9Dg.jpg","original_title":"バトル・ロワイアル","original_language":"ja"},{"id":467467,"adult":false,"title":"A Moment in the Reeds","video":false,"overview":"Having moved to Paris for university, Leevi returns to his native Finland for the summer to help his estranged father renovate the family lake house so it can be sold. Tareq, a recent asylum seeker from Syria, has been hired to help with the work, and when Leevi's father has to return to town on business, the two young men establish a connection and embark on a romance set against the idyllic Finnish summer. However, looming over this chance encounter, is the father's imminent return to the lake house, the continuation of Leevi's studies abroad as well as Tareq's complex relationship with his family in Syria.","genre_ids":[10749,18],"popularity":0.2428,"vote_count":87,"poster_path":"/zqRTsyY7Hzse7vW5n7zSZWurhgx.jpg","release_date":"2018-06-29","vote_average":6.1,"backdrop_path":"/gfmnus8JsIA8uuP5rfa27pvPXyP.jpg","original_title":"Tämä hetki kaislikossa","original_language":"fi"},{"id":467260,"adult":false,"title":"Chinpira","video":false,"overview":"Osamu rescues a girl who was being chased by two punks and is soon mixed up with the Yakuza","genre_ids":[18,80],"popularity":0.2639,"vote_count":1,"poster_path":"/oeMvhGzDFtEqe5MhLxQ3A4Dkohc.jpg","release_date":"2000-11-11","vote_average":7,"backdrop_path":"/kjhGSa0izGAHkmih0niU6uc5jSq.jpg","original_title":"弱虫　チンピラ","original_language":"ja"},{"id":3084,"adult":false,"title":"Wuthering Heights","video":false,"overview":"Young orphan Heathcliff is adopted by the wealthy Earnshaw family and moves into their estate, Wuthering Heights. Soon, the new resident falls for his compassionate foster sister, Cathy. The two share a remarkable bond that seems unbreakable until Cathy, feeling the pressure of social convention, suppresses her feelings and marries Edgar Linton, a man of means who befits her stature. Heathcliff vows to win her back.","genre_ids":[18,10749],"popularity":6.3192,"vote_count":305,"poster_path":"/pwHdSzXwlUFAcYGcFutKcPcX2OW.jpg","release_date":"1939-04-07","vote_average":7.169,"backdrop_path":"/qWSWJnq38eVYrMzs6YkxRT8yMYK.jpg","original_title":"Wuthering Heights","original_language":"en"},{"id":857862,"adult":false,"title":"EVANGELION: DEATH (TRUE)²","video":false,"overview":"A highly experimental film presenting a story out of chronological order taking place 15 years after a near-apocalyptic catastrophe, about four traumatized 14 year olds who are tasked with piloting massive humanoid decisive weapons called Evangelion, the psychologically maladjusted adults who handle and command them, and the events and forces that affect them or which they take part in as they engage massive hostile invaders known as \"Angels.\"","genre_ids":[16,878,28,18],"popularity":2.1988,"vote_count":115,"poster_path":"/AehyZFGm68ep76b81IbLJ1EJ5ot.jpg","release_date":"1998-03-07","vote_average":6.7,"backdrop_path":"/fZxQc2xBqxOJt6q0R8bwq5oe7C9.jpg","original_title":"EVANGELION:DEATH(TRUE)²","original_language":"ja"},{"id":467169,"adult":false,"title":"Eureka Seven Hi-Evolution 1","video":false,"overview":"It all begins with the story that was left untold—the earth-shattering incident where Renton's father disappeared. With the mysterious pilot Eureka by his side, only Adroc Thurston could undo his own mistake, sparking the event that changed everything and earned him the title of a hero. Now, ten years later, Eureka lies in critical condition as Renton leaves the crew of the Gekko. But when he finds himself in the care of his father's old friends, he has a choice to make. Either stay with the loving family he's always wanted, or earn the love he seeks.","genre_ids":[18,16,878,12,28],"popularity":1.0324,"vote_count":8,"poster_path":"/ivfU7kNHkdX7VPSoeVljbkQ2xvm.jpg","release_date":"2017-09-16","vote_average":4.875,"backdrop_path":"/pY6Cq1aXXLSAdcfR6pXMRIBbQGV.jpg","original_title":"交響詩篇エウレカセブン ハイエボリューション1","original_language":"ja"},{"id":467170,"adult":false,"title":"Dance with Devils: Fortuna","video":false,"overview":"Ritsuka Tachibana. She lives a calm and unchanging life. Ritsuka's older brother Lindo returns from studying abroad in the United Kingdom. Shikou Academy student council president Rem Kaginuki calls on the girl, and she begins having mysterious encounters with the student council members. Her life changed a little from that day, but Ritsuka expected nothing more.  However, she comes home to find her mother collapsed with suspicious hooded men nearby. They were not human but devils, vampires, and exorcists seeking the Forbidden Grimoire. Ritsuka's former daily life crumbles around her, and she finds herself slowly becoming attracted to Rem, who helps her in her predicament. On the other hand, confusion deepens with regard to her brother who carries a secret. Ritsuka is unsure what path to choose as she finds herself at the center of a love story.  (Source: ANN)","genre_ids":[16,14,10749],"popularity":0.3538,"vote_count":8,"poster_path":"/bhnYrvDHt4AhxCqo2FOdcVyPV6O.jpg","release_date":"2017-11-04","vote_average":6.4,"backdrop_path":null,"original_title":"Dance with Devils -Fortuna-","original_language":"ja"},{"id":467172,"adult":false,"title":"DC Super Heroes vs. Eagle Talon","video":false,"overview":"Joker has come to Japan to steal the Eagle Talon Society's secret weapons in his continued scheme for pure chaos. However, the Justice League is on his trail, but there's something off with Batman. Now, it's up to Eagle Talon to go find out what's wrong with Batman, and that means going back in time to Bruce Wayne's most traumatic experience, the murder of his parents. If that wasn't enough to worry about, the Eagle Talon Society also have to keep their eyes on their production budget, especially with most of that money going towards the licensing fee for DC's popular characters. Will the Eagle Talon Society and the Justice League be able to stop the Joker before their budget dries up, and they're reduced to simple stick figures!?","genre_ids":[28,16,35],"popularity":0.3714,"vote_count":4,"poster_path":"/wTnuhMGXWprk2syHLtBBi2ZndIh.jpg","release_date":"2017-10-21","vote_average":6.4,"backdrop_path":"/aY8vmigBHaOVLhvRb0UFfATcuTV.jpg","original_title":"DCスーパーヒーローズvs鷹の爪団","original_language":"ja"},{"id":467181,"adult":false,"title":"Blurt!","video":false,"overview":"When nice-guy Jeremy Martin puts on mysterious virtual reality glasses at the mall, he suddenly loses his “inside voice” and starts spouting every thought he has out loud. Making matters worse, Jeremy is running for student council president against his classmate Milly, who is full of great ideas to improve the school. Desperate to get back to normal, Jeremy and his sister Victoria must figure out how to convince his brain that he can speak up for himself.","genre_ids":[10751,35,10770],"popularity":0.9789,"vote_count":65,"poster_path":"/kPA7q8JceNkYSWpkIArLxC8S2v1.jpg","release_date":"2018-10-22","vote_average":7.069,"backdrop_path":"/mz65vXFtcvQw0zLzmpX3nQqhC02.jpg","original_title":"Blurt!","original_language":"en"},{"id":3152,"adult":false,"title":"Big Monster on Campus","video":false,"overview":"A student receives a serial killer's brain in a transplant after being thrown into a pool with no water in it.","genre_ids":[35,27],"popularity":0.4585,"vote_count":26,"poster_path":"/4Pnsi9DX4zOdV0Sqj87yYyctrYm.jpg","release_date":"1998-01-01","vote_average":5.058,"backdrop_path":"/9nLLQNLQHcDAcXZRQVFUJRwZjjy.jpg","original_title":"Big Monster on Campus","original_language":"en"},{"id":1063151,"adult":false,"title":"Envelast","video":false,"overview":"Two teenagers, Anne and Dante, try to reconnect after hooking up.","genre_ids":[18,10749],"popularity":0.1769,"vote_count":0,"poster_path":"/ra1Rk5v6HHY2RPzjf4CluD9Sxyn.jpg","release_date":"2022-02-01","vote_average":0,"backdrop_path":null,"original_title":"Envelast","original_language":"en"}],"external_ids":{"imdb_id":"tt15242330","twitter_id":"movie_slamdunk","facebook_id":"movie.slamdunk","wikidata_id":"Q112897629","instagram_id":"slamdunk_movie"},"social_ids":{"twitter":"movie_slamdunk","facebook":"movie.slamdunk","instagram":"slamdunk_movie"},"gdvg_id":148584,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[