ote_average":0},{"width":736,"height":1104,"file_path":"/f53qdpMIFhAs7XkH5xt8pSRbLoc.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":661,"height":992,"file_path":"/9Dk0HhF7bpyNX8wGaQndRzRssWo.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.666,"vote_average":0},{"width":1969,"height":2953,"file_path":"/kYcsWTH3ctIBo0HiHnUlBa5tIDx.jpg","iso_639_1":"el","iso_3166_1":"GR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1134,"height":1701,"file_path":"/stPbn0v00hEL5M3GmD2oIBqtTpo.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/wJ4HyVZsbZRWH7BS3bLZsvO31rZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/mI7hfScSb8NAWC09viymxCzWZIq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":2.066},{"width":1920,"height":1080,"file_path":"/p8TbXycelgRC2X2SlbwRWmLaajH.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/dvJzocKa1STFfooFGgz8nwL81MS.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1600,"height":900,"file_path":"/QeX6V2jvdpq8uuQAmJUNhH1OOj.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":721,"file_path":"/dHohfbzDC6XU9fTr6CNFg52PRaz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.775,"vote_average":0},{"width":1437,"height":808,"file_path":"/BbnbWiCOp5U9SYabXpoRAcHZTQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1655,"height":931,"file_path":"/f4JEAUyTewRpMM3zDXwdZJDFZYH.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/914uUDjuwlepfGW6NIynJiQFynZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1650,"height":928,"file_path":"/fLENbcmErO2OLplTXaz9H09OOoT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1447,"height":814,"file_path":"/tuulZURn7DhBwTXCIrkAQwr2935.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1447,"height":814,"file_path":"/7Mj02fgsQ0vB0yZAIU5CT0kJ5Sy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1451,"height":816,"file_path":"/o17mYhYNj04r7OX1nUYafDaobR2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1445,"height":813,"file_path":"/bDLLYnMnLowoRmhVYX84EEVhw5a.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1439,"height":809,"file_path":"/q3slp7DbdDm80AVsAGxXY3iijvZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":1450,"height":816,"file_path":"/sThB8KHw8kdW9E2Vf3KJUR9sJC7.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1451,"height":816,"file_path":"/wGDLfY8Or7BpDxpI04DCYaJL27t.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1820,"height":1024,"file_path":"/xpCXHk3FaCTiEsY8YTq7X7h2ijj.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":1.777,"vote_average":0}]},"enriched_at":"2026-02-26T03:41:59.762+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Exterminating Angel","runtime":93,"tagline":"The degeneration of high society!","homepage":"","overview":"After a lavish dinner party, the guests find themselves unable to depart... and, over the next few days, all of their elaborate societal pretenses and façades deteriorate as they are reduced to living like animals."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"L'angelo sterminatore","runtime":93,"tagline":"Tutti avevano qualcosa da nascondere, lussuria, avidità, perversione, vizio, violenza, ma nessuno poteva sfuggire all'angelo sterminatore.","homepage":"","overview":"All'uscita dal teatro, una ventina di persone dell'alta società si ritrovano, per una cena, nella villa di città di Edmondo e Lucia Nobile. Mentre gli ospiti arrivano, i servitori, al contrario, ad eccezione del maggiordomo, se ne vanno con un pretesto o con l'altro, come sotto l'influsso di un presagio. Terminata la cena, il gruppo si riunisce in un vasto salone da ricevimento per ascoltare una famosa pianista. Si fa tardi, e gli ospiti decidono di rincasare: ma ecco, quasi un'insormontabile cortina fosse calata davanti a loro, nessuno riesce più a varcare la soglia del salone. Col trascorrere delle ore, la situazione diventa intollerabile: pur intestardendosi nel voler conservare il decoro del rango e una parvenza di etichetta, pian piano i prigionieri della misteriosa \"presenza\" si liberano dei loro freni inibitori, rivelandosi per quello che sono: pervertiti, ipocriti, lussuriosi, violenti."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Yokedici Melek","runtime":0,"tagline":"","homepage":"","overview":"Şehrin ileri gelenleri, bir akşam yemeği için Señor Edmundo Nobile ve eşi Lucia'nın evinde toplanırlar. Fakat sabahleyin anlayamadıkları bir sebepten dolayı kapılar açık olmasına rağmen odayı terk edemezler. Yanlarında sadece geceden kalan yiyecek ve içecek vardır.Geçen birkaç gün içindeyse, toplumda yer edinmiş bu elit topluluk birbirlerine düşer, hilelerini ortaya döker ve vahşice saldırır.Gerçeküstü sinemanın ustalarından Luis Buñuel'in burjuvazi ve erdemliliği sorguladığı bu filmi, New York Times tarafından en iyi 1000 film arasında gösteriliyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Der Würgeengel","runtime":95,"tagline":"","homepage":"","overview":"Der Abend im Hause der Nobiles scheint sich normal zu entwickeln. Die Hausangestellten bereiten alles für die vornehme Gesellschaft vor, die im herrschaftlichen Ambiente der Villa luxuriös zu Tafeln gedenkt. Doch Merkwürdigerweise verlassen gegen ihre sonstige Gewohnheit sämtliche Bediensteten außer dem Butler noch vor dem Beginn des Festes ihre Arbeitsstätte. Trotzdem entwickelt sich der Abend normal, bis die ersten Gäste tief in der Nacht müde geworden nach Hause gehen wollen. Aber so recht kann sich Niemand dazu entschließen und so betten sich alle auf den zahlreichen Sitzgelegenheiten zur Ruhe. Doch am Morgen müssen sie feststellen, dass es weder Frühstück gibt, noch das sie in der Lage sind, den Salon zu verlassen..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"El ángel exterminador","runtime":0,"tagline":"¡La degeneración de la alta sociedad!","homepage":"","overview":"Después de una cena en la mansión de los Nóbile, los invitados descubren que, por razones inexplicables, no pueden salir del lugar. Al prolongarse la situación durante varios días, la cortesía en el trato deja paso al más primitivo y brutal instinto de supervivencia. Una parábola sobre la descomposición de una clase social encerrada en sí misma."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"L'Ange exterminateur","runtime":93,"tagline":"La dégénérescence de la haute société !","homepage":"","overview":"Edmundo et Lucia de Nobile, un couple bourgeois de Mexico, donnent une réception après l'opéra dans leur luxueuse demeure. Quelques faits bizarres se produisent alors : des domestiques partent sans expliquer leur comportement, les invités connaissent une impression de déjà vu, Ana retire de son sac deux pattes de poulet alors que Blanca joue au piano une sonate de Paradisi. Au moment de partir, une étrange réaction interdit aux invités de quitter les lieux. Ces derniers finissent par dormir sur place. Mais le lendemain matin, ils constatent qu'il est toujours impossible de sortir du salon."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Az öldöklő angyal","runtime":95,"tagline":"","homepage":"","overview":"A Nobile házaspár egy operaelőadás után vacsorát ad a barátainak Gondviselés utcai házában, ahonnan azonban a komornyik kivételével a teljes személyzet eltávozott. A vacsora utáni zenélés, beszélgetés közben egyre többen elálmosodnak, és bár hazamenetelről beszélnek, ott helyben elalszanak. Reggel döbbenten vitatják a történteket, ám az egyébként nyitott szalon küszöbét senki nem tudja átlépni. E megmagyarázhatatlan korlátozottság miatt a társaság egyre kétségbeesettebb és hisztérikusabb lesz."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"המלאך המחסל","runtime":0,"tagline":"","homepage":"","overview":"סאטירה קומית-סוריאליסטית בוטה על אנשי המעמד הגבוה, בניצוחו של הגאון לואיס בונואל (סוד הקסם הבורגני). לאחר ארוחת ערב דשנה, מגלים הסועדים כי הם אינם מסוגלים לצאת מן החדר. במהלך הימים הבאים קורסים כל נימוסי השולחן, ענייני הרוח והיומרות האינטלקטואליות שיצרו החברים סביב אישיותם והמוניטין שלהם. הם נהפכים לחיות שרק רוצות לשרוד."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"O Anjo Exterminador","runtime":95,"tagline":"A obra-prima surrealista sobre a etiqueta que se torna um pesadelo.","homepage":"","overview":"Após uma luxuosa festa de jantar, os convidados da alta sociedade descobrem que, por uma razão inexplicável e psicológica, são fisicamente incapazes de abandonar a sala de visitas. À medida que os dias passam, as normas de etiqueta e a civilidade desmoronam, dando lugar ao instinto primitivo, ao caos e à paranoia."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Tuhon enkeli","runtime":0,"tagline":"","homepage":"","overview":""},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Ангелът унищожител","runtime":94,"tagline":"","homepage":"","overview":"Филмът може да ви стори загадъчен или алогичен, но нали такъв е и самият живот. Във филма има повторения, както и в самия живот и също като него той може да се тълкува най-различно."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"泯灭天使","runtime":0,"tagline":"","homepage":"","overview":"本片是布努艾尔与墨西哥女演员希尔维亚·比那尔（Silvia Pinal）合作，由比那尔的丈夫古斯塔沃·阿拉特里斯特（Gustavo Alatriste）出资制片的三部曲中的第二部。故事从一场盛大的晚宴开始。诺比尔夫妇在家款待朋友，可正当客人驾到之时，厨师和仆人却突然离去，只有管家胡里奥（克劳迪奥·布鲁克 Claudio Brook 饰）留下。宴席过后众宾客在起居室欣赏来宾之一演奏钢琴，但结束后竟无人打算离去。众人和衣在屋中睡下，清早醒来发现依然无人能够离开，只要一走到门口，便心生留意。一行人神秘被困数天，屋外的人也无法进入。被饥饿、干渴、疲乏和恐惧笼罩的这些上层社会男女们开始不顾身份地位地争吵、哭泣、动粗，甚至威胁要杀掉主人，破除“魔咒”……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"O Anjo Exterminador","runtime":95,"tagline":"","homepage":"","overview":"Após uma extravagante e farta refeição, os convidados de uma festa de alta classe sentem-se estranhamente incapazes de deixar a sala de jantar e, nos dias que se seguem, pouco a pouco, caem as máscaras de civilização e virtude e o grupo passa a viver como animais."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Îngerul exterminator","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Ангел-истребитель","runtime":0,"tagline":"","homepage":"","overview":"После роскошного званого ужина гости вдруг обнаруживают, что в силу каких-то таинственных причин не могут выйти из столовой. Проходит день, другой, и множества тщательно выстроенных фасадов и поз — как не бывало. Исчезают без следа понятия о приличиях, обусловленных положением в обществе, люди опускаются до примитивного животного состояния."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Εξολοθρευτής Άγγελος","runtime":0,"tagline":"","homepage":"","overview":"Η ταινία περιγράφει το δείπνο μίας παρέας αριστοκρατών σε κάποιο σπίτι. Μετά το δείπνο, οι καλεσμένοι μεταφέρονται στο σαλόνι από το οποίο, για κάποιον ανεξήγητο λόγο, είναι αδύνατο να εξέλθουν. O εγκλεισμός τους, στο διάστημα των επόμενων ημερών, οδηγεί στην απώλεια της αξιοπρέπειάς τους και την υποταγή στα ένστικτά τους."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"","runtime":95,"tagline":"","homepage":"","overview":"Een groep leden van de upper-class houdt na een operavoorstelling een formeel etentje bij één van de leden thuis. De avond verschuift langzaam naar de nacht en dan blijkt dat de gasten niet meer weg kunnen. Er zijn geen fysieke barrières en de deuren zijn niet op slot."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Ангел-винищувач","runtime":95,"tagline":"","homepage":"","overview":"Після розкішної званої вечері гості раптом виявляють, що — в силу якихось таємничих причин — не можуть вийти з їдальні. Проходить день, другий, і безлічі ретельно вибудуваних фасадів і поз — наче й не було. Зникають без сліду поняття про пристойність, обумовлених положенням в суспільстві, люди опускаються до примітивного тваринного стану…"},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Anděl zkázy","runtime":0,"tagline":"Hrdinové, či spíše antihrdinové této surrealistické absurdity jsou lapeni v honosném domě v blíže neurčeném místě a čase. Z domu uprchlo služebnictvo a zůstává jen skupina elitních hostů.","homepage":"","overview":"Hrdinové, či spíše antihrdinové této surrealistické absurdity jsou lapeni v honosném domě v blíže neurčeném místě a čase. Z domu uprchlo služebnictvo a zůstává jen skupina elitních hostů. Ti hodují, výborně se baví a cynickými dialogy prozrazují svou zvrácenost. Po večeři se nikdo nemá k odchodu -práh místnosti jako by se stal nepřekročitelnou neviditelnou barikádou. Hosté zůstávají v domě. V přepychu trpí nedostatkem základní potřeby - jídla - a krizová situace snímá masky jednotlivců..."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Anjel skazy","runtime":88,"tagline":"","homepage":"","overview":"Skupina ľudí príde na návštevu do honosného sídla, všetci sú spoločensky oblečení. Služobníctvo odišlo, v dome ostal len majordóm. Po večeri, ako sa večer vyvíja, by niektorí už aj chceli odísť – no nedá sa. Hostia sa z neznámej príčiny nevedia dostať z miestnosti, kde sa nachádzajú. Čas plynie, hodiny sa menia na dni... Hostia sa postupne začínajú odhaľovať – predovšetkým spoločensky. Už sa neschovávajú za maskami, ktoré si zvyčajne nasadzujú v spoločnosti, na povrch sa derú ich najskrytejšie túžby, ale aj temné pudy. Buñuelov film je ostrou satirou a výsmechom buržoáznym inštitúciám (v tomto prípade rodiny a celej spoločnosti), pokryteckej morálke a hodnotám."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"절멸의 천사","runtime":0,"tagline":"","homepage":"","overview":"멕시코의 부유한 귀족 노빌은 라 프로빈시아 가의 저택에 친구들을 초대한다. 저녁만찬에서는 계속해서 이상한 일들이 일어난다. 하인들은 이유를 설명하지 않고 나가버리고 피아노 소나타가 연주되는 동안 귀부인의 핸드백에서는 닭다리 두 개가 나온다. 그러나 손님들은 저택을 떠날 생각을 하지 못하고 일종의 감금상태에 놓이게 된다. 다음날 아귀가 엄습하면서 사회적 위치와 지위의 위선 속에 숨겨진 본성들이 당면한 어려운 상황 앞에서 철저히 붕괴되어가고 사람들은 인간으로서의 본성을 드러내게 된다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Anioł Zagłady","runtime":95,"tagline":"","homepage":"","overview":"Grupa zamożnych znajomych spotyka się na wspólnej kolacji. Gdy przyjęcie dobiega końca, z niewyjaśnionych powodów goście nie są w stanie opuścić domu."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"El ángel exterminador","runtime":0,"tagline":"","homepage":"","overview":"Después de una cena en la mansión de los Nóbile, los invitados descubren que, por razones inexplicables, no pueden salir del lugar. Al prolongarse la situación durante varios días, la cortesía en el trato deja paso al más primitivo y brutal instinto de supervivencia. Una parábola sobre la descomposición de una clase social encerrada en sí misma."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Thiên Thần Hủy Diệt","runtime":0,"tagline":"","homepage":"","overview":"Sinh ra tại Calanda, một thị trấn nhỏ thuộc tỉnh Teruel, thuộc vùng Aragon của Tây Ban Nha, ngay từ nhỏ đạo diễn Luis Buñuel đã phải nhận sự giáo dục nghiêm ngặt của Dòng Tên Công giáo, điều này đã gây nên nỗi ám ảnh không nhỏ trong ông, dẫn đến những hành vi chống đối của ông sau này với hầu hết các loại tôn giáo. Vào thời thanh niên, Buñuel được chuyển đến thủ đô Madrid để học Đại học, nơi ông gặp và kết thân cùng họa sĩ Salvador Dalí và nhà thơ, nhạc sĩ Federico García Lorca, tạo nên bộ ba Tây Ban Nha có lẽ là xuất chúng và nổi tiếng nhất trong giới nghệ thuật đầu thế kỉ XX."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"泯滅天使","runtime":0,"tagline":"","homepage":"","overview":"獲1962年法國坎城金棕櫚獎提名。本片是布努艾爾與墨西哥女演員希爾維亞比那爾合作，由比那爾的丈夫古斯塔沃阿拉特裡斯特出資製片的三部曲中的第二部。  故事從一場盛大的晚宴開始。諾比爾夫婦在家款待朋友，可正當客人駕到之時，廚師和僕人卻突然離去，只有管家胡裡奧（克勞迪奧布魯克飾）留下。宴席過後眾賓客在起居室欣賞來賓之一演奏鋼琴，但結束後竟無人打算離去。眾人和衣在屋中睡下，清早醒來發現依然無人能夠離開，只要一走到門口，便心生留意。  一行人神秘被困數天，屋外的人也無法進入。被饑餓、乾渴、疲乏和恐懼籠罩的這些上層社會男女們開始不顧身份地位地爭吵、哭泣、動粗，甚至威脅要殺掉主人，破除「魔咒」......"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"皆殺しの天使","runtime":0,"tagline":"","homepage":"","overview":"オペラ観劇後に晩餐会に招かれ、ノビレ夫妻の邸宅を訪れた20人のブルジョワたち。晩餐を終えた彼らは客間にすっかり腰を落ち着かせ、夜が明けても全員が帰る方法を忘れたかのように客間を出ることができなくなってしまう。そのまま数日が過ぎ、水や食料も底を突いて命を落とす者まで出現。ブルジョワたちの道徳や倫理が崩壊していく中、事態は異様な展開へ転がりはじめる。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Mordängeln","runtime":0,"tagline":"","homepage":"","overview":""},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"}],"reviews_tmdb":[],"recommendations":[{"id":4497,"adult":false,"title":"Viridiana","video":false,"overview":"Viridiana is preparing to start her life as a nun when she is sent, somewhat unwillingly, to visit her aging uncle, Don Jaime. He supports her; but the two have met only once. Jaime thinks Viridiana resembles his dead wife. Viridiana has secretly despised this man all her life and finds her worst fears proven when Jaime grows determined to seduce his pure niece. Viridiana becomes undone as her uncle upends the plans she had made to join the convent.","genre_ids":[18],"media_type":"movie","popularity":1.4569,"vote_count":540,"poster_path":"/mYPuSx5JwL8AdTwS1iQW4Un1cYP.jpg","release_date":"1962-04-01","vote_average":7.657,"backdrop_path":"/2QGuTuyxwCCER9iwSeONW8BAxce.jpg","original_title":"Viridiana","original_language":"es"},{"id":36265,"adult":false,"title":"Simon of the Desert","video":false,"overview":"Simon, a deeply religious man living in the 4th century, wants to be nearer to God so he climbs a column. The Devil wants him come down to Earth and is trying to seduce him.","genre_ids":[35,18,14],"media_type":"movie","popularity":1.5649,"vote_count":232,"poster_path":"/ysTa1FtL9DvQ90F6VGVoiOdp5NM.jpg","release_date":"1965-08-27","vote_average":7.6,"backdrop_path":"/sm7NapjwKYhIH2GzFEgJkiw9hF1.jpg","original_title":"Simón del desierto","original_language":"es"},{"id":42529,"adult":false,"title":"WR: Mysteries of the Organism","video":false,"overview":"What does the energy harnessed through orgasm have to do with the state of communist Yugoslavia circa 1971? Only counterculture filmmaker extraordinaire Dušan Makavejev has the answers (or the questions). His surreal documentary-fiction collision begins as an investigation into the life and work of controversial psychologist and philosopher Wilhelm Reich and then explodes into a free-form narrative of a beautiful young Slavic girl’s sexual liberation.","genre_ids":[18,14,35],"media_type":"movie","popularity":0.3594,"vote_count":92,"poster_path":"/gbyyHQhQSDH7PsIu1gLdpRek091.jpg","release_date":"1971-05-10","vote_average":6.1,"backdrop_path":"/r2Xx2cCOjB2aRnyQCfYKgWuJ8pl.jpg","original_title":"W.R. - Misterije organizma","original_language":"sh"},{"id":63215,"adult":false,"title":"Toute une nuit","video":false,"overview":"Following over two dozen different individuals in the almost wordless atmosphere of a dark night in a Brussels town, acceptance and rejection in the realm of romance is examined.","genre_ids":[18,10749],"media_type":"movie","popularity":0.4156,"vote_count":34,"poster_path":"/ruXSiqpZCWeq1KBNxAWPC0OrnAt.jpg","release_date":"1982-10-27","vote_average":6.4,"backdrop_path":"/3gSqZ9cKFibs60gXrZNoiXAizsO.jpg","original_title":"Toute une nuit","original_language":"fr"},{"id":3060,"adult":false,"title":"The Big Parade","video":false,"overview":"The story of an idle rich boy who joins the US Army's Rainbow Division and is sent to France to fight in World War I, becomes friends with two working class men, experiences the horrors of trench warfare, and finds love with a French girl.","genre_ids":[10749,10752,18],"media_type":"movie","popularity":0.6961,"vote_count":123,"poster_path":"/8aBXJEkAHcwG2ghNYh6GIFd9ool.jpg","release_date":"1925-11-05","vote_average":7.533,"backdrop_path":"/xBpk9twRcwZzNPWk5VHj9OC2M5g.jpg","original_title":"The Big Parade","original_language":"en"},{"id":13686,"adult":false,"title":"The Kovak Box","video":false,"overview":"David Norton is used to being in control. As a best-selling author, he decides the fate of his characters, their lives and their deaths. But what happens when his fictional world becomes all too real?","genre_ids":[878,53,28],"media_type":"movie","popularity":0.9975,"vote_count":116,"poster_path":"/sUrutQD8Xaaf1byXupXDCVPq1lv.jpg","release_date":"2006-07-18","vote_average":5.806,"backdrop_path":"/ihX7NkakPzgf7y0W09xQex1bsQ3.jpg","original_title":"The Kovak Box","original_language":"en"},{"id":202253,"adult":false,"title":"Voices Through Time","video":false,"overview":"Visual ode to contemplative journey through the stages of life and the essence of human existence, set in a timeless backdrop of an Italian village.","genre_ids":[18],"media_type":"movie","popularity":0.1485,"vote_count":29,"poster_path":"/jmX1JW4ePqzfui55IzW8qgmbMP9.jpg","release_date":"1997-11-12","vote_average":7.8,"backdrop_path":"/lxpVhKFvHJ504KFhqolPKbFnJPc.jpg","original_title":"Voci nel tempo","original_language":"it"},{"id":104498,"adult":false,"title":"Leonor","video":false,"overview":"Richard is a medieval nobleman. After his first wife dies in an accident and is buried in the family vault, he remarries and has children by his second wife. A mad longing for his first wife Leonor comes over him, and he sells his soul to the devil for a chance to get her back. But when she returns, she is a murderous vampire.","genre_ids":[27,14,18],"media_type":"movie","popularity":0.3461,"vote_count":25,"poster_path":"/hjerBd6PEWJPB2NzFsDtqBGka8a.jpg","release_date":"1975-09-01","vote_average":5.6,"backdrop_path":"/dbKLMVnSVFAwZxPYWEnitt0mK6T.jpg","original_title":"Leonor","original_language":"fr"},{"id":521867,"adult":false,"title":"Roberto Saviano: Writing Under Police Protection","video":false,"overview":"An upbeat and humorous account of the hard life under police protection led by Italian writer Roberto Saviano since the publication in 2006 of Gomorrah, his controversial book about the Camorra, the ruthless organization that has dominated the criminal underground in Naples for centuries.","genre_ids":[99,10770],"media_type":"movie","popularity":0.0697,"vote_count":39,"poster_path":"/m5SVkiAOzzl4h1M9BI9CiGMmDm0.jpg","release_date":"2016-10-17","vote_average":7.218,"backdrop_