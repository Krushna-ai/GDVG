5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Something Blue\",\"description\":\"Lifelong friends Óscar and Eli find themselves in a messy situation after a drunken night leads to unexpected consequences. Forced to replace a ruined wedding dress, they embark on a chaotic journey filled with setbacks and awkward run-ins with their exes.\",\"image\":\"https://image.tmdb.org/t/p/w500/tdqzzSDXeCZzCEzZKPLYQuTwFdG.jpg\",\"datePublished\":\"2025-02-07\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CO\",\"inLanguage\":\"es\",\"genre\":[\"Romance\",\"Comedy\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.9,\"bestRating\":10,\"ratingCount\":17}}"}}],["$","$L10",null,{"initialDrama":{"id":"76f46180-4110-435c-bbfb-562bd6e6e18e","tmdb_id":1429786,"imdb_id":"tt35537372","content_type":"movie","title":"Something Blue","original_title":"Algo Azul","overview":"Lifelong friends Óscar and Eli find themselves in a messy situation after a drunken night leads to unexpected consequences. Forced to replace a ruined wedding dress, they embark on a chaotic journey filled with setbacks and awkward run-ins with their exes.","poster_path":"/tdqzzSDXeCZzCEzZKPLYQuTwFdG.jpg","backdrop_path":"/ym6yZnCzfFraQkzstBsfnvAx8Xq.jpg","release_date":"2025-02-07","first_air_date":null,"status":"published","original_language":"es","origin_country":["CO","MX"],"genres":[{"id":10749,"name":"Romance"},{"id":35,"name":"Comedy"}],"popularity":3.1279,"vote_average":7.9,"vote_count":17,"runtime":0,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-25T23:03:50.114085+00:00","updated_at":"2026-02-25T23:03:49.921+00:00","tagline":"What if your best friend turns out to be the love of your life?","homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":252575,"name":"BYG Studio","logo_path":null,"origin_country":""},{"id":87569,"name":"11:11 Films & T