XSl5juUP5Y9f.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1904,"height":1071,"file_path":"/bhogoCDBBTf5vHSVlp9wPHmuEz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1904,"height":1071,"file_path":"/tcVB3YeJLelFhC7TQb9SmVE903t.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/7oYFEqMQmLkKiCuUJYzHq4x2lgB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/wwxsEBdD0Hpe8iHyLwcp8dpiDkF.jpg","iso_639_1":"fi","iso_3166_1":"FI","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2600,"height":1463,"file_path":"/grEOYLxk5bN4xvU05VNyaKwai4C.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0}]},"enriched_at":"2026-02-25T03:43:56.561+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Downfall","runtime":155,"tagline":"April 1945, a nation awaits its... Downfall","homepage":"","overview":"In April of 1945, Germany stands at the brink of defeat with the Russian Army closing in from the east and the Allied Expeditionary Force attacking from the west. In Berlin, capital of the Third Reich, Adolf Hitler proclaims that Germany will still achieve victory and orders his generals and advisers to fight to the last man. When the end finally does come, and Hitler lies dead by his own hand, what is left of his military must find a way to end the killing that is the Battle of Berlin, and lay down their arms in surrender."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"El hundimiento","runtime":155,"tagline":"Abril de 1945, una nación espera su... caída","homepage":"","overview":"Berlín, abril de 1945. En las calles de Berlín se libra una encarnizada batalla. Hitler y sus fieles se han atrincherado en un búnker. Entre ellos se encuentra Traudl Junge, la secretaria personal del Führer. En el exterior, la situación se recrudece. A pesar de que Berlín ya no puede resistir más, Hitler se niega a abandonar la ciudad y, acompañado de Eva Braun, prepara su despedida."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":156,"tagline":"","homepage":"","overview":"Berlin, April 1945. Während um ihn herum sein Hirngespinst Großdeutschland in Schutt und Asche liegt, deutsche Truppen quasi nur noch auf dem Papier existieren und die Alliierten die Macht übernehmen, hält Adolf Hitler in seinem Bunker Hof. Spielt sich und seinen Vasallen eine Mär vom unaufhörlichen Triumph der arischen Rasse vor, stachelt seine Untergebenen zu weiteren irrwitzigen Feldzügen an und präsentiert einen galoppierenden Realitätsverlust ungeahnten Ausmaßes. Bis auch im Bunker das große Sterben beginnt."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":156,"tagline":"","homepage":"","overview":"I april 1945 har den russiske hær lagt en jernring omkring Berlin, og Tyskland er ved at tabe krigen. Hitler har sammen med sine nærmeste fortrolige og den militære ledelse forskanset sig i en bunker under Rigskancelliet. Her flytter han rundt på troppestyrker, der ikke mere eksisterer, mens elskerinden Eva Braun forsøger at opretholde en slags dagligdagens normalitet. Hitlers unge sekretær, Traudl Junge, følger med undren og stigende rædsel vanviddet og den moralske opløsning, der breder sig i bunkeren i nederlagets stund."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"La caduta - Gli ultimi giorni di Hitler","runtime":156,"tagline":"Aprile 1945, una nazione attende la sua... Caduta","homepage":"http://www.downfallthefilm.com/","overview":"L'orribile parabola del nazismo racchiusa negli ultimi dodici giorni di Hitler, vissuti nel fondo di un bunker. La storia è narrata dalla sua giovane segretaria, Traudl Junge, che visse quei giorni col Fuhrer e i suoi fedelissimi. L'esercito russo sta ormai circondando Berlino, la capitale è un cumulo di macerie e la sconfitta della Germania è inevitabile. All'interno del bunker, durante i festeggiamenti per il 56° compleanno del Fürhrer, in molti, fra cui il Ministro degli Interni Himmler, pregano Hitler affinché lasci Berlino per un luogo più sicuro. Nel frattempo, in superficie, alcuni ragazzini della Gioventù Hitleriana combattono ancora: uno di loro, il tredicenne Peter, è orgoglioso di aver distrutto due carri armati russi. Suo padre lo implora di tornare a casa ma il ragazzino tenacemente rifiuta. Quando i russi giungono nel centro di Berlino nessuno può più negare la sconfitta, neppure il giovanissimo Peter che troverà i suoi genitori assassinati da uno squadrone della morte."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Çöküş","runtime":0,"tagline":"Nisan 1945, Bir Millet Çöküş'ünü bekliyor.","homepage":"","overview":"Hitler ve yakın arkadaşları kendilerini sığınaklarda güvene almışlardır. Aralarında Führer'in özel sekreteri Traudi Junge de vardır. Berlin artık düşmüş bir kaledir fakat Hitler, şehirden çıkmayı ve teslim olmayı kabul etmemektedir. Halkının tüm fertleri dışarıda yok edilirken o, son yolculuğuna hazırlanmaktadır. Birlikte intihar etmeden birkaç saat önce Eva Braun ile evlenirler. Cesetleri düşman eline geçmemesi için yakılır. Führer'in peşinden yıllarca sadık bir şekilde gitmiş birçok insanın durumu da farklı değildir. Berlin düşerken herkesin ölümle yaşam arasında seçim yapma saati giderek yaklaşmaktadır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Perikato","runtime":156,"tagline":"","homepage":"","overview":"Saksa on hajoamassa, ja kolmannen valtakunnan häviö näyttää väistämättömältä. Hitler on yhdessä lähimpiensä, mm. vaimonsa Eva Braunin ja Goebbelsin perheen kanssa vetäytynyt Berliinin keskustassa sijaitsevaan bunkkeriinsa, jossa he odottavat kohtaloaan."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"La Chute","runtime":155,"tagline":"« Si la guerre est perdue, peu m'importe que le peuple périsse. Ne comptez pas sur moi pour verser une seule larme. »","homepage":"","overview":"Berlin, avril 1945. Le IIIe Reich s'effondre. Les Russes sont dans Berlin, les combats font rage dans les rues de la capitale. Hitler, accompagné de ses généraux et de ses plus proches partisans, s'est réfugié dans son bunker, situé dans les sous-sols des jardins de la Chancellerie. À ses côtés, Traudl Junge, la secrétaire particulière du Führer, refuse de l'abandonner. Tandis qu'à l'extérieur la situation se dégrade, Hitler vit ses dernières heures et la chute du régime."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"A Queda: Hitler e o fim do Terceiro Reich","runtime":156,"tagline":"As Últimas Horas de Hitler.","homepage":"","overview":"Em Novembro de 1942, um grupo de jovens amanuenses é escoltado até à Toca do Lobo, o quartel-general de Hitler na Prússia Oriental. Vão apresentar-se ao posto de secretária pessoal do Führer. Entre elas está Traudl Junge, uma jovem bávara de 22 anos, que é escolhida para o cargo. Mas ela não sabe que irá tornar-se testemunha dos últimos anos do III Reich e da batalha por Berlim, em 1945."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"A bukás - Hitler utolsó napjai","runtime":156,"tagline":"Ismerd meg a gonosz igazi arcát!","homepage":"","overview":"Berlin, 1945 április. Egy nép a bukására vár. A főváros utcáin kegyetlen harcok folynak. Hitler a katonai vezetőséggel és néhány hívével elsáncolja magát a vezetőségi bunkerben. A Birodalom helyzete a Vörös Hadsereg előrenyomulásával egyre reménytelenebbé válik. A folyamatos bombázások állandó rettegésben és életveszélyben tartják a város elkeseredett lakosságát.Miközben az utcákon kétségbeesés tombol, Hitler a Harmadik Birodalom teljes pusztulását a bunker falai között éli át. Jóllehet Berlint már lehetetlen tartani, a Führer tiltakozik a búvóhely elhagyása ellen - Albert Speer építészhez hasonlóan \"a színpadon akar lenni, amikor legördül a függöny\". Már csak néhány órája maradt, mielőtt közös öngyilkosságuk előtt feleségül veszi Eva Braunt. A vég elkerülhetetlenül közeleg, Hitler mindent az utolsó részletig kidolgoz: miután ő és szeretője meghalt, holttestüket a birodalmi kancellária udvarában fogják elégetni, nehogy a tetemük ellenséges kézre jusson..."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Бункер","runtime":156,"tagline":"«Последние 10 дней жизни Гитлера»","homepage":"","overview":"Апрель 1945 года. Советские войска сжимают кольцо вокруг столицы Третьего рейха - Берлина. Перед лицом неминуемого поражения нацистская верхушка ищет спасение в секретном бункере, не желая покидать обезумевшего фюрера. Отвергнув предложения о побеге, Гитлер утверждает, что победа близка. Он приказывает сравнять Германию с землёй и обсуждает детали своего самоубийства. Последнее убежище палачей пронизано агонией и страхом. И лишь те, кто выйдут живыми из этого бетонного ада, смогут поведать историю о последних минутах жизни и мрачном падении диктатора и его режима."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":156,"tagline":"","homepage":"","overview":"De Duitse tiran Adolf Hitler brengt de laatste dagen van zijn heerschappij door in zijn bunker onder Berlijn. Het Rode Leger heeft met grote overmacht Berlijn omringd en daarbij vooral burgerslachtoffers gemaakt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"帝国的毁灭","runtime":156,"tagline":"","homepage":"","overview":"　　本片取材自约阿希姆·费斯特2002年的著作《希特勒的末日》和希特勒的私人秘书特劳德尔·荣格同年的回忆录《直到最后时刻》，曾获得奥斯卡最佳外语片奖的提名。 荣格自从1942年被希特勒雇佣为秘书后，转眼到了1945年3月，苏联大军兵临城下，纳粹德国政府内人心惶惶。不但重要的亲信希姆莱和戈林相继叛离希特勒而去，而且军队人手不足，连平民和小孩都被迫送上战场，看不到希望的将军也整日借酒消愁...这是一部纪实性电影，逼真地反映了希特勒人生的最后12天，第三帝国最后的日子。苏联红军已经攻入柏林，希特勒和情妇爱娃也躲到了掩体下。爱娃知道自己是来陪希特勒一起共赴黄泉的，但她并不后悔。即使在她向希特勒为妹夫求情遭拒绝后，她也和希特勒一起举办了最后一次的婚礼。希特勒的忠实追随者戈倍尔决心全家一起陪着元首殉葬。他共有7个孩子，他和妻子坚决不让自己的孩子们在没有帝国的天空生长，在希特勒和爱娃自杀后也一同自杀。令人不胜感慨。历史的真实通过镜头一幕幕重现。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Upadek","runtime":156,"tagline":"Kwiecień 1945 r. Naród czeka na swój... upadek.","homepage":"","overview":"Berlin, kwiecień 1945 roku. Na ulicach panuje chaos nie do opisania. Naród niemiecki czeka na swą nieuchronną klęskę. Adolf Hitler wraz ze swoimi najbliższymi współpracownikami ukrywa się w bunkrze w podziemiach Kancelarii Rzeszy. Wśród \"świty\" wodza znajduje się Traudl Junge, ostatnia sekretarka Hitlera. To jej wspomnienia posłużyły do przedstawienia ostatnich, spędzonych w izolacji, dwunastu dni życia wodza upadającej III Rzeszy. Te dramatyczne dni wzbudzają tak wiele kontrowersji i domysłów jak żaden inny etap biografii Hitlera. Co naprawdę wydarzyło się 10 metrów pod ulicami Berlina?"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Pád Třetí říše","runtime":0,"tagline":"","homepage":"","overview":"Adolf Hitler slaví 20.dubna 56. narozeniny v kruhu svých věrných spolupracovníků a svého štábu. Eva Braunová už s ním také několik dní žije v bunkru. Himmler, Goering a stranické špičky se odsunuly do bezpečnějších částí Německa, zatímco Hitler nechce v žádném případě opustit své hlavní město. 29. dubna Rudá armáda obklíčila vládní čtvrť a odřízla ji od ostatního území Berlína, v jehož ulicích se bojuje o každý dům. Během této noci diktuje Hitler sekretářce Traudl Jungové svou poslední vůli a žení se s Evou Braunovou. Svatebními svědky jsou Goebbels a Borman. 30. dubna zahájila ruská armáda boj o Říšský sněm (Reichstag). Hitler se rozhodl spáchat sebevraždu. Společně s Evou Braunovou se otrávili a jejich mrtvoly byly spáleny na zahradě říšského kancléřství. O den později otrávila Magda Goebbelsová ve spánku svých šest dětí. Pak odešli Magda a Joseph Goebbelsovi do zahrady a zastřelili se. Přestože generál Weindling vydal rozkaz ke kapitulaci, v ulicích se bojuje dál."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Undergången: Hitler och Tredje rikets fall","runtime":156,"tagline":"","homepage":"","overview":"Traudl Junge, Adolf Hitlers sista sekreterare, berättar om diktatorns sista dagar i hans bunker i Berlin i slutet av andra världskriget."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"ヒトラー ～最期の12日間～","runtime":155,"tagline":"彼の敵は世界 全てを目撃した秘書が今明かす、衝撃の真実。","homepage":"","overview":"1942年、ミュンヘン出身の若い女性ユンゲはヒトラーの個人秘書の職を得る。それから月日は流れて1945年、第2次世界大戦は大詰めを迎え、ヒトラーはごく限られた身内や腹心の部下たちとベルリンのドイツ首相官邸の地下要塞に逃げ、そこで不自由な生活を送る。敗北の気配が濃くなる中、ヒトラーはまだ反撃のシナリオを熱っぽく語るが次第に部下たちは彼から離反していき、ユンゲは歴史の証人としてその光景を静かに見守る。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Η Πτώση","runtime":156,"tagline":"\"Αν ο πόλεμος χαθεί, δεν με αφορά αν χαθούν μαζί του και ανθρώπινες ζωές. Δεν θα έχυνα στάλα δάκρυ γι` αυτούς. Γιατί έπαθαν ό,τι τους αξίζει\". Αδόλφος Χίτλερ","homepage":"","overview":"1945: η ήττα του Χίτλερ θα σημάνει τη λήξη του Β` Παγκοσμίου Πολέμου. Ο Χίτλερ και οι στρατιωτικοί του με τις οικογένειές τους είναι όλοι κλεισμένοι στο καταφύγιο, περιμένοντας το μοιραίο τέλος. Ανάμεσά τους βρίσκεται και η Τράουντλ, η γραμματέας του, που μέσα από τα μάτια της θα παρακολουθήσουμε τις συγκλονιστικές τελευταίες μέρες του Χίτλερ και της κυριαρχίας των Ναζί..."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Ultimele zile ale lui Hitler","runtime":156,"tagline":"Aprilie 1945, o nație își așteaptă...Prăbușirea","homepage":"","overview":"În aprilie 1945, Germania era aproape de înfrângere cu armata rusă apropiindu-se dinspre est și aliații atacând dinspre vest. În Berlin, capitala celui de-al treilea imperiu, Adolf Hitler proclamă că Germania încă va dobândi victoria și le ordonă generalilor și consilierilor să lupte până la ultimul om. Când sfârșitul vine în final, și Hitler zace mort de mâna lui, cei care au mai rămas din militarii lui trebuie să găsească o cale să încheie omorul care este bătălia Berlinului, să pună armele jos și să se predea."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"הנפילה","runtime":0,"tagline":"אפריל 1945, אומה שלמה ממתינה… למפלתה.","homepage":"","overview":"אפריל 1945, היטלר ומזכירתו הראשית טראודל ג'אנג' מוצאים את עצמם בבונקר. מנותק מהצבא שלו ומאנשי האס אס, הנוטשים אותו בזה אחר זה, מסרב היטלר להכיר בהפסד הבלתי נמנע ולהודות שעולמו מתמוטט עליו, הלך רוחו נע מהפסד בלחימה או בריחה, משמירת אמונים למטרה - לשמירה על חייו, עד אשר הוא מקבל את ההחלטה הגורלית לשים את הקץ לחייו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"다운폴","runtime":0,"tagline":"히틀러의 비서가 기록한 독재자의 몰락과 최후의 순간!","homepage":"","overview":"히틀러가 죽기 전 마지막 10일 동안을 그린 작품.\r 1944년 독일, 연합군의 반격과 함께 전황은 나치에게 불리한 쪽으로 흘러가고, 히틀러와 그의 부하들은 어떻게든 상황을 바꾸기 위해 노력한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Крахът на Третия райх","runtime":156,"tagline":"","homepage":"","overview":"Крахът на Третия райх ви отвежда в бункера на Хитлер по време на драматичните последни дни от съществуването на Третия райх. През очите на Труди Юнге, личната секретарка на Фюрера, ще видите как оптимизмът отстъпва на ужаса и на прозрението, че загубата на Германия във войната е неизбежна. Ще видите как Химлер и Гьоринг се опитват да се спасят, изоставяйки своя лидер, как Гьобелс се кълне във вярност на Фюрера и как самият Хитлер се люшка от безумен, сляп оптимизъм към черно, безнадежно отчаяние."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"A Queda! As Últimas Horas de Hitler","runtime":156,"tagline":"Abril de 1945, uma nação aguarda... A Queda!","homepage":"","overview":"Em 1942, o jovem Traudl Junge tem o que parece ser a melhor profissão do mundo: ele é secretário de Hitler. Três anos depois, o império se resume a um abrigo subterrâneo e, de lá, Traudl narra os últimos dias da vida de do ditador."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"La falo","runtime":156,"tagline":"","homepage":"","overview":"Aprilo 1945. La Sovetia armeo senkompate premas la gorĝon de faŝista reĝimo, ĉirkaŭante la ĉefurbon de la 3-a Imperio, Berlinon. Malgraŭ antaŭvidata malvenko la nazia estraro savas sin en sekreta bunkro kaj ne forlasas la freneziĝintan Gvidanton.  Li rifuzas la ideojn pri fuĝo kaj asertas, ke la venko proksimiĝas.  La Gvidanto ordonas detrui Germanion kaj priparolas detalojn de sinmortigo. La lasta kaŝloko de ekzekutistoj estas plenplena je agonio kaj timo. Kaj nur tiuj, kiuj forlasos la betonan inferon vivaj povos rakonti la historion pri la lastaj minutoj de vivo kaj fino de granda diktatoro kaj lia reĝimo.  Tiu ĉi estas unu el la plej elstaraj mulitfilmoj de la lastaj jaroj, baziĝanta sur la libro de fama historiisto Joachim Fest, La Lastaj Tagoj de Hitlero, la memuaroj de Albert Speer, la nazia Ministro pri Armilaro kaj la memuaroj de Traudl Junge, sekretario de Hitlero."},"name":"Esperanto","iso_639_1":"eo","iso_3166_1":"EO","english_name":"Esperanto"},{"data":{"title":"Бункер","runtime":0,"tagline":"","homepage":"","overview":"Сюжет розповідає про події, що сталися у квітні 1945 року, коли війська Радянського Союзу затиснули в кільце залишки нацистської армії, змусивши більшість офіцерів сховатись у засекреченому підземному бункері. Усі лідери Третього Рейху, в тому числі й сам Адольф Гітлер, опинилися у пастці, відрізані від будь-якої підтримки. Перебуваючи у відчаї та розуміючи, що виходу вже немає, диктатор незабаром вирішує покінчити життя самогубством..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Pád Tretej ríše","runtime":0,"tagline":"","homepage":"","overview":"Je apríl 1945 a do úplnej porážky nacistického Nemecka ostáva už len niekoľko dní. Hitler však vo svojom berlínskom bunkri aj naďalej požaduje od svojich generálov boj do posledného muža. Film, detailne popisujúci, ako prebiehali posledné dni Tretej ríše v Hitlerovom berlínskom bunkri, vznikol na motívy knihy Hitlerovej osobnej sekretárky Traudl Jungeovej, ktorá s ním bola v bunkri až do úplného konca."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"帝國毀滅","runtime":0,"tagline":"","homepage":"","overview":"本片取材自約阿希姆·費斯特2002年的著作《希特勒的末日》和希特勒的私人秘書特勞德爾·榮格同年的回憶錄《直到最後時刻》，曾獲得奧斯卡最佳外語片獎的提名。  榮格自從1942年被希特勒僱傭為秘書後，轉眼到了1945年3月，蘇聯大軍兵臨城下，納粹德國政府內人心惶惶。不但重要的親信希姆萊和戈林相繼叛離希特勒而去，而且軍隊人手不足，連平民和小孩都被迫送上戰場，看不到希望的將軍也整日借酒消愁..."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"希特拉的最後十二夜","runtime":0,"tagline":"","homepage":"","overview":"電影從今日特勞德爾·榮格的回憶開始。榮格自從1942年被希特勒僱傭為秘書後，轉眼到了1945年3月，蘇聯大軍兵臨城下，納粹德國政府內人心惶惶。不但重要的親信希姆萊和戈林相繼叛離希特勒而去，而且軍隊人手不足，連平民和小孩都被迫送上戰場，看不到希望的將軍也整日借酒消愁。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Der Untergang - Det tredje rikets siste dager","runtime":156,"tagline":"","homepage":"","overview":"Tyskland er i oppløsning, og det tredje rikets nederlag synes uunngåelig. Hitler har forskanset seg i førerbunkeren i det sentrale Berlin hvor han avventer sin skjebne sammen med bl.a. sin kone Eva Braun og familien Goebbles. De allierte nærmer seg raskt Berlins porter, og Hitlers skiftende sinnstilstand blir verre og verre i takt med krigens utvikling. Førerens nedtelling mot slutten i bunkeren under Berlin vises i all sin galskap, og filmen tegner et bilde av en desillusjonert Hitler med en ekstrem angst for konspirasjoner."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"La Caída","runtime":155,"tagline":"Abril de 1945, una nación espera su ... caída.","homepage":"","overview":"Berlín, abril de 1945. La guerra está sentenciada, pero en las calles de Berlín todavía se libra una encarnizada batalla. Adolf Hitler y sus fieles se han atrincherado en un búnker. Entre ellos se encuentra Traudl Junge, la secretaria personal del Führer. En el exterior, la situación se recrudece. A pesar de que Berlín ya no puede resistir más, Hitler se niega a abandonar la ciudad y, acompañado de Eva Braun, prepara su despedida."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"سقوط","runtime":0,"tagline":"","homepage":"","overview":"فیلمی در ژانر درام جنگی، ساخته الیور هرشبیگل محصول سال ۲۰۰۴ است. سقوط بر اساس کتاب پناهگاه هیتلر تراودل یونگه، کتاب تا آخرین ساعت ملیسا مولر، کتاب هیتلر یوآخیم فست، خاطرات آلبرت اشپر و ارنست-گونتر باده روایت شده است. سقوط دوازده روز آخر زندگی آدولف هیتلر یعنی از ۱۷ تا اواخر آوریل سال ۱۹۴۵ میلادی را در سنگر زیرزمینی فرماندهی او به تصویر کشیده است. در این مرحله، فیلم از فروریختن ماشین نظامی و دستگاه سیاسی عظیم رژیم نازی آلمان آن پرده برمی‌دارد. سقوط از فیلم‌های پر هزینه تاریخ سینمای آلمان به شمار می‌رود. سقوط در اسکار ۲۰۰۴ نامزد جایزه بهترین فیلم خارجی‌زبان شد. امپایر این فیلم را در لیست صد فیلم برتر تاریخ سینمای جهان قرار داد  ترجمه از رضا بهادری"},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Hitler: Konačni pad","runtime":0,"tagline":"Film opisuje posljednje dane diktatora Adolfa Hitlera provedene u Berlinskom bunkeru.","homepage":"","overview":"U travnju 1945. godine, Njemačka se nalazi na rubu poraza jer se ruska vojska približava s istoka, a savezničke  snage napadaju sa zapada. U Berlinu, glavnom gradu Trećeg Reicha, Adolf Hitler proglašava da će Njemačka i dalje ostvarivati pobjedu i naređuje svojim generalima i savjetnicima da se bore do posljednjeg čovjeka. Kad kraj konačno dođe, a Hitler leži mrtav vlastitom rukom, ono što je ostalo od njegove vojske mora pronaći način da okonča bitku za Berlin."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Đế Chế Sụp Đổ","runtime":0,"tagline":"","homepage":"","overview":"Downfall - Der Untergang (2004) là một tác phẩm điện ảnh xuất sắc của Đức, hơn hết đây là bộ phim quan trọng vì nhân vật chính là một trong những tên tuổi có ảnh hưởng đến sự thay đổi của nhân loại - Adolf Hitler."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"ปิดตำนานบุรุษล้างโลก","runtime":0,"tagline":"","homepage":"","overview":"เบื้องหลังเหตุการณ์ที่เกิดขึ้นในช่วงก่อนที่กรุงเบอร์ลินจะถูกกองทัพ พันธมิตรเข้ายึดครอง ซึ่งเป็นช่วงเวลาสุดท้ายในชีวิตของ อดอล์ฟ ฮิตเลอร์ เนื้อเรื่องเป็นการผสมผสานเหตุการณ์ที่เกิดขึ้นจริงเข้ากับเรื่องเล่าต่างๆ โดยอ้างอิงจากหนังสือขายดีชื่อ Inside Hitler s Bunker ของจอคิม เฟสต์ และเรื่อง Until the Final Hour ของ เทราด์ ยุงเงอ และเมลิซซา มุลเลอร์ Dawnfall บอกเล่าเรื่องราวเหตุการณ์ต่างๆ ที่เกิดขึ้นภายในหลุมหลบภัยของฮิตเลอร์ ผ่านทาง เทราด์ ยุงเงอ เลขาคนสนิทของฮิตเลอร์ ผู้ชมจะได้สัมผัสกับอิทธิพลและอำนาจอันยำเกรงของฮิตเลอร์ รวมถึงลัทธิความเชื่อต่างๆ ที่ฝังลึกในจิตใจของผู้นำกองทัพนาซีผู้ซึ่งได้นำพากองทัพเยอรมันเข้าสู่ สงครามโลกครั้งที่สอง และเป็นต้นเหตุของการฆ่าล้างเผ่าพันธุ์ครั้งใหญ่ที่โลกต้องจดจำ Downfall จะนำผู้ชมย้อนกลับไปสัมผัสกับเหตุการณ์อันน่าสะพรึงกลัวเหล่านั้นอีกครั้ง ผ่านทางเรื่องเล่าที่แยบยล"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Trečiojo Reicho žlugimas","runtime":0,"tagline":"","homepage":"","overview":"1945 m. balandžio 20-oji diena, Berlynas. A. Hitleris su svita slepiasi bunkeriuose po Vokietijos Kanceliarija su vadu kartu slepiasi ir jo asmeninė sekretorė Traut Jungė - 22-jų metų rausvaskruostė mergina iš Miuncheno. Rusų armija supa Berlyna vis glaudesniu žiedu, sostinė pavirtusi griuvėsiais. Vokietijos pralaimėjimas neišvengiamas – Berlyną gina tik saujelė kareivių, remiama Liaudies Nerguliariosios kariuomenės (Volkssturm) ir paauglių iš Hitlerio Jaunimo formuočių. Giliai bunkeriuose A. Hitlerio meilužė Eva Braun ruošia 56-ojo Fiurerio gimtadienio šventę."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Allakäik","runtime":0,"tagline":"","homepage":"","overview":"Saksamaa 1945. Adolf Hitleri (Bruno Ganz) viimased päevad. Sõja kaotus on kindel. Ta ei tea kas põgeneda või võidelda lõpuni, kas jääda kodumaale truuks või üritada endal elu sees hoida. Ta laseb enda lapsed hukata ning veedab enda viimased tunnid koos Eva Brauniga salajases punkris ..."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"L'enfonsament","runtime":0,"tagline":"Abril de 1945, una nació espera la seva... caiguda","homepage":"","overview":"Berlín, abril del 1945. Una nació està a punt d'enfonsar-se. Als carrers de la capital alemanya s'hi lliura una batalla acarnissada. Les tropes soviètiques avancen ràpidament i ja tenen la ciutat pràcticament assetjada. Hitler s'ha atrinxerat al seu búnquer amb el seu cercle de confiança. Entre aquestes persones hi ha Traudl Junge, la secretària personal del Führer. Tot i que Berlín ja no pot resistir més, Hitler es nega a abandonar la ciutat, i tampoc vol negociar la capitulació amb les potències aliades. Ha perdut la noció de la realitat i continua pensant que pot guanyar la guerra. Quan per fi s'adona que no li queda cap sortida, prepara el seu últim comiat al costat de la seva dona, Eva Braun."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"سقوط","runtime":0,"tagline":"","homepage":"","overview":"آخر أيام الرايخ الثالث الألماني كما يحكيها (جونج) السكرتير الأخير لـ (هتلر)، ومع اقتراب الجيوش السوفيتية من جنوب وشرق برلين، نشاهد قيادات الرايخ، مثل: (هملر) الذي يحاول النجاة بنفسه، و(جوبلز) الذي يريد الموت مع هتلر، و(هتلر) نفسه الذي يطالبهم بالقتال إلى آخر رجل، والذي تنتابه لحظات من اليأس، ولحظات أخرى من جنون العظمة."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Propad","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"La Chute","runtime":0,"tagline":"","homepage":"","overview":"En avril 1945, Adolf Hitler s'est réfugié dans un bunker sous la chancellerie du IIIe Reich, alors que l'Armée Rouge resserre son étau sur Berlin, dont la population est en perdition. Autour de lui, il y a ses principaux commandants et ministres, notamment Joseph Goebbels, ainsi que sa maîtresse Eva Braun, sa secrétaire personnelle Traudl Junge, son architecte en chef Albert Speer et une poignée de soldats et officiers. Pendant quelques jours, le führer ordonne divers mouvements de troupe dans l'espoir d'empêcher l'avance des Soviétiques sur la capitale. Mais il devient bientôt évident que la guerre est perdue. Alors qu'autour de la chancellerie les tirs de mortier annoncent l'arrivée imminente de l'ennemi, Hitler et son entourage se préparent à mourir ou à fuir."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Der Untergang","runtime":156,"tagline":"","homepage":"","overview":"Berlin, April 1945. Während um ihn herum sein Hirngespinst Großdeutschland in Schutt und Asche liegt, deutsche Truppen quasi nur noch auf dem Papier existieren und die Alliierten die Macht übernehmen, hält Adolf Hitler in seinem Bunker Hof. Spielt sich und seinen Vasallen eine Mär vom unaufhörlichen Triumph der arischen Rasse vor, stachelt seine Untergebenen zu weiteren irrwitzigen Feldzügen an und präsentiert einen galoppierenden Realitätsverlust ungeahnten Ausmaßes. Bis auch im Bunker das große Sterben beginnt."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"}],"reviews_tmdb":[{"id":"64457d3cad87f704a272b314","url":"https://www.themoviedb.org/review/64457d3cad87f704a272b314","author":"Wuchak","content":"**_Hitler’s end_**\r\n\r\nAs the Red Army encroaches upon Berlin in late April, 1945, the final days of Hitler in his bunker (Bruno Ganz) are told from the perspective of his secretary, Traudl Junge (Alexandra Maria Lara).\r\n\r\n\"Downfall” (2004) is not a conventional war movie due to its downbeat subject and is more educational than entertaining, but it’s a necessary piece of the puzzle in understanding WW2. If you appreciate movies like \"Enemy at the Gates\" (2001), \"The Pianist\" (2002), \"Black Book\" (2006), \"Valkyrie\" (2008), \"Rommel\" (2012), \"Warsaw '44\" (2014) and \"Fury\" (2014), you’ll appreciate this one too.\r\n\r\nIt's hard to rate a flick like this because it’s not an enjoyable experience, but it works superbly as means to go back in history and view Hitler’s final days.\r\n\r\nThe film runs 2 hours, 36 minutes, and was shot in Germany (Berlin, Munich and Bavaria Studios) and Russia (St. Petersburg).\r\n\r\nGRADE: B","created_at":"2023-04-23T18:47:24.430Z","updated_at":"2023-05-31T05:20:51.708Z","author_details":{"name":"","rating":7,"username":"Wuchak","avatar_path":"/4KVM1VkqmXLOuwj1jjaSdxbvBDk.jpg"}},{"id":"69736c3dc5025fb8cf893d1a","url":"https://www.themoviedb.org/review/69736c3dc5025fb8cf893d1a","author":"CinemaSerf","content":"$11","created_at":"2026-01-23T12:40:29.352Z","updated_at":"2026-01-23T12:40:29.446Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":6977,"adult":false,"title":"No Country for Old Men","video":false,"overview":"Llewelyn Moss stumbles upon dead bodies, $2 million and a hoard of heroin in a Texas desert, but methodical killer Anton Chigurh comes looking for it, with local sheriff Ed Tom Bell hot on his trail. The roles of prey and predator blur as the violent pursuit of money and justice collide.","genre_ids":[80,53,37],"media_type":"movie","popularity":12.1762,"vote_count":13016,"poster_path":"/6d5XOczc226jECq0LIX0siKtgHR.jpg","release_date":"2007-11-09","vote_average":7.946,"backdrop_path":"/nsHXexZQvUJv8WXvmQHohn5Hv1l.jpg","original_title":"No Country for Old Men","original_language":"en"},{"id":853,"adult":false,"title":"Enemy at the Gates","video":false,"overview":"A Russian and a German sniper play a game of cat-and-mouse during the Battle of Stalingrad in WWII.","genre_ids":[18,10752,36,10749],"media_type":"movie","popularity":3.646,"vote_count":3943,"poster_path":"/cHRAbVdsCWFaQrswRsBP7Bn255W.jpg","release_date":"2001-02-28","vote_average":7.415,"backdrop_path":"/wSMaPDDwqfYbwg1GX9B5MaMnmxe.jpg","original_title":"Enemy at the Gates","original_language":"en"},{"id":2253,"adult":false,"title":"Valkyrie","video":false,"overview":"Wounded in Africa during World War II, Nazi Col. Claus von Stauffenberg returns to his native Germany and joins the Resistance in a daring plan to create a shadow government and assassinate Adolf Hitler. When events unfold so that he becomes a central player, he finds himself tasked with both leading the coup and personally killing the Führer.","genre_ids":[18,53,10752],"media_type":"movie","popularity":3.562,"vote_count":3989,"poster_path":"/8eoRtXswC8IQDsqW7iJWO56NhAv.jpg","release_date":"2008-12-25","vote_average":7,"backdrop_path":"/6ypfd9wGd7bmtmukzbPZfcaCMsO.jpg","original_title":"Valkyrie","original_language":"en"},{"id":6968,"adult":false,"title":"The Baader Meinhof Complex","video":false,"overview":"When German police viciously quell a protest against the shah of Iran, popular journalist Ulrike Meinhof rebels against her dishonest marriage, walks away from her children and joins radical anarchist Andreas Baader. Together with Baader's girlfriend, Gudrun Ensslin, they form the violent Red Faction Army, and together perpetrate a slew of terrorist attacks as a way of disrupting the fabric of what they see as an increasingly fascist state.","genre_ids":[28,80,18,36,53],"media_type":"movie","popularity":1.3622,"vote_count":640,"poster_path":"/36Y0UT6bXnkHBGmmVFWGEnEh8nI.jpg","release_date":"2008-09-25","vote_average":6.955,"backdrop_path":"/7Q44vznK8E9SYsdkmIanrLmydZn.jpg","original_title":"Der Baader Meinhof Komplex","original_language":"de"},{"id":318917,"adult":false,"title":"Look Who's Back","video":false,"overview":"When Adolf Hitler reawakens at the site of his former bunker in present-day Berlin, he is mistaken for a comedian and quickly becomes a media phenomenon.","genre_ids":[35],"media_type":"movie","popularity":2.1841,"vote_count":1893,"poster_path":"/1CxZWytSiCzZiZA5k0AiLUFtQNA.jpg","release_date":"2015-10-08","vote_average":6.786,"backdrop_path":"/4j4OGz6msCN9HsxcVWtHUIHGUqe.jpg","original_title":"Er ist wieder da","original_language":"de"},{"id":560391,"adult":false,"title":"Downhill","video":false,"overview":"Barely escaping an avalanche during a family ski vacation in the Alps, a married couple is thrown into disarray as they are forced to reevaluate their lives and how they feel about each other.","genre_ids":[18,35],"media_type":"movie","popularity":1.0127,"vote_count":292,"poster_path":"/ruLqLb2bfWKykckxVlVZayuBOgW.jpg","release_date":"2020-02-06","vote_average":5.236,"backdrop_path":"/nvZuBYHUGbrFl3LmDnmbRgrQ8xa.jpg","original_title":"Downhill","original_language":"en"},{"id":387,"adult":false,"title":"Das Boot","video":false,"overview":"A German submarine hunts allied ships during the Second World War, but it soon becomes the hunted. The crew tries to survive below the surface, while stretching both the boat and themselves to their limits.","genre_ids":[18,36,10752],"media_type":"movie","popularity":4.3112,"vote_count":2442,"poster_path":"/u8FhQPncOAkwcei2OI9orPWhV6K.jpg","release_date":"1981-09-17","vote_average":8.085,"backdrop_path":"/zGgIlpKE2xP18bhCGsnn79vh80j.jpg","original_title":"Das Boot","original_language":"de"},{"id":11838,"adult":false,"title":"Ju-on: The Grudge","video":false,"overview":"When a social worker is sent to check on a traumatized elderly woman whose family have moved in at the site of a notorious murder case, she unwittingly unleashes a cycle of terror that transmits via its victims.","genre_ids":[27],"media_type":"movie","popularity":2.8993,"vote_count":914,"poster_path":"/6q1hlBC6rudc3mHwXsbMBR2xAT6.jpg","release_date":"2002-10-18","vote_average":6.758,"backdrop_path":"/jNGVlbH2tnZmVqEIvuoxvV78vBY.jpg","original_title":"呪怨","original_language":"ja"},{"id":914,"adult":false,"title":"The Great Dictator","video":false,"overview":"Dictator Adenoid Hynkel tries to expand his empire while a poor Jewish barber tries to avoid persecution from Hynkel's regime.","genre_ids":[35,10752],"media_type":"movie","popularity":3.1385,"vote_count":3624,"poster_path":"/1QpO9wo7JWecZ4NiBuu625FiY1j.jpg","release_date":"1940-10-15","vote_average":8.285,"backdrop_path":"/c8Pi8F1FzpNebtgXcSjC9nWCdSW.jpg","original_title":"The Great Dictator","original_language":"en"},{"id":11101,"adult":false,"title":"Stalingrad","video":false,"overview":"A German Platoon is explored through the brutal fighting of the Battle of Stalingrad. After half of their number is wiped out and they're placed under the command of a sadistic captain, the platoon lieutenant leads his men to desert. The platoon members attempt escape from the city, now surrounded by the Soviet Army.","genre_ids":[18,36,10752],"media_type":"movie","popularity":2.0234,"vote_count":613,"poster_path":"/rB78VDAOK94KJWp9ofgE3GSQEor.jpg","release_date":"1993-01-20","vote_average":7.306,"backdrop_path":"/mo2O5ESdB7PWnY3OBS9jjvjeskB.jpg","original_title":"Stalingrad","original_language":"de"},{"id":348892,"adult":false,"title":"Bajrangi Bhaijaan","video":false,"overview":"A young mute girl from Pakistan loses herself in India with no way to head back. A devoted man with a magnanimous spirit undertakes the task to get her back to her motherland and unite her with her family.","genre_ids":[35,18,12],"media_type":"movie","popularity":2.2239,"vote_count":531,"poster_path":"/vhlliI7HZZlWfo5d6CiyfBAGLrW.jpg","release_date":"2015-07-17","vote_average":7.798,"backdrop_path":"/n9QCm8uagvmXH476u5qFQsW8HkU.jpg","original_title":"बजरंगी भाईजान","original_language":"hi"},{"id":2059,"adult":false,"title":"National Treasure","video":false,"overview":"Modern treasure hunters, led by archaeologist Ben Gates, search for a chest of riches rumored to have been stashed away by George Washington, Thomas Jefferson and Benjamin Franklin during the Revolutionary War. The chest's whereabouts may lie in secret clues embedded in the Constitution and the Declaration of Independence, and Gates is in a race to find the gold before his enemies do.","genre_ids":[12,28,53,9648],"media_type":"movie","popularity":5.2863,"vote_count":6730,"poster_path":"/pxL6E4GBOPUG6CdkO9cUQN5VMwI.jpg","release_date":"2004-11-19","vote_average":6.6,"backdrop_path":"/xXWT0je8dTFFNBq6P2CeTZkPUu2.jpg","original_title":"National Treasure","original_language":"en"},{"id":510,"adult":false,"title":"One Flew Over the Cuckoo's Nest","video":false,"overview":"A petty criminal fakes insanity to serve his sentence in a mental ward rather than prison. He soon finds himself as a leader to the other patients—and an enemy to the cruel, domineering nurse who runs the ward.","genre_ids":[18],"media_type":"movie","popularity":8.094,"vote_count":11223,"poster_path":"/kjWsMh72V6d8KRLV4EOoSJLT1H7.jpg","release_date":"1975-11-19","vote_average":8.4,"backdrop_path":"/6Oa3zTiluBz2W8D2ou1MY16dUiF.jpg","original_title":"One Flew Over the Cuckoo's Nest","original_language":"en"},{"id":47931,"adult":false,"title":"Elite Squad: The Enemy Within","video":false,"overview":"After a bloody invasion of the BOPE in the High-Security Penitentiary Bangu 1 in Rio de Janeiro to control a rebellion of interns, the Lieutenant-Colonel Roberto Nascimento and the second in command Captain André Matias are accused by the Human Right Aids member Diogo Fraga of execution of prisoners. Matias is transferred to the corrupted Military Police and Nascimento is exonerated from the BOPE by the Governor.","genre_ids":[18,28,80],"media_type":"movie","popularity":2.2016,"vote_count":1992,"poster_path":"/c7yCrf3PTSdp6RMGktZQhzFcFFM.jpg","release_date":"2010-10-08","vote_average":7.83,"backdrop_path":"/tmowA51oykuOdiyqRCP0jGYU1mB.jpg","original_title":"Tropa de Elite 2","original_language":"pt"},{"id":338,"adult":false,"title":"Good Bye, Lenin!","video":false,"overview":"Alex Kerner's mother was in a coma while the Berlin wall fell. When she wakes up he must try to keep her from learning what happened (as she was an avid communist supporter) to avoid shocking her which could lead to another heart attack.","genre_ids":[35,18],"media_type":"movie","popularity":1.3687,"vote_count":2578,"poster_path":"/uHk1oGEbnvQGLnyiiYxTslZLoog.jpg","release_date":"2003-02-13","vote_average":7.538,"backdrop_path":"/uBLmfG7MyNXPXI50eMs1ZjxpbnV.jpg","original_title":"Good Bye, Lenin!","original_language":"de"},{"id":828,"adult":false,"title":"The Day the Earth Stood Still","video":false,"overview":"An alien and a robot land on Earth after World War II and tell mankind to be peaceful or face destruction.","genre_ids":[878,53,18],"media_type":"movie","popularity":2.305,"vote_count":1206,"poster_path":"/eslDNzf0LF1m9GsgUXlmyfTcC6Y.jpg","release_date":"1951-09-18","vote_average":7.454,"backdrop_path":"/qwZRvb0DJ5IwDoRuKDRCBuHWzkw.jpg","original_title":"The Day the Earth Stood Still","original_language":"en"},{"id":10775,"adult":false,"title":"Infernal Affairs","video":false,"overview":"Chan Wing Yan, a young police officer, has been sent undercover as a mole in the local mafia. Lau Kin Ming, a young mafia member, infiltrates the police force. Years later, their older counterparts, Chen Wing Yan and Inspector Lau Kin Ming, respectively, race against time to expose the mole within their midst.","genre_ids":[18,28,53,80,9648],"media_type":"movie","popularity":4.2217,"vote_count":1812,"poster_path":"/gix9thDBXfjJ8M7rYbihqbQGBcP.jpg","release_date":"2002-12-12","vote_average":7.799,"backdrop_path":"/iiDGA97Kqt2dVU1deXQF06USBRu.jpg","original_title":"無間道","original_language":"cn"},{"id":205,"adult":false,"title":"Hotel Rwanda","video":false,"overview":"Inspired by true events, this film takes place in Rwanda in the 1990s when more than a million Tutsis were killed in a genocide that went mostly unnoticed by the rest of the world. Hotel owner Paul Rusesabagina houses over a thousand refuges in his hotel in attempt to save their lives.","genre_ids":[18,36,10752],"media_type":"movie","popularity":3.1821,"vote_count":3094,"poster_path":"/p3pHw85UMZPegfMZBA6dZ06yarm.jpg","release_date":"2004-12-22","vote_average":7.715,"backdrop_path":"/jkvvXaN7FPVKGlk8oj9PL0FHNtj.jpg","original_title":"Hotel Rwanda","original_language":"en"},{"id":55,"adult":false,"title":"Amores Perros","video":false,"overview":"A fatalistic car crash in Mexico city sets off a chain of events in the lives of three people: a supermodel, a young man wanting to run off with his sister-in-law, and a homeless man.","genre_ids":[18,53],"media_type":"movie","popularity":5.1714,"vote_count":2847,"poster_path":"/A4lH22nlFF7MdalGfcvSrlC1ttt.jpg","release_date":"2000-06-16","vote_average":7.633,"backdrop_path":"/nFXBmQAjNGdQUFPdTxE1OFqjx0X.jpg","original_title":"Amores perros","original_language":"es"},{"id":280,"adult":false,"title":"Terminator 2: Judgment Day","video":false,"overview":"Ten years after the events of the original, a reprogrammed T-800 is sent back in time to protect young John Connor from the shape-shifting T-1000. Together with his mother Sarah, he fights to stop Skynet from triggering a nuclear apocalypse.","genre_ids":[28,53,878],"media_type":"movie","popularity":15.2872,"vote_count":13971,"poster_path":"/jFTVD4XoWQTcg7wdyJKa8PEds5q.jpg","release_date":"1991-07-03","vote_average":8.139,"backdrop_path":"/xKb6mtdfI5Qsggc44Hr9CCUDvaj.jpg","original_title":"Terminator 2: Judgment Day","original_language":"en"}],"similar_content":[{"id":313219,"adult":false,"title":"Grasshopper","video":false,"overview":"Movie contains the stories of three people: Suzuki (Toma Ikuta), Kujira (Tadanobu Asano) and Semi (Ryosuke Yamada).  Suzuki is a former middle school teacher. His girlfriend was killed, which led him to quit his job and attempt to take revenge on her murderer. To do so, Suzuki has to infiltrate the underground world of criminals. Kujira is a contract killer for hire. He makes his targets fall into confusion and eventually commit suicide. Semi is a contract killer who uses the knife to take out his targets.","genre_ids":[80,53,28,18],"popularity":0.6663,"vote_count":15,"poster_path":"/h9YkeTwcSnep0ZvEA6U5KtqCzb5.jpg","release_date":"2015-11-07","vote_average":5.933,"backdrop_path":"/44L1vTmftGyK0aRtKFJMAMHsEc4.jpg","original_title":"グラスホッパー","original_language":"ja"},{"id":1502116,"adult":false,"title":"24 Flavors","video":false,"overview":"After years abroad, April returns to her homeland, discovering her divorced parents rekindling old ties. Memories of her extreme self-harm resurface as she grapples with her father's infidelity. Facing the impending demolition of the tea shop, April must decide between taking her mother Qiaozhen abroad or supporting her desire to continue the business. Struggling Yongtang silently raises funds for Qiaozhen's shop reopening, inadvertently falling into a scam. April also encounters her resilient half-sister Xiaojing. Amidst the challenges, she begins to reclaim the life, time, and self-reflection she had long avoided.","genre_ids":[18,10751],"popularity":0.1892,"vote_count":0,"poster_path":"/qmjW4BwHnuUJYccNGTP50ni9fMk.jpg","release_date":"2024-11-14","vote_average":0,"backdrop_path":null,"original_title":"二十四味","original_language":"zh"},{"id":1297370,"adult":false,"title":"Silent Introduction","video":false,"overview":"A pretentious record store clerk must defend her music taste after a finance bro tries to purchase a rare used record.","genre_ids":[18],"popularity":0.1291,"vote_count":0,"poster_path":"/svxYvOmwfxcZNBGhufXK7zKK8OW.jpg","release_date":"2024-06-06","vote_average":0,"backdrop_path":null,"original_title":"Silent Introduction","original_language":"en"},{"id":312973,"adult":false,"title":"The Man Who Lived at the Ritz","video":false,"overview":"In this drama, an American art student is trapped amidst the political turmoil of war-torn Europe while visiting Paris and staying at the fabulous Ritz hotel. Rather than cope constructively with it all, the fellow opts to ignore it and continue living the high-life for as long as possible.","genre_ids":[10770,18,10752],"popularity":0.2564,"vote_count":3,"poster_path":"/yBi5sr7MI2zhWME61IesOFPVc77.jpg","release_date":"1988-11-28","vote_average":3.333,"backdrop_path":null,"original_title":"The Man Who Lived at the Ritz","original_language":"en"},{"id":513340,"adult":false,"title":"Animals","video":false,"overview":"Longtime friends and party lovers Laura and Tyler navigate life and love in Dublin, Ireland but find themselves drifting apart when Laura becomes engaged.","genre_ids":[35,18],"popularity":0.5487,"vote_count":51,"poster_path":"/tQyvlLavdNz8xg1vn3Dt7ZC5SnK.jpg","release_date":"2019-08-02","vote_average":5.5,"backdrop_path":"/sNJ3fBAq37dcx3rbjrMuV8S7bkQ.jpg","original_title":"Animals","original_language":"en"},{"id":705394,"adult":false,"title":"Nástup","video":false,"overview":"\"The Rally\" is based on a communist writer Vaclav Řezáč's well-written novel of the same name","genre_ids":[18],"popularity":0.1393,"vote_count":4,"poster_path":null,"release_date":"1953-05-01","vote_average":4,"backdrop_path":null,"original_title":"Nástup","original_language":"cs"},{"id":901034,"adult":false,"title":"Battle Diary: A Day In The Life of Charlie Martin","video":false,"overview":"An extraordinary journey into the past to that fateful day, June 6, 1944. Relive the event of D-Day on the beaches of Normandy with Company Sergeant-Major Charlie Martin of the Queen's Own Rifles. Experience an emotional and intensely personal account of D-Day through a combination of interviews, archival film and Charlie Martin's diary excerpts.","genre_ids":[99,10752],"popularity":0.1417,"vote_count":0,"poster_path":null,"release_date":"1994-11-11","vote_average":0,"backdrop_path":null,"original_title":"Battle Diary: A Day In The Life of Charlie Martin","original_language":"en"},{"id":48620,"adult":false,"title":"The Mighty Macs","video":false,"overview":"In 1971, Cathy Rush becomes the head basketball coach at a tiny, all-girls Catholic college. Though her team has no gym and no uniforms — and the school itself is in danger of being sold — Rush looks to steer her girls to their first national championship.","genre_ids":[18],"popularity":0.5635,"vote_count":42,"poster_path":"/frNp8Rmkr8wBDyKrZ89gYvrtxBa.jpg","release_date":"2011-10-21","vote_average":5.2,"backdrop_path":"/lGWT72QzlEkICmYXw3nNjoLtNcZ.jpg","original_title":"The Mighty Macs","original_language":"en"},{"id":313057,"adult":false,"title":"Mugaldekoak","video":false,"overview":"Mugaldekoak is set in the early 40s, when, on this side of the border, the wounds of the Civil War were still open and, on the other, they were living under occupation by the German Army. The tale revolves around the Comète Network, an initiative developed during World War II on the border with Navarre: the clandestine evacuation of British pilots brought down in enemy territory.","genre_ids":[18,10752,10770],"popularity":2.0273,"vote_count":0,"poster_path":"/wb2aBfpFV1E8XizZNCzqyvWgSoX.jpg","release_date":"2010-04-14","vote_average":0,"backdrop_path":null,"original_title":"Mugaldekoak","original_language":"eu"},{"id":513409,"adult":false,"title":"Earthquake Bird","video":false,"overview":"Tokyo, Japan, 1989. Lucy Fly, a foreigner who works as a translator, begins a passionate relationship with Teiji, a mysterious man obsessed with photography.","genre_ids":[18,9648,10749,53],"popularity":0.8414,"vote_count":460,"poster_path":"/oyKnosHXQ7kkhlGwqsWOvn4RgKR.jpg","release_date":"2019-11-01","vote_average":5.932,"backdrop_path":"/rhklsYtIITDOdFSmhx2fIH9m9Vn.jpg","original_title":"Earthquake Bird","original_language":"en"},{"id":48412,"adult":false,"title":"Battle of the Coral Sea","video":false,"overview":"A US submarine and its crew are captured by the Japanese on the eve of a major WWII battle.","genre_ids":[10752,18,10749],"popularity":0.3527,"vote_count":21,"poster_path":"/5lays4bkpjNRS2pS419DF5ALHOU.jpg","release_date":"1959-11-01","vote_average":5.6,"backdrop_path":"/9ZTF03EQ4Pw4mr1ThQavqC7EBb6.jpg","original_title":"Battle of the Coral Sea","original_language":"en"},{"id":313011,"adult":false,"title":"Diary of a Rapist","video":false,"overview":"This Italian film takes a chilling, nonexploitative look into the mind of a nice young man who compulsively rapes beautiful women. The rapes are graphically presented and may be disturbing to some viewers. Outwardly Luca seems to be a normal, quiet 20-year old. His mother is frequently gone. Trouble begins when Luca becomes obsessed with Valeria, the beauty who works in the next building. He begins spying on her, and then secretly filming her with his camcorder. He tries to get to know her, but she ignores him. Unable to stand her constant refusal, the frustrated young man accosts her on dark street and rapes her. The first rape was almost accidental; he encountered her on the street and he hurt her. Unfortunately, he liked the violence and begins raping every attractive woman he sees. He is particularly violent with Lorena, a jewelry saleswoman whom he beats up in a park before violating her.","genre_ids":[18],"popularity":0.2237,"vote_count":5,"poster_path":"/yIqoKoDkPZ51ZznBN7LDAfBe5xk.jpg","release_date":"1995-02-23","vote_average":4.2,"backdrop_path":"/8BxIcFWrHj9YelOunpu57ZCZFz4.jpg","original_title":"Cronaca di un amore violato","original_language":"it"},{"id":313091,"adult":false,"title":"Ah Pook Is Here.","video":false,"overview":"A disturbingly organic-looking figure speaks to us of life, politics and death as the symbol of the common man toils away. Written and narrated by William S. Burroughs.","genre_ids":[14,18,16],"popularity":0.1395,"vote_count":8,"poster_path":"/c1g0LrBdwQF6ugpfwz6visCV7uv.jpg","release_date":"1994-10-01","vote_average":5.9,"backdrop_path":"/9p2Zwp2Umh0ZCBCpi83LhL0ZuYf.jpg","original_title":"Ah Pook Is Here.","original_language":"en"},{"id":48467,"adult":false,"title":"The Mountain of the Lord","video":false,"overview":"Recounts the 40-year history of building the Salt Lake Temple, shown as if recounted by Wilford Woodruff to a young reporter. It portrays the pioneers' dedication to temple worship.","genre_ids":[36,18,10751,99],"popularity":0.2735,"vote_count":9,"poster_path":"/2Lbeld2zqewPBpO6l2xGRMciHG5.jpg","release_date":"1993-03-01","vote_average":7.9,"backdrop_path":null,"original_title":"The Mountain of the Lord","original_language":"en"},{"id":705730,"adult":false,"title":"This Madding Crowd","video":false,"overview":"","genre_ids":[35,18],"popularity":0.3252,"vote_count":0,"poster_path":"/qTGmX7SgkpS6Ns6fKcYJW3ntpzN.jpg","release_date":"1962-06-28","vote_average":0,"backdrop_path":null,"original_title":"青べか物語","original_language":"ja"},{"id":1109402,"adult":false,"title":"Her Body","video":false,"overview":"A Czech high diver's Olympic dreams are shattered when she suffers a devastating injury while training. Forced to leave the sport she loves, she follows a photographer friend into the world of nude modeling, ultimately reinventing herself as an adult film actress. Inspired by the true story of diving champion Andrea Absolonová.","genre_ids":[18],"popularity":1.6021,"vote_count":39,"poster_path":"/foNYeBzrTpz94Sg9yV6hGMsax8A.jpg","release_date":"2023-11-16","vote_average":6,"backdrop_path":"/ffOxfVhSMcHiM26kWFQ9Lto4v6s.jpg","original_title":"Její tělo","original_language":"cs"},{"id":48697,"adult":false,"title":"Salomé","video":false,"overview":"Short film by Almodovar, which tells the origin of the veil. Abraham, walking with Isaac, meets Salomé, who dances and demands Isaac’s head. Isaac flees but is hypnotised and returned. Abraham, about to act, hears God reveal it was a test of temptation. Salomé is a divine figure, and Abraham is instructed to have women cover themselves as a sign of respect.","genre_ids":[18],"popularity":0.2681,"vote_count":26,"poster_path":"/fnwp6PeI4YU4sM0j4YUuZccumyC.jpg","release_date":"1978-01-01","vote_average":5.36,"backdrop_path":"/rXCZdBdwXp4BLMysPUpTTnJyd6k.jpg","original_title":"Salomé","original_language":"es"},{"id":48764,"adult":false,"title":"The Trial of Joan of Arc","video":false,"overview":"Rouen, Normandy, 1431, during the Hundred Years' War. After being captured by French soldiers from an opposing faction, Joan of Arc, the Maid of Orléans, is unjustly tried by an ecclesiastical court overseen by her English enemies.","genre_ids":[18,36],"popularity":0.3783,"vote_count":147,"poster_path":"/gHb9UUow3j25sMCb3wDIZatfIg1.jpg","release_date":"1963-02-13","vote_average":7.19,"backdrop_path":"/kpjWEZvoMhiinhDArNJ31VXvgh5.jpg","original_title":"Procès de Jeanne d'Arc","original_language":"fr"},{"id":48769,"adult":false,"title":"Gramps Is in the Resistance","video":false,"overview":"It is 1943 in Paris. Like so many others, the Bourbelle family's home has been taken over by the Germans and they now live in their cellar. Little do they know that the son, Guy-Hubert Bourdelle, is far from being the cowardly hairdresser he pretends. He is in truth the Germans’ most feared opponent: le super-résistant!","genre_ids":[35,10752],"popularity":1.4724,"vote_count":429,"poster_path":"/tYAaRDKCHSofMnUDqjg6AIAmTfi.jpg","release_date":"1983-10-26","vote_average":6.865,"backdrop_path":"/gWP0xqcpeapXBqKKPFqLFc2rxDQ.jpg","original_title":"Papy fai