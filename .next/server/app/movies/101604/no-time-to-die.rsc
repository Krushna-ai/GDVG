display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35},{"logo_path":"/vLZKlXUNDcZR7ilvfY9Wr9k80FZ.jpg","provider_id":538,"provider_name":"Plex","display_priority":126}],"flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":2},{"logo_path":"/dpR8r13zWDeUR0QkzWidrdMxa56.jpg","provider_id":1796,"provider_name":"Netflix Standard with Ads","display_priority":154}]},"UY":{"link":"https://www.themoviedb.org/movie/370172-no-time-to-die/watch?locale=UY","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"VE":{"buy":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":4}],"link":"https://www.themoviedb.org/movie/370172-no-time-to-die/watch?locale=VE","rent":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":4}],"flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3}],"link":"https://www.themoviedb.org/movie/370172-no-time-to-die/watch?locale=ZA","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}]},"ZW":{"buy":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":1}],"link":"https://www.themoviedb.org/movie/370172-no-time-to-die/watch?locale=ZW"}}},"wikidata_id":"Q21534241","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-09T22:49:57.461145+00:00","region":null,"main_poster":null,"images":null,"enriched_at":"2026-04-21T06:51:17.937+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":163,"tagline":"The mission that changes everything begins…","homepage":"https://mgm.com/movies/no-time-to-die","overview":"Bond has left active service and is enjoying a tranquil life in Jamaica. His peace is short-lived when his old friend Felix Leiter from the CIA turns up asking for help. The mission to rescue a kidnapped scientist turns out to be far more treacherous than expected, leading Bond onto the trail of a mysterious villain armed with dangerous new technology."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"James Bond har lämnat sin tjänst och njuter av ett lugnt liv på Jamaica. Lugnet blir dock kortvarigt då hans gamle vän Felix Leiter från CIA dyker upp och ber om hjälp. Uppdraget att rädda en kidnappad forskare visar sig vara mer förrädiskt än väntat."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Mourir peut attendre","runtime":163,"tagline":"La mission qui change tout commence…","homepage":"","overview":"James Bond a quitté les services secrets et coule des jours heureux en Jamaïque. Mais sa tranquillité est de courte durée car son vieil ami Felix Leiter de la CIA débarque pour solliciter son aide : il s'agit de sauver un scientifique qui vient d'être kidnappé. Mais la mission se révèle bien plus dangereuse que prévu et Bond se retrouve aux trousses d'un mystérieux ennemi détenant de redoutables armes technologiques…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"James Bond 007 - Keine Zeit zu sterben","runtime":163,"tagline":"Die Mission, die alles verändert, beginnt …","homepage":"https://www.007.com/keinezeitzusterben/","overview":"James Bond hat seine Lizenz zum Töten im Auftrag des britischen Geheimdienstes abgegeben und genießt seinen Ruhestand in Jamaika. Die friedliche Zeit nimmt ein unerwartetes Ende, als sein alter CIA-Kollege Felix Leiter auftaucht und ihn um Hilfe bittet. Ein bedeutender Wissenschaftler ist entführt worden und muss so schnell wie möglich gefunden werden. Was als simple Rettungsmission beginnt, erreicht bald einen bedrohlichen Wendepunkt, denn Bond kommt einem geheimnisvollen Gegenspieler auf die Spur, der im Besitz einer brandgefährlichen neuen Technologie ist."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Agent 007 - No Time To Die","runtime":0,"tagline":"","homepage":"","overview":"Agent 007 har trukket sig tilbage og lever det stille liv på Jamaica. Men freden slutter brat, da han bliver opsøgt af CIA-agenten Felix Leiter, der beder om hjælp. Missionen drejer sig om at redde en kidnappet forsker, men viser sig snart at trække tråde til den modbydelige skurk Safin, der har fået fat i et dødbringende biologisk våben - som han har til hensigt at bruge!"},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"007: Не время умирать","runtime":163,"tagline":"«Миссия, которая всё меняет, начинается...»","homepage":"https://www.universalpictures.ru/micro/no-time-to-die","overview":"Джеймс Бонд оставил оперативную службу и наслаждается спокойной жизнью на Ямайке. Все меняется, когда на острове появляется его старый друг Феликс Лейтер из ЦРУ с просьбой о помощи. Миссия по спасению похищенного ученого оказывается опаснее, чем предполагалось изначально. Бонд попадает в ловушку таинственного злодея, вооруженного опасным биологическим оружием."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"007: Смъртта може да почака","runtime":0,"tagline":"","homepage":"","overview":"Джеймс Бонд вече не е на активна служба и се наслаждава на спокоен живот в Ямайка. Спокойствието му скоро е нарушено от стария му приятел от ЦРУ Феликс Лайтър, който търси помощта му. Мисията да спасят отвлечен учен се оказва доста по-коварна от очакваното, хвърляйки Бонд по следите на мистериозен злодей, който държи в ръцете си опасна нова технология."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"007：无暇赴死","runtime":163,"tagline":"终极任务 亲眼见证","homepage":"","overview":"世界局势波诡云谲，再度出山的邦德（丹尼尔·克雷格 饰）面临有史以来空前的危机，传奇特工007的故事在本片中达到高潮。新老角色集结亮相，蕾雅·赛杜回归，二度饰演邦女郎玛德琳。系列最恐怖反派萨芬（拉米·马雷克 饰）重磅登场，毫不留情地展示了自己狠辣的一面，不仅揭开了玛德琳身上隐藏的秘密，还酝酿着危及数百万人性命的阴谋，幽灵党的身影也似乎再次浮出水面。半路杀出的新00号特工（拉什纳·林奇 饰）与神秘女子（安娜·德·阿玛斯 饰）看似与邦德同阵作战，但其真实目的依然成谜。关乎邦德生死的新仇旧怨接踵而至，暗潮汹涌之下他能否拯救世界？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"007 노 타임 투 다이","runtime":0,"tagline":"가장 강력한 운명의 적과 마주하다","homepage":"","overview":"MI6를 떠난 이후 매들린과 이탈리아의 오랜 도시 마테라에서 평화로운 일상을 즐기던 제임스 본드. 어느 날 CIA 요원 펠릭스가 찾아와 선별적 DNA 공격이 가능한 새로운 형태의 생화학 무기 유출을 알린다. 위험에 처한 전 세계를 구하기 위해 복귀하게 된 제임스 본드는 임무를 수행하는 과정에서 새로운 MI6 요원 노미를 만나고, 모든 사건의 배후에 운명으로 얽혀 있는 최악의 적 사핀이 존재한다는 것을 알아낸다. 위험천만한 위기 속, 감춰져 있던 비밀이 밝혀지면서 작전은 점점 더 예측할 수 없는 상황으로 치닫게 되는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"007: Не час помирати","runtime":163,"tagline":"Місія, що змінює все, починається…","homepage":"","overview":"Короткочасний спокій Бонда перериває нове термінове завдання, де ставки знову надто високі. Суперагент кидає виклик найвпливовішим гравцям злочинного світу, проливає світло на хитросплетені інтриги і викриває підступні змови."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Sin tiempo para morir","runtime":163,"tagline":"Comienza la misión que lo cambia todo...","homepage":"https://www.universalpictures.es/micro/sin-tiempo-para-morir","overview":"James Bond se encuentra disfrutando de unas merecidas vacaciones en Jamaica. Sin embargo, su paz termina cuando su amigo de la CIA, Felix Leiter, lo busca para una nueva misión que implica rescatar a un importante científico que ha sido secuestrado."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":163,"tagline":"","homepage":"","overview":"James Bond heeft de actieve dienst verlaten. Zijn rust is echter van korte duur wanneer zijn oude vriend Felix Leiter van de CIA opduikt met de vraag naar hulp. Het brengt hem op het spoor van een mysterieuze schurk gewapend met gevaarlijke nieuwe technologie."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"007：生死有時","runtime":164,"tagline":"","homepage":"","overview":"占士邦原本在牙買加享受低調人生，但安穩一時，迎上無限美女、未知危機和槍林彈雨，才是真正的特務風骨！他的一位 CIA 舊友 Felix Leiter 突然現身求助，表面上的任務只是營救被綁架科學家，查探下去卻發現背後陰謀超乎想像，令他身陷神秘黑手主宰的高科技殺局..."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Sin tiempo para morir","runtime":163,"tagline":"La misión que cambia todo, comienza...","homepage":"https://www.universalpictures-latam.com/micro/no-time-to-die","overview":"Bond se ha retirado del servicio como agente en activo y disfruta de una tranquila vida en Jamaica. Pero sus días de paz acaban cuando su viejo amigo Felix Leiter de la CIA aparece pidiéndole ayuda. La misión en cuestión, que consiste en rescatar a un científico secuestrado, resulta mucho más compleja de lo esperado y pone a Bond sobre la pista de un misterioso villano armado con peligrosa tecnología de vanguardia."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Τζέιμς Μποντ, Πράκτωρ 007: No Time To Die","runtime":163,"tagline":"Η αποστολή που αλλάζει τα πάντα ξεκινά...","homepage":"","overview":"Ο Τζέιμς Μποντ έχει εγκαταλείψει την ενεργό δράση και απολαμβάνει μια ήρεμη ζωή στη Τζαμάικα. Η γαλήνη της καθημερινότητάς του θα είναι προσωρινή και θα διακοπεί απότομα όταν ένας παλιός γνώριμος, ο Φίλιξ Λέιτερ της CIΑ, θα εμφανιστεί για να ζητήσει τη βοήθειά του. Η αποστολή διάσωσης ενός επιστήμονα τον οποίον έχουν απαγάγει θα αποδειχθεί πολύ πιο περίπλοκη απ’ ό,τι έδειχνε. Ο Τζέιμς Μποντ, μέσα από μια δαιδαλώδη διαδρομή που θα του υποδείξουν τα παρακρατικά μυστικά και οι απρόσμενες αποκαλύψεις, θα οδηγηθεί στα χνάρια ενός μυστηριώδους «κακού», ο οποίος έχει στην κατοχή του μια επικίνδυνη, νέα τεχνολογία."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Ölmek İçin Zaman Yok","runtime":0,"tagline":"Her şeyi değiştiren görev başlıyor…","homepage":"","overview":"James Bond aktif hizmetten ayrılmıştır ama yaşadığı huzur kısa ömürlü olacaktır. Çünkü CIA'den eski bir arkadaşı olan Felix Leiter ortaya çıkarak yardım isteyecek ve Bond'u tehlikeli yeni teknolojilerle donanmış gizemli bir kötü adamın izini sürmeye ikna edecektir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Nie je čas zomrieť","runtime":163,"tagline":"","homepage":"","overview":"James Bond, agent 007, skončil aktívnu službu a užíva si zaslúžený oddych na Jamajke. Pokoj však nemá dlhé trvanie – objaví sa totiž jeho starý priateľ Felix Leiter z CIA a požiada ho o pomoc. Misia na záchranu uneseného vedca sa ukáže byť oveľa zradnejšou, ako spočiatku vyzerala. Bond sa počas nej dostane na stopu nevyspytateľného zločinca, ktorý disponuje nebezpečnou a veľmi ničivou novou technológiou."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Není čas zemřít","runtime":0,"tagline":"Začíná mise, která všechno změní.","homepage":"","overview":"James Bond, agent 007, skončil aktivní službu a užívá si zasloužený odpočinek na Jamajce. Klid však nemá dlouhého trvání – objeví se totiž jeho starý přítel Felix Leiter ze CIA a požádá ho o pomoc. Mise na záchranu uneseného vědce se ukáže být zrádnější, než se na začátku zdálo. Bond se během vyšetřování dostane na stopu nevyzpytatelného zločince, který disponuje nebezpečnou a velmi ničivou novou technologií."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"007 No Time to Die","runtime":0,"tagline":"","homepage":"","overview":"Bond on jättänyt aktiivipalveluksen ja nauttii rauhallisesta elämästä Jamaikalla. Sitä ei kuitenkaan kauaa kestä, sillä hänen vanha ystävänsä Felix Leiter CIA:sta pyytää apua. Siepatun tutkijan pelastustehtävä osoittautuu odotettua vaikeammaksi ja vie Bondin vaarallisella teknologialla aseistautuneen mysteeririkollisen jäljille."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Nincs idő meghalni","runtime":0,"tagline":"Kezdődik a mindent megváltoztató küldetés.","homepage":"","overview":"James Bond visszavonult és Jamaicán élvezi a megérdemelt pihenést. De a nyugalom nem tarthat sokáig, egy régi barátja, Felix Leiter a CIA-tól a segítségét kéri. A küldetés egy elrabolt tudós megmentése, ami sokkal ármányosabb ügynek bizonyul, mint azt gondolták, és Bond hamarosan egy veszélyes új technológiával felfegyverzett rejtélyes bűnöző nyomában találja magát."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"לא זמן למות","runtime":0,"tagline":"המשימה שתשנה את הכול מתחילה...","homepage":"","overview":"בונד כבר איננו בשירות פעיל והוא נהנה מחיים שלווים בג'מייקה. שלוותו מופרת כאשר חברו משכבר הימים פליקס לייטר מהסי-איי-איי מופיע ומבקש את עזרתו. המשימה להציל מדען חטוף מסתבכת מעל למצופה ומובילה את בונד להתחקות אחר נבל מסתורי החמוש בטכנולוגיה חדשה ומסוכנת."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":163,"tagline":"Bond è tornato.","homepage":"","overview":"Bond ha abbandonato gli impegni in prima linea e si gode una tranquilla vita in Giamaica. La sua pace ha vita breve dopo che il vecchio amico Felix Leiter della CIA si palesa con una richiesta d’aiuto. La missione ha l’obiettivo di recuperare uno scienziato rapito e si rivela molto più complessa di quanto atteso: Bond sarà messo alla prova da un misterioso nemico dotato di una nuova arma tecnologica."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"007: Sem Tempo para Morrer","runtime":163,"tagline":"A missão que muda tudo começa...","homepage":"https://www.007.com/no-time-to-die/","overview":"Bond deixou o serviço ativo e está desfrutando de uma vida tranquila na Jamaica. Sua paz é interrompida quando o seu velho amigo Felix Leiter, da CIA, aparece pedindo sua ajuda. A missão de resgatar um cientista sequestrado acaba sendo muito mais difícil do que o esperado, deixando Bond no caminho de um vilão misterioso e armado com uma nova tecnologia perigosa."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"007: Sem Tempo para Morrer","runtime":163,"tagline":"007 chegou à Jamaica.","homepage":"","overview":"Bond já está reformado e decide aproveitar o seu tempo de descanso na Jamaica. Mas, a sua paz é rapidamente interrompida quando o seu velho amigo Felix Leiter, da CIA, aparece e pede ajuda. A missão desta vez é resgatar um cientista sequestrado. O novo desafio acaba por ser muito mais traiçoeiro do que esperava e Bond entra numa trilha de um vilão misterioso."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Nie czas umierać","runtime":163,"tagline":"Rozpoczyna się misja, która zmieni wszystko...","homepage":"","overview":"James Bond opuszcza czynną służbę i cieszy się spokojnym życiem na Jamajce. Tymczasem jednak jego stary przyjaciel Felix Leiter z CIA zwraca się do niego o pomoc. Misja uratowania porwanego naukowca okazuje się o wiele bardziej zdradliwa, niż mogłoby się wydawać i naprowadza agenta 007 na ślad tajemniczego złoczyńcy, dysponującego nową, niezwykle niebezpieczną technologią."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"เจมส์ บอนด์ 007 ภาค 25: 007 พยัคฆ์ร้ายฝ่าเวลามรณะ","runtime":164,"tagline":"","homepage":"","overview":"เรื่องราวของ เจมส์ บอนด์ (แดเนียล เคร็ก) ได้เลิกรับใช้ทางการและกำลังดื่มด่ำกับชีวิตที่แสนเงียบสงบในจาไมก้า แต่ช่วงเวลาสงบสุขของเขาช่างสั้นนัก เพราะเพื่อนเก่าของเขา เฟลิกซ์ ไลเตอร์ (เจฟฟรีย์ ไรท์) จากซีไอเอได้ปรากฏตัวมาขอความช่วยเหลือจากเขา ภารกิจในการช่วยเหลือนักวิทยาศาสตร์ที่ถูกลักพาตัวไปกลับกลายเป็นเรื่องที่ร้ายแรงเกินกว่าที่คาดคิดไว้มากมาย และนำบอนด์ไปสู่ร่องรอยของวายร้ายลึกลับที่มีเทคโนโลยีใหม่สุดอันตรายเป็นอาวุธ"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Mourir peut attendre","runtime":163,"tagline":"La mission qui change tout commence…","homepage":"","overview":"Bond a quitté le service actif et savoure des jours paisibles en Jamaïque. Mais sa paix est interrompue par son vieil ami de la CIA, Felix Leiter, qui vient lui demander de l’aide. La mission, qui consiste à sauver un scientifique enlevé, s’avère beaucoup plus périlleuse que prévu, entraînant Bond sur les traces d’un mystérieux criminel armé d’une nouvelle artillerie technologique."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Није време за умирање","runtime":0,"tagline":"","homepage":"","overview":"Бонд је напустио службу и ужива у мирном животу на Јамајци. Његов мир неће трајати дуго, када се појави његов пријатељ, Феликс Литер, молећи га за помоћ. Мисија у којој је потребно да избаве киднапованог научника испоставиће се много компликованија него што је било очекивано и навешће Бонда на траг мистериозном зликовцу који је наоружан новом, опасном технологијом."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Điệp Viên 007: Không Phải Lúc Chết","runtime":0,"tagline":"Một nhiệm vụ thay đổi tất cả.","homepage":"","overview":"Phần 25 của bộ phim điệp viên huyền thoại 007 sẽ tiếp nối câu chuyện về James Bond cùng những pha hành động táo bạo và hoành tráng hơn bao giờ hết. Sau sự kiện đầy ám ảnh trong Spectre, Bond lui về ở ẩn tại đất nước Jamaica, sống một cuộc đời cô độc nhưng bình lặng. Bỗng một người bạn cũ từ CIA xuất hiện, cầu xin anh giúp đỡ. Bond bất đắc dĩ phải tái xuất, nhưng không hề biết mình sẽ đối đầu với thế lực nào. Chi tiết đáng chú ý nhất là chiếc mặt nạ trắng vỡ nửa, đánh dấu sự xuất hiện của tên ác nhân kì quái bậc nhất trong cả series 007. Màn chạm trán giữa Bond và kẻ thù nguy hiểm này sẽ vén màn những bí ẩn còn để ngỏ và tiếp theo đó, có thể là một cuộc đối đầu “sinh tử”."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"სიკვდილის დრო არ არის","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Nav laiks mirt","runtime":0,"tagline":"","homepage":"","overview":"Džeimss Bonds ir atstājis operatīvo dienestu un bauda mierīgu dzīvi Jamaikā. Viss mainās, kad salā ierodas viņa vecais draugs Felikss Leiters no CIP ar lūgumu palīdzēt. Uzdevums glābt nolaupītu zinātnieku negaidīti izvēršas par slazdu Bondam. Viņš nonāk aci pret aci ar noslēpumainu ienaidnieku, kura rokās ar bīstams jauno tehnoloģiju ierocis."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"","runtime":163,"tagline":"Misi yang merubah segalanya telah dimulai","homepage":"https://www.007.com/","overview":"Bond telah meninggalkan agensi dan menikmati kehidupan yang tenang di Jamaika. Kehidupan damainya berakhir setelah teman lamanya Felix Leiter dari CIA muncul dan meminta bantuannya. Misi awal untuk menyelamatkan ilmuwan yang diculik berkembang menjadi lebih rumit dari yang diharapkan, Bond dihadapkan dengan seorang penjahat misterius yang memiliki senjata teknologi terbaru yang berbahaya."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"لا وَقتَ لِلمَوت","runtime":0,"tagline":"تبدأ المهمة التي تغير كل شيء ...","homepage":"","overview":"ترك بوند الخدمة النشطة ويتمتع بحياة هادئة في جامايكا. لم يدم سلامه طويلاً عندما ظهر صديقه القديم فيليكس ليتر من وكالة المخابرات المركزية يطلب المساعدة. اتضح أن مهمة إنقاذ عالم مخطوف أكثر غدرًا مما كان متوقعًا ، مما دفع بوند إلى مسار الشرير الغامض المسلح بتكنولوجيا جديدة خطيرة."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Za smrt nema vremena","runtime":0,"tagline":"Misija koja mijenja sve započinje...","homepage":"","overview":"Bond je napustio aktivnu službu, no njegova „penzija“ je kratkog vijeka. Dugogodišnji prijatelj iz CIA-e Felix Leiter od njega traži pomoć u borbi protiv misterioznog zločinca naoružanog opasnom novom tehnologijom."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Mirtis palauks","runtime":0,"tagline":"","homepage":"","overview":"Džeimsas Bondas mėgaujasi poilsiu Jamaikoje. Ramią agento kasdienybę sujaukia CŽV skambutis – tikinama, jog netikėtai dingo svarbius tyrimus vykdęs mokslininkas, o vieninteliu jį rasti galinčiu žmogumi pasirodo esąs Džeimsas Bondas. Vyras vyksta į Londoną, kur dar sykį imasi 007 vaidmens, tačiau eiline turėjusi tapti mokslininko gelbėjimo misija komplikuojasi ir tampa kur kas pavojingesne užduotimi negu buvo manyta iš pradžių. Kultinis agentas patenka į paslaptingo piktadario Safino spąstus, galinčius tapti paskutine 007 gyvenimo stotele…"},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"007／ノー・タイム・トゥ・ダイ","runtime":0,"tagline":"時は来た。","homepage":"","overview":"ボンドは00エージェントを退き、ジャマイカで静かに暮らしていた。しかし、CIAの旧友フィリックスが助けを求めてきたことで平穏な生活は突如終わってしまう。誘拐された科学者の救出という任務は、想像を遥かに超えた危険なものとなり、やがて、凶悪な最新技術を備えた謎の黒幕を追うことになる。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"James Bond: No Time To Die","runtime":0,"tagline":"","homepage":"","overview":"Gleden av et tilbaketrukket liv er kortvarig når hans gamle venn Felix Leiter fra CIA dukker opp for å be om hjelp. Oppdraget omhandler å redde en kidnappet forsker, men dette viser seg å være langt mer utfordrende enn forventet, og fører Bond på sporet av en mystisk skurk bevæpnet med farlig ny teknologi."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"لا وقت للموت","runtime":0,"tagline":"تبدأ المهمة التي تغير كل شيء ...","homepage":"","overview":"ترك بوند العميل النشط و الذي يتمتع بحياة هادئة في جامايكا. لم يدم سلامه طويلاً عندما ظهرت صديقه القديم فيليكس ليتر من وكالة المخابرات المركزية يطلب المساعدة. اتضح أن مهمة إنقاذ عالم مختطف أكثر غدرًا مما كان متوقعًا ، مما دفع بوند إلى مسارات شريرة غامضة مسلح بتكنولوجيا جديدة خطيرة."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"007：生死交戰","runtime":0,"tagline":"","homepage":"","overview":"從前線退休的007詹姆斯龐德，在牙買加享受著平靜的餘光，但當他的CIA中央情報局舊友菲利克斯萊特前來向他尋求幫助，這短暫的平靜也隨之結束。M派給龐德的任務本是去營救一個被綁架的科學家，但他不只發現他的007位置被一位女性探員取代，更發現他將要面對一個新型態科技犯罪組織，自己還會身陷危險之中……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"007 James Bond: Nu e vreme de murit","runtime":163,"tagline":"Începe misiunea care schimbă totul...","homepage":"","overview":"Bond a părăsit serviciul activ și se bucură de viață în Jamaica. Însă nu are parte de pace prea mult timp, deoarece vechiul lui prieten de la CIA, Felix Leiter, vine să-i ceară ajutorul."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.universalpictures.at/micro/no-time-to-die","overview":""},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"Ni čas za smrt","runtime":163,"tagline":"Začenja se misija, ki spremeni vse...","homepage":"","overview":"Tajni agent James Bond se je umaknil iz aktivne službe ter uživa mirno življenje na Jamajki. A njegov mir ne traja dolgo, saj ga njegov stari prijatelj Felix Leiter iz CIE prosi za pomoč. Misija reševanja ugrabljenega znanstvenika pa se izkaže za veliko bolj zahrbtno, kot je bilo pričakovati, najboljšega agenta njenega veličanstva pa vodi na sled skrivnostnega negativca, oboroženega z nevarno novo tehnologijo."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"زمانی برای مردن نیست","runtime":0,"tagline":"","homepage":"","overview":"جیمز باند وظیفه دارد یک دانشمند که به گروگان گرفته شده است را نجات دهد. او به دنبال گیر انداختن یکی از افراد شرور مرموز است که به تکنولوژی های جدید و خطرناکی مجهز می باشد."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Ma aha Waqti la Dhinto","runtime":0,"tagline":"Hawlgalka wax walba beddelaya ayaa bilaabmaya…","homepage":"","overview":"Bond wuxuu ka fadhiistay shaqadii wuxuuna ku raaxeysanayaa nolol xasilloon gudaha Jamaica. Nabaddiisu way gaabnaan markii saaxiibkiisii hore ee Felix Leiter oo ka socday CIA uu u yimaado isagoo gargaar weydiisanaya. Hawlgalka lagu badbaadinayo saynisyahan la afduubay ayaa noqday mid ka daran sidii la filayey, taasoo u horseeday Bond inuu ogaado sharfale dahsoon oo ku hubaysan tignoolajiyad cusub oo khatar ah."},"name":"Somali","iso_639_1":"so","iso_3166_1":"SO","english_name":"Somali"},{"data":{"title":"Sense temps per morir","runtime":0,"tagline":"Comença la missió que ho canvia tot...","homepage":"","overview":"James Bond està gaudint d'unes merescudes vacances a Jamaica. Tot i això, la seva pau acaba quan el seu amic de la CIA, Felix Leiter, el busca per a una nova missió que implica rescatar un important científic que ha estat segrestat."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"No time to die ကတော့ No time to disappoint ပါပဲ။ ကျေနပ်စရာကောင်းပါတယ်။ အနားယူပြီးဖြစ်တဲ့ဂျိန်းစ်ဘွန်းကို စီအိုင်အေက စပက်တာတွေနဲ့ ပတ်သတ်တဲ့အမှုတစ်ခု အကူအညီတောင်းလို့ လက်ခံလိုက်ရင်းနဲ့ 007 အသစ်နဲ့ တွေ့ပြီး အရင်ရန်သူဟောင်းတွေရော ရန်သူသစ်တွေရော ချစ်သူဟောင်းတွေရောနဲ့ တွေ့ပြီး ဇာတ်လမ်းတွေရှုပ်ကုန်တာပေါ့။ အဓိကကတော့ ဇီဝလက်နက်နဲ့ လူတွေသတ်ပြီး ကမ္ဘာကြီးကို ပြင်ဆင်ပေးချင်တဲ့ သူတော်ကောင်းကြီးကို007 ဟောင်း လူယုတ်မာကြီးက လိုက်ပြီး တားဆီးရတဲ့ ဇာတ်လမ်းပါပဲ။ အများကြီးတော့ ဇာတ်လမ်းကို မပြောပြတော့ပါဘူး။အားလုံးကြိုက်ကြမှာပါ။"},"name":"","iso_639_1":"my","iso_3166_1":"MY","english_name":"Burmese"},{"data":{"title":"नो टाइम टू डाय","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"007: Surm peab ootama","runtime":0,"tagline":"","homepage":"","overview":"James Bond on lahkunud tegevteenistusest. Tema rahu on lühiajaline, kui CIA vana sõber Felix Leiter ilmub abi paluma ja saadab Bondi missioonile salapärase ohtliku uue tehnoloogiaga relvastatud kurijategija vastu kes on röövinud teadlase."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"}],"reviews_tmdb":[{"id":"615878f3dd731b0042adc7a0","url":"https://www.themoviedb.org/review/615878f3dd731b0042adc7a0","author":"Manuel São Bento","content":"$11","created_at":"2021-10-02T15:21:23.647Z","updated_at":"2021-10-02T15:21:23.647Z","author_details":{"name":"Manuel São Bento","rating":8,"username":"msbreviews","avatar_path":null}},{"id":"6159165d51a64e00283f5cd0","url":"https://www.themoviedb.org/review/6159165d51a64e00283f5cd0","author":"RADIO1'S MR. MOVIE!-MAD AMI 🌠","content":"$12","created_at":"2021-10-03T02:33:01.830Z","updated_at":"2021-10-07T15:51:26.597Z","author_details":{"name":"RADIO1'S MR. MOVIE!-MAD AMI 🌠","rating":10,"username":"Radio1'sMr.Movie!-MadAmi🌠","avatar_path":"/5xKJup6PHf9O52gTxleT4oSkCtd.jpg"}},{"id":"61d86e9842d83700438863df","url":"https://www.themoviedb.org/review/61d86e9842d83700438863df","author":"David","content":"As a life long James Bond fan I thought this movie was a fitting end to the Daniel Craig era as James Bond.  I did not think it would be possible to top Casino Royale, however I think this movie did just that.  This will cement Daniel Craig's legacy as either the best actor to play James Bond or as an equal to Sean Connery.","created_at":"2022-01-07T16:47:20.299Z","updated_at":"2022-01-15T16:17:08.861Z","author_details":{"name":"David","rating":10,"username":"uofmtailgtr","avatar_path":"/jP6T7CTQVUEiasCAFxeDeeU7zto.jpg"}},{"id":"61f1a41c028420009457e0ab","url":"https://www.themoviedb.org/review/61f1a41c028420009457e0ab","author":"Unknownian","content":"This final Bond installment with Craig had the potential to be his best Bond movie.\r\n\r\nThe good:\r\nCinematography, locations, Story, action, and directing.\r\n\r\nThe poor: Rami Malek, the villain, is by far the absolute WORST Bond villain in the history of the franchise. He will literally \"put you to sleep\". Perhaps he was nervous and decided to swallow an entire bottle of Valium before each take.\r\n\r\nLashana Lynch, plays Bond's replacement when he retires. (Nomi) Although her acting was OK, her character is totally unnecessary in the movie, and she gives me the impression that the Producers were more interested in being politically correct\r\nthan making a great film.  They could have cut 30 minutes off this over-length film by simply adding her to the cutting room floor.","created_at":"2022-01-26T19:42:20.469Z","updated_at":"2022-02-02T14:10:23.605Z","author_details":{"name":"","rating":7,"username":"Unknownian","avatar_path":"/1e28g4SWlHHf9MUBVKbZpwxfMsm.jpg"}},{"id":"63be70c35be00e008c137724","url":"https://www.themoviedb.org/review/63be70c35be00e008c137724","author":"GenerationofSwine","content":"I guess there was time to die, and as so many predicted, be replaced with a female Bond of color.  Because... woke.\r\n\r\nBut it is fitting that Craig went out like that, he seemed to be the only man in the world that didn't want to be James Bond.  There was nothing playful about him...\r\n\r\n... he was just miserable, and miserable from start to finish.  I don't see the draw in watching a depressing 007, and I don't see the draw in watching the inevitable new Politically Correct 007 either.\r\n\r\nNeither seem to fit with the franchise.","created_at":"2023-01-11T08:18:11.106Z","updated_at":"2023-01-11T08:18:11.182Z","author_details":{"name":"","rating":1,"username":"GenerationofSwine","avatar_path":"/xYhvrFNntgAowjRsf6mRg9JgITr.jpg"}},{"id":"63cc4fcbd363e5009d68191d","url":"https://www.themoviedb.org/review/63cc4fcbd363e5009d68191d","author":"The Movie Mob","content":"$13","created_at":"2023-01-21T20:49:15.644Z","updated_at":"2023-01-21T20:49:15.746Z","author_details":{"name":"The Movie Mob","rating":5,"username":"mooney240","avatar_path":"/blEC280vq31MVaDcsWBXuGOsYnB.jpg"}},{"id":"643e1b63dd47160469d978c9","url":"https://www.themoviedb.org/review/643e1b63dd47160469d978c9","author":"drystyx","content":"Damsel in distress.\r\nExcept that's what makes this film stand out as different from other Bond movies. \r\nIt isn't a damsel in distress, but instead a child in jeopardy. 007 finds himself trying to protect the most innocent of creatures.\r\nAlong the way, he goes through some high octane action sequences. And he fights against a villain using genetic engineering in a weird and deadly way.\r\nHowever, the biggest problems here are \"predictability\" and \"horrible directing\".\r\nThe imagery is horrible. Even when there are exotic locales, there is not one cinematic second. It's all dull and tedious.\r\nThe classic 007 films of the Connery and Moore era had cinematic beauty with exotic locales. \r\nIn the era of Daniel Craig, this poor actor has to go through movies where the director can't even make imagery out of the most exotic locations.\r\nWhy even film on locations? This may as well been done in the studio of Mr. Rogers and his neighborhood.","created_at":"2023-04-18T04:24:03.850Z","updated_at":"2023-04-18T04:24:03.947Z","author_details":{"name":"","rating":5,"username":"drystyx","avatar_path":"/hLLsAvAnVT0cFU7JuuaaItTWXv8.jpg"}},{"id":"6741c8fe4b15b8ae31b01aeb","url":"https://www.themoviedb.org/review/6741c8fe4b15b8ae31b01aeb","author":"tmdb93836550","content":"This is mid, very overrated and is actually disliked by the fandom.","created_at":"2024-11-23T12:22:22.229Z","updated_at":"2024-11-23T12:22:22.277Z","author_details":{"name":"","rating":6,"username":"tmdb93836550","avatar_path":null}}],"recommendations":[{"id":438631,"adult":false,"title":"Dune","video":false,"overview":"Paul Atreides, a brilliant and gifted young man born into a great destiny beyond his understanding, must travel to the most dangerous planet in the universe to ensure the future of his family and his people. As malevolent forces explode into conflict over the planet's exclusive supply of the most precious resource in existence-a commodity capable of unlocking humanity's greatest potential-only those who can conquer their fear will survive.","genre_ids":[878,12],"media_type":"movie","popularity":20.9281,"vote_count":14477,"poster_path":"/d5NXSklXo0qyIYkgV94XAgMIckC.jpg","release_date":"2021-09-15","vote_average":7.778,"backdrop_path":"/wYMbnrdRCREjNLwFlG5SLWzBjui.jpg","original_title":"Dune","original_language":"en"},{"id":566525,"adult":false,"title":"Shang-Chi and the Legend of the Ten Rings","video":false,"overview":"Shang-Chi must confront the past he thought he left behind when he is drawn into the web of the mysterious Ten Rings organization.","genre_ids":[28,12,14],"media_type":"movie","popularity":12.8124,"vote_count":10200,"poster_path":"/d08HqqeBQSwN8i8MEvpsZ8Cb438.jpg","release_date":"2021-09-01","vote_average":7.496,"backdrop_path":"/fJbWgOb9pSQXihM9m10bRvl2dJ8.jpg","original_title":"Shang-Chi and the Legend of the Ten Rings","original_language":"en"},{"id":617653,"adult":false,"title":"The Last Duel","video":false,"overview":"King Charles VI declares that Knight Jean de Carrouges settle his dispute with his squire, Jacques Le Gris, by challenging him to a duel.","genre_ids":[36,18,28],"media_type":"movie","popularity":5.818,"vote_count":3753,"poster_path":"/zjrJE0fpzPvX8saJXj8VNfcjBoU.jpg","release_date":"2021-10-13","vote_average":7.414,"backdrop_path":"/4LrL40XecjGLRpX5I2gzMTUt04l.jpg","original_title":"The Last Duel","original_language":"en"},{"id":512195,"adult":false,"title":"Red Notice","video":false,"overview":"An Interpol-issued Red Notice is a global alert to hunt and capture the world's most wanted. But when a daring heist brings together the FBI's top profiler and two rival criminals, there's no telling what will happen.","genre_ids":[28,35,80],"media_type":"movie","popularity":6.1832,"vote_count":6293,"poster_path":"/lAXONuqg41NwUMuzMiFvicDET9Y.jpg","release_date":"2021-11-04","vote_average":6.743,"backdrop_path":"/p34WRcgkN2QIHcds5FtFiSpV3PC.jpg","original_title":"Red Notice","original_language":"en"},{"id":580489,"adult":false,"title":"Venom: Let There Be Carnage","video":false,"overview":"After finding a host body in investigative reporter Eddie Brock, the alien symbiote must face a new enemy, Carnage, the alter ego of serial killer Cletus Kasady.","genre_ids":[878,28,12],"media_type":"movie","popularity":9.5327,"vote_count":11025,"poster_path":"/pzKsRuKLFmYrW5Q0q8E8G78Tcgo.jpg","release_date":"2021-09-30","vote_average":6.752,"backdrop_path":"/eENEf62tMXbhyVvdcXlnQz2wcuT.jpg","original_title":"Venom: Let There Be Carnage","original_language":"en"},{"id":542178,"adult":false,"title":"The French Dispatch of the Liberty, Kansas Evening Sun","video":false,"overview":"The staff of an American magazine based in France puts out its last issue, with stories featuring an artist sentenced to life imprisonment, student riots, and a kidnapping resolved by a chef.","genre_ids":[18,35],"media_type":"movie","popularity":4.2746,"vote_count":2909,"poster_path":"/6JXR3KJH5roiBCjWFt09xfgxHZc.jpg","release_date":"2021-10-21","vote_average":7.011,"backdrop_path":"/xS0rl1YrVt51ztzjRf6qoIPZ7TA.jpg","original_title":"The French Dispatch of the Liberty, Kansas Evening Sun","original_language":"en"},{"id":522402,"adult":false,"title":"Finch","video":false,"overview":"On a post-apocalyptic Earth, a robot, built to protect the life of his dying creator's beloved dog, learns about life, love, friendship, and what it means to be human.","genre_ids":[878,18,12],"media_type":"movie","popularity":4.3118,"vote_count":3845,"poster_path":"/eEJtzD1F05xDipFEDY98CTH5yZn.jpg","release_date":"2021-11-04","vote_average":7.8,"backdrop_path":"/uoc358GH6Yl7TufbUKHkETPu64B.jpg","original_title":"Finch","original_language":"en"},{"id":550988,"adult":false,"title":"Free Guy","video":false,"overview":"A bank teller discovers he is actually a background player in an open-world video game, and decides to become the hero of his own story. Now, in a world where there are no limits, he is determined to be the guy who saves his world his way before it's too late.","genre_ids":[35,12,878],"media_type":"movie","popularity":9.1948,"vote_count":9581,"poster_path":"/dxraF0qPr1OEgJk17ltQTO84kQF.jpg","release_date":"2021-08-11","vote_average":7.456,"backdrop_path":"/7py8kUCYaOdFn1TfVS87BDBySOz.jpg","original_title":"Free Guy","original_language":"en"},{"id":646380,"adult":false,"title":"Don't Look Up","video":false,"overview":"Two astronomers go on a media tour to warn humankind of a planet-killing comet hurtling toward Earth. The response from a distracted world: Meh.","genre_ids":[35,878,18],"media_type":"movie","popularity":8.9625,"vote_count":9123,"poster_path":"/th4E1yqsE8DGpAseLiUrI60Hf8V.jpg","release_date":"2021-12-08","vote_average":7.062,"backdrop_path":"/xMJvffWIaW9MtlY9aIXKViUNeIO.jpg","original_title":"Don't Look Up","original_language":"en"},{"id":576845,"adult":false,"title":"Last Night in Soho","video":false,"overview":"A young girl, passionate about fashion design, is mysteriously able to enter the 1960s where she encounters her idol, a dazzling wannabe singer. But 1960s London is not what it seems, and time seems to be falling apart with shady consequences.","genre_ids":[27,9648],"media_type":"movie","popularity":3.5936,"vote_count":3769,"poster_path":"/n1ZRmjlk1BJTY7aASqACfPAaLn2.jpg","release_date":"2021-10-21","vote_average":7.281,"backdrop_path":"/nPWy5KISy7BbUOQcg588dflKzTL.jpg","original_title":"Last Night in Soho","original_language":"en"},{"id":738652,"adult":false,"title":"Copshop","video":false,"overview":"On the run from a lethal assassin, a wily con artist devises a scheme to hide out inside a small-town police station. However, when the hit man turns up at the precinct, an unsuspecting rookie cop finds herself caught in the crosshairs.","genre_ids":[53,80,28],"media_type":"movie","popularity":5.2995,"vote_count":875,"poster_path":"/9LEWWWEhS7SZXFDuH1YYhs0VFct.jpg","release_date":"2021-09-09","vote_average":6.299,"backdrop_path":"/jIkH6cy0Haa1cyitn6gtKmE3lxu.jpg","original_title":"Copshop","original_language":"en"},{"id":655082,"adult":false,"title":"Eiffel","video":false,"overview":"The French government is asking Gustave Eiffel to design something spectacular for the 1889 Paris World Fair, but he simply wants to design the subway—until he crosses paths with a mysterious woman from his past.","genre_ids":[10749,18],"media_type":"movie","popularity":0.9681,"vote_count":714,"poster_path":"/lG2gzXq2ZhZ806Ac7KCKsvNJ6yK.jpg","release_date":"2021-10-07","vote_average":6.246,"backdrop_path":"/AfrGOrPC85hte5sSb94zlSizalT.jpg","original_title":"Eiffel","original_language":"fr"},{"id":796499,"adult":false,"title":"Army of Thieves","video":false,"overview":"A mysterious woman recruits bank teller Ludwig Dieter to lead a group of aspiring thieves on a top-secret heist during the early stages of the zombie apocalypse.","genre_ids":[28,80,35],"media_type":"movie","popularity":4.4335,"vote_count":2224,"poster_path":"/j04Oepj3LGTWSb1ltXm0pcy50Xq.jpg","release_date":"2021-10-29","vote_average":6.8,"backdrop_path":"/bo4evsmoKb16AD1OhHgVOlgJtBw.jpg","original_title":"Army of Thieves","original_language":"en"},{"id":497698,"adult":false,"title":"Black Widow","video":false,"overview":"Natasha Romanoff, also known as Black Widow, confronts the darker parts of her ledger when a dangerous conspiracy with ties to her past arises. Pursued by a force that will stop at nothing to bring her down, Natasha must deal with her history as a spy and the broken relationships left in her wake long before she became an Avenger.","genre_ids":[28,12,878],"media_type":"movie","popularity":11.9978,"vote_count":11032,"poster_path":"/7JPpIjhD2V0sKyFvhB9khUMa30d.jpg","release_date":"2021-07-07","vote_average":7.175,"backdrop_path":"/6azpBJGcLx9SKif8h9VMnflBfa.jpg","original_title":"Black Widow","original_language":"en"},{"id":524434,"adult":false,"title":"Eternals","video":false,"overview":"The Eternals are a team of ancient aliens who have been living on Earth in secret for thousands of years. When an unexpected tragedy forces them out of the shadows, they are forced to reunite against mankind’s most ancient enemy, the Deviants.","genre_ids":[878,28,12],"media_type":"movie","popularity":11.1032,"vote_count":8970,"poster_path":"/lFByFSLV5WDJEv3KabbdAF959F2.jpg","release_date":"2021-11-03","vote_average":6.778,"backdrop_path":"/c6H7Z4u73ir3cIoCteuhJh7UCAR.jpg","original_title":"Eternals","original_language":"en"},{"id":436969,"adult":false,"title":"The Suicide Squad","video":false,"overview":"Supervillains Harley Quinn, Bloodsport, Peacemaker and a collection of nutty cons at Belle Reve prison join the super-secret, super-shady Task Force X as they are dropped off at the remote, enemy-infused island of Corto Maltese.","genre_ids":[28,35,12],"media_type":"movie","popularity":12.3652,"vote_count":9398,"poster_path":"/q61qEyssk2ku3okWICKArlAdhBn.jpg","release_date":"2021-07-28","vote_average":7.468,"backdrop_path":"/jlGmlFOcfo8n5tURmhC7YVd4Iyy.jpg","original_title":"The Suicide Squad","original_language":"en"},{"id":36557,"adult":false,"title":"Casino Royale","video":false,"overview":"Le Chiffre, a banker to the world's terrorists, is scheduled to participate in a high-stakes poker game in Montenegro, where he intends to use his winnings to establish his financial grip on the terrorist market. M sends Bond—on his maiden mission as a 00 Agent—to attend this game and prevent Le Chiffre from winning. With the help of Vesper Lynd and Felix Leiter, Bond enters the most important poker game in his already dangerous career.","genre_ids":[12,28,53],"media_type":"movie","popularity":11.96,"vote_count":11453,"poster_path":"/lMrxYKKhd4lqRzwUHAy5gcx9PSO.jpg","release_date":"2006-11-14","vote_average":7.569,"backdrop_path":"/mXFmGlMCgTIOyHaGmQG1Hb6Rv2m.jpg","original_title":"Casino Royale","original_language":"en"},{"id":624860,"adult":false,"title":"The Matrix Resurrections","video":false,"overview":"Plagued by strange memories, Neo's life takes an unexpected turn when he finds himself back inside the Matrix.","genre_ids":[878,28,12],"media_type":"movie","popularity":7.4227,"vote_count":6303,"poster_path":"/8c4a8kE7PizaGQQnditMmI1xbRp.jpg","release_date":"2021-12-16","vote_average":6.345,"backdrop_path":"/eNI7PtK6DEYgZmHWP9gQNuff8pv.jpg","original_title":"The Matrix Resurrections","original_language":"en"},{"id":206647,"adult":false,"title":"Spectre","video":false,"overview":"A cryptic message from Bond’s past sends him on a trail to uncover a sinister organization. While M battles political forces to keep the secret service alive, Bond peels back the layers of deceit to reveal the terrible truth behind SPECTRE.","genre_ids":[28,12,53],"media_ty