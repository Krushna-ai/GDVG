5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Buddy's Mom\",\"description\":\"20-year-old Kyeong-soo is a man who's full of assumptions. He learned about sex from Internet porn, but nothing about the real thing. He's only had crushes and has never even kissed before. He got embarrassed when he confessed his feelings to Ji-yeon, his crush. He comforted himself from the shame with Japanese girls in his room with his right hand. One day, he has a fight with his father and remembers his friend Baek-hyeon had invited him over to Gangwon-do. There he falls in love with his friends' mother.\",\"image\":\"https://image.tmdb.org/t/p/w500/5JDVEZN0v3e9xMzZbZ92fC7HaQi.jpg\",\"datePublished\":\"2015-11-12\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"erotic film\",\"Drama\",\"Romance\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.7,\"bestRating\":10,\"ratingCount\":14}}"}}],["$","$L10",null,{"initialDrama":{"id":"2e6e9f01-2a79-4898-bea0-3c39a9271c0b","tmdb_id":387848,"imdb_id":"tt6571010","content_type":"movie","title":"Buddy's Mom","original_title":"친구엄마","overview":"20-year-old Kyeong-soo is a man who's full of assumptions. He learned about sex from Internet porn, but nothing about the real thing. He's only had crushes and has never even kissed before. He got embarrassed when he confessed his feelings to Ji-yeon, his crush. He comforted himself from the shame with Japanese girls in his room with his right hand. One day, he has a fight with his father and remembers his friend Baek-hyeon had invited him over to Gangwon-do. There he falls in love with his friends' mother.","poster_path":"/5JDVEZN0v3e9xMzZbZ92fC7HaQi.jpg","backdrop_path":"/78frwN1N9PeHQB0iXxlxbnAFL1L.jpg","release_date":"2015-11-12","first_air_date":null,"status":"published","original_language":"ko","origin_country":["KR"],"genres":[{"name":"erotic film"},{"id":18,"name":"Drama"},{"id":10749,"name":"Romance"},"erotic film"],"popularity":9.3759,"vote_average":5.7,"vote_count":14,"runtime":101,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-31T22:03:38.982674+00:00","updated_at":"2026-02-22T21:17:53.933+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":87159,"name":"Milk Pictures","logo_path":null,"origin_country":""}],"production_countries":[{"name":"South Korea","iso_3166_1":"KR"}],"spoken_languages":[{"name":"한국어/조선말","iso_639_1":"ko","english_name":"Korean"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[{"id":1664,"name":"eroticism"},{"id":155477,"name":"softcore"}],"alternative_titles":[],"videos":[],"watch_providers":{"results":{}},"wikidata_id":"Q21825216","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"KR","main_poster":"/5JDVEZN0v3e9xMzZbZ92fC7HaQi.jpg","images":{"logos":[],"posters":[{"width":500,"height":750,"file_path":"/5JDVEZN0v3e9xMzZbZ92fC7HaQi.jpg","iso_639_1":"ko","vote_average":3.334},{"width":1200,"height":1800,"file_path":"/4U5D99RPAcNtaLi5tBXzC8gzXvm.jpg","iso_639_1":"ko","vote_average":0},{"width":608,"height":912,"file_path":"/dXpl5qmO00CTDiurPnLHDps6YJu.jpg","iso_639_1":"ko","vote_average":0},{"width":680,"height":1000,"file_path":"/3g3CFKrivgM991SsWll8eFT1Yq8.jpg","iso_639_1":null,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/78frwN1N9PeHQB0iXxlxbnAFL1L.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T06:56:25.735+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"친구엄마","runtime":101,"tagline":"","homepage":"","overview":"이론만 강한 남자, 스무살 경수!  섹스를 인터넷 야동으로만 보고 배운 경수. 그는 이론에만 강할뿐 실전은 전무하다. 짝사랑만 했을 뿐 키스한번 못 해 봤다. 짝사랑하던 선배 지연에게 고백했다가 개쪽만 당하고 방구석에서 일본 언니들을 벗삼아 오른손 긴긴 밤을 보내던 어느 날. 홀아버지와 대판 싸운 경수는 방학이 되면 자신의 집에 놀러오라는 친구 백현의 얘기를 떠 올리고 무작정 강원도 삼척으로 향하는 버스에 오른다.  뱀파이어인가! 늙지않는 친구 엄마, 현옥!  20대 뺨을 후려치는 완벽한 바디 라인과 이승환과 친구 먹는 동안의 전복 아가씨 출신 현옥. 긴긴밤 외로이 바닷가를 바라보며 소주잔을 기울이던 그녀에게 무려 20살이나 어린 아들 친구가 작업을 걸어온다. 이 어린 놈의 새끼를 받아줘도 문제. 안 받아줘도 문제?  사랑일까? 엔조이일까?  하루 수십번도 가능한 경수. 집에서도 하고, 해변에서도 하고, 물에서도 하고, 하고 하고 또 해도 경수는 끊임없이 일어선다. 그런 경수가 싫지 않은 현옥. 자신을 시도때도 없이 덮치는 경수가 귀엽고 사랑스럽다. 하지만 경수의 짝사랑 지연이 삼척에 내려오자 지랄 맞은 날씨처럼 경수의 마음이 오락가락 하기 시작한다. 지연에게 한번. 현옥에게 한번. 경수는 현옥을 사랑하는 것일까? 아니면 그냥 엔조이일까?"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Buddy's Mom","runtime":101,"tagline":"","homepage":"","overview":"20-year-old Kyeong-soo is a man who's full of assumptions. He learned about sex from Internet porn, but nothing about the real thing. He's only had crushes and has never even kissed before. He got embarrassed when he confessed his feelings to Ji-yeon, his crush. He comforted himself from the shame with Japanese girls in his room with his right hand. One day, he has a fight with his father and remembers his friend Baek-hyeon had invited him over to Gangwon-do. There he falls in love with his friends' mother."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"朋友的妈妈","runtime":0,"tagline":"","homepage":"","overview":"　　20岁的京秀是一个完整的假设。他从网络色情，但没有关于真正的事情。他只有把和甚至从来没有吻过。他很尴尬当他坦白了自己的感情，姬妍，他迷恋。他用右手安慰自己的房间里的日本女孩的耻辱。有一天，他与父亲吵架，记得他的朋友白贤曾邀请他去江原道。  　　她是一个吸血鬼吗？他朋友的妈妈贤好千古！她很漂亮，看了看20多岁的样子，然后有一天，她在沙滩上度过了一个寂寞的夜晚，她儿子的朋友开始打她。她应该接受还是不接受？  　　是爱情还是爱情？暻秀能做爱一天几次。他们在家里，在海滩上，在水里，一次又一次，他很难再做了。可以认为，京秀贤是可爱的；然而，他暗恋姬妍时，庆洙开始变得迷茫。他爱贤好还是扔？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":101,"tagline":"","homepage":"","overview":"De 20-jarige Kyeong-soo is een man die alles over seks  geleerd heeft  van internetporno Hij is alleen verliefd geweest en heeft nog nooit gezoend. Hij schaamde zich toen hij zijn gevoelens opbiechtte aan Ji-yeon,. Met zijn rechterhand troostte hij zich met de Japanse meisjes in zijn kamer. Op een dag heeft hij ruzie met zijn vader en herinnert hij zich dat zijn vriend Baek-hyeon hem had uitgenodigd om naar Gangwon-do te komen. Daar wordt hij verliefd op de moeder van zijn vriend."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"朋友的媽媽","runtime":0,"tagline":"朋友的媽媽","homepage":"","overview":"二十歲的慶洙，一個只在理論上強的男人！\r Kyung-soo 只是通過在互聯網上觀看色情片才了解性的。他只是理論強，沒有實戰經驗。我只談過單方面的戀愛，但我從未親吻過。某天，他在向暗戀的學長智妍告白後遭到毆打，並在房間的角落裡與日本姐妹們度過了漫長的一夜。與單親父親大吵一架的慶洙想起朋友白賢在放假時要他來自己家的故事，便不顧一切地坐上了前往江原道三陟市的巴士。  你是吸血鬼嗎！Hyeon-ok，一個永遠不會變老的朋友的母親！\r 賢玉，前鮑魚女孩，完美的身體線條在吃朋友的時候拍打著20歲的李承煥的臉頰。在漫長漫長的夜晚，當她獨自看著海灘傾斜著燒酒時，她 20 歲兒子的朋友來上班了。就算接受這個小雜種，也是個問題。我不接受有關係嗎？  這是愛嗎？是享受嗎？\r 一天可以做幾十次的硬水。在家裡，在沙灘上，在水中，一遍又一遍，Kyungsoo不斷地站起來。賢玉不喜歡那種景洙。不費吹灰之力就攻擊他的慶洙可愛又惹人喜愛。然而，當慶洙的單戀智妍落到三陟身上時，慶洙的心開始像天氣一樣來回波動。一次延誤。賢玉曾經。慶洙愛賢諾嗎？還是只是享受？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"朋友的媽媽","runtime":101,"tagline":"","homepage":"","overview":"二十歲的慶洙，一個只在理論上強的男人！  Kyung-soo 只是通過在互聯網上觀看色情片才瞭解性的。他只是理論強，沒有實戰經驗。我只談過單方面的戀愛，但我從未親吻過。某天，他在向暗戀的學長智妍告白後遭到毆打，並在房間的角落裡與日本姐妹們度過了漫長的一夜。與單親父親大吵一架的慶洙想起朋友白賢在放假時要他來自己家的故事，便不顧一切地坐上了前往江原道三陟市的巴士。 你是吸血鬼嗎！Hyeon-ok，一個永遠不會變老的朋友的母親！  賢玉，前鮑魚女孩，完美的身體線條在吃朋友的時候拍打著 20 歲的李承煥的臉頰。在漫長漫長的夜晚，當她獨自看著海灘傾斜著燒酒時，她 20 歲兒子的朋友來上班了。就算接受這個小雜種，也是個問題。我不接受有關係嗎？ 這是愛嗎？是享受嗎？  一天可以做幾十次的硬水。在家裡，在沙灘上，在水中，一遍又一遍，Kyungsoo 不斷地站起來。賢玉不喜歡那種景洙。不費吹灰之力就攻擊他的慶洙可愛又惹人喜愛。然而，當慶洙的單戀智妍落到三陟身上時，慶洙的心開始像天氣一樣來回波動。一次延誤。賢玉曾經。慶洙愛賢諾嗎？還是隻是享受？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":412092,"adult":false,"title":"Mom's Friend 2","video":false,"overview":"An art student named Gwang-ho gets dumped by his girlfriend because she was only his source of comfort, and that he's a Mama's boy and a premature ejaculator. He tries to avoid seeing her by going to a different academy and that's when his mother introduces him to her friend Soo-yeon, a sophisticated and intelligent looking woman. Gwang-ho falls for her.  Gwang-ho's mother suddenly leaves for Australia because his father is sick and Gwang-ho gets to stay in Soo-yeon's house for a few days. Looking at her, he thinks of all the things he would like to do with her and Soo-yeon's niece Ha-kyeong stimulates him to do something about his feelings.","genre_ids":[10749],"media_type":"movie","popularity":5.4438,"vote_count":15,"poster_path":"/mLlke4cd9R65FYqtMVUZ3h3Z2z9.jpg","release_date":"2016-09-01","vote_average":6.1,"backdrop_path":"/dhaHfxS7AVNG53xdHOfJO5hRQbW.jpg","original_title":"엄마친구 2","original_language":"ko"},{"id":209762,"adult":false,"title":"The Bluff","video":false,"overview":"4 old friends gathered after a long time. Banal daily conversation and continuous smut as always. Their sexual bluff battle start with such as, ‘You never held hands of an Idol’, ‘A common point of magpies and congress members – repay favors with their own body.’ and ‘I’ve slept with… nonhuman.’ At last the final chapter of the bluff battle comes. ‘Guys, do you believe in UFO?’","genre_ids":[10749],"media_type":"movie","popularity":0.7136,"vote_count":3,"poster_path":"/t595At9yy1UCW70Li6VonFgkSKI.jpg","release_date":"2013-07-19","vote_average":5,"backdrop_path":"/rnG25Abi58AU5O8p28q6e31y3rK.jpg","original_title":"허풍","original_language":"ko"},{"id":308624,"adult":false,"title":"The Story of Ong-nyeo","video":false,"overview":"Ong-nye had a world of men wrapped around her finger, until, one day, a horrific injury leaves her handicapped, and she retreats to the mountains. But one man may break her loneliness.","genre_ids":[10749,18],"media_type":"movie","popularity":8.9405,"vote_count":5,"poster_path":"/rtl4hW2KJHInieeCiGgrDJmMG7s.jpg","release_date":"2014-08-21","vote_average":5,"backdrop_path":"/w4X3j3ECvmEJMLabhbLB94iGcMV.jpg","original_title":"옹녀뎐","original_language":"ko"},{"id":539686,"adult":false,"title":"Shamshera","video":true,"overview":"Set in the 1800s, the film is about a \"dacoit\" tribe who take charge in fight for their rights and independence against the British.","genre_ids":[28,18,12],"media_type":"movie","popularity":0.9291,"vote_count":55,"poster_path":"/rryN6GhaoovO3sM8IEqGyKgCmXf.jpg","release_date":"2022-07-22","vote_average":5.482,"backdrop_path":"/dNozI03ORnJVydsHPe1SoHGk0cM.jpg","original_title":"शमशेरा","original_language":"hi"},{"id":895003,"adult":false,"title":"Demon Slayer: Kimetsu no Yaiba - Asakusa Arc","video":true,"overview":"Tanjiro ventures to Asakusa for his second mission with the Demon Slayer Corps. A recap of Kimetsu no Yaiba episodes 6–10, with new footage and special end credits.","genre_ids":[16,28,14,53],"media_type":"movie","popularity":2.2569,"vote_count":72,"poster_path":"/t2w332ARBJxy1G65abj8C7VNjeW.jpg","release_date":"2022-08-25","vote_average":7.736,"backdrop_path":"/6EUCHkb3rmqy08EP07oMPZbjpZR.jpg","original_title":"鬼滅の刃 浅草編","original_language":"ja"},{"id":554279,"adult":false,"title":"Return to Christmas Creek","video":false,"overview":"As Christmas approaches, Amelia Hughes, a career-focused Chicago app developer lacking in holiday spirit, returns to her small hometown of Christmas Creek to rediscover the meaning of Christmas. There, she reunites with her childhood best friend Mike and her estranged uncle Harry, whose mysterious rift with Amelia’s father divided her family during the holiday season when she was a child.","genre_ids":[10749,10751,10770],"media_type":"movie","popularity":0.4469,"vote_count":120,"poster_path":"/gCdjZCWM9x9vAbtkvZiIIYL7tOB.jpg","release_date":"2018-11-18","vote_average":6.496,"backdrop_path":"/zNUmOf9vOk0f146jQBrBkdmrZyH.jpg","original_title":"Return to Christmas Creek","original_language":"en"},{"id":784500,"adult":false,"title":"Pretty Guardian Sailor Moon Eternal the Movie Part 2","video":false,"overview":"While under the care of the Outer Sailor Guardians, Hotaru begins to age rapidly. Then, the time comes for all the Sailor Guardia