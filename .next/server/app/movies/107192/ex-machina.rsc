9:{"metadata":[["$","title","0",{"children":"Ex Machina | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/107192/ex-machina"}],["$","meta","5",{"property":"og:title","content":"Ex Machina"}],["$","meta","6",{"property":"og:description","content":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/107192/ex-machina"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Ex Machina"}],["$","meta","12",{"name":"twitter:description","content":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat 