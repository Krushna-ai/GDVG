5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Engraçadinha\",\"description\":\"After the funeral of her father Arnaldo, who committed suicide, Engraçadinha confesses to the priest the motives. On the engagement party of her cousin Sílvio with Letícia, Engraçadinha seduces him in the library, and later she ends her engagement with Zózimo and lies to Letícia, telling that she is pregnant. Letícia decides to tell Arnaldo what happened, and he says that the child can not be born. He exposes dirty secrets to Engraçadinha, and a tragedy is announced.\",\"image\":\"https://image.tmdb.org/t/p/w500/gQbe7uy31iQjlrGuBaAzmU1F6ib.jpg\",\"datePublished\":\"1981-01-01\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"BR\",\"inLanguage\":\"pt\",\"genre\":[\"Comedy\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.8,\"bestRating\":10,\"ratingCount\":15}}"}}],["$","$L10",null,{"initialDrama":{"id":"0e74b0bb-6ad7-437b-b37c-30ce0d15a73d","tmdb_id":261450,"imdb_id":"tt0183044","content_type":"movie","title":"Engraçadinha","original_title":"Engraçadinha","overview":"After the funeral of her father Arnaldo, who committed suicide, Engraçadinha confesses to the priest the motives. On the engagement party of her cousin Sílvio with Letícia, Engraçadinha seduces him in the library, and later she ends her engagement with Zózimo and lies to Letícia, telling that she is pregnant. Letícia decides to tell Arnaldo what happened, and he says that the child can not be born. He exposes dirty secrets to Engraçadinha, and a tragedy is announced.","poster_path":"/gQbe7uy31iQjlrGuBaAzmU1F6ib.jpg","backdrop_path":"/41HfYEnRkqfhyFcAQ60XOUugMep.jpg","release_date":"1981-01-01","first_air_date":null,"status":"published","original_language":"pt","origin_country":["BR"],"genres":[{"id":35,"name":"Comedy"},"drama film"],"popularity":3.7238,"vote_average":4.8,"vote_count":15,"runtime":103,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-26T01:32:50.114942+00:00","updated_at":"2026-02-26T01:32:49.957+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[],"production_countries":[{"name":"Brazil","iso_3166_1":"BR"}],"spoken_languages":[{"name":"Português","iso_639_1":"pt","english_name":"Portuguese"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[],"alternative_titles":[],"videos":[],"watch_providers":{"results":{"BR":{"link":"https://www.themoviedb.org/movie/261450-engracadinha/watch?locale=BR","flatrate":[{"logo_path":"/iiK14imNVYocrOHrVB2qNZcaltt.jpg","provider_id":2488,"provider_name":"Box Brazil Play Amazon Channel","display_priority":79}]}}},"wikidata_id":"Q10272975","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-26T01:32:50.114942+00:00","region":null,"main_poster":null,"images":{"logos":[],"posters":[{"width":600,"height":900,"file_path":"/gQbe7uy31iQjlrGuBaAzmU1F6ib.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":755,"height":1019,"file_path":"/eUk0TMt2U3qVPHHaUfTPuZMP079.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":1,"aspect_ratio":0.741,"vote_average":0},{"width":1707,"height":2560,"file_path":"/aKy2PtQ3loJ451fn3nrGcV59Kno.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/41HfYEnRkqfhyFcAQ60XOUugMep.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/h60oafnR2htOyHNKrWsvMjdKLrZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/lX2OSmszIRGSH4zKgOAhGmxyYY6.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:19:15.798+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":99,"tagline":"","homepage":"","overview":"Um homem conceituado comete suicídio. Após o velório, Arnaldo (José Lewgoy), é questionado sobre o motivo da tragédia. Suspeitava-se que o morto era amante da filha, Engraçadinha (Lucélia Santos), mas um padre descobre que ela tinha se apaixonado por Sílvio (Luís Fernando Guimarães), seu meio-irmão, pensando que era primo — um segredo de família que é desvendado com o toque trágico de Nélson Rodrigues."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":103,"tagline":"","homepage":"","overview":"After the funeral of her father Arnaldo, who committed suicide, Engraçadinha confesses to the priest the motives. On the engagement party of her cousin Sílvio with Letícia, Engraçadinha seduces him in the library, and later she ends her engagement with Zózimo and lies to Letícia, telling that she is pregnant. Letícia decides to tell Arnaldo what happened, and he says that the child can not be born. He exposes dirty secrets to Engraçadinha, and a tragedy is announced."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Engraçadinha","runtime":0,"tagline":"","homepage":"","overview":"Engraçadinha é uma adolescente atraente, com quem todo homem quer se envolver, exceto o seu primo Sílvio, o único homem que ela ama. No dia do noivado de Sílvio, ela o seduz e acaba ficando grávida. Entretanto, seu pai, Arnaldo, conta para ela um segredo horrível, dizendo que a sua criança não pode nascer."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"小可爱","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":705861,"adult":false,"title":"Hustle","video":false,"overview":"After discovering a once-in-a-lifetime player with a rocky past abroad, a down on his luck basketball scout takes it upon himself to bring the phenom to the States without his team's approval. Against the odds, they have one final shot to prove they have what it takes to make it in the NBA.","genre_ids":[18,35],"media_type":"movie","popularity":4.4538,"vote_count":2758,"poster_path":"/xWic7kPq13oRxYjbGLApXCnc7pz.jpg","release_date":"2022-06-03","vote_average":7.712,"backdrop_path":"/hGr0FrLI74vqpBWTBOPloDBwOAK.jpg","original_title":"Hustle","original_language":"en"},{"id":1891,"adult":false,"title":"The Empire Strikes Back","video":false,"overview":"The epic saga continues as Luke Skywalker, in hopes of defeating the evil Galactic Empire, learns the ways of the Jedi from aging master Yoda. But Darth Vader is more determined than ever to capture Luke. Meanwhile, rebel leader Princess Leia, cocky Han Solo, Chewbacca, and droids C-3PO and R2-D2 are thrown into various stages of capture, betrayal and despair.","genre_ids":[12,28,878],"media_type":"movie","popularity":9.5743,"vote_count":18094,"poster_path":"/nNAeTmF4CtdSgMDplXTDPOpYzsX.jpg","release_date":"1980-05-20","vote_average":8.392,"backdrop_path":"/aJCtkxLLzkk1pECehVjKHA2lBgw.jpg","original_title":"The Empire Strikes Back","original_language":"en"},{"id":263115,"adult":false,"title":"Logan","video":false,"overview":"In the near future, a weary Logan cares for an ailing Professor X in a hideout on the Mexican border. But Logan's attempts to hide from the world and his legacy are upended when a young mutant arrives, pursued by dark forces.","genre_ids":[28,18,878],"media_type":"movie","popularity":11.4007,"vote_count":20155,"poster_path":"/fnbjcRDYn6YviCcePDnGdyAkYsB.jpg","release_date":"2017-02-28","vote_average":7.818,"backdrop_path":"/2aQyMFEtppL6dNK384l5qhGSn5G.jpg","original_title":"Logan","original_language":"en"},{"id":693134,"adult":false,"title":"Dune: Part Two","video":false,"overview":"Follow the mythic journey of Paul Atreides as he unites with Chani and the Fremen while on a path of revenge against the conspirators who destroyed his family. Facing a choice between the love of his life and the fate of the known universe, Paul endeavors to prevent a terrible future only he can foresee.","genre_ids":[878,12],"media_type":"movie","popularity":22.2359,"vote_count":7552,"poster_path":"/1pdfLvkbY9ohJlCjQH2CZjjYVvJ.jpg","release_date":"2024-02-27","vote_average":8.13,"backdrop_path":"/ylkdrn23p3gQcHx7ukIfuy2CkTE.jpg","original_title":"Dune: Part Two","original_language":"en"},{"id":293660,"adult":false,"title":"Deadpool","video":false,"overview":"The origin story of former Special Forces operative turned mercenary Wade Wilson, who, after being subjected to a rogue experiment that leaves him with accelerated healing powers, adopts the alter ego Deadpool. Armed with his new abilities and a dark, twisted sense of humor, Deadpool hunts down the man who nearly destroyed his life.","genre_ids":[28,12,35],"media_type":"movie","popularity":14.6236,"vote_count":32390,"poster_path":"/3E53WEZJqP6aM84D8CckXx4pIHw.jpg","release_date":"2016-02-09","vote_average":7.622,"backdrop_path":"/en971MEXui9diirXlogOrPKmsEn.jpg","original_title":"Deadpool","original_language":"en"},{"id":264660,"adult":false,"title":"Ex Machina","video":false,"overview":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl.","genre_ids":[18,878],"media_type":"movie","popularity":7.7588,"vote_count":14042,"poster_path":"/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg","release_date":"2015-01-21","vote_average":7.573,"backdrop_path":"/uqOuJ50EtTj7kkDIXP8LCg7G45D.jpg","original_title":"Ex Machina","original_language":"en"},{"id":283995,"adult":false,"title":"Guardians of the Galaxy Vol. 2","video":false,"overview":"The Guardians must fight to keep their newfound family together as they unravel the mysteries of Peter Quill's true parentage.","genre_ids":[878,12,28],"media_type":"movie","popularity":15.5855,"vote_count":22666,"poster_path":"/y4MBh0EjBlMuOzv9axM4qJlmhzz.jpg","release_date":"2017-04-19","vote_average":7.609,"backdrop_path":"/aJn9XeesqsrSLKcHfHP4u5985hn.jpg","original_title":"Guardians of the Galaxy Vol. 2","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":19.7563,"vote_count":11389,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":475557,"adult":false,"title":"Joker","video":false,"overview":"During the 1980s, a failed stand-up comedian is driven insane and turns to a life of crime and chaos in Gotham City while becoming an infamous psychopathic crime figure.","genre_ids":[80,53,18],"media_type":"movie","popularity":18.0422,"vote_count":27338,"poster_path":"/udDclJoHjfjb8Ekgsd4FDteOkCU.jpg","release_date":"2019-10-01","vote_average":8.128,"backdrop_path":"/hO7KbdvGOtDdeg0W4Y5nKEHeDDh.jpg","original_title":"Joker","original_language":"en"},{"id":495764,"adult":false,"title":"Birds of Prey (and the Fantabulous Emancipation of One Harley Quinn)","video":false,"overview":"Harley Quinn joins forces with a singer, an assassin and a police detective to help a young girl who had a hit placed on her after she stole a rare diamond from a crime lord.","genre_ids":[28,80],"media_type":"movie"