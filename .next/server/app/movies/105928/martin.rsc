9_1":"en","vote_average":0},{"width":1824,"height":1027,"file_path":"/l5gWLU9mYVORptUR17eJq6hwtIE.jpg","iso_639_1":"en","vote_average":0},{"width":1921,"height":1080,"file_path":"/lpETolExUQ7LIYx8M5z7ycJlpaD.jpg","iso_639_1":"en","vote_average":0}]},"enriched_at":"2026-04-21T07:07:53.565+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Martin","runtime":147,"tagline":"","homepage":"https://www.martinthemovie.in/","overview":"Martin revolves around Lt. Brigadier Arjun Saxena, whose journey takes him from Pakistan to India to discover his real identity and fight against black market dealers, who are involved with terrorists to orchestrate massive attacks in the country."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"?????","iso_639_1":"kn","iso_3166_1":"IN","english_name":"Kannada"},{"data":{"title":"Martin","runtime":0,"tagline":"","homepage":"","overview":"Martin ruota attorno al tenente di brigata Arjun Saxena, il cui viaggio lo porta dal Pakistan all'India per scoprire la sua vera identità e combattere contro gli spacciatori del mercato nero, coinvolti con i terroristi nell'orchestrare massicci attacchi nel paese."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"喋血杀机","runtime":147,"tagline":"","homepage":"","overview":"影片主角马丁，一位神秘而勇敢的人物，在充满未知的世界中展开了一场惊心动魄的冒险。马丁不知因何原因陷入了一个复杂的困境之中，他一方面努力探寻自己的真实身份，试图解开过去的谜团。另一方面，他发现自己身处的世界暗流涌动，国内的黑市商人与恐怖分子相互勾结，谋划着一场足以给国家带来巨大灾难的大规模袭击。马丁毅然决然地踏上了阻止这场阴谋的征程。在这个过程中，他遭遇了无数的危险与挑战。敌人凶狠狡诈，不断给他设下陷阱和阻碍。然而，马丁凭借着顽强的意志、过人的智慧和非凡的勇气，一次次化险为夷。他穿梭于城市的大街小巷，深入危险的地下世界，与邪恶势力展开了一场场激烈的较量。在这个艰难的旅程中，马丁也逐渐发现了自己内心深处的力量和使命，他不仅仅是为了自己而战，更是为了国家的安宁和人民的幸福而奋斗。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"مارتن","runtime":0,"tagline":"","homepage":"","overview":"تدور أحداث العمل حول رجل يمر برحلة مليئة بالمتاعب في سبيل محاربة قوى الشر التي تتربص به وتسعى لتدمير الهند، وفي طريقه يقع في حب فتاة جميلة بشكل غير متوقع."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"O Guerreiro","runtime":145,"tagline":"","homepage":"","overview":"A jornada de um homem que descobre a si mesmo, encontra o amor e luta por sua terra natal - será que ele conseguirá manter o controle em todas as três frentes?"},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"El viaje de un hombre que se descubre a sí mismo, encuentra el amor y lucha por su patria. ¿Podrá mantener el fuerte en las tres puertas?"},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Мартин","runtime":0,"tagline":"","homepage":"","overview":"Сюжет фильма «Мартин» вращается вокруг бригадного лейтенанта Арджуна Саксены, чьё путешествие приводит его из Пакистана в Индию, где ему предстоит раскрыть свою настоящую личность и сразиться с торговцами чёрного рынка, которые вместе с террористами организуют масштабные теракты в стране."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":147,"tagline":"","homepage":"","overview":"El viaje de un hombre que se descubre a sí mismo, encuentra el amor y lucha por su patria."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"}],"reviews_tmdb":[],"recommendations":[{"id":565179,"adult":false,"title":"The First King","video":false,"overview":"Romulus and Remus, two shepherds and loyal brothers, end up taking part to a journey that will lead one of them to be the founder of the greatest nation ever seen. However, the fate of the chosen one will pass from killing his own brother.","genre_ids":[36,18],"media_type":"movie","popularity":0.8196,"vote_count":1122,"poster_path":"/dqBU63M3cKy7pfVsmhrbgY5X8iv.jpg","release_date":"2019-01-31","vote_average":7.106,"backdrop_path":"/tKyaXRcVAxYCqU9edDgjRmEKkMX.jpg","original_title":"Il primo re","original_language":"la"},{"id":436343,"adult":false,"title":"On Body and Soul","video":false,"overview":"Two introverted people find out by pure chance that they share the same dream every night. They are puzzled, incredulous, a bit frightened. As they hesitantly accept this strange coincidence, they try to recreate in broad daylight what happens in their dream.","genre_ids":[18,10749,14],"media_type":"movie","popularity":1.6681,"vote_count":594,"poster_path":"/uguWEoZelSSckxgiQctlkZ6gpfU.jpg","release_date":"2017-03-02","vote_average":7.3,"backdrop_path":"/s5BvDOLava3Z8NjAOnT0Xe96iLS.jpg","original_title":"Testről és lélekről","original_language":"hu"},{"id":106845,"adult":false,"title":"Re-Kill","video":false,"overview":"Five years after a zombie outbreak, the men and women of R-Division hunt down and destroy the undead. When they see signs of a second outbreak, they fear humanity may not survive.","genre_ids":[27,878],"media_type":"movie","popularity":2.2003,"vote_count":174,"poster_path":"/wpofLYUv0aJmDNxyUZux0wTFXJH.jpg","release_date":"2015-10-16","vote_average":5.983,"backdrop_path":"/1kQGVh547uKRQwyEsnmYEsVVhiN.jpg","original_title":"Re-Kill","original_language":"en"},{"id":49026,"adult":false,"title":"The Dark Knight Rises","video":false,"overview":"Following the death of District Attorney Harvey Dent, Batman assumes responsibility for Dent's crimes to protect the late attorney's reputation and is subsequently hunted by the Gotham City Police Department. Eight years later, Batman encounters the mysterious Selina Kyle and the villainous Bane, a new terrorist leader who overwhelms Gotham's finest. The Dark Knight resurfaces to protect a city that has branded him an enemy.","genre_ids":[28,80,18,53],"media_type":"movie","popularity":14.5744,"vote_count":24012,"poster_path":"/hr0L2aueqlP2BYUblTTjmtn0hw4.jpg","release_date":"2012-07-17","vote_average":7.8,"backdrop_path":"/y2DB71C4nyIdMrANijz8mzvQtk6.jpg","original_title":"The Dark Knight Rises","original_language":"en"},{"id":768436,"adult":false,"title":"Re-Existences","video":false,"overview":"“Re-Existence” is a documentary about migration stories of individuals from the Brazilian queer community.","genre_ids":[99],"media_type":"movie","popularity":0.078,"vote_count":55,"poster_path":"/ijVCGruXmpjoWkCwWl9d6ArX2QS.jpg","release_date":"2020-11-23","vote_average":7.4,"backdrop_path":null,"original_title":"Re-Existências","original_language":"pt"},{"id":706510,"adult":false,"title":"Desperados","video":false,"overview":"A panicked young woman and her two best friends fly to Mexico to delete a ranting email she sent to her new boyfriend. On arrival, they run into her former beau, who soon gets caught up in their frantic scheme.","genre_ids":[35,10749],"media_type":"movie","popularity":0.9484,"vote_count":490,"poster_path":"/hoUzSMxGu4Bm73EvH6B3iceFwW8.jpg","release_date":"2020-07-01","vote_average":5.984,"backdrop_path":"/k8H6Qp4uJ9WHArPQwDqCaW9g3Sj.jpg","original_title":"Desperados","original_language":"en"},{"id":667,"adult":false,"title":"You Only Live Twice","video":false,"overview":"A mysterious spacecraft captures Russian and American space capsules and brings the two superpowers to the brink of war. James Bond investigates the case in Japan and comes face to face with his archenemy Blofeld.","genre_ids":[28,53,12],"media_type":"movie","popularity":6.6804,"vote_count":2404,"poster_path":"/fdRbvRcEXcf2rC4ghLFZzCWPSmB.jpg","release_date":"1967-06-13","vote_average":6.6,"backdrop_path":"/cpZAXIYA0lkZMpAt7d1MmH8ojNV.jpg","original_title":"You Only Live Twice","original_language":"en"},{"id":407806,"adult":false,"title":"13th","video":false,"overview":"An in-depth look at the prison system in the United States and how it reveals the nation's history of racial inequality.","genre_ids":[99],"media_type":"movie","popularity":1.3478,"vote_count":778,"poster_path":"/tcKNWD6IFPPsvkpvyZ548naz0is.jpg","release_date":"2016-10-07","vote_average":7.875,"backdrop_path":"/hwn9CN2x5Qhm3laLRvZlXttL6LU.jpg","original_title":"13th","original_language":"en"},{"id":595172,"adult":false,"title":"The Pilgrim's Progress","video":false,"overview":"An epic journey, faithfully adapted to modern-day. Christian faces distractions, challenges, and perils at every turn of the way. But ends victorious, with helpful guides, as he stays on the narrow path to the distant Celestial City.","genre_ids":[16,12],"media_type":"movie","popularity":1.3802,"vote_count":95,"poster_path":"/vtfsNxAsDHElFvYHUc9Khwqg17Y.jpg","release_date":"2019-04-18","vote_average":7.6,"backdrop_path":"/l2Ao3NXfrXtWzlBZ5DnP2l2szJj.jpg","original_title":"The Pilgrim's Progress","original_language":"en"},{"id":20993,"adult":false,"title":"Brother 2","video":false,"overview":"Arriving in Moscow, Chechen War veteran Danila meets Konstantin, an old friend who tells him that his twin brother has been forced into signing a crooked contract with a US ice hockey team. Soon after this meeting, Danila discovers Konstantin dead and he sets out to avenge his death; a journey that leads him to Chicago and a whole new experience.","genre_ids":[28,80,18],"media_type":"movie","popularity":1.4066,"vote_count":304,"poster_path":"/r5pffTC8XZsrGUYSU8e23dGmGNK.jpg","release_date":"2000-05-11","vote_average":7.112,"backdrop_path":"/a8bPE7ufmXsfj2BLOrB8KuNMxN5.jpg","original_title":"Брат 2","original_language":"ru"},{"id":481042,"adult":false,"title":"Non C'è Campo","video":false,"overview":"Prevented from using mobile phones due to the non-existent reception of the location, a school trip to a rural town becomes a life-changing experience of friendship and love for a group of Italian kids and their teacher.","genre_ids":[35,10749],"media_type":"movie","popularity":0.4246,"vote_count":225,"poster_path":"/z5vZHFIoo9Ui3tcXU4YQxX9lsti.jpg","release_date":"2017-11-02","vote_average":5.6,"backdrop_path":"/ogxB8Hh9KdxZsJ23jvkcxvklPMX.jpg","original_title":"Non C'è Campo","original_language":"it"},{"id":75780,"adult":false,"title":"Jack Reacher","video":false,"overview":"One morning in an ordinary town, five people are shot dead in a seemingly random attack. All evidence points to a single suspect: an ex-military sniper who is quickly brought into custody. The interrogation yields one written note: 'Get Jack Reacher!'. Reacher, an enigmatic ex-Army investigator, believes the authorities have the right man but agrees to help the sniper's defense attorney. However, the more Reacher delves into the case, the less clear-cut it appears. So begins an extraordinary chase for the truth, pitting Jack Reacher against an unexpected enemy, with a skill for violence and a secret to keep.","genre_ids":[80,18,53,28],"media_type":"movie","popularity":8.3895,"vote_count":7496,"poster_path":"/uQBbjrLVsUibWxNDGA4Czzo8lwz.jpg","release_date":"2012-12-20","vote_average":6.654,"backdrop_path":"/iwvP8XVpYVmJ3xfF9xdBi5uAOWl.jpg","original_title":"Jack Reacher","original_language":"en"},{"id":140607,"adult":false,"title":"Star Wars: The Force Awakens","video":false,"overview":"Thirty years after defeating the Galactic Empire, Han Solo and his allies face a new threat from the evil Kylo Ren and his army of Stormtroopers.","genre_ids":[12,28,878],"media_type":"movie","popularity":12.1339,"vote_count":20296,"poster_path":"/wqnLdwVXoBjKibFRR5U3y0aDUhs.jpg","release_date":"2015-12-15","vote_average":7.25,"backdrop_path":"/8BTsTfln4jlQrLXUBquXJ0ASQy9.jpg","original_title":"Star Wars: The Force Awakens","original_language":"en"},{"id":84194,"adult":false,"title":"Excision","video":false,"overview":"An outcast teenager, Pauline, practices surgical skills and harbors increasingly violent psychosexual fantasies.","genre_ids":[18,27,35],"media_type":"movie","popularity":1.4184,"vote_count":592,"poster_path":"/3aLgB6FTQlNanER0RpckbKdwyh9.jpg","release_date":"2012-09-12","vote_average":6.233,"backdrop_path":"/u5gdLQVhrtZvfY8SaIia0E4KsUE.jpg","original_title":"Excision","original_language":"en"},{"id":101299,"adult":false,"title":"The Hunger Games: Catching Fire","video":false,"overview":"After surviving the Hunger Games, Katniss and Peeta struggle with the consequences of their victory as unrest spreads across Panem. Forced back into the spotlight, they become symbols of hope and resistance while the Capitol prepares a new and deadly challenge that will change the future of the nation forever.","genre_ids":[12,28,878],"media_type":"movie","popularity":9.6074,"vote_count":18198,"poster_path":"/vrQHDXjVmbYzadOXQ0UaObunoy2.jpg","release_date":"2013-11-15","vote_average":7.4,"backdrop_path":"/eHaazLxM5LRMh0ySkVy7SK6wUWt.jpg","original_title":"The Hunger Games: Catching Fire","original_language":"en"},{"id":207933,"adult":false,"title":"Stonehearst Asylum","video":false,"overview":"An Oxford Medical School graduate takes a position at a mental institution and soon becomes obsessed with a female mental patient, but he has no idea of a recent and horrifying staffing change.","genre_ids":[53,9648,27],"media_type":"movie","popularity":3.1837,"vote_count":1543,"poster_path":"/fZxGCCQ0NAtraevqULJ84wSSjo0.jpg","release_date":"2014-10-23","vote_average":6.852,"backdrop_path":"/988AG01BZZe62P33jemkFIacxF9.jpg","original_title":"Stonehearst Asylum","original_language":"en"},{"id":12165,"adult":false,"title":"The Burning Plain","video":false,"overview":"A trailer is burning in the middle of a plain. The bodies of two adulterous lovers are found. Scenes from both families, before and after the dramatic events, suggest an unusual connection between them. But what is their secret?","genre_ids":[18,10749,80],"media_type":"movie","popularity":1.3361,"vote_count":458,"poster_path":"/lZlChM3LmOLUCQCfnbaf2dQKe9J.jpg","release_date":"2008-11-07","vote_average":6.569,"backdrop_path":"/