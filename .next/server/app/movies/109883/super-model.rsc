5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Super Model\",\"description\":\"Super model Mandom (Ronald Cheng) is very famous in the field. One day, he is threatened by someone, asking him not to attend a model competition. Mandom calls for police and Madam Cheung (Karena Lam) is sent to bodyguard him 24 hours a day. However they have hostile feeling to each other. At the same time, Mandom also faces a challenger Fantasy (Sammy). How can Mandom fight against Fantasy in the model competition?\",\"image\":\"https://image.tmdb.org/t/p/w500/jTVdi3WwDeJREXw8vEXZVITCWZU.jpg\",\"datePublished\":\"2004-06-17\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"cn\",\"genre\":[\"Comedy\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.4,\"bestRating\":10,\"ratingCount\":5}}"}}],["$","$L10",null,{"initialDrama":{"id":"ce24573b-2312-4f3e-bdd5-3ef2cd0503b4","tmdb_id":155508,"imdb_id":"tt0440935","content_type":"movie","title":"Super Model","original_title":"我要做Model","overview":"Super model Mandom (Ronald Cheng) is very famous in the field. One day, he is threatened by someone, asking him not to attend a model competition. Mandom calls for police and Madam Cheung (Karena Lam) is sent to bodyguard him 24 hours a day. However they have hostile feeling to each other. At the same time, Mandom also faces a challenger Fantasy (Sammy). How can Mandom fight against Fantasy in the model competition?","poster_path":"/jTVdi3WwDeJREXw8vEXZVITCWZU.jpg","backdrop_path":"/nbeKvj2GqwIh9LGelea8K2PF69V.jpg","release_date":"2004-06-17","first_air_date":null,"status":"published","original_language":"cn","origin_country":["HK"],"genres":[{"id":35,"name":"Comedy"},"comedy film"],"popularity":2.9384,"vote_average":6.4,"vote_count":5,"runtime":105,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-06T22:24:23.788656+00:00","