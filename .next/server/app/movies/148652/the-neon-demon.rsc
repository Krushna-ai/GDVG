_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/jNjuOET0nqtWh7Ee3tRjThBnxQu.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/9QocWC5N8YTxiPCcYbJ8wzojRha.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/nmlaCEB2abbUf4tfJ8L7Dl8TEvD.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/3WefLBlIOvVZDYtZNE4jvI0gLKY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2208,"height":1242,"file_path":"/derqkyskN1u3XXXSH9wOJ0pxSpd.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/rggzhDJ0NUlUKYDcesGLiV1rriZ.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1712,"height":964,"file_path":"/xr3qYfEkogYvieDrHnmY721Bnt0.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":1,"aspect_ratio":1.776,"vote_average":0},{"width":1920,"height":1080,"file_path":"/2wkHdrcxBG1sSMp4hlJVbACjnPv.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1600,"height":900,"file_path":"/s8Jx0NheX0Ejrctem6LanZ1kcai.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2048,"height":1153,"file_path":"/qkYk4B644Gm2FeBSqHHw2lEh1u6.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.776,"vote_average":0},{"width":2275,"height":1280,"file_path":"/5iixvmyIOxObWNbUyBrTBBsGZlQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3838,"height":2160,"file_path":"/9SkefcdDsxpR3DzKulk7qDXB6c9.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3840,"height":2159,"file_path":"/eBTLB34PDEptF1GjEMNsSzsMVSI.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":1422,"height":800,"file_path":"/fnjAw2MfurvwgxkWPeNp1qWXkTr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1422,"height":800,"file_path":"/nlKomYFBCK0maGeT5jkdxnoCRox.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1422,"height":800,"file_path":"/2fcL4E5g2ZTjFXMHC6ZdLXZmMW1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T04:10:23.889+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":118,"tagline":"Beauty is vicious.","homepage":"","overview":"When aspiring model Jesse moves to Los Angeles, her youth and vitality are devoured by a group of beauty-obsessed women who will take any means necessary to get what she has."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":117,"tagline":"L'innocenza è pericolosa","homepage":"http://www.midnightfactory.it/film/the-neon-demon","overview":"Quando l’aspirante modella Jesse si trasferisce a Los Angeles, la sua giovinezza e vitalità vengono fagocitate da un gruppo di donne ossessionate dalla bellezza,disposte ad usare ogni mezzo per prenderle ciò che ha."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Neon Demon","runtime":118,"tagline":"","homepage":"","overview":"Jesse je mladá, krásná a má onu tajemnou esenci, která ji vyčleňuje ze zástupu dokonalých krásek ucházejících se o svých pár let slávy na módních molech v Los Angeles. „Kdo by chtěl zkyslý mlíko, když může mít čerstvý maso\", utrousí na její adresu jedna ze závistivých kolegyň. Neonový puls fashion světa pohlcuje Jesse natolik, že přehlíží varovné signály. Za marnivými kulisami kultu krásy totiž dříme dávné zlo, které se živí nevinností."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":118,"tagline":"Los perversos mueren pronto.","homepage":"","overview":"Jesse es una chica que llega a Los Angeles, California, para hacer su sueño realidad: convertirse en supermodelo. Pero su juventud y belleza despertará al demonio, y se verá atrapada en un peligroso mundo de envidias y celos en el que las modelos están dispuestas a todo para triunfar."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"דוגמניות ושדים","runtime":0,"tagline":"","homepage":"","overview":"ג'סי (אל פאנינג), צעירה השואפת להיות דוגמנית, מגיעה ללוס אנג'לס כדי להגשים את חלומה. יופיה יוצא הדופן מקדם אותה במהירות הבזק במסלול הדוגמנות, אך בה בעת מעורר קנאה עזה בקרב הנשים הסובבות אותה, שמתכוונות לעשות כל שיידרש כדי לגזול ממנה את מה שיש לה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Неоновый демон","runtime":117,"tagline":"","homepage":"","overview":"Когда начинающая модель Джесси переезжает в Лос-Анджелес, она попадает в видение группы одержимых красотой девушек, готовых пойти на что угодно ради того, чтобы заполучить ее молодость и жизненную силу."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":117,"tagline":"La beauté est vicieuse.","homepage":"","overview":"Une jeune fille débarque à Los Angeles. Son rêve est de devenir mannequin. Son ascension fulgurante et sa pureté suscitent jalousies et convoitises. Certaines filles s’inclinent devant elle, d'autres sont prêtes à tout pour lui voler sa beauté."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":118,"tagline":"Ο ομορφιά δεν είναι το παν. Είναι το μοναδικό πράγμα.","homepage":"https://www.facebook.com/theneondemonfilm","overview":"Όταν η Τζέσι, ένα επίδοξο μοντέλο, μετακομίζει στο Λος Άντζελες, τα νιάτα και η ζωντάνια της καταβροχθίζονται από μια ομάδα γυναικών, με εμμονή στην ομορφιά, που θα χρησιμοποιήσουν κάθε μέσο, για να πάρουν αυτό που έχει..."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Demônio de Neon","runtime":117,"tagline":"A inocência é perigosa.","homepage":"","overview":"Jesse (Elle Fannng) é uma jovem de 18 anos que acaba de chegar a Los Angeles. Dona de uma beleza natural impressionante, ela tenta a sorte como modelo profissional. Após tirar algumas fotos mórbidas para um jovem fotógrafo, é contratada por uma conceituada agência de modelos. Bastante ingênua, ela passa a lidar com o ego sempre inflado das demais modelos e também com a maquiadora Ruby (Jena Malone), que possui intenções ocultas com a jovem."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":110,"tagline":"Schönheit ist teuflisch.","homepage":"","overview":"Teenagerin Jesse ist neu in Los Angeles. Sie zieht in ein heruntergekommenes Motel, das vom dubiosen Hank geführt wird, findet aber schnell Anschluss in der fremden Stadt: Stylistin Ruby  bemerkt, was für ein Talent in Jesse steckt und will ihr dabei helfen, den Traum von der Modelkarriere zu verwirklichen. Wenig später hat Jesse mit Jan dann auch schon eine Top-Agentin und wird von einem Fotografen zum nächsten geschickt. Die junge Frau, naiv und betont keusch im Auftreten, taucht immer tiefer in die Glitzerwelt aus dekadenten Partys und schicken Shootings ein. Konkurrentinnen wie den Models Sarah und Gigi bleibt nicht verborgen, wer da zum neuen Liebling der Szene aufsteigt. Bald wird es für Jesse sehr gefährlich …"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Neon Démon","runtime":0,"tagline":"","homepage":"","overview":"Jesse, a feltörekvő modell Los Angelesbe költözik, hogy valóra váltsa az álmát. A divatvilág azonban nem várt módon szippantja be, ráadásul egy csoport varázslatos modell között nem várt konfliktusba keveredik. Mindannyian szenvedélyesen vágynak a kifutó sikerére és ezért szemmel láthatóan bármit hajlandók lennének megtenni. Jesse-nek azonban siker mellett meg kell küzdenie a fotósok fantáziajeleneteivel, a lakásába behatoló ismeretlenekkel és a mind furcsábban viselkedő kollégáival is."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Neon Demon","runtime":0,"tagline":"","homepage":"","overview":"Jesteś piękna i masz w sobie to coś za czym szaleją mężczyźni i czego zazdroszczą ci kobiety. Przyjeżdżasz do neonowego miasta, gdzie w ciągu jednej nocy można zrobić karierę. W Los Angeles poznajesz chłopaka, który jest tobą zafascynowany, i dziewczyny, które chcą się z tobą przyjaźnić. Dostajesz propozycję pracy, o której inni mogą tylko marzyć. Czy to piękny sen? A może wstęp do prawdziwego koszmaru?"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Le démon de néon","runtime":0,"tagline":"","homepage":"","overview":"Jesse déménage à Los Angeles pour tenter sa chance comme mannequin dans l'industrie de la mode. Jeune, jolie, naïve et sans plan B, elle devient amie avec la maquilleuse Ruby qui lui présente plusieurs femmes qui cherchent à évoluer dans ce domaine extrêmement compétitif. Au fil des rencontres, Jesse est signée par une agence et ses contrats font l'envie de ses semblables. Peut-être gagnera-t-elle bientôt suffisamment d'argent pour déménager de son motel délabré et officialiser sa relation avec un jeune photographe. Pour y arriver, elle devra apprendre à mettre ses inhibitions de côté."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"霓虹恶魔","runtime":0,"tagline":"","homepage":"","overview":"一个年轻女孩来到洛杉矶，希望成为一名模特。她的纯洁与热情使她大获成功，也激起了其他他人的嫉妒和垂涎。一些女孩在她面前俯首称臣，另一些人却决定使出所有手段偷走她的美丽容颜。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Неоновий демон","runtime":0,"tagline":"","homepage":"","overview":"Юна модель-новачок Джессі переїжджає до Лос-Анджелеса, де потрапляє у поле зору групи одержимих красою дівчат, готових піти на все заради того, щоб відібрати її молодість і життєву силу."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"네온 데몬","runtime":117,"tagline":"2016년 제69회 칸영화제 경쟁부문 초청, 칸 사운드트랙 어워즈 베스트 작곡상 수상! 칸을 뒤집어 놓은 2016년 가장 악명 높은 문제작! “나는 그들처럼 되고 싶지 않아. 그들이 나처럼 되고 싶어하지”","homepage":"","overview":"모델을 꿈꾸며 네온사인으로 빛나는 도시 LA에 정착한 소녀 ‘제시’(엘르 패닝)는 꾸미지 않고도 넋을 빼앗는 묘한 아름다움으로 단숨에 탑 모델로 주목 받는다. 하지만 그녀를 질투하는 여자들은 점점 ‘제시’의 완벽한 미모를 향해 집착하고 결국 ‘제시’는 그들이 준비한 위험한 파티에 초대받게 되는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":118,"tagline":"","homepage":"","overview":"En ung model forsøger at finde en karriere i LA, hvor hun hurtigt får sig en kontrakt. Hun inviteres til fester, og alle er optagede af hendes smukke ydre. Her møder hun også flere fra samme branche. Men konkurrencen er hård, og de andre modeller skyr ingen midler i deres rivalisering."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Jesse is een aspirerend model dat besluit te vertrekken naar Los Angeles. Daar aangekomen raakt haar jeugdigheid en levenskracht gevangen in een wereld van schoonheid en teloorgang door geobsedeerde vrouwen die er alles voor over hebben om te krijgen wat zij bezit."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Jesse är en ung lovande modell som flyttar till Los Angeles i sitt sökande efter framgång. Där hamnar hon snart i klorna på en grupp kvinnor, vars besatthet av skönhet gör dem beredda att ta till alla medel för att komma åt hennes ungdom och vitalitet."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"霓虹惡魔","runtime":118,"tagline":"美貌不是一切 它，凌駕一切","homepage":"","overview":"來自喬治亞的年輕女孩露比（艾兒芬妮 飾）來到五光十色的罪惡之城──洛杉磯，希望成為一名頂尖模特兒。她的純潔與熱情使她大獲成功，也激起了其他他人的嫉妒和垂涎。一些女孩在她面前俯首稱臣，另一些人卻決定使出所有手段偷走她的美麗容顏。在「美」的魅惑之下，人性赤裸裸到瘋狂，雜交、謀殺、姦屍、食人……在成就美的路上，任何最令人髮指的事情都被容許發生！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Неоновият демон","runtime":118,"tagline":"","homepage":"","overview":"В основата на сюжета стои Джеси, модел по професия. Като такъв се предполага, че жената е изключително красива и следователно й предстоят славни и бляскави дни по отношение на кариерата. Всичко за нея обаче се обръща с главата надолу от момента, в който тя решава да се премести в щата Калифорния. Там тя попада на малко странна и с течение на времето все по-плашеща група от жени, които искат на всяка цена да я обсебят и да вземат всичко, което притежава, а най-лошото е, че няма да се поколебаят да използват отвратителното средство - вуду магия за да постигнат целите си. Ще успее ли Джеси да се спаси от ръцете на вманиачените жени..."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Демон под рефлекторима","runtime":0,"tagline":"","homepage":"","overview":"Када се Џени, модел жељан славе, досели у Лос Анђелес, њену младост и виталност жене опседнуте лепотом почињу да прождиру и она се налази угрожена у свету где је све дозвољено и циљ оправдава средства."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"","runtime":118,"tagline":"","homepage":"","overview":"En ung aspirerende modell flytter til Los Angeles for å prøve lykken. Miljøet hun møter og blir en del av er besatt av ungdommelig skjønnhet og vitalitet og vil ty til desperate midler for å få det."},"name":"Bokmål","iso_639_1":"nb","iso_3166_1":"NO","english_name":"Norwegian Bokmål"},{"data":{"title":"Neon Şeytan","runtime":0,"tagline":"Güzellik kısırdır.","homepage":"","overview":"Jesse, mankenlikte başarıyı yakalayıp yıldız olma hedefiyle Los Angeles’a gelmiştir. Büyüleyici güzelliğiyle kariyer basamaklarını hızla tırmanmaya başlar. Genç model Los Angeles’ta hayatının en parlak günlerini yaşarken, orada tanıştığı bir grup manken arkadaşının hırsı ve güzellik saplantısı, Jesse’yi geri dönüşü olmayan bir çıkmaza sürükler."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"El dimoni de neó","runtime":0,"tagline":"","homepage":"","overview":"Jesse és una noia que arriba a Los Angeles, Califòrnia, per fer el seu somni realitat: convertir-se en supermodel. Però la seva joventut i bellesa despertarà al dimoni, i es veurà atrapada en un perillós món d'enveges i gelosia."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"El demonio neón","runtime":117,"tagline":"","homepage":"","overview":"Jesse, una aspirante a modelo, se muda a Los Ángeles, donde es reclutada por un magnate de la moda como su musa. Al entrar en la industria del modelado en la ciudad, se encuentra con que su vitalidad y juventud son devorados por un grupo de mujeres obsesionadas con la belleza, las cuales van a utilizar cualquier medio para conseguir lo que tiene."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"The Neon Demon - O Demónio de Néon","runtime":118,"tagline":"A beleza é cruel.","homepage":"","overview":"Jesse, uma aspirante a modelo, muda-se para Los Angeles, e rapidamente vê a sua juventude e vitalidade sugadas por um grupo de mulheres obcecadas com a beleza, que farão o que for necessário para ter aquilo que ela tem."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Neoninis demonas","runtime":0,"tagline":"Grožis reikalauja aukų","homepage":"","overview":"Džesė – paprasta mergina, svajojanti užkariauti mados pasaulį. Siekdama savo tikslo, ji atvyksta į Los Andželą ir stačia galva neria į pramogų, modelių bei glamūro pasaulį. Merginą supantys modeliai, siekia pasiglemžti naujokės šlovę ir grožį. Tikslas pateisina priemones, o šios priemonės išgąsdintų net patį velnią. Mados pasaulis dar niekada nebuvo parodytas taip gražiai ir tuo pačiu bauginančiai. Kino genijumi tituluojamas Nicolas Winding Refn pasiekė savo – filmas pakeri, šokiruoja ir pristato žiūrovams mitais apipintą mados pasaulį labai netikėtu kampu."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Neon Demon","runtime":117,"tagline":"Krása zabíja","homepage":"","overview":"Jesse je mladá, krásna a má onú tajomnú esenciu, ktorá ju vyčleňuje zo zástupu dokonalých krások uchádzajúcich sa o svojich pár rokov slávy na módnych mólach v Los Angeles. „Kto by chcel skysnuté mlieko, keď môže mať čerstvé mäso“, poznamená na jej adresu jedna zo závistlivých kolegýň, ktoré ju sprevádzajú po márnivých zákutiach fashion sveta. Neónový pulz večierkov a sektárska atmosféra fotografických seáns začínajú mladé dievča natoľko pohlcovať, že prehliada varovné signály – prostredie plné odleskov a luxusného pozlátka totiž ukrýva zlo, ktoré sprevádza kult krásy od pradávna. Pre naivnú Jesse v ríši divov už ale môže byť neskoro. Zatiaľčo prežíva svoj neónový sen, v diaľke sa prebúdzajú prízraky vrážd, nekrofílie a kanibalizmu."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"霓裳惡魔","runtime":0,"tagline":"","homepage":"","overview":"故事敘述潔西（艾兒·芬妮 飾）是一名有著抱負的模特兒，她到了洛杉磯擔任時尚設計師勞勃（亞力山卓·尼瓦拉 飾）的繆斯女神，使她有望在城市的時尚界發揚光大；但潔西的青春和活力也引起了其他美女們的痴迷，便打算不擇手段的奪走她的一切. . . . 。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Kun uransa alussa oleva malli Jesse muuttaa Los Angelesiin, joukko nuoria naisia, joille kauneus on pakkomielle, käyttävät kaikki keinonsa saadakseen sen, mitä hänellä on. Drive-elokuvan ohjaajan Nicolas Winding Refnin (mm. Drive, Only God Forgives) uutta elokuvaa tähdittävät Elle Fanning, Christina Hendricks, Keanu Reeves, Jena Malone, Bella Heathcote, Abbey Lee ja Karl Glusman."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"ネオン・デーモン","runtime":118,"tagline":"無垢な夢が 邪悪な毒に 染まる","homepage":"","overview":"きらびやかなファッション業界を舞台に、自らの野望に目覚めてのぼりつめていくトップモデルの欲望と狂気を描く。エル・ファニング主演によるスタイリッシュなサスペンス・スリラー。監督は『ドライヴ』のニコラス・ウィンディング・レフン。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Ác Quỷ Sàn Catwalk","runtime":0,"tagline":"","homepage":"","overview":"Cô gái tỉnh lẻ Jesse (Elle Fanning) bước chân vào thế giới của những nàng người mẫu nơi thành phố Thiên Thần, Los Angeles. Jesse lập tức thu hút ánh sáng đèn màu, qua mặt nhiều lớp đàn chị, trở thành người mẫu ăn khách nhất. Cô không hề biết rằng\"Ác Quỷ Sàn Catwalk” lại là thế giới của những con ma cà rồng hút máu tươi hay những kẻ ăn thịt người để tồn tại; cũng là cái thế giới của những cô người mẫu, lặn ngụp giữa các hãng tuyển dụng gương mặt thương hiệu, giữa những ông bầu có lòng tham vô đáy, những tay ma cô, những mụ tú bà.  Ánh đèn sàn catwalk chưa bao giờ rùng rợn đến thế!"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Neonski demon","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"สวยอันตราย","runtime":0,"tagline":"","homepage":"","overview":"เจสซี่ เด็กสาวผู้ฝันจะเป็นนางแบบได้เดินทางมาถึงลอสแองเจลิสเพื่อตามความฝัน เมื่อเธอได้เป็นนางแบบก็รู้ว่าภายใต้ฉากหน้าของวงการแฟชั่น ความสาวและความสดใสของเธอกำลังถูกกลืนกินโดยเพื่อนร่วมงานที่คลั่งไคล้ในความงามและหวังอยากได้ทุกอย่างที่เธอมี"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Demonul de neon","runtime":117,"tagline":"","homepage":"","overview":"În centrul poveștii se află Jesse, o tânără și extrem de frumoasă aspirantă la cariere în modeling, care ajunge la Los Angeles pentru a-și construi un viitor strălucitor. Atrăgând atenția unor oameni influenți din industria modei, dar și a unor modele rivale, Jesse devine ținta unei dorințe obsesive care o va duce într-o spirală de manipulare, invidie și pericol mortal. Pe măsură ce Jesse navighează printr-o lume a aparențelor și a rivalităților implacabile, începe să se dezvăluie o fațadă întunecată a orașului, unde frumusețea nu este doar un dar, ci și o armă periculoasă."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"}],"reviews_tmdb":[{"id":"579cfb439251411b3600833b","url":"https://www.themoviedb.org/review/579cfb439251411b3600833b","author":"Louisa Moore - Screen Zealots","content":"$11","created_at":"2016-07-30T19:08:51.981Z","updated_at":"2021-06-23T15:57:49.708Z","author_details":{"name":"Louisa Moore - Screen Zealots","rating":9,"username":"screenzealots","avatar_path":null}},{"id":"57ce8ced92514148ee00021c","url":"https://www.themoviedb.org/review/57ce8ced92514148ee00021c","author":"Gimly","content":"I don't really foresee _The Neon Demon_ becoming my personal all time favourite film, but from a purely aesthetics point of view, it might just be the best movie I've ever seen.\r\n\r\n_Final rating:★★★★½ - An all round great movie and a whole lot more._","created_at":"2016-09-06T09:31:25.197Z","updated_at":"2021-06-23T15:57:50.849Z","author_details":{"name":"Gimly","rating":9,"username":"Ruuz","avatar_path":"/xUObnJSvHrFPsIpoDmb1jiQZLq7.jpg"}},{"id":"581cf8379251413749001431","url":"https://www.themoviedb.org/review/581cf8379251413749001431","author":"Reno","content":"$12","created_at":"2016-11-04T21:05:59.177Z","updated_at":"2024-05-16T15:18:32.183Z","author_details":{"name":"Reno","rating":3,"username":"Rangan","avatar_path":"/6ZpVUJzqXMzH35VprEtnX0sNI3.jpg"}},{"id":"5ac936d092514162b7044cc4","url":"https://www.themoviedb.org/review/5ac936d092514162b7044cc4","author":"tmdb47633491","content":"Awesome up til the climax. Goes from a guts-deep analysis of 1) narcissism and its development, 2) the horrors of fashion culture to a by-the-numbers \"wow figure out the mystery wow\" thriller. Turn it off when there's 30 minutes left and it'll be your film of the year","created_at":"2018-04-07T21:23:28.186Z","updated_at":"2021-06-23T15:58:07.499Z","author_details":{"name":"","rating":7,"username":"tmdb47633491","avatar_path":null}},{"id":"5ea1fbb5af4324001d9e8b0b","url":"https://www.themoviedb.org/review/5ea1fbb5af4324001d9e8b0b","author":"arkhi","content":"I honestly don’t know if I loved this movie or hated it.\r\n\r\nI would describe it as _beautiful_ and _emotional_, which would match my description of a piece of art.\r\n\r\nThis probably calls for another screening…","created_at":"2020-04-23T20:33:57.529Z","updated_at":"2021-06-23T15:58:37.391Z","author_details":{"name":"","rating":4,"username":"arkhi","avatar_path":null}}],"recommendations":[{"id":77987,"adult":false,"title":"Only God Forgives","video":false,"overview":"Julian, who runs a Thai boxing club as a front organization for his family's drug smuggling operation, is forced by his mother Crystal to find and kill the individual responsible for his brother's recent death.","genre_ids":[18,53,80],"media_type":"movie","popularity":1.7047,"vote_count":2544,"poster_path":"/kWjjFSng1JttmDRwDROoGcIArEh.jpg","release_date":"2013-05-30","vote_average":5.824,"backdrop_path":"/pRrQMx00P8LaXGwJXYJ2tRGoVOs.jpg","original_title":"Only God Forgives","original_language":"en"},{"id":37861,"adult":false,"title":"Valhalla Rising","video":false,"overview":"Scandinavia, 1,000 AD. For years, One Eye, a mute warrior of supernatural strength, has been held prisoner by the Norse chieftain Barde. Aided by Are, a boy slave, One Eye slays his captor and together he and Are escape, beginning a journey into the heart of darkness. On their flight, One Eye and Are board a Viking vessel, but the ship is soon engulfed by an endless fog that clears only as the crew sights an unknown land. As the new world reveals its secrets and the Vikings confront their terrible and bloody fate, One Eye discovers his true self.","genre_ids":[12,18,28,14],"media_type":"movie","popularity":1.498,"vote_count":1298,"poster_path":"/7LBMcAx6XHwEduIsBYipvUke9n.jpg","release_date":"2009-09-04","vote_average":6.108,"backdrop_path":"/5UTOmyAIe7icGgjc5ETOZNMITmj.jpg","original_title":"Valhalla Rising","original_language":"en"},{"id":64690,"adult":false,"title":"Drive","video":false,"overview":"Driver is a skilled Hollywood stuntman who moonlights as a getaway driver for criminals. Though he projects an icy exterior, lately he's been warming up to a pretty neighbor named Irene and her young son, Benicio. When Irene's husband gets out of jail, he enlists Driver's help in a million-dollar heist. The job goes horribly wrong, and Driver must risk his life to protect Irene and Benicio from the vengeful masterminds behind the robbery.","genre_ids":[18,53,80],"media_type":"movie","popularity":7.4073,"vote_count":13381,"poster_path":"/602vevIURmpDfzbnv5Ubi6wIkQm.jpg","release_date":"2011-09-15","vote_average":7.582,"backdrop_path":"/iymDDg4upZWgpbSeiE1JCjsSPBs.jpg","original_title":"Drive","original_language":"en"},{"id":18533,"adult":false,"title":"Bronson","video":false,"overview":"A young man who was sentenced to 7 years in prison for robbing a post office ends up spending 30 years in solitary confinement. During this time, his own personality is supplanted by his alter ego, Charles Bronson.","genre_ids":[18,28,80],"media_type":"movie","popularity":2.0904,"vote_count":2619,"poster_path":"/6diyyGIbBNiANsdIaCGtyv4IofR.jpg","release_date":"2009-03-13","vote_average":7,"backdrop_path":"/uc8FwdCQi3eD7JIbyiZuzo5n6Jv.jpg","original_title":"Bronson","original_language":"en"},{"id":340837,"adult":false,"title":"A Cure for Wellness","video":false,"overview":"An ambitious young executive is sent to retrieve his company's CEO from an idyllic but mysterious \"wellness center\" at a remote location in the Swiss Alps but soon suspects that the spa's miraculous treatments are not what they seem.","genre_ids":[27,9648,878],"media_type":"movie","popularity":5.2857,"vote_count":4114,"poster_path":"/8QWJtne0pTsNoJ86KE993aQYTLW.jpg","release_date":"2017-02-15","vote_average":6.35,"backdrop_path":"/uXx9wjfJEzLlfqB8GW67SYBrhVT.jpg","original_title":"A Cure for Wellness","original_language":"en"},{"id":367147,"adult":false,"title":"Buster's Mal Heart","video":false,"overview":"An eccentric mountain man on the run from the local sheriff recalls the mysterious events that brought him to his present fugitive state.","genre_ids":[9648,18],"media_type":"movie","popularity":0.5023,"vote_count":305,"poster_path":"/e9uR2tAeokwBvQm6e9Y5zSB5KoV.jpg","release_date":"2017-05-28","vote_average":6.144,"backdrop_path":"/xGbcYt0nBWW7Jp8ujKV841sh96t.jpg","original_title":"Buster's Mal Heart","original_language":"en"},{"id":75491,"adult":false,"title":"The Rabbi's Cat","video":false,"overview":"The story of a rabbi and his talking cat, a sharp-tongued feline philosopher brimming with scathing humor and a less than pure love for the rabbi's teenage daughter.","genre_ids":[35,16],"media_type":"movie","popularity":0.4014,"vote_count":187,"poster_path":"/pcjwhq6hF3z2Wir0ZcKHTxmtRsH.jpg","release_date":"2011-05-31","vote_average":7,"backdrop_path":"/obtBUwnhRO8qcjCSB9iGvN9CCWz.jpg","original_title":"Le Chat du rabbin","original_language":"fr"},{"id":313922,"adult":false,"title":"Green Room","video":false,"overview":"A punk rock band is forced to fight for survival after witnessing an act of violence at a skinhead bar.","genre_ids":[27,80,53],"media_type":"movie","popularity":1.8088,"vote_count":2885,"poster_path":"/evZicaR7nXe4LiD9G6QYTorcJGO.jpg","release_date":"2016-04-15","vote_average":6.7,"backdrop_path":"/qRjahAq8JVoJBT2x18x2A01kxZT.jpg","original_title":"Green Room","original_language":"en"},{"id":600184,"adult":false,"title":"The Nest","video":false,"overview":"Samuel, a boy who lives with his mother Elena in Villa dei Laghi, an isolated manor surrounded by woods, feels trapped in the family routine, growing up seemingly protected, but unsatisfied and restless.","genre_ids":[18,27,9648],"media_type":"movie","popularity":0.3301,"vote_count":280,"poster_path":"/f3DNmm0VXlwaPkTuKgznQdrDveD.jpg","release_date":"2019-08-15","vote_average":6.254,"backdrop_path":"/gWE2VGDx5FyVxSMv7tH38P6PFPm.jpg","original_title":"The Nest (Il nido)","original_language":"it"},{"id":338189,"adult":false,"title":"It's Only the End of the World","video":false,"overview":"Louis, a terminally ill writer, returns home after a long absence to tell his family that he is dying.","genre_ids":[18],"media_type":"movie","popularity":0.931,"vote_count":1646,"poster_path":"/riWa3WZrO3n8lLWuaEVMgaqAZGn.jpg","release_date":"2016-09-21","vote_average":7.202,"backdrop_path":"/rsQBqWu6QgAnJmRnpbZu0rC5C7V.jpg","original_title":"Juste la fin du monde","original_language":"fr"},{"id":241258,"adult":false,"title":"Incarnate","video":false,"overview":"An exorcist comes up against an evil from his past when he uses his skills to enter the mind of a nine year old boy.","genre_ids":[27,53],"media_type":"movie","popularity":36.4981,"vote_count":593,"poster_path":"/8j8PLnghBHpDEGfANNh8wc5cT4F.jpg","release_date":"2016-12-01","vote_average":5.5,"backdrop_path":"/okVPfrSx6RopERpOqMnVzpD50ey.jpg","original_title":"Incarnate","original_language":"en"},{"id":375012,"adult":false,"title":"Under the Shadow","video":false,"overview":"After Shideh's building is hit by a missile during the Iran-Iraq War, a superstitious neighbor suggests that the missile was cursed and might be carrying malevolent Middle-Eastern spirits. She becomes convinced a supernatural force within the building is attempting to possess her daughter Dorsa, and she has no choice but to confront these forces if she is to save her daughter and herself.","genre_ids":[18,27,10752],"media_type":"movie","popularity":1.1465,"vote_count":716,"poster_path":"/3hxT9XviA3VzUtelHBk2xA6I9FY.jpg","release_date":"2016-09-30","vote_average":6.48,"backdrop_path":"/keX3XBX34vUDDULvcohfzPXIU8T.jpg","original_title":"زیر سایه","original_language":"fa"},{"id":340666,"adult":false,"title":"Nocturnal Animals","video":false,"overview":"Susan Morrow receives a book manuscript from her ex-husband – a man she left 20 years earlier – asking for her opinion of his writing. As she reads, she is drawn into the fictional life of Tony Hastings, a mathematics professor whose family vacation turns violent.","genre_ids":[18,53],"media_type":"movie","popularity":3.9295,"vote_count":8188,"poster_path":"/mdLDgQBD0va09npSQX5Zgo2evXM.jpg","release_date":"2016-11-04","vote_average":7.413,"backdrop_path":"/5d6m8CIBQcHeiwr6R5ou4wxO9Vn.jpg","original_title":"Nocturnal Animals","original_language":"en"},{"id":393519,"adult":false,"title":"Raw","video":false,"overview":"In Justine's family everyone is a vet and a vegetarian. At 16, she's a gifted teen ready to take on her first year in vet school, where her older sister also studies. There, she gets no time to settle: hazing starts right away. Justine is forced to eat raw meat for the first time in her life. Unexpected consequences emerge as her true self begins to form.","genre_ids":[27,18],"media_type":"movie","popularity":1.9942,"vote_count":3356,"poster_path":"/kc8jT1MAiKM0iwdjAwC5lQrTNry.jpg","release_date":"2017-03-10","vote_average":7.028,"backdrop_path":"/46GikxYW84dRh71sWVY0eRQiHLX.jpg","original_title":"Grave","original_language":"fr"},{"id":334533,"adult":false,"title":"Captain Fantastic","video":false,"overview":"Deep in the forests of the Pacific Northwest, a father devoted to raising his six kids with a rigorous physical and intellectual education is forced to leave his paradise and enter the world, beginning a journey that challenges his idea of what it means to be a parent.","genre_ids":[12,18],"media_type":"movie","popularity":3.2647,"vote_count":6737,"poster_path":"/2sFME73GaD8UsUxPUKe60cPdLif.jpg","release_date":"2016-07-08","vote_average":7.889,"backdrop_path":"/d84M69u6Q202dm6EvhVxbiqrK9f.jpg","original_title":"Captain Fantastic","original_language":"en"},{"id":191720,"adult":false,"title":"Jodorowsky's Dune","video":false,"overview":"In 1974, Chilean-French director Alejandro Jodorowsky embarked on the quixotic project of adapting Frank Herbert's influential novel Dune (1969) for the big screen. After investing two years, and millions of dollars, the gigantic project ended in failure; but the artists Jodorowsky brought together to carry it out continued to work together, and ended up laying the foundations for modern science fiction cinema.","genre_ids":[99],"media_type":"movie","popularity":1.075,"vote_count":743,"poster_path":"/mv1zSd6P59D43iYQXs7qx01nSiX.jpg","release_date":"2013-08-30","vote_average":7.832,"backdrop_path":"/xfC6hsmcsnf2MY1iXDs56gJNfQZ.jpg","original_title":"Jodorowsky's Dune","original_language":"en"},{"id":10086,"adult":false,"title":"Man Bites Dog","video":false,"overview":"The activities of rampaging, indiscriminate serial killer Ben are recorded by a willingly complicit documentary team, who eventually become his accomplices and active participants. Ben provides casual commentary on the nature of his work and arbitrary musings on topics of interest to him, such as music or the conditions of low-income housing, and even goes so far as to introduce the documentary crew to his family. But their reckless indulgences soon get the better of them.","genre_ids":[35,80],"media_type":"movie","popularity":2.5375,"vote_count":986,"poster_path":"/uRVI98a6MxdLkpsXM8LqIM9W7XZ.jpg","release_date":"1992-08-20","vote_average":7.22,"backdrop_path":"/7QLGk7qKm66dtjTtpVeAIRocoan.jpg","original_title":"C'est arrivé près de chez vous","original_language":"fr"},{"id":24382,"adult":false,"title":"Big Deal on Madonna Street","video":false,"overview":"Best friends Peppe and Mario are thieves, but they're not very good at it. Still, Peppe thinks that he's finally devised a master heist that will make them rich. With the help of some fellow criminals, he plans to dig a tunnel from a rented apartment to the pawnshop next door, where they can rob the safe. But his plan is far from foolproof, and the fact that no one in the group has any experience digging tunnels proves to be the least of their problems.","genre_ids":[35,80],"media_type":"movie","popularity":0.6237,"vote_count":767,"poster_path":"/f5OxD8Nl0pR3DcYHtYhHRfpsmjl.jpg","release_date":"1958-07-26","vote_average":8.087,"backdrop_path":"/ryoWP1kvNcwPif6uNbuZwQfrJPy.jpg","original_title":"I soliti ignoti","original_language":"it"},{"id":290250,"adult":false,"title":"The Nice Guys","video":false,"overview":"A private eye investigates the apparent suicide of a fading porn star in 1970s Los Angeles and uncovers a conspiracy.","genre_ids":[35,80,28],"media_type":"movie","popularity":6.1331,"vote_count":8464,"poster_path":"/clq4So9spa9cXk3MZy2iMdqkxP2.jpg","release_date":"2016-05-15","vote_average":7.127,"backdrop_path":"/yxYUN3fBPJdTNdXC1l8L24XFPhX.jpg","original_title":"The Nice Guys","original_language":"en"},{"id":310131,"adult":false,"title":"The Witch","video":false,"overview":"In 1630, a farmer relocates his family to a remote plot of land on the edge of a forest where strange, unsettling things happen. With suspicion and paranoia mounting, each family member's faith, loyalty and love are tested in shocking ways.","genre_ids":[27,14,18],"media_type":"movie","popularity":7.5486,"vote_count":7519,"poster_path":"/zap5hpFCWSvdWSuPGAQyjUv2wAC.jpg","release_date":"2016-02-19","vote_average":6.995,"backdrop_path":"/zi2oYYNSSv7t44iSt5YrxHX9PYs.jpg","original_title":"The Witch","original_language":"en"}],"similar_content":[{"id":8047,"adult":false,"title":"Matador","video":false,"overview":"A conflicted youth confesses to crimes he didn't commit while a man and woman aroused by death become obsessed with each other.","genre_ids":[18,53],"popularity":1.0017,"vote_count":286,"poster_path":"/gJJFkADuwOzDesxuP2jH1WbvFzA.jpg","release_date":"1986-03-07","vote_average":6.673,"backdrop_path":"/3LlTy01X9UUjbQW1eSN7yxiK15O.jpg","original_title":"Matador","original_language":"es"},{"id":8077,"adult":false,"title":"Alien³","video":false,"overview":"After escaping with Newt and Hicks from the alien planet, Ripley crash lands on Fiorina 161, a prison planet and host to a correctional facility. Unfortunately, although Newt and Hicks do not survive the crash, a more unwelcome visitor does. The prison does not allow weapons of any kind, and with aid being a long time away, the prisoners must simply survive in any way they can.","genre_ids":[878,28,27],"popularity":7.6072,"vote_count":6237,"poster_path":"/xh5wI0UoW7DfS1IyLy3d2CgrCEP.jpg","release_date":"1992-05-22","vote_average":6.376,"backdrop_path":"/lU0zVj8KcQVkPczdGGraYGiRC72.jpg","original_title":"Alien³","original_language":"en"},{"id":8088,"adult":false,"title":"Broken Embraces","video":false,"overview":"Harry Caine, a blind writer, reaches this moment in time when he has to heal his wounds from 14 years back. He was then still known by his real name, Mateo Blanco, and directing his last movie.","genre_ids":[18,10749,53],"popularity":1.0559,"vote_count":700,"poster_path":"/uPTOKnc9bzPp1emH3TyuKOGIylQ.jpg","release_date":"2009-03-18","vote_average":7.147,"backdrop_path":"/shrpF5ZivObmV3hnCK8sSS0DP5z.jpg","original_title":"Los abrazos rotos","original_language":"es"},{"id":8090,"adult":false,"title":"Untraceable","video":false,"overview":"Special Agent Jennifer Marsh works in an elite division of the FBI dedicated to fighting cybercrime. She thinks she has seen it all, until a particularly sadistic criminal arises on the Internet. This tech-savvy killer posts live feeds of his crimes on his website; the more hits the site gets, the faster the victim dies. Marsh and her team must find the elusive killer before time runs out.","genre_ids":[53,80,9648,18,27],"popularity":1.6294,"vote_count":969,"poster_path":"/ySUwDRDEn01lKIMPQorpFCMLWqE.jpg","release_date":"2008-01-22","vote_average":6.229,"backdrop_path":"/pPTNyx5xjYQ7WX05n3eRjmhGzdC.jpg","original_title":"Untraceable","original_language":"en"},{"id":8195,"adult":false,"title":"Ronin","video":false,"overview":"A briefcase with undisclosed contents – sought by Irish terrorists and the Russian mob – makes its way into criminals' hands. An Irish liaison assembles a squad of mercenaries, or 'ronin', and gives them the thorny task of recovering the case.","genre_ids":[28,53,80],"popularity":4.7195,"vote_count":2592,"poster_path":"/AirrhRJjHwytOV0pdLu7YZ4DEyr.jpg","release_date":"1998-09-25","vote_average":6.958,"backdrop_path":"/frqahc6v8wt0p2Zo3XKBu2dg73z.jpg","original_title":"Ronin","original_language":"en"},{"id":8202,"adult":false,"title":"Æon Flux","video":false,"overview":"400 years into the future, disease has wiped out the majority of the world's population, except one walled city, Bregna, ruled by a congress of scientists. When Æon Flux, the top operative in the underground 'Monican' rebellion, is sent on a mission to kill a government leader, she uncovers a world of secrets.","genre_ids":[878,28,53],"popularity":4.3601,"vote_count":2400,"poster_path":"/5958Nt4QX6aRSUdQnvNw8wqjTJQ.jpg","release_date":"2005-11-30","vote_average":5.644,"backdrop_path":"/uTqxyztRGHSq96JYhByyNFuqqld.jpg","original_title":"Æon Flux","original_language":"en"},{"id":8208,"adult":false,"title":"The Man Who Knew Too Much","video":false,"overview":"While vacationing in St. Moritz, a British couple receive a clue to an imminent assassination attempt, only to learn that their daughter has been kidnapped to keep them quiet.","genre_ids":[53,9648],"popularity":0.823,"vote_count":438,"poster_path":"/qghwbSfQblFYRFq675uK5qDGr3w.jpg","release_date":"1934-12-09","vote_average":6.489,"backdrop_path":"/o9QuotgupLq34zYyzFrfd4TrimC.jpg","original_title":"The Man Who Knew Too Much","original_language":"en"},{"id":1459227,"adult":false,"title":"Twisted Devotion","video":false,"overview":"R&B star Skye Williams' comeback is threatened when an obsessed fan’s admiration turns into a dangerous fixation. As she and her boyfriend vanish without a trace, Skye must fight to escape before his obsession turns deadly.","genre_ids":[53,18,10402],"popularity":0.1507,"vote_count":1,"poster_path":"/fFaAYeFq7ExPbhbRLbSK2GyLYJC.jpg","release_date":"2025-03-01","vote_average":7,"backdrop_path":"/6VUYrIJ1fMUpGC4u3h17uG6CNX6.jpg","original_title":"Twisted Devotion","original_language":"en"},{"id":8441,"adult":false,"title":"The Man of the Year","video":false,"overview":"Maiquél has lost a bet and dyed his hair blond. This  seemingly innocuous event triggers a head-on collision with destiny in which he goes from nobody to hero to outlaw — all in 24 hours.","genre_ids":[18,80,53],"popularity":0.4151,"vote_count":85,"poster_path":"/7Qai7kYNbx5k8Dy4mGTPHdVxXjK.jpg","release_date":"2003-08-01","vote_average":6.708,"backdrop_path":"/7wZY5QVLv9GWg7KSUzbDdFe6JTA.jpg","original_title":"O Homem do Ano","original_language":"pt"},{"id":8452,"adult":false,"title":"The 6th Day","video":false,"overview":"A world of the very near future in which cattle, fish, and even the family pet can be cloned. But cloning humans is illegal - that is until family man Adam Gibson comes home from work one day to find a clone has replaced him. Taken from his family and plunged into a sinister world he doesn't understand, Gibson must not only save himself from the assassins who must destroy him to protect their secret, but uncover who and what is behind the horrible things happening to him.","genre_ids":[878,28,9648,18,53],"popularity":4.0681,"vote_count":2206,"poster_path":"/rODFJOFiPk1UVCe4pmBza8T6feO.jpg","release_date":"2000-11-17","vote_average":5.99,"backdrop_path":"/opkt6IK1Os5gAwhlpu27bCZCk8K.jpg","original_title":"The 6th Day","original_language":"en"},{"id":8461,"adult":false,"title":"Funny Games","video":false,"overview":"When Ann, husband George, and son Georgie arrive at their holiday home they are visited by a pair of polite and seemingly pleasant young men. Armed with deceptively sweet smiles and some golf clubs, they proceed to terrorize and torture the tight-knit clan, giving them until the next day to survive.","genre_ids":[53,27],"popularity":4.9356,"vote_count":2217,"poster_path":"/zs92sAOh3Q0kDIJkgaJFTBzSFka.jpg","release_date":"2008-03-14","vote_average":6.556,"backdrop_path":"/6P4R7kYUdJprHpyBmOQO6aB85xX.jpg","original_title":"Funny Games","original_language":"en"},{"id":8464,"adult":false,"title":"Top of the Food Chain","video":false,"overview":"An isolated Canadian town (populated by the weirdest group of people this side of Saturn) has seen its share of problems. First the nut factory closed, then the CATV antenna stopped broadcasting, and now something is gruesomely devouring the townsfolk! Can visiting atomic scientist (and expert on \"cool fusion\") Dr. Karel Lamonte solve the mystery before everyone disappears?","genre_ids":[27,35,878],"popularity":0.2306,"vote_count":19,"poster_path":"/rlugDKVFAeXB7n6LRHZVepDUub0.jpg","release_date":"1999-09-11","vote_average":5.158,"backdrop_path":"/tyJQxPqxOVGdSoDoH4mGw1lNJf0.jpg","original_title":"Top of the Food Chain","original_language":"en"},{"id":8471,"adult":false,"title":"Far North","video":false,"overview":"In the arctic, as Saiva is being born, a shaman declares that she is evil and will bring harm to all who become involved with her. Saiva is cast out of her tribe of herders and grows up to live a nomadic existence with Anja, a young woman she adopts as an infant. Then Loki, an injured and starving soldier, stumbles into their isolated lives. The women nurse him back to health, but treachery, violence and doom await them all.","genre_ids":[18,53,10749,80],"popularity":0.4599,"vote_count":56,"poster_path":"/d31sugp9MHWv7YHGxgM5iYQVmXB.jpg","release_date":"2008-10-09","vote_average":5.991,"backdrop_path":"/rOzQTb1CWIiRlDk8ILMULOSuktG.jpg","original_title":"Far North","original_language":"en"},{"id":8512,"adult":false,"title":"Devil in a Blue Dress","video":false,"overview":"In late 1940s Los Angeles, Easy Rawlins is an unemployed black World War II veteran with few job prospects. At a bar, Easy meets DeWitt Albright, a mysterious white man looking for someone to investigate the disappearance of a missing white woman named Daphne Monet, who he suspects is hiding out in one of the city's black jazz clubs. Strapped for money and facing house payments, Easy takes the job, but soon finds himself in over his head.","genre_ids":[53,80,9648],"popularity":3.0907,"vote_count":444,"poster_path":"/5lcJhwKGavLbPva17QkTBhLfqEk.jpg","release_date":"1995-09-29","vote_average":6.45,"backdrop_path":"/n6SFCz0OsyZ800ZSlaD5WpNmqCj.jpg","original_title":"Devil in a Blue Dress","original_language":"en"},{"id":8555,"adult":false,"title":"Creep","video":false,"overview":"Trapped in a London subway station, a woman who's being pursued by a potential attacker heads into the unknown labyrinth of tunnels beneath the city's streets","genre_ids":[27,53,9648],"popularity":1.7095,"vote_count":824,"poster_path":"/w5oxV6MDEfL48FMK9BmYTD2wQRm.jpg","release_date":"2004-08-10","vote_average":6,"backdrop_path":"/ooPtDdWP2nuYCoyLJAVwdthf5dN.jpg","original_title":"Creep","original_language":"en"},{"id":8224,"adult":false,"title":"8MM","video":false,"overview":"A small, seemingly innocuous plastic reel of film leads surveillance specialist Tom Welles down an increasingly dark and frightening path. With the help of the streetwise Max, he relentlessly follows a bizarre trail of evidence to determine the fate of a complete stranger. As his work turns into obsession, he drifts farther and farther away from his wife, family and simple life as a small-town PI.","genre_ids":[53,80,9648],"popularity":4.4738,"vote_count":2200,"poster_path":"/mhr9xRpjOBqlBjgDwtiOx6FsLvV.jpg","release_date":"1999-02-26","vote_average":6.47,"backdrop_path":"/eEP8pyCmldfbnml0SFMvPK7kE4x.jpg","original_title":"8MM","original_language":"en"},{"id":8337,"adult":false,"title":"They Live","video":false,"overview":"A lone drifter stumbles upon a unique pair of sunglasses that reveal aliens are systematically gaining control of the Earth by masquerading as humans and lulling the public into submission.","genre_ids":[878,28,53],"popularity":5.6158,"vote_count":3365,"poster_path":"/ngnybFTuopfbfmmEeX9jjBQQmF6.jpg","release_date":"1988-11-04","vote_average":7.294,"backdrop_path":"/3k2DQBryXzaL7DoAtu6veWWluwt.jpg","original_title":"They Live","original_language":"en"},{"id":8643,"adult":false,"title":"The Exorcism of Emily Rose","video":false,"overview":"When a younger girl called Emily Rose dies, everyone puts blame on the exorcism which was performed on her by Father Moore prior to her death. The priest is arrested on suspicion of murder. The trial begins with lawyer Erin Bruner representing Moore, but it is not going to be easy, as no one wants to believe what Father Moore says is true.","genre_ids":[80,18,27,53],"popularity":2.8981,"vote_count":2988,"poster_path":"/qMN0HIP34f736kkQcfvTfmL9TP3.jpg","release_date":"2005-09-09","vote_average":6.602,"backdrop_path":"/eHT36hVNslbJXCY3SXgtzxPE3cl.jpg","original_title":"The Exorcism of Emily Rose","original_language":"en"},{"id":8653,"adult":false,"title":"The Isle","video":false,"overview":"Mute Hee-Jin is working as a clerk in a fishing resort in the Korean wilderness; selling baits, food and occasionally her body to the fishing tourists. One day she falls in love with Hyun-Shik, who is on the run from the police, and rescues him with a fish hook when he tries to commit suicide.","genre_ids":[18,53],"popularity":1.812,"vote_count":361,"poster_path":"/sZZ7VOFVpAN4IrPiYJzvuoVo