9:{"metadata":[["$","title","0",{"children":"Bāhubali: The Beginning | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"The young Shivudu is left as a foundling in a small village by his mother. By the time he’s grown up, it has become apparent that he possesses exceptional gifts. He meets the beautiful warrior princess Avanthika and learns that her queen has been held captive for the last 25 years. Shividu sets off to rescue her, discovering his own origins in the process."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/110820/b-hubali-the-beginning"}],["$","meta","5",{"property":"og:title","content":"Bāhubali: The Beginning"}],["$","meta","6",{"property":"og:description","content":"The young Shivudu is left as a foundling in a small village by his mother. By the time he’s grown up, it has become apparent that he possesses exceptional gifts. He meets the beautiful warrior princess Avanthika and learns that her queen has been held captive for the last 25 years. Shividu sets off to rescue her, discovering his own origins in the process."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/110820/b-hubali-the-beginning"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/9BAjt8nSSms62uOVYn1t3C3dVto.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Bāhubali: The Beginning"}],["$","meta","12",{"name":"twitter:description","content":"The young Shivudu is left as a foundling in a small village by his mother. By the time he’s grown up, it has become apparent that he possesses exceptional gifts. He meets the beautiful warrior princess Avanthika and learns that her queen has been held captive for the last 25 years. Shividu sets off to rescue her, discovering his own origins in the process."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/9BAjt8nSSms62uOVYn1t3C3dVto.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
