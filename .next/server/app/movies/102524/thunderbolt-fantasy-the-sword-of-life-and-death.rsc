5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Thunderbolt Fantasy: The Sword of Life and Death\",\"description\":\"A theatrical spinoff of the 'Thunderbolt Fantasy' television series which explores the backstory of Shā Wú Shēng, the Screaming Phoenix Killer, and bridges the events of the first and second seasons.\",\"image\":\"https://image.tmdb.org/t/p/w500/gzyCJAnKlRsHFy2DDV0aRzZ9ZGx.jpg\",\"datePublished\":\"2017-12-02\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Fantasy\",\"Animation\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8,\"bestRating\":10,\"ratingCount\":4}}"}}],["$","$L10",null,{"initialDrama":{"id":"f7a6c5a6-f1be-4701-b7e5-d516eaa520de","tmdb_id":492126,"imdb_id":"tt7735462","content_type":"movie","title":"Thunderbolt Fantasy: The Sword of Life and Death","original_title":"Thunderbolt Fantasy: 生死一劍","overview":"A theatrical spinoff of the 'Thunderbolt Fantasy' television series which explores the backstory of Shā Wú Shēng, the Screaming Phoenix Killer, and bridges the events of the first and second seasons.","poster_path":"/gzyCJAnKlRsHFy2DDV0aRzZ9ZGx.jpg","backdrop_path":"/pyPUP9OOID2I3ZRfDlSrSavxLrJ.jpg","release_date":"2017-12-02","first_air_date":null,"status":"published","original_language":"ja","origin_country":["JP","TW"],"genres":[{"id":28,"name":"Action"},{"id":14,"name":"Fantasy"},{"id":16,"name":"Animation"}],"popularity":2.5244,"vote_average":8,"vote_count":4,"runtime":75,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-04T22:29:01.994446+00:00","updated_at":"2026-02-23T13:41:58.367+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":22600,"name":"Nitroplus","logo_path":"/13FsFa7wcjR3mj9zaGSSws4OyOA.png","origin_country":"JP"}],"production_countries":[{"name":"Japan","iso_3166_1":"JP"},{"n