6u8O13rkxVM6HgpuSFxR5DT1.jpg","iso_639_1":"fr","vote_average":0},{"width":2000,"height":3000,"file_path":"/mvnYVD53R2L97Wuz8cZmDKOareM.jpg","iso_639_1":"ru","vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/efQIfpxegsg6KHfTcVngrPO09cs.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/ygOR390GzOX5Quv0kAAcUNDG7fp.jpg","iso_639_1":null,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/1620O3cU3GcJt5wbhmpbtMNOp9J.jpg","iso_639_1":"en","vote_average":0.166},{"width":1280,"height":720,"file_path":"/se7rUCGDtrdBglkd9ltO1R2Fdlv.jpg","iso_639_1":"en","vote_average":0.166},{"width":1920,"height":1080,"file_path":"/dCIauyF3NrCDGQNKxPV6ugFJkCK.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/tYaiwo7pxQI5Rtvkym2V5i4VS6J.jpg","iso_639_1":"en","vote_average":0},{"width":1920,"height":1080,"file_path":"/chlgCHXETiHhgI5791p4dJnFuJ3.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/AbrmwgcCBp0047v3ehoXvBnNs0s.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/eI5XeJqEF7Lt14NswOWjwwRnPXs.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-02-21T11:05:40.41+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":90,"tagline":"Blood flows like the tide.","homepage":"https://www.revasserfilms.com/captainhook","overview":"In the aftermath of a devastating defeat by his archnemesis Admiral Smee, Captain Hook finds refuge in the coastal town of Eldritch Landing."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Капитан Хук - Прокълнатите приливи и отливи","runtime":0,"tagline":"","homepage":"","overview":"След опустошителното поражение от своя заклет враг адмирал Сми, прословутият капитан Джеймс Хук намира убежище в крайбрежния град Елдрич Лендинг, където сключва невероятен съюз със Сайлъс Блекуедър, местен ковач, търсещ възмездие за убийството на сестра си. Докато избягват войниците с червени престилки на Смий в гъстата гора на острова, безмилостни битки с мечове, древни проклятия и противоречиви мотиви ще предизвикат общото им търсене на отмъщение. Заедно Хук и Сайлъс навигират в неизследвани води, за да се изправят срещу коварния адмирал Сми, впускайки се в пътешествие, което ще предефинира трайното наследство на капитан Хук."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"虎克船长：诅咒潮汐","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Capitão Hook: As Marés Malditas","runtime":0,"tagline":"O SANGUE FLUI COMO A MARÉ","homepage":"","overview":"Após uma derrota devastadora contra o Almirante Smee, o Capitão Hook refugia-se na costa de Eldtrich Landing, onde encontra Silas Blackweather, um ferreiro movido pela vingança após o assassinato de sua irmã. Enquanto fogem dos soldados vermelhos do Almirante, eles enfrentam duelos brutais e forças ocultas representadas por antigas maldições. Sua aliança improvável os leva a desafiar Smee em águas inexploradas, num embate que pode redefinir o legado de Hook para sempre."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Капітан Гак: Прокляті береги","runtime":0,"tagline":"","homepage":"","overview":"Після нищівної поразки від свого заклятого ворога, адмірала Смі, сумнозвісний капітан Джеймс Гак знаходить притулок у прибережному місті Елдріч-Лендінг, де він укладає союз із Сайласом Блеквезером, місцевим ковалем, який прагне відплати за вбивство своєї сестри. Тікаючи від солдатів Смі крізь густі ліси острова, вони стикаються з безжальними поєдинками на мечах, давніми прокляттями та суперечливими мотивами, що випробовуватимуть їхнє спільне прагнення до помсти."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"კაპიტანი კაუჭა - დაწყევლილი მოქცევა","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Kapetan Hook – Uklete plime","runtime":0,"tagline":"","homepage":"","overview":"Nakon razornog poraza od svog zakletog neprijatelja, admirala Smeea, zloglasni kapetan James Hook pronalazi utočište u obalnom gradiću Eldritch Landing, gdje sklapa neočekivani savez sa Silasom Blackweatherom, mjesnim kovačem koji traži osvetu za sestrino ubojstvo. Dok bježe od Smeeovih vojnika kroz guste šume otoka, nemilosrdni mačevalački okršaji, drevna prokletstva i sukobljeni motivi stavljaju na kušnju njihovu zajedničku potragu za osvetom. Zajedno, Hook i Silas plove neistraženim vodama kako bi se suočili s podmuklim admiralom Smeeom, krećući na putovanje koje će iznova oblikovati trajno naslijeđe kapetana Hooka."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Tras ser derrotado por el Almirante Smee, el Capitán Hook se refugia en un pueblo maldito. Allí, se alía con un herrero local que busca venganza por el asesinato de su hermana."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Tras ser derrotado por el Almirante Smee, el Capitán Hook se refugia en un pueblo maldito. Allí, se alía con un herrero local que busca venganza por el asesinato de su hermana."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Captain Hook : La Mer Maudite","runtime":90,"tagline":"","homepage":"","overview":"Après sa défaite face à l'amiral Smee, le capitaine Hook se cache à Eldritch Landing et s'allie au forgeron Silas Blackweather pour venger la mort de sa sœur. Va-t-il obtenir sa vengeance ?"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":90,"tagline":"Le sang coule comme la marée.","homepage":"","overview":"Après avoir subi une défaite cuisante face à son ennemi juré, l'amiral Smee, le capitaine Crochet trouve refuge dans la ville côtière d'Eldritch Landing."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Капитан Крюк: Проклятые берега","runtime":0,"tagline":"","homepage":"","overview":"Гроза морей, капитан Джеймс вступает в неравную схватку с заклятым врагом Сми, который однажды его предал и перешёл на службу к королю. Битва заканчивается сокрушительным поражением Джеймса, потерявшего и команду, и руку. Но ему чудом удаётся избежать казни. Скрываясь от преследования, он набредает на дом угрюмого кузнеца Сайласа Блэквезера. Тот делает для раненого капитана металлический крюк вместо отрубленной руки. Новых знакомых объединяет нечто важное - ненависть к адмиралу Сми, убившему сестру Сайласа. Шансы на месть повышаются, когда всплывает мистическое проклятие этих приморских земель."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"}],"reviews_tmdb":[{"id":"68f938704c57ef30dc609570","url":"https://www.themoviedb.org/review/68f938704c57ef30dc609570","author":"mblom","content":"$11","created_at":"2025-10-22T20:02:56.088Z","updated_at":"2025-11-08T23:40:19.563Z","author_details":{"name":"","rating":2,"username":"mblom","avatar_path":null}}],"recommendations":[{"id":42487,"adult":false,"title":"Necromancy","video":false,"overview":"After Lori suffers a stillbirth, her husband Frank obtains a job with a northern California toy company. Frank's new boss, the mysterious Mr. Cato, explains that Frank's position will involve magic. Cato, who seemingly holds enormous influence over the town, pursues the power of necromancy and believes that Lori holds the key that will help him resurrect his own dead son.","genre_ids":[27],"media_type":"movie","popularity":0.3511,"vote_count":35,"poster_path":"/rQHyzMR8t9lR1eB1e2Nyt6J31IP.jpg","release_date":"1972-09-22","vote_average":4.414,"backdrop_path":"/nUDIR168AUjnHXGv1iXyiB51TOZ.jpg","original_title":"Necromancy","original_language":"en"},{"id":1428262,"adult":false,"title":"Mystery Island: Winner Takes All","video":false,"overview":"Mystery Island hosts contest winners vying to solve a fake murder for a grand prize, but the event goes awry when an employee is murdered, and secrets are uncovered.","genre_ids":[9648,10770],"media_type":"movie","popularity":0.326,"vote_count":14,"poster_path":"/sfFlXsgxnoQWePsb4UY6R27opVE.jpg","release_date":"2025-03-13","vote_average":5.714,"backdrop_path":"/eJFCdeVz6EBC5WkpkbCwhRJ4iKj.jpg","original_title":"Mystery Island: Winner Takes All","original_language":"en"},{"id":45878,"adult":false,"title":"Return to Horror High","video":false,"overview":"A few years ago, a mysterious serial-killer caused panic on Crippen High School. The killer was never caught. A movie company, Cosmic Pictures, has decided to make a feature movie about these events - on location, at the now abandoned school. Since members of cast and crew disappear without a trace, it seems as if history is repeating itself...","genre_ids":[27,35],"media_type":"movie","popularity":0.8017,"vote_count":177,"poster_path":"/glZ0Wz5u2Vr7TzM6Kj1f4e6EliU.jpg","release_date":"1987-01-28","vote_average":5.208,"backdrop_path":"/xutd42AYja7C21GuK5d6yR7VJLB.jpg","original_title":"Return to Horror High","original_language":"en"},{"id":283564,"adult":false,"title":"SlugTerra: Return of the Elementals","video":false,"overview":"A new member has joined Eli and the Shane Gang! Junjie, once the protector of the Eastern Caverns, is a master of the slugslinging art of Slug Fu! But even with the power of five slingers, the Shane Gang find themselves in over their heads as they race across The 99 Caverns in search of the Legendary Elemental Slugs. The five Elementals are ancient slugs of great power, and the forbearers of all slugs found in SlugTerra today. In the wrong hands, they could bring Slugterra to the brink of destruction. So when an evil alliance starts hunting down the Elementals, Eli and his friends — old and new — take off in pursuit of the greatest threat their world has ever faced!","genre_ids":[10751,16,12],"media_type":"movie","popularity":0.6128,"vote_count":348,"poster_path":"/ApN2lteDsoIU5dDHJXeqVD13vpd.jpg","release_date":"2014-08-02","vote_average":6.974,"backdrop_path":"/6jnSkRFKkcyKyQJGO5eVfFeXFGF.jpg","original_title":"SlugTerra: Return of the Elementals","original_language":"en"},{"id":125521,"adult":false,"title":"Slayers Return","video":false,"overview":"Lina Inverse and Naga the White Serpent are back! What begins as a routine bandit-stomping turns into the adventure of a lifetime involving magical golems, an ancient Elven weapon and even someone bent on destroying the world. It's a predicament only Lina and Naga could get themselves in to.","genre_ids":[16,12,35,14],"media_type":"movie","popularity":1.1817,"vote_count":2073,"poster_path":"/fNQx9YD4nxpcWvriVm1paIxbMwB.jpg","release_date":"1996-08-03","vote_average":6.546,"backdrop_path":"/1SeydkGlChbUrYJeV95TNSLQsFt.jpg","original_title":"スレイヤーズ RETURN","original_language":"ja"},{"id":11246,"adult":false,"title":"Hellraiser: Hellseeker","video":false,"overview":"When the puzzle box is once again solved, Pinhead and his legion demolish all who dare oppose them. But standing in his way is the only person who has defeated Cenobites of the past.","genre_ids":[27,53],"media_type":"movie","popularity":1.8628,"vote_count":390,"poster_path":"/r6aaaXLgwp2nuX5tGtisRM5fsHW.jpg","release_date":"2002-10-15","vote_average":4.976,"backdrop_path":"/2pGRnOQ6gcDm1MW8qjbVjwJFupF.jpg","original_title":"Hellraiser: Hellseeker","original_language":"en"},{"id":1030419,"adult":false,"title":"Legend of the Galactic Heroes: Die Neue These - Intrigue 1","video":false,"overview":"The story focuses on the exploits of rivals Reinhard von Lohengramm and Yang Wen-li, as they rise to power and fame in the Galactic Empire and the Free Planets Alliance, respectively.","genre_ids":[16,878,10752,18],"media_type":"movie","popularity":0.6327,"vote_count":54,"poster_path":"/brrgSFtcymZWaXl5a23GJRWdOSY.jpg","release_date":"2022-09-30","vote_average":6.074,"backdrop_path":null,"original_title":"銀河英雄伝説 Die Neue These 策謀 1","original_language":"ja"},{"id":874300,"adult":false,"title":"South Park: Post COVID: The Return of COVID","video":false,"overview":"If Stan, Kyle and Cartman could just work together, they could go back in time to make sure Covid never happened. But traveling back to the past seems to be the easy answer until they meet Victor Chaos.","genre_ids":[16,35,10770],"media_type":"movie","popularity":1.0121,"vote_count":464,"poster_path":"/xD88mrJ8hsqYVqQ6kinNNGQLdg1.jpg","release_date":"2021-12-16","vote_average":7.392,"backdrop_path":"/kogLnm2OMn6iUBeZIkIywsrwl3H.jpg","original_title":"South Park: Post COVID: The Return of COVID","original_language":"en"},{"id":850888,"adult":false,"title":"Sayen: The Huntress","video":false,"overview":"Realizing that she cannot take down Fisk alone, Sayen teams up with an underground resistance group with a plan to expose and end Fisk's unchecked plundering once and for all.","genre_ids":[28,53],"media_type":"movie","popularity":1.1879,"vote_count":166,"poster_path":"/upKD8UbH8vQ798aMWgwMxV8t4yk.jpg","release_date":"2024-04-26","vote_average":5.858,"backdrop_path":"/AuTfo1lbE8s2Y8RVTmlbJAeLWPK.jpg","original_title":"Sayen: La cazadora","original_language":"es"},{"id":28260,"adult":false,"title":"Return of the Living Dead III","video":false,"overview":"Having recently witnessed the horrific results of a top secret project to bring the dead back to life, a distraught teenager performs the operation on his girlfriend after she's killed in a motorcycle accident.","genre_ids":[27,10749],"media_type":"movie","popularity":2.38,"vote_count":894,"poster_path":"/lu4Eit7pR5I8hGHJmy3K9Re8FPo.jpg","release_date":"1993-10-01","vote_average":6.567,"backdrop_path":"/3eYQyFx4QQ5j0L0wqjEoC8I1RvF.jpg","original_title":"Return of the Living Dead III","original_language":"en"},{"id":45279,"adult":false,"title":"Yu Yu Hakusho: The Movie - Poltergeist Report","video":false,"overview":"When the Spirit World is flooded due to an unusual rainfall which overflows the River Sanzu (aka the River Styx), Lord Koenma senses an extremely powerful enemy. He entrusts Death God Botan, to deliver to Spirit Detective Yusuke, a mysterious item which must be protected from the invading enemy. However, by the time Botan finds Yusuke, she's too weak to explain the situation. Yusuke and his friends are left in the dark about the new enemy, but not for long. Soon it is a battle for Earth between mere Spirit Detectives and the almighty king of the Netherworld.","genre_ids":[16,14,28],"media_type":"movie","popularity":1.466,"vote_count":62,"poster_path":"/a0KGBLZXJ3riF0UJaZRxTGoVUEt.jpg","release_date":"1994-04-09","vote_average":7.581,"backdrop_path":"/9ePa1XmV4Khyuc5eMCcsG2z5YjR.jpg","original_title":"幽☆遊☆白書 『冥界死闘篇・炎の絆』","original_language":"ja"},{"id":10725,"adult":false,"title":"Wolfen","video":false,"overview":"A New York City cop and an expert criminologist trying to solve a series of grisly deaths in which the victims have seemingly been maimed by feral animals discover a sinister connection between the crimes and an old legend.","genre_ids":[27,53],"media_type":"movie","popularity":4.4915,"vote_count":252,"poster_path":"/hb4TJBeElGyIa7tmF2466iwwItB.jpg","release_date":"1981-07-24","vote_average":5.925,"backdrop_path":"/2emn3D5215BfQrMBNXGV9Y8xInJ.jpg","original_title":"Wolfen","original_language":"en"},{"id":606149,"adult":false,"title":"Captain Sabertooth and the Magical Diamond","video":false,"overview":"Captain Sabertooth and his crew are up against a sunburnt vampire, a manipulating queen, a violent monkey army and two young pirates while on the hunt for the magical diamond.","genre_ids":[16,10751],"media_type":"movie","popularity":0.7297,"vote_count":47,"poster_path":"/e3ffIIhlOU8mUFmC4DjsOdVzVN6.jpg","release_date":"2020-02-13","vote_average":7.1,"backdrop_path":"/aenZ1GSnPOjqiadOqc0FxTQE0Ff.jpg","original_title":"Kaptein Sabeltann og den Magiske Diamant","original_language":"no"},{"id":541524,"adult":false,"title":"Passing","video":false,"overview":"In 1920s New York City, a Black woman finds her world upended when her life becomes intertwined with a former childhood friend who's passing as white.","genre_ids":[18],"media_type":"movie","popularity":0.7715,"vote_count":333,"poster_path":"/t4tYUT1oSWOP6XKZBoclPAG96KP.jpg","release_date":"2021-10-27","vote_average":6.285,"backdrop_path":"/7mH9nwyEyiGrODuq1khFEXyk5iY.jpg","original_title":"Passing","original_language":"en"},{"id":463520,"adult":false,"title":"The Return","video":false,"overview":"The Return is a 2016 documentary directed by Emmy Award winning director Erich Joiner chronicling Ford GT's return to 24 Hours of Le Mans after their 1966 1-2-3 victory.","genre_ids":[99,28],"media_type":"movie","popularity":0.1533,"vote_count":93,"poster_path":"/ROvTxTwcCN8CyxrV4Rhun9MhYD.jpg","release_date":"2017-06-15","vote_average":6.6,"backdrop_path":"/bOTts5qHl3qiRUpsGYcwVYuOQ1H.jpg","original_title":"The Return","original_language":"en"},{"id":25460,"adult":false,"title":"Return to Sender","video":false,"overview":"While fighting for a woman who sits on death row, a lawyer happens upon new information which brings into question the motives of a man associated with her client","genre_ids":[18],"media_type":"movie","popularity":0.7576,"vote_count":170,"poster_path":"/2OZj98sFBQYYS48uIAWTP5siCkT.jpg","release_date":"2004-09-17","vote_average":6.3,"backdrop_path":"/zYhtledBfkAn4QgljNjNep8YDfd.jpg","original_title":"Return to Sender","original_language":"en"},{"id":1125257,"adult":false,"title":"Freakier Friday","video":false,"overview":"Years after Tess and Anna endured an identity crisis, Anna now has a daughter of her own and a soon-to-be stepdaughter. As they navigate the myriad challenges that come when two families merge, Tess and Anna discover lightning might indeed strike twice.","genre_ids":[35,14,10751],"media_type":"movie","popularity":7.1212,"vote_count":616,"poster_path":"/9wV65OmsjLAqBfDnYTkMPutXH8j.jpg","release_date":"2025-08-06","vote_average":6.859,"backdrop_path":"/yQy9Y3p5INwkfTuHSnzYnz4MCV3.jpg","original_title":"Freakier Friday","original_language":"en"},{"id":19142,"adult":false,"title":"The Return of Swamp Thing","video":false,"overview":"The Swamp Thing returns to battle the evil Dr. Arcane, who has a new science lab full of creatures transformed by genetic mutation, and chooses Heather Locklear as his new object of affection.","genre_ids":[27,878],"media_type":"movie","popularity":1.0442,"vote_count":257,"poster_path":"/5sm1Yi1hgj805b9o2a1uC6BXhqw.jpg","release_date":"1989-05-11","vote_average":5.5,"backdrop_path":"/vTGbFAFh3cGAFeLaXS8M3l3sl9z.jpg","original_title":"The Return of Swamp Thing","original_language":"en"},{"id":777620,"adult":false,"title":"Caged","video":false,"overview":"An African American male is imprisoned and placed in solitary confinement after being found guilty of murdering his wife, as he's haunted by internal demons and his dead wife, and pushed to the breaking point by an abusive female guard.","genre_ids":[53,27,18],"media_type":"movie","popularity":0.2845,"vote_count":123,"poster_path":"/8NUM43rtQSt0chumXGJPvnYb01I.jpg","release_date":"2021-01-26","vote_average":6.3,"backdrop_path":"/b0qfFTzpzDGNqK1NUdALroL2XLG.jpg","original_title":"Caged","original_language":"en"},{"id":391596,"adult":false,"title":"Return To Salem's Cove","video":false,"overview":"Evil returns to Salem's Cove. It's up to the sheriff and his closest allies to save not only the town but the world from an evil force that hasn't been heard from since The Salem Witch Trials Ended.  Unexplained evil acts have been happening since Salem's Cove was founded on the coast of North Carolina after the Salem Witch Trials. Paranormal activities has always been stopped and hidden from the general public by a secret order of defenders. The defenders greatest fears are about to be unleashed, not only to the people of Salem's Cove but to the rest of the world. Sheriff Ethan Grey and Lt. Gibbs must enlist help and reveal the truth about the towns best kept secret before it's too late.","genre_ids":[27],"media_type":"movie","popularity":0.1281,"vote_count":29,"poster_path":"/dhYL7zNfOAbLQ0PnSuDoUNIkUZj.jpg","release_date":"2017-10-20","vote_average":6.5,"backdrop_path":null,"original_title":"Return To Salem's Cove","original_language":"en"}],"similar_content":[{"id":667,"adult":false,"title":"You Only Live Twice","video":false,"overview":"A mysterious spacecraft captures Russian and American space capsules and brings the two superpowers to the brink of war. James Bond investigates the case in Japan and comes face to face with his archenemy Blofeld.","genre_ids":[28,53,12],"popularity":7.1355,"vote_count":2402,"poster_path":"/fdRbvRcEXcf2rC4ghLFZzCWPSmB.jpg","release_date":"1967-06-13","vote_average":6.593,"backdrop_path":"/cpZAXIYA0lkZMpAt7d1MmH8ojNV.jpg","original_title":"You Only Live Twice","original_language":"en"},{"id":879,"adult":false,"title":"Hook","video":false,"overview":"The boy who wasn't supposed to grow up—Peter Pan—does just that, becoming a soulless corporate lawyer whose workaholism could cost him his wife and kids. During his trip to see Granny Wendy in London, the vengeful Capt. Hook kidnaps Peter's kids and forces Peter to return to Neverland.","genre_ids":[12,14,35,10751],"popularity":7.3012,"vote_count":5619,"poster_path":"/a6rB1lGXoGms7gWxRfJneQmAjNV.jpg","release_date":"1991-04-10","vote_average":6.838,"backdrop_path":"/39OxcFZjX4uc6vYzexUh5qXghxE.jpg","original_title":"Hook","original_language":"en"},{"id":902,"adult":false,"title":"The City of Lost Children","video":false,"overview":"A scientist in a s