ath":"/rVMaCUIVdjcm2DaHNv4EzxNGr4R.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/wYarrYMbkp8mPWPxyVAU2E7ewGo.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/lDRiEPvsARYaHOF1hgcUPm0mtZR.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/3h8ffFOSVHOEf5ud0nXVA5Q2gor.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/aVlegB73gwctRZlCJlhUXT3ufcn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":1.066},{"width":1280,"height":720,"file_path":"/xlI840pXJI99AQKV8IZeIDxqBss.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":2000,"height":1125,"file_path":"/j03rEkghb3sNLQIA0HZvPI8swgK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":3840,"height":2160,"file_path":"/nR8B299XzW7ISVN8ry0tHCdUF8M.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":3840,"height":2160,"file_path":"/irOvzN2nQwSHs1akv1VtsRP3I1b.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":3840,"height":2160,"file_path":"/gdpOBft4WaFEZ36TgxE12ORGAlA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":1280,"height":720,"file_path":"/n2bNafm1kX3ok76GbEfLgJgG8rb.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1525,"height":858,"file_path":"/eVSTYciFwdgkCeiOJ9yIQkGwteD.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.777,"vote_average":0.166},{"width":2560,"height":1440,"file_path":"/8rq1BU5UcBBvY54SkrqYcQER4sA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":2041,"height":1148,"file_path":"/hpnYP5QX6bpGLklwlHtLLB0cVGk.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2066,"height":1162,"file_path":"/6ACMGysEfB3J1BcO9XZKnZCTJ9P.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/tmdPkpuhHo8tzXWWUlhIVqYoTYd.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/5AiAnsc2tsqjh0lJf1MQhyjjcee.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/cuowhbDFIuQLVev1P91XBKKvrOO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1901,"height":1069,"file_path":"/5oiauWW5iCc8V7NUSM1Loa97PHZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1301,"height":732,"file_path":"/aPwD97mvIp9ikoVfDDzPOjkyxyw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1920,"height":1080,"file_path":"/3q91N3fFaEkFLhWyvcMBaF3wge0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/s7kRQeGdBdPnZOzghzm5T6JM94G.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:48:43.908+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Je suis toujours là","runtime":135,"tagline":"","homepage":"","overview":"Rio, 1971, sous la dictature militaire. La grande maison des Paiva, près de la plage, est un havre de vie, de paroles partagées, de jeux, de rencontres. Jusqu’au jour où des hommes du régime viennent arrêter Rubens, le père de famille, qui disparaît sans laisser de traces. Sa femme Eunice et ses cinq enfants mèneront alors un combat acharné pour la recherche de la vérité..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"I'm Still Here","runtime":138,"tagline":"When a mother's courage defies tyranny, hope is reborn.","homepage":"https://www.sonyclassics.com/film/imstillhere","overview":"A woman married to a former politician during the 1971 military dictatorship in Brazil is forced to reinvent herself and chart a new course for her family after a violent and arbitrary act."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":135,"tagline":"Quando a coragem de uma mãe desafia a tirania, a esperança renasce.","homepage":"","overview":"No início da década de 1970, o Brasil enfrenta o endurecimento da ditadura militar. No Rio de Janeiro, a família Paiva – Rubens, Eunice e seus cinco filhos – vive à beira da praia em uma casa de portas abertas para os amigos. Um dia, Rubens Paiva é levado por militares à paisana e desaparece."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"아임 스틸 히어","runtime":138,"tagline":"그날, 우리의 시간이 멈췄다","homepage":"","overview":"바닷가 근처에 예쁜 집. 웃고 노래하는 사랑스러운 한 가족. 어느 날 찾아온 남자들은 아버지를 끌고 갔다. 아내는 물었다. \"그는 어디에, 그는 왜\" 사람은 말했다. \"그는 없다. 그를 모른다.\" 그렇게 시작된 20년의 돌림 노래. 아들은 글을 썼고 친구는 카메라를 들었으며 당신은 극장에 앉아 있다. 그날의 영원한 증인이 되기 위해."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Io sono ancora qui","runtime":0,"tagline":"","homepage":"","overview":"Eunice, madre di cinque figli, vede cambiare bruscamente la sua vita quando il marito, l'ex deputato del Partito laburista brasiliano Rubens Paiva, scompare improvvisamente, catturato dal regime militare nel 1964. La donna è costretta all’attivismo, sperando in questo modo di trovare il marito e riuscire a salvarlo."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"我仍在此","runtime":138,"tagline":"","homepage":"","overview":"1971年，巴西：整个国家正深陷军事独裁统治的高压控制。当一个家庭的平静生活被恣意暴行无情击碎，一位母亲被迫踏上重塑自我的道路。影片改编自马塞洛·鲁本斯·派瓦的畅销回忆录。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"I'm Still Here","runtime":136,"tagline":"Kiedy odwaga matki przeciwstawia się tyranii, nadzieja odradza się.","homepage":"","overview":"W Rio de Janeiro w latach 70., podczas dyktatury, były zastępca Marcelo Rubens Paiva został zabrany z domu przez żołnierzy na przesłuchanie. Nigdy go nie odnaleziono. Poszukiwanie prawdy trwa 30 długich lat. A gdy zaczynają pojawiać się odpowiedzi, jego matka Eunice Paiva odczuwa pierwsze objawy choroby Alzheimera."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":137,"tagline":"","homepage":"","overview":"Rio de Janeiro, início dos anos 1970, quando o país enfrenta o endurecimento da ditadura militar.  Estamos no centro de uma família, os Paiva: um pai, Rubens, uma mãe, Eunice, e os cinco filhos.  Vivem na frente da praia, numa casa de portas abertas para os amigos.  O afeto e o humor que compartilham entre si são suas formas sutis de resistência à opressão que paira sobre o Brasil.  Um dia, eles sofrem um ato violento e arbitrário que vai mudar para sempre sua história.  Eunice é obrigada a se reinventar e a traçar um novo destino para si e os filhos.  Baseada no livro biográfico de Marcelo Rubens Paiva, a história emocionante dessa família ajudou a redefinir a história do país."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Hâlâ Buradayım","runtime":0,"tagline":"","homepage":"","overview":"Rio de Janeiro’dayız. Hayat güzel, insanlar plajda keyif yapıyor ve her şey çok rahat, hoş, sakin. Ancak, yıl 1971 ve Brezilya askeri diktatörlüğün git gide sıkılaşan pençesinde eziliyor. O gün, eski milletvekili Rubens Paiva ordu tarafından gözaltına alınır, karısı Eunice de daha sonra tutuklanır. Eunice günler sonra serbest bırakılır, ancak Rubens ortadan kaybolmuştur. Beş çocuğuyla ortada kalan Eunice, ailesinin paramparça oluşuyla hem aktivist hem de bir avukat ve kahraman olarak hayatını ve kendini baştan yaratmak zorunda kalır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Aún estoy aquí","runtime":137,"tagline":"","homepage":"","overview":"Brasil, 1971. Un país en las garras de una dictadura militar. Una madre se ve obligada a reinventarse cuando la vida de su familia se ve destrozada por un acto de violencia arbitraria."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"I'm Still Here","runtime":137,"tagline":"","homepage":"","overview":"In de jaren zeventig in Rio de Janeiro, tijdens de militaire dictatuur van Brazilië, werd voormalig plaatsvervanger Rubens Paiva door soldaten uit zijn huis gehaald om te worden ondervraagd. Hij werd nooit meer gevonden. Zijn vrouw en familie gingen op zoek naar de waarheid van zijn lot, in een zoektocht die dertig jaar zou duren."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Я все еще здесь","runtime":135,"tagline":"","homepage":"","overview":"Бразилия, 1971 год. В стране уже шесть лет свирепствует военная диктатура. Инженер Рубенс Пайва, многодетный отец и любящий муж, некогда бывший конгрессменом, готовится облагородить семейное гнёздышко в Рио-де-Жанейро, но в дом приходят солдаты и увозят Рубенса на допрос, с которого он так и не возвращается. Его жена Юнис начинает борьбу за правду и пытается вернуть любимого."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Sunt încă aici","runtime":0,"tagline":"","homepage":"","overview":"La începutul anilor 1970, dictatura militară din Brazilia atinge apogeul. Familia Paiva - Rubens, Eunice și cei cinci copii ai lor - locuiește într-o casă de lângă plajă, în Rio, deschisă pentru toți prietenii lor. Într-o zi, Rubens este luat pentru interogatoriu și nu se mai întoarce."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Aún estoy aquí","runtime":137,"tagline":"","homepage":"","overview":"Una madre se ve obligada al activismo político cuando su marido, el diputado izquierdista Rubens Paiva, fue capturado por el régimen durante la Dictadura militar de Brasil, en 1971. Basada en las memorias de Marcelo Rubens Paiva"},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"אני עדיין כאן","runtime":135,"tagline":"","homepage":"","overview":"בברזיל של  1971, משפחה מבורכת ילדים מנהלת שגרת חיים בריאה ושוקקת סמוך לחופיה המרהיבים של ריו דה ז'נרו. אלא שהאידיליה המשפחתית אינה משקפת את הלך הרוח הפוליטי במדינה, שנמצאת תחת אחיזתה הההדוקה של דיקטטורה צבאית. יום אחד, אבי המשפחה, חבר קונגרס לשעבר, נלקח לחקירה משטרתית, ועקבותיו נעלמות. אשתו תעשה הכל כדי להשיב אותו הביתה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Olen veel siin","runtime":0,"tagline":"","homepage":"","overview":"Rio de Janeiro 1970. aastate algul. Brasiilia seisab silmitsi militaarse diktatuuri haarde tugevnemisega. Paivase perekonnas on isa Rubens, ema Eunice ja nende viis last. Nad elavad rannas üürimajas, mille uksed on sõpradele alati avatud. Riigis valitseva rõhumise vastu võitleb pere huumorimeele ja üksteise armastamisega. Ühel päeval aga langevad nad vägivaldse rünnaku ohvriks. Eunice on seetõttu sunnitud otsast alustama ja peab endale ning oma lastele uue tuleviku looma. Marcelo Rubens Paiva memuaaridel põhinev liigutav lugu aitab tutvustada olulist osa Brasiilia varjatud ajaloost."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"Все още съм тук","runtime":0,"tagline":"","homepage":"","overview":"В началото на 70-те години военната диктатура в Бразилия достига своя връх. Семейството Паива - Рубенс, Юнис и техните пет деца - живеят в къща на брега на Рио, която е отворена за всичките им приятели. Един ден Рубенс е отведен за разпит и не се връща."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Olen yhä täällä","runtime":136,"tagline":"","homepage":"","overview":"Rio de Janeiro, 1970-luvun alkupuoli. Sotilasdiktatuuri kiristää otettaan Brasiliasta, ja poliittisia vastustajia tarkkaillaan ja vainotaan. Entinen kongressiedustaja Rubens Paiva asuu vaimonsa Eunicen ja viiden lapsensa kanssa kauniin hiekkarannan lähellä. Eräänä päivänä sisään marssii aseistettuja miehiä, jotka vievät kuulusteltavaksi ensin perheen isän ja sitten Eunicen sekä heidän tyttärensä Elianan. Sorron julmimpia keinoja vastarinnan nujertamiseksi ovat perheitä ja mieliä rikkovat ihmisten katoamiset."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"アイム・スティル・ヒア","runtime":0,"tagline":"","homepage":"","overview":"元国会議員であったルーベンス・パイヴァが軍事政権によって誘拐されるという、実際に起こった事件をもとに描かれる歴史劇。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"I’m Still Here","runtime":0,"tagline":"","homepage":"","overview":"Brasilien, 1971: Der ehemalige linke Kongressabgeordnete Rubens Pavia lebt mit seiner Familie das pulsierende Lebensgefühlt der 70er-Jahre in Rio de Janeiro. Die Fänge der Militärdiktatur sind Bestandteil des Alltags. Eines Tages wird Rubens von Schergen verschleppt. Seine Familie weiss nicht wo er ist und ob er noch lebt. Seine Ehefrau Eunice versucht ihn aufzuspüren und an Informationen darüber zu gelangen, was mit ihrem geliebten Ehemann geschehen ist."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"CH","english_name":"German"},{"data":{"title":"Είμαι Ακόμη Εδώ","runtime":137,"tagline":"","homepage":"","overview":"Μια θαρραλέα και στωική μητέρα (Fernanda Torres) πέντε παιδιών πασχίζει να κρατήσει ενωμένη την οικογένειά της, όταν ο πρώην βουλευτής συζυγός της (Selton Mello) συλλαμβάνεται από το δικτατορικό καθεστώς της χώρας και κατόπιν εξαφανίζεται. Η ταινία ξεκινά το 1971 και καλύπτει 25 χρόνια του αγώνα της αξιοθαύμαστης αυτής γυναίκας, η οποία μετατρέπει τη δοκιμασία της σε ένα συγκλονιστικό μάθημα αγάπης, πεισματικής αισιοδοξίας και αδιάκοπης συντήρησης της μνήμης."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Für immer hier","runtime":135,"tagline":"","homepage":"https://dcmstories.com/movie/fuer-immer-hier/","overview":"Rio de Janeiro, Anfang der 1970er Jahre. In einem gemieteten Haus am Strand lebt die Familie Paiva: Vater Rubens, Mutter Eunice und ihre fünf Kinder.  Auch mit der allgegenwärtigen Unterdrückung bewahren sie in ihrem Zuhause eine Atmosphäre der Liebe, des Humors und der Offenheit. Ihre Zuneigung zueinander wird zu einem stillen Akt des Widerstands gegen die Diktatur, die ihr Leben radikal verändert. Als Rubens verschwindet, wird Eunice zur treibenden Kraft, um ihrer Familie eine neue Zukunft aufzubauen. Den Herausforderungen dieser dunklen Zeit begegnet sie mit Mut, Entschlossenheit und dem unerschütterlichen Glauben an ihre Kinder. Diese bewegende Geschichte wirft ein Licht auf die verschwiegenen Kapitel der brasilianischen Geschichte und würdigt die Stärke einer Frau, die trotz widrigster Umstände niemals aufgibt."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"من هنوز اینجام","runtime":0,"tagline":"","homepage":"","overview":"در سال 1971 در برزیل، زندگی زنی به نام یونیس پایوا و پنج فرزندش پس از ناپدید شدن همسرش، روبنس پایوا، نماینده سابق حزب کارگر برزیل، ناگهان تغییر می‌کند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Navždy s vámi","runtime":0,"tagline":"","homepage":"","overview":"Rio de Janeiro, 70. léta 20. století. Na pozadí sílící vojenské diktatury vede rodina Paivových idylický život. Bývalý poslanec Rubens bydlí se svou manželkou Eunice a pěti dětmi v domě u pláže, ve kterém se neustále střídají radostné návštěvy. Láska a humor jim slouží jako vlastní forma obrany v temné kapitole brazilských dějin. Jednoho dne však represe nenávratně zasáhnou i jejich rodinu a Eunice je nucena hledat novou budoucnost pro sebe a své děti."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"我依然在此","runtime":136,"tagline":"","homepage":"","overview":"1970年的里約熱內盧，沙灘上到處是嬉鬧人群，魯本斯與尤妮絲一家七口就住在海濱街區，與朋友聚會、歡笑暢談、拍照留念是他們的日常；但同時，不滿獨裁政府的反對聲浪四起，也讓白色恐怖逐漸蔓延每個角落。一日，意外的訪客打破平靜，魯本斯遭軍方強行帶走，自此下落不明。悲痛的尤妮絲被迫挺身而出，找尋丈夫失蹤的真相，並獨自撐起這個家，以堅定的心持續帶給孩子們完整的愛與希望。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Je suis toujours là","runtime":138,"tagline":"","homepage":"https://www.sonypictures.ca/fr/movies/je-suis-toujours-l%C3%A0","overview":"Au Brésil, dans les années 1970, une mère de famille entreprend un combat acharné pour retrouver son mari enlevé par le régime militaire."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"ما زلت هنا","runtime":0,"tagline":"","homepage":"","overview":"في عام 1971، بلغت الديكتاتورية العسكرية في البرازيل ذروتها. تعيش عائلة بايفا — روبنز، ويونيس، وأطفالهما الخمسة — في منزل يطل على الشاطئ في ريو دي جانيرو، حيث يستقبلون أصدقاءهم بكل ترحاب. في يوم من الأيام، يتم استدعاء روبنز للتحقيق ولا يعود."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"I'm Still Here","runtime":0,"tagline":"","homepage":"","overview":"Brasilien, 1970. Rio de Janeiros stränder sjuder av liv, men i kulisserna hårdnar militärjuntans grepp om landet. När Rubens Paiva hämtas i sitt hem av beväpnade män, förbyts idyllen i oro och förtvivlan. Plötsligt står hans fru Eunice ensam med parets fem barn, och nu börjar hennes envisa kamp för att återförena familjen."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Aš vis dar čia","runtime":0,"tagline":"","homepage":"","overview":"Aštuntojo dešimtmečio pradžioje karinė diktatūra Brazilijoje pasiekia aukščiausią tašką. Paivų šeima – Rubensas, Eunice ir penki jų vaikai – gyvena Rio paplūdimio name, atvirame visiems jų draugams. Vieną dieną Rubensas išvežamas į apklausą ir nebegrįžta."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Én még itt vagyok","runtime":137,"tagline":"","homepage":"","overview":"Eunice boldog életet él férjével és gyermekeikkel Rio de Janeiróban. Férjét, Rubens Paivát, az ellenzéki politikust és az uralkodó katonai diktatúra nyílt kritikusát azonban 1971-ben a hatóságok erőszakkal elhurcolják otthonukból. Eunice-nak és a gyerekeknek nemcsak a férfi hiányával kell megbirkózniuk, hanem az elnyomó rezsim kíméletlen valóságával is szembe kell nézniük. Évekig reménykednek, és várják, hogy Rubens visszatérjen – bár lehet, hogy soha nem tér vissza. Eunice mégis rendíthetetlenül kitart eltökéltsége mellett, hogy megtalálja eltűnt férjét."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Tôi Vẫn Ở Đây","runtime":0,"tagline":"","homepage":"","overview":"Một buổi chiều năm 1971, Rubens Paiva, cựu dân biểu và là người chỉ trích thẳng thắn chế độ độc tài quân sự mới được thành lập của Brazil, đã bị các viên chức chính phủ bắt khỏi nhà riêng ở Rio de Janeiro. Được chuyển thể từ hồi ký của con trai ông là Marcelo Rubens Paiva, bộ phim chính trị hoành tráng, được thực hiện phong phú này của Walter Salles vẫn gắn chặt với góc nhìn của vợ Rubens - Eunice, người đã không ngừng tìm kiếm sự thật về chồng mình trong nhiều thập kỷ."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"ในปี 1971 ระบอบเผด็จการทหารในบราซิลถึงขีดสุด ครอบครัว Paiva ประกอบด้วย Rubens, Eunice และลูกๆ ทั้งห้าคน อาศัยอยู่ในบ้านริมชายหาดในริโอที่เปิดให้เพื่อนๆ ทุกคนเข้าได้ วันหนึ่ง Rubens ถูกพาตัวไปสอบปากคำและไม่ได้กลับมาอีกเลย"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Я досі тут","runtime":0,"tagline":"","homepage":"","overview":"У 1971 році військова диктатура в Бразилії досягає свого розквіту. Сім’я Пайва — Рубенс, Юніс та їхні п’ятеро дітей — живуть у будинку на березі моря в Ріо, відкритому для всіх своїх друзів. Одного разу Рубенса ведуть на допит і він не повертається."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"我生如是繼續","runtime":0,"tagline":"","homepage":"","overview":"「被失蹤是政權最殘酷的行為之一。」1970 年代裏約熱內盧，軍政府陰霾籠罩，派瓦一家七口本過得樂也融融，直至一日曾任國會議員的父親浩本斯被強行帶走，從此音訊全無。母親尤妮斯也一度遭拘留審問，她飽受煎熬，仍竭力照顧兒女，亦從沒拋棄過追尋丈夫。一家的真實生活軌跡，映照巴西軍政獨裁的黑暗歲月，看似平淡卻張力萬鈞，深沉地撼動你我。當身處苦難，拒絕遺忘，微笑佇立活下去，原是最堅韌的反抗。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Encara soc aquí","runtime":0,"tagline":"","homepage":"","overview":"Rio de Janeiro, a començaments dels anys 70. El Brasil s’enfronta a una dictadura militar cada vegada més severa. Coneixem els Paiva: un pare, en Rubens; una mare, l’Eunice; i els seus cinc fills. Viuen a la platja, en una casa llogada amb les portes sempre obertes als amics. L’afecte i l’humor que comparteixen són la seva manera subtil de resistir l’opressió que amenaça el país. Un dia, pateixen un acte violent i arbitrari que canviarà les seves vides per sempre. A partir d’aquell moment, l’Eunice es veu obligada a reinventar-se i a forjar un nou futur per a ella i els seus fills. La commovedora història d’aquesta família, basada en les memòries de Marcelo Rubens Paiva, va ajudar a reconstruir una part fonamental de la història silenciada del Brasil."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Još sam ovdje","runtime":0,"tagline":"","homepage":"","overview":"Majka mora ponovno pronaći sebe i svoju obitelj pod sve jačim stiskom vojne diktature."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"}],"reviews_tmdb":[{"id":"6796c46d16f0d960df239910","url":"https://www.themoviedb.org/review/6796c46d16f0d960df239910","author":"Brent Marchant","content":"$11","created_at":"2025-01-26T23:25:33.925Z","updated_at":"2025-01-27T09:16:17.626Z","author_details":{"name":"Brent Marchant","rating":10,"username":"Brent_Marchant","avatar_path":null}},{"id":"679bb5fdb00d3bad92bd8ba1","url":"https://www.themoviedb.org/review/679bb5fdb00d3bad92bd8ba1","author":"CinemaSerf","content":"$12","created_at":"2025-01-30T17:25:17.824Z","updated_at":"2025-01-30T17:38:39.221Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}},{"id":"67c0f7ea9adcd2562535ad79","url":"https://www.themoviedb.org/review/67c0f7ea9adcd2562535ad79","author":"r96sk","content":"<em>'I’m Still Here'</em> undoubtedly merits praise, it's an astutely made picture regarding a dark time in Brazilian history. The film's biggest plus, for me, is how warmly they portray the Paivas, it genuinely feels as if you are watching a real family; the actors play a big part in that, of course.\r\n\r\nFernanda Torres is the standout, rightly so given she leads much of what we see. An excellent performance! Selton Mello sticks out too, as do all of the relatively younger cast members; e.g. Luiza Kosovski and Valentina Herszage. There isn't anyone onscreen who puts a foot wrong.\r\n\r\nI will say that I don't think this needed to be a 138 minute movie, there are a couple of moments where I felt like it was going to conclude and it didn't. This isn't a major detail though, because it is a film of sturdy quality and is most definitely worth viewing.","created_at":"2025-02-27T23:40:26.772Z","updated_at":"2025-02-27T23:40:26.862Z","author_details":{"name":"","rating":8,"username":"r96sk","avatar_path":"/mwR7rFHoDcobAx1i61I3skzMW3U.jpg"}},{"id":"695330e476a338c001d79fc0","url":"https://www.themoviedb.org/review/695330e476a338c001d79fc0","author":"badelf","content":"$13","created_at":"2025-12-30T01:54:44.305Z","updated_at":"2025-12-30T07:53:06.316Z","author_details":{"name":"","rating":10,"username":"badelf","avatar_path":null}}],"recommendations":[{"id":1118848,"adult":false,"title":"The Quiet Son","video":false,"overview":"Pierre, a devoted father in his 50s, raises his two sons alone. When Louis, the youngest, leaves home to attend the Sorbonne in Paris, Fus, slightly older and not as successful academically, becomes more and more secretive. Driven by a fascination for violence, he gets entangled in far-right extremist groups, at the very opposite of his father’s values. Between them, there is love and hate, until tragedy happens.","genre_ids":[18],"media_type":"movie","popularity":0.9578,"vote_count":133,"poster_path":"/CLpEUf9FutbFkLX3PGaKKEqXjf.jpg","release_date":"2025-01-22","vote_average":6.447,"backdrop_path":"/OhOA3pvYlllL0Bq3Fbb4voHtLe.jpg","original_title":"Jouer avec le feu","original_language":"fr"},{"id":1028196,"adult":false,"title":"Nickel Boys","video":false,"overview":"Chronicles the powerful friendship between two young Black teenagers navigating the harrowing trials of reform school together in Florida.","genre_ids":[18,36],"media_type":"movie","popularity":2.6044,"vote_count":320,"poster_path":"/lu2vmmtStmTNMmSZl2LgrrQpLZo.jpg","release_date":"2024-12-13","vote_average":6.586,"backdrop_path":"/kmLssINCNdXnIDjWkBsk6LUNSbe.jpg","original_title":"Nickel Boys","original_language":"en"},{"id":959596,"adult":false,"title":"Maldoror","video":false,"overview":"When two girls go missing, Paul Chartier, an impulsive young police recruit, is assigned to “Maldoror”. This secret unit has been set up to monitor a dangerous sex offender. When the operation fails, fed up with the limits of the legal system, Chartier embarks on a solitary hunt to bring down the culprits.","genre_ids":[53,80,18],"media_type":"movie","popularity":0.7965,"vote_count":92,"poster_path":"/kdOeeJOZySlQ5pDFijMIUuwLIPG.jpg","release_date":"2024-09-08","vote_average":6.391,"backdrop_path":"/5N3w3cC5d8fDMLuuDMn8io4StUE.jpg","original_title":"Le Dossier Maldoror","original_language":"fr"},{"id":1278263,"adult":false,"title":"The Seed of the Sacred Fig","video":false,"overview":"Investigating judge Iman grapples with paranoia amid political unrest in Tehran. When his gun vanishes, he suspects his wife and daughters, imposing draconian measures that strain family ties as societal rules crumble.","genre_ids":[18,53,80],"media_type":"movie","popularity":2.5979,"vote_count":427,"poster_path":"/ifOazNzv2cNJ5CQjMV7cPXG2Lmy.jpg","release_date":"2024-09-18","vote_average":7.563,"backdrop_path":"/zqZzYVE4DWv92xrYSCEELPcLnUP.jpg","original_title":"Les Graines du figuier sauvage","original_language":"fr"},{"id":1211472,"adult":false,"title":"September 5","video":false,"overview":"During the 1972 Munich Olympics, an American sports broadcasting crew finds itself thrust into covering the hostage crisis involving Israeli athletes.","genre_ids":[53,18,36],"media_type":"movie","popularity":3.2284,"vote_count":514,"poster_path":"/3kcQOLwYKGPwyjiynFsvP8vHvRn.jpg","release_date":"2024-11-07","vote_average":7.002,"backdrop_path":"/nEH7XUCeWsEuJtGgWUVUl6MEQW0.jpg","original_title":"September 5","original_language":"en"},{"id":1088514,"adult":false,"title":"The Room Next Door","video":false,"overview":"Ingrid and Martha were close friends in their youth, when they worked together at the same magazine. Ingrid went on to become an autofiction novelist while Martha became a war reporter, and they were separated by the circumstances of life. After years of being out of touch, they meet again in an extreme but strangely sweet situation.","genre_ids":[18,35],"media_type":"movie","popularity":3.0635,"vote_count":660,"poster_path":"/qMibLyArrlBJ87AoqQBeVaFeRXp.jpg","release_date":"2024-10-07","vote_average":6.751,"backdrop_path":"/9Xx0BCkxDsF47niAPsb8lQ0O9Qu.jpg","original_title":"La habitación de al lado","original_language":"es"},{"id":1013850,"adult":false,"title":"A Real Pain","video":false,"overview":"Mismatched cousins David and Benji reunite for a tour through Poland to honor their beloved grandmother. The adventure takes a turn when the pair's old tensions resurface against the backdrop of their family history.","genre_ids":[35,18],"media_type":"movie","popularity":4.6031,"vote_count":1314,"poster_path":"/67xRIXm5TxXRT4nV2V4AEJ9yq2d.jpg","release_date":"2024-11-01","vote_average":6.766,"backdrop_path":"/fViElUGfdoZjtnVxvSpJX8TwxY6.jpg","original_title":"A Real Pain","original_language":"en"},{"id":1064213,"adult":false,"title":"Anora","video":false,"overview":"A young sex worker from Brooklyn gets her chance at a Cinderella story when she meets and impulsively marries the son of an oligarch. Once the news reaches Russia, her fairytale is threatened as his parents set out to get the marriage annulled.","genre_ids":[18,35,10749],"media_type":"movie","popularity":11.8488,"vote_count":2972,"poster_path":"/cgXk2tNYhJZLXdBDO5DidAVzQ82.jpg","release_date":"2024-10-14","vote_average":7.057,"backdrop_path":"/qvyOfwTC3qdbzkqdXWSSEMHtjBZ.jpg","original_title":"Anora","original_language":"en"},{"id":549509,"adult":false,"title":"The Brutalist","video":false,"overview":"When an innovative modern architect flees post-war Europe, he is given the opportunity to rebuild his legacy. Set during the dawn of the modern United States (in Pennsylvania), his wife joins him, and their lives are forever changed by a demanding, wealthy patron.","genre_ids":[18],"media_type":"movie","popularity":7.7736,"vote_count":1555,"poster_path":"/vP7Yd6couiAaw9jgMd5cjMRj3hQ.jpg","release_date":"2024-12-20","vote_average":6.96,"backdrop_path":"/hmZnqijPaaACjenDkrbWcCmcADI.jpg","original_title":"The Brutalist","original_language":"en"},{"id":1038263,"adult":false,"title":"Maria","video":false,"overview":"Maria Callas, the world's greatest opera singer, lives the last days of her life in 1970s Paris, as she confronts her identity and life.","genre_ids":[36,18,10402],"media_type":"movie","popularity":3.169,"vote_count":432,"poster_path":"/3oQRG0bwPUqE4N4n8z2kAzr7e40.jpg","release_date":"2024-11-27","vote_average":6.446,"backdrop_path":"/9iw4a6AQkxUO3EuRn59Vgrqf0zO.jpg","original_title":"Maria","original_language":"en"},{"id":1155828,"adult":false,"title":"Sing Sing","video":false,"overview":"Divine G, imprisoned at Sing Sing for a crime he didn't commit, finds purpose by acting in a theatre group alongside other incarcerated men in this story of resilience, humanity, and the transformative power of art.","genre_ids":[18],"media_type":"movie","popularity":2.5295,"vote_count":329,"poster_path":"/s0TPyI8QlMiktEiq3JVhea0zFhM.jpg","release_date":"2024-07-12","vote_average":7.444,"backdrop_path":"/CZyMhVVpraYDptLpYXxXjgAuCH.jpg","original_title":"Sing Sing","original_language":"en"},{"id":929204,"adult":false,"title":"Wallace & Gromit: Vengeance Most Fowl","video":false,"overview":"Gromit’s concern that Wallace is becoming too dependent on his inventions proves justified, when Wallace invents a “smart” gnome that seems to develop a mind of its own. When it emerges that a vengeful figure from the past might be masterminding things, it falls to Gromit to battle sinister forces and save his master… or Wallace may never be able to invent again!","genre_ids":[10751,35,12,16],"media_type":"movie","popularity":4.9421,"vote_count":614,"poster_path":"/jUWFSBxTOiCinPdTOh3IDUXVemZ.jpg","release_date":"2024-12-18","vote_average":7.467,"backdrop_path":"/XNVdWNgiAHu8y4BsJv5ndUHXxN.jpg","original_title":"Wallace & Gromit: Vengeance Most Fowl","original_language":"en"},{"id":1321412,"adult":false,"title":"Ride Away","video":false,"overview":"From the Atlantic to the Black Sea, Mathias and Philippe, two old friends, embark on a bicycle journey that Mathias’s son made before his tragic death. The two men ride through the ordeals with tenderness, humor and emotion.","genre_ids":[35,18],"media_type":"movie","popularity":1.8045,"vote_count":96,"poster_path":"/84j57nt48tBB2521lEBfQq9HARQ.jpg","release_date":"2025-02-26","vote_average":7.2,"backdrop_path":"/bLuf0gUwHQRqYRxzPrnMnT0L6cw.jpg","original_title":"À bicyclette !","original_language":"fr"},{"id":1236419,"adult":false,"title":"Piece by Piece","video":false,"overview":"A unique cinematic experience that invites audiences on a vibrant journey through the life of cultural icon Pharrell Williams. Told through the lens of LEGO® animation, turn up the volume on your imagination and witness the evolution of one of music's most innovative minds.","genre_ids":[16,10751,10402,99,35],"media_type":"movie","popularity":1.9724,"vote_count":141,"poster_path":"/fmOPcP8WRvm8cok4Hz3REwD7rlJ.jpg","release_date":"2024-10-10","vote_average":7.298,"backdrop_path":"/oqWTbBixgF8XwqzGeFWMzkNwqAw.jpg","original_title":"Piece by Piece","original_language":"en"},{"id":1113120,"adult":false,"title":"Sons","video":false,"overview":"Eva, an idealistic prison officer, is faced with the dilemma of her life when a young man from her past gets transferred to the prison where she works. Without revealing her secret, Eva asks to be moved to the young man’s ward – the toughest and most violent in the prison. Here begins an unsettling psychological thriller, where Eva’s sense of justice puts both her morality and future at stake.","genre_ids":[53,18],"media_type":"movie","popularity":3.1879,"vote_count":92,"poster_path":"/rbNoiXJS3PW1u3geU3VcttBqi6C.jpg","release_date":"2024-07-10","vote_average":6.636,"backdrop_path":"/b5ei2QImsyKJlY63zGBEpQScTDQ.jpg","original_title":"Vogter","original_language":"da"},{"id":804862,"adult":false,"title":"Bring Them Down","video":false,"overview":"When the ongoing rivalry between farmers Michael and Jack suddenly escalates, it triggers a chain of events that take increasingly violent and devastating turns, leaving both families permanently altered.","genre_ids":[18,53],"media_type":"movie","popularity":1.0229,"vote_count":73,"poster_path":"/2jskL5eOFTQknpRalJ4chVYyuFo.jpg","release_date":"2025-02-06","vote_average":6.76,"backdrop_path":"/om7apkYMeZMsZ60RsR9DGitTkPy.jpg","original_title":"Bring Them Down","original_language":"en"},{"id":1063875,"adult":false,"title":"Miss Violet","video":false,"overview":"France. End of the 19th century. Louise Violet  40, a Parisian teacher, is sent on a mission to the French countryside. But in a place where the daily life is linked to the seasons, land and crops, she must first convince parents to send their kids to school. With the help of the mayor, she is gradually accepted by the parents and their children. But soon, her past catches up with her. Despite the obstacles she faces, Miss Violet will give her heart and soul to her belief that education is the key to freedom.","genre_ids":[18,36],"media_type":"movie","popularity":4.3418,"vote_count":56,"poster_path":"/eFTgCTDbWMEsxOGZnQq78XoUMyY.jpg","release_date":"2024-11-06","vote_average":6.973,"backdrop_path":"/zT8LR9MkZuHZxJsaqgNpxUf9lxl.jpg","original_title":"Louise Violet","original_language":"fr"},{"id":893228,"adult":false,"title":"Section 8","video":false,"overview":"After avenging the murder of his family, a former soldier is sprung from prison and recruited by a shadowy government agency.","genre_ids":[28,53],"media_type":"movie","popularity":1.6218,"vote_count":132,"poster_path":"/3G1wHQNITyfiABp2fgytpiFMHf9.jpg","release_date":"2022-09-23","vote_average":6.1,"backdrop_path":"/vtsqIXoDGM8ZS6rcQ1TKfdOycjC.jpg","original_title":"Section 8","original_language":"en"},{"id":42536,"adult":false,"title":"Napoleon","video":false,"overview":"A biopic of Napoleon Bonaparte, tracing the Corsican's career from his schooldays (where a snowball fight is staged like a military campaign) to his flight from Corsica, through the French Revolution (where a real storm is intercut with a political storm) and the Terror, culminating in his triumphant invasion of Italy in 1797.","genre_ids":[18,36,10752],"media_type":"movie","popularity":1.4858,"vote_count":213,"poster_path":"/zGupJ1ZO07BWco8YGjBHk90hYWh.jpg","release_date":"1927-01-10","vote_average":7.8,"backdrop_path":"/aZ6YMH5OjY1IYSlREtVmmcHqgQf.jpg","original_title":"Napoléon","original_language":"fr"},{"id":1108336,"adult":false,"title":"Wild Diamond","video":false,"overview":"Liane, 19 years old, daring and fiery, lives with her mother and little sister under the dusty sun of Fréjus in the South of France. Obsessed with beauty and the need to become “someone”, she sees reality TV as her opportunity to be loved... Fate smiles upon her when she auditions for “Miracle Island”.","genre_ids":[18],"media_type":"movie","popularity":1.4369,"vote_count":96,"poster_path":"/eEF2q2e3vntpKsHa4hQfaF0CVR8.jpg","release_date":"2024-10-09","vote_average":6.401,"backdrop_path":"/rCwzI7prQhPMRxOY2r5x7Zb34Yq.jpg","original_title":"Diamant brut","original_language":"fr"}],"similar_content":[{"id":661539,"adult":false,"title":"A Complete Unknown","video":false,"overview":"New York, early 1960s. Against the backdrop of a vibrant music scene and tumultuous cultural upheaval, an enigmatic 19-year-old from Minnesota arrives in the West Village with his guitar and revolutionary talent, destined to change the course of American music.","genre_ids":[18,10402],"popularity":6.2729,"vote_count":1369,"poster_path":"/llWl3GtNoXosbvYboelmoT459NM.jpg","release_date":"2024-12-25","vote_average":7.081,"backdrop_path":"/kcCy5tKTe6WepVQ6SQaSewpmoCj.jpg","original_title":"A Complete Unknown","original_language":"en"},{"id":8349,"adult":false,"title":"The Red Baron","video":false,"overview":"Richthofen goes off to war like thousands of other men. As fighter pilots, they become cult heroes for the soldiers on the battlefields. Marked by sportsmanlike conduct, technical exactitude and knightly propriety, they have their own code of honour. Before long he begins to understand that his hero status is deceptive. His love for Kate, a nurse, opens his eyes to the brutality of war.","genre_ids":[28,12,18,36,10752],"popularity":1.0629,"vote_count":274,"poster_path":"/lUuryram6Aoa11dCgoXohR8avjU.jpg","release_date":"2008-03-29","vote_average":6.6,"backdrop_path":"/lAS4vRXqpA6jrSK1vRmxbtpsCop.jpg","original_title":"Der rote Baron","original_language":"de"},{"id":8417,"adult":false,"title":"Süss, the Jew","video":false,"overview":"Nazi historical drama about Duke Karl Alexander of Württemberg and his treasurer Süß Oppenheimer.","genre_ids":[18,36],"popularity":0.3031,"vote_count":45,"poster_path":"/3fN1p4OY7Mi0zXQqMJvCdhRwEYs.jpg","release_date":"1940-09-24","vote_average":4.3,"backdrop_path":"/4msV23h4lRFXQoOUUL8Oc0XTcxt.jpg","original_title":"Jud Süß","original_language":"de"},{"id":8434,"adult":false,"title":"Summer Things","video":false,"overview":"Two couple of friends, one very rich, the other almost homeless, decide to go on Holiday. Julie, a single mother, joins them too. Once at seaside, it starts a complicate love cross among them that will involve also a transsexual, a jealous brother, a Latin Lover and another nervous stressed couple. Not to mention about the daughter of one of them that is secretly in Chicago with one of her father's employees... At the end of the summer, all of them will join the same party...","genre_ids":[35,18,10749],"popularity":0.5262,"vote_count":102,"poster_path":"/laV4Xo5O1COZefAFPJLFZ28pkYS.jpg","release_date":"2002-03-04","vote_average":5.809,"backdrop_path":"/azkp4brPsmzJiyKw5ExkPDrVpWA.jpg","original_title":"Embrassez qui vous voudrez","original_language":"fr"},{"id":8435,"adult":false,"title":"A Cock and Bull Story","video":false,"overview":"Steve Coogan, an arrogant actor with low self-esteem and a complicated love life, is playing the eponymous role in an adaptation of \"The Life and Opinions of Tristram Shandy, Gentleman\" being filmed at a stately home. He constantly spars with actor Rob Brydon, who is playing Uncle Toby and believes his role to be of equal importance to Coogan's.","genre_ids":[35,36],"popularity":0.6497,"vote_count":148,"poster_path":"/g14QNhGkWLviBr18nCGDB1U8w8f.jpg","release_date":"2005-07-17","vote_average":6.149,"backdrop_path":"/8MWKVstOmGUlCsS80iPTHDH7N22.jpg","original_title":"A Cock and Bull Story","original_language":"en"},{"id":661436,"adult":false,"title":"An Accident","video":false,"overview":"In the 1980s, the building themes were transformed into bipolar moral dilemmas involving overly ambitious individuals who wanted to excel at any cost. The hero is the head of a demolition crew that demolishes large buildings, initially a sympathetic young man who, in the pursuit of career and accolades, begins to transgress the boundaries of what was then called socialist morality and legality. He gradually finds himself at odds with the principles of ordinary but honest people. The narrative's bland, proclamatory film is closely connected to its time of creation, and there are hardly any more timeless insights to be found.","genre_ids":[18],"popularity":0.2665,"vote_count":0,"poster_path":"/iFKRA8kCddfN0B23EXbSW3sOgI4.jpg","release_date":"1986-09-01","vote_average":0,"backdrop_path":null,"original_title":"Havárie","original_language":"cs"},{"id":8326,"adult":false,"title":"Holes","video":false,"overview":"After being wrongfully convicted for stealing a pair of shoes, Stanley Yelnats is sent away to Camp Green Lake, a boys detention facility where inmates are forced to dig holes all day in the hot desert sun as a form of character building. But Stanley and the other boys start to unravel a mystery, linked with the camps tough-as-nails warden —and possibly Stanley’s family itself.","genre_ids":[12,10751,18,35],"popularity":3.4761,"vote_count":1508,"poster_path":"/o2Dm2mcE1qW8vT0bpsJO5OMBbqa.jpg","release_date":"2003-04-18","vote_average":6.897,"backdrop_path":"/cVMK2k0Wbs8DV3IK5sS4ziVenrI.jpg","original_title":"Holes","original_language":"en"},{"id":8327,"adult":false,"title":"The Holy Mountain","video":false,"overview":"The Alchemist assembles together a group of people from all walks of life to represent the planets in the solar system. The occult adept's intention is to put his recruits through strange mystical rites and divest them of their worldly baggage before embarking on a trip to Lotus Island. There they ascend the Holy Mountain to displace the immortal gods who secretly rule the universe.","genre_ids":[18],"popularity":2.0506,"vote_count":997,"poster_path":"/mP5FGQbNjFkrjcZ6AVHrvokPRe5.jpg","release_date":"1973-11-29","vote_average":7.535,"backdrop_path":"/oUceCsSe255ZKXCMsHhqXM1xuUp.jpg","original_title":"La montaña sagrada","original_language":"es"},{"id":8332,"adult":false,"title":"Antibodies","video":false,"overview":"When a notorious German serial killer is captured after committing some of the most heinous acts against humanity ever imaginable, a farmer and police officer from a sleepy rural community on the outskirts of Berlin is drawn into the case as he searches for the answers to a murder that has shaken his tight-knit community.","genre_ids":[53,80,18,27],"popularity":0.7007,"vote_count":186,"poster_path":"/wIQP8C3yz8E4J1La9ehIy4Yta6e.jpg","release_date":"2005-04-24","vote_average":6.715,"backdrop_path":"/qwpkykpdPFycZBhjOQvA0xYluCT.jpg","original_title":"Antikörper","original_language":"de"},{"id":8338,"adult":false,"title":"Blindness","video":false,"overview":"When a sudden plague of blindness devastates a city, a small group of the afflicted band together to triumphantly overcome the horrific conditions of their imposed quarantine.","genre_ids":[18,9648,878,53],"popularity":5.8895,"vote_count":1340,"poster_path":"/deBsx5IxyqCC217j3VY24TkkE0Z.jpg","release_date":"2008-05-14","vote_average":6.514,"backdrop_path":"/sN0czEtCT1jEFQVajWBsKwdFBKm.jpg","original_title":"Blindness","original_language":"en"},{"id":661475,"adult":false,"title":"Apinan vuosi","video":false,"overview":"A young student seeks direction in his life to counterbalance the studies through female adventures.","genre_ids":[18,35],"popularity":0.424,"vote_count":2,"poster_path":"/2OnmxCt66lXG1MuSky901gwGruq.jpg","release_date":"1983-11-11","vote_average":7,"backdrop_path":"/7XvomNV2M9UqZEa87IRk69F441R.jpg","original_title":"Apinan vuosi","original_language":"fi"},{"id":661484,"adult":false,"title":"Homebound","video":false,"overview":"Mika's mother marries a man who is getting out of the jail. At the beginning everything seems to be all right. Mika leaves Oulu, an industrial city up in Northern Finland, to study in the capital, Helsinki. He does very well with his studies and also begins a relationship with the girl he knew already back in Oulu. Meanwhile the new husband reveals his true self - and all of a sudden things get very serious.","genre_ids":[18,80],"popularity":0.1424,"vote_count":6,"poster_path":"/p7EGNACTjvLsoulLpQuOEIjWCTZ.jpg","release_date":"1989-03-10","vote_average":4.333,"backdrop_path":"/obXiQdOSvswg8me5RFe2u4FZvne.jpg","original_title":"Kotia päin","original_language":"fi"},{"id":471103,"adult":false,"title":"The Fight for Rome II - The Betrayal","video":false,"overview":"The devious general Cethegus plays the Byzantine and Gothic forces against each other for his own gain.","genre_ids":[18,12,36],"popularity":0.2616,"vote_count":5,"poster_path":"/mSCCFODBAn6HE1fY3jbRegPJWZ0.jpg","release_date":"1969-02-21","vote_average":7,"backdrop_path":"/tM5nwmohCwKInwqbHyQ8WX9W75E.jpg","original_title":"Kampf um Rom II - Der Verrat","original_language":"de"},{"id":661653,"adult":false,"title":"Oliverio and the Pool","video":false,"overview":"When something unexpected happens in Oliverio’s family, all he wants to do is walk away. He settles on a deckchair by the pool and decides there is no reason to move. Life swirls around him, revealing secrets and presenting new challenges. Through moments of death, excrement and basic physics, Oliverio learns that some truths cannot be ignored.","genre_ids":[18,35],"popularity":0.2318,"vote_count":8,"poster_path":"/nJlTuSCvg6GuI5Y21xN2cF9tzhT.jpg","release_date":"2022-02-03","vote_average":5,"backdrop_path":"/kpfOgz6u1AySqZTvMjfcod8NTcu.jpg","original_title":"Oliverio y la piscina","original_language":"es"},{"id":8440,"adult":false,"title":"Carandiru","video":false,"overview":"When a doctor decides to carry out an AIDS prevention program inside Latin America’s largest prison: the Casa de Detenção de São Paulo - Carandiru, he meets the future victims of one of the darkest days in Brazilian History when the State of São Paulo’s Military Police, with the excuse for law enforcement, shot to death 111 people. Based on real facts and on the book written by Dráuzio Varella.","genre_ids":[18],"popularity":3.3175,"vote_count":594,"poster_path":"/kKAgIMwQWQ6u4s0c56XKSDX3vAs.jpg","release_date":"2003-03-21","vote_average":7.577,"backdrop_path":"/rhrBU761a5B4w7hhpA9og3fNBCH.jpg","original_title":"Carandiru","original_language":"pt"},{"id":661681,"adult":false,"title":"Our Season","video":false,"overview":"Bok-ja is granted a special vacation after her death, which allows her to go see her daughter, Jin-joo, a university professor living abroad. Unlike her expectation, Bok-ja finds Jin-joo living in her old house running a local diner and becomes frustrated with questions that she is unable to ask. After spending time alongside Jin-joo, Bok-ja realizes that her daughter is struggling with the unresolved feelings about her, and tries to find a way to show her sincere feelings that she had never shared before.","genre_ids":[18,14],"popularity":0.9055,"vote_count":9,"poster_path":"/o39QYkDnmuS6gmyAIPPZnGiUFzr.jpg","release_date":"2023-12-06","vote_average":8.556,"backdrop_path":"/sY0PJZRxNtPM7W4RpAAeDKXNrv5.jpg","original_title":"3일의 휴가","original_language":"ko"},{"id":471288,"adult":false,"title":"Dreams I Never Had","video":false,"overview":"A teenage girl is held captive in the home of a wealthy family. She is befriended by the family's young gardener, himself an illegal from Mexico. Their friendship carries both of them through their hopeless, sequestered lives and ultimately inspires them to break free.","genre_ids":[18],"popularity":0.2318,"vote_count":3,"poster_path":"/oViL0Ixk5PVP649ciEa9tNHy66c.jpg","release_date":"2018-04-01","vote_average":5,"backdrop_path":"/yCctV5LWdfVusw1vh6iVYeOSNwK.jpg","original_title":"Dreams I Never Had","original_language":"en"},{"id":8588,"adult":false,"title":"Shooting Dogs","video":false,"overview":"Two westerners, a priest and a teacher find themselves in the middle of the Rwandan genocide and face a moral dilemna. Do they place themselves in danger and protect the refugees, or escape the country with their lives? Based on a true story.","genre_ids":[18,36],"popularity":0.5575,"vote_count":159,"poster_path":"/9xC2yUgqPVvoHykYuigrxLyunya.jpg","release_date":"2006-03-08","vote_average":7.469,"backdrop_path":"/6PkzgNLKoK1Oy0j7L79JuBgl22r.jpg","original_title":"Shooting Dogs","original_language":"en"},{"id":8619,"adult":false,"title":"Master and Commander: The Far Side of the World","video":false,"overview":"After an abrupt and violent encounter with a French warship inflicts severe damage upon his ship, a captain of the British Royal Navy begins a chase over two oceans to capture or destroy the enemy, though he must weigh his commitment to duty and ferocious pursuit of glory against the safety of his devoted crew, including the ship's thoughtful surgeon, his best friend.","genre_ids":[12,18,10752],"popularity":3.6584,"vote_count":3437,"poster_path":"/s1cVTQEZYn4nSjZLnFbzLP0j8y2.jpg","release_date":"2003-11-14","vote_average":7.181,"backdrop_path":"/zMHyNxNt4zhL939XX8QLBW3gWfu.jpg","original_title":"Master and Commander: The Far Side of the World","original_language":"en"},{"id":8643,"adult":false,"title":"The Exorcism of Emily Rose","video":false,"overview":"When a younger girl called Emily Rose dies, everyone puts blame on the exorcism which was performed on her by Father Moore prior to her death. The priest is arrested on suspicion of murder. The trial begins with lawyer Erin Bruner representing Moore, but it is not going to be easy, as no one wants to believe what Father Moore says is true.","genre_ids":[80,18,27,53],"popularity":3.4774,"vote_count":2988,"poster_path":"/qMN0HIP34f736kkQcfvTfmL9TP3.jpg","release_date":"2005-09-09","vote_average":6.602,"backdrop_path":"/eHT36hVNslbJXCY3SXgtzxPE3cl.jpg","original_title":"The Exorcism of Emily Rose","original_language":"en"}],"external_ids":{"imdb_id":"tt14961016","twitter_id":null,"facebook_id":null,"wikidata_id":"Q124262351","instagram_id":null,"metacritic_id":"movie/im-still-here-2024","mydramalist_id":"382268","rotten_tomatoes_id":"m/im_still_here_2024"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148269,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AE","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-05-30T00:00:00.000Z","certification":""}]},{"iso_3166_1":"AR","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-02-20T00:00:00.000Z","certification":""}]},{"iso_3166_1":"AT","release_dates":[{"note":"Vienna International Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2024-10-22T00:00:00.000Z","certification":""},{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-03-14T00:00:00.000Z","certification":""}]},{"iso_3166_1":"AU","release_dates":[{"note":"Brazilian Film Festival ","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-11-02T00:00:00.000Z","certification":""},{"note":"","type":3,"iso_639_1":"","descriptors"