:2668,"height":1500,"file_path":"/k8KbaWmr3deVZNzABgr6bPSp7D.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":2668,"height":1500,"file_path":"/q0pEDNEddMNxIOjiHdCpZXRIquQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0}]},"enriched_at":"2026-04-21T03:12:04.594+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"172 Days","runtime":103,"tagline":"","homepage":"","overview":"A young woman with a troubled past turns to religion as she seeks purpose in life — and a chance at finding true love."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"172 Dni","runtime":0,"tagline":"","homepage":"","overview":"Zira i Amer byli ze sobą przez 172 bardzo pamiętne dni. Los rozdzielił ich, Amer odszedł zbyt wcześnie, pozostawiając Zirze wiele miłych wspomnień."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"172 dana","runtime":0,"tagline":"","homepage":"","overview":"Zira i Amer proveli su zajedno 172 vrlo nezaboravna dana. Sudbina ih je rastavila, Amer je otišao prerano, ostavljajući Ziru s mnogo lijepih uspomena."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"172天","runtime":0,"tagline":"","homepage":"","overview":"齐拉与阿米尔曾共度了极为难忘的172个日夜。命运弄人，阿米尔过早地离去，给齐拉留下了诸多甜蜜回忆。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":967582,"adult":false,"title":"3 Days Max","video":false,"overview":"Clumsy policeman Rayane has three days to rescue his kidnapped grandmother from a Mexican cartel.","genre_ids":[35],"media_type":"movie","popularity":1.043,"vote_count":209,"poster_path":"/qIExh8vD4d5EzkXTGtnZHY1cw0m.jpg","release_date":"2023-10-25","vote_average":5.4,"backdrop_path":"/ytz80kMmyiZd4sJOcUeM8guYQKi.jpg","original_title":"3 jours max","original_language":"fr"},{"id":1267822,"adult":false,"title":"My Sunshine","video":false,"overview":"Two young skaters, polar opposites in personality, team up to train for an ice-dancing competition, their growing bond blurring the lines between partners and more as winter unfolds.","genre_ids":[18],"media_type":"movie","popularity":0.8261,"vote_count":41,"poster_path":"/qdBfHxQnaXifIatOpwX7IZvhsiK.jpg","release_date":"2024-09-06","vote_average":7.073,"backdrop_path":"/4dUlirtJJYodQq1x0raUp7N3XyR.jpg","original_title":"ぼくのお日さま","original_language":"ja"},{"id":919207,"adult":false,"title":"12.12: The Day","video":false,"overview":"After the assassination of President Park, martial law has been declared. A coup d'état bursts out by Defense Security Commander Chun Doo-gwang and a private band of officers following him. Capital Defense Commander Lee Tae-shin, an obstinate soldier who believes the military should not take political actions, fights against Chun Doo-gwang to stop him. The conflict between the two grows while military leaders are holding their decision and Defense Minister is gone. In the midst of chaos, the spring of Seoul that everyone longed for heads to unexpected direction.","genre_ids":[18,53,28,10752,36,80],"media_type":"movie","popularity":3.8366,"vote_count":143,"poster_path":"/vy14tKxsbJYdDyFl6kQuVkK2s44.jpg","release_date":"2023-11-22","vote_average":7.493,"backdrop_path":"/yOn8w3aGd6Rf9JYki7XaC9ZiyDg.jpg","original_title":"서울의 봄","original_language":"ko"},{"id":1175161,"adult":false,"title":"Agak Laen","video":false,"overview":"Four friends, working in a haunted house ride at a night market, unintentionally cause the death of an elderly man with heart disease through fright. They decide to bury his body within the haunted house, which turns out to be beneficial for the attraction... at least for a little while.","genre_ids":[35],"media_type":"movie","popularity":0.7587,"vote_count":28,"poster_path":"/lUOwyPbDD9Agl3pHQVHGbZE0TvI.jpg","release_date":"2024-02-01","vote_average":7.1,"backdrop_path":"/aMD179LsRq3oyFeAUSjij3dDtRX.jpg","original_title":"Agak Laen","original_language":"id"},{"id":1081620,"adult":false,"title":"The Weapon","video":false,"overview":"Dallas is a one-man killing machine on a mysterious rampage. His attacks on biker gangs and meth labs anger the Vegas mob boss who’s holding Dallas’ girlfriend hostage. But who is Dallas working for? Even torture won’t make him talk, and he won’t stop until justice is served.","genre_ids":[28],"media_type":"movie","popularity":0.787,"vote_count":41,"poster_path":"/slQYCDzCMM8SBh9Xa3aPeM2fekA.jpg","release_date":"2023-02-17","vote_average":4.9,"backdrop_path":"/i7nnmCTnjK50vNqbMfVtmoVULWJ.jpg","original_title":"The Weapon","original_language":"en"},{"id":592717,"adult":false,"title":"Hotel Belgrade","video":false,"overview":"Pasha, a Serbian womanizer and entertainer, owns a luxurious hotel in Belgrade. He lives carelessly until one day he accidentally breaks a mafia kingpin’s new collectable that is worth a few million. To cover the debt the mafia kingpin makes Pasha marry his daughter. While the girl is preparing to marry the charming hotelier, Pasha by chance meets his Russian love Dasha, who he has not seen for four years. Their love is about to flare up in the romantic atmosphere of the ancient city… if not for the future father-in-law, a real husband, a blind grandad, and a friend with no money.","genre_ids":[35,10749],"media_type":"movie","popularity":0.3617,"vote_count":44,"poster_path":"/A3bNX4gmaWTRMmRUDekWjm55iik.jpg","release_date":"2020-03-05","vote_average":6.593,"backdrop_path":"/lPw2nRM7r677zyowGA3znJIzBhj.jpg","original_title":"Отель «Белград»","original_language":"ru"},{"id":960762,"adult":false,"title":"DJS The Movie: Biarkan Aku Menari","video":false,"overview":"All his life Wulan, he only wanted to be a dancer. When his father, Lukman and his brother, Satria were still alive, they were the ones who always supported Wulan's ideals. But now they are dead, and Wulan lives only with her mother, Linda. Linda wants Wulan to succeed in her life, but she is worried about Wulan who likes to dance. For him dance is something serious. One day they are without an object, making Wulan go to the hills with Joko, her boyfriend who has been secretly hidden for so long. On their way home, they had a miraculous accident, leaving Wulan stranded in another world.","genre_ids":[18,10749,10402,14],"media_type":"movie","popularity":0.2104,"vote_count":2,"poster_path":"/hlDoOZbrCz4aTbLcoVop5ktTd4p.jpg","release_date":"2022-04-21","vote_average":6,"backdrop_path":null,"original_title":"DJS The Movie: Biarkan Aku Menari","original_language":"id"},{"id":532794,"adult":false,"title":"Sex Plate 17","video":false,"overview":"A woman who can make all of one man’s fantasies come true moves in next door .","genre_ids":[35,18,10749],"media_type":"movie","popularity":7.4199,"vote_count":12,"poster_path":"/4MFOBDKciazhjdE12Mm3aNirk4J.jpg","release_date":"2017-11-13","vote_average":6.1,"backdrop_path":"/58qsiLrXYXxSJl5CjeeF7fZbKZH.jpg","original_title":"성판17: 남자들의 17가지 성적 판타지","original_language":"ko"},{"id":37958,"adult":false,"title":"Immortals","video":false,"overview":"Theseus is a mortal man chosen by Zeus to lead the fight against the ruthless King Hyperion, who is on a rampage across Greece to obtain a weapon that can destroy humanity.","genre_ids":[14,28,18],"media_type":"movie","popularity":2.8083,"vote_count":2760,"poster_path":"/4SPPX5KIyaQ9O8n5rLvvUIiIhpF.jpg","release_date":"2011-11-10","vote_average":6.041,"backdrop_path":"/vbcUqIQZl7q7O2op2NT0ZqTLXxH.jpg","original_title":"Immortals","original_language":"en"},{"id":20982,"adult":false,"title":"Naruto Shippuden the Movie","video":false,"overview":"Demons that once almost destroyed the world, are revived by someone. To prevent the world from being destroyed, the demon has to be sealed and the only one who can do it is the shrine maiden Shion from the country of demons, who has two powers; one is sealing demons and the other is predicting the deaths of humans. This time Naruto's mission is to guard Shion, but she predicts Naruto's death. The only way to escape it, is to get away from Shion, which would leave her unguarded, then the demon, whose only goal is to kill Shion will do so, thus meaning the end of the world. Naruto decides to challenge this \"prediction of death.\"","genre_ids":[16,28,14],"media_type":"movie","popularity":6.0003,"vote_count":1051,"poster_path":"/vDkct38sSFSWJIATlfJw0l3QOIR.jpg","release_date":"2007-08-04","vote_average":7.408,"backdrop_path":"/p6Yh10E46lXpj45XvG9Mwc4HZNi.jpg","original_title":"劇場版 NARUTO -ナルト- 疾風伝","original_language":"ja"},{"id":533535,"adult":false,"title":"Deadpool & Wolverine","video":false,"overview":"A listless Wade Wilson toils away in civilian life with his days as the morally flexible mercenary, Deadpool, behind him. But when his homeworld faces an existential threat, Wade must reluctantly suit-up again with an even more reluctant Wolverine.","genre_ids":[28,35,878],"media_type":"movie","popularity":22.6059,"vote_count":8293,"poster_path":"/8cdWjvZQUExUUTzyp4t6EDMubfO.jpg","release_date":"2024-07-24","vote_average":7.557,"backdrop_path":"/ufpeVEM64uZHPpzzeiDNIAdaeOD.jpg","original_title":"Deadpool & Wolverine","original_language":"en"},{"id":693134,"adult":false,"title":"Dune: Part Two","video":false,"overview":"Follow the mythic journey of Paul Atreides as he unites with Chani and the Fremen while on a path of revenge against the conspirators who destroyed his family. Facing a choice between the love of his life and the fate of the known universe, Paul endeavors to prevent a terrible future only he can foresee.","genre_ids":[878,12],"media_type":"movie","popularity":22.2359,"vote_count":7552,"poster_path":"/1pdfLvkbY9ohJlCjQH2CZjjYVvJ.jpg","release_date":"2024-02-27","vote_average":8.13,"backdrop_path":"/ylkdrn23p3gQcHx7ukIfuy2CkTE.jpg","original_title":"Dune: Part Two","original_language":"en"},{"id":957452,"adult":false,"title":"The Crow","video":false,"overview":"Soulmates Eric and Shelly are brutally murdered when the demons of her dark past catch up with them. Given the chance to save his true love by sacrificing himself, Eric sets out to seek merciless revenge on their killers, traversing the worlds of the living and the dead to put the wrong things right.","genre_ids":[28,14,27],"media_type":"movie","popularity":5.0027,"vote_count":1213,"poster_path":"/g8TbOXrNMuqq7AaKqdvqS2oG4ob.jpg","release_date":"2024-08-21","vote_average":5.8,"backdrop_path":"/503LUrI9juBk1rktOPzxyMUTDEu.jpg","original_title":"The Crow","original_language":"en"},{"id":1140817,"adult":false,"title":"As","video":false,"overview":"Three years after the death of her beloved child, Elouise, Mara still feels her presence when she sits on the butterfly bedding in front of the jar with her ashes in it. Mara arranges a twelfth birthday party for Elouise, further alienating her from her husband, Richter, and remaining daughter, Hannah. Although Mara eventually vacates Elouise's room at the insistence of her husband, she does find a way to stay close to Elouise. Before long, however, Hannah discovers her mother's secret.","genre_ids":[],"media_type":"movie","popularity":0.1773,"vote_count":185,"poster_path":null,"release_date":"2023-01-01","vote_average":7.054,"backdrop_path":null,"original_title":"As","original_language":"en"},{"id":508947,"adult":false,"title":"Turning Red","video":false,"overview":"Thirteen-year-old Mei is experiencing the awkwardness of being a teenager with a twist – when she gets too excited, she transforms into a giant red panda.","genre_ids":[16,10751,35,14],"media_type":"movie","popularity":9.7641,"vote_count":5686,"poster_path":"/qsdjk9oAKSQMWs0Vt5Pyfh6O4GZ.jpg","release_date":"2022-03-10","vote_average":7.32,"backdrop_path":"/fOy2Jurz9k6RnJnMUMRDAgBwru2.jpg","original_title":"Turning Red","original_language":"en"},{"id":940721,"adult":false,"title":"Godzilla Minus One","video":false,"overview":"In postwar Japan, Godzilla brings new devastation to an already scorched landscape. With no military intervention or government help in sight, the survivors must join together in the face of despair and fight back against an unrelenting horror.","genre_ids":[878,27,28],"media_type":"movie","popularity":9.4979,"vote_count":3008,"poster_path":"/2E2WTX0TJEflAged6kzErwqX1kt.jpg","release_date":"2023-11-03","vote_average":7.579,"backdrop_path":"/1FMnXfgPFJFWhPrCZBgXwHbwmye.jpg","original_title":"ゴジラ-1.0","original_language":"ja"},{"id":1147400,"adult":false,"title":"Miraculous World: Paris, Tales of Shadybug and Claw Noir","video":false,"overview":"Miraculous holders from another world appear in Paris. They come from a parallel universe where everything is reversed: the holders of Ladybug and Black Cat Miraculouses, Shadybug and Claw Noir, are the bad guys, and the holder of the Butterfly Miraculous, Betterfly, is a superhero. Ladybug and Cat Noir will have to help Betterfly counter the attacks of their evil doubles and prevent them from seizing the Butterfly Miraculous. Can our heroes also help Betterfly make Shadybug and Claw Noir better people?","genre_ids":[16,10751,28,14],"media_type":"movie","popularity":3.7786,"vote_count":622,"poster_path":"/nydROKumZe9oFZNiSn792MDDA1v.jpg","release_date":"2023-10-21","vote_average":7.262,"backdrop_path":"/hU1Q9YVzdYhokr8a9gLywnSUMlN.jpg","original_title":"Miraculous World : Paris, Les Aventures de Toxinelle et Griffe Noire","original_language":"fr"},{"id":1216221,"adult":false,"title":"Demon Slayer: Kimetsu no Yaiba -To the Hashira Training-","video":true,"overview":"Tanjiro undergoes rigorous training with the Stone Hashira, Himejima, in his quest to become a Hashira. Meanwhile, Muzan continues to search for Nezuko and Ubuyashiki. A recap of Kimetsu no Yaiba episodes 55–56, with new footage and special end credits.","genre_ids":[28,16,14,53],"media_type":"movie","popularity":6.0875,"vote_count":481,"poster_path":"/3daOEMQCOGU2n9EbUC0PICnUCek.jpg","release_date":"2024-02-02","vote_average":6.516,"backdrop_path":"/9mrSx9MVmNOOlvcPxDTdf1APzud.jpg","original_title":"「鬼滅の刃」絆の奇跡、そして柱稽古へ","original_language":"ja"},{"id":1022789,"adult":false,"title":"Inside Out 2","video":false,"overview":"Teenager Riley's mind headquarters is undergoing a sudden demolition to make room for something entirely unexpected: new Emotions! Joy, Sadness, Anger, Fear and Disgust, who’ve long been running a successful operation by all accounts, aren’t sure how to feel when Anxiety shows up. And it looks like she’s not alone.","genre_ids":[16,12,35,10751],"media_type":"movie","popularity":19.7012,"vote_count":6476,"poster_path":"/vpnVM9B6NMmQpWeZvzLvDESb2QY.jpg","release_date":"2024-06-11","vote_average":7.547,"backdrop_path":"/p5ozvmdgsmbWe0H8Xk7Rc8SCwAB.jpg","original_title":"Inside Out 2","original_language":"en"},{"id":1022796,"adult":false,"title":"Wish","video":false,"overview":"Asha, a sharp-witted idealist, makes a wish so powerful that it is answered by a cosmic force – a little ball of boundless energy called Star. Together, Asha and Star confront a most formidable foe - the ruler of Rosas, King Magnifico - to save her community and prove that when the will of one courageous human connects with the magic of the stars, wondrous things can happen.","genre_ids":[16,10751,14,12],"media_type":"movie","popularity":6.5368,"vote_count":1735,"poster_path":"/nesuSdJakNkf0zs7OfoasB6Clxf.jpg","release_date":"2023-11-13","vote_average":6.2,"backdrop_path":"/ehumsuIBbgAe1hg343oszCLrAfI.jpg","original_title":"Wish","original_language":"en"}],"similar_content":[{"id":1058435,"adult":false,"title":"The Blue Whale","video":false,"overview":"The film revolves around the \"Blue Whale Challenge\" game used by many young people and adolescents, after the spread of technology and the parents are too busy to look after their children which might lead to their exposure to great risks.","genre_ids":[18,53,27],"popularity":0.3732,"vote_count":0,"poster_path":"/pZEeURRtkuUTVe5mevPzLbugGRF.jpg","release_date":"2020-08-26","vote_average":0,"backdrop_path":"/e15IvvWX3dl8zTYiaK535ylCz7Q.jpg","original_title":"الحوت الأزرق","original_language":"ar"},{"id":462824,"adult":false,"title":"Jack Kerouac's Road: A Franco-American Odyssey","video":false,"overview":"Part documentary, part drama, this film presents the life and work of Jack Kerouac, an American writer with Québec roots who became one of the most important spokesmen for his generation. Intercut with archival footage, photographs and interviews, this film takes apart the heroic myth and even returns to the childhood of the author whose life and work contributed greatly to the cultural, sexual and social revolution of the 1960s.","genre_ids":[18,99],"popularity":0.136,"vote_count":1,"poster_path":"/8j5ATlmngqvYwJla20vzUDB7hhw.jpg","release_date":"1987-03-01","vote_average":8,"backdrop_path":"/hsQ4QbsXgANCTOCypKWJHpvNYb.jpg","original_title":"Le Grand Jack","original_language":"fr"},{"id":27,"adult":false,"title":"9 Songs","video":false,"overview":"Matt, a young glaciologist, soars across the vast, silent, icebound immensities of the South Pole as he recalls his love affair with Lisa. They meet at a mobbed rock concert in a vast music hall - London's Brixton Academy. They are in bed at night's end. Together, over a period of several months, they pursue a mutual sexual passion whose inevitable stages unfold in counterpoint to nine live-concert songs.","genre_ids":[18,10402,10749],"popularity":8.0872,"vote_count":564,"poster_path":"/91O7z0vo7MiNWd5xD2BoivwbQsb.jpg","release_date":"2004-07-16","vote_average":5.533,"backdrop_path":"/qU7tNIMpRqkizIObXfkJY3haTqh.jpg","original_title":"9 Songs","original_language":"en"},{"id":28,"adult":false,"title":"Apocalypse Now","video":false,"overview":"At the height of the Vietnam war, Captain Benjamin Willard is sent on a dangerous mission that, officially, \"does not exist, nor will it ever exist.\" His goal is to locate - and eliminate - a mysterious Green Beret Colonel named Walter Kurtz, who has been leading his personal army on illegal guerrilla missions into enemy territory.","genre_ids":[18,10752],"popularity":11.5037,"vote_count":8898,"poster_path":"/gQB8Y5RCMkv2zwzFHbUJX3kAhvA.jpg","release_date":"1979-05-19","vote_average":8.267,"backdrop_path":"/eN5G8vTWLnZxJ0LTd4g27oPObcZ.jpg","original_title":"Apocalypse Now","original_language":"en"},{"id":38,"adult":false,"title":"Eternal Sunshine of the Spotless Mind","video":false,"overview":"Joel Barish, heartbroken that his girlfriend underwent a procedure to erase him from her memory, decides to do the same. However, as he watches his memories of her fade away, he realises that he still loves her, and may be too late to correct his mistake.","genre_ids":[878,18,10749],"popularity":11.7483,"vote_count":16052,"poster_path":"/5MwkWH9tYHv3mV9OdYTMR5qreIz.jpg","release_date":"2004-03-19","vote_average":8.091,"backdrop_path":"/jzZcW65MZQfAgvbEoX8EWCvlxpk.jpg","original_title":"Eternal Sunshine of the Spotless Mind","original_language":"en"},{"id":66,"adult":false,"title":"Absolute Power","video":false,"overview":"A master thief coincidentally is robbing a house where a murder—in which the President of the United States is involved—occurs in front of his eyes. He is forced to run, while holding evidence that could convict the President.","genre_ids":[80,18,28],"popularity":2.2658,"vote_count":1203,"poster_path":"/izvyt3cxlilhbYwybTOteDWqf99.jpg","release_date":"1997-02-14","vote_average":6.658,"backdrop_path":"/cLftTzGw40BlLw8IggKSWDjKOQo.jpg","original_title":"Absolute Power","original_language":"en"},{"id":854356,"adult":false,"title":"Disobedience","video":false,"overview":"A university student wants to avenge his sister from a businessman who abandoned her after leaving her pregnant. To do this, he decides to seduce the man’s sister to make him suffer the same fate.","genre_ids":[18],"popularity":0.2122,"vote_count":0,"poster_path":"/83yPN3iBey7Xcl5mD5d9yhq6YfV.jpg","release_date":"1958-12-14","vote_average":0,"backdrop_path":null,"original_title":"親不孝通り","original_language":"ja"},{"id":854152,"adult":false,"title":"Inubu: The Dog Club","video":false,"overview":"Hanai Sota is 22-years-old and a university student in the veterinary department. Since he was little, he has always loved animals. His apartment is full of animals that needed help. One day, Hanai Sota saves a dog that was being used in experiments. To save more of the animals, he sets up the \"Inubu\" club. His friend Shibasaki Ryosuke, among other people, joins the group. Shibasaki Ryosuke also loves dogs and is a student in the same veterinary department as Hanai Sota. They work hard to protect the animals. 16 years later, a report comes out. The report is about Hanai Sota, who was arrested.","genre_ids":[18,10751],"popularity":0.4494,"vote_count":4,"poster_path":"/982Vb7oAw6CWacnKbDjzan7QKIU.jpg","release_date":"2021-07-22","vote_average":6.75,"backdrop_path":"/nvOrS60C5x3pL4aAY5hlT7S6jY7.jpg","original_title":"犬部！","original_language":"ja"},{"id":15,"adult":false,"title":"Citizen Kane","video":false,"overview":"Newspaper magnate Charles Foster Kane is taken from his mother as a boy and made the ward of a rich industrialist. As a result, every well-meaning, tyrannical or self-destructive move he makes for the rest of his life appears in some way to be a reaction to that deeply wounding event.","genre_ids":[9648,18],"popularity":5.4972,"vote_count":5937,"poster_path":"/sav0jxhqiH0bPr2vZFU0Kjt2nZL.jpg","release_date":"1941-04-17","vote_average":7.98,"backdrop_path":"/9Y85oA1y6toL2OACXdaC6iTl7eQ.jpg","original_title":"Citizen Kane","original_language":"en"},{"id":19,"adult":false,"title":"Metropolis","video":false,"overview":"In a futuristic city sharply divided between the rich and the poor, the son of the city's mastermind meets a prophet who predicts the coming of a savior to mediate their differences.","genre_ids":[18,878],"popularity":3.2252,"vote_count":3040,"poster_path":"/kr9wXRN23zLuWJIelahas1mtnYj.jpg","release_date":"1927-01-10","vote_average":8.095,"backdrop_path":"/eeMoFKxjjiCi6iep2GEZtSAMYIr.jpg","original_title":"Metropolis","original_language":"de"},{"id":854239,"adult":false,"title":"Till","video":false,"overview":"The true story of Mamie Till Mobley’s relentless pursuit of justice for her 14 year old son, Emmett Till, who, in 1955, was lynched while visiting his cousins in Mississippi.","genre_ids":[18,36],"popularity":2.7651,"vote_count":322,"poster_path":"/cmDs0CYlgioyP2AQQTTmavt3uoO.jpg","release_date":"2022-10-14","vote_average":7.29,"backdrop_path":"/xFKjWcxEumvwEhovqTDzoDCmD45.jpg","original_title":"Till","original_language":"en"},{"id":274428,"adult":false,"title":"Moment of Truth: A Child Too Many","video":false,"overview":"Patty Nowakowski already has three children, but decides to be a surrogate mother. Fully confident of being able to give up her baby, she is nonetheless stunned when she discovers that she is expecting twins, and the couple for whom she is pregnant will only accept one child, provided it is female.","genre_ids":[18,10770],"popularity":0.1467,"vote_count":7,"poster_path":null,"release_date":"1993-10-11","vote_average":5.6,"backdrop_path":null,"original_title":"Moment of Truth: A Child Too Many","original_language":"en"},{"id":858024,"adult":false,"title":"Hamnet","video":false,"overview":"The powerful story of love and loss that inspired the creation of Shakespeare's timeless masterpiece, Hamlet.","genre_ids":[18,10749,36],"popularity":68.9666,"vote_count":736,"poster_path":"/vbeyOZm2bvBXcbgPD3v6o94epPX.jpg","release_date":"2025-11-26","vote_average":7.721,"backdrop_path":"/73BClq9FOcrWrutnpiqhCNEWEwJ.jpg","original_title":"Hamnet","original_language":"en"},{"id":3112,"adult":false,"title":"The Night of the Hunter","video":false,"overview":"In Depression-era West Virginia, a serial-killing preacher hunts two young children who know the whereabouts of a stash of money.","genre_ids":[80,18,53],"popularity":3.3213,"vote_count":1781,"poster_path":"/rBka0nFWiHxabHRLr0KfIA8Yiaq.jpg","release_date":"1955-07-26","vote_average":7.863,"backdrop_path":"/ngh5pnvXPceZYdeKZqO4OYS9VHF.jpg","original_title":"The Night of the Hunter","original_language":"en"},{"id":3116,"adult":false,"title":"Midnight Cowboy","video":false,"overview":"Joe Buck is a wide-eyed hustler from Texas hoping to score big with wealthy New York City women; he finds a companion in Enrico \"Ratso\" Rizzo, an ailing swindler with a bum leg and a quixotic fantasy of escaping to Florida.","genre_ids":[18],"popularity":2.6772,"vote_count":1551,"poster_path":"/ckklq45UxUkwgHve9xItXqXr06r.jpg","release_date":"1969-05-25","vote_average":7.5,"backdrop_path":"/pEdb6DfEBgaXF7S0EHzqnJvTGex.jpg","original_title":"Midnight Cowboy","original_language":"en"},{"id":3133,"adult":false,"title":"Badlands","video":false,"overview":"An impressionable teenage girl from a dead-end town and her older greaser boyfriend embark on a killing spree in the South Dakota badlands.","genre_ids":[80,18,10749],"popularity":3.4184,"vote_count":1308,"poster_path":"/z81rBzHNgiNLean2JTGHgxjJ8nq.jpg","release_date":"1974-01-05","vote_average":7.471,"backdrop_path":"/5rp9Jydh9RxrvVBW2lr27B8NYiT.jpg","original_title":"Badlands","original_language":"en"},{"id":858082,"adult":false,"title":"Ponniyin Selvan: Part II","video":false,"overview":"968 AD. The Pandyan assassins gather once again to destroy the Chola dynasty. Now the mighty Chola princes must fight the Pandyas, the Rashtrakutas and other Chola enemies who have joined forces. Also, at play are the rumours of Ponniyin Selvan’s death at sea, the powerful Pazhuvettarayar’s betrayal, and the tragic destiny of Aditha Karikalan, whose heart was long lost to the vengeful Nandini.","genre_ids":[28,12,36,18],"popularity":0.7726,"vote_count":60,"poster_path":"/1fMM5yjLYJNfO3CSQBpfC1kqeIK.jpg","release_date":"2023-04-28","vote_average":6.217,"backdrop_path":"/dWwcwqAOkS6e4GCRJ5fC9iSVx9O.jpg","original_title":"பொன்னியின் செல்வன்: பாகம் 2","original_language":"ta"},{"id":3033,"adult":false,"title":"Gods and Monsters","video":false,"overview":"It's 1957, and James Whale's heyday as the director of \"Frankenstein,\" \"Bride of Frankenstein\" and \"The Invisible Man\" is long behind him. Retired and a semi-recluse, he lives his days accompanied only by images from his past. When his dour housekeeper, Hannah, hires a handsome young gardener, the flamboyant director and simple yard man develop an unlikely friendship, which will change them forever.","genre_ids":[18],"popularity":0.955,"vote_count":382,"poster_path":"/awvJH3NtXoStsjAtXKr99hfuVaG.jpg","release_date":"1998-09-12","vote_average":6.933,"backdrop_path":"/v1HOjtXoGwQz26fT4elHeNT0JnW.jpg","original_title":"Gods and Monsters","original_language":"en"},{"id":3035,"adult":false,"title":"Frankenstein","video":false,"overview":"Henry Frankenstein pieces together body parts in the hope of bringing a human-like creature to life. The mad scientist’s dreams are shattered by his monstrous creation awakening with rage to a world that hates and fears him.","genre_ids":[18,27,878],"popularity":2.8172,"vote_count":1759,"poster_path":"/mu6wHwH0IwCCaEYtpqujuPJYat1.jpg","release_date":"1931-11-21","vote_average":7.5,"backdrop_path":"/wFbPbJ9uRDpjY7micBTeolgkOA4.jpg","original_title":"Frankenstein","original_language":"en"},{"id":3055,"adult":false,"title":"Valley of the Dolls","video":false,"overview":"Lured by their dreams of fame and fortune, three ambitious young women enter the world of show business and discover how easy it is to sink into a celebrity nightmare of ego, alcohol and pills — the beloved \"dolls.\"","genre_ids":[18,10749],"popularity":1.1686,"vote_count":137,"poster_path":"/hQgsWkNTL8GJloJRzqonImIaIJb.jpg","release_date":"1967-12-27","vote_average":6,"backdrop_path":"/43kxj1gcewWJNlzqGmPkZXE3fek.jpg","original_title":"Valley of the Doll