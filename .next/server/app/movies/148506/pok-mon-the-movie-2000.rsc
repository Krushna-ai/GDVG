_average":3.334},{"width":1920,"height":1080,"file_path":"/giKFmoYiIBWWWZuhpRCtlTf55Ks.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/6G1MjNiIygazcZnIhgsndexwWAV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":2.542},{"width":3840,"height":2160,"file_path":"/8ZIJko7649bYIbYJcQiuolbWcpq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":2.542},{"width":1920,"height":1080,"file_path":"/qkt3dbIBkgy3vGJeGqeQ2vPUbDa.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":2.278},{"width":1920,"height":1080,"file_path":"/vVyY60DeLc0GJ3Xz5mylRlhL4Qi.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":2.278},{"width":1920,"height":1080,"file_path":"/jGkaLc5PLH3lzFLaZBfX8tPIrGw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":2732,"height":1536,"file_path":"/aPLlJoWLMUa3GqXtgnYL4t25aIg.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":1,"aspect_ratio":1.779,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/hij1TALhABQk2edGgRpW7LlBy03.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/mOSwnNmVhiuukUtSSFph5YLgTMd.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/nIOTaTrQQYbZWF6jRAZLgiMxtZx.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/jQid5RrCRVTDp5hhbrU1eN19eLE.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/7xqiBskR5BvlDvWrS0tFziT5Aw1.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/hWO0sqIAba7rOfG3LcKSeXG0mKH.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:47:49.117+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Pokémon the Movie 2000","runtime":84,"tagline":"One person can make all the difference.","homepage":"https://www.warnerbros.com/movies/pokemon-movie-2000","overview":"When Lawrence III's scheme to capture the Legendary Pokémon Lugia upsets the balance of nature, it is up to Ash Ketchum and his friends to save the world."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Pokémon 2: Die Macht des Einzelnen","runtime":84,"tagline":"","homepage":"","overview":"Aus dem Jahre 2000 stammende Fortsetzung des Anime-Erfolgs. Im zweiten Teil will der Pokémon-Sammler Lawrence III drei Pokémon-Vögel fangen, um so das Gleichgewicht der Natur zu verändern. Ash muss nun seine Kräfte testen. Doch kann er es mit dem Sammler aufnehmen? Und wird es ihm gelingen die Welt zu retten?"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Pokémon 2 - La forza di uno","runtime":84,"tagline":"Una persona può fare la differenza.","homepage":"","overview":"Un collezionista di Pokémon, Lawrence III, decide di catturare il Pokémon leggendario Lugia intrappolandolo nella sua nave da guerra volante. Per svolgere la sua missione deve prima catturare i tre uccelli leggendari: Articuno, Zapdos e Moltres. Inizia proprio da quest'ultimo, disturbando l'equilibrio meteorologico del pianeta.  A causa dell'imprigionamento del Pokémon di Fuoco, Ash, Misty e Tracey, in viaggio attraverso le Isole Orange, sono costretti a causa del maltempo a rifugiarsi sull'isola Shamuti, proprio nel giorno dedicato ad una tradizionale cerimonia del luogo."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Pokémon 2: Ensam är stark","runtime":0,"tagline":"En person kan göra hela skillnaden","homepage":"","overview":"Pokémontränaren Ash Ketchum och hans vänner Misty (Vatten-Pokémontränare) och Tracy (Pokémon-skådare) är ute på en båttur, men råkar ut för en storm som för dem till De Orangea Öarna (The Orange Islands). Där får de veta att en profetia har slagit in, och att världen hotas att bli översvämmad av en jättevåg. Bara \"Den Utvalde\" kan stoppa profetian från att slå in, och det visar sig vara Ash som är den utvalde.  För att rädda världen från undergång måste Ash samla på sig tre klot från tre olika öar (Eldön, Blixtön och Isön), för att sedan förena dessa i ett tempel på den stora ön som ligger i samband med de tre övriga."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Pokémon 2 : Le pouvoir est en toi","runtime":76,"tagline":"","homepage":"","overview":"Dans l'Archipel Orange situé tout au sud de Kanto, le Dresseur Gelardan a un plan sinistre : attraper les Pokémon légendaires Artikodin, Électhor et Sulfura dans le but de réveiller Lugia, le gardien des abysses… Lorsque Sacha et ses amis arrivent, les habitants de l'archipel lui demandent de partir à la recherche de 3 sphères élémentaires issues de différentes îles. Alors que le climat est extrêmement perturbé dans le monde entier, il devient évident que la capture du trio légendaire a déséquilibré la planète. Avec l'aide de Lugia, Sacha pourra-t-il trouver les sphères sacrées, rétablir l'équilibre originel et devenir l'Élu tant attendu par tous ?"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Pokémon 2: El poder de uno","runtime":80,"tagline":"Hay alguien que marca la diferencia","homepage":"","overview":"Segunda entrega del famoso videojuego japonés. Ash Ketchum, Pokémon y sus amigos llegan a la isla de Shamouti, y allí se transformarán en los protagonistas de una leyenda reencarnada; el equilibrio de la naturaleza representado por las tres poderosas aves Moltres (que domina el fuego), Zapdos (que representa los relámpagos) y Articuno (que conserva el hielo). Cuando Moltres resulta secuestrada según la profecía sólo un humano podrá salvarla."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Pokémon 2. - Bízz az erõben!","runtime":0,"tagline":"","homepage":"","overview":"Ash Ketchum és színes társasága ismét nagy próbatétel elõtt áll. Lawrence III, a repülõ gépezetén száguldozó kapzsi Pokémon-gyűjtõ káoszt teremt a Világegyetemben azzal, hogy felbontja a természet egyensúlyát. Elrabolja a három Pokémon madarat, (Moltres, Zapdos és Articuno) amely a tüzet, villámot és a jeget uralja. Hamarosan Lugia, a tengeri Pokémon is a gonosz áldozatává válik. Ash, Misty és a többiek gyorsan akcióba lépnek, hogy megakadályozzák a teljes pusztulást... A Pokémonok második egész estés filmje is kalandos perceket szerez a rajongók táborának."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Pokémon 2: de film - Op eigen kracht","runtime":0,"tagline":"","homepage":"","overview":"Een oude voorspelling komt uit als de Pokémon Articuno, Zapdos en Moltres na eeuwen van harmonie worden verstoord. De natuurelementen raken uit hun evenwicht en het leven op aarde hangt af van de onwaarschijnlijke samenwerking tussen de mythische Pokémon Lugia en een mysterieuze 'uitverkorene' waarvan in de legende sprake is."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"פוקימון 2000: כוחו של אחד","runtime":0,"tagline":"אדם אחד יכול לעשות את ההבדל.","homepage":"","overview":"אספן פוקימונים רשע בשם\" לורנס השלישי\" יוצא אל איי התפוז ללכוד את שלושת הפוקימונים מולטרס, זאפדוס וארטיקנו כדי למשוך מהים את הפוקימון השומר, לוגיה. מעשה זה גורם לשרשרת אסונות טבע בכל העולם, מה שלא מזיז לאספן. אש, מיסטי וברוק מגיעים לאיי התפוז והמקומיים מבקשים מאש להשתתף בפסטיבל האגדות הפולחני שלהם. על אש לאסוף שלושה כדורי זכוכית ממקומות שונים. אם יצליח, יוכל לסכל את מזימתו של לורנס, לרכוב על לוגיה ולהציל את העולם."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Pokémon: Filmen 2000","runtime":0,"tagline":"","homepage":"","overview":"Ash Ketchum må sætte sine evner på prøve, når han forsøger at redde verden fra undergang. Den Greedy Pokemon samler Lawrence III kaster universet i kaos efter at forstyrre balancen i naturen ved at erobre en af ​​de Pokemon fugle, der udgør de elementer af ild, lyn og is. Vil Ash har hvad det kræver at redde verden?"},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Pokémon 2: Síla jednotlivce","runtime":0,"tagline":"Jen jedna osoba může všechno změnit!","homepage":"","overview":"Připravte se na nezapomenutelná dobrodružství zcela nových Pokémonů! Starodávná pověst se naplní, když jsou Pokémoni Articuno, Zapdos a Moltres vyrušeni ze staleté harmonie. Když jsou narušeny samy síly přírody, závisí život na zemi na nečekané spolupráci legendárního Pokémona Kugia a mystického vyvoleného jenž byl předpovězen legendou. Dokáže Ash Ketchum sebrat odvahu, aby zachránil svět? Podívejte se, jak může jeden hrdina zcela změnit situaci."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Pokémon: O Filme 2000 - O Poder de Um","runtime":80,"tagline":"Uma Pessoa Pode Fazer a Diferença.","homepage":"","overview":"Ash, treinador de pokémon, e seus companheiros têm a difícil tarefa de restaurar o equilíbrio das forças naturais na Terra para impedir que uma grande catástrofe aconteça. Para isso, precisam recuperar três pokémon que estão nas mãos de um vilão."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Πόκεμον 2: Η δύναμη του ενός","runtime":0,"tagline":"","homepage":"","overview":"Ο Ας πρέπει να εμποδίσει έναν ασυνείδητο συλλέκτη πόκεμον να συλλάβει τρία μυθικά πουλιά που διατηρούν την ισορροπία της φύσης πάνω στη Γη, ελέγχοντας τη φωτιά, τον κεραυνό και τον πάγο."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Pokémon 2: En Güçlü O","runtime":77,"tagline":"Bir Tek Kişi Tüm Farkı Yaratabilir!","homepage":"","overview":"Lawrence, yakayabildiği pokemonları koleksiyonuna katan bir çocuktur. En büyük hayali denizlerin efsane pokemonlarından biri olan Lugia'yı yakalayıp koleksiyonuna katmaktır. Zira bu şekilde dünyanın en iyi pokemon terbiyecisi olabilecektir. Lugia, diğer hiçbir pokemona benzememektedir. Hem çok güçlüdür hem de tektir. Onun yok olması, tüm pokemonların sonu olabilir. Ash ve arkadaşları bir an önce Lawrence'ı ve onun hırsını engellemek durumundadırlar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Pokémon 2 : Le Pouvoir Est En Toi","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Pokémon la película 2000","runtime":0,"tagline":"","homepage":"","overview":"Ash Ketchum debe reunir las tres esferas de fuego, hielo y relámpago para devolver el equilibrio a las Islas Naranja."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Pokémon 2: Yhden voimalla","runtime":80,"tagline":"","homepage":"","overview":""},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"宝可梦：梦幻的宝可梦 洛奇亚爆诞","runtime":82,"tagline":"","homepage":"","overview":"在橘子群岛一带旅行的小智等人，某日在乘船时意外被暴风雨吹至当中的一个岛屿-亚西亚岛，当地适逢庆典，他们结识少女芙芦拉等居民，并得知流传岛上的古老传说。 就在同时，贪婪的收藏家吉尔露太，为了满足自己的收藏欲望，捕捉了传说中神圣不可侵犯的的火焰鸟与闪电鸟，甚至想进一步捕捉急冻鸟，以引出传说中的海之神-洛奇亚，致使传说成真，各处气候变异、关都，城都地区步向毁灭，小智决定挺身而出前往化解危机...."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":81,"tagline":"命をかけて、かかってこい!!","homepage":"https://www.pokemon.co.jp/tv_movie/movie/1999","overview":"オレンジ諸島の旅を続けるサトシたちの船が突然の嵐で流され、アーシア島に漂流する。お祭りで賑わうその島で、サトシは島の少女・フルーラに祭りの行事である\"すぐれたあやつり人\"の役目をおわされた。その頃、世界中の珍しい物を集める謎のコレクター、ジラルダンが、海の神と呼ばれる幻のポケモン、ルギアを手に入れようと画策していた・・・"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Покемон 2000","runtime":0,"tagline":"","homepage":"","overview":"Древние предсказания сбываются, когда покемоны Артикуно, Запдос и Молтрес потревожены после веков гармонии. Нарушен баланс природных сил, жизнь на Земле зависит от того, смогут ли мифический покемон Луджия и таинственный «избранный» объединить свои усилия, как это предсказано в легенде. Сможет ли Эш Кетчам набраться смелости и спасти положение?"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"극장판 포켓몬스터: 루기아의 탄생","runtime":0,"tagline":"","homepage":"","overview":"오렌지제도를 여행하던 지우 일행.  그들 앞에 의문의 수집가 「라단」이 나타나 불의 신이라고 불리는 「특별한 파이어」를 붙잡아 버린다.  그것이 원인이 되어 자연계의 균형은 망가지고, 세계에는 천재지변이 일어나기 시작한다.  지우 일행은 세계를 구할 수 있을 것인가...  그리고 이 순간에 나타난 환상의 포켓몬 「루기아」는 과연 적인가 아군인가?!"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Pokemon Filmen 2: Den enes kraft","runtime":0,"tagline":"Pokémon: Den enes kraft","homepage":"","overview":""},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"神奇寶貝劇場版：夢幻之神奇寶貝 洛奇亞爆誕","runtime":0,"tagline":"","homepage":"","overview":"在橘子群島一帶旅行的小智等人，某日在乘船時意外被暴風雨吹至當中的一個島嶼-亞西亞島，當地適逢慶典，他們結識少女芙蘆拉等居民，並得知流傳島上的古老傳說。 就在同時，貪婪的收藏家吉爾露太，為了滿足自己的收藏慾望，捕捉了傳說中神聖不可侵犯的的火焰鳥與閃電鳥，甚至想進一步捕捉急凍鳥，以引出傳說中的海之神-洛奇亞，致使傳說成真，各處氣候變異、關都，城都地區步向毀滅，小智決定挺身而出前往化解危機...."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Pokémon 2: Uwierz w swoją siłę","runtime":0,"tagline":"Jeden człowiek może zmienić wszystko","homepage":"","overview":"Ash wraz z przyjaciółmi próbuje powstrzymać złego kolekcjonera pokemonów, który chce zawładnąć światem."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Pokémon 2: Sila jednotlivca","runtime":0,"tagline":"","homepage":"","overview":"Starodávna povesť sa naplní, keď sú Pokémoni Articuno, Zapdos a Moltres vyrušení zo stáročnej harmónie. Keď sú narušené samotné sily prírody, závisí život na zemi od nečakanej spolupráce legendárneho Pokémona Lugia a mystického vyvoleného, ktorý bol predpovedaný legendou. Dokáže Ash Ketchum nabrať odvahu na to, aby zachránil svet?"},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Pokémon 2 - O Poder Único","runtime":77,"tagline":"Uma Pessoa Pode Fazer Toda a Diferença.","homepage":"","overview":"Uma lenda antiga torna-se realidade quando os Pokémons Articuno, Zapdos e Moltres são perturbados depois de séculos de harmonia. À medida que as forças da natureza começam a ficar desequilibradas, a vida na Terra depende apenas do improvável trabalho de equipa do mítico Pokémon Lugia e um misterioso \"escolhido\", anunciado na lenda. Conseguirá Ash Ketchum reunir a coragem e força para salvar o mundo?"},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"โปเกมอน เดอะมูฟวี่ ตอน ลูเกีย จ้าวแห่งทะเลลึก","runtime":0,"tagline":"","homepage":"","overview":"ซาโตชิ พิคาชู และเหล่าผองเพื่อนได้ออกเดินทางไปยังดินแดนแห่งหนึ่งซึ่งถูกปกคลุมไปถ้วยอำนาจมืดพวกเขาจึงต้องช่วยกันนำลูกแก้วจากภูเขาสามแห่งกลับมายังดินแดนแห่งนึ้เพื่อสลายพลังอำนาจชั่วร้ายซึ่งพวกเขาต้องเผชิญหน้ากับเหล่าโปเกมอนวิหคที่มากด้วยพละกำลังมหาศาล แต่การต่อสู่กลับปลุกลูเกีย โปเกมอนแห่งท้องทะเลลึก ให้ตื่นขึ้น และช่วยปกป้องพวกซาโตชิ ให้นำลูกแก้วกลับมาอย่างปลอดภัย ..."},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Pokémon: Sự bùng nổ của Lugia huyền thoại","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"寵物小精靈劇場版：夢夢之寵物小精靈 利基亞爆誕","runtime":84,"tagline":"","homepage":"","overview":"在橘子群島一帶旅行的小智等人，某日在乘船時意外被暴風雨吹至當中的一個島嶼 - 亞西亞島，當地適逢慶典，他們結識少女芙蘆拉等居民，並得知流傳島上的古老傳説。\r 就在同時，貪婪的收藏家吉爾露太，為了滿足自己的收藏慾望，捕捉了傳説中神聖不可侵犯的的火鳥與雷鳥，甚至想進一步捕捉急凍鳥，以引出傳説中的海之神 - 利基亞，致使傳説成真，各處氣候變異、關都，城都地區步向毀滅，小智決定挺身而出前往化解危機. . . ."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Pokémon 2","runtime":0,"tagline":"","homepage":"","overview":"Nú reynir virkilega á hæfileika Ash Ketchum; hann þarf að bjarga Jörðinni frá gereyðingu. Hinn gráðugi Pokemon safnari Lawrence III setur allt á annan endann í alheiminum þegar hann riðlar jafnvægi náttúrunnar með því að taka til fanga einn af Pokemon fuglunum sem stjórna kröftunum eldi, eldingum og ís. Mun Ash ná að bjarga heiminum?"},"name":"Íslenska","iso_639_1":"is","iso_3166_1":"IS","english_name":"Icelandic"}],"reviews_tmdb":[],"recommendations":[{"id":10228,"adult":false,"title":"Pokémon: The First Movie","video":false,"overview":"Determined to prove its superiority, a bio-engineered Pokémon called Mewtwo lures Ash, Pikachu and others into a Pokemon match like none before.","genre_ids":[16,10751,12,14,28],"media_type":"movie","popularity":5.2989,"vote_count":1550,"poster_path":"/xPW3AeK3iQi1Zd9dCbdNLijE48o.jpg","release_date":"1998-07-18","vote_average":6.946,"backdrop_path":"/eA0qc5ihjSKG05tdJO4QPgYPAwY.jpg","original_title":"劇場版ポケットモンスター ミュウツーの逆襲","original_language":"ja"},{"id":10991,"adult":false,"title":"Pokémon 3: The Movie","video":false,"overview":"When the sadness of her father's disappearance gets to Molly Hale, she unknowingly uses the Unown to create her own dream world along with Entei, who she believes to be her father. When Entei kidnaps Ash's mother, Ash — alongside Misty and Brock — invade the mansion looking for his mom and trying to stop the mysteries of Molly's Dream World and Entei!","genre_ids":[12,14,16,28,10751],"media_type":"movie","popularity":3.1028,"vote_count":671,"poster_path":"/hrBWiMWnD7mheMx846ycUWA3ohs.jpg","release_date":"2000-07-08","vote_average":6.529,"backdrop_path":"/dLGQo5Xq6H18vPx00Czot8VHi3K.jpg","original_title":"劇場版ポケットモンスター 結晶塔の帝王 ENTEI","original_language":"ja"},{"id":12600,"adult":false,"title":"Pokémon 4Ever","video":false,"overview":"In order to escape a greedy Pokémon hunter, Celebi must use the last of its energy to travel through time to the present day. Celebi brings along Sammy, a boy who had been trying to protect it. Along with Ash, Pikachu, and the rest of the gang, Sammy and Celebi must encounter an enemy far more advanced than the hunter, with the fate of the forest hanging in the balance.","genre_ids":[12,14,16,878,10751],"media_type":"movie","popularity":3.1997,"vote_count":449,"poster_path":"/thz83PS9twtVBEEAM59J1bh75nU.jpg","release_date":"2001-07-06","vote_average":6.468,"backdrop_path":"/lnwNzJdU4gMlgoQlaT8HgSI2OpD.jpg","original_title":"劇場版ポケットモンスター セレビィ 時を超えた遭遇","original_language":"ja"},{"id":137773,"adult":false,"title":"Pokémon: The Mastermind of Mirage Pokémon","video":false,"overview":"The story of \"The Mastermind of Mirage Pokémon\" centers on a Pokémon scientist who has developed a new Mirage System to resurrect extinct Pokémon. Satoshi, Haruka, Masato, and Takeshi show up at the Mirage Mansion for a demonstration of this new machine, only to witness the kidnapping of the scientist! Then a mysterious stranger appears and claims that the machine can actually create Pokémon without weaknesses. It’s up to Satoshi and company to preserve the natural balance of the Pokémon world.","genre_ids":[10770,16,28,12],"media_type":"movie","popularity":1.3254,"vote_count":58,"poster_path":"/hJU76t41sf5BoKVHT3L3TtQP9xs.jpg","release_date":"2006-04-29","vote_average":6.8,"backdrop_path":"/isnRO0gqBRSaUJyBULOQSZ8T6nU.jpg","original_title":"戦慄のミラージュポケモン","original_language":"ja"},{"id":36756,"adult":false,"title":"Pokémon: Pikachu's Rescue Adventure","video":false,"overview":"One day, Pikachu and its friends are walking along when they suddenly fall through a Diglett hole and into Pokémon Valley, a secret location that no one knows about. Pikachu and its buddies tell the Pokémon that they could use some help looking for Togepi, who fell through the hole first. The group sets off and eventually finds Togepi in the Exeggcute nest—but one of the Exeggcute is missing. That leads the group on another hunt; this time, though, Pikachu and its friends come back to the nest empty-handed. That’s when a storm begins to brew, filling Pokémon valley with roaring thunder and gusts of wind that almost blow the friends—and the Exeggcute nest—away! Are the friends going to be able to keep the nest safe and reunite the Exeggcute?","genre_ids":[16,35,12,10751],"media_type":"movie","popularity":0.9105,"vote_count":39,"poster_path":"/eoEaWuXdxCnyhHIYjBDpb8LqX4D.jpg","release_date":"1999-07-17","vote_average":6.2,"backdrop_path":"/fd2Cs6nwDXwCAORYOWnGDm039x9.jpg","original_title":"ピカチュウたんけんたい","original_language":"ja"},{"id":33875,"adult":false,"title":"Pokémon Heroes","video":false,"overview":"Ash, Pikachu and the gang try and stop a pair of thieves hiding out in the canals and alleyways of Altomare, the age-old water capital. Joining the adventure are two new legendary Pokémon, a pair of siblings named Latias and Latios, who serve as peacekeepers and protectors of the Soul Dew — a priceless treasure with a mysterious power.","genre_ids":[16,12,28,14,878],"media_type":"movie","popularity":2.9084,"vote_count":375,"poster_path":"/eySv5rdYLW1k6LxepxCNl8ND26R.jpg","release_date":"2002-07-13","vote_average":6.675,"backdrop_path":"/6nfEmbfWMuMBenYMOY6Vdho3Ycg.jpg","original_title":"劇場版ポケットモンスター 水の都の護神 ラティアスとラティオス","original_language":"ja"},{"id":36897,"adult":false,"title":"Pokémon: Mewtwo Returns","video":false,"overview":"The Team Rocket leader, Giovanni, has found Mewtwo in a remote area of the Johto region. As Giovanni tries to re-capture Mewtwo, Ash and his friends are kidnapped by Domino, a new Team Rocket member, while trying to rescue Pikachu from Jessie and James. The Clone Pokemon are also captured and are then used as bait for Mewtwo. The situation then becomes a battle between the wills of Mewtwo and Giovanni; and Mewtwo also tries to discover if it and the clones have a purpose in life, even though they are products of science.","genre_ids":[16,10751,28,12,18,14],"media_type":"movie","popularity":2.9504,"vote_count":423,"poster_path":"/zIYljUBF2rXzB0yYZVEPY1l8zHp.jpg","release_date":"2001-08-17","vote_average":6.723,"backdrop_path":"/pJszL2mPl084IDSzLDPH8NqIq0r.jpg","original_title":"ポケットモンスター ミュウツー! 我ハココニ在リ MEWTWO SAGA","original_language":"ja"},{"id":9288,"adult":false,"title":"Dungeons & Dragons: Wrath of the Dragon God","video":false,"overview":"Due to a curse from his former master Profion, Damodar survived his death by Ridley Freeborn as an undead entity in pursuit of an evil artifact for some hundred years, so that he might be capable of unleashing unstoppable destruction on Izmir and the descendants of those who caused his demise.","genre_ids":[28,12,14,10770],"media_type":"movie","popularity":1.5893,"vote_count":137,"poster_path":"/n5PV0sV4Nd0eCZMcRfipeNhTpmz.jpg","release_date":"2005-09-01","vote_average":4.7,"backdrop_path":"/eBJDAJmhFVLINV78sB0VkvCsVkB.jpg","original_title":"Dungeons & Dragons: Wrath of the Dragon God","original_language":"en"},{"id":16110,"adult":false,"title":"Thomas and the Magic Railroad","video":false,"overview":"Mr. Conductor's supply of magic gold dust, which allows him to travel between Shining Time and Thomas's island, is critically low. Unfortunately, he doesn't know how to get more. Meanwhile, Thomas is fending off attacks by the nasty diesel engines. Getting more gold dust will require help from Mr. C's slacker cousin, his new friend Lily and her morose grandfather, plus the secret engine.","genre_ids":[10751,14,12],"media_type":"movie","popularity":0.993,"vote_count":92,"poster_path":"/aPEJ36e8a7gLu28KVfsGDQdmruk.jpg","release_date":"2000-07-14","vote_average":5.4,"backdrop_path":"/QpDVV6g1nyQ54o5oYX3HF8mWri.jpg","original_title":"Thomas and the Magic Railroad","original_language":"en"},{"id":58218,"adult":false,"title":"The Devil's Nightmare","video":false,"overview":"Seven tourists sent by Satan to a castle are caught by a ghastly woman as they commit deadly sins.","genre_ids":[27,14],"media_type":"movie","popularity":0.5034,"vote_count":47,"poster_path":"/tRvh4IpxWvRg2AKuTOIpVNXbX7d.jpg","release_date":"1971-11-14","vote_average":6.149,"backdrop_path":"/8HAsJfoCv5AIY70ON5xd4oqhiTN.jpg","original_title":"La Plus Longue Nuit du Diable","original_language":"fr"},{"id":1379520,"adult":false,"title":"Rule Breakers","video":false,"overview":"In a nation where educating girls is seen as rebellion, a visionary woman dares to teach young minds to dream. When their innovation draws global attention, their success sparks hope—and opposition. As threats loom and sacrifices are made, their courage and unity ignite a movement that could forever transform the world.","genre_ids":[18],"media_type":"movie","popularity":1.1062,"vote_count":21,"poster_path":"/zJ6yH7e7XFsVTbF1gZnERCVeQJn.jpg","release_date":"2025-03-06","vote_average":7.5,"backdrop_path":"/oaliethcvyREtDbNBp94hi5IXeP.jpg","original_title":"Rule Breakers","original_language":"en"},{"id":37640,"adult":false,"title":"Let's Get Lost","video":false,"overview":"Documentary about jazz great Chet Baker that intercuts footage from the 1950s, when he was part of West Coast Cool, and from his last years. We see the young Baker, he of the beautiful face, in California and in Italy, where he appeared in at least one movie and at least one jail cell (for drug possession). And, we see the aged Baker, detached, indifferent, his face a ruin. Includes interviews with his children and ex-wife, women companions, and musicians.","genre_ids":[10402,99],"media_type":"movie","popularity":0.4252,"vote_count":47,"poster_path":"/voAn1Btvyy9icPHaf7HNwBfFZor.jpg","release_date":"1988-09-15","vote_average":7,"backdrop_path":"/aCIcZUtcmOYux5h3k10wlod4VgO.jpg","original_title":"Let's Get Lost","original_language":"en"},{"id":166696,"adult":false,"title":"Good Morning Althea","video":false,"overview":"The story revolves around Nikolai, apparently a part-cyborg; Galory, a young boy who apparently is part human/part Crest person, and Althea, who is entirely a Crest person. Seems the Earth and the Crest people were at war for 300 years so there's still a lot of bad feelings present. The ship Galory, Nikolai and others are on is ambushed and almost everyone killed by some kind of automated attack ships from a huge Crest ship that has been taken over by an automaton. Galory, Nikolai and Althea go to the ship to try and see if there are any survivors of an advanced party from Galory's ship that can be saved, and to see if they can destroy the Type 38 automaton in the ship's core.","genre_ids":[16,878],"media_type":"movie","popularity":0.3657,"vote_count":4,"poster_path":"/flxQD9nzWmfRh6ibzKWEHgmRcq.jpg","release_date":"1987-12-16","vote_average":5.75,"backdrop_path":"/frmmEmxHlV2o1nsLOYll1qjpKL8.jpg","original_title":"グッドモーニング・アルテア","original_language":"ja"},{"id":474626,"adult":false,"title":"To Each His Own","video":false,"overview":"Takashi Aoyama has way too much work to do and pushes himself mentally too hard. He blacks out and collapses at a railroad station. When he is about to be hit by a train, he is saved by Yamamoto. After his encounter with Yamamoto, Takashi recovers his bright personality and gets better results at work. One day, Takashi sees Yamamoto boarding a bus to the cemetery with a serious expression.","genre_ids":[18],"media_type":"movie","popularity":0.5044,"vote_count":17,"poster_path":"/bpHDTrGsdCR8uB7nhKGtPzf7E3f.jpg","release_date":"2017-05-27","vote_average":6.5,"backdrop_path":"/f4kY9hFWTkg196ZqaXlTEb4ENR.jpg","original_title":"ちょっと今から仕事やめてくる","original_language":"ja"},{"id":50087,"adult":false,"title":"Pokémon: Zoroark - Master of Illusions","video":false,"overview":"Ash and his friends must stop a greedy media mogul from using the shape-shifting Zoroark to capture the time-travelling Celebi.","genre_ids":[10751,16,12,14],"media_type":"movie","popularity":1.9283,"vote_count":231,"poster_path":"/tWgH64RZmm2rIHtO2DNnfN3DZa8.jpg","release_date":"2010-07-10","vote_average":6.7,"backdrop_path":"/7fC65V10NQ2lhHHQ0KA1KNA1PvO.jpg","original_title":"劇場版ポケットモンスター ダイヤモンド&パール 幻影の覇者 ゾロアーク","original_language":"ja"},{"id":34065,"adult":false,"title":"Pokémon: Destiny Deoxys","video":false,"overview":"Deoxys, a Pokémon from outer space, terrorizes the high-tech city Ash Ketchum and his friends are visiting.","genre_ids":[10751,12,16,14],"media_type":"movie","popularity":1.9601,"vote_count":284,"poster_path":"/3UV4evNh70gvPZB9KJEoh3a9B6I.jpg","release_date":"2004-07-22","vote_average":6.609,"backdrop_path":"/q2AAQdTJopOKjhoefLlmjzv4nSr.jpg","original_title":"劇場版ポケットモンスター アドバンスジェネレーション 裂空の訪問者 デオキシス","original_language":"ja"},{"id":3126,"adult":false,"title":"Alvin and the Chipmunks Meet Frankenstein","video":false,"overview":"The Chipmunks work in an amusement park attraction. After Alvin drives a crazy tour group, they miss their next performance and are locked in the park after closing time. Little do they know that the real Dr. Frankenstein has been hired in a new attraction called, \"Frankenstein's Castle\"; figuring that the castle isn't scary enough, the mad scientist recreates the real Monster.","genre_ids":[16,35,10751],"media_type":"movie","popularity":0.8982,"vote_count":153,"poster_path":"/hiXOFmWtxQ3LdrGgP2uOuR1DHBp.jpg","release_date":"2001-10-04","vote_average":6.739,"backdrop_path":"/vsLwmFVWKg1qydVJDX5sA5psiCa.jpg","original_title":"Alvin and the Chipmunks Meet Frankenstein","original_language":"en"},{"id":34067,"adult":false,"title":"Pokémon: Lucario and the Mystery of Mew","video":false,"overview":"In the legendary past, before Poké Balls were invented, an aura-guiding hero Pokémon named Lucario sensed two groups of armies about to clash, and a threat of a massive war in front of Oldoran Castle in Kanto that would leave no survivors. He transferred this message to his master, the legendary hero Arlon, while he was being attacked by a violent group of Hellgar. During the battle, his sense of sight was lost and he was rendered unable to see. He used the detection of his Aura, and so with the offensive Wave Bomb, he eliminated them. Though by the threat, the queen of Rota, Lady Rin was resolute to die with her civilians, and so Arlon made a choice.","genre_ids":[10751,12,16,14,28,878],"media_type":"movie","popularity":2.6806,"vote_count":325,"poster_path":"/3A3WiPXPmWVhXC7bGSiqtsYY9z6.jpg","release_date":"2005-07-16","vote_average":7,"backdrop_path":"/7qzuPx3ukGxCyLR9j0Ahg3fFI7r.jpg","original_title":"劇場版ポケットモンスター アドバンスジェネレーション ミュウと波導の勇者 ルカリオ","original_language":"ja"},{"id":421892,"adult":false,"title":"Shrek 5","video":false,"overview":"The fifth film in the Shrek franchise. Plot TBA.","genre_ids":[16,10751,35,14,12],"media_type":"movie","popularity":8.9288,"vote_count":0,"poster_path":"/aRntI6gNBMu4B6YozI7rxXRPyQo.jpg","release_date":"2027-06-30","vote_average":0,"backdrop_path":"/tgiuYuRg0vKh8OSjxbl1DzT9BfI.jpg","original_title":"Shrek 5","original_language":"en"}],"similar_content":[{"id":470703,"adult":false,"title":"Body Jack: Sublime Separation","video":false,"overview":"A high schooler fulfills a lifelong fantasy after a high-tech device lets him slip into the body of his childhood crush's best friend.","genre_ids":[16,35],"popularity":0.5371,"vote_count":5,"poster_path":"/yEzTCkU2eURPpxXBTFp6rHmkVJ5.jpg","release_date":"1987-01-28","vote_average":4.4,"backdrop_path":"/tq7zViUEXnVzMfaYEeVEE0zuZT3.jpg","original_title":"ボディジャック 楽しい幽体離脱","original_language":"ja"},{"id":8452,"adult":false,"title":"The 6th Day","video":false,"overview":"A world of the very near future in which cattle, fish, and even the family pet can be cloned. But cloning humans is illegal - that is until family man Adam Gibson comes home from work one day to find a clone has replaced him. Taken from his family and plunged into a sinister world he doesn't understand, Gibson must not only save himself from the assassins who must destroy him to protect their secret, but uncover who and what is behind the horrible things happening to him.","genre_ids":[878,28,9648,18,53],"popularity":4.0681,"vote_count":2206,"poster_path":"/rODFJOFiPk1UVCe4pmBza8T6feO.jpg","release_date":"2000-11-17","vote_average":5.99,"backdrop_path":"/opkt6IK1Os5gAwhlpu27bCZCk8K.jpg","original_title":"The 6th Day","original_language":"en"},{"id":1067282,"adult":false,"title":"Demon Slayer: Kimetsu no Yaiba -To the Swordsmith Village-","video":true,"overview":"A recap of Kimetsu no Yaiba episodes 43–45, with new footage and special end credits. Together with his comrades, Zenitsu and Inosuke, along with one of the top-ranking members of the Demon Slayer Corps, Tengen Uzui, Tanjiro embarks on a mission within the Entertainment District, where they encounter the formidable, high-ranking demons, Daki and Gyutaro.","genre_ids":[16,28,14,53],"popularity":4.5706,"vote_count":393,"poster_path":"/hEhGrcST85vMd63PBDgPBqih2tR.jpg","release_date":"2023-02-03","vote_average":7.322,"backdrop_path":"/tcYO8ay3A0liCWxHu2creU3Q9IB.jpg","original_title":"「鬼滅の刃」上弦集結、そして刀鍛冶の里へ","original_language":"ja"},{"id":8487,"adult":false,"title":"Wild Wild West","video":false,"overview":"Legless Southern inventor Dr. Arliss Loveless plans to rekindle the Civil War by assassinating President Ulysses S. Grant. Only two men can stop him: gunfighter James West and master-of-disguise and inventor Artemus Gordon. The two must team up to thwart Loveless' plans.","genre_ids":[28,12,35,878,37],"popularity":4.7179,"vote_count":3519,"poster_path":"/mCdo7nykEVCa25bjnkwgyX35fjm.jpg","release_date":"1999-06-30","vote_average":5.315,"backdrop_path":"/tbzWgnaqhFwN5mCIiwbgN5oiw0V.jpg","original_title":"Wild Wild West","original_language":"en"},{"id":8587,"adult":false,"title":"The Lion King","video":false,"overview":"Young lion prince Simba, eager to one day become king of the Pride Lands, grows up under the watchful eye of his father Mufasa; all the while his villainous uncle Scar conspires to take the throne for himself. Amid betrayal and tragedy, Simba must confront his past and find his rightful place in the Circle of Life.","genre_ids":[10751,16,18,12],"popularity":17.1511,"vote_count":19406,"poster_path":"/sKCr78MXSLixwmZ8DyJLrpMsd15.jpg","release_date":"1994-06-15","vote_average":8.252,"backdrop_path":"/6GF9uJs7AnbcJvyfoZyjZv063Oo.jpg","original_title":"The Lion King","original_language":"en"},{"id":8592,"adult":false,"title":"Dick Tracy","video":false,"overview":"The comic strip detective finds his life vastly complicated when Breathless Mahoney makes advances towards him while he is trying to battle Big Boy Caprice's united mob.","genre_ids":[12,35,80],"popularity":4.6454,"vote_count":1012,"poster_path":"/sjeP4bpgsUvAGE8oFcICy2GaHxw.jpg","release_date":"1990-04-05","vote_average":6.147,"backdrop_path":"/zkIMr5t0B95nZPhY4AvI4v3qYH.jpg","original_title":"Dick Tracy","original_language":"en"},{"id":8355,"adult":false,"title":"Ice Age: Dawn of the Dinosaurs","video":false,"overview":"Times are changing for Manny the moody mammoth, Sid the motor mouthed sloth and Diego the crafty saber-toothed tiger. Life heats up for our heroes when they meet some new and none-too-friendly neighbors – the mighty dinosaurs.","genre_ids":[16,35,10751,12],"popularity":7.379,"vote_count":8749,"poster_path":"/cXOLaxcNjNAYmEx1trZxOTKhK3Q.jpg","release_date":"2009-06-26","vote_average":6.761,"backdrop_path":"/o0zPARvs47f0UhAJuUqdQsyQaji.jpg","original_title":"Ice Age: Dawn of the Dinosaurs","original_language":"en"},{"id":8358,"adult":false,"title":"Cast Away","video":false,"overview":"Chuck Noland, a top international manager for FedEx, and Kelly, a Ph.D. student, are in love and heading towards marriage. Then Chuck's plane to Malaysia crashes at sea during a terrible storm. He's the only survivor, and finds himself marooned on a desolate island. With no way to escape, Chuck must find ways to survive in his new home.","genre_ids":[12,18],"popularity":10.4577,"vote_count":12081,"poster_path":"/7lLJgKnAicAcR5UEuo8xhSMj18w.jpg","release_date":"2000-12-22","vote_average":7.66,"backdrop_path":"/oCFVYPXI4IfhtF3GapU2jkDicDI.jpg","original_title":"Cast Away","original_language":"en"},{"id":8953,"adult":false,"title":"Steamboy","video":false,"overview":"In 1860s Britain, a boy inventor finds himself caught in the middle of a deadly conflict over a revolutionary advance in steam power.","genre_ids":[16,14,878],"popularity":2.0606,"vote_count":477,"poster_path":"/wszfXaMx74a91yRTBgO1fwSvMj3.jpg","release_date":"2004-07-17","vote_average":6.901,"backdrop_path":"/c31SAQjVMeVGv7mZsrw5BKGXj2P.jpg","original_title":"スチームボーイ","original_language":"ja"},{"id":8965,"adult":false,"title":"Atlantis: Milo's Return","video":false,"overview":"Milo and Kida reunite with their friends to investigate strange occurances around the world that seem to have links to the secrets of Atlantis.","genre_ids":[14,16,878,10751,28],"popularity":2.9405,"vote_count":3887,"poster_path":"/hyAbWGld5WLdrmUB9OHyewcJQGL.jpg","release_date":"2003-02-25","vote_average":6.3,"backdrop_path":"/GDTwA5FBvVUOjCGKoNDMflbs3Z.jpg","original_title":"Atlantis: Milo's Return","original_language":"en"},{"id":8997,"adult":false,"title":"Hollow Man II","video":false,"overview":"After the mysterious death of scientist Dr. Devin Villiers, Det. Frank Turner and his partner are assigned to protect Villiers' colleague, who revealed that  a veteran soldier was subjected to an experiment with the objective of creating the ultimate national security weapon... an undetectable soldier. The experiment failed – with disastrous side effects.","genre_ids":[27,53,878],"popularity":1.9757,"vote_count":275,"poster_path":"/c6Ga1AUGPe3GwlpX3qDYrD9y3EZ.jpg","release_date":"2006-05-23","vote_average":4.904,"backdrop_path":"/nlfjdxHeMuGhMwjyP60DdM8OIxU.jpg","original_title":"Hollow Man II","original_language":"en"},{"id":471278,"adult":false,"title":"Gravity Rush: The Animation - Overture","video":false,"overview":"The 20-minute animation that bridges the gap between the original Gravity Rush and Gravity Rush 2. Featuring Kat \"Gravity Queen\" and her friends Raven and Syd. Can they find more clues about the fearsome enemy threatening to unravel the fabric of the universe?","genre_ids":[14,16,28,878],"popularity":0.3274,"vote_count":7,"poster_path":"/wbCRcelo7ugtwEXAeD1lRZDK67.jpg","release_date":"2016-12-26","vote_average":6.9,"backdrop_path":"/e92PLDvuAcmx1rQYF2ZiMZwAayP.jpg","original_title":"『GRAVITY DAZE 2』スペシャルアニメーション","original_language":"ja"},{"id":277834,"adult":false,"title":"Moana","video":false,"overview":"In Ancient Polynesia, when a terrible curse incurred by Maui reaches an impetuous Chieftain's daughter's island, she answers the Ocean's call to seek out the demigod to set things right.","genre_ids":[12,35,10751,16],"popularity":3.3037,"vote_count":13554,"poster_path":"/9tzN8sPbyod2dsa0lwuvrwBDWra.jpg","release_date":"2016-10-13","vote_average":7.564,"backdrop_path":"/iYLKMV7PIBtFmtygRrhSiyzcVsF.jpg","original_title":"Moana","original_language":"en"},{"id":8916,"adult":false,"title":"Antz","video":false,"overview":"A neurotic worker ant in love with a rebellious princess rises to unlikely stardom when he switches places with a soldier. Signing up to march in a parade, he ends up under the command of a bloodthirsty general. But he's actually been enlisted to fight against a termite army.","genre_ids":[16,35,12,10752],"popularity":5.4326,"vote_count":4663,"poster_path":"/lWPjxbUMpAHFkJpZHHNWhQaRsax.jpg","release_date":"1998-10-02","vote_average":6.174,"backdrop_path":"/i4NvcHeYeAdLEFiLxEVvUA3BT0.jpg","original_title":"Antz","original_language":"en"},{"id":8810,"adult":false,"title":"Mad Max 2","video":false,"overview":"Max Rockatansky returns as the heroic loner who drives the dusty roads of a postapocalyptic Australian Outback in an unending search for gasoline. Arrayed against him and the other scraggly defendants of a fuel-depot encampment are the bizarre warriors commanded by the charismatic Lord Humungus, a violent leader whose scruples are as barren as the surrounding landscape.","genre_ids":[12,28,53,878],"popularity":6.0284,"vote_count":4081,"poster_path":"/l1KVEhkGDpWRzQ0VqIhZqDDuOim.jpg","release_date":"1981-12-24","vote_average":7.385,"backdrop_path":"/MMSI9WzRmOdqXarevQ3Kqnytrx.jpg","original_title":"Mad Max 2","original_language":"en"},{"id":8814,"adult":false,"title":"Doom","video":false,"overview":"A team of space marines known as the Rapid Response Tactical Squad, led by Sarge, is sent to a science facility on Mars after somebody reports a security breach. There, they learn that the alert came after a test subject, a mass murderer purposefully injected with alien DNA, broke free and began killing people. Dr. Grimm, who is related to team member Reaper, informs them all that the chromosome can mutate humans into monsters -- and is highly infectious.","genre_ids":[28,27,878],"popularity":4.2513,"vote_count":2383,"poster_path":"/y50lH061yWOvEstoZRn7lYs0huk.jpg","release_date":"2005-10-20","vote_average":5.181,"backdrop_path":"/9EpgaLS44zlXoTSAOhGiJmkIA4B.jpg","original_title":"Doom","original_language":"en"},{"id":9312,"adult":false,"title":"Mortal Kombat","video":false,"overview":"For nine generations an evil sorcerer has been victorious in hand-to-hand battle against his mortal enemies. If he wins a tenth Mortal Kombat tournament, desolation and evil will reign over the multiverse forever. To save Earth, three warriors must overcome seemingly insurmountable odds, their own inner demons, and superhuman foes.","genre_ids":[28,14],"popularity":3.1524,"vote_count":2462,"poster_path":"/fcK7tzSSXMYiMN8E9KlZJL1BYyp.jpg","release_date":"1995-08-18","vote_average":5.874,"backdrop_path":"/dfU9xyEEyLxvZ5unTn05Whm9Lce.jpg","original_title":"Mortal Kombat","original_language":"en"},{"id":9320,"adult":false,"title":"The Avengers","video":false,"overview":"British Ministry agent John Steed, under direction from \"Mother\", investigates a diabolical plot by arch-villain Sir August de Wynter to rule the world with his weather control machine. Steed investigates the beautiful Doctor Mrs. Emma Peel, the only suspect, but simultaneously falls for her and joins forces with her to combat Sir August.","genre_ids":[28,12,53,878,35],"popularity":2.7429,"vote_count":763,"poster_path":"/1p5thyQ4pCy876HpdvFARqJ62N9.jpg","release_date":"1998-08-13","vote_average":4.44,"backdrop_path":"/nMjfRk5SBNuxT01f5FYO5rJLwnI.jpg","original_title":"The Avengers","original_language":"en"},{"id":9323,"adult":false,"title":"Ghost in the Shell","video":false,"overview":"In the year 2029, the barriers of our world have been broken down by the net and by cybernetics, but this brings new vulnerability to humans in the form of brain-hacking. When a highly-wanted hacker known as 'The Puppetmaster' begins involving them in politics, Section 9, a group of cybernetically enhanced cops, are called in to investigate and stop the Puppetmaster.","genre_ids":[28,16,878],"popularity":6.7526,"vote_count":3767,"poster_path":"/9gC88zYUBARRSThcG93MvW14sqx.jpg","release_date":"1995-11-18","vote_average":7.924,"backdrop_path":"/jIpagj2Dud9g3ZVJFvaWikEWsYz.jpg","original_title":"GHOST IN THE SHELL","original_language":"ja"},{"id":9325,"adult":false,"title":"The Jungle Book","video":false,"overview":"The boy Mowgli makes his way to the man-village with Bagheera, the wise panther. Along the way he meets jazzy King Louie, the hypnotic snake Kaa and the lovable, happy-go-lucky bear Baloo, who teaches Mowgli \"The Bare Necessities\" of life and the true meaning of friendship.","genre_ids":[10751,16,12],"popularity":6.4269,"vote_count":6579,"poster_path":"/yN1kuupnPTLUprgfvC5WapgrxG4.jpg","release_date":"1967-10-18","vote_avera