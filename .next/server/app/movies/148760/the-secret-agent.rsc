4,"file_path":"/2h5PODQOID0LbZwPve1cekXuR24.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1408,"height":792,"file_path":"/mZugUEhlxPBcF3oyJljslH3DtLb.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1412,"height":795,"file_path":"/p3osHDQwlZP4b5t07MpWIt7QJtk.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.776,"vote_average":0},{"width":1429,"height":804,"file_path":"/wwHBKw1NY5yfEnfcjtAuzASpCLQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1429,"height":804,"file_path":"/XpMVfnBNz0wePWLIppz37PELaa.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1429,"height":804,"file_path":"/3QpSwayGm3T20ihSh29BkbaAbht.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1404,"height":789,"file_path":"/yA3tygC1vA46JcIBWQ1SqUeQjJb.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":2197,"height":1236,"file_path":"/rjPPxUlcQZFDjViAefP5CYnpgJ9.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2224,"height":1251,"file_path":"/tRgE02nhnpA7Q80pP6Ii3sfbGBz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2251,"height":1266,"file_path":"/3PhRcupWb36iUWGGZG0gGQ06aGK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2245,"height":1263,"file_path":"/lxwvEONLKrvnxa3vx7N5fxcj58F.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2245,"height":1263,"file_path":"/ri9Wl2mSRuCS2Tz4H7ah3kP69vD.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/x6yFzKLCexU1SfRJwUptE1HVCqU.jpg","iso_639_1":"el","iso_3166_1":"GR","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T04:56:50.6+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Secret Agent","runtime":161,"tagline":"Brazil 1977, a time of great mischief.","homepage":"https://www.neonrated.com/film/the-secret-agent","overview":"Brazil, 1977. Marcelo, a technology expert in his early 40s, is on the run. Hoping to reunite with his son, he travels to Recife during Carnival but soon realizes that the city is not the safe haven he was expecting."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"L’Agent secret","runtime":158,"tagline":"Brésil, 1977, une période trouble...","homepage":"","overview":"1977, Brésil. Marcelo, un homme d’une quarantaine d’années fuyant un passé trouble, arrive dans la ville de Recife où il espère construire une nouvelle vie et renouer avec sa famille. C’est sans compter sur les menaces de mort qui rôdent et planent au-dessus de sa tête…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":158,"tagline":"Eletrizante, emocionante e cheio de pirraça.","homepage":"https://www.oagentesecreto.com","overview":"No Brasil de 1977, Marcelo, um especialista em tecnologia fugindo de um passado misterioso, volta ao Recife em busca de um pouco de paz, mas percebe que a cidade está longe de ser o refúgio que procura."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"L'agente segreto","runtime":0,"tagline":"","homepage":"","overview":"Brasile, 1977. Marcelo è in fuga. Raggiunge Recife durante la settimana del Carnevale per riabbracciare il figlio, ma scopre presto che la città non è l’ameno rifugio che aveva immaginato: sotto la superficie festosa pulsa una realtà soffocante, carica di tensione, violenza e pericolo."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"시크릿 에이전트","runtime":160,"tagline":"","homepage":"","overview":"1977년 브라질의 군사 독재 시절, 고향 헤시피로 돌아온 마르셀로는 실종된 어머니의 기록을 찾고 아들과 재회하려 하지만 도시는 감시와 망각의 거미줄처럼 얽혀 있다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":161,"tagline":"","homepage":"","overview":"Brazilië, 1977. Marcelo, technologie-expert en weduwnaar, is op de vlucht. Terwijl de militaire dictatuur steeds wredere maatregelen oplegt aan de bevolking komt hij aan in Recife, waar hij zich hoopt te herenigen met zijn zoontje. Daar, tijdens de carnavalsweek, vindt hij een onderkomen bij een groep gelijkgestemden en neemt hij een valse identiteit aan. Maar Marcelo’s situatie is penibeler dan hij doorheeft: al snel beseft hij zich dat de stad verre van het geweldloze toevluchtsoord is dat hij zoekt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Tajny agent","runtime":160,"tagline":"","homepage":"","overview":"Brazylia, 1977 r. W środku dyktatury wojskowej Marcelo, specjalista od technologii, ucieka przed tajemniczą przeszłością i wraca do Recife w poszukiwaniu spokoju. Wkrótce zdaje sobie sprawę, że miasto jest daleko od schronienia, którego szuka."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"El agente secreto","runtime":158,"tagline":"","homepage":"","overview":"En 1977, durante la dictadura militar brasileña, Marcelo, un profesor que huye de un pasado turbulento, regresa huyendo a la ciudad de Recife, donde espera construir una nueva vida y reencontrarse con su hijo. Pero pronto se da cuenta de que la ciudad está lejos de ser el refugio que busca, que las fuerzas gubernamentales le persiguen y las amenazas de muerte se ciernen sobre él."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Tajni agent","runtime":0,"tagline":"","homepage":"","overview":"Brazil, 1977. Marcelo, tehnološki stručnjak u ranim 40-ima, u bijegu je. Stiže u Recife tijekom karnevalskog tjedna, nadajući se da će se ponovno ujediniti sa sinom, ali ubrzo shvaća da je grad daleko od nenasilnog utočišta koje traži."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"The Secret Agent","runtime":158,"tagline":"","homepage":"","overview":"Brasilien, 1977. Marcelo, ein Technikexperte in seinen frühen 40ern, ist auf der Flucht. Er kommt in der Karnevalswoche in Recife an, in der Hoffnung, seinen Sohn wiederzusehen, muss aber bald feststellen, dass die Stadt bei weitem nicht die gewaltfreie Zuflucht ist, die er sucht."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"密探","runtime":0,"tagline":"","homepage":"","overview":"1977年，在被军事独裁统治折磨的巴西，四十多岁的马塞洛（瓦格纳·马拉 饰）逃离了他混乱的过去，来到累西腓，希望在这里建立新的生活并与家人重修旧好。然而，他并未料到死亡威胁如影随形，笼罩在他的头顶。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Slepenais aģents","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"הסוכן החשאי","runtime":158,"tagline":"","homepage":"","overview":"ברזיל, 1977. מרצ'לו עוזב את העיר הגדולה לטובת עיירת ילדותו כדי להתחבא מהשלטונות שרודפים אחריו ולהתאחד עם בנו. שם, תחת שם בדוי בתוך קהילה של נרדפים אחרים, הוא מנסה לחיות מחוץ לרדאר עד שהמשטר המושחת יקרוס - אך מגלה שטבעת הסכנה בכל זאת הולכת ומתהדקת סביבו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Таємний агент","runtime":0,"tagline":"","homepage":"","overview":"Бразилія 1970-х – небезпечне місце, в якому лютує військова диктатура. Науковець Марсело зневолі стає втікачем, коли дізнається, що його дослідженнями хоче заволодіти корумпований міністр. Рятуючись від найманих убивць, чоловік рушає до місця свого народження. У цьому місті на узбережжі океану він потрапляє в хаос карнавалу, поліцейських розправ і таємничого руху опору. Його мета одна – возз’єднатися з сином, щоб разом покинути країну."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"這不只是個間諜故事","runtime":0,"tagline":"","homepage":"","overview":"在1977年軍事獨裁統治的巴西，一位科學專家逃離神祕的過網，並決定回到家鄉雷西非尋求平靜。然而，他很快意識到這也不是他要的避難所。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"The Secret Agent","runtime":0,"tagline":"","homepage":"","overview":""},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Gizli Ajan","runtime":0,"tagline":"","homepage":"","overview":"Brezilya, 1977. 40'lı yaşlarının başındaki teknoloji uzmanı Marcelo, bir kaçaktır. Oğluyla yeniden bir araya gelme umuduyla karnaval haftasında Recife şehrine varır, ancak çok geçmeden şehrin aradığı şiddetten uzak sığınak olmadığını anlar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Salaagent","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"","runtime":158,"tagline":"A paz é uma ilusão quando o passado te persegue.","homepage":"","overview":"Em 1977, em Recife, Marcelo, um especialista em tecnologia com cerca de quarenta anos, regressa no meio do Carnaval para se reunir com o seu filho e planear uma fuga perigosa sob os olhos sempre vigilantes do regime militar repressivo do Brasil."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"El agente secreto","runtime":161,"tagline":"","homepage":"","overview":"En Brasil, en 1977, Marcelo, un especialista en tecnología que huye de un pasado misterioso, regresa a Recife en busca de paz, pero se da cuenta de que la ciudad está lejos del refugio que busca."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"The Secret Agent","runtime":0,"tagline":"Brasilien 1977 - en tid av intriger och ofog.","homepage":"","overview":"Brasilien, 1977. Marcelo, en teknikexpert i 40-årsåldern, är på flykt. Han anländer till Recife under karnevalsveckan i hopp om att återförenas med sin son, men han inser snart att staden är långt ifrån den fristad som han har sökt."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Tajni agent","runtime":0,"tagline":"Brazilija, 1977. Čas velikih prevar.","homepage":"","overview":"Leta 1977 v Braziiji tehnološki strokovnjak pobegne pred skrivnostno preteklostjo in se v iskanju miru vrne v svoj rojstni kraj Recife, a kmalu ugotovi, da mesto skriva več nevarnosti kot upanja."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"ประเทศนี้ อยู่เฉย ๆ ก็ผิดได้","runtime":0,"tagline":"","homepage":"","overview":"ในปี 1997 ผู้เชี่ยวชาญทางด้านเทคโนโลยีคนหนึ่งหนีจากอดีตอันลึกลับและกลับไปยังบ้านเกิดที่เมือง เรซีเฟ เพื่อค้นหาความสงบ ก่อนที่ไม่นานเขาจะได้รู้ว่า เมืองแห่งนี้ยังห่างไกลจากการเป็นที่พักพิงที่เขาตามหาอยู่มาก"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Секретный агент","runtime":0,"tagline":"«Бразилия, 77-ой, время больших неприятностей»","homepage":"","overview":"Последние годы военной диктатуры в Бразилии. Школьный учитель Марселу бежит от своего прошлого, но не может найти себе покоя даже в другом городе."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Тайният агент","runtime":0,"tagline":"","homepage":"","overview":"През 1977 г. в Бразилия технологичният специалист Марсело, опитващ се да избяга от мистериозното си минало, се връща в Ресифи с надеждата да намери спокойствие, но скоро разбира, че градът е далеч от убежището, което е очаквал."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Đặc Vụ Mật","runtime":0,"tagline":"","homepage":"","overview":"Brazil, năm 1977. Marcelo, một chuyên gia công nghệ ngoài bốn mươi tuổi, đang trên đường trốn chạy. Với hy vọng được đoàn tụ cùng con trai, anh đến Recife đúng dịp Carnival—nhưng nhanh chóng nhận ra thành phố này không hề là nơi trú ẩn an toàn như anh tưởng."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Tajný agent","runtime":0,"tagline":"","homepage":"","overview":"V roce 1977 v Brazílii, která je stále poničená vojenskou diktaturou, sledujeme příběh Marcela, čtyřicetiletého učitele, který opouští svou pohnutou minulost a přijíždí do Recife v naději, že si vybuduje nový život a znovu se spojí se svou rodinou. Marcello doufá, že se v Recife během karnevalového týdne znovu setká se svým synem. Brzy však zjistí, že ho v jeho novém útočišti sledují a špehují sousedé, kteří mu nedávají možnost úniku z chapadel všudypřítomného korupčního prostředí."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"シークレット・エージェント","runtime":0,"tagline":"","homepage":"","overview":"1977 年、軍事政権下のブラジル。カーニバルの喧騒に紛れ、男は再び街へと舞い戻る。過去を消し身分を隠し、抑圧された僅かな自由にすがる人々と猜疑心渦巻くこの国で、「ある目的」を果たすために……。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Agentul secret","runtime":0,"tagline":"","homepage":"","overview":"Brazilia, 1977. Marcelo, un expert în tehnologie trecut de 40 de ani, trăiește ca un fugar. În plină săptămână de Carnaval, ajunge la Recife cu speranța de a-și regăsi fiul și de a găsi liniștea pe care o caută de ani de zile. Dar orașul pulsează de violență și neliniște, iar culorile, muzica și agitația carnavalului ascund o lume în care pericolul pândește la fiecare colț."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"مامور مخفی","runtime":0,"tagline":"","homepage":"","overview":"در سال ۱۹۷۷، یک متخصص فناوری از گذشته‌ای مرموز فرار می‌کند و در جستجوی آرامش به زادگاهش رسیف بازمی‌گردد. او خیلی زود متوجه می‌شود که این شهر به هیچ وجه پناهگاهی که او به دنبالش است، نیست."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Ο Μυστικός Πράκτορας","runtime":0,"tagline":"","homepage":"","overview":"Το 1977, κατά τη διάρκεια της στρατιωτικής δικτατορίας της Βραζιλίας, ο Μαρσέλο, ένας δάσκαλος, δραπετεύει από το ταραχώδες παρελθόν του, και εγκαθίσταται ως φυγάς στην πόλη Ρεσίφε, όπου ελπίζει να χτίσει μια νέα ζωή και να επανενωθεί με τον γιο του. Σύντομα συνειδητοποιεί ότι η πόλη απέχει πολύ από το να γίνει το καταφύγιο που αναζητά, καθώς οι κυβερνητικές δυνάμεις τον κυνηγούν και η ζωή του απειλείται όλο και περισσότερο."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Тајни агент","runtime":0,"tagline":"","homepage":"","overview":"Бразил, 1977. Марсело, технолошки стручњак у раним четрдесетим, је у бекству. Стиже у Ресифе током карневалске недеље, надајући се да ће се поново срести са сином, али убрзо схвата да је град далеко од ненасилног уточишта које тражи."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"L'agent secret","runtime":0,"tagline":"","homepage":"","overview":"L’any 1977, durant la dictadura militar brasilera, en Marcelo, un professor amb un passat turbulent, torna a Recife esperant començar de nou i retrobar-se amb el seu fill. Aviat descobreix, però, que la ciutat no és un refugi: les forces governamentals el persegueixen i la mort el ronda constantment."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"}],"reviews_tmdb":[{"id":"68f45329e81492b1b98e6f55","url":"https://www.themoviedb.org/review/68f45329e81492b1b98e6f55","author":"Brent Marchant","content":"$11","created_at":"2025-10-19T02:55:37.076Z","updated_at":"2025-10-19T02:55:37.155Z","author_details":{"name":"Brent Marchant","rating":4,"username":"Brent_Marchant","avatar_path":null}},{"id":"69894d08a8ad1d728e8c9742","url":"https://www.themoviedb.org/review/69894d08a8ad1d728e8c9742","author":"Chandler Danier","content":"This film looks great. Brazil is such a cool place. I want to go live in this time...but as a rich white guy visiting who doesn't have to deal with the apparent horrors. Perhaps we could do a The Secret Agent 2 starring me.\r\n\r\nI'd probably have to duck while using the phone booth. I crouch well.\r\n\r\nFun story. Interesting characters. Great! I bet this will get a Hollywood redux in a few years.","created_at":"2026-02-09T02:57:12.492Z","updated_at":"2026-02-09T02:57:12.508Z","author_details":{"name":"Chandler Danier","rating":8,"username":"chandlerdanier","avatar_path":null}}],"recommendations":[{"id":2925,"adult":false,"title":"The First Wives Club","video":false,"overview":"After years of helping their hubbies climb the ladder of success, three mid-life Manhattanites have been dumped for a newer, curvier model. But the trio is determined to turn their pain into gain. They come up with a cleverly devious plan to hit their exes where it really hurts - in the wallet!","genre_ids":[35],"media_type":"movie","popularity":2.7607,"vote_count":809,"poster_path":"/2ApifgYnfdJUSmCKzTBrWOYYWsn.jpg","release_date":"1996-09-20","vote_average":6.708,"backdrop_path":"/gtLbJuGgAEvxG4DaPHRARURlD2H.jpg","original_title":"The First Wives Club","original_language":"en"},{"id":1122099,"adult":false,"title":"The Ballad of Wallis Island","video":false,"overview":"An eccentric lottery winner who lives alone on a remote island tries to make his fantasies come true by getting his favourite musicians to perform at his home.","genre_ids":[35,18,10402],"media_type":"movie","popularity":1.9636,"vote_count":156,"poster_path":"/haS6bnqDqZoi5sYcCPJWaj2yMbB.jpg","release_date":"2025-03-28","vote_average":7.179,"backdrop_path":"/1nn7nCFRTKeWOXbtjrFxfSvf1EI.jpg","original_title":"The Ballad of Wallis Island","original_language":"en"},{"id":1294698,"adult":false,"title":"Case 137","video":false,"overview":"Stéphanie, a police officer working for Internal Affairs, is assigned to a case involving a young man severely wounded during a tense and chaotic demonstration in Paris. While she finds no evidence of illegitimate police violence, the case takes a personal turn when she discovers the victim is from her hometown.","genre_ids":[80,18],"media_type":"movie","popularity":1.2482,"vote_count":106,"poster_path":"/t93h1ptV098Q6vzl9gfEymJQ6Qp.jpg","release_date":"2025-11-19","vote_average":7,"backdrop_path":"/kjKxmpuPIvXjDP4reWCkMaeK2Es.jpg","original_title":"Dossier 137","original_language":"fr"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":35.4356,"vote_count":26828,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.903,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":346698,"adult":false,"title":"Barbie","video":false,"overview":"Barbie and Ken are having the time of their lives in the colorful and seemingly perfect world of Barbie Land. However, when they get a chance to go to the real world, they soon discover the joys and perils of living among humans.","genre_ids":[35,12],"media_type":"movie","popularity":20.1629,"vote_count":10800,"poster_path":"/iuFNMS8U5cb6xfzi51Dbkovj7vM.jpg","release_date":"2023-07-19","vote_average":6.929,"backdrop_path":"/ctMserH8g2SeOAnCw5gFjdQF8mo.jpg","original_title":"Barbie","original_language":"en"},{"id":297222,"adult":false,"title":"PK","video":false,"overview":"A stranger in the city asks questions no one has asked before. Known only by his initials, the man's innocent questions and childlike curiosity take him on a journey of love, laughter and letting go.","genre_ids":[35,18,878],"media_type":"movie","popularity":6.4772,"vote_count":1122,"poster_path":"/z2x2Y4tncefsIU7h82gmUM5vnBJ.jpg","release_date":"2014-12-18","vote_average":7.698,"backdrop_path":"/gxfvtq5eYiClS2X7hxAAPBNrbWA.jpg","original_title":"पीके","original_language":"hi"},{"id":671,"adult":false,"title":"Harry Potter and the Philosopher's Stone","video":false,"overview":"Harry Potter has lived under the stairs at his aunt and uncle's house his whole life. But on his 11th birthday, he learns he's a powerful wizard—with a place waiting for him at the Hogwarts School of Witchcraft and Wizardry. As he learns to harness his newfound powers with the help of the school's kindly headmaster, Harry uncovers the truth about his parents' deaths—and about the villain who's to blame.","genre_ids":[12,14],"media_type":"movie","popularity":21.0223,"vote_count":29186,"poster_path":"/wuMc08IPKEatf9rnMNXvIDxqP4W.jpg","release_date":"2001-11-16","vote_average":7.899,"backdrop_path":"/1XAC6RPT01UX9EQGy2JVn5c8pgy.jpg","original_title":"Harry Potter and the Philosopher's Stone","original_language":"en"},{"id":49046,"adult":false,"title":"All Quiet on the Western Front","video":false,"overview":"Paul Baumer and his friends Albert and Muller, egged on by romantic dreams of heroism, voluntarily enlist in the German army. Full of excitement and patriotic fervour, the boys enthusiastically march into a war they believe in. But once on the Western Front, they discover the soul-destroying horror of World War I.","genre_ids":[10752,36,18],"media_type":"movie","popularity":8.6956,"vote_count":4528,"poster_path":"/2IRjbi9cADuDMKmHdLK7LaqQDKA.jpg","release_date":"2022-10-07","vote_average":7.721,"backdrop_path":"/zbOlpFM306PHE7EP1OELCH5qSmS.jpg","original_title":"Im Westen nichts Neues","original_language":"de"},{"id":76600,"adult":false,"title":"Avatar: The Way of Water","video":false,"overview":"Set more than a decade after the events of the first film, learn the story of the Sully family (Jake, Neytiri, and their kids), the trouble that follows them, the lengths they go to keep each other safe, the battles they fight to stay alive, and the tragedies they endure.","genre_ids":[28,12,878],"media_type":"movie","popularity":31.3514,"vote_count":13749,"poster_path":"/t6HIqrRAclMCA60NsSmeqe9RmNV.jpg","release_date":"2022-12-14","vote_average":7.598,"backdrop_path":"/cd8YDn7M0lfaHhZdU6MvCDxPalP.jpg","original_title":"Avatar: The Way of Water","original_language":"en"},{"id":264660,"adult":false,"title":"Ex Machina","video":false,"overview":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl.","genre_ids":[18,878],"media_type":"movie","popularity":7.0085,"vote_count":14042,"poster_path":"/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg","release_date":"2015-01-21","vote_average":7.573,"backdrop_path":"/uqOuJ50EtTj7kkDIXP8LCg7G45D.jpg","original_title":"Ex Machina","original_language":"en"},{"id":96721,"adult":false,"title":"Rush","video":false,"overview":"In the 1970s, a rivalry propels race car drivers Niki Lauda and James Hunt to fame and glory — until a horrible accident threatens to end it all.","genre_ids":[18,28],"media_type":"movie","popularity":7.5617,"vote_count":7663,"poster_path":"/95BDrWmcfJDEa2WCfjmLgi67jhi.jpg","release_date":"2013-09-02","vote_average":7.731,"backdrop_path":"/D3eDUNEzJPBDG3TCJcR7RyRgTA.jpg","original_title":"Rush","original_language":"en"},{"id":1562,"adult":false,"title":"28 Weeks Later","video":false,