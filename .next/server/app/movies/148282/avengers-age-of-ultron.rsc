"/rE6Se7Hsx9RdWDecnaLqnIMoeN8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.775,"vote_average":0},{"width":2862,"height":1612,"file_path":"/67VT80dpYKsVc0MmaS7ShjJ7JRZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.775,"vote_average":0},{"width":2862,"height":1612,"file_path":"/AkrtRrNC8cMWtATVi9gWloVEQrf.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.775,"vote_average":0},{"width":2862,"height":1612,"file_path":"/pMHroDj5F2qM2HWdg43HozS4D7q.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.775,"vote_average":0},{"width":2862,"height":1612,"file_path":"/hLFHvWdfu1B2He667Kwy47Pk6yF.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.775,"vote_average":0},{"width":2862,"height":1612,"file_path":"/smdRCCtFNOHrbWwH2a8JzsZJKzX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.775,"vote_average":0},{"width":2862,"height":1612,"file_path":"/3J2mxklbc57sRqOn6Rj9hmfbO51.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.775,"vote_average":0},{"width":1920,"height":1080,"file_path":"/6FIhloVIo7p4BlqfX7bMS1VbWVO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/c12qNRa3WK8AO4XKxhLQhdp44rc.jpg","iso_639_1":"ja","iso_3166_1":"JP","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/cYipoHQpQfR11rmqALe3vlBXa7i.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/knwC7WkVubWoqpd4QpDDIUvPM8d.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/4NSop41PJojGNPhHQUuGnx9JSMS.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1422,"height":800,"file_path":"/s260VwQ6sziN7T2KRkxHVgia2nE.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1422,"height":800,"file_path":"/jUwmXKqnmAoJe9OHSiks4gZrEkq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1422,"height":800,"file_path":"/3u0aYzSW5nllAzDFt3jb7oDwEYf.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:49:36.645+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":141,"tagline":"A new age has come.","homepage":"https://www.marvel.com/movies/avengers-age-of-ultron","overview":"When Tony Stark tries to jumpstart a dormant peacekeeping program, things go awry and Earth’s Mightiest Heroes are put to the ultimate test as the fate of the planet hangs in the balance. As the villainous Ultron emerges, it is up to The Avengers to stop him from enacting his terrible plans, and soon uneasy alliances and unexpected action pave the way for an epic and unique global adventure."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":141,"tagline":"Una nuova era è giunta.","homepage":"http://marvel.com/movies/movie/193/avengers_age_of_ultron","overview":"Quando Tony Stark riprende un programma di mantenimento della pace in disuso, qualcosa va storto e la squadra degli eroi più potenti della Terra composta da Iron Man, Captain America, Thor, l’Incredibile Hulk, Vedova Nera e Occhio di Falco, sarà messa a dura prova per salvare il mondo da un destino inesorabile. Toccherà agli Avengers far fronte al malvagio Ultron e impedirgli di portare a compimento i suoi terribili piani. Nuove e scomode alleanze ed eventi imprevisti daranno vita a una straordinaria ed epica avventura"},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Avengers 2: Đế Chế Ultron","runtime":141,"tagline":"Một kỷ nguyên mới đã tới.","homepage":"","overview":"Avengers: Age of Ultron tiếp nối các sự kiện xảy ra trong Captain America: The Winter Soldier ra mắt hè 2014. Kẻ thù của Biệt đội siêu anh hùng lần này là Ultron – một robot với trí tuệ nhân tạo, những năng lực siêu nhiên mạnh hơn bất kỳ ai trong The Avenger và có dã tâm chia rẽ nội bộ biệt đội nhằm thôn tính Trái Đất. Hắn được tạo ra từ phòng thí nghiệm của Tony Stark với mụ đích ban đầu là một hệ thống đặc biệt với mục đích gìn giữ hòa bình thế giới nhưng do Người Sắt sơ suất đã để mọi thứ vượt ra khỏi tầm kiểm soát, đẩy số phận của loài người lâm vào tình cảnh ngàn cân treo sợi tóc. Một lần nữa, những siêu anh hùng quả cảm - Iron Man, Captain America, Thor, The Incredible Hulk, Black Widow và Hawkeye - tiếp tục hợp tác để ngăn chặn kẻ thù. Trong hành trình bảo vệ hòa bình, nhóm kết nạp thêm hai thành viên: Wanda Maxioff và Pietro Maxioff – cặp song sinh bí hiểm và sở hữu một nguồn sức mạnh lớn lao, cũng như gặp lại một người bạn cũ trong hình dạng hoàn toàn mới có tên The Vision."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Avengers: Czas Ultrona","runtime":141,"tagline":"Rozpoczyna się nowy wiek...","homepage":"","overview":"Agencja, w której służą walczący ze złem superbohaterowie, zostaje rozwiązana. Herosów specjalnie to nie martwi, bo coraz częściej marzyli o zasłużonym odpoczynku. W tej sytuacji Tony Stark, znany też jako Iron Man, wskrzesza zaawansowaną  sztuczną inteligencję, Ultrona. Niezwykła maszyna ma samodzielnie wykrywać i eliminować potencjalne zagrożenia. Kiedy Ultron uznaje ludzkość za wroga i postanawia ją zniszczyć, Iron Man (Robert Downey Jr.), Kapitan Ameryka (Chris Evans), Thor (Chris Hemsworth), Hulk (Mark Ruffalo), Czarna Wdowa (Scarlett Johansson), Sokole Oko (Jeremy Renner) i Nick Fury (Samuel L. Jackson) stają do walki przeciwko niemu."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Avengers : L'Ère d'Ultron","runtime":143,"tagline":"Une nouvelle ère est venue.","homepage":"","overview":"Alors que Tony Stark tente de relancer un programme de maintien de la paix jusque-là suspendu, les choses tournent mal et les super-héros Iron Man, Captain America, Thor, Hulk, Black Widow et Hawkeye vont devoir à nouveau unir leurs forces pour combattre le plus puissant de leurs adversaires : le terrible Ultron, un être technologique terrifiant qui s’est juré d’éradiquer l’espèce humaine. Afin d’empêcher celui-ci d’accomplir ses sombres desseins, des alliances inattendues se scellent, les entraînant dans une incroyable aventure et une haletante course contre le temps…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Мстители: Эра Альтрона","runtime":141,"tagline":"«Наступила Новая Эра»","homepage":"","overview":"Человечество на грани уничтожения. На этот раз людям угрожает Альтрон — искусcтвенный интеллект, ранее созданый для того, чтобы защищать Землю от любых угроз. Однако, главной угрозой он посчитал человечество. Международная организация Щ. И. Т не способна справится с таким мощным врагом, и потому они вновь обращаются за помощью к Величайшим Героям Земли — Мстителям. Однако Альтрон слишком силен, и есть большая вероятность, что даже им не удастся остановить начало надвигающейся Эры Альтрона, где нет места для людей…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Vengadores: La era de Ultrón","runtime":141,"tagline":"Una nueva era comienza.","homepage":"","overview":"Cuando Tony Stark intenta reactivar un programa caído en desuso cuyo objetivo es mantener la paz, las cosas empiezan a torcerse y los héroes más poderosos de la Tierra, incluyendo a Iron Man, Capitán América, Thor, El Increíble Hulk, Viuda Negra y Ojo de Halcón, tendrán que afrontar la prueba definitiva cuando el destino del planeta se ponga en juego. Cuando el villano Ultron emerge, le corresponderá a Los Vengadores detener sus terribles planes, que junto a incómodas alianzas llevarán a una inesperada acción que allanará el camino para una épica y única aventura."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":142,"tagline":"","homepage":"","overview":"The Avengers, een buitengewoon team van superhelden bestaande uit Iron Man, Incredible Hulk, Black Widow, Thor, Hawkeye en Captain America komen opnieuw samen om de strijd aan te binden tegen Ultron, een intelligente robot."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Vingadores: A Era de Ultron","runtime":141,"tagline":"Uma nova era chegou.","homepage":"","overview":"Quando Tony Stark e Bruce Banner tentam reativar um programa de manutenção da paz adormecido chamado Ultron, as coisas correm terrivelmente mal e cabe aos heróis mais poderosos da Terra impedir o vilão Ultron de executar o seu terrível plano."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":141,"tagline":"","homepage":"","overview":"Superheltealliancen Avengers har brug for en pause. Deres leder, Tony Stark, genopliver et gammelt fredsprogram, Ultron. Men programmets kunstige intelligens løber løbsk, og Ultron udser sig menneskeheden som sin nye fjende, der må udryddes. Så Iron Man, Captain America, Thor, Hulk, Black Widow, Hawkeye & Co. må på den igen, denne gang bistået af tvillingerne Pietro og Wanda Maximoff og androiden Vision."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Bosszúállók: Ultron kora","runtime":142,"tagline":"Egy új korszak kezdete.","homepage":"http://marvel.com/avengers","overview":"Amikor Tony Stark újra életet akar lehelni a parkolópályára állított békefenntartó programba, nem minden sikerül a tervei szerint. A Föld legnagyobb hőseinek, vagyis Vasembernek, Amerika kapitánynak, Thornak, a Hihetetlen Hulknak, a Fekete Özvegynek és Sólyomszemnek ezúttal a legvégső megmérettetésen kell helytállniuk, mivel a bolygó sorsáról van szó. A rettegett Ultron megjelenésével a Bosszúállókra vár a feladat, hogy megakadályozzák ördögi terve megvalósítását. Az egyedülálló, globális kaland azonban csupán vonakodva megköttetett szövetségek és nem várt események árán teljesedhet ki."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"复仇者联盟2：奥创纪元","runtime":142,"tagline":"超级英雄震撼回归 强势出击力挽狂澜","homepage":"http://marvel.com/avengers","overview":"托尼·斯塔克试图重启一个已经废弃的维和项目，不料该项目却成为危机导火索。世上最强大的超级英雄——钢铁侠、美国队长、雷神、绿巨人、黑寡妇和鹰眼，不得不接受终极考验，拯救危在旦夕的地球。神秘反派奥创逐渐崛起，超级英雄们必须重新集结，竭力阻止奥创实施人类灭绝计划。战斗中，复仇者联盟成员们还遇到了两个新人物——旺达·马克西莫夫和皮特罗·马克西莫夫，以及以全新面目归来的老朋友——幻视。世界秩序濒临崩溃，复仇者联盟必须阻止奥创的阴谋。强敌不断出现，一场空前绝后的全球浩战即将展开……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":141,"tagline":"Ein neues Zeitalter beginnt","homepage":"","overview":"Milliardär, Lebemann und Genie Tony Stark aka Iron Man will ein inaktives Friedensprogramm in Gang bringen, doch dabei geht etwas schief. So taucht der niederträchtige Roboter-Bösewicht Ultron auf und verfolgt Pläne zur Ausrottung der Menschheit. Nun ist es an den Helden, sich wieder zu sammeln und das schreckliche Schicksal der Welt abzuwenden. Zusammen mit Iron Man treten Thor, Captain America, Hulk, Black Widow und Hawkeye dem fiesen Ultron entgegen und bekommen dabei Unterstützung von den ehemaligen S.H.I.E.L.D.-Agenten Nick Fury und Maria Hill. Außerdem kreuzen die geheimnisvollen und mit besonderen Fähigkeiten ausgestatteten Newcomer Wanda und Pietro Maximoff den Weg der Helden, wie auch ein alter Bekannter in neuer Gestalt: Vision. Die Rächer müssen ihre Kräfte vereinen, unsichere Allianzen schmieden und auf unerwartete Aktionen reagieren, um die Bewohner der Erde einmal mehr vor dem drohenden Untergang zu bewahren."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"הנוקמים: עידן אולטרון","runtime":0,"tagline":"דבר לא נמשך לנצח.","homepage":"","overview":"כאשר טוני סטארק מנסה להתניע תכנית של שמירת שלום רדומה, דברים משתבשים וגיבורי העל הגדולים ביותר בכדור הארץ עומדים למבחן האולטימטיבי כשגורלו של כדור הארץ עומד על כף המאזניים. כשאולטרון, נבל טכנולוגיה מבהיל ומרושע עולה ומנסה להכחיד את האנושות, זה תלוי רק בנוקמים לעצור אותו מלממש את תכניותיו הנוראיות. הם נאלצים להתעמת עם שתי דמויות מסתוריות וחדשות: וונדה מקסימוב ופייטרו מקסימוב ופוגשים חבר ישן בחזות חדשה. כל זה מביא אותם לכדי בריתות לא קלות ופעולות בלתי צפויות הסוללות את הדרך לאפוס יוצא דופן של הרפתקה גלובלית."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"المنتقمون  عهد الترون","runtime":0,"tagline":"لقد جاء عصر جديد.","homepage":"","overview":"عندما يحاول الرجل الحديدي (توني ستارك) إعادة إحياء مشروع (حفظ السلام) ، تنحرف الأمور عن مسارها حين يتسبب في خلق ذكاء اصطناعي مدمر يمكنه التخطيط بنفسه ، ومحاولة تطبيق معاييره الفلسفية الجهنمية على البشر ، ويصبح مصير استمرار الحياة على كوكب الأرض معتمدا على نجاح أعتى الرجال الخارقين مثل الرجل الحديدي ، وكابتن أميركا ، والعملاق الأخضر ، والأرملة السوداء ، وهوك ، في مواجهة الذكاء الشرير (ألترون) ، والآن على فريق المنتقمين أن يواجهوا هذا الشر ."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"","runtime":141,"tagline":"","homepage":"","overview":"Tony Stark yrittää käynnistää uudelleen uinuvan rauhanturvaohjelman, mutta asiat menevät pahasti pieleen ja Maailman mahtavimmat sankarit, mukaan lukien Iron Man, Captain America, Thor, The Incredible Hulk, Black Widow ja Hawkeye, joutuvat äärimmäiseen testiin koko planeetan kohtalon ollessa vaakalaudalla. Kun ilkeä Ultron ilmaantuu kuvioihin, Avengersien tehtävä on estää häntä toteuttamasta karmeita suunnitelmiaan, ja pian yllättävä toiminta ja ristiriitaiset liittoutumat johdattavat katsojat eeppiselle ja globaalille seikkailulle."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Отмъстителите: Ерата на Ултрон","runtime":0,"tagline":"Настъпва нова ера","homepage":"","overview":"След извънземната инвазия на Локи, Ник Фюри ще трябва отново да събере Отмъстителите, защото нова заплаха грози човечеството. Танос - злодеят от финалните сцени на първият филм ще отприщи яростта си към Земята."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Εκδικητές: Η Εποχή του Ultron","runtime":142,"tagline":"Μια νέα εποχή έφτασε.","homepage":"","overview":"Όταν ο Tony Stark, μετά την καταστροφή της S.H.I.E.L.D., προσπαθεί να ενεργοποιήσει ένα πρόγραμμα τεχνητής νοημοσύνης που αποσκοπεί στη διατήρηση της τάξης, τα πράγματα δεν πάνε και τόσο καλά. Για την ακρίβεια, πάνε εντελώς στραβά, καθώς δημιουργεί τον Utron, ένα εξελιγμένο ρομπότ που, όμως διακατέχεται από ιδέες μεγαλείου. Οι πανίσχυροι υπερασπιστές του πλανήτη Γη πρέπει να συνασπιστούν κατ’ επειγόντως, για να πάρουν την κατάσταση στα χέρια τους. Καθώς ο μοχθηρός Ultron εγείρεται εναντίον της ανθρωπότητας, οι Εκδικητές είναι οι μοναδικοί που μπορούν να αποκρούσουν τα φρικτά σχέδιά του. Περίεργες και ύπουλες συμμαχίες θα προκύψουν και θα προλειάνουν το έδαφος για μια μοναδική παγκοσμίου βεληνεκούς τιτανομαχία."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Месники: Ера Альтрона","runtime":0,"tagline":"Нова ера почалася.","homepage":"http://www.marvel.com/avengers","overview":"Коли Тоні Старк намагається запустити миротворчу програму, справи йдуть невдало і Наймогутніші Герої Землі стикаються з остаточним випробуванням, оскільки доля планети висить на волосині. З появою штучного інтелекту, Альтрона, тільки “Месники” в змозі зупинити здійснення його страшних планів, і незабаром непрості союзи та несподівані дії відкривають шлях до епічної та унікальної глобальної пригоди."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"","runtime":141,"tagline":"","homepage":"","overview":"Pokus miliardáře Tonyho Starka oživit program na udržení celosvětového míru skončí nezdarem a největší hrdinové světa, včetně Iron Mana, Kapitána Ameriky, Thora, Neuvěřitelného Hulka, Black Widow a Hawkeye musí čelit děsivému nebezpečí. V sázce je osud celé planety. Povstane zlovolný Ultron a jenom Avengers mu mohou zabránit v uskutečnění ďábelských plánů. Nová křehká spojenectví a nečekané zvraty jsou zárukou vzrušujícího a jedinečného akčního dobrodružství globálních rozměrů."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Răzbunătorii: Sub semnul lui Ultron","runtime":141,"tagline":"O eră nouă a venit.","homepage":"","overview":"Bunele intenții fac ravagii atunci când Tony Stark îl creează, fără să vrea, pe Ultron, un monstru care jură că va obține „pacea mondială” prin extincție în masă. Acum, Răzbunătorii trebuie să se regrupeze pentru a-l învinge și a salva omenirea."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"어벤져스: 에이지 오브 울트론","runtime":141,"tagline":"기다림은 끝났다","homepage":"","overview":"토니 스타크는 뉴욕전쟁 때와 같은 사태가 벌어지지 않도록 한때 가동하려다 중단된 휴면 상태의 평화 유지 프로그램을 작동 시키려 한다. 배너 박사와 함께 지구를 지킬 최강의 인공지능 울트론을 탄생시키게 되지만, 울트론은 예상과 다르게 지배를 벗어나 폭주하기 시작하고 어벤져스는 지구의 운명이 걸린 거대한 시험대에 오르게 된다. 울트론이 자신을 복제해 위협을 가하자 이를 저지하기 위해 아이언맨, 캡틴 아메리카, 토르, 헐크, 블랙위도우, 호크아이 등으로 구성된 어벤져스와 새로 합류하게 되는 퀵 실버, 스칼렛 위치 남매와 불안한 동맹을 맺는다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"อเวนเจอร์ส: มหาศึกอัลตรอนถล่มโลก","runtime":0,"tagline":"","homepage":"","overview":"เมื่อโทนี่ย์ สตาร์กได้ริเริ่มโปรแกรมรักษาความสงบและปกป้องสันติภาพของโลก สิ่งที่เกิดขึ้นดูจะผิดพลาดไปเป็นเหตุให้เหล่าซูเปอร์ฮีโร่ผู้กล้าของโลกนี้ที่ประกอบไปด้วยไอรอน แมน, กัปตันอเมริกา, ทอร์, ฮัลค์, แบล็ค ไวโดว์ และฮอร์ค อายส์ พวกเขาทั้งหมดได้เข้าสู่สุดยอดการทดสอบโดยมีชะตากรรมของดาวดวงนี้แขวนอยู่บนเส้นด้าย ด้วยการปรากฏตัวของอัลตรอน ทำให้ทีมอเวนเจอร์สต้องช่วยกันหยุดยั้งเขาจากแผนการอันชั่วร้ายนี้ การร่วมตัวกันที่ไม่ใช่เรื่องง่ายและสุดจะคาดคิดในไม่ช้านี้จะเป็นการปูทางไปสู่การผจญภัยทั่วโลกอันยิ่งใหญ่ที่ไม่เคยเกิดขึ้นมาก่อน\""},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Yenilmezler: Ultron Çağı","runtime":144,"tagline":"Yeni bir çağ başlıyor","homepage":"","overview":"Iron Man Tony Stark önderliğinde bir grup süper kahraman, aktif olarak kullanılmayan bir barışı koruma programını gerçekleştirmek isterler, ancak işler çığrından çıkar ve insan yapımı bir yapay zeka olan Ultron'un eline, hain planlarını gerçekleştirme fırsatı geçer. Süper kahramanlar onu durdurabilmek için bir kez daha güç birliği yapmak zorundadır. Tüm dünyaya yayılan bir savaş başlayacaktır.  Filmde Robert Downey Jr. Scarlett Johansson, Mark Ruffalo ve daha birçok popüler aktör rol alırken, James Spader, Ultron'a sesiyle hayat veriyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"アベンジャーズ／エイジ・オブ・ウルトロン","runtime":142,"tagline":"愛を知る──全人類に捧ぐ。","homepage":"https://marvel.disney.co.jp/movie/avengers","overview":"アイアンマンことトニー・スタークが完成させた人工知能“ウルトロン”の暴走に端を発する、ヒーローたちによる愛する者たちを救うための戦いをダイナミックに描く。人類の危機的状況を何度も打破してきたアイアンマンことトニー・スタークは、平和維持システムとしての人工知能“ウルトロン”を誕生させる。人類を脅威から守るために完成させたウルトロンであったが、平和を脅かす唯一の存在は人類だと結論付け、抹消しようとする。監督は、前作でもメガホンを取ったジョス・ウェドン。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":141,"tagline":"","homepage":"","overview":"När Tony Stark försöker starta ett fredsbevarande program går det snett. Jordens framtid är hotad och Iron Man, Captain America, Thor, Hulk, Black Widow samt Hawkeye sätts alla nu på prov. När den onde Ultron träder fram är det upp till medlemmarna i Avengers att stoppa honom från att sätta sina planer till verket, vilket leder till ett episkt, unikt och världsomspännande äventyr."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Avengers: Vek Ultrona","runtime":141,"tagline":"","homepage":"","overview":"Pokus miliardára Tonyho Starka oživiť program na udržanie celosvetového mieru sa skončil neúspechom. Navyše jeho tím nechtiac prebudil ničivé sily neznámej umelej inteligencie, ktorá chce vyhladiť nedokonalé ľudstvo z povrchu Zeme, a zrazu je v stávke osud celej planéty. Po zásahu proti zločineckej spoločnosti Hydra a analýze kameňa z Lokiho žezla povstal zlovoľný ničiteľ Ultron, ktorý plánuje zničiť svojich protivníkov - tím Avengers, a potom celé ľudstvo, pretože je zúfalo nedokonalé. Ochrancovia Zeme a najväčší superhrdinovia sa musia znova spojiť, aby zachránili svet."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Nastavak megahita \"Osvetnici\" iz 2012. godine. Ovog puta se Osvetnici (Iron Man, Captain America, Thor, Hulk, Black Widow i Hawkeye, uz potporu Nicka Furyja i Marije Hill) suprostavljaju novom negativcu, inteligentnom robotu Ultronu (James Spader), koji ima kompleks Boga, mrzi svoje tvorce ljude i želi pokoriti Zemlju i naseliti je robotima sličnim sebi koje sam stvara. Osvetnici će susresti moćne blizance, Pietra i Wandu Maximoff, tj. Quicksilvera i Scarlet Witch kao i Visiona."},"name":"Bosanski","iso_639_1":"bs","iso_3166_1":"BS","english_name":"Bosnian"},{"data":{"title":"Osvetnici 2: Vladavina Ultrona","runtime":0,"tagline":"Došlo je novo doba.","homepage":"","overview":"Nakon uspješne racije Hydrine baze, Tony Stark i Bruce Banner stvore umjetnu inteligenciju zvanu Ultron, koji je dizajniran da pomogne Avengersima očuvati mir u svijetu i zaštititi ih od njihovih neprijatelja. No, stvari pođu po zlu kada Ultron uvidi da je ljudska rasa sama sebi neprijatelj, te odluči uništiti ju, kao i same Avengerse. Iron Man, Captain America, Hulk, Black Widow i Hawkeye sada se moraju ponovno okupiti kako bi zaustavili Ultrona, a osim toga tu su i novi neprijatelji koji će im pokušati stati na put."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Saat Tony Stark (Robert Downey Jr) memutuskan untuk membuat program perdamaian. Tony menciptakan robot cerdas Ultron untuk menggantikan peran Iron Man, Captain America, Thor, The Incredible Hulk, Black Widow dan Hawkeye. Tapi Ternyata Ultron mampu berfikir dan memiliki niat jahat yang sangat mengerikan.  Ultron kini menjadi musuh bersama tim Avengers. Tidak mudah bagi tim untuk membasmi Ultron disaat mereka terancam tercerai berai karena berbeda pendapat. Tim Avengers harus bisa menghentikan rencana jahat Ultron dan membangun kekuatan bersama untuk menyelamatkan bumi dari kehancuran."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"বাংলা","iso_639_1":"bn","iso_3166_1":"BD","english_name":"Bengali"},{"data":{"title":"انتقام جویان: عصر آلترون","runtime":0,"tagline":"","homepage":"","overview":"تونی استارک روی یک پروژه برای حفظ صلح کار می کند، اما اوضاع از کنترلش خارج می شود و اکنون گروه انتقام جویان باید آلترون، ساخته ی دست استارک را، از رسیدن به اهداف شریرانه اش باز دارند..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Vingadores: Era de Ultron","runtime":141,"tagline":"Começa uma nova era.","homepage":"","overview":"Ao tentar proteger o planeta de ameaças, Tony Stark constrói um sistema de inteligência artificial que cuidaria da paz mundial. O projeto acaba dando errado e gera o nascimento do Ultron. Com o destino da Terra em jogo, os Vingadores terão que se unir para mais uma vez salvar a raça humana da extinção."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"復仇者聯盟：奧創紀元","runtime":0,"tagline":"超級英雄震撼回歸 強勢出擊力挽狂瀾","homepage":"","overview":"「鋼鐵人」東尼史塔克為了維護地球和平安全，神盾局瓦解後，把史塔克大樓改成新的復仇者基地。鋼鐵人在圍剿九頭蛇時，中了汪達的幻術魔法，認為地球無力抵抗外星人入侵，於是打造人工智慧機器人「奧創」，不料奧創自行進化，卻認為唯有殲滅人類，才能維護世界和平。而後奧創與汪達結盟，黑寡婦、美國隊長與雷神索爾接連中了汪達的幻術，心中的夢魘陰影化成幻覺浮現眼前，浩克大搞破壞，鋼鐵人只好穿上「浩克毀滅者」來制服。復仇者們遭逢前所未見的心理戰猛攻，潰不成軍。他們要如何克服自己的陰影，重新集結，打敗奧創呢?"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Avengers 2: Era de Ultrón","runtime":141,"tagline":"Una nueva era comienza.","homepage":"","overview":"Cuando Tony Stark y Bruce Banner intentan poner en marcha un inactivo programa de mantenimiento de la paz llamado Ultrón, las cosas van terriblemente mal y depende de los héroes más poderosos de la Tierra evitar que el villano Ultrón lleve a cabo su terrible plan."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Avengers : L'ère d'Ultron","runtime":141,"tagline":"Une nouvelle ère est venue.","homepage":"","overview":"Après avoir défait l'Hydra et récupéré le sceptre de Loki, contenant la pierre de l'esprit, Tony Stark, aidé de Bruce Banner, tente une expérience scientifique avec celle-ci, pour créer une intelligence artificielle supérieure à Jarvis. Pourtant, l'expérimentation tourne mal et naît Ultron, une conscience robotisée aux desseins machiavéliques. Les Avengers devront unir leurs forces pour le vaincre, mais plusieurs obstacles seront mis sur leur chemin. Ils devront notamment affronter deux êtres optimisés, Scarlet Witch et Quicksilver, issus de l'armée de Strucker et de l'Hydra, qui se joindront au rang d'Ultron."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"შურისმაძიებლები: ალტრონის ერა","runtime":0,"tagline":"","homepage":"","overview":"სიკველის სიუჟეტის მოვლენები დატრიალდება ახალი საერთო პრობლემის გარშემო - ულტრონის სახით - ხელოვნური ინტელექტი, რომელიც იყო შექმნილი დედამიწის მაცხოვრებლების დასაცავად. მიუხედავად თავისი დანიშნულებისა, კაცობრიობის ყველაზე მთავარ საფრთხედ ის აღმოაჩინა ზუსტად ადამიანებში. თუ “შურისმაძიებლების” გუნდი ვერ მოახერხებს მის შეჩერებას, მაშინ დედამიწაზე დადგება ახალი ერა, სადაც არ იქნება არცერთი ადამიანი."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Осветници: Ера Алтрона","runtime":0,"tagline":"Дошло је ново доба.","homepage":"","overview":"Кад Тони Старк покуша да пробуди успавани програм за одржавање мира, ствари ће кренути по злу и највећи светски хероји: Ајронмен, Капетан Америка, Тор, Невероватни Хулк, Црна Удовица и Хокај стављени су на највећи тест док судбина планете буде висила о концу. Кад се страшни Алтрон појави, Осветници ће морати да га спрече да оствари своје опаке планове и ускоро ће овај невероватни савез прокрчити пут епској и јединственој авантури по целом свету."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Atriebēji: Ultrona laikmets","runtime":141,"tagline":"","homepage":"","overview":"Cilvēce atrodas uz iznīcības robežas. Ultrons - mākslīgais intelekts, kurš bija radīts, lai aizsargātu Zemi no ārējiem ienaidniekiem, ir kļuvis par ienaidnieku pašai cilvēcei. Vienīgie, kas var mest izaicinājumu tik neapturamam pretiniekam, ir Atriebēji. Taču Ultrons ir pārāk spēcīgs - viņa laikmets ir sācies un tajā nav paredzēta vieta cilvēkiem."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Tony Stark skaper Ultron ved en feil, et grusomt monster som vil utrydde menneskene. Nå må Iron Man, Captain America, Thor og Hulken – sammen med Black Widow, Hawkeye og Nick Fury gjenforenes for å beseire Ultron og redde menneskeheten... om de kan!"},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Keršytojai. Altrono amžius","runtime":0,"tagline":"","homepage":"","overview":"Geležinis žmogus – Tonis Starkas (akt. Robertas Downey‘is Jaunesnysis) – milijardierius, filantropas, mergišius ir technologijų genijus, sukuria dar vieną šedevrą – intelektualų ir itin galingą robotą Altroną. Tonio tikslai buvo kilnūs, tačiau naujasis jo kūrinys manė kitaip – jis tampa pasaulį užvaldyti trokštančiu monstru. Piktasis Altronas pasėja paniką visame pasaulyje. Jis toks rūstus ir stiprus, kad kelią jam užkirsti gali tik savo jėgas suvienyję drąsiausi žemės superherojai – Geležinis žmogus, Kapitonas Amerika, Toras, Juodoji našlė ir Sakalo akis. Bet, kad jiems būtų dar sudėtingiau – į veiksmą įsitraukia ir paslaptingi bei pavojingi naujokai Wanda Miximoff (akt. Elizabeth Olsen) ir Pietro Maximoff (akt. Aaronas Tayloras-Johnsonas). Visi kartu jie mėgins užgesinti Žemėje Altrono užkurtą pragarą."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"復仇者聯盟 2：奧創紀元","runtime":141,"tagline":"","homepage":"","overview":"Marvel 英雄最強集結 捲入超視覺空前巨戰 東尼史達 (羅拔唐尼 飾) 執意研究神秘晶石的強大力量，竟意外製造出邪惡機械生命體奧創！為打倒這頭矢志殲滅人類的惡魔，鐵甲奇俠、美國隊長 (基斯伊雲斯 飾)、雷神奇俠 (基斯咸士禾夫 飾)、變形俠醫 (麥克雷法路 飾) 再次結集，聯同黑寡婦 (施嘉莉祖安遜 飾)、鷹眼 (謝洛美維納 飾) 及費局長 (森姆積遜 飾) 等戰友緊急出動……而獨具犀利異能的閃銀 (艾倫莊遜 飾)、紅女巫 (伊莉莎白奧爾森 飾) 與幻視亦會加入戰團，勢必引爆空前轟烈的超視覺激鬥！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Qasoskorlar: Altron Davri","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ozbek","iso_639_1":"uz","iso_3166_1":"UZ","english_name":"Uzbek"},{"data":{"title":"Maščevalci: Ultronova doba","runtime":0,"tagline":"","homepage":"","overview":"Po uničenju O.B.O.D.-a in razhodu Maščevalcev želi Tony Stark človeštvu pomagati s pomočjo spečega robotskega programa Ultron. Toda prebujena umetna inteligenca se obrne proti ljudem in jim napove popolno uničenje, zato morajo Iron Man, Stotnik Amerika, Hulk, Thor, Sokol in Črna vdova znova združiti moči in se v vrtincu vratolomnih spopadov soočiti z neizprosnim nasprotnikom."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Venjadors: L’era d’Ultron","runtime":0,"tagline":"Una nova era comença.","homepage":"","overview":"Quan Tony Stark intenta reactivar un programa caigut en desús l'objectiu del qual és mantenir la pau, les coses comencen a torçar-se i els herois més poderosos de la Terra, incloent Iron Man, Capità Amèrica, Thor, L'Increïble Hulk, Vídua Negra i Ull de Falcó, hauran d'afrontar la prova definitiva quan el destí del planeta es posi en joc. Quan el malvat Ultron emergeix, correspondrà als Venjadors aturar els seus terribles plans, que juntament amb incòmodes aliances portaran a una inesperada acció que aplanarà el camí per a una èpica i única aventura."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"अवेंजर्स 2: कलयुग का महायुद्ध","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"Tasujad: Ultroni ajastu","runtime":0,"tagline":"","homepage":"","overview":"Just siis, kui Tony Stark üritab käivitada suurejoonelist rahuvalveprogrammi, hakkavad asjad täielikult allamäge minema, mis tähendab seda, et taaskord peavad oma rusikad kokku lööma maailma kõige suursugusemad kangelased - Raudmees, Kapten Ameerika, Thor, Hulk, Must Lesk ja Kullisilm -, et alistada oma vastane Ultron, kelle tõttu ripub planeedi saatus juuksekarva otsas."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"}],"reviews_tmdb":[{"id":"56351986c3a3681b59017d48","url":"https://www.themoviedb.org/review/56351986c3a3681b59017d48","author":"Hotsake","content":"There is a lot going on in this movie but it all just seemed kind of pointless and dull to me. Every now and then there would be a good scene or piece of dialogue but for the most part I felt myself getting bored and reaching for my phone to play Cribbage. I guess what I didn't like most is that it all felt like a big filler episode instead of an action packed character driven story arc.","created_at":"2015-10-31T19:41:58.194Z","updated_at":"2021-06-23T15:57:38.244Z","author_details":{"name":"","rating":6.5,"username":"Hotsake","avatar_path":null}},{"id":"5804e364c3a3686a3400000e","url":"https://www.themoviedb.org/review/5804e364c3a3686a3400000e","author":"Andres Gomez","content":"Action, good Fx and a \"not-completely-absurd\" story. The actors perform well and you can identify them very well with their characters ... but it is all old and without imagination.\r\n\r\nI suppose nobody was expecting anything else, though ...","created_at":"2016-10-17T14:42:44.693Z","updated_at":"2021-06-23T15:57:51.666Z","author_details":{"name":"Andres Gomez","rating":7,"username":"tanty","avatar_path":null}},{"id":"5a66d16ec3a3680cfb006191","url":"https://www.themoviedb.org/review/5a66d16ec3a3680cfb006191","author":"Per Gunnar Jonsson","content":"$11","created_at":"2018-01-23T06:08:46.790Z","updated_at":"2024-05-16T15:21:16.153Z","author_details":{"name":"Per Gunnar Jonsson","rating":7,"username":"Dark Jedi","avatar_path":null}},{"id":"5b1678d7c3a3685352018aad","url":"https://www.themoviedb.org/review/5b1678d7c3a3685352018aad","author":"Gimly","content":"$12","created_at":"2018-06-05T11:49:43.675Z","updated_at":"2021-06-23T15:58:09.355Z","author_details":{"name":"Gimly","rating":7,"username":"Ruuz","avatar_path":"/xUObnJSvHrFPsIpoDmb1jiQZLq7.jpg"}},{"id":"5c842655c3a3684e95db3e38","url":"https://www.themoviedb.org/review/5c842655c3a3684e95db3e38","author":"tmdb44006625","content":"The fact that Joss Whedon was able to salvage some sort of coherent film out of all he was forced to cram into a single movie is quite commendable. But the sad fact is that Avengers: Age of Ultron is really just a run of the mill \"bad guy wants to destroy the world for reasons\" actioner that we've seen done better many times before.\r\n\r\nDon't get me wrong. The movie's fun. The dialogue is frequently clever and humourous. And I really appreciated the quiet bits of storytelling that Whedon was able to sneak in. It's just that at the end of the day, the villain is weak sauce, there's way too much set up for other movies, and if I'm criticizing Man of Steel for having excessive destruction, I can't give Avengers a pass since they needlessly blow up not one, not two, but three cities. Pretty sure many insurance agencies went bankrupt paying out all the victims.","created_at":"2019-03-09T20:47:17.431Z","updated_at":"2021-06-23T15:58:19.186Z","author_details":{"name":"","rating":5,"username":"tmdb44006625","avatar_path":null}},{"id":"5dc32f5299259c00187a12c4","url":"https://www.themoviedb.org/review/5dc32f5299259c00187a12c4","author":"Justin Lopez","content":"Movie was great but felt like there was just too much action and fighting. The creativity of the choreography gets lost in the whirlwind of action and this I noticed most in Captain America's scenes. He does like a hundred different awesome things with his shield, but you don't have time to really take it in because you're already looking at Iron Man blasting 20 Ultron-bots to bits.","created_at":"2019-11-06T20:38:42.032Z","updated_at":"2021-06-23T15:58:28.578Z","author_details":{"name":"Justin Lopez","rating":null,"username":"ShawnSmith","avatar_path":"/5zwo9rNpYTQxPFxXJeYHxEw86SC.jpg"}},{"id":"5dc389ff8d22fc00143d1db1","url":"https://www.themoviedb.org/review/5dc389ff8d22fc00143d1db1","author":"LoganWright","content":"This is the movie where Captain America became my favorite Avenger. Sure he doesn't have monstrous abilities like Iron Man and Hulk, but to be holding his own on the same ground as them is just a testament to how great of a hero he truly is.","created_at":"2019-11-07T03:05:35.729Z","updated_at":"2021-06-23T15:58:28.637Z","author_details":{"name":"LoganWright","rating":null,"username":"LoganWright1","avatar_path":"/4o5phid5homM5vcwwEE3Mg6FS4H.jpg"}},{"id":"5dc393227d2bc100133d151b","url":"https://www.themoviedb.org/review/5dc393227d2bc100133d151b","author":"BradleyStewart","content":"It has become a well-known fact that coming out with a sequel that's better than, if not on par with, the first one is an insane task. But kudos to Marvel for staying true to their colors with this sequel.","created_at":"2019-11-07T03:44:34.837Z","updated_at":"2021-06-23T15:58:28.689Z","author_details":{"name":"BradleyStewart","rating":null,"username":"BradleyStewart","avatar_path":"/orXNhkMKAAHKVhIKS3DD8I6jnxd.jpg"}},{"id":"5dc399569d89390013350f9f","url":"https://www.themoviedb.org/review/5dc399569d89390013350f9f","author":"Jane Hall","content":"I expected more from Quicksilver.  He would've been a great addition to the Avengers.","created_at":"2019-11-07T04:11:02.061Z","updated_at":"2021-06-23T15:58:28.729Z","author_details":{"name":"Jane Hall","rating":null,"username":"JaneHall","avatar_path":"/jJy4oZdlQp1BkqaEiWlCeBzPxDV.jpg"}},{"id":"5dc56e74470ead00189063a7","url":"https://www.themoviedb.org/review/5dc56e74470ead00189063a7","author":"JessieCollins","content":"The thing that puzzles me is that in this film, Vision is presented to be a powerful hero, having the mind stone and all. But on the next films, he's become more of like a side character that just wasn't relevant anymore except for that little piece of stone on his forehead. Shame.","created_at":"2019-11-08T13:32:36.277Z","updated_at":"2021-06-23T15:58:28.780Z","author_details":{"name":"JessieCollins","rating":null,"username":"JessieCollins","avatar_path":"/gW1joveFfv736XrPgXOSpNgj8ju.jpg"}},{"id":"5dc579e46f8d950017c29a57","url":"https://www.themoviedb.org/review/5dc579e46f8d950017c29a57","author":"John Smith","content":"I'm glad to see that they found another role for Hawkeye other than being that one guy who seemed to be trying hard to keep up with the other more powerful heroes on the team. Now he's more of like the thing that keeps the team together and it suits his character well.","created_at":"2019-11-08T14:21:24.351Z","updated_at":"2021-06-23T15:58:28.816Z","author_details":{"name":"John Smith","rating":null,"username":"1JohnSmith1","avatar_path":"/3pdg3XNVdCkOs17PrCXnDxpmNyp.jpg"}},{"id":"5e00e910d1a89300198cbe02","url":"https://www.themoviedb.org/review/5e00e910d1a89300198cbe02","author":"Justin Lopez","content":"Movie was great but felt like there was just too much action and fighting. The creativity of the choreography gets lost in the whirlwind of action and this I noticed most in Captain America's scenes. He does like a hundred different awesome things with his shield, but you don't have time to really take it in because you're already looking at Iron Man blasting 20 Ultron-bots to bits.","created_at":"2019-12-23T16:19:28.195Z","updated_at":"2021-06-23T15:58:30.410Z","author_details":{"name":"Justin Lopez","rating":null,"username":"ShawnSmith","avatar_path":"/5zwo9rNpYTQxPFxXJeYHxEw86SC.jpg"}},{"id":"5e00ee6875110d0011d84af1","url":"https://www.themoviedb.org/review/5e00ee6875110d0011d84af1","author":"1RobertJohnson1","content":"Avengers: Age of Ultron\r\nI liked plenty of the stuff in it but it was pretty much the same as the first movie. Still a good watch though if you're not looking for anything serious.","created_at":"2019-12-23T16:42:16.041Z","updated_at":"2021-06-23T15:58:30.425Z","author_details":{"name":"","rating":null,"username":"1RobertJohnson1","avatar_path":null}},{"id":"5e01023d0284200019af5170","url":"https://www.themoviedb.org/review/5e01023d0284200019af5170","author":"MichaelWilliams","content":"The humor in this movie was not as witty as the first one. It felt too childish and cheesy.","created_at":"2019-12-23T18:06:53.750Z","updated_at":"2021-06-23T15:58:30.468Z","author_details":{"name":"","rating":null,"username":"MichaelWilliams","avatar_path":null}},{"id":"5e011ad70284200016af7e51","url":"https://www.themoviedb.org/review/5e011ad70284200016af7e51","author":"WilliamJones","content":"Still good, clean Avengers fun though a bit messier. The first one was still better.","created_at":"2019-12-23T19:51:51.123Z","updated_at":"2021-06-23T15:58:30.508Z","author_details":{"name":"","rating":null,"username":"WilliamJones","avatar_path":null}},{"id":"5e02863c26dac10012674860","url":"https://www.themoviedb.org/review/5e02863c26dac10012674860","author":"DavidBrown1","content":"With the vast array of heroes and their own personal character stories, you can expect how much of a challenge it is to bring together all these superheroes and have them work on a single mission on a single timeline. It's not easy, experts.","created_at":"2019-12-24T21:42:20.693Z","updated_at":"2021-06-23T15:58:30.591Z","author_details":{"name":"","rating":null,"username":"DavidBrown1","avatar_path":null}},{"id":"5e08fd574a2226001728f48c","url":"https://www.themoviedb.org/review/5e08fd574a2226001728f48c","author":"JosephWilson","content":"I confirmed in this movie that what's really making these films successful is the chemistry that the actors have. You can really see that everyone's doing their best.","created_at":"2019-12-29T19:24:07.133Z","updated_at":"2021-06-23T15:58:30.935Z","author_details":{"name":"","rating":null,"username":"JosephWilson","avatar_path":"/8S3UwmIBCOLKVjfx2sKJeSgrRaF.jpg"}},{"id":"5e091e34a1c59d0018ab0aea","url":"https://www.themoviedb.org/review/5e091e34a1c59d0018ab0aea","author":"richardmiller","content":"Strong film from beginning to end. Has just enough humor, angst, and drama to make it a film worthy to be called a sequel.","created_at":"2019-12-29T21:44:20.547Z","updated_at":"2021-06-23T15:58:30.979Z","author_details":{"name":"","rating":null,"username":"richardmiller","avatar_path":"/1K04FeI31vKVrrudHBHLbEYGxNX.jpg"}},{"id":"5e09b6c91684f700159c39d1","url":"https://www.themoviedb.org/review/5e09b6c91684f700159c39d1","author":"ThomasMoore","content":"If you're a fan of action, suspense, and awe worthy moments, then this movie is the right fit for you! Overall outstanding performance by everyone both on and off screen.","created_at":"2019-12-30T08:35:21.957Z","updated_at":"2021-06-23T15:58:31.081Z","author_details":{"name":"","rating":null,"username":"ThomasMoore","avatar_path":"/39b4G3bZAotuY6uTMoI3JKdcO3c.jpg"}},{"id":"5e0e0c5468b1ea00187f406e","url":"https://www.themoviedb.org/review/5e0e0c5468b1ea00187f406e","author":"JeffreyYoung","content":"Despite the challenge of having to top their first Avengers film, Marvel did beautifully and the result was amazing. I hope to see more films like this in the future.","created_at":"2020-01-02T15:29:24.122Z","updated_at":"2021-06-23T15:58:31.260Z","author_details":{"name":"","rating":null,"username":"JeffreyYoung","avatar_path":null}}],"recommendations":[{"id":102899,"adult":false,"title":"Ant-Man","video":false,"overview":"Armed with the astonishing ability to shrink in scale but increase in strength, master thief Scott Lang must embrace his inner-hero and help his mentor, Doctor Hank Pym, protect the secret behind his spectacular Ant-Man suit from a new generation of towering threats. Against seemingly insurmountable obstacles, Pym and Lang must plan and pull off a heist that will save the world.","genre_ids":[878,12,28],"media_type":"movie","popularity":12.3752,"vote_count":20641,"poster_path":"/rQRnQfUl3kfp78nCWq8Ks04vnq1.jpg","release_date":"2015-07-14","vote_average":7.065,"backdrop_path":"/1K3JmSNUN8OpjYsCjc0Hy0SYxAb.jpg","original_title":"Ant-Man","original_language":"en"},{"id":271110,"adult":false,"title":"Captain America: Civil War","video":false,"overview":"Following the events of Age of Ultron, the collective governments of the world pass an act designed to regulate all superhuman activity. This polarizes opinion amongst the Avengers, causing two factions to side with Iron Man or Captain America, which causes an epic battle between former allies.","genre_ids":[12,28,878],"media_type":"movie","popularity":13.608,"vote_count":23762,"poster_path":"/rAGiXaUfPzY7CDEyNKUofk3Kw2e.jpg","release_date":"2016-04-27","vote_average":7.446,"backdrop_path":"/wdwcOBMkt3zmPQuEMxB3FUtMio2.jpg","original_title":"Captain America: Civil War","original_language":"en"},{"id":299536,"adult":false,"title":"Avengers: Infinity War","video":false,"overview":"As the Avengers and their allies have continued to protect the world from threats too large for any one hero to handle, a new danger has emerged from the cosmic shadows: Thanos. A despot of intergalactic infamy, his goal is to collect all six Infinity Stones, artifacts of unimaginable power, and use them to inflict his twisted will on all of reality. Everything the Avengers have fought for has led up to this moment - the fate of Earth and existence itself has never been more uncertain.","genre_ids":[12,28,878],"media_type":"movie","popularity":31.1023,"vote_count":31520,"poster_path":"/7WsyChQLEftFiDOVTGkv3hFpyyt.jpg","release_date":"2018-04-25","vote_average":8.234,"backdrop_path":"/mDfJG3LC3Dqb67AZ52x3Z0jU0uB.jpg","original_title":"Avengers: Infinity War","original_language":"en"},{"id":24428,"adult":false,"title":"The Avengers","video":false,"overview":"When an unexpected enemy emerges and threatens global safety and security, Nick Fury, director of the international peacekeeping agency known as S.H.I.E.L.D., finds himself in need of a team to pull the world back from the brink of disaster. Spanning the globe, a daring recruitment effort begins!","genre_ids":[878,28,12],"media_type":"movie","popularity":50.7557,"vote_count":36090,"poster_path":"/RYMX2wcKCBAr24UyPD7xwmjaTn.jpg","release_date":"2012-04-25","vote_average":7.951,"backdrop_path":"/pGFQCp12a8andfPlpnmXz44IIvY.jpg","original_title":"The Avengers","original_language":"en"},{"id":168259,"adult":false,"title":"Furious 7","video":false,"overview":"Deckard Shaw seeks revenge against Dominic Toretto and his family for his comatose brother.","genre_ids":[28,80,53],"media_type":"movie","popularity":9.0259,"vote_count":11149,"poster_path":"/ktofZ9Htrjiy0P6LEowsDaxd3Ri.jpg","release_date":"2015-04-01","vote_average":7.219,"backdrop_path":"/ehzI1mVcnHqB58NqPyQwpMqcVoz.jpg","original_title":"Furious 7","original_language":"en"},{"id":100402,"adult":false,"title":"Captain America: The Winter Soldier","video":false,"overview":"After the cataclysmic events in New York with The Avengers, Steve Rogers, aka Captain America is living quietly in Washington, D.C. and trying to adjust to the modern world. But when a S.H.I.E.L.D. colleague comes under attack, Steve becomes embroiled in a web of intrigue that threatens to put the world at risk. Joining forces with the Black Widow, Captain America struggles to expose the ever-widening conspiracy while fighting off professional assassins sent to silence him at every turn. When the full scope of the villainous plot is revealed, Captain America and the Black Widow enlist the help of a new ally, the Falcon. However, they soon find themselves up against an unexpected and formidable enemy—the Winter Soldier.","genre_ids":[28,12,878],"media_type":"movie","popularity":6.7637,"vote_count":19753,"poster_path":"/tVFRpFw3xTedgPGqxW0AOI8Qhh0.jpg","release_date":"2014-03-20","vote_average":7.654,"backdrop_path":"/1RWLMyC9KcFfcaoViMiJGSSZzzr.jpg","original_title":"Captain America: The Winter Soldier","original_language":"en"},{"id":118340,"adult":false,"title":"Guardians of the Galaxy","video":false,"overview":"Light years from Earth, 26 years after being abducted, Peter Quill finds himself the prime target of a manhunt after discovering an orb wanted by Ronan the Accuser.","genre_ids":[28,878,12],"media_type":"movie","popularity":9.5371,"vote_count":29353,"poster_path":"/r7vmZjiyZw9rpJMQJdXpjgiCOk9.jpg","release_date":"2014-07-30","vote_average":7.905,"backdrop_path":"/vmBSlRZYKfNdaDZ7wGkrSNbmdMI.jpg","original_title":"Guardians of the Galaxy","original_language":"en"},{"id":207703,"adult":false,"title":"Kingsman: The Secret Service","video":false,"overview":"The story of a super-secret spy organization that recruits an unrefined but promising street kid into the agency's ultra-competitive training program just as a global threat emerges from a twisted tech genius.","genre_ids":[80,35,28,12],"media_type":"movie","popularity":10.7587,"vote_count":17595,"poster_path":"/r6q9wZK5a2K51KFj4LWVID6Ja1r.jpg","release_date":"2015-01-24","vote_average":7.62,"backdrop_path":"/qzUIOTk0E3F1zjvYjcBRTKUTgf9.jpg","original_title":"Kingsman: The Secret Service","original_language":"en"},{"id":299534,"adult":false,"title":"Avengers: Endgame","video":false,"overview":"After the devastating events of Avengers: Infinity War, the universe is in ruins due to the efforts of the Mad Titan, Thanos. With the help of remaining allies, the Avengers must assemble once more in order to undo Thanos' actions and restore order to the universe once and for all, no matter what consequences may be in store.","genre_ids":[12,878,28],"media_type":"movie","popularity":18.84,"vote_count":27290,"poster_path":"/ulzhLuWrPK07P1YkdWQLZnQh1JL.jpg","release_date":"2019-04-24","vote_average":8.236,"backdrop_path":"/7RyHsO4yDXtBv1zUU3mTpHeQ0d5.jpg","original_title":"Avengers: Endgame","original_language":"en"},{"id":10195,"adult":false,"title":"Thor","video":false,"overview":"Against his father Odin's will, The Mighty Thor - a powerful but arrogant warrior god - recklessly reignites an ancient war. Thor is cast down to Earth and forced to live among humans as punishment. Once here, Thor learns what it takes to be a true hero when the most dangerous villain of his world sends the darkest forces of Asgard to invade Earth.","genre_ids":[12,14,28],"media_type":"movie","popularity":11.703,"vote_count":22091,"poster_path":"/prSfAi1xGrhLQNxVSUFh61xQ4Qy.jpg","release_date":"2011-04-21","vote_average":6.768,"backdrop_path":"/cDJ61O1STtbWNBwefuqVrRe3d7l.jpg","original_title":"Thor","original_language":"en"},{"id":76341,"adult":false,"title":"Mad Max: Fury Road","video":false,"overview":"An apocalyptic story set in the furthest reaches of our planet, in a stark desert landscape where humanity is broken, and most everyone is crazed fighting for the necessities of life. Within this world exist two rebels on the run who just might be able to restore order.","genre_ids":[28,12,878],"media_type":"movie","popularity":14.7289,"vote_count":23775,"poster_path":"/hA2ple9q4qnwxp3hKVNhroipsir.jpg","release_date":"2015-05-13","vote_average":7.629,"backdrop_path":"/l0eIS009XtEO80aC6zjM3o3AkEl.jpg","original_title":"Mad Max: Fury Road","original_language":"en"},{"id":262500,"adult":false,"title":"Insurgent","video":false,"overview":"Beatrice Prior must confront her inner demons and continue her fight against a powerful alliance which threatens to tear her society apart.","genre_ids":[28,878,53],"media_type":"movie","popularity":5.3913,"vote_count":10333,"poster_path":"/dP5Fb6YRfzmCQtRbHOr2kO7tJW9.jpg","release_date":"2015-03-18","vote_average":6.363,"backdrop_path":"/8YNNyQiPZlF9qv5EGOUK20mnXVk.jpg","original_title":"Insurgent","original_language":"en"},{"id":1771,"adult":false,"title":"Captain America: The First Avenger","video":false,"overview":"During World War II, Steve Rogers is a sickly man from Brooklyn who's transformed into super-soldier Captain America to aid in the war effort. Rogers must stop the Red Skull – Adolf Hitler's ruthless head of weaponry, and the leader of an organization that intends to use a mysterious device of untold powers for world domination.","genre_ids":[28,12,878],"media_type":"movie","popularity":7.4408,"vote_count":22474,"poster_path":"/vSNxAJTlD0r02V9sPYpOjqDZXUK.jpg","release_date":"2011-07-22","vote_average":7.004,"backdrop_path":"/yFuKvT4Vm3sKHdFY4eG6I4ldAnn.jpg","original_title":"Captain America: The First Avenger","original_language":"en"},{"id":122917,"adult":false,"title":"The Hobbit: The Battle of the Five Armies","video":false,"overview":"Following Smaug's attack on Laketown, Bilbo and the dwarves try to defend Erebor's mountain of treasure from others who claim it: the men of the ruined Laketown and the elves of Mirkwood. Meanwhile an army of Orcs led by Azog the Defiler is marching on Erebor, fueled by the rise of the dark lord Sauron. Dwarves, elves and men must unite, and the hope for Middle-Earth falls into Bilbo's hands.","genre_ids":[28,12,14],"media_type":"movie","popularity":19.7363,"vote_count":15119,"poster_path":"/xT98tLqatZPQApyRmlPL12LtiWp.jpg","release_date":"2014-12-10","vote_average":7.331,"backdrop_path":"/3UbaCMmqOd7mca4Y5DOzY2ZVTyX.jpg","original_title":"The Hobbit: The Battle of the Five Armies","original_language":"en"},{"id":76338,"adult":false,"title":"Thor: The Dark World","video":false,"overview":"Thor fights to restore order across the cosmos… but an ancient race led by the vengeful Malekith returns to plunge the universe back into darkness. Faced with an enemy that even Odin and Asgard cannot withstand, Thor must embark on his most perilous and personal journey yet, one that will reunite him with Jane Foster and force him to sacrifice everything to save us all.","genre_ids":[28,12,14],"media_type":"movie","popularity":8.9375,"vote_count":18111,"poster_path":"/wp6OxE4poJ4G7c0U2ZIXasTSMR7.jpg","release_date":"2013-10-30","vote_average":6.51,"backdrop_path":"/4zTsF0RtO0av3YX1NaKDqGKPxYF.jpg","original_title":"Thor: The Dark World","original_language":"en"},{"id":284052,"adult":false,"title":"Doctor Strange","video":false,"overview":"After his career is destroyed, a brilliant but arrogant surgeon gets a new lease on life when a sorcerer takes him under her wing and trains him to defend the world against evil.","genre_ids":[14,12,28],"media_type":"movie","popularity":11.7486,"vote_count":23179,"poster_path":"/xf8PbyQcR5ucXErmZNzdKR0s8ya.jpg","release_date":"2016-10-25","vote_average":7.417,"backdrop_path":"/3zvZ699gMW2RhWc0GisIukzq0Ls.jpg","original_title":"Doctor Strange","original_language":"en"},{"id":76757,"adult":false,"title":"Jupiter Ascending","video":false,"overview":"In a universe where human genetic material is the most precious commodity, an impoverished young Earth woman becomes the key to strategic maneuvers and internal strife within a powerful dynasty…","genre_ids":[878,14,28],"media_type":"movie","popularity":5.2351,"vote_count":7009,"poster_path":"/2NCcAZ3M3F0FxENYmammBknwpVn.jpg","release_date":"2015-02-04","vote_average":5.456,"backdrop_path":"/w4hk4QG05nDuSgimpa7XAM6OyPX.jpg","original_title":"Jupiter Ascending","original_language":"en"},{"id":198184,"adult":false,"title":"Chappie","video":false,"overview":"Every child comes into the world full of promise, and none more so than Chappie: he is gifted, special, a prodigy. Like any child, Chappie will come under the influence of his surroundings—some good, some bad—and he will rely on his heart and soul to find his way in the world and become his own man. But there's one thing that makes Chappie different from any one else: he is a robot.","genre_ids":[80,28,878],"media_type":"movie","popularity":7.2369,"vote_count":8339,"poster_path":"/uuDUpzlMFomdSfNWlpEPS9nVZWV.jpg","release_date":"2015-03-04","vote_average":6.786,"backdrop_path":"/3pKIcv6KhUE35jsKnv3MylQ3OT2.jpg","original_title":"Chappie","original_language":"en"},{"id":135397,"adult":false,"title":"Jurassic World","video":false,"overview":"Twenty-two years after the events of Jurassic Park, Isla Nublar now features a fully functioning dinosaur theme park, Jurassic World, as originally envisioned by John Hammond.","genre_ids":[28,12,878,53],"media_type":"movie","popularity":11.0871,"vote_count":21335,"poster_path":"/rhr4y79GpxQF9IsfJItRXVaoGs4.jpg","release_date":"2015-06-06","vote_average":6.698,"backdrop_path":"/s5QfDFqRO6sjgPtKkjxD0WqXQef.jpg","original_title":"Jurassic World","original_language":"en"},{"id":264660,"adult":false,"title":"Ex Machina","video":false,"overview":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl.","genre_ids":[18,878],"media_type":"movie","popularity":7.9469,"vote_count":14040,"poster_path":"/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg","release_date":"2015-01-21","vote_average":7.573,"backdrop_path":"/uqOuJ50EtTj7kkDIXP8LCg7G45D.jpg","original_title":"Ex Machina","original_language":"en"}],"similar_content":[{"id":95,"adult":false,"title":"Armageddon","video":false,"overview":"When an asteroid threatens to collide with Earth, NASA honcho Dan Truman determines the only way to stop it is to drill into its surface and detonate a nuclear bomb. This leads him to renowned driller Harry Stamper, who agrees to helm the dangerous space mission provided he can bring along his own hotshot crew. Among them is the cocksure A.J. who Harry thinks isn't good enough for his daughter, until the mission proves otherwise.","genre_ids":[28,53,878,12],"popularity":7.0448,"vote_count":8423,"poster_path":"/eTM3qtGhDU8cvjpoa6KEt5E2auU.jpg","release_date":"1998-07-01","vote_average":6.829,"backdrop_path":"/1cO6OQJxz7YhTZ4V1OlkYfebeJa.jpg","original_title":"Armageddon","original_language":"en"},{"id":96,"adult":false,"title":"Beverly Hills Cop II","video":false,"overview":"Axel Foley returns to the land of sunshine and palm trees to investigate the near-fatal shooting of police Captain Andrew Bogomil. With the help of Sgt. Taggart and Det. Rosewood, they soon uncover that the shooting is associated with a series of \"alphabet\" robberies masterminded by a heartless weapons kingpin—and the chase is on.","genre_ids":[28,35,80],"popularity":3.717,"vote_count":2756,"poster_path":"/egDakU8O5yUwpUJP9IMAUVtIDll.jpg","release_date":"1987-05-18","vote_average":6.5,"backdrop_path":"/bIA65PCRtIQfBvIoKohJbtOPl3M.jpg","original_title":"Beverly Hills Cop II","original_language":"en"},{"id":106,"adult":false,"title":"Predator","video":false,"overview":"A team of elite commandos on a secret mission in a Central American jungle come to find themselves hunted by an extraterrestrial warrior.","genre_ids":[878,28,12,53],"popularity":14.8271,"vote_count":8869,"poster_path":"/k3mW4qfJo6SKqe6laRyNGnbB9n5.jpg","release_date":"1987-06-12","vote_average":7.5,"backdrop_path":"/otkJlfjB7zJ5h34FEIfemenMbCy.jpg","original_title":"Predator","original_language":"en"},{"id":120,"adult":false,"title":"The Lord of the Rings: The Fellowship of the Ring","video":false,"overview":"Young hobbit Frodo Baggins, after inheriting a mysterious ring from his uncle Bilbo, must leave his home in order to keep it from falling into the hands of its evil creator. Along the way, a fellowship is formed to protect the ringbearer and make sure that the ring arrives at its final destination: Mt. Doom, the only place where it can be destroyed.","genre_ids":[12,14,28],"popularity":32.2335,"vote_count":27058,"poster_path":"/6oom5QYQ2yQTMJIbnvbkBL9cHo6.jpg","release_date":"2001-12-18","vote_average":8.429,"backdrop_path":"/z51Wzj94hvAIsWfknifKTqKJRwp.jpg","original_title":"The Lord of the Rings: The Fellowship of the Ring","original_language":"en"},{"id":121,"adult":false,"title":"The Lord of the Rings: The Two Towers","video":false,"overview":"Frodo Baggins and the other members of the Fellowship continue on their sacred quest to destroy the One Ring--but on separate paths. Their destinies lie at two towers--Orthanc Tower in Isengard, where the corrupt wizard Saruman awaits, and Sauron's fortress at Barad-dur, deep within the dark lands of Mordor. Frodo and Sam are trekking to Mordor to destroy the One Ring of Power while Gimli, Legolas and Aragorn search for the orc-captured Merry and Pippin. All along, nefarious wizard Saruman awaits the Fellowship members at the Orthanc Tower in Isengard.","genre_ids":[12,14,28],"popularity":19.0754,"vote_count":23476,"poster_path":"/5VTN0pR8gcqV3EPUHHfMGnJYN9L.jpg","release_date":"2002-12-18","vote_average":8.4,"backdrop_path":"/kWYfW2Re0rUDE6IHhy4CRuKWeFr.jpg","original_title":"The Lord of the Rings: The Two Towers","original_language":"en"},{"id":122,"adult":false,"title":"The Lord of the Rings: The Return of the King","video":false,"overview":"As armies mass for a final battle that will decide the fate of the world--and powerful, ancient forces of Light and Dark compete to determine the outcome--one member of the Fellowship of the Ring is revealed as the noble heir to the throne of the Kings of Men. Yet, the sole hope for triumph over evil lies with a brave hobbit, Frodo, who, accompanied by his loyal friend Sam and the hideous, wretched Gollum, ventures deep into the very dark heart of Mordor on his seemingly impossible quest to destroy the Ring of Power.​","genre_ids":[12,14,28],"popularity":26.3842,"vote_count":26074,"poster_path":"/rCzpDGLbOoPwLjy3OAm5NUPOTrC.jpg","release_date":"2003-12-17","vote_average":8.5,"backdrop_path":"/2u7zbn8EudG6kLlBzUYqP8RyFU4.jpg","original_title":"The Lord of the Rings: The Return of the King","original_language":"en"},{"id":123,"adult":false,"title":"The Lord of the Rings","video":false,"overview":"Young Hobbit Frodo Baggins is thrown into an amazing adventure when he's tasked with destroying the One Ring, created by the dark lord Sauron. Frodo must travel in a small fellowship of nine warriors and accomplices. But it won't be an easy journey for the Fellowship of the Ring, on the ultimate quest to rid Middle-earth of evil.","genre_ids":[12,16,14],"popularity":3.0653,"vote_count":1023,"poster_path":"/liW0mjvTyLs7UCumaHhx3PpU4VT.jpg","release_date":"1978-11-15","vote_average":6.6,"backdrop_path":"/TXSxV23MWYkezZ3219gtgcSX6n.jpg","original_title":"The Lord of the Rings","original_language":"en"},{"id":128,"adult":false,"title":"Princess Mononoke","video":false,"overview":"Ashitaka, a prince of the disappearing Emishi people, is cursed by a demonized boar god and must journey to the west to find a cure. Along the way, he encounters San, a young human woman fighting to protect the forest, and Lady Eboshi, who is trying to destroy it. Ashitaka must find a way to bring balance to this conflict.","genre_ids":[12,14,16],"popularity":10.5812,"vote_count":8781,"poster_path":"/cMYCDADoLKLbB83g4WnJegaZimC.jpg","release_date":"1997-07-12","vote_average":8.324,"backdrop_path":"/gl0jzn4BupSbL2qMVeqrjKkF9Js.jpg","original_title":"もののけ姫","original_language":"ja"},{"id":18,"adult":false,"title":"The Fifth Element","video":false,"overview":"In 2257, a taxi driver is unintentionally given the task of saving a young girl who is part of the key that will ensure the survival of humanity.","genre_ids":[878,28,12],"popularity":11.8876,"vote_count":11464,"poster_path":"/fPtlCO1yQtnoLHOwKtWz7db6RGU.jpg","release_date":"1997-05-02","vote_average":7.6,"backdrop_path":"/bx1W729hyWQqNQoiq9LsX30FBf.jpg","original_title":"Le Cinquième Élément","original_language":"fr"},{"id":62,"adult":false,"title":"2001: A Space Odyssey","video":false,"overview":"Humanity finds a mysterious object buried beneath the lunar surface and sets off to find its origins with the help of HAL 9000, the world's most advanced super computer.","genre_ids":[878,9648,12],"popularity":11.9001,"vote_count":12361,"poster_path":"/ve72VxNqjGM69Uky4WTo2bK6rfq.jpg","release_date":"1968-04-02","vote_average":8.056,"backdrop_path":"/w5IDXtifKntw0ajv2co7jFlTQDM.jpg","original_title":"2001: A Space Odyssey","original_language":"en"},{"id":75,"adult":false,"title":"Mars Attacks!","video":false,"overview":"A fleet of Martian spacecraft surrounds the world's major cities and all of humanity waits to see if the extraterrestrial visitors have, as they claim, \"come in peace.\" U.S. President James Dale receives assurance from science professor Donald Kessler that the Martians' mission is a friendly one. But when a peaceful exchange ends in the total annihilation of the U.S. Congress, military men call for a full-scale nuclear retaliation.","genre_ids":[35,14,878],"popularity":4.8484,"vote_count":5779,"poster_path":"/hll4O5vSAfnZDb6JbnP06GPtz7b.jpg","release_date":"1996-12-13","vote_average":6.4,"backdrop_path":"/ELsTifJ2lu4vsMhoHeZ5EnncHw.jpg","original_title":"Mars Attacks!","original_language":"en"},{"id":78,"adult":false,"title":"Blade Runner","video":false,"overview":"In the smog-choked dystopian Los Angeles of 2019, blade runner Rick Deckard is called out of retirement to terminate a quartet of replicants who have escaped to Earth seeking their creator for a way to extend their short life spans.","genre_ids":[878,18,53],"popularity":11.9762,"vote_count":14713,"poster_path":"/63N9uy8nd9j7Eog2axPQ8lbr3Wj.jpg","release_date":"1982-06-25","vote_average":7.9,"backdrop_path":"/hJ5R9d6QuH3tzr8L8neZZTuzNXm.jpg","original_title":"Blade Runner","original_language":"en"},{"id":81,"adult":false,"title":"Nausicaä of the Valley of the Wind","video":false,"overview":"After a global war, the seaside kingdom known as the Valley of the Wind remains one of the last strongholds on Earth untouched by a poisonous jungle and the powerful insects that guard it. Led by the courageous Princess Nausicaä, the people of the Valley engage in an epic struggle to restore the bond between humanity and Earth.","genre_ids":[12,16,14],"popularity":5.3279,"vote_count":3979,"poster_path":"/tcrkfB8SRPQCgwI88hQScua6nxh.jpg","release_date":"1984-03-11","vote_average":7.946,"backdrop_path":"/ulVUa2MvnJAjAeRt7h23FFJVRKH.jpg","original_title":"風の谷のナウシカ","original_language":"ja"},{"id":85,"adult":false,"title":"Raiders of the Lost Ark","video":false,"overview":"When Dr. Indiana Jones – the tweed-suited professor who just happens to be a celebrated archaeologist – is hired by the government to locate the legendary Ark of the Covenant, he finds himself up against the entire Nazi regime.","genre_ids":[12,28],"popularity":12.4381,"vote_count":13408,"poster_path":"/ceG9VzoRAVGwivFU403Wc3AHRys.jpg","release_date":"1981-06-12","vote_average":7.921,"backdrop_path":"/zPAC