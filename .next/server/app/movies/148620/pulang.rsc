le":"Lapua 1976","original_language":"fi"},{"id":9366,"adult":false,"title":"Donnie Brasco","video":false,"overview":"An FBI undercover agent infiltrates the mob and identifies more with the mafia life at the expense of his regular one.","genre_ids":[80,18,53],"popularity":3.8935,"vote_count":4764,"poster_path":"/xtKLvpOfARi1XVm8u2FTdhY5Piq.jpg","release_date":"1997-02-27","vote_average":7.538,"backdrop_path":"/eSICWLHrkeydx7DGcCH0gLhVGIa.jpg","original_title":"Donnie Brasco","original_language":"en"},{"id":1067950,"adult":false,"title":"Girl You Know It's True","video":false,"overview":"The rise and fall of Milli Vanilli, a studio group assembled by German producer Frank Farian and fronted by nightclub dancers Robert Pilatus and Fabrice Morvan. After a string of worldwide hit singles, awards and performances, it was revealed that the duo never sang a note of their songs, leading to one of the biggest scandals in music history.","genre_ids":[18,36,10402],"popularity":0.6836,"vote_count":120,"poster_path":"/yKYSHULhVfFzibLmWyJfUiwsFkR.jpg","release_date":"2023-12-06","vote_average":7.333,"backdrop_path":"/muG1Inh2Eawg8MoAElROpwHGtur.jpg","original_title":"Girl You Know It's True","original_language":"de"}],"external_ids":{"imdb_id":"tt8595708","twitter_id":null,"facebook_id":null,"wikidata_id":"Q57240742","instagram_id":null,"rotten_tomatoes_id":"m/pulang"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148620,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"FR","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2018-10-08T00:00:00.000Z","certification":""}]},{"iso_3166_1":"IT","release_dates":[{"note":"Netflix ","type":4,"iso_639_1":"","descriptors":[],"release_date":"2018-10-07T00:00:00.000Z","certification":""}]},{"iso_31