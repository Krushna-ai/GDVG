5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"A Silent Voice: The Movie\",\"description\":\"Shouya Ishida starts bullying the new girl in class, Shouko Nishimiya, because she is deaf. But as the teasing continues, the rest of the class starts to turn on Shouya for his lack of compassion. When they leave elementary school, Shouko and Shouya do not speak to each other again... until an older, wiser Shouya, tormented by his past behaviour, decides he must see Shouko once more. He wants to atone for his sins, but is it already too late...?\",\"image\":\"https://image.tmdb.org/t/p/w500/tuFaWiqX0TXoWu7DGNcmX3UW7sT.jpg\",\"datePublished\":\"2016-09-17\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"coming-of-age film\",\"drama film\",\"Animation\",\"Drama\",\"Romance\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.4,\"bestRating\":10,\"ratingCount\":4349}}"}}],["$","$L10",null,{"initialDrama":{"id":"88fb2af8-0594-4fb7-b61a-91b614aa3aa8","tmdb_id":378064,"imdb_id":"tt5323662","content_type":"movie","title":"A Silent Voice: The Movie","original_title":"映画 聲の形","overview":"Shouya Ishida starts bullying the new girl in class, Shouko Nishimiya, because she is deaf. But as the teasing continues, the rest of the class starts to turn on Shouya for his lack of compassion. When they leave elementary school, Shouko and Shouya do not speak to each other again... until an older, wiser Shouya, tormented by his past behaviour, decides he must see Shouko once more. He wants to atone for his sins, but is it already too late...?","poster_path":"/tuFaWiqX0TXoWu7DGNcmX3UW7sT.jpg","backdrop_path":"/5lAMQMWpXMsirvtLLvW7cJgEPkU.jpg","release_date":"2016-09-17","first_air_date":null,"status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"name":"coming-of-age film"},{"name":"drama film"},{"id":16,"