h":"/lCPu7sHa5hGeKzEPiHW9sdWICqm.jpg","iso_639_1":"zh","vote_average":0}],"backdrops":[{"width":3440,"height":1935,"file_path":"/pU8pR29OYRTQqy5rEj387PdDGft.jpg","iso_639_1":null,"vote_average":2.278},{"width":2834,"height":1594,"file_path":"/vfeG3In81Gjzr3HJFCJytVyMRAN.jpg","iso_639_1":null,"vote_average":1.75},{"width":2045,"height":1150,"file_path":"/j4CbXnqPjxncVSaOiBhfmu7IQvw.jpg","iso_639_1":null,"vote_average":1.75},{"width":2000,"height":1125,"file_path":"/puuiZD76Zl5wo7mRKVPcf1c2J6P.jpg","iso_639_1":null,"vote_average":0},{"width":2312,"height":1301,"file_path":"/7ni8339oEAn0nT7VMgH66EhktEG.jpg","iso_639_1":null,"vote_average":0},{"width":2768,"height":1557,"file_path":"/wL1FBP4ncZP9M7hCrReuU46hZKC.jpg","iso_639_1":null,"vote_average":0},{"width":2772,"height":1559,"file_path":"/5e8cyV8v1S6iotvaFRAbfn6jczb.jpg","iso_639_1":null,"vote_average":0},{"width":2813,"height":1582,"file_path":"/hKKTnpsSbLd8PtjZQPZaP5ig4K3.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/y6WowFs6I7xoZ9bbolKKfTmpwar.jpg","iso_639_1":"zh","vote_average":0},{"width":1920,"height":1080,"file_path":"/sjCfCS8jRIre5piNvmX4DHnHCr5.jpg","iso_639_1":"zh","vote_average":0},{"width":1920,"height":1080,"file_path":"/sLUGMX5DULkIzo2B7MnZ2hsnKG2.jpg","iso_639_1":"zh","vote_average":0},{"width":1920,"height":1080,"file_path":"/o0xiCJ1ORFAY6kuGA0xZ1DmoJkj.jpg","iso_639_1":"zh","vote_average":0},{"width":1920,"height":1080,"file_path":"/zbS7NdvCsgL6rM6cfsArCqdEcv3.jpg","iso_639_1":"zh","vote_average":0}]},"enriched_at":"2026-02-21T15:20:34.013+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"志愿军：存亡之战","runtime":144,"tagline":"战争巨制 铁血不灭","homepage":"","overview":"影片聚焦铁原阻击战。1951年5月，中国人民志愿军第63军刚刚结束了持续一个月的作战，就受命进驻铁原战场，正面对抗“联合国军”4个师。志愿军将士们浴血奋战，终于把敌军打上了谈判桌。为了完成任务，63军189师的战士化整为零，把自己变成一根钉子，牢牢钉在阵地上!1营阵地上，身为营教导员的李想立下“一步也不会再退”的誓言，死守阵地。炮火连天中，李默尹一家三口在战场上团聚，一把钥匙，一顿战壕中的团圆饭，让这个因战争分离的小家更为亲密。为了给新中国造出更好的武器，归国军工专家吴本正在张孝恒的保护下进入战场。身为警卫员的张孝恒坚信，守住了吴本正，就是守住了祖国的未来。孙醒、杨三弟也纷纷来到铁原。63军全体将士一起，在铁原战场上筑成了一道冲不破的“铁长城”！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"The Volunteers: The Battle of Life and Death","runtime":144,"tagline":"A war masterpiece. Iron blood will never die.","homepage":"","overview":"The movie focuses on the battle of Cheolwon, where the 63rd Army of the Chinese People's Volunteer Army (CPVA) was ordered to enter the battlefield of Cheolwon in May 1951, just after a month-long battle, to fight against four divisions of the United Nations Army (UNA). The volunteers fought with bloodshed and finally brought the enemy to the negotiation table."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"志願軍第二部: 存亡之戰","runtime":144,"tagline":"","homepage":"","overview":"影片聚焦鐵原阻擊戰。1951 年 5 月，中國人民志願軍第 63 軍剛剛結束了持續一個月的作戰，就受命進駐鐵原戰場，正面對抗“聯合國軍”4 個師。志願軍將士們浴血奮戰，終於把敵軍打上了談判桌。\r 為了完成任務，63 軍 189 師的戰士化整為零，把自己變成一根釘子，牢牢釘在陣地上! 1 營陣地上，身為營教導員的李想（朱一龍）立下“一步也不會再退”的誓言，死守陣地； 炮火聯天中，李默尹（辛柏青 飾）一家三口在戰場上團聚，一把鑰匙，一頓戰壕中的團圓飯，讓這個因戰爭分離的小家更為親密。\r 為了給新中國造出更好的武器，歸國軍工專家吳本正（朱亞文 飾）在張孝恆（歐豪 飾）的保護下進入戰場。身為警衞員的張孝恆堅信，守住了吳本正，就是守住了祖國的未來。\r 孫醒（陳飛宇 飾）、楊三弟（張宥浩 飾）也紛紛來到鐵原。63 軍全體將士一起，在鐵原戰場上築成了一道衝不破的“鐵長城”！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Quân Tình Nguyện: Trận Chiến Sinh Tử","runtime":0,"tagline":"","homepage":"","overview":"Bộ phim tập trung vào trận chiến Cheolwon, nơi Quân đoàn 63 của Quân đội Tình nguyện Nhân dân Trung Quốc (CPVA) được lệnh tiến vào chiến trường Cheolwon. Vào tháng 5 năm 1951, chỉ sau một tháng chiến đấu với bốn sư đoàn của Quân đội Liên hợp quốc (UNA), những người tình nguyện đã chiến đấu bằng máu và cuối cùng đã đưa kẻ thù vào bàn đàm phán."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"The Volunteers: The Battle of Life and Death","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"志願軍：存亡之戰","runtime":144,"tagline":"","homepage":"","overview":"《志願軍》三部曲第二部將延續前作故事，聚焦抗美援朝第三到五次戰役，重點講述第五次戰役中一場至關重要的“存亡之戰”——鐵原阻擊戰。戰士們堅定不移的目光穿過戰場的硝煙彌漫，背後寄託著對未來的希望。這支“英雄鐵軍”用鋼鐵般的信念，在戰場上構築了一道敵人沖不破的鋼鐵長城。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":1280330,"adult":false,"title":"Operation Hadal","video":false,"overview":"Mercenaries have occupied an offshore platform in Chinese territorial waters by force. The Chinese Navy sets sail to repel the invaders as the Jiao Long commando team prepares for a fierce fight in the deep sea.","genre_ids":[18,28,10752],"media_type":"movie","popularity":1.6,"vote_count":13,"poster_path":"/joALXjCQCKTSDREQEJxn83U4ORK.jpg","release_date":"2025-01-26","vote_average":7.462,"backdrop_path":"/wteoGPQwhj79yQuEINoTwqfEzav.jpg","original_title":"蛟龙行动","original_language":"zh"},{"id":1105208,"adult":false,"title":"Spicy Police Flower 2","video":false,"overview":"In a kidnapping case at a convenience store where the hostages are successfully rescued, the police know from the victims the existence of a shocking P2P lending and human trafficking case involving many people. Meanwhile, SWAT team member Hao Miaomiao's cousin Zhang Lele is deeply caught in a P2P lending trap. While attempting to apprehend the criminal gang, Hao Miaomiao is accidentally abducted by the gang in Zhang Lele's place. And SWAT team member Tang Shiyu timely informs the criminal police team about what happened so that they can have a joint operation. In a series of battles of wits and courage, Tang Shiyu finds out by chance that Zhang Lele's boyfriend is a gang member. At the crucial moment when Tang Shiyu's identity is about to be revealed, the SWAT team finally manages to arrest the mastermind, free the imprisoned young girls, and bring all the criminals to justice.","genre_ids":[28,80],"media_type":"movie","popularity":0.1656,"vote_count":1,"poster_path":"/7PmemxuM8lxhqlYzYESFWle6wSH.jpg","release_date":"2023-03-26","vote_average":7,"backdrop_path":"/fjwKHaeJV16VRWvIgq9k8EgXYTD.jpg","original_title":"辣警狂花2","original_language":"zh"},{"id":1064486,"adult":false,"title":"Memoir of a Snail","video":false,"overview":"Forcibly separated from her twin brother when they are orphaned, a melancholic misfit learns how to find confidence within herself amid the clutter of misfortunes and everyday life.","genre_ids":[16,18,35],"media_type":"movie","popularity":4.731,"vote_count":733,"poster_path":"/woaN8CbloH0akyX0E72ayxlJAB4.jpg","release_date":"2024-10-17","vote_average":8.054,"backdrop_path":"/jl2YIADk391yc6Qjy9JhgCRkHJk.jpg","original_title":"Memoir of a Snail","original_language":"en"},{"id":1195506,"adult":false,"title":"Novocaine","video":false,"overview":"When the girl of his dreams is kidnapped, everyman Nate turns his inability to feel pain into an unexpected strength in his fight to get her back.","genre_ids":[28,35,53],"media_type":"movie","popularity":7.8449,"vote_count":1457,"poster_path":"/xmMHGz9dVRaMY6rRAlEX4W0Wdhm.jpg","release_date":"2025-03-12","vote_average":6.803,"backdrop_path":"/lyBH2mFFU6qrHwD5QKotL2JnEb6.jpg","original_title":"Novocaine","original_language":"en"},{"id":912649,"adult":false,"title":"Venom: The Last Dance","video":false,"overview":"Eddie and Venom are on the run. Hunted by both of their worlds and with the net closing in, the duo are forced into a devastating decision that will bring the curtains down on Venom and Eddie's last dance.","genre_ids":[28,878,12],"media_type":"movie","popularity":19.3743,"vote_count":4016,"poster_path":"/1RaSkWakWBxxYOWRrqmwo2my5zg.jpg","release_date":"2024-10-22","vote_average":6.663,"backdrop_path":"/3V4kLQg0kSqPLctI5ziYWabAZYF.jpg","original_title":"Venom: The Last Dance","original_language":"en"},{"id":575264,"adult":false,"title":"Mission: Impossible - Dead Reckoning Part One","video":false,"overview":"Ethan Hunt and his IMF team embark on their most dangerous mission yet: To track down a terrifying new weapon that threatens all of humanity before it falls into the wrong hands. With control of the future and the world's fate at stake and dark forces from Ethan's past closing in, a deadly race around the globe begins. Confronted by a mysterious, all-powerful enemy, Ethan must consider that nothing can matter more than his mission—not even the lives of those he cares about most.","genre_ids":[28,53,12],"media_type":"movie","popularity":12.5395,"vote_count":4926,"poster_path":"/NNxYkU70HPurnNCSiCjYAmacwm.jpg","release_date":"2023-07-08","vote_average":7.507,"backdrop_path":"/628Dep6AxEtDxjZoGP78TsOxYbK.jpg","original_title":"Mission: Impossible - Dead Reckoning Part One","original_language":"en"},{"id":680,"adult":false,"title":"Pulp Fiction","video":false,"overview":"A burger-loving hit man, his philosophical partner, a drug-addled gangster's moll and a washed-up boxer converge in this sprawling, comedic crime caper. Their adventures unfurl in three stories that ingeniously trip back and forth in time.","genre_ids":[53,80,35],"media_type":"movie","popularity":23.9216,"vote_count":29710,"poster_path":"/vQWk5YBFWF4bZaofAbv0tShwBvQ.jpg","release_date":"1994-09-10","vote_average":8.486,"backdrop_path":"/96hiUXEuYsu4tcnvlaY8tEMFM0m.jpg","original_title":"Pulp Fiction","original_language":"en"},{"id":1106739,"adult":false,"title":"Juror #2","video":false,"overview":"While serving as a juror in a high profile murder trial, family man Justin Kemp finds himself struggling with a serious moral dilemma…one he could use to sway the jury verdict and potentially convict—or free—the accused killer.","genre_ids":[18,53],"media_type":"movie","popularity":4.432,"vote_count":2356,"poster_path":"/ugQkpGajKFQ8eyOEhGheR0HfWQ.jpg","release_date":"2024-10-30","vote_average":6.882,"backdrop_path":"/9Qq8InnodUYs8zdam8Zj967i6RO.jpg","original_title":"Juror #2","original_language":"en"},{"id":1071585,"adult":false,"title":"M3GAN 2.0","video":false,"overview":"After the underlying tech for M3GAN is stolen and misused by a powerful defense contractor to create a military-grade weapon known as Amelia, M3GAN's creator Gemma realizes that the only option is to resurrect M3GAN and give her a few upgrades, making her faster, stronger, and more lethal.","genre_ids":[28,878,53],"media_type":"movie","popularity":15.8071,"vote_count":1152,"poster_path":"/oekamLQrwlJjRNmfaBE4llIvkir.jpg","release_date":"2025-06-25","vote_average":7.27,"backdrop_path":"/cT9ZfwoPDk8JbgkessmQgxAWiaM.jpg","original_title":"M3GAN 2.0","original_language":"en"},{"id":1234821,"adult":false,"title":"Jurassic World Rebirth","video":false,"overview":"Five years after the events of Jurassic World Dominion, covert operations expert Zora Bennett is contracted to lead a skilled team on a top-secret mission to secure genetic material from the world's three most massive dinosaurs. When Zora's operation intersects with a civilian family whose boating expedition was capsized, they all find themselves stranded on an island where they come face-to-face with a sinister, shocking discovery that's been hidden from the world for decades.","genre_ids":[878,12,28],"media_type":"movie","popularity":34.4455,"vote_count":2998,"poster_path":"/1RICxzeoNCAO5NpcRMIgg1XT6fm.jpg","release_date":"2025-07-01","vote_average":6.306,"backdrop_path":"/zNriRTr0kWwyaXPzdg1EIxf0BWk.jpg","original_title":"Jurassic World Rebirth","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":21.4528,"vote_count":11366,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.036,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":823219,"adult":false,"title":"Flow","video":false,"overview":"A solitary cat, displaced by a gr