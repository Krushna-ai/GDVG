5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Volunteers: The Battle of Life and Death\",\"description\":\"The movie focuses on the battle of Cheolwon, where the 63rd Army of the Chinese People's Volunteer Army (CPVA) was ordered to enter the battlefield of Cheolwon in May 1951, just after a month-long battle, to fight against four divisions of the United Nations Army (UNA). The volunteers fought with bloodshed and finally brought the enemy to the negotiation table.\",\"image\":\"https://image.tmdb.org/t/p/w500/s6iSPGkpEHwcztNmNIMr21M6inK.jpg\",\"datePublished\":\"2024-09-30\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Drama\",\"War\",\"History\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.4,\"bestRating\":10,\"ratingCount\":17}}"}}],["$","$L10",null,{"initialDrama":{"id":"826856a6-4011-4eb2-b34f-4dd216b1d2b3","tmdb_id":1298727,"imdb_id":"tt32843258","content_type":"movie","title":"The Volunteers: The Battle of Life and Death","original_title":"志愿军：存亡之战","overview":"The movie focuses on the battle of Cheolwon, where the 63rd Army of the Chinese People's Volunteer Army (CPVA) was ordered to enter the battlefield of Cheolwon in May 1951, just after a month-long battle, to fight against four divisions of the United Nations Army (UNA). The volunteers fought with bloodshed and finally brought the enemy to the negotiation table.","poster_path":"/s6iSPGkpEHwcztNmNIMr21M6inK.jpg","backdrop_path":"/pU8pR29OYRTQqy5rEj387PdDGft.jpg","release_date":"2024-09-30","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":18,"name":"Drama"},{"id":10752,"name":"War"},{"id":36,"name":"History"}],"popularity":2.6038,"vote_average":6.4,"vote_count":17,"runtime":144,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:52:07.66411