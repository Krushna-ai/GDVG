,"title":"Assembly","video":false,"overview":"Follows a soldier trying to gain recognition for comrades who died in 1948, at a turning point in the civil war between the communists and the nationalist forces of the Kuomintang.","genre_ids":[28,36],"popularity":1.3427,"vote_count":146,"poster_path":"/d8drBimtE0UFLlIh8BrLyk0C8Ad.jpg","release_date":"2007-10-09","vote_average":6.969,"backdrop_path":"/cSR493LjJxDmRy3hPpk9YCPHfZn.jpg","original_title":"集结号","original_language":"zh"},{"id":13398,"adult":false,"title":"Tokyo Godfathers","video":false,"overview":"On Christmas Eve, three homeless people living on the streets of Tokyo discover a newborn baby among the trash and set out to find its parents.","genre_ids":[16,18,35],"popularity":2.2305,"vote_count":1470,"poster_path":"/sPC66btzQlzuRdPKiSDYZ5Hvxgc.jpg","release_date":"2003-12-05","vote_average":7.917,"backdrop_path":"/mnppPdfdtKPNoRemzIZDwOKpgfv.jpg","original_title":"東京ゴッドファーザーズ","original_language":"ja"}],"external_ids":{"imdb_id":"tt32843258","twitter_id":null,"facebook_id":null,"wikidata_id":"Q130397306","instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":109890,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"CN","release_dates":[{"note":"Beijing","type":1,"iso_639_1":"","descriptors":[],"release_date":"2024-09-27T00:00:00.000Z","certification":""},{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2024-09-30T00:00:00.000Z","certification":""},{"note":"","type":4,"iso_639_1":"zh","descriptors":[],"release_date":"2024-12-13T00:00:00.000Z","certification":""}]},{"iso_3166_1":"HK","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2024-10-01T00:00:00.000Z","certification":""}]}],"aggregate_credits":null,"original_network":null,"screenwriters":