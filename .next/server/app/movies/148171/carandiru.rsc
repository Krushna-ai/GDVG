25F6G8V.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1135,"height":1703,"file_path":"/3VfkE7LyKaHB5Ukvmr4EvJFABdL.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.666,"vote_average":0},{"width":1364,"height":2046,"file_path":"/lZlh2z5eLU1kfnNPfKz2DXSkATf.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":988,"height":1481,"file_path":"/19U9HKcApn3tAZrMM8MKgoy0ERu.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/rhrBU761a5B4w7hhpA9og3fNBCH.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/x0I4tEVu3vEmn4tHwqqgetU36gt.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/9ka10RUmWRZfNyUmxABuQSoO4SD.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1828,"height":1028,"file_path":"/51i42iRvqBGeRaQ3SKbrNGpzsIx.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/gmoKcmmfCbm3uk6weNolp92r1Xp.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":1280,"height":720,"file_path":"/9AtTPsbMmLGliV8rYH4vQfKtq78.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958}]},"enriched_at":"2026-04-21T08:23:22.109+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":145,"tagline":"Inside here nobody is guilty. Do you believe that?","homepage":"","overview":"When a doctor decides to carry out an AIDS prevention program inside Latin America’s largest prison: the Casa de Detenção de São Paulo - Carandiru, he meets the future victims of one of the darkest days in Brazilian History when the State of São Paulo’s Military Police, with the excuse for law enforcement, shot to death 111 people. Based on real facts and on the book written by Dráuzio Varella."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"'Carandiru', içinde yaklaşık 8000 mahkum barındıran, halk arasında 'Carandiru' olarak bilinen Brezilya Sao Paulo Hapishanesi'nde 1992 Ekim'inde gerçekleşen bir isyanın öyküsünü beyazperdeye taşıyor. Babenco, bir isyan olarak başlayıp bir katliama dönüşen olayı ('9. Koğuş Katliamı'), öykünün merkezine AIDS'le mücadele için hapishaneye gelen, idealist bir doktor karakterini koyarak işlemeyi tercih etmiş. Zamanla hapishanedeki farklı grupların saygısını kazanan doktor, hızla gelişen olaylar karşısında çaresiz kalıyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Carandiru","runtime":148,"tagline":"","homepage":"","overview":"Um médico (Luiz Carlos Vasconcelos) se oferece para realizar um trabalho de prevenção a AIDS no maior presídio da América Latina, o Carandiru. Lá ele convive com a realidade atrás das grades, que inclui violência, superlotação das celas e instalações precárias. Porém, apesar de todos os problemas, o médico logo percebe que os prisioneiros não são figuras demoníacas, existindo dentro da prisão solidariedade, organização e uma grande vontade de viver."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":146,"tagline":"","homepage":"","overview":"La prison de Carandiru, à São Paulo, est la plus grande d'Amérique latine. Dans cet endroit surpeuplé et délabré, un célèbre médecin doit mener un programme de prévention contre le sida. Habitué à la médecine haut de gamme, il va devoir apprendre à se débrouiller en se fiant à son instinct. Peu à peu, il découvre les détenus, leur monde à part, leur humanité et leur fabuleuse envie de vivre. A force de contacts et de temps, il gagne leur respect et partage leurs secrets. A travers son regard, c'est toute la tragédie sociale d'un pays qui se révèle, jusqu'au jour du terrible massacre de Carandiru..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":146,"tagline":"","homepage":"","overview":"Carandiru ist ein berüchtigtes Gefängnis im brasilianischen São Paulo, das mit 8000 Insassen auf einem für 4000 Menschen geplanten Platz deutlich überbelegt ist. In den beengten Verhältnissen, die sich der Ordnungsmacht weitgehend einer Kontrolle entziehen, hat sich ein eigenes Sozialsystem ausgebildet. Basierend auf den Erlebnissen des brasilianischen Arztes Drauzio Varella, der in den 1990er Jahren in Carandiru arbeitete, entwirft Hector Babenco ein episodisches Gefängnisdrama. Varella (Luiz Carlos Vasconcelos) sucht Carandiru auf, um die Gefangenen über AIDS aufzuklären, das sich zu einer gefährlichen Seuche unter den Insassen zu entwickeln droht. Dabei lernt er zahlreiche Knastbrüder kennen, die ihm auch ihre Hintergründe offenbaren. In Rückblenden schildert der Film einige ihrer Geschichten und porträtiert das komplexe System aus sozialen Regeln, das Carandiru prägt."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Carandiru","runtime":146,"tagline":"","homepage":"","overview":"Deze film is gebaseerd op een waargebeurd verhaal van Dokter Drauzio Varella die werkte in de Carandiru gevangenis in São Paulo, Brazilië. Toen Dokter Drauzio op bezoek kwam in de gevangenis om mee te helpen AIDS te voorkomen in de gevangenis, vond hij honderden gevangenen in erbarmelijke omstandigheden. Als de gevangenen in opstand komen loopt het erg uit de hand."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Carandiru","runtime":0,"tagline":"","homepage":"","overview":"Un famoso medico deve condurre un programma di prevenzione dall’aids nella prigione di Carandiru, a San Paolo, la più grande dell’America latina. Abituato alla medicina di alto livello, qui invece non può fidarsi che del suo istinto. Conosce i detenuti, il loro mondo a parte, la loro umanità. Si guadagna il loro rispetto e conosce i loro segreti. Fino al giorno in cui scoppia la rivolta che termina con un terribile massacro."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Vzpoura ve věznici Carandiru","runtime":148,"tagline":"","homepage":"","overview":"Doktor Drauzia Varella byl povolán do největší věznice v Brazílii - Carandiru, aby zahájil prevenci a léčbu postižených virem HIV. Dostal se do prostředí jedné z nejdrsnějších věznic na světě, kde se přímo setkal s absolutně nelidským zacházením s vězni. Stovky vězňů žili v hrozných podmínkách. V roce 1992 ve věznici Carandiru vypukla série nepokojů, které přerostli do vzpoury, při které přišlo o život 111 vězňů. Film je inspirovaný skutečnými událostmi, které popsal doktor Drauzia Varella ve své knize Carandiru Station."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":140,"tagline":"Czyściec gorszy niż piekło","homepage":"","overview":"Scenariusz powstał na podstawie wspomnień doktora Drauzio Varelli, który przez 14 lat pracował w nieistniejącym już zakładzie karnym Carandiru w Sao Paulo. Naoczny świadek opisuje koszmar codziennego życia w piekle, jakim było to przerażające miejsce. Nieludzkie warunki, niebywałe zatłoczenie i brutalne prawa, narzucone przez przestępczą elitę, doprowadziły w konsekwencji do tragicznych wydarzeń. W 1992 roku Carandiru stało się areną najbardziej krwawego buntu więźniów w historii."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"קראנדירו","runtime":0,"tagline":"","homepage":"","overview":"סרטו הקשה של הקטור בבנקו (נשיקת אשת העכביש) מבוסס על זכרונותיו האמיתיים של רופא שהובא אל מתקן הכליאה קאראנדירו בסאן פאולו, ברזיל, כדי לעורר מודעות לאיידס וסכנותיו. במהלך שהותו שם היה עד לתנאים המפלצתיים בהם הוחזקו האסירים, עד למרד הגדול שהתרחש ב-1992 והסתיים בטבח. הסרט עוקב אחר חייהם של האסירים ומציג את הפנים האנושיות של אלה שהממסד הפך לחיות בכלוב."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Carandiru","runtime":0,"tagline":"","homepage":"","overview":"La película está basada en las experiencias del doctor Drauzio Varella en la prisión estatal Carandiru, en São Paulo, Brasil, durante sus trabajos de prevención del SIDA. En la prisión se encontró con cientos de convictos bajo condiciones infrahumanas hasta el punto culminante de 1992 cuando una revuelta provocó el asesinato de 111 hombres."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":146,"tagline":"Aqui dentro ninguém é culpado. Você acredita nisso?","homepage":"","overview":"Um médico se oferece para realizar um trabalho de prevenção a AIDS no maior presídio da América Latina, o Carandiru. Lá ele convive com a realidade dos cárceres, que inclui violência, superlotação das celas e instalações precárias. Porém, apesar de todos os problemas, o médico logo percebe que os prisioneiros não são figuras demoníacas, existindo dentro da prisão solidariedade, organização e uma grande vontade de viver."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":139,"tagline":"","homepage":"","overview":"Filmen baseras på verkliga upplevelser av läkare Drauzio Varella inne i fruktansvärda State Penitentiary Carandiru i São Paulo, Brasilien, medan han gjorde ett socialt arbete för förebyggande av aids. Där fann han hundratals fångar leva under förnedrande förhållanden. Situationen kom till ett klimax 1992, då polisen för att kväva ett uppror dödade 111 män."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Carandiru - A börtönlázadás","runtime":148,"tagline":"","homepage":"","overview":"A Carandiru a világ egyik legnagyobb gyűjtőfogháza volt, amely Sao Paolóban működött egészen 2002-ig. Legnagyobb kihasználtsága időszakában a 3000 férőhelyen 8000 rabot tartottak fogva. Akkor vált igazán hírhedtté, amikor 1992-ben, egy lázadás alkalmával 111 rabot koncoltak itt fel. Habár a rendőrség arra hivatkozott, hogy önvédelemből cselekedtek, egyetlen rendőr sem halt meg az összetűzés során."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Карандиру","runtime":148,"tagline":"","homepage":"","overview":"Убийци, изнасилвачи, доносници, наркомани. Те са най-опасните --престъпниците, които в действителност управляват Карандиру - най-големия затвор в Бразилия. Черньо - почетен крадец и уважаван лидер, Принца - ловък манипулатор, който трябва да издържа две семейства, Езекиел - бивш сърфист, превърнал се в наркоман, Кинжала - жесток убиец, с Бог на своя страна. Те са затворническият елит, неколцината избраници, които ръководят Карандиру по собствените си правила и закони. Управление, което ще завърши с кървава баня, когато 300 полицаи превземат затвора и брутално убият 111 от невъоръжените му обитатели."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"카란디루","runtime":0,"tagline":"지상 최대의 감옥에서 일어난 최악의 폭동! 비극의 그날이 손에 잡힐 듯 생생하게 재현된다!","homepage":"","overview":"남미 최대의 감옥 카란디루. 과밀수용으로 폭력과 전염병이 급속도로 번져가던 어느 날 에이즈 치료와 예방교육을 위해 한 의사(드라우지오 바렐라)가 도착한다. 바렐라는 카란디루에 발을 들여놓는 순간부터 거친 수감자들의 칼부림을 목격하고 열악한 환경에 몸서리치지만, 수 많은 환자들을 외면하지 못해 그곳에 남기로 한다.  감옥 한 쪽에 마련된 간이 진료실은 ‘이곳에 죄 지은 사람은 없다’는 수감자들의 각양각색 사연들이 오가는 특별한 공간이 된다. 자기는 원래 좀도둑에 불과했다고 주장하는 우연한 살인범 에보니, 아내‘들’의 사랑다툼이 방화로 이어져 감옥신세까지 지게 되었다는 미워할 수 없는 바람둥이 하이니스, 이름과는 정반대로 트랜스젠더 레이디 디와 사랑에 빠지고 옥중결혼식까지 올리는 행운의 사나이 투 배드(Too bad)... 바렐라는 다양한 죄수들을 만나 각각의 너무나 인간적인 범죄의 뒷이야기에 귀를 기울인다.  얼핏 보면 온갖 범죄자들이 모인 무법천지, 그러나 나름의 엄격한 위계질서를 가지고 움직이던 카란디루의 최대행사인 축구시합이 열리던 날! 축구장 밖에서 일어난 사소한 싸움이 카란디루 전체의 폭동으로 번지게 되고... 경찰기동대의 잔혹한 진압으로 카란디루는 순식간에 끔찍한 피바다를 이룬다. 운 좋게도 비극의 그날 카란디루를 잠시 떠나있었던 바렐라는 살아남은 자들의 생생한 고백을 전해듣는다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"监狱淌血","runtime":145,"tagline":"","homepage":"","overview":"位于圣保罗的卡兰迪鲁是拉美最大监狱。长期超负荷关押七千名犯人的卡兰迪鲁环境恶劣，俨然一个自有体系的犯罪社会，监狱中简陋的医疗设施无法避免犯人之间传播疾病，一位医生来此实施防御艾滋病的医疗计划，由此揭开了众多犯人过往的经历……毒贩兹克（Wagner Moura 饰）在进入监狱后本打算洗手不干，然而环境再次把他拖入毒品的漩涡；犯人“女士”（罗德里格•桑托罗 Rodrigo Santoro 饰）在监狱中爱上了医生的助手，最后成婚；抢劫犯米罗被妻子背叛，怒而连杀多人入狱；流浪汉海尼斯为爱情犯下了纵火的罪行。一幕幕人间悲剧汇聚在卡兰迪鲁，压抑的人群最终爆发出一场令人瞠目结舌的监狱暴动。\r 本片根据1992年发生在巴西的监狱暴动事件改编。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Карандиру","runtime":145,"tagline":"","homepage":"","overview":"Если бы Сатана искал местечко для филиала ада на Земле, ему не пришлось бы долго возиться. Наверняка им стала бы тюрьма Карандиру, самое жуткое исправительное заведение в Бразилии.  Фантастическая антисанитария, отвратительная еда, охранники-садисты и нарушения всех мыслимых прав человека сделали ее печально знаменитой задолго до того, как однажды в 1992 году доведенные до отчаяния заключенные Карандиру подняли мятеж.  Полиция с огромным трудом потопила восстание в крови, убив 111 человек. В итоге, из-за разразившегося международного скандала властям пришлось разрушить тюрьму до основания как символ национального позора."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"კარანდირუ","runtime":0,"tagline":"","homepage":"","overview":"თუ სატანა დედამიწაზე ჯოჯოხეთის ფილიალისთვის ადგილის ძებნას დაიწყებდა, მას დიდხანს არ მოუწევდა სიარული. ეს ადგილი იქნებოდა კარანდირუს ციხე - ბრაზილიაში ყველაზე რთულად სამართავი ორგანიზაცია ..."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"La película está basada en las experiencias del doctor Drauzio Varella en la prisión estatal Carandiru, en São Paulo, Brasil, durante sus trabajos de prevención del SIDA. En la prisión se encontró con cientos de convictos bajo condiciones infrahumanas hasta el punto culminante de 1992 cuando una revuelta provocó el asesinato de 111 hombres."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Карандіру","runtime":0,"tagline":"","homepage":"","overview":"Доктор Варелла на безкоштовній основі, в ролі волонтера прибуває у в’язницю Карандіру з метою профілактики СНІДу серед ув’язнених. В перший же день він знайомиться із життям і порядками в переповненій в’язниці. Багато ув’язнених розповідають йому свої історії подій, що стали причиною їх арешту. Це реальні історії про кохання, смерть, помсту, наркотики."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"แดนนรกคุกทมิฬ","runtime":0,"tagline":"","homepage":"","overview":"ขณะที่ ดราอูวิโอ วาเรลล่า นายแพทย์ผู้เข้ามาทำงานป้องกันเรื่องโรคเอดส์ ในคุกคาแรนดิรู ในเซา เปาโล ประเทศบราซิล เขาพบว่านักโทษนับร้อยๆชีวิตมีความเป็นอยู่ที่แสนเลวร้าย สถานการณ์มาถึงจุดสิ้นสุดในปี 1992 เมื่อการปราบปรามผู้ประท้วงในคุกแห่งนี้ ตำรวจได้สังหารนักโทษไปถึง 111 คน"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"監獄淌血","runtime":0,"tagline":"","homepage":"","overview":"位於聖保羅的卡蘭迪魯是拉美最大監獄。長期超負荷關押七千名犯人的卡蘭迪魯環境惡劣，儼然一個自有體系的犯罪社會，監獄中簡陋的醫療設施無法避免犯人之間傳播疾病，一位醫生來此實施防禦艾滋病的醫療計劃，由此揭開了眾多犯人過往的經歷……毒販茲克（Wagner Moura 飾）在進入監獄后本打算洗手不幹，然而環境再次把他拖入毒品的漩渦；犯人“女士”（洛迪文裏格•桑托羅 Rodrigo Santoro 飾）在監獄中愛上了醫生的助手，最後成婚；搶劫犯米羅被妻子背叛，怒而連殺多人入獄；流浪漢海尼斯為愛情犯下了縱火的罪行。一幕幕人間悲劇匯聚在卡蘭迪魯，壓抑的人群最終爆發出一場令人瞠目結舌的監獄暴動。\r 本片根據 1992 年發生在巴西的監獄暴動事件改編。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":20268,"adult":false,"title":"Last Stop 174","video":false,"overview":"Sandro was a boy who loved to sing rap, to kiss, to stare the statue of Christ the Redeemer and dreamed to go visit Copacabana. Growing up on streets, the story culminates at the infamous episode of 12th June 2000, when Sandro hijacked bus 174.","genre_ids":[18,80],"media_type":"movie","popularity":0.6107,"vote_count":187,"poster_path":"/qvSZA7HIJMelYSaQ7ObBCylDnsX.jpg","release_date":"2008-10-24","vote_average":7.195,"backdrop_path":"/xhK1B9ilRCvOKdEs6JofFQj5JDf.jpg","original_title":"Última Parada 174","original_language":"pt"},{"id":34196,"adult":false,"title":"God Is Brazilian","video":false,"overview":"God decides to take a vacation, but first He has to find a saint who can rule the universe while He's away. So He goes to the Northeast of Brazil, where He believes there's a very good man for the job. As soon as He comes down to Earth, a young man comes along to help on His quest.","genre_ids":[12,35,14],"media_type":"movie","popularity":0.5367,"vote_count":159,"poster_path":"/g7mDnFbYus7q9z2OtvJgFWLFjFn.jpg","release_date":"2003-01-31","vote_average":6.2,"backdrop_path":"/8B5KwdFiSUZTQZsLybMj8nt0NU9.jpg","original_title":"Deus é Brasileiro","original_language":"pt"},{"id":40823,"adult":false,"title":"The Man Who Copied","video":false,"overview":"A young photocopier operator becomes infatuated with his neighbor and, unable to afford anything from her shop, turns to shady schemes to make money.","genre_ids":[35,18,10749,80],"media_type":"movie","popularity":0.4663,"vote_count":371,"poster_path":"/3RsEkEdLEFd0Q5HThqMd4X8tYZk.jpg","release_date":"2003-06-13","vote_average":7.503,"backdrop_path":"/fN4OThflKQ8ZT1w2qRRIJmLejKk.jpg","original_title":"O Homem Que Copiava","original_language":"pt"},{"id":51976,"adult":false,"title":"Brother","video":false,"overview":"Brothers Daniel and Julio fight to escape a violent and poor Caracas neighborhood by playing soccer. Daniel wishes to go professional while Julio supports the family with dirty money. The opportunity of a lifetime comes when a talent scout invites them to the local football club. However, after their mother is killed in a shootout, each brother is forced to decide what's more important: family, revenge, or achieving their dreams.","genre_ids":[18],"media_type":"movie","popularity":0.4931,"vote_count":30,"poster_path":"/1nTTDblwirJMMhqeJu70pAmetuK.jpg","release_date":"2010-07-02","vote_average":6.7,"backdrop_path":"/hMPHmocpwcMKoHCpcUKFbx7Uq1A.jpg","original_title":"Hermano","original_language":"es"},{"id":33636,"adult":false,"title":"Nina","video":false,"overview":"After losing her job, an unstable woman sinks further and further into a violent fantasy world.","genre_ids":[18,53],"media_type":"movie","popularity":3.4308,"vote_count":25,"poster_path":"/qrNAhc4sY2OKgw4GlkCR9fvW6Ii.jpg","release_date":"2004-01-28","vote_average":5.6,"backdrop_path":"/xVW4IOder9cyJKSZMI5ip9zHWDf.jpg","original_title":"Nina","original_language":"pt"},{"id":289350,"adult":false,"title":"Spending the Night","video":false,"overview":"A teen couple plans for a night in private when the boy’s parents are away. At first it appears as a cosy night of sofa lounging, snack eating and film. But it soon becomes evident that beneath the façade of relaxed mutuality, there is a relationship based on insecurities and demands. Due to a fight, the parents cut their evening short, and when they return, the situation gets out of hand and feelings of hurt lead to abuse. Adolfsson paints a gruesome picture of adolescent love and how fears and expectations can completely override a young person’s will.","genre_ids":[18],"media_type":"movie","popularity":0.2212,"vote_count":6,"poster_path":"/7FSR6pfacBJmDcsqI0IKSGPahlj.jpg","release_date":"2007-08-29","vote_average":3.667,"backdrop_path":null,"original_title":"Myskväll","original_language":"sv"},{"id":1118267,"adult":false,"title":"Fale Comigo Verão: O diário de um cineasta amador","video":false,"overview":"For years, together with his partners from the production company O Quadro, he has been betting on cinema as a tool to explore the typical issues of youth. In this film, Evandro Scorsin turns the cameras on himself as he deals with the dilemmas of the passing of time and the imposition of adulthood. In an exercise in autofiction where cinema and life merge, the film is also a cinematic love letter to the beloved masters (especially Nicholas Ray). Coming and going between two countries and times, it records the vertigo of displacement and the reinventions inherent to an immigrant experience.","genre_ids":[99,18],"media_type":"movie","popularity":0.0952,"vote_count":1,"poster_path":"/vLnHtEqmQ9tCiBBY1BRZ9CLf0xP.jpg","release_date":"2023-06-15","vote_average":7,"backdrop_path":"/9FKMIpZ4ETw5hqzRn67QfSAnink.jpg","original_title":"Fale Comigo Verão: O diário de um cineasta amador","original_language":"pt"},{"id":464619,"adult":false,"title":"Deus ex Machina","video":false,"overview":"A young, unbelieving couple is being pursued by a terrifying monster. They try to hide in a church, where they meet a priest who seems friendly at first glance, but it soon becomes clear that the priest has less than honorable plans for them. They are trapped.","genre_ids":[14,27,9648,36],"media_type":"movie","popularity":0.0311,"vote_count":1,"poster_path":"/tGUKNZVCqtWQzMhDkmRUfGOm0qm.jpg","release_date":"2017-05-13","vote_average":8,"backdrop_path":null,"original_title":"Deus ex Machina","original_language":"nl"},{"id":314029,"adult":false,"title":"Neon Bull","video":false,"overview":"Iremar works at the rodeo in North East of Brazil. From his home, the truck he uses to transport the animals, he dreams of a future in the region's booming clothing industry.","genre_ids":[18],"media_type":"movie","popularity":0.4265,"vote_count":101,"poster_path":"/5UZOBQBxofQguD2jGgHxvZjqiLI.jpg","release_date":"2016-01-14","vote_average":6.718,"backdrop_path":"/ldVlc16CVgreuzuv236HRMbmI2.jpg","original_title":"Boi Neon","original_language":"pt"},{"id":14757,"adult":false,"title":"Osama","video":false,"overview":"After the rise of the Taliban in Afghanistan and the restriction of women in public life, a preteen girl is forced to masquerade as a boy in order to find work to support her mother and grandmother.","genre_ids":[18],"media_type":"movie","popularity":0.6094,"vote_count":127,"poster_path":"/pOKz4zpccIjdib2pfDRkg69Ojej.jpg","release_date":"2004-03-24","vote_average":6.984,"backdrop_path":"/1Xwbli4B20ajKdq4fWSmWavMAds.jpg","original_title":"Osama","original_language":"ps"},{"id":1002307,"adult":false,"title":"Untold: Operation Flagrant Foul","video":false,"overview":"Years after serving time for betting on games he officiated, former NBA referee Tim Donaghy revisits the scandal that shook up the league.","genre_ids":[99],"media_type":"movie","popularity":0.2796,"vote_count":47,"poster_path":"/pArr12pr825SWb06ihiWesJsuR0.jpg","release_date":"2022-08-30","vote_average":7.074,"backdrop_path":"/maZ8F3fvi8moX5p8fJ1eXDq9Dj4.jpg","original_title":"Untold: Operation Flagrant Foul","original_language":"en"},{"id":52345,"adult":false,"title":"Lisbela and the Prisoner","video":false,"overview":"Lisbela is a young woman who loves going to the movies. Leléu is a con man, going from town to town selling all sort of things and performing as master of ceremonies for some cheesy numbers, such as the woman who gets transformed into a gorilla. He gets involved with Linaura, a sexy and beautiful woman who happens to be the wife of the most frightening hitman of the place. The hitman finds out his wife's affair and goes after Leléu, who has to leave in a hurry. In another town, he meets and falls instantly in love with Lisbela, who is engaged to Douglas, a hillbilly who tries hard to pass for a cosmopolitan Rio de Janeiro dweller.","genre_ids":[35,10749],"media_type":"movie","popularity":0.7134,"vote_count":401,"poster_path":"/raCdo5Hjpd3uXbpSd1JZ7tEyE31.jpg","release_date":"2003-08-22","vote_average":7.825,"backdrop_path":"/eAOOeqa14oCxgdKxLvpDYxCJhqQ.jpg","original_title":"Lisbela e o Prisioneiro","original_language":"pt"},{"id":53961,"adult":false,"title":"Brainstorm","video":false,"overview":"Neto is a middle class teenager living a normal life. After his father finds a marijuana cigarette on his pocket, he is sent to a mental institution, where he gets to know a completely absurd and inhumane reality in which people are devoured by a corrupt and cruel system.","genre_ids":[18],"media_type":"movie","popularity":0.5194,"vote_count":225,"poster_path":"/x6NXI2jvi9iKbzjjHRMtZ7mCPjB.jpg","release_date":"2001-06-22","vote_average":7.9,"backdrop_path":"/nwPHdJp7bwFCFwcxUTuqHvtcESi.jpg","original_title":"Bicho de Sete Cabeças","original_language":"pt"},{"id":70666,"adult":false,"title":"VIPs","video":false,"overview":"Marcelo leaves his family and moves to Mato Grosso do Sul, where he learns how to fly airplanes by himself watching the pilots. One day, he responds the call of a drug dealer and uses his boss' plane to help the man to transport his cargo. He is hired by the drug lord to work transporting drugs in his airplanes. When he is arrested by the Federal Police, he does not rat his gang and the leader of the cartel gives a large amount of money as a bonus and asks him to leave the gang since he is known by the police. Marcelo uses the money to promote a party in the Carnival of Recife pretending to be the son of the owner of the Gol (a Brazilian air flight company). He lures the high-society, including the television presenter Amaury Jr. Marcelo is arrested again and is sent to prison. During a rebellion, he uses his leadership to present the claims of the prisoners and help to control the situation.","genre_ids":[18],"media_type":"movie","popularity":1.5886,"vote_count":115,"poster_path":"/vVkXbIxrgRkXr0mir5iDVrCh657.jpg","release_date":"2011-03-25","vote_average":6.404,"backdrop_path":"/e3AwTLfByC96w1sTgtpbag9Jqwp.jpg","original_title":"VIPs","original_language":"pt"},{"id":651906,"adult":false,"title":"M8 - When Death Rescues Life","video":false,"overview":"When Maurício becomes a student at a top medical school, he becomes obsessed with a mystery linked to the dead bodies used for dissection.","genre_ids":[18,53],"media_type":"movie","popularity":0.2272,"vote_count":52,"poster_path":"/cCyAqeRPvKj8nJm1Eux5logss7W.jpg","release_date":"2019-12-03","vote_average":7.2,"backdrop_path":"/uC2CEyuz0ex1NthuBmFIV4U6gM4.jpg","original_title":"M-8: Quando a Morte Socorre a Vida","original_language":"pt"},{"id":173443,"adult":false,"title":"Rio 2096: A Story of Love and Fury","video":false,"overview":"“Rio 2096 – A Story of Love and Fury” is an animated film that portrays the love between an immortal hero and Janaína, the woman he has been in love with for 600 years. As a backdrop to the romance, the feature highlights four phases of Brazilian history: colonization, slavery, the Military Regime and the future, in 2096, when there will be a war for water.","genre_ids":[16,18,36,10749,878,14],"media_type":"movie","popularity":0.5066,"vote_count":91,"poster_path":"/aqvJxBR3Tpj9semsPYgCZ2tE3UZ.jpg","release_date":"2013-03-07","vote_average":7.2,"backdrop_path":"/vv5QbvqKRpsqVcVTK6aZzTtdaq8.jpg","original_title":"Uma História de Amor e Fúria","original_language":"pt"},{"id":17358,"adult":false,"title":"My Name Ain't Johnny","video":false,"overview":"The true story of João Guilherme Estrella (\"Johnny\"), a young middle-class bon vivant who became a big-time cocaine dealer in Rio de Janeiro in the early 1990s.","genre_ids":[80,18],"media_type":"movie","popularity":0.3004,"vote_count":276,"poster_path":"/mKDKutX0bCvg401k68U9Nt7EG0y.jpg","release_date":"2008-01-04","vote_average":7.1,"backdrop_path":"/uAX6NW8kFFrGmc0nJTWL7ajymQf.jpg","original_title":"Meu Nome não é Johnny","original_language":"pt"},{"id":227493,"adult":false,"title":"Tattoo","video":false,"overview":"Paulete, the star of a daring theater group, is visited by his military brother-in-law, the young Fininha. A torrid relationship arises between the two, and now the soldier must deal with the prevailing repression during the Brazilian military dictatorship.","genre_ids":[18],"media_type":"movie","popularity":0.4361,"vote_count":82,"poster_path":"/oTOAnRwz9LzesLqis5VwR9sWNnM.jpg","release_date":"2013-11-14","vote_average":7.6,"backdrop_path":"/2LULaQUvzXPkhRhFDs5wYoHYb3r.jpg","original_title":"Tatuagem","original_language":"pt"},{"id":14421,"adult":false,"title":"The Year My Parents Went on Vacation","video":false,"overview":"A boy is left alone in a Jewish neighborhood in the year of 1970, where both world cup and dictatorship happen in Brazil.","genre_ids":[18],"media_type":"movie","popularity":0.2274,"vote_count":120,"poster_path":"/nwa1Xo1sldbiLIOfFWLvF3rgdKG.jpg","release_date":"2006-09-26","vote_average":7.204,"backdrop_path":"/bJkz0osfRO2RwLCr7LVqLFyd2pL.jpg","original_title":"O Ano em que Meus Pais Saíram de Férias","original_language":"pt"},{"id":36093,"adult":false,"title":"Behind the Sun","video":false,"overview":"Brazilian badlands, April 1910. Tonho is ordered by his father to avenge the death of his older brother. The young man knows that if he commits this crime, his life will be divided in two: the twenty years he has already lived and the few days he has left to live, before the other family avenges their son's death. He is torn between fulfilling his ancestral duty and rebelling against it, urged by his younger brother Pacu. That's when a tiny travelling circus passes through the vast badlands where Tonho's family lives.","genre_ids":[18,53,10749],"media_type":"movie","popularity":0.3695,"vote_count":128,"poster_path":"/zkNQBhT8op04I1JYwRqNhjX4quD.jpg","release_date":"2001-12-12","vote_average":7.336,"backdrop_path":"/9fKYqsnqDKvu2vRgTzJMTfPeBoc.jpg","original_title":"Abril Despedaçado","original_language":"pt"}],"similar_content":[{"id":101,"adult":false,"title":"Léon: The Professional","video":false,"overview":"Léon, the top hit man in New York, has earned a rep as an effective \"cleaner\". But when his next-door neighbors are wiped out by a loose-cannon DEA agent, he becomes the unwilling custodian of 12-year-old Mathilda. Before long, Mathilda's thoughts turn to revenge, and she considers following in Léon's footsteps.","genre_ids":[80,18,28],"popularity":14.251,"vote_count":15809,"poster_path":"/bxB2q91nKYp8JNzqE7t7TWBVupB.jpg","release_date":"1994-09-14","vote_average":8.295,"backdrop_path":"/jRJrQ72VLyEnVsvwfep8Xjlvu8c.jpg","original_title":"Léon","original_language":"fr"},{"id":66,"adult":false,"title":"Absolute Power","video":false,"overview":"A master thief coincidentally is robbing a house where a murder—in which the President of the United States is involved—occurs in front of his eyes. He is forced to run, while holding evidence that could convict the President.","genre_ids":[80,18,28],"popularity":2.7585,"vote_count":1202,"poster_path":"/izvyt3cxlilhbYwybTOteDWqf99.jpg","release_date":"1997-02-14","vote_average":6.658,"backdrop_path":"/cLftTzGw40BlLw8IggKSWDjKOQo.jpg","original_title":"Absolute Power","original_language":"en"},{"id":69,"adult":false,"title":"Walk the Line","video":false,"overview":"A chronicle of country music legend Johnny Cash's life, from his early days on an Arkansas cotton farm to his rise to fame with Sun Records in Memphis, where he recorded alongside Elvis Presley, Jerry Lee Lewis and Carl Perkins.","genre_ids":[18,10402,10749],"popularity":2.8961,"vote_count":3073,"poster_path":"/p8lPTjvjOjTfvC1E9pmMwcF9vkn.jpg","release_date":"2005-09-13","vote_average":7.495,"backdrop_path":"/pMBKzEotLUzk3NuQiyVjZEDlH70.jpg","original_title":"Walk the Line","original_language":"en"},{"id":73,"adult":false,"title":"American History X","video":false,"overview":"Derek Vineyard is paroled after serving 3 years in prison for killing two African-American men. Through his brother, Danny Vineyard's narration, we learn that before going to prison, Derek was a skinhead and the leader of a violent white supremacist gang that committed acts of racial crime throughout L.A. and his actions greatly influenced Danny. Reformed and fresh out of prison, Derek severs contact with the gang and becomes determined to keep Danny from going down the same violent path as he did.","genre_ids":[18],"popularity":7.7894,"vote_count":12341,"poster_path":"/x2drgoXYZ8484lqyDj7L1CEVR4T.jpg","release_date":"1998-07-01","vote_average":8.327,"backdrop_path":"/6qHI1IYj7QlLSCwHRzkL62X175s.jpg","original_title":"American History X","original_language":"en"},{"id":88,"adult":false,"title":"Dirty Dancing","video":false,"overview":"Expecting the usual tedium that accompanies a summer in the Catskills with her family, 17-year-old Frances 'Baby' Houseman is surprised to find herself stepping into the shoes of a professional hoofer—and unexpectedly falling in love.","genre_ids":[18,10402,10749],"popularity":7.9902,"vote_count":6423,"poster_path":"/9Jw6jys7q9gjzVX5zm1z0gC8gY9.jpg","release_date":"1987-08-21","vote_average":7.328,"backdrop_path":"/6iDQCBUSZKzY8Rnu8ECwl2gXcfG.jpg","original_title":"Dirty Dancing","original_language":"en"},{"id":2,"adult":false,"title":"Ariel","video":false,"overview":"A Finnish man goes to the city to find a job after the mine where he worked is closed and his father commits suicide.","genre_ids":[35,18,10749,80],"popularity":2.7092,"vote_count":369,"poster_path":"/ojDg0PGvs6R9xYFodRct2kdI6wC.jpg","release_date":"1988-10-21","vote_average":7.104,"backdrop_path":"/hQ4pYsIbP22TMXOUdSfC2mjWrO0.jpg","original_title":"Ariel","original_language":"fi"},{"id":854086,"adult":false,"title":"The Web of Silence - A.I.D.S.","video":false,"overview":"Walter is HIV positive and is leading a promiscuis life in Rome.  He does this so that he won’t infect his wife. Walter’s wife is also cheating on him.  In a decidedly dull subplot, Walter’s father is a senator who wants to use his son’s illness to promote his own political career by calling for more AIDS research.","genre_ids":[18],"popularity":0.1548,"vote_count":2,"poster_path":"/pbdZZomz9vstYuBNCZBPaf6dLJP.jpg","release_date":"1994-04-08","vote_average":2,"backdrop_path":null,"original_title":"La ragnatela del silenzio – A.I.D.S.","original_language":"it"},{"id":271223,"adult":false,"title":"The Plague","video":false,"overview":"A nurse in the Red Crescent (the Turkish equivalent of the Red Cross) fights to save the populace during a plague.","genre_ids":[18],"popularity":0.6731,"vote_count":1,"poster_path":"/y5wJXWk6aBg1rhkXZnqlTYer10Y.jpg","release_date":"1954-01-01","vote_average":6,"backdrop_path":null,"original_title":"Salgin","original_language":"en"},{"id":1598,"adult":false,"title":"Cape Fear","video":false,"overview":"Sam Bowden is a small-town corporate attorney. Max Cady is a tattooed, cigar-smoking, Bible-quoting, psychotic rapist. What do they have in common? 14 years ago, Sam was a public defender assigned to Max Cady's rape trial, and he made a serious error: he hid a document from his illiterate client that could have gotten him acquitted. Now, the cagey Cady has been released, and he intends to teach Sam Bowden and his family a thing or two about loss.","genre_ids":[18,80,53],"popularity":3.6632,"vote_count":3776,"poster_path":"/ws4mrtndzgSH5QGCamOFAgilr2R.jpg","release_date":"1991-11-13","vote_average":7.255,"backdrop_path":"/ntgpger7OwFNlEldxuvvFHDKzjW.jpg","original_title":"Cape Fear","original_language":"en"},{"id":1574,"adult":false,"title":"Chicago","video":false,"overview":"Murderesses Velma Kelly and Roxie Hart find themselves on death row together and fight for the fame that will keep them from the gallows in 1920s Chicago.","genre_ids":[35,80,18],"popularity":4.4551,"vote_count":2852,"poster_path":"/3ED8cWCXY9zkx77Sd0N5qMbsdDP.jpg","release_date":"2002-12-10","vote_average":7.1,"backdrop_path":"/jkyqFgqmZlH5vSURckq0GgsewOY.jpg","original_title":"Chicago","original_language":"en"},{"id":1623,"adult":false,"title":"Brubaker","video":false,"overview":"The new warden of a small prison farm in Arkansas tries to clean it up of corruption after initially posing as an inmate.","genre_ids":[80,18],"popularity":3.9049,"vote_count":508,"poster_path":"/4DhrSojl3J0Z4wZyM2CfNGnKQWl.jpg","release_date":"1980-06-20","vote_average":7.1,"backdrop_path":"/1mrub90uU3Q36Nvnwz2fzZdItwl.jpg","original_title":"Brubaker","original_language":"en"},{"id":1627,"adult":false,"title":"The Wild Child","video":false,"overview":"In a French forest circa 1798, a child–who cannot walk, speak, read or write–is found. A doctor becomes interested in the case and patiently attempts to civilise the boy.","genre_ids":[18,36],"popularity":0.6389,"vote_count":299,"poster_path":"/ivIyyc2VgefJK9LdAogl1BEgmeH.jpg","release_date":"1970-02-26","vote_average":7,"backdrop_path":"/iezEtU0jnEu0P2128PkBxVjJf7x.jpg","original_title":"L'Enfant sauvage","original_language":"fr"},{"id":1645,"adult":false,"title":"A Time to Kill","video":false,"overview":"A young lawyer defends a black man accused of murdering two white men who raped his 10-year-old daughter, sparking a rebirth of the KKK.","genre_ids":[80,18,53],"popularity":5.1467,"vote_count":2868,"poster_path":"/w8UCke112E9jrhjKcwG32kyhTx5.jpg","release_date":"1996-07-24","vote_average":7.386,"backdrop_path":"/bwLQCW6LqmrJ6aJsevypcg93JCU.jpg","original_title":"A Time to Kill","original_language":"en"},{"id":1653,"adult":false,"title":"The Motorcycle Diaries","video":false,"overview":"Based on the journals of Che Guevara, leader of the Cuban Revolution. In his memoirs, Guevara recounts adventures he and best friend Alberto Granado had while crossing South America by motorcycle in the early 1950s.","genre_ids":[18],"popularity":2.2876,"vote_count":1400,"poster_path":"/qz2aBYT8CAiJYvX4fRZpJ5G0Oz1.jpg","release_date":"2004-02-06","vote_average":7.411,"backdrop_path":"/o6Ln9kTC4ZrHZNUhWLOwBfUvqXU.jpg","original_title":"Diarios de motocicleta","original_language":"es"},{"id":1782,"adult":false,"title":"Afterwards","video":false,"overview":"Newly divorced lawyer Nathan Del Amico is shaken up after he meets a doctor who claims that he can sense when select people are about to die. Though he doesn't believe the doctor, events in Nathan's life slowly make him think he's not long for this world.","genre_ids":[18,9648,53],"popularity":3.0059,"vote_count":142,"poster_path":"/byElFR4rU7aU8FQoorVNmIxCSUV.jpg","release_date":"2008-10-01","vote_average":5.488,"backdrop_path":"/k2UCLlYQIy0nj2M8jtSwAHW442u.jpg","original_title":"Afterwards","original_language":"en"},{"id":1711,"adult":false,"title":"No Code of Conduct","video":false,"overview":"A cop, his partner, and his father uncover a plot by city elders to smuggle drugs from Mexico into Phoenix, Arizona.","genre_ids":[28,18,53],"popularity":0.6242,"vote_count":32,"poster_path":"/9Ml1UUzLvoB5BjDvwFyMVvdstiH.jpg","release_date":"1999-03-19","vote_average":5.344,"backdrop_path":"/yqwxYu9UoPMYYNJFs9l12ID9qze.jpg","original_title":"No Code of Conduct","original_language":"en"},{"id":465501,"adult":false,"title":"The Christmas Cure","video":false,"overview":"A doctor returns home for Christmas to find that her father has decided to retire from his own practice. After reuniting with her high school sweetheart, she wonders if she should stay and take over her father's practice.","genre_ids":[10770,10749,18],"popularity":0.5462,"vote_count":58,"poster_path":"/q5lRVUm0qFUUP4Ffo7z6kAHflBL.jpg","release_date":"2017-07-15","vote_average":5.871,"backdrop_path":"/jj5PFvnd5Y2QyqtBDZGrlgsUM0E.jpg","original_title":"The Christmas Cure","original_language":"en"},{"id":1873,"adult":false,"title":"Beyond Rangoon","video":false,"overview":"Dr. Laura Bowman is a young widow who's unwittingly drawn into political turmoil while vacationing in Burma in the late 1980s. Bowman initially left San Francisco with her sister in an attempt to escape painful memories of her husband and son's violent deaths. But her fight to escape to Thailand could prove just as harrowing.","genre_ids":[18,53],"popularity":0.6038,"vote_count":83,"poster_path":"/xTiy5kSP3Hetig7xB4E8INq5ron.jpg","release_date":"1995-08-25","vote_average":6.6,"backdrop_path":"/dcGsNJtwBXnXmSqze0289IjScTR.jpg","original_title":"Beyond Rangoon","original_language":"en"},{"id":1879,"adult":false,"title":"Guess Who's Coming to Dinner","video":false,"overview":"A couple's attitudes are challenged when their daughter brings home a fiancé who is black.","genre_ids":[18,10749],"popularity":1.9927,"vote_count":898,"poster_path":"/fkHeYWahNbhxhuLefaAg553lYo5.jpg","release_date":"1967-12-11","vote_average":7.579,"backdrop_path":"/yTKXKR9quKkH8N8szLjWLJ6TLBy.jpg","original_title":"Guess Who's Coming to Dinner","original_language":"en"},{"id":1883,"adult":false,"title":"Malcolm X","video":false,"overview":"A tribute to the controversial black activist and leader of the struggle for black liberation. He hit bottom during his imprisonment in the '50s, he became a Black Muslim and then a leader in the Nation of Islam. His assassination in 1965 left a legacy of self-determination and racial pride.","genre_ids":[18,36],"popularity":4.0729,"vote_count":1841,"poster_path":"/o2s9ow0uRRm1BcF3teznk5twd90.jpg","release_date":"1992-11-18","vote_average":7.543,"backdrop_path":"/2yZdgLUHmhL1UG57OYc2yksrmPl.jpg","original_title":"Malcolm X","original_language":"en"}],"external_ids":{"imdb_id":"tt0293007","twitter_id":null,"facebook_id":null,"wikidata_id":"Q2280159","instagram_id":null,"metacritic_id":"movie/carandiru","mydramalist_id":"38523","rotten_tomatoes_id":"m/carandiru"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148171,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AR","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2004-03-18T00:00:00.000Z","certification":""}]},{"iso_3166_1":"BR","release_dates":[{"note":"II Panorama Internaciona