9:{"metadata":[["$","title","0",{"children":"Cannonball | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Coy \"Cannonball\" Buckman and his blazing red Pontiac enter the Trans-America Grand Prix, an underground road race spanning the continent in which there are no rules, no speed limits and no heed for the law. En route, Buckman jockeys with an international ensemble of racers for a $100,000 purse. But there are none more important than Cade Redman, his direct competition for a guaranteed spot on the elite Modern Motors racing team."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/102083/cannonball"}],["$","meta","5",{"property":"og:title","content":"Cannonball"}],["$","meta","6",{"property":"og:description","content":"Coy \"Cannonball\" Buckman and his blazing red Pontiac enter the Trans-America Grand Prix, an underground road race spanning the continent in which there are no rules, no speed limits and no heed for the law. En route, Buckman jockeys with an international ensemble of racers for a $100,000 purse. But there are none more important than Cade Redman, his direct competition for a guaranteed spot on the elite Modern Motors racing team."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/102083/cannonball"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/u85Yi7wJRKS7lgLjQdpQqOxJNO7.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Cannonball"}],["$","meta","12",{"name":"twitter:description","content":"Coy \"Cannonball\" Buckman and his blazing red Pontiac enter the Trans-America Grand Prix, an underground roa