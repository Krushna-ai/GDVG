ES","english_name":"Spanish"},{"data":{"title":"A Cela dos Milagres","runtime":0,"tagline":"","homepage":"","overview":"Preso por um crime que não cometeu, um pai dedicado luta para provar a própria inocência. Enquanto isso, sua filha precisa se virar sozinha."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Dopo essere stato falsamente accusato di un terribile crimine, Hector, un uomo affetto da una disabilità neurologica, viene rinchiuso in una prigione segreta. La sua bontà conquista i prigionieri, che decidono di provare la loro innocenza."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"A Father's Miracle","runtime":0,"tagline":"","homepage":"","overview":"พ่อผู้ทุ่มเทให้กับลูกสาวถูกจำคุกอย่างไม่เป็นธรรมในข้อหาที่เขาไม่ได้กระทำ ทำให้ลูกสาวต้องดิ้นรนเอาตัวรอดเพียงลำพัง ขณะที่เขาพยายามพิสูจน์ความบริสุทธิ์ของตนเอง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[],"external_ids":{"imdb_id":"tt39742477","twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148371,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AR","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-02-13T00:00:00.000Z","certification":""}]},{"iso_3166_1":"BR","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-02-13T00:00:00.000Z","certification":"14"}]},{"iso_3166_1":"MX","release_dates":[{"note":"","type":3,"iso_639_1":"es","descriptors":[],"release_date":"2025-12-25T00:00:00.000Z","certification"