1920,"height":1080,"file_path":"/xwwgHMrsvVIcqrgjinKZIwvbr3e.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/4zaXnKq25i64VhdwuN3KUm8M3pw.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/hrCUkBW3LhiVULRibGymtxq84sH.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/eaXgfqUjXA9iNwzL2nxujQCNWhs.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2400,"height":1350,"file_path":"/47oXVoDjOtih551WNisVSiGG9xI.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/nbSwyE90WWvd7TSyXdmaxOI1zWy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/mBURk89N2RG9CARHPr3A372OVYj.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/bNoZplkkDk4h2VJD4Qb7jDmJyX4.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/jdr8EsV3C8hIF89KZKp2fnjGcVn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/4uMg6okWarzWUJP6cx3V5sWOrSe.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/pLSniyrBvljv0gYpXTUQizqMdKI.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/1SNAD4hXtMhVviYX7dubA72F3Kv.jpg","iso_639_1":"da","iso_3166_1":"DK","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":null,"enrichment_cycle":0,"translations":[{"data":{"title":"The Fifth Element","runtime":126,"tagline":"There is no future without it.","homepage":"https://www.sonypictures.com/movies/thefifthelement","overview":"In 2257, a taxi driver is unintentionally given the task of saving a young girl who is part of the key that will ensure the survival of humanity."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Das fünfte Element","runtime":126,"tagline":"Das Fünfte ist Leben.","homepage":"","overview":"Im 23. Jahrhundert bewegt sich das Böse in Form eines nahezu unzerstörbaren Kometen auf die Erde zu. Wird er nicht aufgehalten, wird er die Welt vernichten. Doch die Mondoshawan, ein uraltes, friedliebendes Volk, besitzen eine Waffe, das sogenannte fünfte Element, mit der der Komet vernichtet werden kann. Auf ihrem Weg zur Erde werden sie jedoch von bösen Mächten vernichtet, die den Untergang der Menschheit herbeiführen wollen. Wissenschaftlern aber gelingt es, das fast zerstörte fünfte Element wieder herzustellen. Durch eine Reihe von Zufällen wird schließlich der Taxifahrer Korben Dallas in die Geschichte hineingezogen: In seinen Händen liegt plötzlich die Zukunft der Menschheit."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"El quinto elemento","runtime":127,"tagline":"No hay futuro sin él.","homepage":"","overview":"Cada 5.000 años se abre una puerta entre las dimensiones. En una dimensión existe el Universo y la vida. En la otra dimensión existe un elemento que no está hecho ni de tierra, ni de fuego, ni de aire, ni de agua, sino que es una anti-energía, la anti-vida: es el quinto elemento."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":126,"tagline":"Il n'y a pas d'avenir sans cela.","homepage":"","overview":"New York, XXIIIe siècle. Une boule de feu fonce sur la Terre. Pour l'arrêter il faut retrouver le Cinquième Élément, l'être suprême, qui, associé aux quatre éléments vitaux - l'air, l'eau, le feu et la terre - peut seul repousser Le Mal. Cornélius reçoit l'aide de Korben, taxi et ancien agent secret, et de Leeloo, extraterrestre qui a pris la forme d'une jeune femme aux cheveux oranges."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Il quinto elemento","runtime":122,"tagline":"Non c'è futuro senza di esso.","homepage":"","overview":"Una congiunzione provoca l'apertura di un varco attraverso cui una forza penetra nel nostro universo. Gli antichi egizi lo sapevano, ed anzi erano i custodi dell'arma capace di arrestarla, basata sulla fusione dei quattro elementi primari: terra, acqua, fuoco e aria, e di un quinto elemento. Ma agli inizi del ventesimo secolo scendono sulla Terra i Mondoshawan, esseri superiori e benefici che portano via l'arma, promettendo di restituirla. Il momento arriva nel 2259, quando il passaggio si riapre e l'universo è di nuovo minacciato. I Mondoshawan rispediscono sulla Terra l'arma con il quinto elemento, l'amore, incarnato in Leeloo,  ma l'astronave viene intercettata e distrutta dai Mangalore. Fortunatamente dal relitto vengono estratti resti sufficienti a clonare la ragazza, ma la nuova Leeloo non ricorda nulla di sè nè del compito che l'attende. Fuggendo si imbatte nel tassista Korben Dallas, che l'aiuterà a recuperare gli altri quattro elementi e a salvare il mondo."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"O 5º Elemento","runtime":126,"tagline":"Sem ele, não há futuro...","homepage":"","overview":"Estamos no ano 2257. Uma esfera do tamanho de um planeta, representando o mal supremo, está a aproximar-se da Terra a uma velocidade vertiginosa e ameaça todas as formas de vida do planeta. A única forma de impedi-lo é conseguir reunir quatro pedras antigas que representam quatro — terra, vento, fogo e água — com um misterioso 5.º Elemento."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Пятый элемент","runtime":126,"tagline":"«Он должен быть найден»","homepage":"","overview":"2257 год. Бывший секретный агент Корбен Даллас работает таксистом, ест в одном и том же ресторане и не ждёт перемен от жизни. Всё меняется, когда в его такси падает инопланетянка Лилу — единственное существо, способное спасти человечество. Вместе им предстоит остановить надвигающееся зло и предотвратить межгалактическую войну."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bokmål","iso_639_1":"nb","iso_3166_1":"NO","english_name":"Norwegian Bokmål"},{"data":{"title":"Beşinci Güç","runtime":0,"tagline":"","homepage":"","overview":"23. yüzyılda New York. Dünya yok olmanın eşiğindedir. Her 5000 yılda bir geri dönerek yaşamı yok etmeye çalışan şeytani güç, bir gezegen biçiminde hızla dünyaya yaklaşmaktadır. Tek kurtuluş beşinci güç olarak adlandırılan, kimsenin ne olduğunu bilmediği elementin dünyaya ulaşmasıdır.Bunu başaracak tek kişi eski bir asker olan taksi şoförü Korben Dallas'dır. Ancak onun ilgilenmesi gereken mükemmel güzellikte bir yaratık vardır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Pátý element","runtime":126,"tagline":"","homepage":"","overview":"Každých pět tisíc let se otevře brána mezi dvěma světy. V prvním leží náš vesmír, ve druhém se rozprostírá antienergie. Tato věčná temnota trpělivě čeká na příležitost, aby zničila všechen život. Každých pět tisíc let potřebuje vesmír hrdinu. A teď, ve 23. století, se jím stal newyorský taxikář Korben Dallas, v jehož rukou nyní leží osud lidstva. A nejen lidstva."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"האלמנט החמישי","runtime":0,"tagline":"אין עתיד בלעדיו.","homepage":"","overview":"סרטו עטור האפקטים של בסון לוקח אותנו אל ניו יורק של שנת 2259. נהג מונית בשם קורבן דאלאס, מסתבך עם כוחות הרשע המחפשים את השליטה באלמנט החמישי - הנוסף למים, אדמה, רוח ואש. כמובן שאת ההגנה צריך דאלאס לתת לבחורה ג'ינג'ית מדהימה - לילו - הלבושה על פי עיצובו של ז'אן פול גוטייה המעצב המופרע והכשרוני. הסרט התבשל בראשו של בסון כבר מגיל 16 ופתח את פסטיבל הסרטים החגיגי בקאן של שנת 1997."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Piąty element","runtime":126,"tagline":"Bez tego nie ma przyszłości.","homepage":"","overview":"W ciągu każdych 5000. lat Zło Absolutne nawiedza Wszechświat w celu zniszczenia wszystkiego, co żyje. Przed wiekami w obronie wszechświata stawali Mondoshawanowie - dobroczynni kosmici, którzy wynaleźli skuteczną broń przeciw Złu i ukryli ją na Ziemi, w egipskiej świątyni, gdzie przeleżała całe stulecia. Broń ta składa się z pięciu elementów, z których cztery są przechowywanymi w specjalnych pojemnikach żywiołami natury: ziemią, ogniem, wodą i powietrzem. Niech pozostanie tajemnicą, co (a może raczej, kto) jest tym piątym, najważniejszym elementem..."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"第五元素","runtime":0,"tagline":"没有它就没有未来。","homepage":"","overview":"　　一头红发，perfect的“第五元素”莉露受命来到地球，她要协助人类与每隔五百年降临一次的邪恶力量对抗，联合风、火、水、土四块神石击退敌人。在实验室被复制出来后，言语不通的莉露在躲避人类的追捕中搭上了退役特工科本的出租车。科本带莉露找到了负责接头的神父，两人也渐渐的产生了好感。莉露与科本一同前往一个叫“失落天堂”的星球找寻另外四种元素的神石。但是，在战斗中莉露受伤昏迷，而且由于人类的暴行和无知杀戮，莉露陷入了内心的迷惘。大敌当前，科本究竟用什么力量才能唤醒莉露呢？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Az Ötödik elem","runtime":126,"tagline":"Nincs jövő nélküle.","homepage":"","overview":"Minden ötezredik évben egy kapu feltárul két dimenzió között. Az egyikben található az univerzum és benne mindenféle életforma. A másikban a Gonosz, melynek csupán egy célja van: elpusztítani az Életet. Csak a titokzatos ötödik elem mentheti meg a világot az ötezer évenként feltámadó Gonosz pusztításától. Így az univerzumnak minden ötezredik eszetendőben szüksége van egy hősre. A XXIII. század veszélyekkel és furcsaságokkal teletűzdelt univerzumában, New Yorkban egy nem mindennapi hős, Korben Dallas szembeszáll a Gonosszal, hogy az emberiséget megvédelmezze."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":126,"tagline":"","homepage":"","overview":"In de 23e eeuw wordt, zoals elke 5000 jaar, het leven op de aarde bedreigd. De enige die het onheil kan voorkomen is een vrouw, het Vijfde Element. Zij wordt geholpen door de taxichauffeur Corben Dallas. Samen moeten ze op zoek naar de andere vier elementen, en hierbij verschillende mensen en aliens zien te omzeilen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Det femte element","runtime":0,"tagline":"","homepage":"","overview":"Drosjesjåføren Korben Dallas lever i det 23. Århundrenes New York. En vanlig dag får han en vanlig passasjer, og blir dratt inn i jakten på det femte element. Det eneste som kan redde jorden fra undergang. Den kvinnelige hovedpersonen Leeloo viser seg å stå i sentrum for jakten, der den grusomme Zorg og hans undersåtter kjemper mot verdens herskere. Luc Besson (\"Nikita\", \"Leon\", \"Det Store Blå\") har skapt en fantastisk blanding av action, thriller, komedie og science fiction. Filmen er blitt en verdensomspennende suksess, godt hjulpet av Hollywoods enorme ressurser og moteskaperen Jean-Paul Gaultiers utrolige klesdesign."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Det femte elementet","runtime":127,"tagline":"","homepage":"","overview":"Taxichauffören Korben Dallas lever i det 23:e århundradets New York. En vanlig dag får han en mycket ovanlig passagerare och blir indragen i jakten på det femte elementet som skall rädda jorden från dess undergång. Den mystiska, kvinnliga huvudpersonen Leeloo visar sig snart stå i centrum för den vilda jakten, där den grymme Zorg och hans brutala undersåtar kämpar mot världens härskare med munken Cornelius i spetsen."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Piaty element","runtime":126,"tagline":"","homepage":"","overview":"Na Zem priletí kozmická loď a kontakt s ním nadviažu príslušníci mondoshawanskej civilizácie, aby si odniesli magické kamene, ktoré symbolizujú štyri živly (elementy), a sochu Najvyššej bytosti, ktorá jediná môže bojovať s Absolútnym zlom, ktoré sa na Zemi objavuje každých päťtisíc rokov. O 300 rokov neskôr sa vo vesmíre objavila stále sa zväčšujúca čierna diera - prichádza Absolútne zlo, ktoré môže zničiť svet. Jediný, kto o tom vie, je starý kňaz, strážca kľúča od tajného vchodu do svätyne. Mondohawania prichádzajú zachrániť svet, ale ich raketu zničí zástupca Absolútneho zla, magnát a vynálezca so zvrátenou životnou filozofiou Zorg. Vedcom sa podarí zrekonštruovať posledného živého mimozemšťana do podoby krásneho dievčaťa Leeloo, tá im však utečie. Súčasného newyorského taxikára Korbena Dallasa donúti, aby jej pomohol nájsť magické kamene. Tie musia rozostaviť do príslušnej konjunkcie s jedinou možnou zbraňou proti Zlu, s piatym elementom, ktorým je práve Leeloo."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Det femte element","runtime":126,"tagline":"","homepage":"","overview":"Taxachaufføren Korben Dallas redder den rødhårede Leeloo fra general Munro's mænd. Pludselig er han den eneste, der kan frelse universet fra den ondskab, som er på vej mod Jorden. De fem elementer må bringes sammen et sted i Ægypten, hvis det onde skal overvindes. Men først må Korben og Leeloo tage kampen op mod den magtbegærlige Zorg."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Το Πέμπτο Στοιχείο","runtime":126,"tagline":"Δεν υπάρχει μέλλον χωρίς αυτό","homepage":"","overview":"Μέσα στον 23ο αιώνα o Korben Dallas βρίσκεται αντιμέτωπος σε μια πάλη με μια αρχαία προφειτία. Σήμφωνα με αυτή την προφητεία η Γη θα καταστραφόταν απο ένα δαίμονα. Εκείνη τη στιγμή εμφανίζεται μια νεαρή γυναίκα που θα ανατρέψει κάποια δεδομένα, αφού με τη παρουσία της θα πείσει ότι μπορει να ξεδιαλύνει το μυστήριο και να αποφευχθεί η καταστροφή της Γης."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Петият елемент","runtime":121,"tagline":"Няма бъдеще без нея.","homepage":"","overview":"На всеки 5000 години се отваря врата между измеренията. В нашето измерение е Вселената с всичките многобройни и разнообразни форми на живот. В другата съществува един елемент, който не е направен от земя, въздух, огън или вода, а от антиенергия. Това „нещо“, този безкраен мрак, чака търпеливо възможност да унищожи целия живот. На всеки 5000 години Вселената се нуждае от герой, а да се намери такъв през XXIII век в Ню Йорк е много трудна задача."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"フィフス・エレメント","runtime":127,"tagline":"それがなければ 地球が 滅びる。","homepage":"","overview":"1914年、ナイル河畔の地下の神殿で見つかった古代文字は火・水・土・風以外の“第5の要素”があると示す。2214年、ニューヨーク。久しぶりに地球を訪れたモンドシャワン人の宇宙船は、武器商人ゾーグとその手下マンガロワ人に撃墜される。宇宙船にあった細胞を再生すると、地球の言語が分からない美少女が生まれ、町に逃げ出す。彼女、リールーはタクシー運転手コーベンに救われ、彼女の言葉が分かる神父のもとへ向かう。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"El cinquè element","runtime":0,"tagline":"No hi ha futur sense ell.","homepage":"","overview":"Cada 5000 anys s'obre una porta entre les dimensions. En una dimensió existeix l'Univers i la vida. En l'altra dimensió hi ha un element que no està fet ni de terra, ni de foc, ni d'aire, ni d'aigua, sinó que és una antienergia, l'antivida: és el cinquè element."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Al cincilea element","runtime":126,"tagline":"Nu există viitor fără el.","homepage":"","overview":"În anul 2257, un șofer de taxi are în mod neintenționat sarcina de a salva o tânără care face parte din cheia care va asigura supraviețuirea omenirii."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"П’ятий елемент","runtime":126,"tagline":"Без цього немає майбутьного.","homepage":"","overview":"Кожні 5000 років між паралельними вимірами відкриваються ворота, і сили зла та хаосу прагнуть порушити існуючу гармонію. І кожні 5000 років нашій планеті потрібен герой, який ризикне стати на заваді цього зла. У ХХIII столітті настала \"червона\" дата всесвітнього календаря і нью-йорському таксисту Корбену Даласу випала зовсім не радісна місія - врятувати світ. Йому на допомогу приходить ідеальна істота - на вигляд тендітна дівчина, яка вражена агресивністю земної цивілізації. Її звуть Лілу. Коли настане цей час, вона доповнить чотири елементи усього сутнього: вогонь, воду, землю і повітря. Але по-справжньому врятувати світ може лише кохання..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"제5원소","runtime":0,"tagline":"사라진 4개 원소를 되찾고 제 5원소의 비밀을 밝혀라","homepage":"","overview":"1914년 이집트. 한 노학자가 피라미드의 벽에 새겨진 5개 원소의 비밀을 밝혀낸다. 2259년 뉴욕. 지구에 거대한 행성이 다가와 대통령을 비롯한 전 군대는 비상상태에 빠진다. 지구를 구할 4개 원소를 가진 몬도샤인들은 지구로 오는 도중에 모두 죽게 되고 과학자들은 남은 팔로 유전자 합성을 통해 빨간 머리 소녀 리루를 만든다. 리루는 과학자들에게서 도망치던 중 전직 연방 요원인 코벤을 만나고, 두 사람은 4개 원소를 찾기 위해 피라미드의 예언을 알고 있는 코넬리우스 신부와 함께 파라다이스 행성으로 간다. 한편 무기상인 조르그도 4개 원소를 손에 넣기 위해 그들을 뒤쫓는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"O Quinto Elemento","runtime":125,"tagline":"Não existe futuro sem ele.","homepage":"","overview":"No século XXIII, um motorista de taxi de Nova York se envolve em uma aventura na qual tem de deter um ser demoníaco que percorre a galáxia a cada cinco mil anos. Se nada for feito, a Terra será destruída. Mas para isto, ele precisa encontrar quatro pedras antigas que representam os elementos e colocá-las em volta de uma bela mulher, que é o quinto elemento."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"รหัส 5 คนอึดทะลุโลก","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Пети елемент","runtime":0,"tagline":"","homepage":"","overview":"Сваких пет хиљада година отварају се врата која деле две димензије. У једној је свемир с мноштвом најразноврснијих облика живота, а у другој елемент који није сачињен од земље, ваздуха , ватре или воде, већ од анти-енергије, анти-живота. Та „ствар“, тама, на прагу свемира стрпљиво чека тренутак како би уништила свеколики живот и светло. Прекрасна млада жена Лило, савршеног духа и тела, једина може сјединити моћ четири древна елемента која одржавају живот - земљу, ваздух, ватру и воду - како би спасила Земљу од насртаја сила анти-живота..."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Penktasis elementas","runtime":0,"tagline":"","homepage":"","overview":"Keturi pasaulio elementai - žemė, oras, ugnis ir vanduo - kartu sudaro sąlygas atsirasti penktajam - gyvybei. Tačiau egzistuoja jėga, priešinga teigiamai gyvybės energijai. Jėga, kurią sudaro visa, kas bloga, kurios tikslas - sunaikinti gyvybę. Kas 5000 metų tarp dviejų pasaulių atsiveria praėjimas, ir blogio jėgos gali išsiveržti. Kas 5000 metų visatai reikia didvyrio, kuris sukliudytų blogio jėgoms. 2259 - aisiais tokiu herojumi pats to nenorėdamas netikėtai tampa niekuo neišsiskiriantis Niujorko taksistas Korbenas Dalasas. Košė užverda tada, kai į jo skraidantį taksi vieną gražią dieną tiesiog pro stogą įkrenta... pusnuogė mergina. Atsipeikėjusi ji ima labai keistai elgtis..."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Peti element","runtime":0,"tagline":"","homepage":"","overview":"Bruce Willis glumi Korbena Dallasa, njujorškog taksistu koji će postati junak u ovoj priči o ljubavi i preživljavaju u 23. stoljeću. U budućnosti kakvu je osmislio režiser Luc Besson, čovječanstvo je krenulo prema zvijezdama, šireći životnu energiju. No svakih 5000 godina, kada se nakratko otvore vrata paralelnih dimenzija, mračna sila napada univerzum. Upravo sada je to vrijeme i zao Zorg (Gary Oldman) to želi iskoristiti. Nadu za spas čovječanstvu može pružiti samo Leeloo, koja predstavlja peti element, životnu snagu. Budućnost Svemira u njezinim je rukama."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Viies element","runtime":0,"tagline":"","homepage":"","overview":"New York, 23. sajand. Maad ootab ees hukk, sest planeedile läheneb hiiglaslik tulekera. Vana munk Cornelius teab, et selle peatamiseks on vaja Viiendat Elementi, mis ühendab neli põhielementi ehk õhu, vee, tule ja maa. Corneliusele tulevad appi endine salaagent, nüüdne taksojuht Korben Dallas, ja tulnukas Leeloo. Seiklused algavad, kui kolmik asub inimkonda päästma ning astub võitlusse koletu Zorgi ja tema liitlastega."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"The Fifth Element - puuttuva tekijä","runtime":0,"tagline":"","homepage":"","overview":"Taksikuski Korben Dallas elää 2200-luvun New Yorkissa. Eräänä tavallisena päivänä hän saa hyvin epätavallisen matkustajan, ja tulee vedetyksi mukaan maailman tuholta pelastavan, viidennen elementin, ajojahtiin. Salaperäinen, kaunis punapäinen avaruusolio, Leeloo, on villin ajojahdin keskipisteenä, julman Zorgin ja hänen raakalaismaisten alamaistensa tehdessä kaikkensa kaaoksen luomiseksi."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"La kvina elemento","runtime":126,"tagline":"","homepage":"","overview":"Egiptio, 1914. Du serĉantoj malkovras la ekziston, krom akvo, aero, tero kaj fajro, de kvina elemento, kiu sola povos savi la mondon. Tiu sekreto estas protektata de Mondoshawan, estaĵoj venintaj el alia galaksio, kiuj foriras kun la promeso reveni tricent jarojn poste, kiam Malbono denove alvenos.  Tri jarcentojn poste, en nov-jorka megalopolo, la prezidento kaj ties ĉefa stabo donas maksimuman alarmon pro alproksimiĝo de giganta fajro-bulo, kiu estas detruonta la planedon. Unu el la konsilantoj, pastro Cornelius, tiama terana gardanto de la sekreto, konfirmas, ke la sola rimedo estas posedata de la Mondoshawan. Sed ilia veturilo estas detruita de Mangalores. Tie postvivas embria maso, kiu prenita de militistoj transformiĝas en belegan rufan junan virinon, Leeloo (Leeloo Mina Lekatariba Laminatcha Ekbat D Sebat). Timigita, ŝi eskapas el la stabejo antaŭ ol fali sur la taksion de Korben Dallas, kiu veturas en la aera spaco de la civito, kiel ĉiuj aliaj multnombraj veturiloj."},"name":"Esperanto","iso_639_1":"eo","iso_3166_1":"EO","english_name":"Esperanto"},{"data":{"title":"第五元素","runtime":126,"tagline":"","homepage":"","overview":"「你們人類造的每一樣東西都用在毀滅上。」  一頭紅髮的謎樣女孩莉露（蜜拉喬娃維 飾演），在實驗室中被複製出來，而此刻地球正面臨每五千年一次的浩劫，眾人相信她與消滅宇宙邪惡勢力的五種元素有所關聯，不知自己身在何處的莉露驚恐逃出實驗室，意外跌落在計程車司機柯本（布魯斯威利 飾）的車裡，兩人躲避追逐後，決定聯手尋找元素之謎並對抗與邪惡勢力勾結的野心實業家佐格。  《第五元素》據說本片的原始構想來自導演盧貝松16歲時所寫的少年小說。本片有號稱影史上特效花費最多的特效製作，而且有相當多歐洲電影及特效工作者參與，創造出與好萊塢風格不大相同的未來世界，是一部影迷必看的佳片！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"El Quinto Elemento","runtime":0,"tagline":"No hay futuro sin el.","homepage":"","overview":"Cada 5.000 años se abre una puerta entre las dimensiones. En una dimensión existe el Universo y la vida. En la otra dimensión existe un elemento que no está hecho ni de tierra, ni de fuego, ni de aire, ni de agua, sino que es una anti-energía, la anti-vida: es el quinto elemento."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Le cinquième élément","runtime":126,"tagline":"Accrochez vos ceintures à bord du Fhloston Paradise...","homepage":"","overview":"Au XXIII siècle, dans un univers étrange et coloré, ou tout espoir de survie est impossible sans la découverte du cinquième élément, un héros affronte le mal pour sauver l'humanité."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Пяты элемент","runtime":0,"tagline":"","homepage":"","overview":"ХХІІІ стагоддзе. Да Зямлі набліжаецца Зло неверагоднай сілы. Каб спыніць яго, нью-ёркскаму таксісту трэба сабраць 4 асноўных стыхіі – зямля, вада, агонь, паветра – і дадаць яшчэ адзін загадкавы Пяты элемент..."},"name":"беларуская мова","iso_639_1":"be","iso_3166_1":"BY","english_name":"Belarusian"},{"data":{"title":"Piektais elements","runtime":0,"tagline":"","homepage":"","overview":"Katrus 5000 gadus, Zemi un visu dzīvo uz tās mēģina iznīcināt Ļaunums. 23. gadsimtā visa dzīvā glābēja misiju ir jāuzņemas taksometra šoferim Korbenam Dallasam kopā ar kādu meiteni - Lilū, kura pavisam negaidīti uzradās Korbena taksometra aizmugurējā sēdeklī. Tomēr Lilū nav parasta meitene - viņa ir galvenais (piektais) elements, bez kura Ļaunumu apturēt nav iespējams."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Nhân Tố Thứ 5","runtime":0,"tagline":"","homepage":"","overview":"Ba trăm năm một lần, Quỷ dữ lại quay lại tìm cách thôn tính loài người ẩn chứa dưới vỏ bọc bí mật là một sức mạnh huỷ diệt không thể chế ngự được, kết hợp từ các nhân tố Kim, Mộc, Thủy, Hỏa trong tự nhiên và “Nhân Tố Thứ 5”. Korben Dallas, một tài xế taxi đã tình cờ đón được một nữ hành khách rất đặc biệt, LeeLoo. Cô không biết nói tiếng Anh nhưng lại có một bộ não thông minh cực kì đáng nể. Korben không thể cưỡng lại được sự quyến rũ đầy hoang dã của LeeLoo. Anh càng không thể ngờ mình đang bị kéo vào một cuộc phiêu lưu đầy sóng gió…"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"لا يوجد مستقبل بدونها.","homepage":"","overview":"في عام 2257 ، تم تكليف سائق سيارة أجرة عن غير قصد بمهمة إنقاذ فتاة صغيرة هي جزء من المفتاح الذي يضمن بقاء البشرية."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"მეხუთე ელემენტი","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"第五元素","runtime":0,"tagline":"","homepage":"","overview":"「你們人類造的每一樣東西都用在毀滅上。」 一頭紅髮的謎樣女孩莉露（蜜拉喬娃維 飾演），在實驗室中被複製出來，而此刻地球正面臨每五千年一次的浩劫，眾人相信她與消滅宇宙邪惡勢力的五種元素有所關聯，不知自己身在何處的莉露驚恐逃出實驗室，意外跌落在計程車司機柯本（布魯斯威利 飾）的車裏，兩人躲避追逐後，決定聯手尋找元素之謎並對抗與邪惡勢力勾結的野心實業家佐格。\r 《第五元素》據説本片的原始構想來自導演盧貝松 16 歲時所寫的少年小説。本片有號稱影史上特效花費最多的特效製作，而且有相當多歐洲電影及特效工作者參與，創造出與好萊塢風格不大相同的未來世界，是一部影迷必看的佳片！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Peti element","runtime":122,"tagline":"","homepage":"","overview":"Zgodba o ljubezni in preživetju v 23. stoletju, kakršnega si je zamisli režiser Luc Besson in v katerem človeštvo potuje med zvezde ter širi življenjsko energijo. A vsakih 5000 let, ko se za hip odpro vrata v paralelne razsežnosti, mračna sila napade vesolje. To skuša izkoristiti zlobni Zorg, in edini up človeštva je Leeloo, ki predstavlja peti element, življenjsko silo, pri tem pa ji, sprva po naključju in nehote, pomaga newyorški taksist Korben Dallas."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"عنصر پنجم","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Петтиот елемент","runtime":0,"tagline":"Нема иднина без него.","homepage":"","overview":"Брус Вилис го игра Корбен Далас, њујоршки таксист којшто ќе стане херој во оваа приказна за љубовта и преживувањето во 23. век. Во иднината замислена од режисерот Лук Бесон, човештвото тргнало кон ѕвездите, ширејќи ја животната енергија. Но на секои 5000 години, кога накратко се отвораат вратите на паралелните димензии, мрачна сила го напаѓа универзумот. Токму сега е тоа време и злиот Зорг (Гери Олдман) сака да го искористи тоа. Надеж за спас на човештвото може да пружи само Лилу (Мила Јовович), која го претставува петтиот елемент, животната сила. Иднината на универзумот е во нејзините раце..."},"name":"","iso_639_1":"mk","iso_3166_1":"MK","english_name":"Macedonian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Pada tahun 2257, seorang sopir taksi secara tidak sengaja diberi tugas untuk menyelamatkan seorang gadis muda yang merupakan bagian dari kunci yang akan menjamin kelangsungan hidup umat manusia."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"}],"reviews_tmdb":[{"id":"51429e9c19c295563404fc6e","url":"https://www.themoviedb.org/review/51429e9c19c295563404fc6e","author":"GeekMasher","content":"This movie is one of the best movies of all time! It has a great story lines and graphics of it's time and even to today's standards it is brilliant. The world is well though out and well demonstrated. Zorg is a great bad guy, played by Gary Oldman and Bruce Willis plays his role very well. All in all a excellent movie.","created_at":"2013-03-15T04:07:56.245Z","updated_at":"2021-06-23T15:57:20.936Z","author_details":{"name":"","rating":9.5,"username":"GeekMasher","avatar_path":null}},{"id":"51ec27cb19c29551e21149d2","url":"https://www.themoviedb.org/review/51ec27cb19c29551e21149d2","author":"Matt Golden","content":"$11","created_at":"2013-07-21T18:26:19.779Z","updated_at":"2021-06-23T15:57:21.944Z","author_details":{"name":"Matt Golden","rating":null,"username":"FarSky","avatar_path":null}},{"id":"5916a40ac3a3683a9302a7b5","url":"https://www.themoviedb.org/review/5916a40ac3a3683a9302a7b5","author":"Gimly","content":"Ever since I first watched The Fifth Element in the late 90s, I've been inspired by Gary Oldman's Jean-Baptiste Emanuel Zorg.\r\n\r\n_Final rating:★★★½ - I strongly recommend you make the time._","created_at":"2017-05-13T06:13:30.344Z","updated_at":"2021-06-23T15:57:57.317Z","author_details":{"name":"Gimly","rating":7,"username":"Ruuz","avatar_path":"/xUObnJSvHrFPsIpoDmb1jiQZLq7.jpg"}},{"id":"5c43bae00e0a266d69d20db8","url":"https://www.themoviedb.org/review/5c43bae00e0a266d69d20db8","author":"John Chard","content":"$12","created_at":"2019-01-20T00:03:44.643Z","updated_at":"2024-05-16T15:22:19.529Z","author_details":{"name":"","rating":8,"username":"John Chard","avatar_path":"/utEXl2EDiXBK6f41wCLsvprvMg4.jpg"}},{"id":"65068fb8fa27f400caa4105a","url":"https://www.themoviedb.org/review/65068fb8fa27f400caa4105a","author":"Prodank","content":"\"The Fifth Element\" is like a journey down memory lane for me, brimming with nostalgia. I've lost count of how many times I've caught it on TV. The cast was on point, the makeup and costumes were seriously cool, and those futuristic locations were quite intriguing.\r\n\r\nIn the grand scheme of things, \"The Fifth Element\" is a certified classic. It possesses that timeless quality that's hard to find. I'd easily give it a solid 9 out of 10. But if you're a fan of this movie, you should definitely check out the animated film \"Heavy Metal\" (1981), which served as inspiration for many animation and science fiction films, including this one.","created_at":"2023-09-17T05:33:44.235Z","updated_at":"2023-09-18T15:40:40.340Z","author_details":{"name":"","rating":9,"username":"Prodank","avatar_path":"/4YQkb2jDLTP2K6tcyq5NcFvQEY.jpg"}},{"id":"665eb3c58afe3dc52f5179d6","url":"https://www.themoviedb.org/review/665eb3c58afe3dc52f5179d6","author":"CinemaSerf","content":"$13","created_at":"2024-06-04T06:27:17.906Z","updated_at":"2024-06-04T06:27:18.142Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":20,"adult":false,"title":"My Life Without Me","video":false,"overview":"A fatally ill mother with only two months to live creates a list of things she wants to do before she dies without telling her family of her illness.","genre_ids":[18,10749],"media_type":"movie","popularity":1.0925,"vote_count":494,"poster_path":"/pFEtVPW88pWflYV84UFL0h1iJr3.jpg","release_date":"2003-03-07","vote_average":6.086,"backdrop_path":"/kZyurQjTMLHalUxs7sHgH5XeiwO.jpg","original_title":"My Life Without Me","original_language":"en"},{"id":98,"adult":false,"title":"Gladiator","video":false,"overview":"After the death of Emperor Marcus Aurelius, his devious son takes power and demotes Maximus, one of Rome's most capable generals who Marcus preferred. Eventually, Maximus is forced to become a gladiator and battle to the death against other men for the amusement of paying audiences.","genre_ids":[28,18,12],"media_type":"movie","popularity":15.3337,"vote_count":20538,"poster_path":"/ty8TGRuvJLPUmAR1H1nRIsgwvim.jpg","release_date":"2000-05-04","vote_average":8.2,"backdrop_path":"/jhk6D8pim3yaByu1801kMoxXFaX.jpg","original_title":"Gladiator","original_language":"en"},{"id":602,"adult":false,"title":"Independence Day","video":false,"overview":"Strange phenomena surface around the globe. The skies ignite. Terror races through the world's major cities. As these extraordinary events unfold, it becomes increasingly clear that a force of incredible magnitude has arrived. Its mission: total annihilation over the Fourth of July weekend. The last hope to stop the destruction is an unlikely group of people united by fate and unimaginable circumstances.","genre_ids":[28,12,878],"media_type":"movie","popularity":8.4509,"vote_count":10219,"poster_path":"/p0BPQGSPoSa8Ml0DAf2mB2kCU0R.jpg","release_date":"1996-06-25","vote_average":6.899,"backdrop_path":"/kFI1oF6KVnLEbUT7yLIbKXeyvu.jpg","original_title":"Independence Day","original_language":"en"},{"id":9322,"adult":false,"title":"Nikita","video":false,"overview":"A beautiful felon, sentenced to life in prison for the murder of a policeman, is given a second chance – as a secret political assassin controlled by the government.","genre_ids":[28,53],"media_type":"movie","popularity":3.0474,"vote_count":2103,"poster_path":"/1ulQDewUG4KKHOhpXdGKm3GdLFq.jpg","release_date":"1990-02-21","vote_average":7.097,"backdrop_path":"/rk56vslwBXUCcNlQ74s6gmpJqxa.jpg","original_title":"Nikita","original_language":"fr"},{"id":24,"adult":false,"title":"Kill Bill: Vol. 1","video":false,"overview":"An assassin is shot by her ruthless employer, Bill, and other members of their assassination circle – but she lives to plot her vengeance.","genre_ids":[28,80],"media_type":"movie","popularity":16.6569,"vote_count":18600,"poster_path":"/v7TaX8kXMXs5yFFGR41guUDNcnB.jpg","release_date":"2003-10-10","vote_average":7.971,"backdrop_path":"/iffzIhuLAO38Po6sh1s6ZEVwlNL.jpg","original_title":"Kill Bill: Vol. 1","original_language":"en"},{"id":1992,"adult":false,"title":"Planet Terror","video":false,"overview":"Two doctors find their graveyard shift inundated with townspeople ravaged by sores. Among the wounded is Cherry Darling, a dancer whose leg was ripped from her body. As the invalids quickly become enraged aggressors, Cherry and her ex-boyfriend El Wray lead a team of accidental warriors into the night.","genre_ids":[27,28,53],"media_type":"movie","popularity":3.6755,"vote_count":3748,"poster_path":"/3705GxG0RN9XDV5y9IiXKYHw1fK.jpg","release_date":"2007-04-06","vote_average":6.684,"backdrop_path":"/iZBUOcku0xv9MMfiEMXiDqErPXl.jpg","original_title":"Planet Terror","original_language":"en"},{"id":1576,"adult":false,"title":"Resident Evil","video":false,"overview":"When a virus leaks from a top-secret facility, turning all resident researchers into ravenous zombies and their lab animals into mutated hounds from hell, the government sends in an elite military task force to contain the outbreak.","genre_ids":[27,28,878],"media_type":"movie","popularity":4.3107,"vote_count":6780,"poster_path":"/1UKNef590A0ZaMnxsscIcWuK1Em.jpg","release_date":"2002-03-15","vote_average":6.649,"backdrop_path":"/xcENFGw9AlsmtiQGWuzIGbg1bdi.jpg","original_title":"Resident Evil","original_language":"en"},{"id":607,"adult":false,"title":"Men in Black","video":false,"overview":"After a police chase with an otherworldly being, a New York City cop is recruited as an agent in a top-secret organization established to monitor and police alien activity on Earth: the Men in Black. Agent K and new recruit Agent J find themselves in the middle of a deadly plot by an intergalactic terrorist who has arrived on Earth to assassinate two ambassadors from opposing galaxies.","genre_ids":[28,12,35,878],"media_type":"movie","popularity":9.3173,"vote_count":14594,"poster_path":"/uLOmOF5IzWoyrgIF5MfUnh5pa1X.jpg","release_date":"1997-07-02","vote_average":7.216,"backdrop_path":"/o9puyKpayQoX8ikIaYtf2PfKv3.jpg","original_title":"Men in Black","original_language":"en"},{"id":63,"adult":false,"title":"Twelve Monkeys","video":false,"overview":"In the year 2035, convict James Cole reluctantly volunteers to be sent back in time to discover the origin of a deadly virus that wiped out nearly all of the earth's population and forced the survivors into underground communities. But when Cole is mistakenly sent to 1990 instead of 1996, he's arrested and locked up in a mental hospital. There he meets psychiatrist Dr. Kathryn Railly and the son of a famous virus expert who may hold the key to the Army of the 12 Monkeys; thought to be responsible for unleashing the killer disease.","genre_ids":[878,53,9648],"media_type":"movie","popularity":8.5281,"vote_count":8939,"poster_path":"/gt3iyguaCIw8DpQZI1LIN5TohM2.jpg","release_date":"1995-12-29","vote_average":7.601,"backdrop_path":"/mKIkGoyuR71qz6FdiEiOjxvBQcS.jpg","original_title":"Twelve Monkeys","original_language":"en"},{"id":64635,"adult":false,"title":"Total Recall","video":false,"overview":"Factory worker Doug Quaid takes a virtual mind-trip vacation with the Rekall company, opting for implanted memories of being a spy. When the procedure goes wrong, Quaid becomes a wanted man by the police and joins forces with a rebel fighter to stop the evil Chancellor Cohaagen.","genre_ids":[28,878,53],"media_type":"movie","popularity":5.0261,"vote_count":5778,"poster_path":"/hVUxVVzZ0WvvPIpKwsMPMDOQyqi.jpg","release_date":"2012-08-02","vote_average":6.025,"backdrop_path":"/uBHeAB2Ug9ELBzkMyls8CUjzn4i.jpg","original_title":"Total Recall","original_language":"en"},{"id":1995,"adult":false,"title":"Lara Croft: Tomb Raider","video":false,"overview":"Orphaned heiress, English aristocrat and intrepid archaeologist, Lara Croft, embarks on a dangerous quest to retrieve the two halves of an ancient artifact which controls time before it falls into the wrong hands. As an extremely rare planetary alignment is about to occur for the first time in 5,000 years, the fearless tomb raider will have to team up with rival adventurers and sworn enemies to collect the pieces, while time is running out. But, in the end, who can harness the archaic talisman's unlimited power?","genre_ids":[12,28,14],"media_type":"movie","popularity":4.6758,"vote_count":6414,"poster_path":"/ye5h6fhfz8TkKV4QeuTucvFzxB9.jpg","release_date":"2001-06-15","vote_average":5.911,"backdrop_path":"/bL41GVWvp4YJDJ50PDcxaN4cds9.jpg","original_title":"Lara Croft: Tomb Raider","original_language":"en"},{"id":277,"adult":false,"title":"Underworld","video":false,"overview":"Vampires and werewolves have waged a nocturnal war against each other for centuries. But all bets are off when a female vampire warrior named Selene, who's famous for her strength and werewolf-hunting prowess, becomes smitten with a peace-loving male werewolf, Michael, who wants to end the war.","genre_ids":[14,28,53],"media_type":"movie","popularity":5.3263,"vote_count":6492,"poster_path":"/zsnQ41UZ3jo1wEeemF0eA9cAIU0.jpg","release_date":"2003-09-19","vote_average":6.846,"backdrop_path":"/zsgdVbuEwqZbnUN9qLGEMBYf2Zo.jpg","original_title":"Underworld","original_language":"en"},{"id":563,"adult":false,"title":"Starship Troopers","video":false,"overview":"Set in the future, the story follows a young soldier named Johnny Rico and his exploits in the Mobile Infantry. Rico's military career progresses from recruit to non-commissioned officer and finally to officer against the backdrop of an interstellar war between mankind and an arachnoid species known as \"the Bugs.\"","genre_ids":[12,28,53,878],"media_type":"movie","popularity":6.1365,"vote_count":5348,"poster_path":"/cxCmv23O7p3hyHwqoktHYkZcGsY.jpg","release_date":"1997-11-07","vote_average":7.1,"backdrop_path":"/zHkaKyt6eTqFpjUXWav0qdEbbye.jpg","original_title":"Starship Troopers","original_language":"en"},{"id":70,"adult":false,"title":"Million Dollar Baby","video":false,"overview":"Despondent over a painful estrangement from his daughter, trainer Frankie Dunn isn't prepared for boxer Maggie Fitzgerald to enter his life. But Maggie's determined to go pro and to convince Dunn and his cohort to help her.","genre_ids":[18],"media_type":"movie","popularity":5.5225,"vote_count":10183,"poster_path":"/jcfEqKdWF1zeyvECPqp3mkWLct2.jpg","release_date":"2004-12-05","vote_average":7.954,"backdrop_path":"/oGMomeS7bE43eN8SGJUaKvQnmud.jpg","original_title":"Million Dollar Baby","original_language":"en"},{"id":6479,"adult":false,"title":"I Am Legend","video":false,"overview":"Robert Neville is a scientist who was unable to stop the spread of the terrible virus that was incurable and man-made. Immune, Neville is now the last human survivor in what is left of New York City and perhaps the world. For three years, Neville has faithfully sent out daily radio messages, desperate to find any other survivors who might be out there. But he is not alone.","genre_ids":[18,878,53],"media_type":"movie","popularity":8.5067,"vote_count":16580,"poster_path":"/iPDkaSdKk2jRLTM65UOEoKtsIZ8.jpg","release_date":"2007-12-12","vote_average":7.21,"backdrop_path":"/aTLq0TMKdsmIy1ZyFM1LfPs326d.jpg","original_title":"I Am Legend","original_language":"en"},{"id":101,"adult":false,"title":"Léon: The Professional","video":false,"overview":"Léon, the top hit man in New York, has earned a rep as an effective \"cleaner\". But when his next-door neighbors are wiped out by a loose-cannon DEA agent, he becomes the unwilling custodian of 12-year-old Mathilda. Before long, Mathilda's thoughts turn to revenge, and she considers following in Léon's footsteps.","genre_ids":[80,18,28],"media_type":"movie","popularity":14.251,"vote_count":15809,"poster_path":"/bxB2q91nKYp8JNzqE7t7TWBVupB.jpg","release_date":"1994-09-14","vote_average":8.295,"backdrop_path":"/jRJrQ72VLyEnVsvwfep8Xjlvu8c.jpg","original_title":"Léon","original_language":"fr"},{"id":10528,"adult":false,"title":"Sherlock Holmes","video":false,"overview":"Eccentric consulting detective Sherlock Holmes and Doctor John Watson battle to bring down a new nemesis and unravel a deadly plot that could destroy England.","genre_ids":[28,12,80,9648],"media_type":"movie","popularity":5.9438,"vote_count":14593,"poster_path":"/momkKuWburNTqKBF6ez7rvhYVhE.jpg","release_date":"2009-12-23","vote_average":7.216,"backdrop_path":"/85g84VtSf9tu1A9JqqruXEHspb7.jpg","original_title":"Sherlock Holmes","original_language":"en"},{"id":11452,"adult":false,"title":"National Lampoon's Van Wilder","video":false,"overview":"Van Wilder has been attending college for far too many years and is scared to graduate, but Van’s father eventually realizes what is going on. When he stops paying his son's tuition fees, Van must come up with the money if he wants to stay in college, so he and his friends come up with a great fund-raising idea – throwing parties. However, when the college magazine finds out and reporter Gwen is sent to do a story on Van Wilder, things get a little complicated.","genre_ids":[35,10749],"media_type":"movie","popularity":2.4359,"vote_count":1916,"poster_path":"/4IvM4qnzlo62oLmS54FtyRt54ze.jpg","release_date":"2002-03-29","vote_average":6,"backdrop_path":"/7CAEkkp07JBPHGIxmagu181f4CP.jpg","original_title":"National Lampoon's Van Wilder","original_language":"en"},{"id":603,"adult":false,"title":"The Matrix","video":false,"overview":"Set in the 22nd century, The Matrix tells the story of a computer hacker who joins a group of underground insurgents fighting the vast and powerful computers who now rule the earth.","genre_ids":[28,878],"media_type":"movie","popularity":24.788,"vote_count":27416,"poster_path":"/p96dm7sCMn4VYAStA6siNz30G1r.jpg","release_date":"1999-03-31","vote_average":8.238,"backdrop_path":"/tlm8UkiQsitc8rSuIAscQDCnP8d.jpg","original_title":"The Matrix","original_language":"en"},{"id":562,"adult":false,"title":"Die Hard","video":false,"overview":"NYPD cop John McClane's plan to reconcile with his estranged wife is thrown for a serious loop when, minutes after he arrives at her office's Christmas Party, the entire building is overtaken by a group of terrorists. With little help from the LAPD, wisecracking McClane sets out to single-handedly rescue the hostages and bring the bad guys down.","genre_ids":[28,53],"media_type":"movie","popularity":11.5424,"vote_count":12054,"poster_path":"/7Bjd8kfmDSOzpmhySpEhkUyK2oH.jpg","release_date":"1988-07-15","vote_average":7.806,"backdrop_path":"/bvk2AAH64lP2YZs02Q3jskfHT8j.jpg","original_title":"Die Hard","original_language":"en"}],"similar_content":[{"id":653346,"adult":false,"title":"Kingdom of the Planet of the Apes","video":false,"overview":"Several generations following Caesar's reign, apes – now the dominant species – live harmoniously while humans have been reduced to living in the shadows. As a new tyrannical ape leader builds his empire, one young ape undertakes a harrowing journey that will cause him to question all he's known about the past and to make choices that will define a future for apes and humans alike.","genre_ids":[878,12,28],"popularity":9.4287,"vote_count":4102,"poster_path":"/gKkl37BQuKTanygYQG1pyYgLVgf.jpg","release_date":"2024-05-08","vote_average":7.054,"backdrop_path":"/iHYh4cdO8ylA3W0dUxTDVdyJ5G9.jpg","original_title":"Kingdom of the Planet of the Apes","original_language":"en"},{"id":270826,"adult":false,"title":"Wicked Priest 2: Ballad of Murder","video":false,"overview":"The long awaited second film in the Wicked Priest series is a masterpiece of sword swinging fury as Shinkai is asked by a man on the run to bring his young son to live with his grandfather, the master of a ju-jitsu dojo during the Taisho period of the early 20th century. Shinkai then runs afoul of a gangster group using strong-arm tactics to take over the profits from local gambling. When he proves to be more than they can handle, they hire the one man who has the ability to kill Shinkai and exact revenge, Ryotatsu, the karate priest whom Shinkai blinded in the first film. This ultra-violent entry has long been considered the best movie in the series and never made its way to home video before. See a spectacular display of Wakayama Tomisaburo’s martial art expertise in this action packed film. The Holy Grail of sword movies has arrived at last! /Winterheart of CG","genre_ids":[28,18],"popularity":0.1958,"vote_count":2,"poster_path":"/6n20k3iChfzldchx2OGUiSZ7uZw.jpg","release_date":"1968-11-30","vote_average":6.5,"backdrop_path":"/hhgQC2FmxSXC3Hga2I7xwCx0sfi.jpg","original_title":"極悪坊主 人斬り数え唄","original_language":"ja"},{"id":124167,"adult":false,"title":"Alphabet City","video":false,"overview":"A New York City drug dealer decides to get out of the business, but has to flee from mobsters.","genre_ids":[80,18,28],"popularity":1.2963,"vote_count":32,"poster_path":"/6usQSU0ftXQMTa3yRCENxFqIn4k.jpg","release_date":"1984-03-04","vote_average":4.484,"backdrop_path":"/9x51wNZAYTKMJjWHYKPmsgDm1Nz.jpg","original_title":"Alphabet City","original_language":"en"},{"id":124556,"adult":false,"title":"Project Nightmare","video":false,"overview":"Beneath the desert lies a terrifying secret! While camping out, two close friends, Gus and John are attacked by an awesome, but unidentifiable force. Fleeing this unknown terror, they come upon Marcy, a vision of beauty, alone in the desert. She’s too good to be true – and probably isn’t!","genre_ids":[27,878,53],"popularity":0.4152,"vote_count":7,"poster_path":"/h35yRTp30LyDtRNPeLwpFMFDznB.jpg","release_date":"1987-08-01","vote_average":1.9,"backdrop_path":null,"original_title":"Project Nightmare","original_language":"en"},{"id":124366,"adult":false,"title":"Harald Handfaste","video":false,"overview":"Harald Handfaste is a 15th century Swedish Robin Hood, who fights against foreign oppression. He becomes the leader of a band of highwaymen and they start dealing with the evil bailiff. However, the bailiff will stop at nothing to catch Handfaste and show the people who is in charge. He even attempts to marry Handfaste's beloved Karin, and when she refuses to subdue, the bailiff decides to execute both her, her father and a monk who has been helping them.","genre_ids":[28,10749,12],"popularity":0.1646,"vote_count":1,"poster_path":"/9txHeVRbKNMdAOmIkmtKfObuHf5.jpg","release_date":"1946-12-26","vote_average":5,"backdrop_path":"/wLGp5eMeUNiZMW8DaruBTFlQFtU.jpg","original_title":"Harald Handfaste","original_language":"sv"},{"id":1172265,"adult":false,"title":"The Blue Trail","video":false,"overview":"In the name of economic recovery, the Brazilian Government created a perennial system of compulsory vertical isolation for seniors over 80 to be confined in a colony. Teca is 77 and lives in the village of Muriti, in the Amazon, when she is surprised by the announcement of the age reduction, including her age group. Cornered, Teca makes an intriguing journey hidden from the officers amidst rivers, boats and the underworld to clandestinely try to fulfill her last dream, to take a plane ride.","genre_ids":[18,878,35],"popularity":3.659,"vote_count":78,"poster_path":"/ua8XnJ450rhBTxkY2wpD2ITw7BJ.jpg","release_date":"2025-08-28","vote_average":7,"backdrop_path":"/2UXrkv2G1aXMyn3VY70krD9Anid.jpg","original_title":"O Último Azul","original_language":"pt"},{"id":1172344,"adult":false,"title":"The Perfect Date","video":false,"overview":"2041: A babysitter called Elena decides to accompany a lonely man named Javier inside a 'fonda' (small restaurant/diner) in Mexico City. After her companion discovers her true nature, Elena fights to survive against this future's dark portrait personified, testing the limits of her own existence and her humanity.","genre_ids":[878,53],"popularity":0.1164,"vote_count":0,"poster_path":"/8aq67W2151EUXEIA3gkZQX6Otqj.jpg","release_date":"2023-09-12","vote_average":0,"backdrop_path":null,"original_title":"La Cita Perfecta","original_language":"es"},{"id":366182,"adult":false,"title":"Space Clown","video":false,"overview":"A hapless filmmaker documents the weird, violent, and surreal torments of an extraterrestrial clown.","genre_ids":[35,27,878],"popularity":0.1583,"vote_count":1,"poster_path":"/yoafSSTBenQs3LlVDNlQK2rVF8w.jpg","release_date":"2016-11-11","vote_average":2,"backdrop_path":"/c15hXN2Tncq93k5WiXPceGhPdBL.jpg","original_title":"Space Clown","original_language":"en"},{"id":111901,"adult":false,"title":"The Collapsed","video":false,"overview":"In the wake of the end of the world, a family of four desperately tries to survive. Their goal: escaping the city and traveling to the rural community they once called home.  The constant threat of a violent death forcing them to stay as far away from civilization as possible, they take to the forest, soon to discover the danger posed by other survivors may be the least of their worries.","genre_ids":[18,27,878],"popularity":0.21,"vote_count":31,"poster_path":"/m8burOTP8Oi3AGmDlXUGMDzVisY.jpg","release_date":"2011-07-02","vote_average":4,"backdrop_path":"/4HocFQH4Dr1Y6xCID24OKITYEpR.jpg","original_title":"The Collapsed","original_language":"en"},{"id":111983,"adult":false,"title":"Live Wire: Human Timebomb","video":false,"overview":"A computer chip turns an FBI agent into a lethal weapon.","genre_ids":[28,18,53],"popularity":0.349,"vote_count":7,"poster_path":"/uCtJUy9C6RqKUxzDzNImi2OWgWY.jpg","release_date":"1996-02-27","vote_average":4.7,"backdrop_path":null,"original_title":"Human Timebomb","original_language":"en"},{"id":112141,"adult":false,"title":"Menno's Mind","video":false,"overview":"Menno is a computer programmer at The Resort, an enormous funhouse where people can live out their fantasies in virtual reality. Feeding their personal data into a software program called The System, head of security Felix Medina is setting up a big voting fraud, in order to win the presidential elections. His only concern is a group of terrorists, rebelling against his plans. As an ex-colleague of their leader, Menno is forced to help them.","genre_ids":[53,878],"popularity":0.2371,"vote_count":8,"poster_path":"/37cHyRq1pmVpvq8OnHKaXoBvXdG.jpg","release_date":"1997-12-13","vote_average":4.8,"backdrop_path":"/aPOn7IGjybT9uyFSFU0HOFxEZGi.jpg","original_title":"Menno's Mind","original_language":"en"},{"id":369426,"adult":false,"title":"The Desperate Mission","video":false,"overview":"A man who has lost everything joins others paid to convey a wealthy man's wife - and a mysterious treasure - to safety in San Francisco.","genre_ids":[37,28,12,18,10770],"popularity":0.4298,"vote_count":6,"poster_path":"/gd2ZzJlhzG29DlxSbY5a8mOPlPj.jpg","release_date":"1969-11-20","vote_average":4,"backdrop_path":"/ub7ucREwvyeO01R6WPRQzXiUfKZ.jpg","original_title":"The Desperate Mission","original_language":"en"},{"id":1562642,"adult":false,"title":"Archangel","video":false,"overview":"A weapons researcher protects his community from an aggressive corporation.","genre_ids":[28],"popularity":0.5366,"vote_count":0,"poster_path":"/dVZpRAAmVCi7lMAhTdBAtty7Ewf.jpg","release_date":"2026-11-04","vote_average":0,"backdrop_path":null,"original_title":"Archangel","original_language":"en"},{"id":137113,"adult":false,"title":"Edge of Tomorrow","video":false,"overview":"Major Bill Cage is an officer who has never seen a day of combat when he is unceremoniously demoted and dropped into combat. Cage is killed within minutes, managing to take an alpha alien down with him. He awakens back at the beginning of the same day and is forced to fight and die again... and again - as physical contact with the alien has thrown him into a time loop.","genre_ids":[28,878],"popularity":9.6459,"vote_count":14802,"poster_path":"/nBM9MMa2WCwvMG4IJ3eiGUdbPe6.jpg","release_date":"2014-05-27","vote_average":7.634,"backdrop_path":"/4V1yIoAKPMRQwGBaSses8Bp2nsi.jpg","original_title":"Edge of Tomorrow","original_language":"en"},{"id":137230,"adult":false,"title":"The End of the World","video":false,"overview":"Foreman West lives in a small mining town with his daughters Edith and Dina. When entrepreneur and mine owner Frank Stoll comes to town to inspect the work, he falls in love with Dina. Against her father's will, she elopes with the unscrupulous Stoll. News of a meteor approaching the earth causes panic and Stoll exploits the situation to make a killing on the stock market; Collaborating with the press to quell the news of the meteor eases public tensions and guarantees him a fortune. He plans to survive in a secret underground tunnel, with Dina and his wealthy pals in tow. But things don't go as planned.","genre_ids":[878,28,18],"popularity":0.1472,"vote_count":22,"poster_path":"/lEnCnwEkciKLnG8C1iArdhNdjSD.jpg","release_date":"1916-04-01","vote_average":6.1,"backdrop_path":"/7XZLHTbOmBzgBkPerICrsC5AsrH.jpg","original_title":"Verdens undergang","original_language":"da"},{"id":137094,"adult":false,"title":"Jack Ryan: Shadow Recruit","video":false,"overview":"Jack Ryan, as a young covert CIA analyst, uncovers a Russian plot to crash the U.S. economy with a terrorist attack.","genre_ids":[28,18,53],"popularity":3.5055,"vote_count":3024,"poster_path":"/m7HcLUodrD4lM4s0Hui1tzO2pjO.jpg","release_date":"2014-01-15","vote_average":6.123,"backdrop_path":"/6KaCzcVKsdxlsTIq35xAix5U3Nb.jpg","original_title":"Jack Ryan: Shadow Recruit","original_language":"en"},{"id":370097,"adult":false,"title":"Stormageddon","video":false,"overview":"What happens when you ask the most powerful computer program, run by the most powerful computers, to follow, listen and predict human behavior? The program learns, becomes sentient and begins to behave like a human. When a master computer program, Echelon, takes over America's entire online system, our country is threatened to be brought to its knees. Hacking into DARPA, Echelon gains the ability to manipulate the weather, create earthquakes, and cause a level of destruction unlike anything the country could ever imagine. But how do you stop a computer program when it has control over any and every defense you have?","genre_ids":[28,18,53,878],"popularity":3.6278,"vote_count":96,"poster_path":"/loZHFn4RoTeh4t1I4hS01DRYF7q.jpg","release_date":"2015-11-18","vote_average":6.1,"backdrop_path":"/wAvmYcjENgIBE3Bp8u0AO9gNmDQ.jpg","original_title":"Stormageddon","original_language":"en"},{"id":138103,"adult":false,"title":"The Expendables 3","video":false,"overview":"Barney, Christmas and the rest of the team comes face-to-face with Conrad Stonebanks, who years ago co-founded The Expendables with Barney. Stonebanks subsequently became a ruthless arms trader and someone who Barney was forced to kill… or so he thought. Stonebanks, who eluded death once before, now is making it his mission to end The Expendables -- but Barney has other plans. Barney decides that he has to fight old blood with new blood, and brings in a new era of Expendables team members, recruiting individuals who are younger, faster and more tech-savvy. The latest mission becomes a clash of classic old-school style versus high-tech expertise in the Expendables’ most personal battle yet.","genre_ids":[28,12,53],"popularity":5.9482,"vote_count":5248,"poster_path":"/utS5euWHlEdKBNnEFwjpZ2oGuhF.jpg","release_date":"2014-08-07","vote_average":6.205,"backdrop_path":"/d3B8BQDmEEK2Qy6tjYRP3hkpv6J.jpg","original_title":"The Expendables 3","original_language":"en"},{"id":138036,"adult":false,"title":"Bounty Dog","video":true,"overview":"In the future, mankind has colonized the bleak expanses of the moon. Cities now stand proudly where there was once only desolation and emptiness. But there are alien forces that do not want mankind to succeed and only one man can stop them. He is a member of the Bounty Dog Investigation Unit, a high-tech cybernetic mercenary team.","genre_ids":[28,16,878],"popularity":0.4941,"vote_count":6,"poster_path":"/4WqC0AXmgGeBNedpzgOwbvpfv06.jpg","release_date":"1994-10-01","vote_average":6.3,"backdrop_path":"/A0E83FwpvrcT7pz2wLEBAqkfvU9.jpg","original_title":"バウンティ・ドッグ","original_language":"ja"},{"id":370487,"adult":false,"title":"The Aerodrome","video":false,"overview":"In the future England is ruled by a fascist government, and one day the leaders begin the construction of a heavily guarded, mysterious airport. BBC adaptation of  Rex Warner's 1941 novel of the same name. A stereotypical village in a somewhat alternative England is taken over wholesale by 'The Air Force.' Living in the village is young Roy, who has just learned he is not who he thought he was. Attempting to forge a new sense of identity, he joins the dashing Air Force, seduced by its dynamism and direct and brutal ways.","genre_ids":[18,878,10770],"popularity":0.1424,"vote_count":1,"poster_path":"/jDm8fWvgkqU4HZHyY0LXqdQylsR.jpg","release_date":"1983-12-13","vote_average":7,"backdrop_path":null,"original_title":"The Aerodrome","original_language":"en"}],"external_ids":{"imdb_id":"tt0119116","twitter_id":null,"facebook_id":null,"wikidata_id":"Q106506","instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148138,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3