5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Lost in Beijing\",\"description\":\"A look at modern-day life in China's capital centered on a ménage-a-quatre involving a young woman, her boss, her husband and her boss's wife.\",\"image\":\"https://image.tmdb.org/t/p/w500/2LZ7qbdnCqlOzlngcj5wdvnLfjA.jpg\",\"datePublished\":\"2007-09-26\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"drama film\",\"Romance\",\"Drama\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.541,\"bestRating\":10,\"ratingCount\":61}}"}}],["$","$L10",null,{"initialDrama":{"id":"83a02eb0-2631-4b80-9b8a-0d022de10925","tmdb_id":30112,"imdb_id":"tt0949489","content_type":"movie","title":"Lost in Beijing","original_title":"苹果","overview":"A look at modern-day life in China's capital centered on a ménage-a-quatre involving a young woman, her boss, her husband and her boss's wife.","poster_path":"/2LZ7qbdnCqlOzlngcj5wdvnLfjA.jpg","backdrop_path":"/7F1djgcBJkMWFOeQ0ZK4b5Q3LPb.jpg","release_date":"2007-09-26","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"name":"drama film"},{"id":10749,"name":"Romance"},{"id":18,"name":"Drama"},"drama film"],"popularity":15.4463,"vote_average":6.541,"vote_count":61,"runtime":112,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-04T22:19:45.91808+00:00","updated_at":"2026-02-23T17:34:31.389+00:00","tagline":null,"homepage":null,"budget":0,"revenue":5095696,"production_companies":[{"id":5447,"name":"Laurel Films","logo_path":null,"origin_country":""},{"id":20800,"name":"The French Connection","logo_path":null,"origin_country":"FR"}],"production_countries":[{"name":"China","iso_3166_1":"CN"},{"name":"France","iso_3166_1":"FR"}],"spoken_languages":[{"name":"普通话","iso_639_1":"zh","english_name":"Mandarin"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[{"id":570,"name":"rape"},{"id":11259,"name":"extortion"},{"id":33625,"name":"illegal prostitution"},{"id":34094,"name":"extramarital affair"},{"id":187056,"name":"woman director"}],"alternative_titles":[{"type":"Romanized pronunciation","title":"Ping Guo","iso_3166_1":"CN"},{"type":"","title":"Lost in Beijing","iso_3166_1":"US"},{"type":"","title":"蘋果","iso_3166_1":"HK"},{"type":"","title":"蘋果 (2007)","iso_3166_1":"HK"}],"videos":[{"id":"6230c054befd9100447a4442","key":"ue_-qEvvglg","name":"《苹果》LOST IN BEIJING Trailer","site":"YouTube","size":1080,"type":"Trailer","official":false,"iso_639_1":"en","iso_3166_1":"US","published_at":"2012-07-31T20:29:16.000Z"}],"watch_providers":{"results":{"FR":{"link":"https://www.themoviedb.org/movie/30112/watch?locale=FR","flatrate":[{"logo_path":"/jWUqMTaqhDcdK3HCI7HV4EWDr8r.jpg","provider_id":2614,"provider_name":"Outbuster Amazon Channel","display_priority":106}]},"KR":{"link":"https://www.themoviedb.org/movie/30112/watch?locale=KR","rent":[{"logo_path":"/hPcjSaWfMwEqXaCMu7Fkb529Dkc.jpg","provider_id":356,"provider_name":"wavve","display_priority":3}]}}},"wikidata_id":"Q5226961","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/bqfeXqCSpWObWmVuZVgdezOEnS1.jpg","images":{"logos":[{"width":698,"height":188,"file_path":"/cxyXpfIHFjxpBaqc36Npmt3OT2D.png","iso_639_1":null,"vote_average":0}],"posters":[{"width":1000,"height":1500,"file_path":"/bqfeXqCSpWObWmVuZVgdezOEnS1.jpg","iso_639_1":"rw","vote_average":3.334},{"width":1000,"height":1426,"file_path":"/jKvBAHiDAAKzrQkT1T63oCTAB9I.jpg","iso_639_1":null,"vote_average":0.166},{"width":510,"height":750,"file_path":"/A23mo7Puy2ZhfnNp9jOytLeqyLR.jpg","iso_639_1":null,"vote_average":0.166},{"width":1175,"height":1763,"file_path":"/2LZ7qbdnCqlOzlngcj5wdvnLfjA.jpg","iso_639_1":"en","vote_average":0},{"width":900,"height":1282,"file_path":"/pOpX6fyscIafZd3ITbkkvaZZanN.jpg","iso_639_1":"ko","vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/7F1djgcBJkMWFOeQ0ZK4b5Q3LPb.jpg","iso_639_1":null,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/fRgkq1B7517gddt5NaY7VoXGjrv.jpg","iso_639_1":null,"vote_average":3.334},{"width":2044,"height":1150,"file_path":"/uYxCZpdj1qdXB3lSBnAJdzWvKy1.jpg","iso_639_1":null,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/stgX5CErRxIryzLhiuYAbADoQAO.jpg","iso_639_1":null,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/yAK0cSZB9xT2kaXbf6AEyFUGo2L.jpg","iso_639_1":"zh","vote_average":0.166}]},"enriched_at":"2026-04-21T06:24:58.591+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Lost in Beijing","runtime":112,"tagline":"","homepage":"","overview":"A look at modern-day life in China's capital centered on a ménage-a-quatre involving a young woman, her boss, her husband and her boss's wife."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":115,"tagline":"放纵的肉体  迷失的心灵","homepage":"","overview":"刘苹果（范冰冰 饰）在北京一家洗脚城里做按摩妹，丈夫安坤（佟大为 饰）是负责清洗高楼落地窗的工人，二人生活贫困，却相亲相爱。洗脚城老板林东（梁家辉 饰）是个好色的港商，时常找不同小姐满足生理需要。老婆王梅（金燕玲 饰）不能生育，经营一家美容院，两人感情冷淡。\r 一日刘苹果的好友小妹因为得罪客人而被开除，二人喝得酩酊大醉。神志混乱的苹果误打误撞走到一间足浴客房，正好是林东的休息室，林东趁刘苹果酒醉强行和她发生了关系，而这时却被正在刷窗的安坤看到。安坤欲借此敲诈林东，并前去找王梅谈判，愤怒的王梅要林东也尝尝“戴绿帽”的滋味，于是与安坤发生关系。而在这时，一个更大的变故产生。苹果怀孕了，而到底谁才是这个孩子的父亲成了林东与安坤赌博的筹码，四人签订协议，如果是林东的骨肉，他将给二人十二万元的补偿费，而如果是安坤的，则双方互不相欠....."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Perdidos en Pekín (Lost in Beijing)","runtime":0,"tagline":"","homepage":"","overview":"Lost in Beijing, nos traslada al submundo de los centros de masajes de Beijing, en donde una joven trabaja como masajista y debe esconder la identidad y existencia de su esposo, un limpia vidrios que un día en su trabajo se topa con la insufrible noticia que su esposa le era infiel con su jefe (Tony Leung Kai Fai) sin saber que, ella en estado de ebriedad habia sido violada por el dueño del Centro de Masajes."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"אבודים בביג'ינג","runtime":0,"tagline":"","homepage":"","overview":"ליו ואן הם זוג נשוי שמתגורר בבייג'ינג. לה יש עבודת משרד בטוחה והוא מנקה חלונות של גורדי שחקים. יום אחד מותקפת ליו מינית על ידי הבוס שלה ומגלה שהיא בהריון. בעלה, שיודע הכל, מציע לעשות שימוש בהריון כדי לסחוט את האנס. הבוס, בניגוד לכל הציפיות, מוכן לשלם הרבה כסף כדי שהזוג ישמור על העובר ויגדל את ילדו. העלילה מסתבכת כשגם אשתו של הבוס נכנסת לתמונה. סרטה של יו לי נאלץ לעמוד בפני דרישות צנזורה מחמירות מטעם השלטונות ועורר תרעומת."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Ztraceni v Pekingu","runtime":112,"tagline":"","homepage":"","overview":"Snímek nabízí pohled na současný život v čínském hlavním městě. Sledujeme vztahový čtyřúhelník mezi mladou ženou, jejím šéfem, jejím manželem a manželkou jejího šéfa."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Lost in Beijing - Alles ist möglich","runtime":109,"tagline":"","homepage":"","overview":"In der boomenden Metropole Peking suchen zahlreiche Zuwanderer aus der chinesischen Provinz ihr Glück. Eine von ihnen ist die junge Liu Ping Guo (Fan Bingbing), die sich ihren knappen Lebensunterhalt im Golden Basin verdient, einem Pekinger Fußmassagesalon für wohlhabende Geschäftsleute. Dabei kam sie nach Peking, um sich dort genug Geld zu verdienen, um später in bescheidenem Wohlstand auf das Land zurückkehren zu können.Davon ist Liu Ping Guo jedoch weit entfernt. Stattdessen muss sie sich die Übergriffe der lüsternen Kundschaft gefallen lassen und ihre Ehe verheimlichen, um nicht ihren Job zu verlieren. Nachdem sie sich mit einer Freundin betrank, die gefeuert wurde, weil sie sich gegen einen allzu aufdringlichen Kunden wehrte, wird sie von ihrem Chef Lin Dong (Tony Leung Ka Fai) vergewaltigt."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"A pekingi gyermek","runtime":0,"tagline":"","homepage":"","overview":"Lin Dong és Wang Mei egy jómódú, középkorú házaspár, akik jól menő masszázsszalont üzemeltetnek Pekingben. Boldogságukhoz már csak a gyermekáldás hiányozna, de ez csak nem akar bekövetkezni. Egy nap vágyaitól vezérelve Lin megerőszakolja egyik dolgozóját, az elfogyasztott alkoholmennyiségtől félájult Liu Pingguót. Igen ám, de az esetet Liu férje, An Kun is végignézi, és elhatározza, hogy bosszú áll Linen. Ehhez Wang Mei is felajánlja segítségét, ám a helyzet egyszer csak új fordulatot vesz, mikor kiderül, hogy Liu terhes."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"로스트 인 베이징","runtime":0,"tagline":"로스트 인 베이징","homepage":"","overview":"리얼하고 섹시한 도시 남녀들의 일상!\r 베이징에서 샵을 운영하는 성공한 사업가 린동(양가휘)과 부인 왕메이. 행복한 꿈을 안고 베이징으로 온 동거커플 핑궈(판빙빙)와 안쿤. 가난하지만 순수한 사랑을 나누며 행복하게 지내던 핑궈는 어느 날 일하던 샵에서 원치 않은 동침으로 임신까지 하게 된다. 이 사건을 계기로 네 사람의 심경이 복잡하게 요동치기 시작한다. 포기했던 자식을 얻을 희망이 생긴 린동, 남편을 증오하지만 다른 여자에게 자신의 자리를 뺏길 수 없는 왕메이, 가난을 벗어나 새 출발의 기회를 얻고 싶은 안쿤, 남편의 사랑과 아이를 모두 지키고 싶은 핑궈! 얽히고 설킨 네 남녀의 엇갈린 욕망은 예상을 뒤엎는 거래를 시작하게 하는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"蘋果","runtime":0,"tagline":"","homepage":"","overview":"2007，迷失北京。來到京城誓要力爭上遊改善生活的年輕夫婦蘋果和安坤，日子本來過得平靜。一天，蘋果被老闆林東性侵犯，為兩個家庭帶來驚天巨變。不甘愛妻被強暴，安坤決意以暴易暴，對林東勒索威脅。而林東的妻子發現丈夫與下屬有染，竟勾引安坤，以其人之道還自其人之身。兩對夫婦，逐漸發展出一段欲斷難斷、愛恨交纏的畸戀。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Un regard sur la vie moderne dans la capitale chinoise centré sur un ménage à quatre impliquant une jeune femme, son patron, son mari et la femme de son patron. La masseuse Pingguo (Apple) (L'étonnante Fan Bingbing) vit dans un appartement exigu avec son mari, laveur de vitres de mauvaise humeur, Kun (Tong Dawei), vivant à peine avec leur maigre salaire. Lorsque Pingguo se fait violer par son patron Lin (Tony Leung) un après-midi, Kun, qui lave les vitres de l'immeuble, est témoin de l'acte. Le Kun enragé essaie de se venger d'abord en faisant chanter (sans succès) Lin, puis en couchant avec la femme de Lin (Elaine Kam). Les relations s'emmêlent encore plus lorsque Pingguo découvre qu'elle est enceinte. Avec la paternité du bébé en suspens, Kun, avide d'argent, conclut un accord avec Lin, qui a hâte d'avoir un fils."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"lost in beijing","runtime":0,"tagline":"","homepage":"","overview":"Liu Ping Guo e suo marito An Kun fanno parte di quei due milioni di persone attirate a Pechino dalla possibilità di trovare un lavoro. Liu Ping lavora come massaggiatrice dei piedi e An Kun lava i vetri dei grattacieli..."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Zagubieni w Pekinie","runtime":0,"tagline":"","homepage":"","overview":"Liu Ping Guo pracuje jako masażystka stóp. Kiedy podczas przyjęcia przesadza z alkoholem i zasypia w gabinecie szefa, ten postanawia ją wykorzystać. Całe zajście widzi przez okno mąż kobiety, Kun."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"蘋果","runtime":0,"tagline":"","homepage":"","overview":"劉蘋果（范冰冰飾）在北京一家洗腳城裡做按摩妹，丈夫安坤（佟大為飾）是負責清洗高樓落地窗的工人，二人生活貧困，卻相親相愛。 洗腳城老闆林東（梁家輝飾）是個好色的港商，時常找不同小姐滿足生理需要。老婆王梅（金燕玲飾）不能生育，經營一家美容院，兩人感情冷淡。一日劉蘋果的好友小妹因為得罪客人而被開除，二人喝得酩酊大醉。神志混亂的蘋果誤打誤撞走到一間足浴客房，正好是林東的休息室，林東趁劉蘋果酒醉強行和她發生了關係，而這時卻被正在刷窗的安坤看……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"เกมรักหักหลัง","runtime":0,"tagline":"","homepage":"","overview":"เมื่อหลิวผิงกัว (ฝ่านปิงปิง) เผลอไปมีความสัมพันธ์ลึกซึ้งกับนายจ้างของเธอ จนต้งท้องขึ้นมา และอานคุนผู้เป็นสามีก็พยายามจะเรียกเงินค่าเสียหายจากนายจ้างของเธอ ทั้งสองจึงทำข้อตกลงบางอย่างแก่กัน ซึ่งข้อตกลงนี้ดูเหมือนว่าจะไม่มีใครต้องเสียอะไร ถ้าไม่เป็นเพราะอานคุนเริ่มคิดได้ว่า เงินไม่มีความหมายสำหรับเขาเท่ากับลูกและเมีย และนายจ้างของผิงกัวเองไม่เริ่มรักเด็กในท้องของผิงกัวขึ้นมา ทั้งๆ ที่ตอนแรกเขาไม่ยอมรับด้วยซ้ำว่าได้ล่วงเกินผิงกัว ไปๆ มาๆ ข้อตกลงเหล่านั้นกลับกลายเป็นหลุมขนาดใหญ่ที่พวกเขาตกลงไป และหาทางปีนกลับขึ้นมาไม่เจอ"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Потерянные в Пекине","runtime":112,"tagline":"","homepage":"","overview":"Пинго работает массажисткой в Дворце массажа ног «Золотой таз» — популярном массажном заведении, принадлежащем Линь Дуну, бизнесмену средних лет. Однажды девушка напивается и Дун пользуется ситуацией, чтобы изнасиловать её. Муж Пинго Ань Кунь, который работает мойщиком окон высотных зданий, становится этому свидетелем. Пинго забеременела. Ань Кунь шантажирует Линь Дуна: либо тот заплатит компенсацию, либо он подаст жалобу об изнасиловании."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Lạc Lối Ở Bắc Kinh","runtime":0,"tagline":"","homepage":"","overview":"Tại Bắc Kinh có đôi vợ chồng trẻ: Kiên (Đồng Đại Vy) và Táo (Phạm Băng Băng). Chồng làm nghề lau kiếng cho các căn hộ cao ốc, vợ làm massage. Táo chơi thân với một cô bé trong tiệm tên Tiểu Mai. Vì chống lại một người khách sàm sỡ, Tiểu Mai bị đuổi còn Táo đi uống rượu cùng Tiểu Mai rồi về tiệm nằm ngủ hớ hênh bị ông chủ (Lương Gia Huy) cưỡng bức. Thoạt tiên cô chống đỡ nhưng sau đó lại cam chịu. Trong khi đó, Kiên đang lau kiếng ở bên ngoài trông thấy đã xông vào gây hấn với ông chủ."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Pasimetę Pekine","runtime":112,"tagline":"","homepage":"","overview":"Modernus Pekinas, kylanti šalies ekonomika. Liu Ping Guo dirba masažuotoja populiariame naujos kartos verslininko salone. Kartą linksmai bepietaudama su draugu Liu padaugina alkoholio, o jos bosas pasinaudoja šia situacija. Mergina išprievartaujama tiesiog savo darbo vietoje, o šią šiurkščią sceną netyčia pamato jos prie darbo belaukiantis vyras An Kun. Tarsi to būtų negana, netrukus paaiškėja, kad Liu laukiasi... Sukrėstas jos vyras bando surasti išeitį ir priremia prievartautoją prie sienos: arba jis sumoka kompensaciją, arba bus paduotas į teismą.\r Turtingas verslininkas Lin Dong jaunai porai pasiūlo netikėtą išeitį: kadangi jis su žmona neturi vaikų, už pinigus pasiims kūdikį ir augins jį kaip savo. Po derybų Liu ir An Kun sutinka atsisakyti kūdikio už didelę pinigų sumą. Tiesa, su sąlyga, jog Liu šešiems mėnesiams kaip auklė apsigyvens pagyvenusios poros namuose. Nuo tos akimirkos abi šeimos savo kailiu patiria, kad jų sprendimo pasekmės gali būti neprognozuojamos."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"}],"reviews_tmdb":[],"recommendations":[{"id":45447,"adult":false,"title":"She Shoots Straight","video":false,"overview":"Hong Kong police officer Mina Kao marries Huang Tsung-Pao, who is a member of a law enforcement dynasty. His father and his many sisters are also officers, and the eldest sister Chia-Ling is one of the highest ranking women in the police department. When a Vietnamese gang begins a rampage through the city, the women must overcome their suspicion of one another to bring the criminals to justice.","genre_ids":[28,80],"media_type":"movie","popularity":1.25,"vote_count":30,"poster_path":"/7XumtdPXkoKZ2mXhSxyPcAPkGm.jpg","release_date":"1990-04-07","vote_average":6.5,"backdrop_path":"/cK1e6u74LP4FZm0OYVn87JNnNmi.jpg","original_title":"皇家女將","original_language":"cn"},{"id":134764,"adult":false,"title":"Due West: Our Sex Journey","video":false,"overview":"Set in contemporary Hong Kong, several young people are searching for romance and struggling to learn the difference between lust and love in an adventure that takes them to the mainland where pleasure is much more readily available.","genre_ids":[35,18,10749],"media_type":"movie","popularity":4.092,"vote_count":56,"poster_path":"/iHNfgw9bS5DBjsVxVAXL8Nm6Klm.jpg","release_date":"2012-09-20","vote_average":6,"backdrop_path":"/xu7d0EZo6nqKUb41CC96YdTg2Jw.jpg","original_title":"一路向西","original_language":"cn"},{"id":63064,"adult":false,"title":"Buddha Mountain","video":false,"overview":"In Chengdu, China, a retired female opera singer named Master Chang takes in a trio of young tenants into her boarding home. The tenants include a rock singer and a college student who has run away from home.","genre_ids":[18],"media_type":"movie","popularity":0.6304,"vote_count":40,"poster_path":"/A2CcakhYdSTyZSHV8IcxjSeQEuP.jpg","release_date":"2011-03-03","vote_average":6.75,"backdrop_path":"/4KlIXNsXQfealpVIefjvF4X46Yr.jpg","original_title":"观音山","original_language":"zh"},{"id":635389,"adult":false,"title":"Jiang Ziya","video":false,"overview":"Atop the ruins of war, top commander Jiang Ziya is given the task to banish the Nine-tailed Fox Demon who threatens all mortals' very existence. When he discovers the Nine-tailed Fox's life linked to the soul of an innocent girl, he is faced with a challenging decision: follow the will of heaven or find his own path to righteousness.","genre_ids":[16,28,14,12],"media_type":"movie","popularity":1.4602,"vote_count":211,"poster_path":"/eDq4dGgNHxPbT3Y5S6mfymsQ0rQ.jpg","release_date":"2020-10-01","vote_average":7.268,"backdrop_path":"/6Urx7y2CQQvxIlzk5R0BpOKI2NR.jpg","original_title":"姜子牙","original_language":"zh"},{"id":366080,"adult":false,"title":"Kabali","video":false,"overview":"A gangster in Malaysia goes in search of his family after 25 years of imprisonment.","genre_ids":[28,80,18],"media_type":"movie","popularity":0.5103,"vote_count":90,"poster_path":"/va0M1xhP3sUUERWfHeSKGVhtJHW.jpg","release_date":"2016-07-22","vote_average":5.978,"backdrop_path":"/12DJjwUO8rr3ds2CAXpPNwhPet6.jpg","original_title":"கபாலி","original_language":"ta"},{"id":950075,"adult":false,"title":"Sookshmadarshini","video":false,"overview":"Manuel returns with his mother to their former home in a middle-class neighbourhood. Suspicious of his intentions, Priyadarshini and her friends begin gathering clues, convinced he may be hiding something sinister.","genre_ids":[9648,53,35],"media_type":"movie","popularity":0.7943,"vote_count":28,"poster_path":"/rOZt5FVZC51keFRRUSzWGE5y1Rt.jpg","release_date":"2024-11-22","vote_average":7.446,"backdrop_path":"/jdSLtUpElZuKkqlY85n6YHZhVWB.jpg","original_title":"സൂക്ഷ്മദര്‍ശിനി","original_language":"ml"},{"id":99735,"adult":false,"title":"Dam Street","video":false,"overview":"Yun is shunned when she becomes pregnant in school, and her mother gives the child up for adoption. When Yun tutors a boy 10 years later, her mother discovers he is Yun's son.","genre_ids":[18],"media_type":"movie","popularity":0.3788,"vote_count":12,"poster_path":"/1OVP9azXo56ymqLWxapICebK82D.jpg","release_date":"2005-09-09","vote_average":6.167,"backdrop_path":"/7zc0rDOHXKOyCraGKTSLdUuSVGR.jpg","original_title":"红颜","original_language":"zh"},{"id":58043,"adult":false,"title":"My Piece of the Pie","video":false,"overview":"France, a factory worker, lives with her three daughters in Dunkirk. The factory where she worked has been closed, leaving France and all of her workmates without a job. She decides to go to Paris to look for work. There she finds a cleaning job at the home of a rich man, Steve, whose world is radically different from her own. As their paths keep crossing, she discovers that her employer played a part in closing the factory in Dunkirk...","genre_ids":[18,35],"media_type":"movie","popularity":1.0414,"vote_count":189,"poster_path":"/xWaG5iXaYpl8MmSvMVYhuiAinMt.jpg","release_date":"2011-03-16","vote_average":5.683,"backdrop_path":"/1pz3SskOp7i1JHGosUBmrrB57LN.jpg","original_title":"Ma part du gâteau","original_language":"fr"},{"id":145954,"adult":false,"title":"The Monkey King 3D: Uproar in Heaven","video":false,"overview":"A completely remade animation film based on the original 1961 animation The Monkey King. Mythical ancient China. Born from some magic stones that fell to Earth a long time ago when Goddess Nüwa mended the sky, Sun Wukong, aka Monkey King, sets off on his first adventure to gain a worthy weapon. This earns the attention of the Jade Emperor of Heaven.","genre_ids":[16],"media_type":"movie","popularity":0.7193,"vote_count":11,"poster_path":"/kCWKk5tq6XphcncG1bhC6ugAdAW.jpg","release_date":"2012-01-12","vote_average":7.4,"backdrop_path":"/2JkdHrPDFXP7CsOnPq8am9IyNeM.jpg","original_title":"大闹天宫","original_language":"zh"},{"id":276290,"adult":false,"title":"Wonder Women","video":false,"overview":"This is an outrageous comedy about seven days in the life of two girls Leung and Ling, who want to skyrocket to the top by entering a beauty pageant. Both girls are ballyhooed as the hottest contestants, but at the end neither can make it to the top 5! What's more, Ling is dumped by her boyfriend, and gets fired at the same time. Being afraid of going home to get along with her father. Leung gives her a hand, inviting Ling to stay with her in her roof-top bungalow. Then they begin their days of similar conscious degradation, which force them to become best friends. But their friendship becomes short-lived when they run into a handsome and well-built young man Wong. They start to vie for his attention and his sex. However, before the climax of their war comes, they find out that he's a dawdler. Shattered by the fact, the two girls eventually come to team with one another.","genre_ids":[35],"media_type":"movie","popularity":0.3947,"vote_count":5,"poster_path":"/2DBpyhAJo4CEuD0gaUNcgFsbh1O.jpg","release_date":"1987-10-03","vote_average":4.4,"backdrop_path":"/samwcUPaze8zqdeoHeMmj9yDxFA.jpg","original_title":"神奇兩女俠","original_language":"cn"},{"id":72785,"adult":false,"title":"The Flight of the Eagle","video":false,"overview":"The Swedish 19th century engineer Salomon August Andrée sets out to become the first man on the north pole. His idea is to launch a polar expedition using a hydrogen balloon, together with two friends. The balloon, \"The Eagle\", takes off from Svalbard in 1897, but the three men are never heard from again.","genre_ids":[18,12],"media_type":"movie","popularity":0.7932,"vote_count":26,"poster_path":"/azCz5nVSHUuHt3HQ99cZSNf2heA.jpg","release_date":"1982-08-26","vote_average":7,"backdrop_path":"/cmut591ASCNLH7XemJqjItn1C34.jpg","original_title":"Ingenjör Andrées luftfärd","original_language":"sv"},{"id":12104,"adult":false,"title":"Pink Floyd: The Wall","video":false,"overview":"A troubled rock star descends into madness in the midst of his physical and social isolation from everyone.","genre_ids":[10402,18],"media_type":"movie","popularity":2.5682,"vote_count":1609,"poster_path":"/aElHyIdF5jmctFGhlhhaPFsbBJC.jpg","release_date":"1982-07-14","vote_average":7.942,"backdrop_path":"/Ag4eANWzHEwC7rQVyvcGsL34ieP.jpg","original_title":"Pink Floyd: The Wall","original_language":"en"},{"id":945961,"adult":false,"title":"Alien: Romulus","video":false,"overview":"While scavenging the deep ends of a derelict space station, a group of young space colonizers come face to face with the most terrifying life form in the universe.","genre_ids":[27,878],"media_type":"movie","popularity":14.3854,"vote_count":4306,"poster_path":"/2uSWRTtCG336nuBiG8jOTEUKSy8.jpg","release_date":"2024-08-13","vote_average":7.169,"backdrop_path":"/iYqSQaWDttQIQzsxg9xHyg0bttG.jpg","original_title":"Alien: Romulus","original_language":"en"},{"id":99861,"adult":false,"title":"Avengers: Age of Ultron","video":false,"overview":"When Tony Stark tries to jumpstart a dormant peacekeeping program, things go awry and Earth’s Mightiest Heroes are put to the ultimate test as the fate of the planet hangs in the balance. As the villainous Ultron emerges, it is up to The Avengers to stop him from enacting his terrible plans, and soon uneasy alliances and unexpected action pave the way for an epic and unique global adventure.","genre_ids":[28,12,878],"media_type":"movie","popularity":16.5757,"vote_count":24137,"poster_path":"/4ssDuvEDkSArWEdyBl2X5EHvYKU.jpg","release_date":"2015-04-22","vote_average":7.271,"backdrop_path":"/kIBK5SKwgqIIuRKhhWrJn3XkbPq.jpg","original_title":"Avengers: Age of Ultron","original_language":"en"},{"id":23273,"adult":false,"title":"Too Much","video":false,"overview":"Oscar dreams of becoming an actor or a stuntman. To contact a manufacturer he stages an accident and consequently injures a young actress, then tries to limit the damage by taking the girl to his home.","genre_ids":[35],"media_type":"movie","popularity":1.54,"vote_count":206,"poster_path":"/dSLGHuYPDMAoVebdl7OPPDXfqfO.jpg","release_date":"1986-01-30","vote_average":6.437,"backdrop_path":"/7OrQ4XqjgAl830UY5BReLstzlA0.jpg","original_title":"Troppo forte","original_language":"it"},{"id":10238,"adult":false,"title":"Cries and Whispers","video":false,"overview":"As Agnes slowly dies of cancer, her sisters are so immersed in their own psychic pains that they are unable to offer her the support she needs.","genre_ids":[18],"media_type":"movie","popularity":1.2055,"vote_count":762,"poster_path":"/a1bMgB09YDvvRN9SitCclUYragr.jpg","release_date":"1972-12-21","vote_average":7.882,"backdrop_path":"/xmLgdb0yDBXa7Dlo3aCzjhjCkuE.jpg","original_title":"Viskningar och rop","original_language":"sv"},{"id":173731,"adult":false,"title":"The Cave of the Golden Rose 3","video":false,"overview":"The powerful evil wizard Tarabas gets knowledge about a prophecy that a king's child will defeat him. So he sends out his army of dead soldiers to kidnap all royal children. When the soldiers attack Fantaghiro's castle to steal the babies of her sisters, the battle seems to be lost until she discovers the secret to defeat the solders but by doing that she loses Romualdo. Now Fantaghiro must find the evil wizard Tarabas and convince him to break the spell and bring back Romualdo.","genre_ids":[12,10751,14,10749],"media_type":"movie","popularity":0.9828,"vote_count":103,"poster_path":"/3xRkLoMRxCbL3AN17KUdjZ5heLD.jpg","release_date":"1993-12-20","vote_average":6.3,"backdrop_path":"/r6Ddjy5H1LFWbW0BgQ83dFX5Cqr.jpg","original_title":"Fantaghirò 3","original_language":"it"},{"id":2786,"adult":false,"title":"Pierrot le Fou","video":false,"overview":"Pierrot escapes his boring society and travels from Paris to the Mediterranean Sea with Marianne, a girl chased by hit-men from Algeria. They lead an unorthodox life, always on the run.","genre_ids":[18,10749,80],"media_type":"movie","popularity":1.5971,"vote_count":922,"poster_path":"/i124H6iQB4CawrgFW9aZaZs7OBO.jpg","release_date":"1965-11-05","vote_average":7.3,"backdrop_path":"/4zJ9w3lZcZI3mBXcNiq6s8bqpDO.jpg","original_title":"Pierrot le fou","original_language":"fr"},{"id":10905,"adult":false,"title":"The Man with One Red Shoe","video":false,"overview":"A man is mistaken as a spy by the CIA when he arrives at the airport with one red shoe.","genre_ids":[28,35],"media_type":"movie","popularity":1.5636,"vote_count":297,"poster_path":"/lD44uiCKnLVCKiEnB0urtqIR0nE.jpg","release_date":"1985-07-18","vote_average":5.675,"backdrop_path":"/1iwpwlP9SafsCxMKieZVlxCjYaa.jpg","original_title":"The Man with One Red Shoe","original_language":"en"},{"id":55197,"adult":false,"title":"The Flavor of Green Tea Over Rice","video":false,"overview":"The arranged marriage between a capricious woman from Tokyo high society and a quiet and rustic man is tested by a marital crisis.","genre_ids":[18],"media_type":"movie","popularity":0.803,"vote_count":98,"poster_path":"/mCXg9AfQlcwCR7E7vJCI96n4nLv.jpg","release_date":"1952-10-01","vote_average":7.5,"backdrop_path":"/p5BLZ8KmcQFOaT51KnmDmRxrpnb.jpg","original_title":"お茶漬けの味","original_language":"ja"}],"similar_content":[{"id":279753,"adult":false,"title":"Alma's Rainbow","video":false,"overview":"The teenage daughter of a Brooklyn 