5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"About Time\",\"description\":\"The night after another unsatisfactory New Year's party, Tim's father tells his son that the men in his family have always had the ability to travel through time. They can't change history, but they can change what happens and has happened in their own lives. Thus begins the start of a lesson in learning to appreciate life itself as it is, as it comes, and most importantly, the people living alongside us.\",\"image\":\"https://image.tmdb.org/t/p/w500/iR1bVfURbN7r1C46WHFbwCkVve.jpg\",\"datePublished\":\"2013-09-04\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"GB\",\"inLanguage\":\"en\",\"genre\":[\"romantic comedy\",\"time-travel film\",\"comedy film\",\"romance film\",\"drama film\",\"science fiction film\",\"Drama\",\"Romance\",\"Fantasy\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.906,\"bestRating\":10,\"ratingCount\":9069}}"}}],["$","$L10",null,{"initialDrama":{"id":"43709797-291d-4830-b580-d233a7f2a8de","tmdb_id":122906,"imdb_id":"tt2194499","content_type":"movie","title":"About Time","original_title":"About Time","overview":"The night after another unsatisfactory New Year's party, Tim's father tells his son that the men in his family have always had the ability to travel through time. They can't change history, but they can change what happens and has happened in their own lives. Thus begins the start of a lesson in learning to appreciate life itself as it is, as it comes, and most importantly, the people living alongside us.","poster_path":"/iR1bVfURbN7r1C46WHFbwCkVve.jpg","backdrop_path":"/einbto9qLXFx9QXxEHylaxDbKPx.jpg","release_date":"2013-09-04","first_air_date":null,"status":"published","original_language":"en","origin_country":["GB"],"genres":[{"name":"romantic comedy"},{"name":"time-travel film"},{"name":"comedy film"},{"name":"romance f