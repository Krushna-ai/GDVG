5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Bramayugam\",\"description\":\"A folk singer in 17th-century Kerala discovers a mansion. Inside, he encounters an enigmatic cook and a powerful master, setting in motion a chain of events that changes his life.\",\"image\":\"https://image.tmdb.org/t/p/w500/snQLwRrfQAl5YFKVefZq9Lbscki.jpg\",\"datePublished\":\"2024-02-15\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"IN\",\"inLanguage\":\"ml\",\"genre\":[\"Horror\",\"Thriller\",\"Drama\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.636,\"bestRating\":10,\"ratingCount\":77}}"}}],["$","$L10",null,{"initialDrama":{"id":"04b77802-23be-4af6-9562-a45804170c0c","tmdb_id":1166133,"imdb_id":"tt27431598","content_type":"movie","title":"Bramayugam","original_title":"ഭ്രമയുഗം","overview":"A folk singer in 17th-century Kerala discovers a mansion. Inside, he encounters an enigmatic cook and a powerful master, setting in motion a chain of events that changes his life.","poster_path":"/snQLwRrfQAl5YFKVefZq9Lbscki.jpg","backdrop_path":"/3Y5pOfxMrG8SqbIcGhYy497eOXc.jpg","release_date":"2024-02-15","first_air_date":null,"status":"published","original_language":"ml","origin_country":["IN"],"genres":[{"id":27,"name":"Horror"},{"id":53,"name":"Thriller"},{"id":18,"name":"Drama"}],"popularity":5.3874,"vote_average":7.636,"vote_count":77,"runtime":139,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:54:55.652508+00:00","updated_at":"2026-02-21T13:20:51.505+00:00","tagline":"The Age of Madness","homepage":"https://bramayugam.online/","budget":3300000,"revenue":10000000,"production_companies":[{"id":11835,"name":"Y NOT Studios","logo_path":"/yEkKuDfFOGouqL5i9lssaAo5Key.png","origin_country":"IN"},{"id":206433,"name":"Night Shift Studios","logo_path":null,"origin_country":""}],"production_countries":[{"name":"India","iso_3166_1":"IN