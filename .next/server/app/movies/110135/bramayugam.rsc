c0fxRyq13eFE9A.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-02-21T13:21:06.175+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Bramayugam","runtime":139,"tagline":"The Age of Madness","homepage":"https://bramayugam.online/","overview":"A folk singer in 17th-century Kerala discovers a mansion. Inside, he encounters an enigmatic cook and a powerful master, setting in motion a chain of events that changes his life."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"","iso_639_1":"ml","iso_3166_1":"IN","english_name":"Malayalam"},{"data":{"title":"பிரமயுகம்","runtime":0,"tagline":"","homepage":"","overview":""},"name":"தமிழ்","iso_639_1":"ta","iso_3166_1":"IN","english_name":"Tamil"},{"data":{"title":"బ్రహ్మయుగం","runtime":0,"tagline":"","homepage":"","overview":""},"name":"తెలుగు","iso_639_1":"te","iso_3166_1":"IN","english_name":"Telugu"},{"data":{"title":"ಬ್ರಹ್ಮಯುಗಂ","runtime":0,"tagline":"","homepage":"","overview":""},"name":"?????","iso_639_1":"kn","iso_3166_1":"IN","english_name":"Kannada"},{"data":{"title":"भ्रमयुगम","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"Bramayugam","runtime":145,"tagline":"","homepage":"","overview":"Thevan, ein Volkssänger aus der Kaste der Paanan, hat auf der Flucht vor der Sklaverei eine schicksalhafte Begegnung, die ihn zur Entdeckung einer alten Tradition führt, die sein Schicksal verändert."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"轮回:疯狂时代","runtime":0,"tagline":"","homepage":"","overview":"在电影发布会上，萨达西万指出，这个故事“植根于喀拉拉邦的黑暗时代”。 这部电影计划以五种印度语言同时发行。 马拉雅拉姆语小说家T. D. Ramakrishnan加入了这个项目，负责电影的对话。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Bramayugam","runtime":0,"tagline":"","homepage":"","overview":"Thevan, un cantante folclórico de la casta Paanan, tiene un encuentro fatídico cuando escapa de la esclavitud, lo que lo lleva a descubrir una antigua tradición que altera su destino."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Thevan, un chanteur folk de la caste Paanan, fait une rencontre fatidique en échappant à l'esclavage, ce qui l'amène à découvrir une ancienne tradition qui modifie son destin."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Thevan, lidový zpěvák z kasty Paanan, se na útěku z otroctví setkává s osudovou událostí, která ho přivede k objevení prastaré tradice, jež změní jeho osud."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"輪回：瘋狂時代","runtime":0,"tagline":"","homepage":"","overview":"在電影發布會上，薩達西萬指出，這個故事“植根於喀拉拉邦的黑暗時代”。這部電影計劃以五種印度語言同時發行。馬拉雅拉姆語小說家T.D.Ramakrishnan加入了這個項目，負責電影的對話。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Bramayugam","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Bramayugam","runtime":0,"tagline":"La era de la locura","homepage":"","overview":"Thevan, un cantante folclórico de la casta Paanan, tiene un encuentro fatídico cuando escapa de la esclavitud, lo que lo lleva a descubrir una antigua tradición que altera su destino."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Bramayugam","runtime":0,"tagline":"","homepage":"","overview":"Thevan, um cantor folk da casta Paanan, tem um encontro fatídico ao escapar da escravidão, o que o leva a descobrir uma antiga tradição que altera seu destino."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Брамаюгам. Эпоха безумия","runtime":0,"tagline":"","homepage":"","overview":"Южный Малабар, XVII век. Бывший певец местного правителя направлялся домой, но, после того как его попутчика съела демоница, мужчина заблудился в лесу. Не имея возможности перейти бурную реку, он выходит к некогда богатому запущенному особняку, где его встречают хозяин и единственный слуга. Послушав пение гостя, хозяин предлагает ему остаться на несколько дней, а тот с радостью соглашается, не подозревая, что покинуть зловещий дом будет не так просто."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"브라마유감","runtime":0,"tagline":"","homepage":"","overview":"\"광기의 시대\" 17세기 케랄라의 한 민속 가수가 한 저택을 발견한다. 그 안에서 그는 수수께끼 같은 요리사와 강력한 주인을 만나게 되며, 이는 그의 삶을 바꾸는 일련의 사건들을 촉발시킨다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"17. yüzyıl Kerala'sında bir halk ozanı bir konak keşfeder. İçeride esrarengiz bir aşçı ve güçlü bir efendiyle karşılaşır ve bu durum hayatını değiştirecek bir olaylar zincirini başlatır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"}],"reviews_tmdb":[],"recommendations":[{"id":607145,"adult":false,"title":"Rocketry: The Nambi Effect","video":false,"overview":"The story of the great Indian rocket scientist, Shri Nambi Narayanan's life, a true patriot, who was turned into a villain in the blink of an eye after being falsely accused of treason.","genre_ids":[18,36],"media_type":"movie","popularity":0.4076,"vote_count":54,"poster_path":"/o7A1agEoXvwyyOmIbHnUhfnC34j.jpg","release_date":"2022-07-01","vote_average":7.611,"backdrop_path":"/nkdXBPZmX7i2Dt8MKSYjmPPF7ov.jpg","original_title":"Rocketry: The Nambi Effect","original_language":"ta"},{"id":960876,"adult":false,"title":"Dunki","video":false,"overview":"Four friends from a sleepy little village in Punjab share a common dream: to go to England. Their problem is that they have neither the visa nor the ticket. A soldier alights from a train one day, and their lives change. He gives them a soldier's promise: He will take them to the land of their dreams. What follows is a hilarious and heartwarming tale of a perilous journey through the desert and the sea, but most crucially through the hinterlands of their mind.","genre_ids":[12,35,18],"media_type":"movie","popularity":1.3699,"vote_count":104,"poster_path":"/kPRb1mbVHGop0egQ7153y0lhzGL.jpg","release_date":"2023-12-21","vote_average":6.4,"backdrop_path":"/uuw0PRR4sgGi1IV4CYYpEYtez9y.jpg","original_title":"डंकी","original_language":"hi"},{"id":1149791,"adult":false,"title":"Premalu","video":false,"overview":"Sachin, a carefree graduate, crosses paths with Reenu, a spirited IT professional, in Hyderabad. As their friendship deepens, unspoken feelings, career ambitions and life choices challenge their bond.","genre_ids":[10749,35],"media_type":"movie","popularity":1.028,"vote_count":55,"poster_path":"/uPpmBjY3znUqGY8kYwI5xvOrSc0.jpg","release_date":"2024-02-09","vote_average":7.745,"backdrop_path":"/gDyLcjvmdAhmYqjCMwZ9PndnAVm.jpg","original_title":"പ്രേമലു","original_language":"ml"},{"id":472221,"adult":false,"title":"The Goat Life","video":false,"overview":"Indian migrant worker Najeeb Muhammad goes to Saudi Arabia to earn money. However, in a twist of fate, he finds himself living a slave-like existence, herding goats in the middle of the desert.","genre_ids":[18,12],"media_type":"movie","popularity":2.92,"vote_count":58,"poster_path":"/vwRkVhvJuAFz4i8udXMNkcJCztc.jpg","release_date":"2024-03-28","vote_average":7.233,"backdrop_path":"/u7GXKY7EUTBS4kQO6aXqDNXWgpd.jpg","original_title":"ആടുജീവിതം","original_language":"ml"},{"id":987895,"adult":false,"title":"Maaveeran","video":false,"overview":"After a head injury, cowardly newspaper cartoonist Sathya hears a voice in his mind, foretells events and puts him in precarious situations and forces him to take