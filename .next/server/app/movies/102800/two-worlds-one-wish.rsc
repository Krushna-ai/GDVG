_path":"/pJ3j5B804iuBih40iy2NXPOu7BJ.jpg","iso_639_1":"en","vote_average":1.75},{"width":750,"height":1125,"file_path":"/kaFvxuNGxkc7iwTOTolmmspJAZv.jpg","iso_639_1":"tr","vote_average":1.75},{"width":833,"height":1250,"file_path":"/uvSQ60H3F1AOPc44iibwk9ob1AV.jpg","iso_639_1":"tr","vote_average":0.166},{"width":853,"height":1280,"file_path":"/vCo5UPxKoftqqPQiB8f7kFA4UP3.jpg","iso_639_1":"it","vote_average":0},{"width":848,"height":1264,"file_path":"/9hz2kCHTvAkKEnEkc43Vebg0Wuu.jpg","iso_639_1":"pt","vote_average":0},{"width":2000,"height":3000,"file_path":"/fap4iIVduMoV9wAsKhemmoDTu9t.jpg","iso_639_1":"fr","vote_average":0},{"width":2000,"height":3000,"file_path":"/xF5raKXPA2yyUW0Z28hy8w73fXY.jpg","iso_639_1":"ar","vote_average":0},{"width":2000,"height":3000,"file_path":"/7dtZeenNGHuFEAfT5lhb3NNLzA7.jpg","iso_639_1":"ar","vote_average":0},{"width":500,"height":750,"file_path":"/3kqAiP9dYlPwV56AFtIuKGMA0JA.jpg","iso_639_1":"pt","vote_average":0},{"width":1920,"height":2880,"file_path":"/z3TOm0laEXLGPoH3VmzTYyHu1YR.jpg","iso_639_1":"es","vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/kKWZq6M76mJM98U0HdpaxBRnPuD.jpg","iso_639_1":"en","vote_average":3.334},{"width":3840,"height":2160,"file_path":"/yh21dJHKVkSX4tzNYrFNPAhCEzD.jpg","iso_639_1":"ar","vote_average":0},{"width":3840,"height":2160,"file_path":"/2yZmwuXiQw58GiXwJwGNYtsDrEL.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/easkSlFLOsvAsA0mI0HCQ2AaFkZ.jpg","iso_639_1":"tr","vote_average":0},{"width":1920,"height":1080,"file_path":"/dgInJBQMlx3jIGpfzFpWz9VrjwO.jpg","iso_639_1":"ka","vote_average":0}]},"enriched_at":"2026-04-21T07:20:24.351+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Two Worlds One Wish","runtime":118,"tagline":"","homepage":"https://www.amazon.com/dp/B0FWDXNRPN","overview":"Twenty-one years after a magical meeting at a children's hospital, Bilge and Can suddenly begin hearing each other's voices telepathically. What seems like a miracle soon reveals a hidden secret, as fate-reuniting them after decades-has much more in store."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Два мира, одно желание","runtime":0,"tagline":"«Когда пути расходятся – судьба соединяет»","homepage":"","overview":"На первый взгляд кажется, что Бильге и Джана разделяют целые миры: он - страстный археолог, чьё имя знают далеко за пределами родины, а она - уверенный в себе юрист, привыкшая полагаться лишь на разум и чёткие правила. И всё же их история началась ещё в детстве, когда простая дружба постепенно раскрылась в чувство, способное оставить след на всю жизнь. Время и обстоятельства развели их по разным дорогам, но судьба оказалась настойчивой: однажды она вновь свела Бильге и Джана, чтобы проверить, насколько крепкими могут быть чувства, которые не смогли стереть ни расстояние, ни годы."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Due mondi, un desiderio","runtime":118,"tagline":"","homepage":"","overview":"Ventuno anni dopo un magico incontro in un ospedale pediatrico, Bilge e Can iniziano a sentire telepaticamente una la voce dell'altro. Un apparente miracolo rivela un segreto nascosto e il fato, riunendoli dopo decine di anni, riserva loro molto altro. Un'avventura emozionante e un amore epico li attendono."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Çocuk hastanesinde tanışıp büyülü anlar yaşayan Bilge ve Can, 21 yıl sonra aniden telepatik olarak birbirlerini duymaya başlar. Çok geçmeden Can bu mücizenin arkasında büyük bir sır olduğunu keşfeder. Bunca yıl sonra onları bir araya getiren kaderin başka planları vardır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Deux mondes pour un vœu","runtime":0,"tagline":"","homepage":"","overview":"Vingt et un ans après leur rencontre magique à l'hôpital pour enfants, Bilge et Can commencent à s'entendre parler de façon télépathique. Ce qui semble être un miracle révèle bientôt un secret, car le destin, qui les a réunis après des décennies, leur réserve bien des surprises. Une aventure palpitante et une histoire d'amour épique les attendent."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"สองโลกหนึ่งคำอธิษฐาน","runtime":0,"tagline":"","homepage":"","overview":"ยี่สิบเอ็ดปีหลังจากการพบกันอย่างมหัศจรรย์ที่โรงพยาบาลเด็ก บีลเกกับจานกลับเริ่มได้ยินเสียงของกันและกันทางจิต สิ่งที่ดูเหมือนปาฏิหาริย์กลับเผยความลับที่ซ่อนอยู่ เมื่อลิขิตชักนำให้พวกเขามาพบกันอีกครั้งหลังผ่านไปหลายทศวรรษ โดยมีเรื่องราวสุดระทึกใจพร้อมกับความรักอันยิ่งใหญ่รออยู่ข้างหน้า"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Dois Mundos, Um Desejo","runtime":118,"tagline":"Quando o Amor tem Destino","homepage":"","overview":"Vinte e um anos depois de um encontro mágico em um hospital infantil, Bilge e Can de repente começam a ouvir a voz um do outro telepaticamente. O que parece um milagre logo revela um segredo escondido, pois o destino, ao reuni-los depois de décadas, lhes reserva muito mais. Uma aventura emocionante e uma história de amor épica os aguardam."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Dos mundos, un deseo","runtime":118,"tagline":"","homepage":"","overview":"Bilge y Can comienzan a escucharse telepáticamente veintiún años después de aquel encuentro mágico en el hospital infantil. Lo que parece ser un milagro termina siendo un secreto oculto, ya que el destino les reserva mucho más a pesar del tiempo: una aventura emocionante y una historia de amor épica."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Dwa światy - jedno życzenie","runtime":0,"tagline":"","homepage":"","overview":"Dwadzieścia jeden lat po magicznym spotkaniu w szpitalu dziecięcym Bilge i Can nagle zaczynają słyszeć się telepatycznie. To, co wydawało się cudem, okazuje się skrywać jeszcze jedną tajemnicę, dzięki czemu spotykają się po latach, a los planuje dla nich jeszcze więcej wydarzeń. To niesamowita przygoda i piękna historia o miłości."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"跨界情緣","runtime":0,"tagline":"","homepage":"","overview":"在兒童醫院魔幻的初遇後過了21年，碧潔和強突然可以透過心電感應聽到彼此的聲音。感覺像是奇蹟降臨，很快地兩人便發現了不為人知的秘密：命運在數十載後又將兩人湊在一起，絕對是別有用意。驚悚的冒險、精彩的愛情故事，就此展開。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"عالمان، أمنية واحدة","runtime":0,"tagline":"","homepage":"","overview":"بعد واحد وعشرين عاماً من لقاءٍ ساحر في مستشفى للأطفال، تبدأ بيلغا وجان فجأةً في سماع أصوات بعضهما بعضاً عن بُعد. وما يبدو معجزةً، سرعان ما يكشف سراً خفياً، حيث يُخبئ القدر لهما المزيد إذ يجمعهما بعد عقود. مغامرةٌ مثيرة وقصة حب ملحمية في انتظارهما."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Dos mundos, un deseo","runtime":0,"tagline":"","homepage":"","overview":"Veintiún años después de un encuentro mágico en un hospital infantil, Bilge y Can comienzan repentinamente a oír telepáticamente la voz del otro. Lo que parece un milagro pronto revela un secreto, y el destino, al reunirlos después de décadas, les tiene reservado algo mucho mayor. Te esperan una aventura emocionante y una historia de amor épica."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"两个世界一个愿望","runtime":0,"tagline":"","homepage":"","overview":"一位世界著名的考古学家和一位务实的律师在童年纽带多年后重新联系，当时他们天真无邪的友谊变成了坚不可破的东西。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Zwei Welten, ein Herzenswunsch","runtime":0,"tagline":"","homepage":"","overview":"Einundzwanzig Jahre nach einer magischen Begegnung in einem Kinderkrankenhaus beginnen Bilge und Can plötzlich, die Stimmen des anderen telepathisch zu hören. Was wie ein Wunder erscheint, offenbart bald ein verborgenes Geheimnis, denn das Schicksal, das sie nach Jahrzehnten wieder zusammenführt, hat noch viel mehr zu bieten."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Deux mondes pour un vœu","runtime":0,"tagline":"","homepage":"","overview":"Vingt et un ans après leur rencontre magique à l'hôpital pour enfants, Bilge et Can commencent à s'entendre parler de façon télépathique. Ce qui semble être un miracle révèle bientôt un secret, car le destin, qui les a réunis après des décennies, leur réserve bien des surprises. Une aventure palpitante et une histoire d'amour épique les attendent."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"두 세계, 하나의 소원","runtime":0,"tagline":"","homepage":"","overview":"아동 병원에서의 마법 같은 만남으로부터 21년 후, 빌게와 잔은 갑자기 텔레파시를 통해 서로의 목소리를 듣게 된다. 기적 같은 일으로 곧 숨겨진 비밀이 밝혀지고, 수십 년 만의 운명적인 재회에 담긴 원대한 계획이 드러난다. 짜릿한 모험과 서사적인 사랑 이야기가 펼쳐진다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"２つの世界 １つの願い","runtime":0,"tagline":"","homepage":"","overview":"小児病院で運命的に出会ったビルゲとジャン。21年後、二人は突然、テレパシーのように互いの声が聞こえるようになる。奇跡のようなこの出来事は、やがて封印された秘密を呼び覚ます。数十年の時を超えて再び彼らをめぐり合わせた運命は、さらなる驚きの展開へ。待ち受けるのは、スリルあふれる冒険と、壮大な愛の物語だった。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Два свята, едно желание","runtime":0,"tagline":"","homepage":"","overview":"През 1998 г., на Нова година, Билге и Кан се срещат като деца в болница и създават дълбока, магическа връзка. Години по-късно Билге вече е успешен адвокат, а Кан – уважаван археолог. Съдбата отново ги събира, но това събиране поставя на изпитание силата на тяхната уникална, споделена история."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"عالمان، أمنية واحدة","runtime":0,"tagline":"","homepage":"","overview":"بعد واحد وعشرين عاماً من لقاءٍ ساحر في مستشفى للأطفال، تبدأ بيلغا وجان فجأةً في سماع أصوات بعضهما بعضاً عن بُعد. وما يبدو معجزةً، سرعان ما يكشف سراً خفياً، حيث يُخبئ القدر لهما المزيد إذ يجمعهما بعد عقود. مغامرةٌ مثيرة وقصة حب ملحمية في انتظارهما."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Enogtyve år efter et magisk møde på et børnehospital begynder Bilge og Can pludselig at kunne høre hinandens stemmer via telepati. Det, der virker som et mirakel, afslører snart en skjult hemmelighed, da skæbnen har langt mere i vente til dem efter at have genforenet dem efter årtier. Et spændende eventyr og en episk kærlighedshistorie er i vente."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Eenentwintig jaar na een magische ontmoeting in een kinderziekenhuis beginnen Bilge en Can elkaars stemmen ineens telepathisch te horen. Wat een wonder lijkt, onthult al gauw een verborgen geheim, aangezien het lot dat hen na decennia herenigt veel meer in petto heeft: een spannend avontuur en een epische liefde."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"两个世界一个愿望","runtime":0,"tagline":"","homepage":"","overview":"在儿童医院那场奇妙的相遇过去二十一年后，比尔吉和坎恩突然能够通过心灵感应听见彼此的声音。起初这看似一场命运的奇迹，却不知那只是秘密的开端。命运让他们在阔别多年后重逢，而这场重逢仅仅是故事的开始--一段跨越时光的爱情与一场惊心动魄的冒险即将展开。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"Dva světy, jedno přání","runtime":0,"tagline":"","homepage":"","overview":"Dvacet jedna let po magickém setkání v dětské nemocnici začnou Bilge a Can zčistajasna telepaticky slyšet hlas toho druhého. To, co vypadá jako zázrak, brzy odhalí skryté tajemství. Osud, který je po desetiletích znovu svedl dohromady, má totiž v zásobě mnohem víc. Čeká vás vzrušující dobrodružství a epický milostný příběh."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"跨界情緣","runtime":0,"tagline":"","homepage":"","overview":"在兒童醫院魔幻的初遇後過了21年，碧潔和強突然可以透過心電感應聽到彼此的聲音。感覺像是奇蹟降臨，很快地兩人便發現了不為人知的秘密：命運在數十載後又將兩人湊在一起，絕對是別有用意。驚悚的冒險、精彩的愛情故事，就此展開。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"टू वर्ल्ड्स वन विश","runtime":0,"tagline":"","homepage":"","overview":"बच्चों के अस्पताल में एक जादुई मुलाकात के 21 साल बाद, बिल्गेह और जान को अचानक टेलीपेथी के ज़रिए एक-दूसरे की आवाज़ें सुनाई देती हैं। बहुत जल्द यह चमत्कार एक छुपे हुए राज़ का खुलासा करता है, जहाँ कई दशकों के बाद इन्हें मिलाकर किस्मत में और भी बहुत कुछ है। एक रोमांचक सफ़र और महान प्रेम कहानी आने को है।"},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"Δύο Κόσμοι Μία Ευχή","runtime":0,"tagline":"","homepage":"","overview":"Είκοσι ένα χρόνια μετά από μια μαγική συνάντηση σε ένα νοσοκομείο παίδων, η Μπιλγκέ κι ο Τζαν αρχίζουν ξαφνικά να ακούν ο ένας τον άλλον τηλεπαθητικά. Αυτό που αρχικά μοιάζει με θαύμα σύντομα ξεσκεπάζει ένα κρυμμένο μυστικό, καθώς η μοίρα, η οποία τους ένωσε δεκαετίες μετά, τους επιφυλάσσει πολλά ακόμα. Μια συναρπαστική περιπέτεια και επική ιστορία αγάπης ακολουθεί."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"שני עולמות ומשאלה אחת","runtime":0,"tagline":"","homepage":"","overview":"עשרים ואחת שנים לאחר מפגש קסום בבית חולים לילדים, בילגה וג'אן מתחילים פתאום לשמוע זה את קולו של זה באופן טלפתי. מה שנראה כמו נס חושף עד מהרה סוד נסתר, שכן הגורל, אשר איחד ביניהם לאחר עשרות שנים, צופן להם הרבה יותר. הרפתקה מרתקת עם סיפור אהבה אפי."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"On kulunut 21 vuotta maagisesta tapaamisesta lastensairaalassa. Bilge ja Can alkavat yhtäkkiä kuulla toistensa äänen telepaattisesti. Ihmeeltä vaikuttava asia paljastaa pian piilotetun salaisuuden, kun heidät vuosikymmenien jälkeen takaisin yhteen tuoneella kohtalolla on paljon enemmän varastossa. On tiedossa jännittävä seikkailu ja eeppinen rakkaustarina."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Dua Dunia Satu Harapan","runtime":0,"tagline":"","homepage":"","overview":"Dua puluh satu tahun setelah pertemuan ajaib di rumah sakit anak, Bilge dan Can tiba-tiba mulai saling mendengar suara satu sama lain secara telepati. Apa yang tampak seperti keajaiban segera mengungkap rahasia tersembunyi, karena takdir-yang mempertemukan mereka kembali setelah puluhan tahun-masih menyimpan banyak kejutan. Sebuah petualangan menegangkan dan kisah cinta besar menanti."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Tjueen år etter et magisk møte på et barnesykehus, begynner Bilge og Can plutselig å høre hverandre telepatisk. Det som virker som et mirakel, avslører snart en skjult hemmelighet. For skjebnen - som gjenforener dem etter et tiår - har mer å by på. Et spennende eventyr og en episk kjærlighetshistorie venter."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Vinte e um anos após um encontro mágico num hospital infantil, Bilge e Can começam a ouvir as vozes um do outro telepaticamente. O que parece ser um milagre revela-se um segredo oculto, pois o destino, que os reuniu após décadas, tem muito mais reservado para eles. Uma aventura emocionante e uma história de amor épica esperam por eles."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Két világ, egy kívánság","runtime":0,"tagline":"","homepage":"","overview":"Huszonegy évvel egy varázslatos, gyermekkórházban történt találkozás után Bilge és Can hirtelen telepatikusan hallani kezdik egymás hangját. Ami kezdetben csodának tűnik, hamarosan rejtett titkokat tár fel, hiszen a sors, amely évtizedek múltán újra egymáshoz sodorja őket, többet tartogat számukra, mint hinnék: egy izgalmas kaland és egy örök szerelmi történet veszi kezdetét."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Dua Dunia Satu Hajat","runtime":0,"tagline":"","homepage":"","overview":"Dua puluh satu tahun selepas pertemuan ajaib di sebuah hospital kanak-kanak, Bilge dan Can tiba-tiba mula mendengar suara satu sama lain secara telepati. Apa yang disangka keajaiban rupa-rupanya menyembunyikan rahsia apabila takdir yang mempertemukan mereka semula selepas puluhan tahun membawa sesuatu yang lebih besar menanti. Sebuah pengembaraan mendebarkan dan kisah cinta epik bakal terungkap."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"Dalawang Mundo Isang Hiling","runtime":0,"tagline":"","homepage":"","overview":"Dalawampu't-isang taon matapos ang mahikal na pagkikita sa isang ospital na pambata, naririnig na nina Bilge at Can ang isa't-isa sa pamamagitan ng isip lamang. Ang isang tila himala ay nagsiwalat ng lihim, dahil ang tadhana -pinagkita sila matapos ang ilang dekada - ay may nakalaan pa para sa kanila. Isang kapana-panabik na adventure at epic love story ang naghihintay."},"name":"","iso_639_1":"tl","iso_3166_1":"PH","english_name":"Tagalog"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Tjugoett år efter ett magiskt möte på ett barnsjukhus börjar Bilge och Can plötsligt höra varandras röster telepatiskt. Vad som först verkar vara ett mirakel avslöjar snart en dold hemlighet. För ödet, som återförenar dem efter decennier, har mycket mer i beredskap. Ett spännande äventyr och en episk kärlekshistoria väntar."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Două lumi, o dorință","runtime":0,"tagline":"","homepage":"","overview":"La 21 de ani după o întâlnire magică într-un spital de copii, Bilge și Can încep brusc să se audă unul pe celălalt prin telepatie. Ceea ce pare o minune scoate curând la iveală un secret ascuns, iar soarta, care i-a reunit după două decenii, are planuri mult mai mari pentru ei. O aventură palpitantă și o poveste de dragoste epică îi așteaptă."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Два світи, одне бажання","runtime":0,"tagline":"","homepage":"","overview":"Більге і Джан познайомилися в лікарні, куди вони потрапили ще дітьми напередодні Нового року 1998-го. Минуло багато років, і доля знову зводить їхні шляхи, що встигли розійтися в різні боки. Більге стала успішною та амбітною адвокаткою, а Джан — археологом, що стоїть на порозі важливого відкриття. І той самий зв’язок, який виник між ними в новорічну ніч, цього разу пройде через серйозні випробування."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"دو دنیا، یک آرزو","runtime":0,"tagline":"","homepage":"","overview":"داستان دو دوست کودکی، یک باستان‌شناس و یک وکیل که پس از سال‌ها به یکدیگر می‌رسند و رابطه‌شان به چیزی فرای دوستی تبدیل می‌شود."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"}],"reviews_tmdb":[{"id":"693062418ba99ff10d789065","url":"https://www.themoviedb.org/review/693062418ba99ff10d789065","author":"Ina_77","content":"This movie was emotional rollercoaster and i loved it, i was crying and laughing while watching. Also i really liked chemistry between lead actors. Such a sweet romance.","created_at":"2025-12-03T16:16:01.745Z","updated_at":"2025-12-03T16:59:28.392Z","author_details":{"name":"","rating":10,"username":"Ina_77","avatar_path":null}}],"recommendations":[],"similar_content":[],"external_ids":{"imdb_id":"tt36499994","twitter_id":null,"facebook_id":null,"wikidata_id":"Q136983137","instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":102800,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"BR","release_dates":[{"note":"Prime Video","type":4,"iso_639_1":"","descriptors":[],"release_date":"2025-11-24T00:00:00.000Z","certification":"12"}]},{"iso_3166_1":"ES","release_dates":[{"note":"Prime Video","type":4,"iso_639_1":"","descriptors":[],"release_date":"2025-11-25T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"IT","release_dates":[{"note":"Prime Video","type":4,"iso_639_1":"","descriptors":[],"release_date":"2025-11-25T00:00:00.000Z","certification":""}]},{"iso_3166_1":"SG","release_dates":[{"note":"Prime Video","type":4,"iso_639_1":"","descriptors":[],"release_date":"2025-11-26T00:00:00.000Z","certification":"PG13"}]},{"iso_3166_1":"TR","release_dates":[{"note":"Prime Video","type":4,"iso_639_1":"","descriptors":[],"release_date":"2025-11-25T00:00:00.000Z","certification":"16+"}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikidata_metadata":{},"mood_tags":null,"trope_tags":null,"vibe_description":null,"ai_enriched_at":null,"ai_enrichment_version":0}}]]
