9:{"metadata":[["$","title","0",{"children":"Two Worlds One Wish | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Twenty-one years after a magical meeting at a children's hospital, Bilge and Can suddenly begin hearing each other's voices telepathically. What seems like a miracle soon reveals a hidden secret, as fate-reuniting them after decades-has much more in store."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/102800/two-worlds-one-wish"}],["$","meta","5",{"property":"og:title","content":"Two Worlds One Wish"}],["$","meta","6",{"property":"og:description","content":"Twenty-one years after a magical meeting at a children's hospital, Bilge and Can suddenly begin hearing each other's voices telepathically. What seems like a miracle soon reveals a hidden secret, as fate-reuniting them after decades-has much more in store."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/102800/two-worlds-one-wish"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/mZcwX1aN2RdCLwamxdkoINIhVAm.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Two Worlds One Wish"}],["$","meta","12",{"name":"twitter:description","content":"Twenty-one years after a magical meeting at a children's hospital, Bilge and Can suddenly begin hearing each other's voices telepathically. What seems like a miracle soon reveals a hidden secret, as fate-reuniting them after decades-has much more in store."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/mZcwX1aN2RdCLwamxdkoINIhVAm.jpg"}],["$","link","14",{"rel":"icon","href":"/f