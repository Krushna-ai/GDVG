166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3072,"height":1728,"file_path":"/gvHRaNQv1dkFrObKZS3dUZqfx2v.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/sJ8NHKezcDBB4klYNpU4QOXgOT8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/hwIDGmS9Akpm6C1I7z11SE4AmIo.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/4oKM2g2LiywMncI0mcI4LSmfZRZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/rA5ba6nSpVXP9e3rBdadpMQ7qQV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/u6JbDmsIOMiKAemZZtkADLU1VKX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/fLD893lZV9b1GF83PqRvY9A7FXV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/99zKWGf3nMER243DgpTTiSqeYTd.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/yKUcI1FwBFShXGZHjuKpfQ4earD.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/z8IqbA9SMVt8WbEaiMiGEeLfg7z.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/ohXZfQgSQajjrvuPo9b5CNm0790.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/sZVGbjK0bLasfHwpE7ChaZrHNoY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-03-01T09:04:01.116+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"En la provincia de Tucumán, Argentina, siguen Julieta, una joven acusada de infanticidio, y Soledad Deza, la audaz abogada que lo arriesga todo para asumir su caso altamente controvertido y que sienta precedentes. A medida que se desarrolla el juicio, la difícil situación de Julieta se convierte en un punto álgido en la batalla contra un sistema legal conservador, lo que provoca una oleada de indignación y una creciente ola de solidaridad que trasciende las fronteras."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":108,"tagline":"Based on a true story.","homepage":"https://press.amazonmgmstudios.com/us/en/original-movies/belen","overview":"In the conservative northwestern region of Argentina, Julieta finds herself accused of infanticide after a medical emergency. With support from her attorney and women's rights advocates, she fights for justice in a landmark case that could change lives."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":100,"tagline":"","homepage":"","overview":"La verdadera historia de una joven mujer que enfrentó una injusta sentencia de prisión tras haber sido acusada de cometer un aborto ilegal, lo que la llevó a trabajar en equipo con la abogada Soledad Deza, quien abordó este caso aparentemente imposible."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"Tucumán, Argentine, 2014 ; Une jeune femme est hospitalisée pour de fortes douleurs abdominales, ignorant qu'elle est enceinte. À son réveil, elle est enveloppée dans un brancard et encerclée par la police. Accusée d'avoir avorté volontairement, elle est condamnée, après deux ans de détention provisoire, à huit ans de prison pour homicide involontaire, avec circonstances aggravantes. Une avocate de Tucumán se battra pour sa libération, avec le soutien de milliers de femmes et d'organisations, qui s'uniront pour changer le cours de l'histoire."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"我们是伯利恒","runtime":0,"tagline":"","homepage":"","overview":"2014年，阿根廷图库曼省；一名年轻女性因剧烈腹痛入院，当时她并不知道自己已有身孕。醒来时，她发现自己被手铐铐在轮床上，周围全是警察。她被指控自行堕胎，在拘留两年后，因加重杀人罪被判处八年监禁。图库曼省的一位女律师将为她的自由而战，数千名女性与众多组织纷纷声援，她们团结起来，试图改变历史的走向。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Belén: Uma História de Injustiça","runtime":108,"tagline":"","homepage":"https://www.primevideo.com/-/pt/detail/Bel%C3%A9n-Uma-Hist%C3%B3ria-de-Injusti%C3%A7a/0QDJPKAW4DCLM23P7FWWH5HL2V","overview":"No conservador norte da Argentina, Julieta é acusada de infanticídio após uma emergência médica. Correndo o risco de ser presa por um crime que não cometeu, sua única esperança é Soledad, advogada destemida que arrisca tudo para defendê-la. Juntas, elas transformam uma batalha judicial num movimento por justiça, solidariedade e direitos das mulheres."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Belén","runtime":105,"tagline":"","homepage":"","overview":"W prowincji Tucumán w Argentynie śledź losy Juliety, młodej kobiety oskarżonej o dzieciobójstwo, i Soledad Dezy, odważnej prawniczki, która ryzykuje wszystko, by zająć się jej niezwykle kontrowersyjną, precedensową sprawą. W miarę rozwoju procesu, los Juliety staje się punktem zapalnym w walce z konserwatywnym systemem prawnym – wywołując falę oburzenia i rosnącą falę solidarności, która przekracza granice."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"我們是伯利恆","runtime":0,"tagline":"","homepage":"","overview":"2014年，阿根廷圖庫曼省；一名年輕女性因劇烈腹痛入院，當時她並不知道自己已有身孕。醒來時，她發現自己被手銬銬在輪床上，周圍全是警察。她被指控自行墮胎，在拘留兩年後，因加重殺人罪被判處八年監禁。圖庫曼省的一位女律師將為她的自由而戰，數千名女性與眾多組織紛紛聲援，她們團結起來，試圖改變歷史的走向。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Белен","runtime":0,"tagline":"","homepage":"","overview":"Соледад Деса, смелая адвокат, рискует всем, чтобы взяться за крайне спорное и прецедентное дело. Молодая женщина по имени Хулиета Белен госпитализирована из-за болей в животе. При оказании неотложной медицинской помощи, обнаруживается, что она была беременна. После снятия наркоза она оказывается арестованной полицией по обвинению о провоцировании аборта, незаконного в Аргентине. При поддержке своего адвоката и защитников прав женщин она борется за справедливость в знаменательном деле, которое может изменить жизни."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"بلن","runtime":0,"tagline":"","homepage":"","overview":"داستان زنی که پس از بستری شدن در بیمارستان، متوجه می‌شود حامله است. اما او متهم به ارتکاب جرم می‌شود و حالا باید با کمک وکیل خود و وکلای مداقع حقوق زنان، در این پرونده نجات پیدا کند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"}],"reviews_tmdb":[{"id":"691950b8c14a37294e4ca5ab","url":"https://www.themoviedb.org/review/691950b8c14a37294e4ca5ab","author":"Brent Marchant","content":"$11","created_at":"2025-11-16T04:19:04.952Z","updated_at":"2025-11-16T04:19:05.037Z","author_details":{"name":"Brent Marchant","rating":6,"username":"Brent_Marchant","avatar_path":null}}],"recommendations":[{"id":81022,"adult":false,"title":"Widows","video":false,"overview":"A married man's death puts his widow and mistress in an unusual living arrangement.","genre_ids":[18],"media_type":"movie","popularity":2.274,"vote_count":23,"poster_path":"/kGB2RHAXZix3N9XT1bOcWg01mP4.jpg","release_date":"2011-08-18","vote_average":5.565,"backdrop_path":"/ebzkyy40gmPD8aj0kegjJxK0m48.jpg","original_title":"Viudas","original_language":"es"},{"id":93782,"adult":false,"title":"Fate","video":false,"overview":"Serial killers have plagued the American landscape for decades, committing gruesome atrocities, and providing some tough cases for criminal investigators to crack. Two detectives are on the trail of a bizarre murderer intent on slaughtering his victims, then using them as real-life puppets in a tale that he is trying to tell.","genre_ids":[18,53],"media_type":"movie","popularity":1.0834,"vote_count":5,"poster_path":"/3rIOyrU9I4xpUeYcLIM8hdZNJZU.jpg","release_date":"2003-03-14","vote_average":3.5,"backdrop_path":null,"original_title":"Fate","original_language":"en"},{"id":206067,"adult":false,"title":"Eye for an Eye","video":false,"overview":"A vengeful widow hires a professional killer to train her son so that he can hunt down and kill the men who murdered her husband. The quest for revenge soon becomes an obsession.","genre_ids":[37,53,28],"media_type":"movie","popularity":0.1411,"vote_count":7,"poster_path":"/zUIUwGwWo25AJktCBStKfvfm4Ga.jpg","release_date":"1971-04-29","vote_average":5,"backdrop_path":"/tlqXr9oie2ND1idOyPLdDbiPKle.jpg","original_title":"El sabor de la venganza","original_language":"es"},{"id":525153,"adult":false,"title":"Shadows","video":false,"overview":"During the Second World War, tens of thousands of blonde, blue-eyed Polish children were snatched from their parents and given to German families. Lebensborn was part of Hitler's plan to expand the Aryan master race within the Third Reich. Eight-year old Jerzy returns home at the end of the war to a joyful reunion with his long-lost mother and grandfather. But problems arise as he is taunted by his peers and, longing for his missing father, burns with resentment for his new communist stepfather.","genre_ids":[18],"media_type":"movie","popularity":0.0704,"vote_count":4,"poster_path":"/emSTzEr2qdo3lV14ZQ3uIYsqHJS.jpg","release_date":"1988-08-22","vote_average":7.6,"backdrop_path":null,"original_title":"Cienie","original_language":"pl"},{"id":607527,"adult":false,"title":"Mutthi Bhar Mitti","video":false,"overview":"Jamaal recounts to himself the events that led to him leaving India and migrating to Pakistan after The Great Indian Partition, which explains the title and allows for a narration in the past tense.","genre_ids":[18],"media_type":"movie","popularity":0.1075,"vote_count":1,"poster_path":null,"release_date":"2008-08-14","vote_average":10,"backdrop_path":null,"original_title":"Mutthi Bhar Mitti","original_language":"ur"},{"id":197047,"adult":false,"title":"Crazy Crying Lady","video":false,"overview":"A woman is afflicted with an unusual condition; she cries all the time, at the slightest provocation regardless of whether she's happy or sad, beset by anxieties or problem-free. Nicknamed \"Madame Ho\", this pitiful woman strives to play a more visible role in a household that continually belittles her.","genre_ids":[35],"media_type":"movie","popularity":0.3509,"vote_count":5,"poster_path":"/f0oBlKLkmrOo6gvRl0wrpgIf3Oz.jpg","release_date":"2012-12-24","vote_average":5.2,"backdrop_path":"/x0HkcMSFLIJBHMLUnhmijdtEzgd.jpg","original_title":"คุณนายโฮ","original_language":"th"},{"id":750741,"adult":false,"title":"Strange Object","video":false,"overview":"An archival investigation into the imperial image-making of the RAF ‘Z Unit’, which determined the destruction of human, animal and cultural life across Somaliland, as well as Africa and Asia.","genre_ids":[99,16],"media_type":"movie","popularity":0.3106,"vote_count":1,"poster_path":"/gQPVf2qApFqYIC0n5BJuEpknQys.jpg","release_date":"2020-10-07","vote_average":6,"backdrop_path":"/inuZ4JK0AxKB6xPjNtkUeFAPPDZ.jpg","original_title":"Strange Object","original_language":"en"},{"id":297460,"adult":false,"title":"Adormidera","video":false,"overview":"Malta, the late 1300s. Five soldiers are returning home from battle. Hungry and exhausted, they stumble upon a fort. What was meant to be a one-night stopover rapidly escalades into a whirlwind of intrigue and an epic sword fight for retribution. Will a beautiful woman change their destiny? Or are they doomed to die in their ever quest to protect their land against invaders?","genre_ids":[12,28],"media_type":"movie","popularity":0.1085,"vote_count":14,"poster_path":"/vi04iHkxHU5qJfx0K4Y4FUBgCu3.jpg","release_date":"2013-01-01","vote_average":3.3,"backdrop_path":"/4OkSDMTHwIKKHxfDLa0UtiqsCLe.jpg","original_title":"Adormidera","original_language":"en"},{"id":836032,"adult":false,"title":"Rebecca Zahau: An ID Murder Mystery","video":false,"overview":"When Rebecca Zahau and Max Shacknai both die in mysterious circumstances at the same mansion, their families search for answers—and the truth.","genre_ids":[99,80],"media_type":"movie","popularity":0.0286,"vote_count":2,"poster_path":"/bZvlCAn5SwA0YpEsQclOpxb1dH5.jpg","release_date":"2019-05-27","vote_average":7,"backdrop_path":null,"original_title":"Rebecca Zahau: An ID Murder Mystery","original_language":"en"},{"id":530190,"adult":false,"title":"Third Wedding","video":false,"overview":"Martin, a homosexual widower and whimsical of fifty years, sees itself propose to contract a marriage white with a Congolese of twenty years, Tamara. These two beings that everything separates are going to believe in their love against the authorities of migration and to force to pretend.","genre_ids":[18,35],"media_type":"movie","popularity":1.1299,"vote_count":4,"poster_path":"/fBRdttdQDgRHhp87fMkDHwNfZ0H.jpg","release_date":"2018-06-14","vote_average":5.5,"backdrop_path":"/nS38rKYoXmlrIaV64EZdSdqMu02.jpg","original_title":"Troisièmes Noces","original_language":"fr"},{"id":569538,"adult":false,"title":"Mi héroe","video":false,"overview":"","genre_ids":[],"media_type"