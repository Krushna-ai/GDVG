age":"fr"},{"id":35135,"adult":false,"title":"Hold Anything","video":false,"overview":"Bosko is a construction worker who impresses Honey by making music from everything in sight, including a decapitated mouse, a typewriter and a goat filled with hot air.","genre_ids":[16,35,10751],"media_type":"movie","popularity":0.1451,"vote_count":17,"poster_path":"/n1mpry07SLPyHf9lAumdCTDACjO.jpg","release_date":"1930-10-01","vote_average":5.353,"backdrop_path":"/hm5sRh5TVw3TpMZVavHl6oFdOq8.jpg","original_title":"Hold Anything","original_language":"en"},{"id":441695,"adult":false,"title":"Road War: The Making of 'The Road Warrior'","video":false,"overview":"Retrospective on the making of \"Mad Max 2\".","genre_ids":[99],"media_type":"movie","popularity":0.1947,"vote_count":3,"poster_path":"/s3Q3Up6JqIpdS3Nr8OdomorKjrF.jpg","release_date":"2016-12-06","vote_average":6,"backdrop_path":"/3gG9rkJTdjERQl0Bru2hCzl3W65.jpg","original_title":"Road War: The Making of 'The Road Warrior'","original_language":"en"},{"id":887624,"adult":false,"title":"In the Name of the Sugarcane","video":false,"overview":"A documentary on the struggle of millworkers, farmworkers, and people of Hacienda Luisita, Philippines.","genre_ids":[99],"media_type":"movie","popularity":0.1521,"vote_count":1,"poster_path":"/vLdGpUDUfY3DqE9NAfnkOXoiKh3.jpg","release_date":"2005-01-30","vote_average":10,"backdrop_path":"/bwQehAhqA5wY1wY8Vkbi0ZKG4bp.jpg","original_title":"Sa Ngalan ng Tubo","original_language":"en"}],"similar_content":[{"id":8055,"adult":false,"title":"The Reader","video":false,"overview":"The story of Michael Berg, a German lawyer who, as a teenager in the late 1950s, had an affair with an older woman, Hanna, who then disappeared only to resurface years later as one of the defendants in a war crimes trial stemming from her actions as a concentration camp guard late in the war. He alone realizes that Hanna is illiterate and may be concealing that fact at the expense of her freedom.","genre_ids":[18,10749],"popularity":3.1528,"vote_count":3329,"poster_path":"/r0WURbmnhgKeBpHcpDULBgRedQM.jpg","release_date":"2008-12-10","vote_average":7.466,"backdrop_path":"/waMGsUEoHfYj3A1uRMUUgpBa71d.jpg","original_title":"The Reader","original_language":"en"},{"id":470691,"adult":false,"title":"Esmeralda","video":false,"overview":"It was the first film version of the Hunchback of Notre Dame.","genre_ids":[18],"popularity":1.8091,"vote_count":1,"poster_path":"/yPohMvllKNZoDNd7ODCsBsXkWZM.jpg","release_date":"1905-12-01","vote_average":3,"backdrop_path":null,"original_title":"Esmeralda","original_language":"fr"},{"id":277296,"adult":false,"title":"Vice and Virtue","video":false,"overview":"1944 : Occupied France. Juliette (Vice) is Wehrmacht General Bamberg's mistress and enjoys a privileged life. Her younger sister  Justine (Virtue) is about to marry Jean who is in the Resistance and come to Juliette for help. Both sisters end up at \"la Commanderie\", where Juliette becomes SS Colonel Schonberg's mistress and Justine is detained with other pretty girls who must satisfy the sexual needs of high-ranking nazi officials. Inspired by \"Justine ou les infortunes de la vertu\" by the marquis de Sade","genre_ids":[18,35],"popularity":0.1858,"vote_count":14,"poster_path":"/4s6aUGjsjP3FkiC98HzWmXvA0FR.jpg","release_date":"1963-03-01","vote_average":5.4,"backdrop_path":"/zK30zKTI5QqXK43GGO73NH3d72m.jpg","original_title":"Le Vice et la Vertu","original_language":"fr"},{"id":8092,"adult":false,"title":"This Boy's Life","video":false,"overview":"When a son and mother move to Seattle in hopes for a better life, the mother meets a seemingly polite man. Things go south when the man turns out to be abusive, endangering their lives. As the mother struggles to maintain hope in an impossible situation, the son has plans to escape.","genre_ids":[18],"popularity":1.8552,"vote_count":1056,"poster_path":"/pRMSZfen1Cv1eqwDbtxCBpBqxnU.jpg","release_date":"1993-04-09","vote_average":7.125,"backdrop_path":"/6N6VUUR1gzbCkiGpQzvRREv3Od1.jpg","original_title":"This Boy's Life","original_language":"en"},{"id":8094,"adult":false,"title":"The Magdalene Sisters","video":false,"overview":"Three young Irish women struggle to maintain their spirits while they endure dehumanizing abuse as inmates of a Magdalene Sisters Asylum.","genre_ids":[18,36],"popularity":0.8331,"vote_count":449,"poster_path":"/akOnyPsfzcDvCwP3lzY35i2NIha.jpg","release_date":"2002-08-30","vote_average":7.422,"backdrop_path":"/teMi2HuGuWOmBL599u7dg1xtD1Q.jpg","original_title":"The Magdalene Sisters","original_language":"en"},{"id":470756,"adult":false,"title":"Krisis","video":false,"overview":"Dimitri Venkov’s Krisis is based on a Facebook discussion on December 8, 2013, the day on which pro-European demonstrators in Kiev started to demolish statues of Vladimir Lenin. The film reenacts debates between Russian and Ukrainian artists during the protests, revealing deep aesthetic, historical, and political divisions.","genre_ids":[18,27,10752,10751],"popularity":0.7401,"vote_count":1,"poster_path":"/3MhLGWUU69ZLO37nkUC6rs5DSI7.jpg","release_date":"2016-02-12","vote_average":10,"backdrop_path":"/hDjaIuuOscXjsbCVETnJ9MLbt3j.jpg","original_title":"Krisis","original_language":"ru"},{"id":661539,"adult":false,"title":"A Complete Unknown","video":false,"overview":"New York, early 1960s. Against the backdrop of a vibrant music scene and tumultuous cultural upheaval, an enigmatic 19-year-old from Minnesota arrives in the West Village with his guitar and revolutionary talent, destined to change the course of American music.","genre_ids":[18,10402],"popularity":5.1723,"vote_count":1369,"poster_path":"/llWl3GtNoXosbvYboelmoT459NM.jpg","release_date":"2024-12-25","vote_average":7.081,"backdrop_path":"/kcCy5tKTe6WepVQ6SQaSewpmoCj.jpg","original_title":"A Complete Unknown","original_language":"en"},{"id":470918,"adult":false,"title":"Beast","video":false,"overview":"A troubled woman living in an isolated community finds herself pulled between the control of her oppressive family and the allure of a secretive outsider suspected of a series of brutal murders.","genre_ids":[9648,80,18],"popularity":0.7893,"vote_count":326,"poster_path":"/kZdncyp1IKhEqwv5zdmUpK5Dc7S.jpg","release_date":"2018-04-18","vote_average":6.5,"backdrop_path":"/t3W767pq9rUdMXxVGzWVt2hs1Hs.jpg","original_title":"Beast","original_language":"en"},{"id":8489,"adult":false,"title":"Ali","video":false,"overview":"In 1964, a brash, new pro boxer, fresh from his Olympic gold medal victory, explodes onto the scene: Cassius Clay. Bold and outspoken, he cuts an entirely new image for African Americans in sport with his proud public self-confidence and his unapologetic belief that he is the greatest boxer of all time. Yet at the top of his game, both Ali's personal and professional lives face the ultimate test.","genre_ids":[18],"popularity":3.4275,"vote_count":1832,"poster_path":"/32l3FaCzs8cXWps6hkgNJAcOsP.jpg","release_date":"2001-12-10","vote_average":6.754,"backdrop_path":"/bot4HZT2FWmq8IEcq7MhIVJSj1I.jpg","original_title":"Ali","original_language":"en"},{"id":8289,"adult":false,"title":"Gorky Park","video":false,"overview":"Police Inspector Renko tries to solve the case of three bodies found in Moscow's Gorky Park but finds his attempts to solve the crime impeded by his superiors. Working on his own, Renko seeks out more information and stumbles across a conspiracy involving the highest levels of the government.","genre_ids":[53,80,18,9648],"popularity":1.315,"vote_count":334,"poster_path":"/xQFH7XlMk8pLPDzK5XVEj5McsRm.jpg","release_date":"1983-12-15","vote_average":6.323,"backdrop_path":"/dO8qUkabhQwBy8lPGawtvWQkdKd.jpg","original_title":"Gorky Park","original_language":"en"},{"id":8291,"adult":false,"title":"Poetic Justice","video":false,"overview":"Still grieving after the murder of her boyfriend, hairdresser Justice writes poetry to deal with the pain of her loss. Unable to get to Oakland to attend a convention because of her broken-down car, Justice gets a lift with her friend, Iesha, and Iesha's postal worker boyfriend, Chicago. Along for the ride is Chicago's co-worker, Lucky, to whom Justice grows close after some initial problems. But is she ready to open her heart again?","genre_ids":[18,10749],"popularity":1.377,"vote_count":270,"poster_path":"/fOtMHxhYaCQcu3dwWpg7lz4Bqo0.jpg","release_date":"1993-07-23","vote_average":6.785,"backdrop_path":"/lNvlerKoYwboltmK7hQfgxsYtNP.jpg","original_title":"Poetic Justice","original_language":"en"},{"id":8326,"adult":false,"title":"Holes","video":false,"overview":"After being wrongfully convicted for stealing a pair of shoes, Stanley Yelnats is sent away to Camp Green Lake, a boys detention facility where inmates are forced to dig holes all day in the hot desert sun as a form of character building. But Stanley and the other boys start to unravel a mystery, linked with the camps tough-as-nails warden —and possibly Stanley’s family itself.","genre_ids":[12,10751,18,35],"popularity":3.73,"vote_count":1509,"poster_path":"/o2Dm2mcE1qW8vT0bpsJO5OMBbqa.jpg","release_date":"2003-04-18","vote_average":6.895,"backdrop_path":"/cVMK2k0Wbs8DV3IK5sS4ziVenrI.jpg","original_title":"Holes","original_language":"en"},{"id":8619,"adult":false,"title":"Master and Commander: The Far Side of the World","video":false,"overview":"After an abrupt and violent encounter with a French warship inflicts severe damage upon his ship, a captain of the British Royal Navy begins a chase over two oceans to capture or destroy the enemy, though he must weigh his commitment to duty and ferocious pursuit of glory against the safety of his devoted crew, including the ship's thoughtful surgeon, his best friend.","genre_ids":[12,18,10752],"popularity":4.3795,"vote_count":3438,"poster_path":"/s1cVTQEZYn4nSjZLnFbzLP0j8y2.jpg","release_date":"2003-11-14","vote_average":7.181,"backdrop_path":"/zMHyNxNt4zhL939XX8QLBW3gWfu.jpg","original_title":"Master and Commander: The Far Side of the World","original_language":"en"},{"id":8643,"adult":false,"title":"The Exorcism of Emily Rose","video":false,"overview":"When a younger girl called Emily Rose dies, everyone puts blame on the exorcism which was performed on her by Father Moore prior to her death. The priest is arrested on suspicion of murder. The trial begins with lawyer Erin Bruner representing Moore, but it is not going to be easy, as no one wants to believe what Father Moore says is true.","genre_ids":[80,18,27,53],"popularity":2.8981,"vote_count":2988,"poster_path":"/qMN0HIP34f736kkQcfvTfmL9TP3.jpg","release_date":"2005-09-09","vote_average":6.602,"backdrop_path":"/eHT36hVNslbJXCY3SXgtzxPE3cl.jpg","original_title":"The Exorcism of Emily Rose","original_language":"en"},{"id":8649,"adult":false,"title":"Bringing Out the Dead","video":false,"overview":"Once called \"Father Frank\" for his efforts to rescue lives, Frank Pierce sees the ghosts of those he failed to save around every turn. He has tried everything he can to get fired, calling in sick, delaying taking calls where he might have to face one more victim he couldn't help, yet cannot quit the job on his own.","genre_ids":[18],"popularity":3.0113,"vote_count":1191,"poster_path":"/gE2Q8mL0m0EA6HakRyc92uzSPJn.jpg","release_date":"1999-10-22","vote_average":6.607,"backdrop_path":"/A1V1suhllQJ1CTrKpCulcM7mjyj.jpg","original_title":"Bringing Out the Dead","original_language":"en"},{"id":1067395,"adult":false,"title":"Jim","video":false,"overview":"Jim, a gay priest, invites a sex worker over for the night. The encounter changes Jim’s life forever, but not as he expects.","genre_ids":[18],"popularity":1.3816,"vote_count":1,"poster_path":"/rRaevoRngEBxcUnIOcHXcAfmNel.jpg","release_date":"2022-10-13","vote_average":8,"backdrop_path":"/v2gWERoRMzPO4rYhpj1LpyOZ7RT.jpg","original_title":"Jim","original_language":"en"},{"id":8665,"adult":false,"title":"K-19: The Widowmaker","video":false,"overview":"When Russia's first nuclear submarine malfunctions on its maiden voyage, the crew must race to save the ship and prevent a nuclear disaster.","genre_ids":[18,36,53,9648,10752],"popularity":2.4333,"vote_count":1135,"poster_path":"/vImR0HQkJs7Xs2qgdXEUDeX49m0.jpg","release_date":"2002-07-19","vote_average":6.5,"backdrop_path":"/puleizXkdZrYW9641MZHj7IhAY4.jpg","original_title":"K-19: The Widowmaker","original_language":"en"},{"id":8680,"adult":false,"title":"The Shell Seekers","video":false,"overview":"Penelope Keeling, a sixty-four-year-old daughter of a famous artist, reflects on her life, and the fate and choices that defined it, when she arrives in the Mediterranean to stay with her headstrong daughter. Shifting through time, and falling into place like the pieces of a jigsaw, the truth of Penelope's rich, heartbreaking and surprising life unfolds.","genre_ids":[18,10749],"popularity":0.384,"vote_count":7,"poster_path":"/y7oxk0TY47vpJ1v2kcnYak0GKkX.jpg","release_date":"2007-10-18","vote_average":6.9,"backdrop_path":"/3OqHYx2QlUQxbXx6TsCAenICQd7.jpg","original_title":"The Shell Seekers","original_language":"en"},{"id":8696,"adult":false,"title":"Calendar Girls","video":false,"overview":"Members of a Yorkshire branch of the Women's Institute cause controversy when they pose nude for a charity calendar.","genre_ids":[18,35],"popularity":3.2174,"vote_count":397,"poster_path":"/yy2cPwrnUquMCmShrf8TbYu6emd.jpg","release_date":"2003-09-02","vote_average":6.531,"backdrop_path":"/mB23ce4CxfUwSb9Y6YY8NPLyy2E.jpg","original_title":"Calendar Girls","original_language":"en"},{"id":661475,"adult":false,"title":"Apinan vuosi","video":false,"overview":"A young student seeks direction in his life to counterbalance the studies through female adventures.","genre_ids":[18,35],"popularity":0.3868,"vote_count":2,"poster_path":"/2OnmxCt66lXG1MuSky901gwGruq.jpg","release_date":"1983-11-11","vote_average":7,"backdrop_path":"/7XvomNV2M9UqZEa87IRk69F441R.jpg","original_title":"Apinan vuosi","original_language":"fi"}],"external_ids":{"imdb_id":"t