https://www.themoviedb.org/movie/37004-fuga/watch?locale=TC","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"TT":{"link":"https://www.themoviedb.org/movie/37004-fuga/watch?locale=TT","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"UY":{"link":"https://www.themoviedb.org/movie/37004-fuga/watch?locale=UY","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"VE":{"link":"https://www.themoviedb.org/movie/37004-fuga/watch?locale=VE","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]}}},"wikidata_id":"Q5870778","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-25T22:46:50.523776+00:00","region":null,"main_poster":null,"images":{"logos":[],"posters":[{"width":1000,"height":1500,"file_path":"/8oZ0me8AFv3181yiIsVjXkH11Db.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":500,"height":750,"file_path":"/f2YNgbyvK3PHNCirIBopptRcZou.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/7d1NO9R1Py41N5LTefhlmOSas3L.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/xiTmVW5RyL00LBLqnmN1ge1hIdC.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:00:55.489+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":110,"tagline":"","homepage":"","overview":"Could a brilliant composer's music actually be killing his loved ones? Eliseo can't help but believe it when his younger sister dies tragically and then his pianist Georgina suddenly dies on the piano. Completely traumatized, Eliseo is taken to a mental hospital where he can find escape only through music."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":110,"tagline":"","homepage":"","overview":"Montalbán es un músico atrapado en una composición inconclusa. Siendo niño es testigo de la muerte de su hermana quien es asesinada sobre un piano, hecho en el cual se compone accidentalmente una melodía. Esto lo transforma en un músico obsesionado y mentalmente perturbado, atrapado por esa música: el compositor de una música mortal, vanguardista y codiciada. Años después, otro hombre intenta rescatar esa original sinfonía, sin saber los peligros que encierra tal hazaña. Ricardo Coppa es un músico mediocre y sin talento que pretende reconocimiento y éxito; un Salieri de todos los tiempos. Junto a un grupo de músicos emprende un viaje en búsqueda de Montalbán y su olvidada creación musical, con el objeto de transformar esa música en una composición propia. (FILMAFFINITY)"},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"פוגה","runtime":0,"tagline":"","homepage":"","overview":"אליסאו מונטלבאן הוא מוזיקאי מוכשר, שזיכרונות טראומטיים מילדותו הביאו אותו לידי מחלת נפש ואשפוז בבית חולים פסיכיאטרי. שם הוא יפגוש באורח חיים חדש ודמויות מוזרות וססגוניות. צוות של מוזיקאים מתחקה אחר מונטלבאן, בניסיון לגרום לו לשחזר את יצירתו ולהשלים אותה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":110,"tagline":"","homepage":"","overview":"Eliseo Montalbán (Benjamín Vicuña) è un giovane compositore che ha subito un trauma e nel quale - in seguito alla misteriosa morte della pianista durante la prima di un sua composizione - si risveglia la memoria della violenza che subì sua sorella, violentata e uccisa su un pianoforte, portandolo alla follia. Finisce così in un manicomio, scomparendo al mondo, finché un musicista mediocre, Ricardo Coppa (Gastón Pauls), nel tentativo di ricostruire la sua ultima composizione perduta, si mette alla sua ricerca."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"赋格曲","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"賦格曲","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":313922,"adult":false,"title":"Green Room","video":false,"overview":"A punk rock band is forced to fight for survival after witnessing an act of violence at a skinhead bar.","genre_ids":[27,80,53],"media_type":"movie","popularity":1.8088,"vote_count":2885,"poster_path":"/evZicaR7nXe4LiD9G6QYTorcJGO.jpg","release_date":"2016-04-15","vote_average":6.7,"backdrop_path":"/qRjahAq8JVoJBT2x18x2A01kxZT.jpg","original_title":"Green Room","original_language":"en"},{"id":164064,"adult":false,"title":"La búsqueda","video":false,"overview":"A family is taken hostage by a trio of criminals. The father is killed, and the daughter swears revenge.","genre_ids":[28,18],"media_type":"movie","popularity":1.7493,"vote_count":21,"poster_path":"/79TPLPMaRPVgOLwbEZrZLwlxjgn.jpg","release_date":"1985-09-19","vote_average":5.857,"backdrop_path":"/znYovh4ALjghAPfnkkbELWDbzcK.jpg","original_title":"La búsqueda","original_language":"es"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":19.7563,"vote_count":11387,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":264660,"adult":false,"title":"Ex Machina","video":false,"overview":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl.","genre_ids":[18,878],"media_type":"movie","popularity":7.7588,"vote_count":14041,"poster_path":"/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg","release_date":"2015-01-21","vote_average":7.573,"backdrop_path":"/uqOuJ50EtTj7kkDIXP8LCg7G45D.jpg","original_title":"Ex Machina","original_language":"en"},{"id":11324,"adult":false,"title":"Shutter Island","video":false,"overview":"World War II soldier-turned-U.S. Marshal Teddy Daniels investigates the disappearance of a patient from a hospital for the criminally insane, but his efforts are compromised by troubling visions and a mysterious doctor.","genre_ids":[18,53,9648],"media_type":"movie","popularity":14.6244,"vote_count":25458,"poster_path":"/nrmXQ0zcZUL8jFLrakWc90IR8z9.jpg","release_date":"2010-02-14","vote_average":8.2,"backdrop_path":"/8xt8AMb1OKC63AdhNSaYBWxB4Iq.jpg","original_title":"Shutter Island","original_language":"en"},{"id":297222,"adult":false,"title":"PK","video":false,"overview":"A stranger in the city asks questions no one has asked before. Known only by his initials, the man's innocent questions and childlike curiosity take him on a journey of love, laughter and letting go.","genre_ids":[35,18,878],"media_type":"movie","popularity":6.4022,"vote_count":1122,"poster_path":"/z2x2Y4tncefsIU7h82gmUM5vnBJ.jpg","release_date":"2014-12-18","vote_average":7.698,"backdrop_path":"/gxfvtq5eYiClS2X7hxAAPBNrbWA.jpg","original_title":"पीके","original_language":"hi"},{"id":19995,"adult":false,"title":"Avatar","video":false,"overview":"In the 22nd century, a paraplegic Marine is dispatched to the moon Pandora on a unique mission, but becomes torn between following orders and protecting an alien civilization.","genre_ids":[28,12,14,878],"media_type":"movie","popularity":31.5771,"vote_count":33506,"poster_path":"/gKY6q7SjCkAU6FqvqWybDYgUKIF.jpg","release_date":"2009-12-16","vote_average":7.6,"backdrop_path":"/vL5LR6WdxWPjLPFRLe133jXWsh5.jpg","original_title":"Avatar","original_language":"en"},{"id":565770,"adult":false,"title":"Blue Beetle","video":false,"overview":"Recent college grad Jaime Reyes returns home full of aspirations for his future, only to find that home is not quite as he left it. As he searches to find his purpose in the world, fate intervenes when Jaime unexpectedly finds himself in possession of an ancient relic of alien biotechnology: the Scarab.","genre_ids":[28,878,12],"media_type":"movie","popularity":7.4075,"vote_count":3024,"poster_path":"/mXLOHHc1Zeuwsl4xYKjKh2280oL.jpg","release_date":"2023-08-16","vote_average":6.646,"backdrop_path":"/3H9NA1KWEQN0ItL3Wl3SFZYP6yV.jpg","original_title":"Blue Beetle","original_language":"en"},{"id":293660,"adult":false,"title":"Deadpool","video":false,"overview":"The origin story of former Special Forces operative turned mercenary Wade Wilson, who, after being subjected to a rogue experiment that leaves him with accelerated healing powers, adopts the alter ego Deadpool. Armed with his new abilities and a dark, twisted sense of humor, Deadpool hunts down the man who nearly destroyed his life.","genre_ids":[28,12,35],"media_type":"movie","popularity":14.6236,"vote_count":32389,"poster_path":"/3E53WEZJqP6aM84D8CckXx4pIHw.jpg","release_date":"2016-02-09","vote_average":7.622,"backdrop_path":"/en971MEXui9diirXlogOrPKmsEn.jpg","original_title":"Deadpool","original_language":"en"},{"id":245891,"adult":false,"title":"John Wick","video":false,"overview":"Ex-hitman John Wick comes out of retirement to track down the gangsters that took everything from him.","genre_ids":[28,53],"media_type":"movie","popularity":9.7043,"vote_count":20492,"poster_path":"/wXqWR7dHncNRbxoEGybEy7QTe9h.jpg","release_date":"2014-10-22","vote_average":7.454,"backdrop_path":"/ff2ti5DkA9UYLzyqhQfI2kZqEuh.jpg","original_title":"John Wick","original_language":"en"},{"id":24428,"adult":false,"title":"The Avengers","video":false,"overview":"When an unexpected enemy emerges and threatens global safety and security, Nick Fury, director of the international peacekeeping agency known as S.H.I.E.L.D., finds himself in need of a team to pull the world back from the brink of disaster. Spanning the globe, a daring recruitment effort begins!","genre_ids":[878,28,12],"media_type":"movie","popularity":50.5441,"vote_count":36095,"poster_path":"/RYMX2wcKCBAr24UyPD7xwmjaTn.jpg","release_date":"2012-04-25","vote_average":7.951,"backdrop_path":"/pGFQCp12a8andfPlpnmXz44IIvY.jpg","original_title":"The Avengers","original_language":"en"},{"id":332872,"adult":false,"title":"Julieta","video":false,"overview":"The film spans 30 years in Julieta’s life from a nostalgic 1985 where everything seems hopeful, to 2015 where her life appears to be beyond repair and she is on the verge of madness.","genre_ids":[18,10749],"media_type":"movie","popularity":1.5435,"vote_count":906,"poster_path":"/z4aErD1RQQ3alpu3PoUu408HEVc.jpg","release_date":"2016-04-08","vote_average":6.986,"backdrop_path":"/yG8iQi4gX0tjUBAvMNsliES3Czy.jpg","original_title":"Julieta","original_language":"es"},{"id":389,"adult":false,"title":"12 Angry Men","video":false,"overview":"The defense and the prosecution have rested and the jury is filing into the jury room to decide if a young Spanish-American is guilty or innocent of murdering his father. What begins as an open and shut case soon becomes a mini-drama of each of the jurors' prejudices and preconceptions about the trial, the accused, and each other.","genre_ids":[18],"media_type":"movie","popularity":12.4833,"vote_count":9765,"poster_path":"/ow3wq89wM8qd5X7hWKxiRfsFf9C.jpg","release_date":"1957-04-10","vote_average":8.556,"backdrop_path":"/w4bTBXcqXc2TUyS5Fc4h67uWbPn.jpg","original_title":"12 Angry Men","original_language":"en"},{"id":150540,"adult":false,"title":"Inside Out","video":false,"overview":"When 11-year-old Riley moves to a new city, her Emotions team up to help her through the transition. Joy, Fear, Anger, Disgust and Sadness work together, but when Joy and Sadness get lost, they must journey through unfamiliar places to get back home.","genre_ids":[16,10751,12,18,35],"media_type":"movie","popularity":16.5969,"vote_count":23188,"poster_path":"/2H1TmgdfNtsKlU9jKdeNyYL5y8T.jpg","release_date":"2015-06-17","vote_average":7.9,"backdrop_path":"/o3i6AfTcWAuNvzAUV3q5lOmi6Gx.jpg","original_title":"Inside Out","original_language":"en"},{"id":68718,"adult":false,"title":"Django Unchained","video":false,"overview":"With the help of a German bounty hunter, a freed slave sets out to rescue his wife from a brutal Mississippi plantation owner.","genre_ids":[18,37],"media_type":"movie","popularity":13.7776,"vote_count":27605,"poster_path":"/7oWY8VDWW7thTzWh3OKYRkWUlD5.jpg","release_date":"2012-12-25","vote_average":8.187,"backdrop_path":"/s4cJQaj40SwMifUrrdtdOJsjnRO.jpg","original_title":"Django Unchained","original_language":"en"},{"id":634649,"adult":false,"title":"Spider-Man: No Way Home","video":false,"overview":"Peter Parker is unmasked and no longer able to separate his normal life from the high-stakes of being a super-hero. When he asks for help from Doctor Strange the stakes become even more dangerous, forcing him to discover what it truly means to be Spider-Man.","genre_ids":[28,12,878],"media_type":"movie","popularity":25.0407,"vote_count":21600,"poster_path":"/1g0dhYtq4irTY1GPXvft6k4YLjm.jpg","release_date":"2021-12-15","vote_average":7.932,"backdrop_path":"/nqUThBjou0TAWXu93Q4SNFpgqai.jpg","original_title":"Spider-Man: No Way Home","original_language":"en"},{"id":44214,"adult":false,"title":"Black Swan","video":false,"overview":"A committed dancer struggles to maintain her sanity after winning the lead role in a production of Tchaikovsky's \"Swan Lake\".","genre_ids":[18,53,27],"media_type":"movie","popularity":7.786,"vote_count":15339,"poster_path":"/viWheBd44bouiLCHgNMvahLThqx.jpg","release_date":"2010-12-03","vote_average":7.7,"backdrop_path":"/g0geLM1zXpLb9mpqKw1ePcA5bTJ.jpg","original_title":"Black Swan","original_language":"en"},{"id":105,"adult":false,"title":"Back to the Future","video":false,"overview":"Eighties teenager Marty McFly is accidentally sent back in time to 1955, inadvertently disrupting his parents' first meeting and attracting his mother's romantic interest. Marty must repair the damage to history by rekindling his parents' romance and - with the help of his eccentric inventor friend Doc Brown - return to 1985.","genre_ids":[12,35,878],"media_type":"movie","popularity":18.5525,"vote_count":21420,"poster_path":"/vN5B5WgYscRGcQpVhHl6p9DDTP0.jpg","release_date":"1985-07-03","vote_average":8.324,"backdrop_path":"/qskzmLTbarKnXDbo2HRj4NJ3vcW.jpg","original_title":"Back to the Future","original_language":"en"},{"id":157336,"adult":false,"title":"Interstellar","video":false,"overview":"The adventures of a group of explorers who make use of a newly discovered wormhole to surpass the limitations on human space travel and conquer the vast distances involved in an interstellar voyage.","genre_ids":[12,18,878],"media_type":"movie","popularity":43.1132,"vote_count":38958,"poster_path":"/gEU2QniE6E77NI6lCU6MxlNBvIx.jpg","release_date":"2014-11-05","vote_average":8.467,"backdrop_path":"/2ssWTSVklAEc98frZUQhgtGHx7s.jpg","original_title":"Interstellar","original_language":"en"},{"id":152532,"adult":false,"title":"Dallas Buyers Club","video":false,"overview":"Loosely based on the true-life tale of Ron Woodroof, a drug-taking, women-loving, homophobic man who in 1986 was diagnosed with HIV/AIDS and given thirty days to live.","genre_ids":[18,36],"media_type":"movie","popularity":3.966,"vote_count":8926,"poster_path":"/7Fdh7gUq3plvQqxRbNYhWvDABXA.jpg","release_date":"2013-11-01","vote_average":7.918,"backdrop_path":"/sbVKj98cq0FztCukzu47bu0H8o7.jpg","original_title":"Dallas Buyers Club","original_language":"en"}],"similar_content":[{"id":108,"adult":false,"title":"Three Colors: Blue","video":false,"overview":"The wife of a famous composer survives a car accident that kills her husband and daughter. Now alone, she shakes off her old identity and explores her newfound freedom but finds that she is unbreakably bound to other humans, including her husband’s mistress, whose existence she never suspected.","genre_ids":[18],"popularity":2.8713,"vote_count":1852,"poster_path":"/33wsWxzsNstI8N7dvuwzFmj1qBd.jpg","release_date":"1993-09-08","vote_average":7.641,"backdrop_path":"/nAyUVvcdOKHmukdgGHZ7xR5er1q.jpg","original_title":"Trois couleurs : Bleu","original_language":"fr"},{"id":279,"adult":false,"title":"Amadeus","video":false,"overview":"Disciplined Italian composer Antonio Salieri becomes consumed by jealousy and resentment towards the hedonistic and remarkably talented young Salzburger composer Wolfgang Amadeus Mozart.","genre_ids":[36,10402,18],"popularity":4.656,"vote_count":4654,"poster_path":"/gQRfiyfGvr1az0quaYyMram3Aqt.jpg","release_date":"1984-09-19","vote_average":8.022,"backdrop_path":"/4i3Amppd6eW5Qkhjv4gdHk3CCoE.jpg","original_title":"Amadeus","original_language":"en"},{"id":1590,"adult":false,"title":"Copying Beethoven","video":false,"overview":"A fictionalised exploration of Beethoven's life in his final days working on his Ninth Symphony. It is 1824. Beethoven is racing to finish his new symphony. However, it has been years since his last success and he is plagued by deafness, loneliness and personal trauma. A copyist is urgently needed to help the composer. A fictional character is introduced in the form of a young conservatory student and aspiring composer named Anna Holtz. The mercurial Beethoven is skeptical that a woman might become involved in his masterpiece but slowly comes to trust in Anna's assistance and in the end becomes quite fond of her. By the time the piece is performed, her presence in his life is an absolute necessity. Her deep understanding of his work is such that she even corrects mistakes he has made, while her passionate personality opens a door into his private world.","genre_ids":[18],"popularity":0.6683,"vote_count":180,"poster_path":"/xplAbPXhZF9B3H4OnhjQsEKUESe.jpg","release_date":"2006-09-10","vote_average":6.425,"backdrop_path":"/7b3cLZjiOIR8pqjnF2g2GkBwcZ4.jpg","original_title":"Copying Beethoven","original_language":"en"},{"id":2054,"adult":false,"title":"Mr. Holland's Opus","video":false,"overview":"In 1965, passionate musician Glenn Holland takes a day job as a high school music teacher, convinced it's just a small obstacle on the road to his true calling: writing a historic opus. As the decades roll by with the composition unwritten but generations of students inspired through his teaching, Holland must redefine his life's purpose.","genre_ids":[18,10402],"popularity":0.9919,"vote_count":441,"poster_path":"/kBmwWeSN3ajnYHZ3dSybEobxEPI.jpg","release_date":"1995-12-29","vote_average":6.954,"backdrop_path":"/oUptKQLatCgywVDx0ETVhq7knHt.jpg","original_title":"Mr. Holland's Opus","original_language":"en"},{"id":5723,"adult":false,"title":"Once","video":false,"overview":"A vacuum repairman moonlights as a street musician and hopes for his big break. One day a Czech immigrant, who earns a living selling flowers, approaches him with the news that she is also an aspiring singer-songwriter. The pair decide to collaborate, and the songs that they compose reflect the story of their blossoming love.","genre_ids":[18,10402,10749],"popularity":4.3474,"vote_count":1429,"poster_path":"/7nW363kSYRCkr4VGOMvuSGwtzKs.jpg","release_date":"2007-03-23","vote_average":7.415,"backdrop_path":"/p1XSyBriqz7oBWoVcRqYlB6Kve3.jpg","original_title":"Once","original_language":"en"},{"id":5123,"adult":false,"title":"August Rush","video":false,"overview":"Lyla and Louis, a singer and a musician, fall in love, but are soon compelled to separate. Lyla is forced to give up her newborn but unknown to her, he grows up to become a musical genius.","genre_ids":[10751,18,10402],"popularity":3.1193,"vote_count":2799,"poster_path":"/oA6ZeICPINiS6YtD5WZeBaGVmuT.jpg","release_date":"2007-11-21","vote_average":7.412,"backdrop_path":"/i3pONuqGZSR3UYOOdBeU2CiQnxj.jpg","original_title":"August Rush","original_language":"en"},{"id":1467402,"adult":false,"title":"Шум времени","video":false,"overview":"A biopic about Soviet composer Dmitry Shostakovich.","genre_ids":[18,36],"popularity":0.5869,"vote_count":0,"poster_path":null,"release_date":"2026-09-24","vote_average":0,"backdrop_path":null,"original_title":"Шум времени","original_language":"ru"},{"id":7550,"adult":false,"title":"Blueprint","video":false,"overview":"The story of the first cloned human being - told in her own words: At the age of thirty the world-famous composer Iris Sellin learns that she has an incurable illness. She - a person who wanted to live for ever - does however not give in. In order to preserve her art and also herself, beyond death, for all posterity, she has herself cloned. Her daughter Siri, whom, in this way, she turns into her virtual twin, learns as a child that she is the world's first cloned human being. In fact a blueprint: a blueprint of her mother. From that moment on nothing is as it was before...","genre_ids":[18,878],"popularity":0.5431,"vote_count":18,"poster_path":"/1FE5mDwSXw7h9HuB8fWgfJ83l3.jpg","release_date":"2003-12-08","vote_average":4.1,"backdrop_path":"/7v3Sqj0U9ee92JhJG1B9SE6p7yt.jpg","original_title":"Blueprint","original_language":"de"},{"id":1076708,"adult":false,"title":"Music by John Williams","video":false,"overview":"His unforgettable scores are an essential part of some of the most beloved movies of our time, over a career that spans decades. See and hear maestro John Williams' own story, with insights from filmmakers, musicians, and others he has inspired, complete with rare behind-the-scenes looks at the making of movie history.","genre_ids":[99,10402],"popularity":0.9311,"vote_count":78,"poster_path":"/dIZ3SzuT3YuAWX1fjdxDevbwQBX.jpg","release_date":"2024-11-01","vote_average":8.077,"backdrop_path":"/7jzCLnt5IDGDHhNAKTfbq1In4dM.jpg","original_title":"Music by John Williams","original_language":"en"},{"id":1069145,"adult":false,"title":"Santini's Network","video":false,"overview":"Santini's Network is a biographical film by German filmmaker Georg Brintrup on the life of Roman music collector Fortunato Santini and how his famous private assembly of manuscript scores grew into the greatest music collection of the age.","genre_ids":[18],"popularity":0.1491,"vote_count":0,"poster_path":"/qjkl0lKYwqvReBR2YUW9XFfFZAh.jpg","release_date":"2014-04-01","vote_average":0,"backdrop_path":"/qYGUI1SO4FzkzpgfBSsmuUAWcwW.jpg","original_title":"La Rete di Santini","original_language":"en"},{"id":475506,"adult":false,"title":"John Cage: I Have Nothing to Say and I Am Saying It","video":false,"overview":"This 56-minute documentary on America's most controversial and unique composer manages to cover a great many aspects of Cage's work and thought. His love for mushrooms, his Zen beliefs and use of the I Ching, and basic bio details are all explained intelligently and dynamically. Black Mountain, Buckminster Fuller, Rauschenberg, Duchamp are mentioned. Yoko Ono, John Rockwell, Laurie Anderson, Richard Kostelanetz make appearances. Fascinating performance sequences include Margaret Leng-Tan performing on prepared piano, Merce Cunningham and company, and performances of Credo In Us, Water Music, and Third Construction. Demystifies the man who made music from silence, from all sounds, from life.","genre_ids":[99,10402,10770],"popularity":0.1688,"vote_count":0,"poster_path":"/5L0VeyI51OCIIY9IqMHOzYtVlfv.jpg","release_date":"1990-09-18","vote_average":0,"backdrop_path":null,"original_title":"John Cage: I Have Nothing to Say and I Am Saying It","original_language":"en"},{"id":1539,"adult":false,"title":"No Songs of Love","video":false,"overview":"As Tobias, a young director, supposes that his girl-friend Ellen had an affair with his brother Markus, front man of \"Hansen\", one year ago, he decides to shoot a documentary about the band's next tour. When Ellen joins the project, everybody's emotions boil over, although they are observed all the time.","genre_ids":[10402,18,10749],"popularity":0.1889,"vote_count":14,"poster_path":"/jq1Pbm0SevZBTwUaIIDC5b8CE1i.jpg","release_date":"2005-10-26","vote_average":5.571,"backdrop_path":null,"original_title":"Keine Lieder über Liebe","original_language":"de"},{"id":3641,"adult":false,"title":"House of Ricordi","video":false,"overview":"The film covers a hundred years in the lives of the Ricordi family, the Milan publishing house of the title, and the various composers and other historic personalities, whose careers intersected with the growth of the Ricordi house. It beautifully draws the parallel between the great music of the composers, the historic and social upheavals of their times, as well as the \"smaller stories\" of the successive generations of Ricordi.","genre_ids":[36,18,10402],"popularity":0.2634,"vote_count":5,"poster_path":"/78XTNX7BYPbabBz2E76eMwVCbRp.jpg","release_date":"1954-12-01","vote_average":6.2,"backdrop_path":"/2ylxgaYO4SFignCK3iuT0zcRVhM.jpg","original_title":"Casa Ricordi","original_language":"it"},{"id":419,"adult":false,"title":"About the Looking for and the Finding of Love","video":false,"overview":"Director helmut Dietls and Patric Susskinds illustrate a legendary story of two lovers who cant keep themselves away from death.","genre_ids":[35,10749,18,10402],"popularity":0.228,"vote_count":17,"poster_path":"/eauZ3KLBcBejZDyXge5HoWJ6zwn.jpg","release_date":"2005-01-27","vote_average":4.3,"backdrop_path":"/yGTku4DYJ5BiVraUvP3tvTUuYiv.jpg","original_title":"Vom Suchen und Finden der Liebe","original_language":"de"},{"id":4459,"adult":false,"title":"Night Without Sleep","video":false,"overview":"Upon awaking in the morning, a man finds his thoughts clouded by the possibility that he committed a murder.","genre_ids":[9648,53,18],"popularity":0.3053,"vote_count":10,"poster_path":"/8tJ36codDm1DixT8DL23zYCppl4.jpg","release_date":"1952-09-26","vote_average":5.4,"backdrop_path":"/uRJYHrunUJZ5786H22HjqDCIInn.jpg","original_title":"Night Without Sleep","original_language":"en"},{"id":6693,"adult":false,"title":"Die Deutschmeister","video":false,"overview":"Young Stanzi who is visiting Vienna helps a young corporal and musician to become famous for his marching song \"Die Deutschmeister\".","genre_ids":[10749,35,10402],"popularity":0.5685,"vote_count":17,"poster_path":"/x3upr2JzyJui07hUu3fP9YV7cJS.jpg","release_date":"1955-08-11","vote_average":7,"backdrop_path":"/6KXyHEc6nbclGGlqDkd0CC5F4jG.jpg","original_title":"Die Deutschmeister","original_language":"de"},{"id":6619,"adult":false,"title":"Death in Venice","video":false,"overview":"Composer Gustav von Aschenbach travels to Venice for health reasons. There, he becomes obsessed with the stunning beauty of an adolescent Polish boy named Tadzio who is staying with his family at the same Grand Hôtel des Bains on the Lido as Aschenbach.","genre_ids":[18],"popularity":1.4771,"vote_count":527,"poster_path":"/s81SuFBSqY8T5Lrn5R8ucX8LKxi.jpg","release_date":"1971-03-05","vote_average":7.227,"backdrop_path":"/tyWnJeMatQGLsiLfLsxBV0pp9nk.jpg","original_title":"Morte a Venezia","original_language":"it"},{"id":280185,"adult":false,"title":"Rock N' Roll","video":false,"overview":"Chandramouli, an international drummer, goes to Chennai to help his friend in his new project. However, his life turns upside down when he falls in love with a playback singer.","genre_ids":[10402,10749],"popularity":0.1334,"vote_count":8,"poster_path":"/oZuP8j0CXtsTZg31AkdDaYx6uTP.jpg","release_date":"2007-11-16","vote_average":4,"backdrop_path":null,"original_title":"റോക്ക് N' റോള്‍","original_language":"ml"},{"id":473888,"adult":false,"title":"Ryuichi Sakamoto: Coda","video":false,"overview":"Oscar-winning composer Ryuichi Sakamoto weaves man-made and natural sounds together in his works. His anti-nuclear activism grew after the 2011 Fukushima disaster, and his career only paused after a 2014 cancer diagnosis.","genre_ids":[99,10402],"popularity":0.557,"vote_count":51,"poster_path":"/604KuuoYofIbYRjZZ8BUoq2f8NE.jpg","release_date":"2017-11-04","vote_average":7.4,"backdrop_path":"/xYb2xZXTmsf0MSV08jLEDXK4Fjc.jpg","original_title":"Ryuichi Sakamoto: Coda","original_language":"ja"},{"id":280004,"adult":false,"title":"The Great Waltz","video":false,"overview":"A musical based on the life and music of Johann Strauss, Jr.","genre_ids":[10402,18,10749],"popularity":0.3374,"vote_count":1,"poster_path":"/uvbt7jOkerMQ8uqlAumYp5GS41U.jpg","release_date":"1972-11-01","vote_average":5,"backdrop_path":"/3L1lgSajnnvq6lM7lYNp8ZRtLy2.jpg","original_title":"The Great Waltz","original_language":"en"}],"external_ids":{"imdb_id":"tt0442236","twitter_id":null,"facebook_id":null,"wikidata_id":"Q5870778","instagram_id":null,"mydramalist_id":"199048"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148485,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AR","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2007-03-01T00:00:00.000Z","certification":""}]},{"iso_3166_1":"AU","release_dates":[{"note":"Sydney Latin American Film Festival","type":1,"iso_639_1":"","descriptors":[],"re