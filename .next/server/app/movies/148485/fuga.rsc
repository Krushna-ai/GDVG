5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Fuga\",\"description\":\"Could a brilliant composer's music actually be killing his loved ones? Eliseo can't help but believe it when his younger sister dies tragically and then his pianist Georgina suddenly dies on the piano. Completely traumatized, Eliseo is taken to a mental hospital where he can find escape only through music.\",\"image\":\"https://image.tmdb.org/t/p/w500/8oZ0me8AFv3181yiIsVjXkH11Db.jpg\",\"datePublished\":\"2006-03-30\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CL\",\"inLanguage\":\"es\",\"genre\":[\"Drama\",\"Thriller\",\"Music\",null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.9,\"bestRating\":10,\"ratingCount\":21}}"}}],["$","$L10",null,{"initialDrama":{"id":"99d97034-52ba-400a-82f0-c4e4a6a24a52","tmdb_id":37004,"imdb_id":"tt0442236","content_type":"movie","title":"Fuga","original_title":"Fuga","overview":"Could a brilliant composer's music actually be killing his loved ones? Eliseo can't help but believe it when his younger sister dies tragically and then his pianist Georgina suddenly dies on the piano. Completely traumatized, Eliseo is taken to a mental hospital where he can find escape only through music.","poster_path":"/8oZ0me8AFv3181yiIsVjXkH11Db.jpg","backdrop_path":"/7d1NO9R1Py41N5LTefhlmOSas3L.jpg","release_date":"2006-03-30","first_air_date":null,"status":"published","original_language":"es","origin_country":["CL","AR"],"genres":[{"id":18,"name":"Drama"},{"id":53,"name":"Thriller"},{"id":10402,"name":"Music"},"musical film","drama film"],"popularity":3.9689,"vote_average":5.9,"vote_count":21,"runtime":110,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-25T22:46:50.523776+00:00","updated_at":"2026-02-25T22:46:50.351+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":21546,"name"