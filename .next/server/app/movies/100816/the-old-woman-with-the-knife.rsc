639_1":"en","vote_average":3.334},{"width":677,"height":346,"file_path":"/hFqrp3qaH9xHbF8NwMgNqGFcntk.png","iso_639_1":null,"vote_average":0},{"width":676,"height":345,"file_path":"/ooFYzdCO1LlkplwCpbYIeYKiRP1.png","iso_639_1":"zh","vote_average":0},{"width":1280,"height":462,"file_path":"/8sLjukZq9owOOeR7eHASef9ycZ8.png","iso_639_1":"ru","vote_average":0}],"posters":[{"width":1200,"height":1800,"file_path":"/wbmxnsv41vsg5UEaNDlf203dOWw.jpg","iso_639_1":"en","vote_average":10},{"width":1200,"height":1714,"file_path":"/tpeVnrdDmWy0QgWRyHb41QtW7gu.jpg","iso_639_1":"en","vote_average":5.786},{"width":2000,"height":3000,"file_path":"/csOuyd4HCHkm4pUi0A1Qa9MvtyK.jpg","iso_639_1":"de","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/n5AdPYD5DzVV5On2Ho6bnE4XHuQ.jpg","iso_639_1":"en","vote_average":3.334},{"width":1200,"height":1714,"file_path":"/p4q1HSDKZrAUcNMZQsZoFw1YEZz.jpg","iso_639_1":"en","vote_average":2.278},{"width":1000,"height":1500,"file_path":"/A9yJjkI7GdqeFYMyUe4PebA2NIw.jpg","iso_639_1":"ko","vote_average":2.278},{"width":1200,"height":1710,"file_path":"/88k4LdP9HGGVo1zWY1F0NL843En.jpg","iso_639_1":"en","vote_average":1.75},{"width":1200,"height":1714,"file_path":"/du65x58CJrMMThuiT85kBFMYi0Z.jpg","iso_639_1":"ko","vote_average":1.75},{"width":1382,"height":2048,"file_path":"/bSHMSpL7sfVBkByh1nDuKeSRK3E.jpg","iso_639_1":"en","vote_average":1.75},{"width":728,"height":1080,"file_path":"/Ak49yhRtzW0dotWnsvHoQsYzN6y.jpg","iso_639_1":"en","vote_average":1.75},{"width":2000,"height":3000,"file_path":"/rpZHW8XFAjn2CEtFMN2G3QQkpEU.jpg","iso_639_1":"en","vote_average":1.75},{"width":1000,"height":1500,"file_path":"/b4ENXcbwBnJqqhazu76MNb1l469.jpg","iso_639_1":"en","vote_average":1.75},{"width":1268,"height":1901,"file_path":"/1pCEEpLeoI1pbrJQJ6BLmXmvw3E.jpg","iso_639_1":"ko","vote_average":1.222},{"width":1143,"height":1714,"file_path":"/mE4yAadJcaDEoO8he1AoB0BP8E4.jpg","iso_639_1":"ko","vote_average":0.166},{"width":1000,"height":1500,"file_path":"/g9DxMc9M3JnQLjlUSlUL2UcAWFP.jpg","iso_639_1":"en","vote_average":0}],"backdrops":[{"width":3000,"height":1688,"file_path":"/fepnF3W4VP3s8ui8nDtrlsFVYwO.jpg","iso_639_1":null,"vote_average":3.334},{"width":1350,"height":760,"file_path":"/z1gPTU7mzQxZaKcdDJZ7m7MwV2z.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/qY9e6jrT08dDigLPeopbtwsjqEa.jpg","iso_639_1":"en","vote_average":3.334},{"width":3840,"height":2160,"file_path":"/g4s7Zveen1fTBcj5jyr9q8n6Tmo.jpg","iso_639_1":null,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/wr714prThlFfmaoq9bncPMUnxEn.jpg","iso_639_1":null,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/dusCZp37BFrCYePZ8qksAX0ocQW.jpg","iso_639_1":"en","vote_average":1.222},{"width":1500,"height":844,"file_path":"/heoiOSCT63ROdnVbCdgIo2lLQe9.jpg","iso_639_1":null,"vote_average":0},{"width":1500,"height":844,"file_path":"/BUKKtqvrHlnqYWMDJT2GRlB4Ls.jpg","iso_639_1":null,"vote_average":0},{"width":1500,"height":844,"file_path":"/mDHeGlQbEI7z8h6hrBUrZyjUo9f.jpg","iso_639_1":null,"vote_average":0},{"width":2627,"height":1478,"file_path":"/tul0Z7fKgMkzfNq0cRod8Lm2zzm.jpg","iso_639_1":null,"vote_average":0},{"width":2863,"height":1611,"file_path":"/ff6KG0zIcHAXZQV4mwJOzo7yfyB.jpg","iso_639_1":null,"vote_average":0},{"width":2700,"height":1519,"file_path":"/5uowINHFV9uSzBkbn8mC3q1k29L.jpg","iso_639_1":null,"vote_average":0},{"width":2048,"height":1152,"file_path":"/dIbmEAuhrbNZhheBMyn0E58Sv2Z.jpg","iso_639_1":null,"vote_average":0},{"width":2048,"height":1152,"file_path":"/nMX8MtXWAiDmwcHLU7vILlLoyze.jpg","iso_639_1":null,"vote_average":0},{"width":1365,"height":768,"file_path":"/sgMJ7uFcx9F5RFZoNQLcreflfAx.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T06:15:57.565+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":123,"tagline":"손을 내밀 것인가, 칼을 꽂을 것인가","homepage":"","overview":"40여 년간 감정 없이 바퀴벌레 같은 인간들을 방역해온 60대 킬러 조각. 대모님이라 불리며 살아있는 전설로 추앙받지만 점차 오랜 시간 몸담은 회사 신성방역에서조차도 한물간 취급을 받는다. 한편, 평생 조각을 쫓은 젊고 혈기 왕성한 킬러 투우는 신성방역의 일원이 되고 조각에게서 시선을 떼지 않는다. 지켜야 할 건 만들지 말자고 약속했던 조각은 여전한 실력에도 불구하고 상처를 입은 그날 밤, 자신을 치료해 준 수의사 강선생과 그의 딸에게 남다른 감정을 느낀다. 투우는 그런 낯선 조각의 모습에 분노가 폭발하는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"The Old Woman with the Knife","runtime":123,"tagline":"Now I see who you are.","homepage":"","overview":"Aging assassin Hornclaw has seen it all, but she never expected to mentor a reckless rookie like Bullfight. As their unlikely bond deepens, cracks form in the underworld they navigate together. When Hornclaw discovers someone wants her dead, she's thrust into a deadly game of deception. With enemies closing in and trust in short supply, survival means staying sharp—both blade and mind."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Старуха с ножом","runtime":125,"tagline":"","homepage":"","overview":"Легендарная наёмная убийца уже в преклонном возрасте занимается устранением отбросов общества. Её привычная жизнь неожиданно меняется, когда она знакомится с молодым киллером, который напрашивается к ней в напарники. Однако случай из общего прошлого заставляет женщину сомневаться, даже когда парень признаётся ей в том, что помнит её как единственного человека, отнёсшегося к нему по-доброму. Она не может его вспомнить и не понимает его истинных намерений. Возникшее недопонимание приводит к финальному поединку между героями."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"The Old Woman with the Knife","runtime":131,"tagline":"","homepage":"","overview":"Une tueuse vieillissante rencontre un jeune protégé désireux d'apprendre le métier."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"The Old Woman with the Knife","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Стара жінка з ножем","runtime":0,"tagline":"","homepage":"","overview":"Легендарна наймана вбивця вже в похилому віці займається очищенням суспільства від покидьків, коли молодий кілер напрошується до неї в напарниками."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"破果","runtime":104,"tagline":"","homepage":"","overview":"该片根据同名小说改编，讲述工作果断的60代女莎手「爪角」碰到了一位男性总是给她打造她人生中没有的东西，然后陷入苦恼的故事。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"聖母殺手","runtime":120,"tagline":"","homepage":"","overview":"傳奇殺手爪角以剷除社會敗類為宗旨，奉行「絕不能擁有要守護之物」的訓誡，雷厲風行、冷酷俐落，被江湖中人奉為「聖母」。然而年過六十的她，逐漸被長年效力的組織視為過氣殺手。一次行動受傷，她被姜醫師所救，卻意外勾起她內心深處的初心與羈絆，隨著這種脆弱的情感萌芽，爪角陷入了前所未有的危機！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Đại Mẫu","runtime":0,"tagline":"","homepage":"","overview":"Hornclaw, một sát thủ già từng trải, tưởng chừng đã nhìn thấu mọi mặt của thế giới ngầm, nhưng bà không ngờ rằng mình sẽ trở thành người dẫn dắt cho một tay lính mới liều lĩnh tên Bullfight. Khi mối quan hệ kỳ lạ giữa hai người dần sâu sắc, những rạn nứt trong thế giới ngầm mà họ hoạt động cũng bắt đầu lộ ra. Mọi thứ càng trở nên nguy hiểm khi Hornclaw phát hiện có kẻ đang muốn lấy mạng mình. Giữa vòng vây của kẻ thù và sự phản bội rình rập, để sống sót, bà buộc phải giữ cho lưỡi dao – và cả đầu óc – luôn sắc bén."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"The Old Woman with the Knife","runtime":125,"tagline":"","homepage":"","overview":"Die alternde Assassine Hornclaw hat schon alles gesehen, doch hätte sie nie erwartet, einmal die Mentorin eines rücksichtslosen Neulings wie Bullfight zu werden. Während ihre ungewöhnliche Bindung stärker wird, bilden sich Risse in der Unterwelt, durch die sie gemeinsam navigieren. Als Hornclaw entdeckt, dass jemand ihren Tod will, wird sie in ein tödliches Täuschungsspiel hineingezogen. Da die Feinde immer näher kommen und Vertrauen Mangelware ist, bedeutet Überleben, scharfsinnig zu bleiben – sowohl mit der Klinge als auch mit dem Verstand."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"הזקנה עם הסכין","runtime":0,"tagline":"","homepage":"","overview":"מתנקשת מזדקנת בשם הורנקלו ראתה כבר הכול, אבל לא ציפתה להפוך למנטורית של טירון פזיז כמו בולפייט. ככל שהקשר הבלתי צפוי ביניהם מעמיק, מתחילות להיווצר סדקים בעולם התחתון שבו הם פועלים יחד. כאשר הורנקלו מגלה שמישהו רוצה במותה, היא נשאבת למשחק קטלני של תחבולות ובגידות. עם אויבים שסוגרים עליה ואמון שהולך ואוזל, הדרך היחידה לשרוד היא להישאר חדה – בלהב ובשׂכל."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"The Old Woman with the Knife","runtime":125,"tagline":"","homepage":"","overview":"De bejaarde huurmoordenaar Hornclaw heeft het allemaal meegemaakt, maar ze had nooit verwacht dat ze een roekeloze beginneling als Bullfight zou begeleiden. Naarmate hun onwaarschijnlijke band sterker wordt, ontstaan ​​er scheuren in de onderwereld waar ze samen doorheen navigeren. Wanneer Hornclaw ontdekt dat iemand haar dood wil, belandt ze in een dodelijk spel van bedrog. Met vijanden die op de loer liggen en een gebrek aan vertrouwen, betekent overleven dat je scherp moet blijven – zowel met je mes als met je verstand."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"聖母殺手","runtime":0,"tagline":"","homepage":"","overview":"傳奇殺手「爪角」（李慧英 飾），以剷除社會敗類為宗旨，冷酷無情、行事俐落是她的風格，黑暗世界中將她奉為「聖母」。年過六十的爪角，逐漸被長年效力的組織「新星防疫」視為過氣殺手。某天，她教訓了才剛加入組織、桀傲不遜又氣焰高張的新秀殺手「鬥牛」（金聖喆 飾）；從此鬥牛將她視為眼中釘，監視、跟蹤、挑釁並對她窮追不捨，讓爪角備感壓力。\r 遵循師父「柳」（金武烈 飾）立下「絕不能擁有要守護之物」訓誡的爪角，一直過著深居簡出、獨來獨往的日子。一次行動受傷後，她被路過的「姜醫師」（延玗臻 飾）救回一命，意外勾起了內心深處的初心與羈絆。然而，這種脆弱的情感將讓她陷入前所未有的絕境，生命中的最後一戰即將展開！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Μια γηραιά δολοφόνος με ταλέντο στο να εξοντώνει τους χειρότερους ανθρώπους της κοινωνίας συναντά μια νεαρή προστατευόμενη που είναι πρόθυμη να μάθει το επάγγελμα. Καθώς δημιουργούν έναν απρόσμενο δεσμό, η βετεράνος δολοφόνος ανακαλύπτει ένα νέο σκοπό στα τελευταία χρόνια της βίας και της ρουτίνας της."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Staruszka z nożem","runtime":0,"tagline":"","homepage":"","overview":"Starzejąca się zabójczyni Hornclaw widziała już wszystko, ale nigdy nie spodziewała się, że będzie mentorką lekkomyślnego nowicjusza, takiego jak Bullfight. W miarę jak ich nietypowa więź się pogłębia, w podziemnym świecie pojawiają się pęknięcia, po których wspólnie się poruszają. Kiedy Hornclaw odkrywa, że ​​ktoś chce jej śmierci, zostaje wciągnięta w śmiertelnie niebezpieczną grę podstępu. Z wrogami nacierającymi na nią z każdej strony i ograniczonym zaufaniem, przetrwanie wymaga skupienia się – zarówno na ostrzu, jak i na umyśle."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"A Velha Com a Faca","runtime":123,"tagline":"","homepage":"","overview":"A assassina envelhecida Hornclaw viu tudo, mas ela nunca esperava orientar um novato imprudente como Bullfight. À medida que seu vínculo improvável se aprofunda, rachaduras se formam no submundo em que eles navegam juntos. Quando Hornclaw descobre que alguém a quer morta, ela é empurrada para um jogo mortal de engano. Com os inimigos se aproximando e confiando na falta de oferta, sobreviver significa permanecer afiada - tanto a lâmina quanto a mente."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"O asasină în vârstă, care se pricepe să-i elimine pe cei mai răi din societate, întâlnește un tânăr dornic să învețe meserie. Pe măsură ce formează o legătură improbabilă, ucigașa veterană descoperă un nou scop după atâția ani de violență și rutină."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Egy idősödő bérgyilkos, aki ért a társadalom legrosszabbjainak kiiktatásához, találkozik egy fiatal pártfogoltjával, aki szívesen megtanulná a szakmát. Miközben valószínűtlen kötelék alakul ki közöttük, a veterán gyilkos új célt talál az erőszak és a rutin alkonyán.  (Szarka Károly)"},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"La anciana con el cuchillo","runtime":0,"tagline":"","homepage":"","overview":"A sus 65 años, Hornclaw es una legendaria asesina que empieza a sentir el peso del tiempo. Mientras su cuerpo falla y considera el retiro, se ve acechada por un joven sicario sediento de venganza y por un inesperado despertar de su propia humanidad que pone en peligro su última misión."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"La anciana con el cuchillo","runtime":0,"tagline":"","homepage":"","overview":"A sus 65 años, Hornclaw es una legendaria asesina que empieza a sentir el peso del tiempo. Mientras su cuerpo falla y considera el retiro, se ve acechada por un joven sicario sediento de venganza y por un inesperado despertar de su propia humanidad que pone en peligro su última misión."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"}],"reviews_tmdb":[{"id":"68bb7f144e058dc0fe9bfbd5","url":"https://www.themoviedb.org/review/68bb7f144e058dc0fe9bfbd5","author":"MovieGuys","content":"$11","created_at":"2025-09-06T00:23:48.331Z","updated_at":"2025-09-08T22:38:01.128Z","author_details":{"name":"","rating":8,"username":"MovieGuys","avatar_path":null}}],"recommendations":[{"id":1127110,"adult":false,"title":"Diablo","video":false,"overview":"Ex-con Kris Chaney seizes the daughter of a Colombian gangster to fulfill a noble promise to the young girl's mother. When her father enlists both the criminal underworld and a psychotic killer to exact his revenge, Kris relies on everything he's ever learned to stay alive and keep his word.","genre_ids":[28,53,80],"media_type":"movie","popularity":8.6465,"vote_count":199,"poster_path":"/uFQduVyYIinJy3eLjozgfl6Xtcn.jpg","release_date":"2025-06-13","vote_average":7.3,"backdrop_path":"/5AB4EfS39K7aQYtUim0CFfKBU6r.jpg","original_title":"Diablo","original_language":"en"},{"id":1267319,"adult":false,"title":"Mantis","video":false,"overview":"The secret society of contract killers falls into chaos, unleashing a new breed of assassins. With old rules in ruins, who dares claim the shadows?","genre_ids":[28,80,53],"media_type":"movie","popularity":8.5497,"vote_count":140,"poster_path":"/pzsXKLJsZ26HUV1oCMa7WiFFQbW.jpg","release_date":"2025-09-25","vote_average":6.25,"backdrop_path":"/yOFqBpJ0PEkBdQqalDEaeOiaKbz.jpg","original_title":"사마귀","original_language":"ko"},{"id":928480,"adult":false,"title":"Monster Summer","video":false,"overview":"When a mysterious force begins to disrupt their big summer fun, Noah and his friends team up with a retired police detective to embark on a monstrous adventure to save their island.","genre_ids":[12,14,9648,27],"media_type":"movie","popularity":2.3446,"vote_count":151,"poster_path":"/zD2UZkh0DwbDEMuOKIR7jgwgulZ.jpg","release_date":"2024-10-04","vote_average":6.263,"backdrop_path":"/sJL9R7V1VZcB7i6so6zrQSfYrWa.jpg","original_title":"Monster Summer","original_language":"en"},{"id":1469823,"adult":false,"title":"The Pact","video":false,"overview":"Yoon Ji-hee played with the ouija board in childhood. As she grew, she sank deeper into the occult using ritual to change her appearance, manipulate events, enchant people - her ultimate aim: to rule Korea. Meanwhile, Kim Seok-il, a sturdy presidential candidate, is being investigated by a journalist who discovers things best kept hidden.","genre_ids":[18,9648,27],"media_type":"movie","popularity":0.4507,"vote_count":7,"poster_path":"/7N1A0ZhfJLO9hIS92neHr6wRVyl.jpg","release_date":"2025-06-02","vote_average":5.8,"backdrop_path":"/8JHYkBAeyo8KsVaBpbxBvN56K3G.jpg","original_title":"신명","original_language":"ko"},{"id":804370,"adult":false,"title":"Arco","video":false,"overview":"10-year-old Arco lives in a far future. During his first flight in his rainbow suit, he loses control and falls into the past. Iris, a girl his age from 2075, comes to his rescue and tries by all means to help send him back to his era.","genre_ids":[16,878,12,14,10751],"media_type":"movie","popularity":4.5132,"vote_count":70,"poster_path":"/62PDjxO03RhZ4SDB5pwEvjWT8Nz.jpg","release_date":"2025-10-22","vote_average":7.8,"backdrop_path":"/jFKbhV0uFZuA3K73UJIq1dzisCi.jpg","original_title":"Arco","original_language":"fr"},{"id":1372605,"adult":false,"title":"I Heart Willie","video":false,"overview":"A psychopathic man lures his friends into a deadly mouse trap, where pure evil aims to harvest their skin and take on the form of the beloved cartoon character he once helped create. This chilling origin story reveals the dark side behind the most cherished animated figure of modern times.","genre_ids":[27],"media_type":"movie","popularity":0.2323,"vote_count":10,"poster_path":"/72QrUmBW4NBbtIj9BnqEZ4KJHTp.jpg","release_date":"2025-02-26","vote_average":4.7,"backdrop_path":"/bnpmZwfFuDhwqaBD7hyZeSUpR4n.jpg","original_title":"I Heart Willie","original_language":"en"},{"id":1476453,"adult":false,"title":"Kirot","video":false,"overview":"A conservative woman, engaged to her high school sweetheart, receives a life-saving heart transplant. But as she recovers, unexpected passions and desires begin to surface, pulling her into a world that threatens the life and identity she thought she wanted.","genre_ids":[18],"media_type":"movie","popularity":2.0104,"vote_count":2,"poster_path":"/l1vVrAs2dtxiSYnD1f5G8iFc6UH.jpg","release_date":"2025-09-30","vote_average":5.5,"backdrop_path":"/