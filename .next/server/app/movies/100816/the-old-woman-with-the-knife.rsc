th":"/kbEZKyMET9fbbB7oq5voHnc3ozB.jpg","release_date":"1985-01-01","vote_average":7,"backdrop_path":"/hanQ3ecNARGD9uDMzjiSepo8TqF.jpg","original_title":"Albert","original_language":"sk"},{"id":589992,"adult":false,"title":"Hlídač č. 47","video":false,"overview":"A young village shopkeeper, Ferda Zuska, wants to jump in front of a train because his girlfriend has married someone else. At the last moment, he is saved by the railway guard Douša and his wife Anna. Ferda soon forgets his sadness and starts courting Anna. The unsuspecting Douša is the laughing stock of the whole village. Moreover, during Ferda's rescue, he slipped on the embankment, injured himself, and has had difficulty hearing since then. One day, he even discovers with horror that he has gone completely deaf and that he must therefore leave his job...","genre_ids":[18],"popularity":0.7943,"vote_count":1,"poster_path":"/ujztgEgdvFfidR3UPvWMC08Q5e.jpg","release_date":"1937-12-03","vote_average":7,"backdrop_path":null,"original_title":"Hlídač č. 47","original_language":"cs"},{"id":947992,"adult":false,"title":"Zlaté rybičky","video":false,"overview":"","genre_ids":[18,80,10770],"popularity":1.3262,"vote_count":4,"poster_path":null,"release_date":"1979-05-19","vote_average":4,"backdrop_path":null,"original_title":"Zlaté rybičky","original_language":"cs"},{"id":591242,"adult":false,"title":"Divoch","video":false,"overview":"","genre_ids":[10749,18],"popularity":2.8601,"vote_count":2,"poster_path":null,"release_date":"1936-08-04","vote_average":5,"backdrop_path":null,"original_title":"Divoch","original_language":"cs"},{"id":591273,"adult":false,"title":"Fear Street: 1994","video":false,"overview":"After a series of brutal slayings, a teen and her friends take on an evil force that's plagued their notorious town for centuries.","genre_ids":[27,9648],"popularity":2.616,"vote_count":2573,"poster_path":"/9J9Wy39ZjrVmfk7yMkulpcI5sy0.jpg","release_date":"2021-06-28","vote_average":6.694,"backdrop_path":"/vu5Y8qFq