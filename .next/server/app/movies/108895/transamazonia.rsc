9:{"metadata":[["$","title","0",{"children":"Transamazonia | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Rebecca, the daughter of missionary Lawrence Byrne, was declared a “miracle” after she survived a plane crash as a child, deep in the Amazon Forest. Years later, Rebecca, who became a famous healer in the region, and her father find themselves embroiled in an escalating conflict when illegal loggers invade the land belonging to the indigenous people they are evangelizing."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/108895/transamazonia"}],["$","meta","5",{"property":"og:title","content":"Transamazonia"}],["$","meta","6",{"property":"og:description","content":"Rebecca, the daughter of missionary Lawrence Byrne, was declared a “miracle” after she survived a plane crash as a child, deep in the Amazon Forest. Years later, Rebecca, who became a famous healer in the region, and her father find themselves embroiled in an escalating conflict when illegal loggers invade the land belonging to the indigenous people they are evangelizing."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/108895/transamazonia"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/zHV02lJqwmYMqxZeezaQk1mwCTL.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Transamazonia"}],["$","meta","12",{"name":"twitter:description","content":"Rebecca, the daughter of missionary Lawrence Byrne, was declared a “miracle” after she survived a plane crash as a child, deep in the Amazon Forest. Years later, Rebecca, who became a famous healer in the region, and her father find themselves embroiled in an escalating conflict when illegal loggers invade the land belonging to the indigenous people they are evangelizing."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/zHV02lJqwmYMqxZeezaQk1mwCTL.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L12","15",{}]],"error":null,"digest":"$undefined"}
