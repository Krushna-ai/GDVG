"width":977,"height":115,"file_path":"/buFOQImKUjrTNpzLwXKH4UV7nmv.png","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":8.496,"vote_average":0}],"posters":[{"width":2000,"height":3000,"file_path":"/A5oEQOVW4bwj5r76fdO2gPeFymH.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":500,"height":750,"file_path":"/384wl9E5zCoh1ebrlgS6aXubi3E.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":500,"height":750,"file_path":"/uzMBxfaRllUwPazFo0wjqlireCm.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":1280,"height":1785,"file_path":"/6V5rUvf4wqqkqsJGPIleOAx7Qn2.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":2,"aspect_ratio":0.717,"vote_average":1.75},{"width":900,"height":1255,"file_path":"/gB2wiF9ssNe006HpiHUqW8DyCsy.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.717,"vote_average":0},{"width":1200,"height":1800,"file_path":"/1gRdyOV9F6M6Sq4lcBdMwM4h9IZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1200,"height":1800,"file_path":"/32bQFVCMpxN4NN6qNyUqhqcJyTn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":2048,"height":1152,"file_path":"/ifAa0cKTTGGLCaHg65FceG5e4d0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":2801,"height":1576,"file_path":"/JLm1nRqzh8yjbzimGKa16ZFjGn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.777,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/fAXlzA0WKfu7iSdfqseGjHbWu5z.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/6eMTFjCwGMraTqv6zID8CZVgahY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/7d5na6d9oUSdzQ9MKE3s76IUDfI.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/lA0pVloqcWfHtW1Vtn1CSMveIJf.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/jLvqNeJfzaj4TEh9WFIrplg4U88.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T03:56:20.217+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":103,"tagline":"Never stop searching","homepage":"http://www.bowfinger.es/en/perdida/","overview":"A policewoman whose childhood friend disappeared in Patagonia years ago starts a new search to find answers, and soon finds her own life in danger."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":90,"tagline":"Tercera parte de la trilogía \"Los crímenes del sur\".","homepage":"","overview":"Catorce años atrás, durante un viaje de estudios, una adolescente, Cornelia Villalba, se escapa con sus compañeras para ir a bailar y se pierde en el medio de los bosques patagónicos. Nunca más se supo de ella. Hoy, Manuela Pelari, su mejor amiga, decide usar sus herramientas de mujer policía para emprender una nueva búsqueda. Impulsada por el desacato y la necesidad imperiosa de ponerle fin a años de silencio y de vínculos rotos, se enfrenta con un poder que amenaza con convertirla en una pieza más de un engranaje que puede costarle la vida."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"הנערה הנעדרת","runtime":0,"tagline":"","homepage":"","overview":"שוטרת (לואיסנה לופילטו) שחברת הילדות שלה נעלמה בפטגוניה לפני שנים, חוזרת אל הפרשה ההיא בניסיון למצוא תשובות – ומגלה שחייה נמצאים בסכנה"},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Perdida - Scomparsa","runtime":0,"tagline":"","homepage":"","overview":"In cerca di risposte sull’amica d'infanzia scomparsa in Patagonia anni prima, una poliziotta avvia nuove ricerche, mettendo ben presto a rischio la sua vita."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Zaginiona","runtime":103,"tagline":"","homepage":"","overview":"Policjantka, której przyjaciółka z dzieciństwa wiele lat temu zaginęła w Patagonii, na nowo rozpoczyna poszukiwania. Wkrótce jej życiu zaczyna grozić niebezpieczeństwo."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":86,"tagline":"Nunca dejes de buscar.","homepage":"","overview":"Catorce años atrás, durante un viaje de estudios, una adolescente, Cornelia Villalba, se escapa con sus compañeras para ir a bailar y se pierde en el medio de los bosques patagónicos. Nunca más se supo de ella. Hoy, Manuela Pelari, su mejor amiga, decide usar sus herramientas de mujer policía para emprender una nueva búsqueda. Impulsada por el desacato y la necesidad imperiosa de ponerle fin a años de silencio y de vínculos rotos, se enfrenta con un poder que amenaza con convertirla en una pieza más de un engranaje que puede costarle la vida."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Αγνοούμενη","runtime":0,"tagline":"","homepage":"","overview":"Η εξαφάνιση της Κορνήλια που συνέβη πριν από 14 χρόνια έρχεται και πάλι στο προσκήνιο μετά από κάποια περίεργα γεγονότα. Μια αστυνομικός η οποία ήταν κολλητή φίλη με την Κορνήλια αποφασίζει να ανοίξει και πάλι την υπόθεση που δεν έπαψε ποτέ να την στοιχειώνει. Θα αναγκαστεί να έρθει αντιμέτωπη με το παρελθόν της, ενώ μια μεγάλη έκπληξη την περιμένει. Βασισμένο σε νουβέλα."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Desaparecida","runtime":103,"tagline":"","homepage":"","overview":"Anos depois de sua melhor amiga de escola desaparecer na Patagônia, uma policial volta à região decidida a solucionar o caso. Mas, desta vez, é sua vida que corre perigo."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":103,"tagline":"","homepage":"","overview":"Une policière dont l'amie d'enfance a disparu en Patagonie des années auparavant entreprend de nouvelles recherches en quête de réponses... au péril de sa vie."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"En kvinnlig polis påbörjar en ny jakt efter svar på varför hennes barndomsvän försvann i Patagonien för många år sedan, och snart svävar hennes liv i fara."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Потерянная","runtime":107,"tagline":"","homepage":"","overview":"Фильм основан на романе Флоренции Этчевеш «Корнелия», в котором пойдет о учителе из престижной школы в Буэнос-Айресе совершает поездку с пятью ее учениками, но возвращается только с четырьмя, потому что один из них таинственно исчезает."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"네가 없는 시간","runtime":0,"tagline":"","homepage":"","overview":"경찰인 마누엘라는 종결된 사건에 뛰어든다. 피해자는 단짝이었던 코르넬리아. 14년 전 실종된 친구는 어디로 사라졌을까. 위험한 과거가 그녀를 수렁에 빠뜨린다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Kayboluş","runtime":0,"tagline":"","homepage":"","overview":"Arjantin’in Başkentindeki prestijli bir okulda bir ögretmen 5 ögrencisi ile çalışma gezisine çıkarlar.Ancak 4 ögrencisiyle dönüş yapmak zorunda kalır çünkü Patagonya ormanlarında diğer ögrenci kaybolur."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":103,"tagline":"","homepage":"","overview":"Een lerares van een prestigieuze school in Buenos Aires maakt met 5 van haar studenten een studietrip in Patagonië maar komt terug met maar 4 studenten, omdat eentje mysterieus verdwijnt. Het is Cornelia Villalba, die er vandoor is gegaan tijdens het dansen in de bossen van Patagonië."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Az elveszett","runtime":103,"tagline":"","homepage":"","overview":"Argentin bűnügyi film. Főhősnője egy nyomozónő, akinek évekkel ezelőtt Patagóniában eltűnt egy régi barátja. Megpróbálja kideríteni az igazságot, közben ő is életveszélyes helyzetbe kerül."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"科妮莉亚","runtime":103,"tagline":"","homepage":"","overview":"本片基于弗洛伦西亚埃切夫斯的小说《科妮莉亚》改编，讲述一位来自布宜诺斯艾利斯的名校老师和五名学生进行了一次学习旅行，其中一个叫科妮莉亚·维拉尔巴的学生神秘失踪，据说，她和同伴们相约一起去跳舞，结果在巴塔哥尼亚森林中走失...."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Perdida [verloren]","runtime":0,"tagline":"","homepage":"","overview":"Die junge Manuela \"Pipa\" Pelari blickt als Kind, von ihrem Fenster hinab auf die fruchtlosen Untersuchungen und Ermittlungen nach dem Verschwinden ihrer Freundin Cornelia. Auf Drängen Claras, Cornelias Mutter, begibt sie sich Jahre später, mittlerweile als erwachsene Polizistin, selbst auf die Suche nach ihrer ehemaligen Freundin. Bald findet sie heraus, dass ihre Ermittlungen nun ihr eigenes Leben in Gefahr bringen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Anos após o desaparecimento da sua amiga na Patagónia, uma mulher polícia inicia uma investigação para obter repostas, mas depressa percebe que a sua vida corre perigo."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"失われた少女","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"สาบสูญ","runtime":0,"tagline":"","homepage":"","overview":"เมื่อหลายปีก่อน เพื่อนสมัยเด็กของตำรวจหญิงคนหนึ่งหายตัวไปในปาตาโกเนีย เธอเริ่มต้นค้นหาคำตอบอีกครั้ง และไม่นานก็พบว่าชีวิตของเธอกำลังตกอยู่ในอันตราย"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"那天後","runtime":0,"tagline":"","homepage":"","overview":"一名女警的兒時玩伴多年前在巴塔哥尼亞失蹤。她重啟搜索，尋找真相，但很快就發現自己的性命危在旦夕。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":290544,"adult":false,"title":"Sunstrokes","video":false,"overview":"A group of girlfriends gather almost every day to sunbathe in the terrace of a building, in an age where getting the perfect tan was everything.","genre_ids":[35],"media_type":"movie","popularity":0.1671,"vote_count":21,"poster_path":"/uYkB3aliTWlVp2wmQsSQJdzAglx.jpg","release_date":"2014-09-18","vote_average":5.9,"backdrop_path":"/zCp3YFHghmygvqb6eBa1s1gexaL.jpg","original_title":"Las insoladas","original_language":"es"},{"id":499925,"adult":false,"title":"Animal","video":false,"overview":"Antonio Decoud is a conservative family man who is forced by destiny to face an unexpected situation that shakes him to the core, scrambling up his life and his priorities, pushing him to forget his beliefs and his way of understanding life and follow the most basic instinct: the animal instinct.","genre_ids":[53,18],"media_type":"movie","popularity":0.4061,"vote_count":44,"poster_path":"/dL44SbXxd4arcHeM7KiukuVmeIm.jpg","release_date":"2018-05-24","vote_average":6.42,"backdrop_path":"/4xaSUkSjvojI0mvIMk2Zs881d7I.jpg","original_title":"Animal","original_language":"es"},{"id":326904,"adult":false,"title":"Dorami & Doraemons: Robot School's Seven Mysteries","video":false,"overview":"It is time for Doraemon's younger sister - Dorami-chan to graduate from the Robot School. But a mysterious wind sucks Doraemon and the principal away. Dorami escapes, and finds Doraemon's Good Friend Telepathy Card. This is a device Doraemon uses to communicate with his friends—collectively known as The Doraemons.","genre_ids":[16],"media_type":"movie","popularity":0.826,"vote_count":12,"poster_path":"/2KdnqaPGxXc6PpoSrg6aWdrD02b.jpg","release_date":"1996-03-02","vote_average":7.167,"backdrop_path":"/r3ckyiKJqhE5tRQT4uASEhgs9M6.jpg","original_title":"ドラミ＆ドラえもんズ ロボット学校七不思議！？","original_language":"ja"},{"id":490453,"adult":false,"title":"Framed By My Fiancé","video":false,"overview":"Daniel, a brilliant lawyer who is about to become one of the state's youngest judges, is driving with his fiancé Jenny when they hit another car. She wakes up to learn the other driver is dead and she's being charged with manslaughter. Before help arrived on the scene, Daniel shifted Jenny to the driver's seat to hide his culpability. Desperate to get her life back, Jenny sets out to convince the vengeful dead driver's wife that she's innocent--only to realize that Daniel is determined to keep the truth secret.","genre_ids":[53,10770],"media_type":"movie","popularity":0.3179,"vote_count":22,"poster_path":"/9wnL6AKbqWMxWHcBQUfj3JhQ6WH.jpg","release_date":"2017-11-27","vote_average":6.6,"backdrop_path":"/y9bwTkrQTjwvv1kBvYWACnQ1tDN.jpg","original_title":"Framed By My Fiancé","original_language":"en"},{"id":469950,"adult":false,"title":"Music When The Lights Go Out","video":false,"overview":"A documentary floating on this thin border between fiction and reality. An author comes to a small city in Brazil’s countryside, to turn Emelyn’s life into a fictional narrative. The more the author teases Emelyn with cameras, the more she becomes Bernard, a teenager boy divided between living the desire and continuing desiring.","genre_ids":[99],"media_type":"movie","popularity":0.089,"vote_count":15,"poster_path":"/hJA1Nj9aSxJaH7vFQ9U6SV8RxEG.jpg","release_date":"2016-08-18","vote_average":6.3,"backdrop_path":"/znWkAJkudv1NlT0VZTiWyJtzxXC.jpg","original_title":"Música para Quando as Luzes Se Apagam","original_language":"pt"},{"id":185738,"adult":false,"title":"Stockholm","video":false,"overview":"The story of the encounter between a boy and a girl. He confesses that he fell in love with her at first sight, but she does not believe him. However, as they walk through the night in Madrid, they share their desires, secrets, and maybe a few little lies. But soon the film brings us back to the harsh reality of power struggles, psychological games and conflicts between the sexes. Stockholm thus offers an incredible reading of the relations between young people today.","genre_ids":[18,10749],"media_type":"movie","popularity":0.3862,"vote_count":117,"poster_path":"/72Kl7ve97Uwrgjnpia30VzfwtFM.jpg","release_date":"2013-04-25","vote_average":6.244,"backdrop_path":"/ijpvcY138IqXIYLadDEp8Pe186g.jpg","original_title":"Stockholm","original_language":"es"},{"id":468362,"adult":false,"title":"The Angel","video":false,"overview":"True story of Ashraf Marwan, who was President Nasser's son-in-law and special adviser and confidant to his successor Anwar Sadat - while simultaneously Israeli Intelligence's most precious asset of the 20th century. Based on NYT bestselling book 'The Angel: The Egyptian Spy Who Saved Israel' by Uri Bar-Joseph.","genre_ids":[28,18,36,53,10752],"media_type":"movie","popularity":1.1122,"vote_count":324,"poster_path":"/d5vBixJD1coOvHvr8N2pbyffxFU.jpg","release_date":"2018-05-15","vote_average":6.579,"backdrop_path":"/hrPM6KM36D0NhcEGL9t76tHG2XP.jpg","original_title":"The Angel","original_language":"en"},{"id":254905,"adult":false,"title":"Manglehorn","video":false,"overview":"AJ Manglehorn is an aging, ordinary guy in a small town. He nurses his sick cat, squeezes out a conversation with the local bank teller every Friday, and eats at the same place every day.  But there is more to Manglehorn than meets the eye: he’s an ex-con who, 40 years ago, gave up the woman of his dreams for a big ‘job’. After a dramatic effort to start over, Manglehorn faces a terrifying moment and is unmasked as a guy with a very, very dark past.","genre_ids":[18],"media_type":"movie","popularity":31.4737,"vote_count":221,"poster_path":"/ms27YhpvgE5b0JIwaNiWw6EDC8g.jpg","release_date":"2015-06-03","vote_average":5.41,"backdrop_path":"/gWIyXGdzd2s1OFSXEa199EPQ92S.jpg","original_title":"Manglehorn","original_language":"en"},{"id":768447,"adult":false,"title":"Motherly","video":false,"overview":"Kate and her daughter Beth live alone in an isolated farmhouse in the woods, but when Kate slowly begins to suspect that something sinister is happening, her motherly instincts are put to the test.","genre_ids":[53,27],"media_type":"movie","popularity":1.6953,"vote_count":57,"poster_path":"/wmh1likQEetSLIUs5MAvfWjEayY.jpg","release_date":"2022-08-04","vote_average":6.053,"backdrop_path":"/ugZbX5lKx4L9ONEu0WTNbR96J0t.jpg","original_title":"Motherly","original_language":"en"},{"id":9310,"adult":false,"title":"American Dreamz","video":false,"overview":"The new season of \"American Dreamz,\" the wildly popular television singing contest, has captured the country's attention, as the competition looks to be between a young Midwestern gal and a showtunes-loving young man from Orange County. Recently awakened President Staton even wants in on the craze, as he signs up for the potential explosive season finale.","genre_ids":[35,18],"media_type":"movie","popularity":1.7091,"vote_count":311,"poster_path":"/qwRbRvfJR7jjsaGfS741Tl3DRr7.jpg","release_date":"2006-03-04","vote_average":5.029,"backdrop_path":"/mVwHzPqOi5QlviMSDsOy0nEyicI.jpg","original_title":"American Dreamz","original_language":"en"},{"id":239459,"adult":false,"title":"No Half Measures: Creating the Final Season of Breaking Bad","video":false,"overview":"A documentary about the making of season five of the acclaimed AMC series Breaking Bad.","genre_ids":[99],"media_type":"movie","popularity":1.333,"vote_count":121,"poster_path":"/ApitDfnYDwFNOPfyVuhW5ElWzhe.jpg","release_date":"2013-11-26","vote_average":8.372,"backdrop_path":"/27JyB13Wr2KEVUIKjtw9x669I39.jpg","original_title":"No Half Measures: Creating the Final Season of Breaking Bad","original_language":"en"},{"id":620883,"adult":false,"title":"Intuition","video":false,"overview":"Police officer Pipa works on her first big case while simultaneously investigating her boss, who is suspected of murder. The prequel to \"Perdida\".","genre_ids":[53,80],"media_type":"movie","popularity":0.5851,"vote_count":188,"poster_path":"/m2rJGjlesDKxugl7ypW8n3Mipjl.jpg","release_date":"2020-05-28","vote_average":6.197,"backdrop_path":"/prnq2ONhqo9Tga7dOMZKgFJMofs.jpg","original_title":"La corazonada","original_language":"es"},{"id":360055,"adult":false,"title":"Riot","video":false,"overview":"Copper Jack Stone purposefully orchestrates a bank robbery in order to be thrown into prison with the notorious Russian kingpin Balam. Balam is more than just a mob criminal; he's a very cunning and dangerous lord who controls the police force from behind bars. Balam lives in prison as a cover for his real power, which is King of the city. His cell is a lavish private room built specifically for him, inaccessible to most in the depths of the prison structure. Even the warden fears venturing into his area of the prison. However, even surrounded by his loyal henchmen and guards in his sectioned off fortress, Balam doesn't know Jack is coming for him to avenge his family, who Balam murdered in cold blood. Balam is tough... but Jack is tougher.","genre_ids":[28],"media_type":"movie","popularity":1.0729,"vote_count":193,"poster_path":"/5Q2pHzDfJ8QlUA2vx2yAXWJkof7.jpg","release_date":"2015-09-27","vote_average":5.6,"backdrop_path":"/9RFhoU6z6g0jJWjPlVJlZv7987N.jpg","original_title":"Riot","original_language":"en"},{"id":397442,"adult":false,"title":"Win It All","video":false,"overview":"A gambling addict faces a conflict when entrusted with keeping a bunch of money that isn't his.","genre_ids":[35],"media_type":"movie","popularity":0.4989,"vote_count":271,"poster_path":"/aEc69JY0azD9PwYtwS2RFwoyFOT.jpg","release_date":"2017-03-11","vote_average":5.685,"backdrop_path":"/aRQWgjhP0ECCgBgZJHIet8lVChD.jpg","original_title":"Win It All","original_language":"en"},{"id":124470,"adult":false,"title":"Exists","video":false,"overview":"A group of friends venture into the remote Texas woods for a party weekend and find themselves stalked by Bigfoot.","genre_ids":[27],"media_type":"movie","popularity":1.1573,"vote_count":379,"poster_path":"/m3BteJOJcbEI3pDgrZ1Fguy0ndV.jpg","release_date":"2014-03-17","vote_average":5.512,"backdrop_path":"/m9xwvflfh4hpjmlSapeDx2h9RCP.jpg","original_title":"Exists","original_language":"en"},{"id":394723,"adult":false,"title":"The Red Thread","video":false,"overview":"Seven years after their first infatuated encounter, Abril and Manuel meet again. Despite the fact that they are both married, it is soon apparent that their attraction has only grown.","genre_ids":[18,10749],"media_type":"movie","popularity":0.9867,"vote_count":193,"poster_path":"/iqOovsJWgh7zYeNMUfOc4Xxxhrn.jpg","release_date":"2016-05-19","vote_average":6.666,"backdrop_path":"/5IHPxCeflw0dSRHtAQibQpypWcz.jpg","original_title":"El hilo rojo","original_language":"es"},{"id":538858,"adult":false,"title":"Tumbbad","video":false,"overview":"India, 1918. On the outskirts of Tumbbad, a cursed village where it always rains, Vinayak, along with his mother and his brother, care of a mysterious old woman who keeps the secret of an ancestral treasure that Vinayak gets obsessed with.","genre_ids":[14,27],"media_type":"movie","popularity":1.3298,"vote_count":313,"poster_path":"/z1xOCxw780WFJC5uCTMfCkQ4Agi.jpg","release_date":"2018-10-12","vote_average":7.564,"backdrop_path":"/v4Rvu6BMup3uecXgLjKmxO9SkxK.jpg","original_title":"तुम्बाड","original_language":"hi"},{"id":340176,"adult":false,"title":"Tag","video":false,"overview":"As the sole survivor of a horrendous and rather mysterious accident, teenage Mitsuko's day is off to a bad start. An unstoppable force of nature, a doomed field trip, and a strange case of amnesia easily coexist in a bizarre parallel universe, where a desperate Mitsuko is always on the run from something inexplicable, intangible, and utterly deadly. However, amid piles of fresh corpses, mounds of scorching bullet shells, and rivulets of fragrant adolescent blood, Mitsuko must fight to stay alive, before her already messed-up day becomes even stranger. But one question still remains: who or what is the enemy?","genre_ids":[27,28],"media_type":"movie","popularity":3.8761,"vote_count":393,"poster_path":"/1xqQv9PoOIVX4nHlKVQELaAHyvG.jpg","release_date":"2015-05-11","vote_average":6.483,"backdrop_path":"/rch5tr1bpNyfeRJxARoU7I2a9KR.jpg","original_title":"リアル鬼ごっこ","original_language":"ja"},{"id":611395,"adult":false,"title":"Double World","video":false,"overview":"Keen to bring honor to his clan, young villager Dong Yilong embarks on a perilous journey to compete in a tournament that selects warriors for battle.","genre_ids":[28,12,14],"media_type":"movie","popularity":1.4434,"vote_count":248,"poster_path":"/lv3RonWge4GlC9ymNzC0oWpFCfv.jpg","release_date":"2020-07-21","vote_average":6.724,"backdrop_path":"/90yhXKTDNfaV7JnC7RcTpZcRTGC.jpg","original_title":"征途","original_language":"zh"},{"id":520318,"adult":false,"title":"Fatima","video":false,"overview":"In 1917, outside the parish of Fátima, Portugal, a 10-year-old girl and her two younger cousins witness multiple visitations of the Virgin Mary, who tells them that only prayer and suffering will bring an end to World War I.  As secularist government officials and Church leaders try to force the children to recant their story, word of the sighting spreads across the country, inspiring religious pilgrims to flock to the site in hopes of witnessing a miracle..","genre_ids":[18],"media_type":"movie","popularity":3.7667,"vote_count":192,"poster_path":"/lfA46pZbk4kxIaQvHyBPq0KH84Q.jpg","release_date":"2020-08-13","vote_average":7.2,"backdrop_path":"/jrsB8tChsAFTQilhsS8fxNTuear.jpg","original_title":"Fatima","original_language":"en"}],"similar_content":[{"id":8055,"adult":false,"title":"The Reader","video":false,"overview":"The story of Michael Berg, a German lawyer who, as a teenager in the late 1950s, had an affair with an older woman, Hanna, who then disappeared only to resurface years later as one of the defendants in a war crimes trial stemming from her actions as a concentration camp guard late in the war. He alone realizes that Hanna is illiterate and may be concealing that fact at the expense of her freedom.","genre_ids":[18,10749],"popularity":3.1528,"vote_count":3329,"poster_path":"/r0WURbmnhgKeBpHcpDULBgRedQM.jpg","release_date":"2008-12-10","vote_average":7.466,"backdrop_path":"/waMGsUEoHfYj3A1uRMUUgpBa71d.jpg","original_title":"The Reader","original_language":"en"},{"id":470691,"adult":false,"title":"Esmeralda","video":false,"overview":"It was the first film version of the Hunchback of Notre Dame.","genre_ids":[18],"popularity":1.8091,"vote_count":1,"poster_path":"/yPohMvllKNZoDNd7ODCsBsXkWZM.jpg","release_date":"1905-12-01","vote_average":3,"backdrop_path":null,"original_title":"Esmeralda","original_language":"fr"},{"id":277296,"adult":false,"title":"Vice and Virtue","video":false,"overview":"1944 : Occupied France. Juliette (Vice) is Wehrmacht General Bamberg's mistress and enjoys a privileged life. Her younger sister  Justine (Virtue) is about to marry Jean who is in the Resistance and come to Juliette for help. Both sisters end up at \"la Commanderie\", where Juliette becomes SS Colonel Schonberg's mistress and Justine is detained with other pretty girls who must satisfy the sexual needs of high-ranking nazi officials. Inspired by \"Justine ou les infortunes de la vertu\" by the marquis de Sade","genre_ids":[18,35],"popularity":0.1858,"vote_count":14,"poster_path":"/4s6aUGjsjP3FkiC98HzWmXvA0FR.jpg","release_date":"1963-03-01","vote_average":5.4,"backdrop_path":"/zK30zKTI5QqXK43GGO73NH3d72m.jpg","original_title":"Le Vice et la Vertu","original_language":"fr"},{"id":8092,"adult":false,"title":"This Boy's Life","video":false,"overview":"When a son and mother move to Seattle in hopes for a better life, the mother meets a seemingly polite man. Things go south when the man turns out to be abusive, endangering their lives. As the mother struggles to maintain hope in an impossible situation, the son has plans to escape.","genre_ids":[18],"popularity":1.8552,"vote_count":1056,"poster_path":"/pRMSZfen1Cv1eqwDbtxCBpBqxnU.jpg","release_date":"1993-04-09","vote_average":7.125,"backdrop_path":"/6N6VUUR1gzbCkiGpQzvRREv3Od1.jpg","original_title":"This Boy's Life","original_language":"en"},{"id":661539,"adult":false,"title":"A Complete Unknown","video":false,"overview":"New York, early 1960s. Against the backdrop of a vibrant music scene and tumultuous cultural upheaval, an enigmatic 19-year-old from Minnesota arrives in the West Village with his guitar and revolutionary talent, destined to change the course of American music.","genre_ids":[18,10402],"popularity":5.1723,"vote_count":1369,"poster_path":"/llWl3GtNoXosbvYboelmoT459NM.jpg","release_date":"2024-12-25","vote_average":7.081,"backdrop_path":"/kcCy5tKTe6WepVQ6SQaSewpmoCj.jpg","original_title":"A Complete Unknown","original_language":"en"},{"id":8512,"adult":false,"title":"Devil in a Blue Dress","video":false,"overview":"In late 1940s Los Angeles, Easy Rawlins is an unemployed black World War II veteran with few job prospects. At a bar, Easy meets DeWitt Albright, a mysterious white man looking for someone to investigate the disappearance of a missing white woman named Daphne Monet, who he suspects is hiding out in one of the city's black jazz clubs. Strapped for money and facing house payments, Easy takes the job, but soon finds himself in over his head.","genre_ids":[53,80,9648],"popularity":3.0907,"vote_count":444,"poster_path":"/5lcJhwKGavLbPva17QkTBhLfqEk.jpg","release_date":"1995-09-29","vote_average":6.45,"backdrop_path":"/n6SFCz0OsyZ800ZSlaD5WpNmqCj.jpg","original_title":"Devil in a Blue Dress","original_language":"en"},{"id":8289,"adult":false,"title":"Gorky Park","video":false,"overview":"Police Inspector Renko tries to solve the case of three bodies found in Moscow's Gorky Park but finds his attempts to solve the crime impeded by his superiors. Working on his own, Renko seeks out more information and stumbles across a conspiracy involving the highest levels of the government.","genre_ids":[53,80,18,9648],"popularity":1.315,"vote_count":334,"poster_path":"/xQFH7XlMk8pLPDzK5XVEj5McsRm.jpg","release_date":"1983-12-15","vote_average":6.323,"backdrop_path":"/dO8qUkabhQwBy8lPGawtvWQkdKd.jpg","original_title":"Gorky Park","original_language":"en"},{"id":8326,"adult":false,"title":"Holes","video":false,"overview":"After being wrongfully convicted for stealing a pair of shoes, Stanley Yelnats is sent away to Camp Green Lake, a boys detention facility where inmates are forced to dig holes all day in the hot desert sun as a form of character building. But Stanley and the other boys start to unravel a mystery, linked with the camps tough-as-nails warden —and possibly Stanley’s family itself.","genre_ids":[12,10751,18,35],"popularity":3.73,"vote_count":1509,"poster_path":"/o2Dm2mcE1qW8vT0bpsJO5OMBbqa.jpg","release_date":"2003-04-18","vote_average":6.895,"backdrop_path":"/cVMK2k0Wbs8DV3IK5sS4ziVenrI.jpg","original_title":"Holes","original_language":"en"},{"id":8619,"adult":false,"title":"Master and Commander: The Far Side of the World","video":false,"overview":"After an abrupt and violent encounter with a French warship inflicts severe damage upon his ship, a captain of the British Royal Navy begins a chase over two oceans to capture or destroy the enemy, though he must weigh his commitment to duty and ferocious pursuit of glory against the safety of his devoted crew, including the ship's thoughtful surgeon, his best friend.","genre_ids":[12,18,10752]