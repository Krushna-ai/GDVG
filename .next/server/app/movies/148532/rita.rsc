5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Rita\",\"description\":\"Rita, who finds herself alone when husband Ariel works abroad. They both find solace and sexual satisfaction in other people. When Ariel comes back, they both act like nothing happened. But will this keep their marriage from falling apart?\",\"image\":\"https://image.tmdb.org/t/p/w500/pXENxAzOBrTSDJGxDcUnlNTNmWr.jpg\",\"datePublished\":\"2024-03-22\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"PH\",\"inLanguage\":\"tl\",\"genre\":[\"Drama\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6,\"bestRating\":10,\"ratingCount\":20}}"}}],["$","$L10",null,{"initialDrama":{"id":"474d1d34-22ac-4170-910e-04572ba8db3c","tmdb_id":1241752,"imdb_id":"tt31589922","content_type":"movie","title":"Rita","original_title":"Rita","overview":"Rita, who finds herself alone when husband Ariel works abroad. They both find solace and sexual satisfaction in other people. When Ariel comes back, they both act like nothing happened. But will this keep their marriage from falling apart?","poster_path":"/pXENxAzOBrTSDJGxDcUnlNTNmWr.jpg","backdrop_path":"/5AsIFZ2AJC7JcGpq40aRPuRuaRc.jpg","release_date":"2024-03-22","first_air_date":null,"status":"published","original_language":"tl","origin_country":["PH"],"genres":[{"id":18,"name":"Drama"}],"popularity":11.71,"vote_average":6,"vote_count":20,"runtime":113,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-25T23:29:05.019279+00:00","updated_at":"2026-02-25T23:29:04.854+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":149142,"name":"Vivamax","logo_path":"/25oYoXHsfWYlddAzJSBReajN3BM.png","origin_country":"PH"}],"production_countries":[{"name":"Philippines","iso_3166_1":"PH"}],"spoken_languages":[{"name":"","iso_639_1":"tl","english_name":"Tagalog"}],"networks":[],"last_air_date":null,"