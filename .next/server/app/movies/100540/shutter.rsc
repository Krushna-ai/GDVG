","rent":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3}],"flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}],"link":"https://www.themoviedb.org/movie/17111/watch?locale=ZA","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}]}}},"wikidata_id":"Q1519981","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"TH","main_poster":"/igBvzh5ro0ySISCMUesLQsAweeY.jpg","images":{"logos":[{"width":3194,"height":1014,"file_path":"/6Y9Uv6SaScPcoBdKC5XGdjHP4ey.png","iso_639_1":"en","vote_average":3.334},{"width":1272,"height":402,"file_path":"/5Rru3tJF4Mybe5vcHI1CtJyNApY.png","iso_639_1":"en","vote_average":0},{"width":2554,"height":1070,"file_path":"/qmwMPfncioWaP86XmK1leJfSwJt.png","iso_639_1":"th","vote_average":0},{"width":2130,"height":1275,"file_path":"/iCw66eqCdkjiDzj4gPeCvTXY3ux.png","iso_639_1":"zh","vote_average":0},{"width":3191,"height":1428,"file_path":"/v4KcyEhRrwBXBFfpnXAmTZmhTcK.png","iso_639_1":"zh","vote_average":0}],"posters":[{"width":900,"height":1283,"file_path":"/igBvzh5ro0ySISCMUesLQsAweeY.jpg","iso_639_1":"ko","vote_average":3.334},{"width":820,"height":1200,"file_path":"/t9bG1SOCHHVidLI746RyJKqY4AG.jpg","iso_639_1":"es","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/yu46FT4rrxUEG0SyzQnYUbMYIsg.jpg","iso_639_1":"zh","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/c73npKeocy779c6zmXjkfJehV2Q.jpg","iso_639_1":"th","vote_average":3.334},{"width":1433,"height":2048,"file_path":"/uhmfeYO0LtWHz3TScV1BRER0JqS.jpg","iso_639_1":"th","vote_average":3.334},{"width":1433,"height":2048,"file_path":"/rhruRisYPlIhXO9khRr44De05aE.jpg","iso_639_1":"th","vote_average":3.334},{"width":1433,"height":2048,"file_path":"/8BGNT8K3ZUX0gL9nNP6WpeehF1A.jpg","iso_639_1":"th","vote_average":3.334},{"width":1753,"height":2471,"file_path":"/beLbI3dd3fH2maPrpKsJnoCrdtJ.jpg","iso_639_1":"es","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/7Tq7SrB14r3WpjJQOldbDHQk89J.jpg","iso_639_1":null,"vote_average":2.542},{"width":2000,"height":3000,"file_path":"/zUyaVtyugDaDHtOC6kCMJhbZsWu.jpg","iso_639_1":"en","vote_average":2.542},{"width":600,"height":900,"file_path":"/cO7OUF6onXboXm0jcAOx5n0oWRw.jpg","iso_639_1":"en","vote_average":1.75},{"width":666,"height":999,"file_path":"/wC4RbWzn8ZDCZYJWEo8cz1Wj5ra.jpg","iso_639_1":"en","vote_average":1.75},{"width":737,"height":1000,"file_path":"/jBTPePTg5LbDLyj8KdQEb6C0KDS.jpg","iso_639_1":"en","vote_average":0.166},{"width":1000,"height":1426,"file_path":"/mCAdGU8YWqgPXND2xTI632mbZNs.jpg","iso_639_1":"en","vote_average":0.166},{"width":1067,"height":1600,"file_path":"/p8FKENSDgjUP8CJSVbQ4kdHQvjq.jpg","iso_639_1":"en","vote_average":0.166}],"backdrops":[{"width":1280,"height":720,"file_path":"/A60vJDDv3idUAW3wDmeM7rnt7EJ.jpg","iso_639_1":"en","vote_average":3.334},{"width":3840,"height":2160,"file_path":"/cX48taTcXP2oGXPvka8QFa4f4Qb.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/pt03n9myD99YAN7Ffzq8cxFyJjh.jpg","iso_639_1":null,"vote_average":2.278},{"width":3840,"height":2160,"file_path":"/kyVSY4kJcC7ThHE6hQFXxtyaLJv.jpg","iso_639_1":null,"vote_average":1.75},{"width":2048,"height":1152,"file_path":"/iAV22HP3mO9xY1h0HfNu9A7VUPU.jpg","iso_639_1":null,"vote_average":1.434},{"width":1280,"height":720,"file_path":"/hr6Wrk7vjIUUYIY7kxqmWmI4XKu.jpg","iso_639_1":"en","vote_average":0.166},{"width":3840,"height":2160,"file_path":"/l5YdK5aBmbYbuO05XcC7fCNgepW.jpg","iso_639_1":null,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/wR40Z265TP5QD3yrumgOsrcS5Sw.jpg","iso_639_1":"en","vote_average":0},{"width":1280,"height":720,"file_path":"/aeuI0bkf1tQcnvp1qmwrs3bfn5g.jpg","iso_639_1":"en","vote_average":0},{"width":1280,"height":720,"file_path":"/k5YPKoIQeL1VLs6eZmzeu5dFXip.jpg","iso_639_1":"en","vote_average":0},{"width":3840,"height":2160,"file_path":"/wG51OUdka9CyK4jRmFilecbqQMh.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/ihXxwrGnV0fBxgV2PCGsyLZLWct.jpg","iso_639_1":"zh","vote_average":0},{"width":1280,"height":720,"file_path":"/wXt39ygMeQhtaPfVWedwyHw9Ior.jpg","iso_639_1":"pt","vote_average":0},{"width":1280,"height":720,"file_path":"/yBhDdv9frEH0hiOJMrQYzmzcJVp.jpg","iso_639_1":"pt","vote_average":0},{"width":1280,"height":720,"file_path":"/rFY0YXdWLrOcTb063wVYPz6buAc.jpg","iso_639_1":"pt","vote_average":0}]},"enriched_at":"2026-04-21T09:08:12.736+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Shutter","runtime":96,"tagline":"The most terrifying images are the ones that are real.","homepage":"","overview":"When Jane and Tun run over a girl in a car accident, they speed away immediately from the crime scene. However, Tun, a photographer, soon discovers strange shadows in his photos, which unsettles them."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Espíritos - A Morte Está ao Seu Lado","runtime":97,"tagline":"","homepage":"","overview":"Thun (Ananda Everingham), um jovem fotógrafo, e sua namorada Jane (Natthaweeranuch Thongmee) atropelam acidentalmente uma pedestre. Eles fogem da cena do crime e retornam às suas vidas normais, em Bangkok. A partir de então Jane passa a ser atormentada por estranhos pesadelos, enquanto que Thun nota que em suas fotos aparecem estranhas figuras, parecidas com fantasmas. O casal decide investigar o fenômeno e encontra outras fotografias com imagens sobrenaturais. Paralelamente os melhores amigos de Thun começam a morrer, um a um, de forma misteriosa."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Shutter","runtime":96,"tagline":"Sie sind unter uns.","homepage":"","overview":"Als Jane ihren angetrunkenen Freund Tun nach einer Hochzeitsfeier heimfährt, überrollt sie eine junge Frau, die plötzlich aus dem Nichts über die Straße rast. In Panik verleitet Tun Jane zur Fahrerflucht. Auch wenn dies die Beziehung stark belastet, der Alltag holt das Pärchen schnell wieder ein. Besonders Tun findet sich bald wieder in seinem Fotografenjob. Doch seine Bilder sind plötzlich durch bizarre Verzerrungen und grelle Lichter unbrauchbar. Und Jane wird immer häufiger von brutalen Albträumen geplagt, in denen ein gespenstisches Mädchen sie erbarmungslos verfolgt. Als auch Tuns Nchte von dieser Vision gestört werden, beginnen die beiden mit Nachforschungen über die vermeintliche Tote. Zurück am Unfallort erfahren sie, dass eine Leiche nie gefunden wurde..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Shutter - Widmo","runtime":92,"tagline":"","homepage":"","overview":"Pewnego wieczoru młody fotograf Tun wracając samochodem ze swoją dziewczyną Jane z podmiejskiego przyjęcia, na pustej drodze potrąca kobietę. Przerażeni uciekają z miejsca wypadku. Próbują zapomnieć o feralnej nocy, ale wkrótce okaże się, że przed przeszłością nie da się uciec. Nocami Jane prześladują koszmary, a Tun zaczyna dostrzegać na swych zdjęciach dziwne, rozmazane postacie. W tajemniczych okolicznościach zaczynają ginąć ich najbliżsi. Tun i Jane muszą znaleźć odpowiedź na pytanie kto lub co pojawia się na zdjęciach, bo wkrótce może być za późno."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Затвор","runtime":97,"tagline":"","homepage":"","overview":"Тан, молодой фотограф, сбивает девушку и скрывается с места аварии вместе со своей подругой Джен. После несчастного случая, на снимках, которые он делает, появляется странная тень.  Сначала Тан решает, что это просто брак, но тень появляется снова и снова, а друзья Тана начинают умирать."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Resimdeki Hayalet","runtime":0,"tagline":"","homepage":"","overview":"Genç bir fotoğrafçı olan Tun ve kız arkadaşı Jane, arkadaşlarıyla çıktıkları bir yemekten dönerken karanlık yolda yürüyen bir kıza arabalarıyla çarparlar. Panik yapan ve ne yapacaklarını bilemeyen ikili, yaralı kıza yardım etmeden olay yerinden kaçarlar...  Bir yandan da kıza ne olduğunu merak eden çift ertesi gün gazetelere baktıklarında olayla karşılaşmazlar. Kıza birşey olmadığını varsayan ikiliden Tun, çektiği fotoğraflarda gizemli gölge ve şekillerin bulunduğunu fark eder.  Jane de bir süre sonra benzer tuhaflıklarla karşılacaktır. Bunun çarptıkları kızın hayaleti olabileceğini düşünen çift, o gece yemekte beraber oldukları arkadaşlarının ardı ardına intihar etmesi ile bir başka gerilim boyutuna geçerler..."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Shutter","runtime":97,"tagline":"Chaque photo est une preuve.","homepage":"","overview":"Une nuit sur une petite route de campagne, Tan et Jane renversent accidentellement une jeune femme. Ils décident de prendre la fuite et essaient d'oublier le drame. Les jours passent mais les rêves de Jane sont hantés de cauchemars tandis que Tan, photographe professionnel, remarque l'apparition de formes mystérieuses sur ses photos. Les phénomènes inquiétants se multiplient autour d'eux, Tan et Jane doivent faire la lumière sur le mystère qui les entoure…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Shutter: El fotógrafo","runtime":97,"tagline":"","homepage":"","overview":"Avanzada la noche, en una carretera rural, Tun y Jane atropellan accidentalmente a un misterioso peatón. Huyen de la escena y regresan a su quehacer cotidiano en Bangkok. Sin embargo, algunos fenómenos sin explicación empiezan a convertir su vida en una pesadilla constante. Jane se ve asediada por terribles sueños. Tun, fotógrafo de profesión, percibe extrañas figuras espectrales que empiezan a aparecer en sus fotografías. Cuando deciden regresar al lugar del accidente para investigar, no queda ningún rastro de la víctima ni noticia alguna sobre su desaparición o sobre el descubrimiento del cadáver. Sin embargo, uno a uno, van muriendo los amigos más próximos de Tun. Tanto él como Jane saben muy bien que deben resolver este misterio antes de que sea éste el que destruya sus propias vidas."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"ชัตเตอร์ กดติดวิญญาณ","runtime":0,"tagline":"วิญญาณอยู่รอบ ๆ ตัวเรา","homepage":"","overview":"เรื่องราวของ ช่างภาพหนุ่ม มาดเซอร์ กับ แฟนสาวของเขา เรื่องเริ่มต้นขึ้น เมื่อทั้งคู่ ขับรถชนหญิงสาว คนหนึ่งอย่างแรง แล้วตัดสินใจ ขับหนีไป ไม่นานทั้งคู่ ก็ต้องพบกับ เหตุการณ์ประหลาด เมื่อภาพถ่ายขอ งพระเอกนั้น ถ่ายติดแสงเงา ประหลาดมาด้วย แรกเริ่มเขาก็คิด เพียงว่ามันเป็น แค่รูปเสีย แต่เขาก็พบว่า มันมีอะไร บางอย่าง มากกว่านั้น คือมีเงาคล้ายกับ ใบหน้าของ ผู้หญิง ติดมาในรูปด้วย ทั้งคู่เริ่มค้นพบว่า เงาที่ปรากฏในภาพทั้งหลายนั้น มีบางอย่าง ที่เชื่อมโยงถึงกัน"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Shutter","runtime":97,"tagline":"Le immagini più terrificanti sono quelle reali.","homepage":"","overview":"Il fotografo Tun e la sua fidanzata Jane, tornando da un matrimonio, investono una ragazza, ma scappano senza prestarle soccorso. Da quel momento misteriose ombre appaiono nelle fotografie scattate dall'uomo: ombre misteriose, dalle sembianze umane."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"鬼影","runtime":0,"tagline":"","homepage":"","overview":"年轻的自由摄影师Thun（Ananda Everingham）这日携女友Jane（Natthaweeranuch Thongmee）与大学同窗聚会完毕开车归家，途中Jane将一名飘忽而至的女子撞倒在地。Jane欲下车查看女子伤势，被Thun劝阻，两人匆忙逃离肇事现场。Jane开始终日坐立不安，并指责Thun冷血，Thun只叫她放宽心莫多虑。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"צמצם","runtime":0,"tagline":"","homepage":"","overview":"לילה חשוך. צלם צעיר פוגע בהולך רגל ובורח מזירת התאונה. דמויות אווריריות מוזרות מתחילות להופיע בצילומיו וחבריו מתחילים למות בזה אחר זה. הגיבור מנסה להלחם על חייו ולומד שיעור מפחיד - אפשר לברוח מהחושך, אבל אי אפשר להימלט מהאפלה שבתוכך."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Ο Tun και η Jane, ένα νεαρό ζευγάρι, οδηγεί προς το σπίτι του ένα βράδυ και χτυπά μια γυναίκα που στέκεται στη μέση του σκοτεινού δρόμου. Θα την εγκαταλείψουν εκεί"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Espíritos: A Morte Esta Ao Seu Lado","runtime":92,"tagline":"Tudo o que eles querem é estar estre nós!","homepage":"","overview":"Thun (Ananda Everingham), um jovem fotógrafo, e sua namorada Jane (Natthaweeranuch Thongmee) atropelam acidentalmente uma pedestre. Eles fogem da cena do crime e retornam às suas vidas normais, em Bangkok. A partir de então Jane passa a ser atormentada por estranhos pesadelos, enquanto que Thun nota que em suas fotos aparecem estranhas figuras, parecidas com fantasmas. O casal decide investigar o fenômeno e encontra outras fotografias com imagens sobrenaturais. Paralelamente os melhores amigos de Thun começam a morrer, um a um, de forma misteriosa."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"셔터","runtime":0,"tagline":"셔터를 누르는 순간, 귀신이 살아난다","homepage":"","overview":"25살의 사진작가 '턴'과 그의 여자친구 '제인'. 대학동창의 결혼식에 다녀오던 길에 한 여자를 차로 치고 만다. 두려움에 뺑소니를 치고 마는 그들... 다음날, '턴'은 자신이 찍은 사진 속에서 형체를 구분하기 어려운 무언가를 발견하기 시작한다.  두려움의 원인을 찾아 결국 사고 현장을 다시 찾게 되는 그들. 그러나 그 도로 위에선 어떤 사건 사고도 보고된 바 없다! 점점 더 혼란과 공포 속으로 빠져드는 '턴'과 '제인'. 뿐만 아니라 '턴'의 대학동창들은 하나 둘 의문의 자살을 시작하는데...  턴과 제인은 의문의 사진들이 찍힌 현장을 찾아 다시 셔터를 누르기 시작한다. 그리고 사진 속 '그것'이 그들에게 무언가를 말하려 한다는 것을 깨닫게 된다! 그들은 언제나 당신 옆에 있다... 당신이 원하건 원하지 않건 그들은 바로 당신 곁에 서서 당신에게 무언가를 말하고 있다!!!"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"鬼影","runtime":0,"tagline":"","homepage":"","overview":"所有離奇怪事由一次酒後駕駛開始……攝影師東及女友不慎撞倒一名女子後不顧而逃，自始，東拍攝的照片都會出現靈異的模糊女影，東更出現莫名頸痛背痛、身邊朋友神秘地相繼身亡。後來他才意識到照片中的影像與他撞倒的女子容貌相似，「鬼影」幢幢…令他決定深入調查這些糾纏不休的照片後的真相！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"鬼影","runtime":0,"tagline":"","homepage":"","overview":"25歲的泰國攝影師「東」（亞萊特飾）與女友「珍」（娜特慧蘭飾）與友人喝酒後，二人駕車歸家途中，不慎把一名女子撞倒，車子失控繼而撞上路旁的告示牌。不省人事的女子躺在路中心，但此時後面已有車輛駛至，二人沒有下車探視傷者，反而選擇趕緊駕車逃離現場。  可是意外發生後，離奇怪事就接踵而來，「東」發現他拍攝的照片中出現一些靈異的光芒及影像，有些照片像是有人站在照相機前，把鏡頭都擋住，但是實際上在拍攝照片時, 並沒有這樣的情形發生。  開始時他以為只是拍攝失誤，後來他仔細查證後，才意識到照片中的神秘影像與被他們撞倒的女子容貌相似，與此同時，「東」不單惡夢連連，頸部也出現莫名其妙的痛楚。  他的朋友一個一個神秘的相繼身亡，他決定深入調查這些糾纏他不休的照片後的真相。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Shutter","runtime":97,"tagline":"","homepage":"","overview":"De jonge fotograaf Tun en z'n vriendin Jane rijden per ongeluk een vrouw aan op straat. De vrouw overlijdt aan haar verwondingen en Thun en Jane ontvluchten de plaats van het ongeluk. Een tijd later komt Thun een mysterieuze schaduw tegen op een van zijn foto's. Hij gaat ervan uit dat het gewoon een slechte foto is. De schaduwen blijven echter opduiken en Thun merkt op dat de vorm van de schaduw wel erg lijkt op het gezicht van de vrouw die hij had aangereden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Están entre nosotros","runtime":97,"tagline":"","homepage":"","overview":"Avanzada la noche, en una carretera rural, Tun y Jane atropellan accidentalmente a un misterioso peatón. Huyen de la escena y regresan a su quehacer cotidiano en Bangkok. Sin embargo, algunos fenómenos sin explicación empiezan a convertir su vida en una pesadilla constante. Jane se ve asediada por terribles sueños. Tun, fotógrafo de profesión, percibe extrañas figuras espectrales que empiezan a aparecer en sus fotografías. Cuando deciden regresar al lugar del accidente para investigar, no queda ningún rastro de la víctima ni noticia alguna sobre su desaparición o sobre el descubrimiento del cadáver. Sin embargo, uno a uno, van muriendo los amigos más próximos de Tun. Tanto él como Jane saben muy bien que deben resolver este misterio antes de que sea éste el que destruya sus propias vidas."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Shutter","runtime":97,"tagline":"","homepage":"","overview":"Fotograf Tun a jeho přítelkyně Jane se vracejí domů z oslavy, ale způsobí autonehodu.  Nešťastnou náhodou srazí mladá dívka a utečou z místa činu.  Od toho dne jejich pronásleduje přízrak ženy, objevující se na Tunových fotkách.  Fotografovi kamarádi brzy záhadným způsobem spáchají sebevraždu.  Jane se pouští do pátrání a odhaluje minulost oné dívky, která je hrozivě propojena právě s Tunom."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Hồn Ma Theo Đuổi","runtime":0,"tagline":"","homepage":"","overview":"Trên đường về từ đám cưới của cậu bạn thân Tonn, xe của Tun và cô bạn gái là Jane đụng phải 1 cô gái. Trong cơn hoảng loạn, Tun đã giục Jane lái xe đi bỏ mặc sự sống chết của nạn nhân.  Sau tai nạn đó, Jane luôn gặp ác mộng. Mỗi ngày cô phải sống trong sự thấp thỏm, lo âu và hối hận. Trong khi đó Tun lại xem như không có chuyện gì xảy ra. Cho đến khi những đốm sáng kì lạ xuất hiện trên các bức ảnh của Tun và những người bạn của anh lần lượt chết 1 cách khó hiểu, cơn ác mộng thật sự mới bắt đầu…  Lần theo dấu vết của những đốm sáng bí ẩn đó, Jane phát hiện tất cả chúng hợp thành khuôn mặt của một cô gái. Cô gái này chính là bạn gái cũ của Tun, những bí mật đen tối nhất trong quá khứ dần dần được hé mở…"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"心霊写真","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Umbre printre noi","runtime":97,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Призрачна бленда","runtime":0,"tagline":"","homepage":"","overview":"Тън е млад фотограф, който живее заедно с приятелката си Джейн. Увлечени от фотографията, двамата често работят заедно. След проявяването на поредния филм, Джейн и Тън откриват загадъчни сенки в снимките си. Докато двамата правят собствено разследване по случая, наяве излизат други снимки със сходни свръхестествени елементи. Същият феномен скоро сполита и най-добрите приятели на Тън и Джейн открива, че нейният интимен приятел не е споделил всичко, което знае. Една ужасяваща тайна от миналото се оказва в основата на тази черна и изпълнена с ужаси мистерия."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Okidač","runtime":0,"tagline":"Najstrašnije slike su one koje su stvarne.","homepage":"","overview":"Nakon što pregaze mladu djevojku u prometnoj nesreći, par počinje primjećivati sablasne slike na svojim fotografijama. Dok istražuju tajnu iza tih slika, otkrivaju mračnu povezanost između prošlosti i sadašnjosti koja ih vodi prema užasavajućoj istini."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Shutter","runtime":95,"tagline":"","homepage":"","overview":"En fotograf opdager mærkelige skygger og ansigter på sine fotografier, efter de er blevet fremkaldt. Hvad er det, der har havnet på fotografierne? Døde mennesker, der går igen?"},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"}],"reviews_tmdb":[],"recommendations":[{"id":37973,"adult":false,"title":"Alone","video":false,"overview":"When Pim and Ploy, twins conjoined at the stomach, are separated, the operation leaves Pim the surviving sister, haunted by Ploy's vengeful ghost.","genre_ids":[27,9648,18],"media_type":"movie","popularity":0.6031,"vote_count":239,"poster_path":"/vNsCrJSTsSLnldhdpc9koXf2IcO.jpg","release_date":"2007-03-29","vote_average":7.178,"backdrop_path":"/qn5HfQcouuCk40FNXCnq8HKzpav.jpg","original_title":"แฝด","original_language":"th"},{"id":10885,"adult":false,"title":"Shutter","video":false,"overview":"A newly married couple discovers disturbing, ghostly images in photographs they develop after a tragic accident. Fearing the manifestations may be connected, they investigate and learn that some mysteries are better left unsolved.","genre_ids":[27,9648,53],"media_type":"movie","popularity":1.5329,"vote_count":801,"poster_path":"/t5AEelR6nS0ISwaSZCcUrF2GKZi.jpg","release_date":"2008-03-21","vote_average":5.546,"backdrop_path":"/icPIdA81Au1TEmgF9rXiW6LdH3e.jpg","original_title":"Shutter","original_language":"en"},{"id":17590,"adult":false,"title":"Deathtrap","video":false,"overview":"A Broadway playwright puts murder in his plan to take credit for a student's script.","genre_ids":[35,80,53],"media_type":"movie","popularity":0.9241,"vote_count":293,"poster_path":"/fwrqCTcu5rAkU2dL2YqG6jjrLPn.jpg","release_date":"1982-03-19","vote_average":6.7,"backdrop_path":"/pk5GvHFVB1a5ifKPrtFTcyLBWsO.jpg","original_title":"Deathtrap","original_language":"en"},{"id":177221,"adult":false,"title":"The Battery","video":false,"overview":"In rural Connecticut, baseball players Ben and Mickey are trying to survive a zombie plague. They are forced to form a battery: a catcher and a pitcher who work together to outwit the batter, the one who hits the ball. And the batter in this case just happens to be a zombie. Tough Ben and gentle Mickey frequently disagree on the best way to go about the situation. Then they suddenly hear a human voice through their walkie-talkies. Is salvation nearby, like Mickey thinks, or is Ben’s suspicion justified?","genre_ids":[18,27],"media_type":"movie","popularity":1.3274,"vote_count":299,"poster_path":"/nI7lzx2t4UPfuqhunB5bEVymOOV.jpg","release_date":"2012-10-13","vote_average":6.134,"backdrop_path":"/tgA2GbzyUBVm13qvI7AyPIdWSsS.jpg","original_title":"The Battery","original_language":"en"},{"id":9568,"adult":false,"title":"The Dentist","video":false,"overview":"Dr. Alan Feinstone has everything: a beautiful wife and a successful career in dentistry. However, when he discovers his wife's affair, he realizes that behind every clean, white surface lies the stench of decay.","genre_ids":[53,27],"media_type":"movie","popularity":3.1639,"vote_count":323,"poster_path":"/4jKZXQy0OJW3B0tt8AdQ8epI9sU.jpg","release_date":"1996-06-07","vote_average":5.525,"backdrop_path":"/25pNPKtYHtZFLsJ71SC5skiXJAe.jpg","original_title":"The Dentist","original_language":"en"},{"id":10741,"adult":false,"title":"Bobby","video":false,"overview":"In 1968 the lives of a retired doorman, hotel manager, lounge singer, busboy, beautician and others intersect in the wake of Robert F. Kennedy's assassination at the Ambassador Hotel in Los Angeles.","genre_ids":[18],"media_type":"movie","popularity":2.105,"vote_count":417,"poster_path":"/ea6aSTUFQopOW7kWFZB9AvMYnbs.jpg","release_date":"2006-09-05","vote_average":6.4,"backdrop_path":"/3ivhTBoGtSRcxqsTdXHHkYFLxO2.jpg","original_title":"Bobby","original_language":"en"},{"id":10389,"adult":false,"title":"The Eye","video":false,"overview":"A blind concert violinist gets a cornea transplant allowing her to see again. However, she gets more than she bargained for when she realizes her new eye can see ghosts. She sets out to find the origins of the cornea and discover the fate of its former host.","genre_ids":[27],"media_type":"movie","popularity":1.2613,"vote_count":450,"poster_path":"/ux5xsVRBwusVrmOTlhV9zRhu93d.jpg","release_date":"2002-05-09","vote_average":6.586,"backdrop_path":"/npVGufP6534Eze4moT2CCG04YEg.jpg","original_title":"見鬼","original_language":"cn"},{"id":685274,"adult":false,"title":"Mobile Suit Gundam Hathaway","video":false,"overview":"12 years after Char's rebellion, Hathaway Noa leads an insurgency against Earth Federation, but meeting an enemy officer and a mysterious woman alters his fate.","genre_ids":[16,28,18,878],"media_type":"movie","popularity":3.3481,"vote_count":139,"poster_path":"/6gw8onh4FKsruBA7Oouv01EFxzn.jpg","release_date":"2021-06-11","vote_average":7.2,"backdrop_path":"/mI0Qo7VtgW5siCtQQqNPXIk0Ar6.jpg","original_title":"機動戦士ガンダム 閃光のハサウェイ","original_language":"ja"},{"id":10103,"adult":false,"title":"Windstruck","video":false,"overview":"Kyung-jin, a police officer who finds herself chasing down a suspected bag-snatcher on her day off. However, the man she catches turns out to be Myungwoo, a passer-by who was himself trying to apprehend the real criminal.","genre_ids":[35,10749,18],"media_type":"movie","popularity":1.3066,"vote_count":152,"poster_path":"/8OyugG9zsjK4HT42yIcqXMXc2CR.jpg","release_date":"2004-06-03","vote_average":7.138,"backdrop_path":"/fE3DxK3zjWZwhdNpyPY0guCTTgm.jpg","original_title":"내 여자친구를 소개합니다","original_language":"ko"},{"id":214100,"adult":false,"title":"Sunshine on Leith","video":false,"overview":"Davy and Ally have to re-learn how to live life in Edinburgh after coming home from serving in Afghanistan. Both struggle to learn to live a life outside the army and to deal with the everyday struggles of family, jobs and relationships. Sunshine on Leith is based on the sensational stage hit of the same name, featuring music by pop-folk band The Proclaimers.","genre_ids":[10402,35,18],"media_type":"movie","popularity":0.708,"vote_count":133,"poster_path":"/9OsWiIBLcYPd2mP6GvyOWykOISJ.jpg","release_date":"2013-10-03","vote_average":6.6,"backdrop_path":"/27Anwkr9amLXOApPKeXE5ip9XU2.jpg","original_title":"Sunshine on Leith","original_language":"en"},{"id":933090,"adult":false,"title":"Starve Acre","video":false,"overview":"When their son starts acting strangely, a couple unwi