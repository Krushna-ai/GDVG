pect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/s5ksD5C4sBjfeYKPOmB9mpCQLjo.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/32qUWBRWGxMk3sBPempIQaprSYG.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:42:34.341+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":121,"tagline":"In search of salvation, he'll make the city rain blood.","homepage":"https://www.netflix.com/title/80148162/","overview":"After sparing a girl's life during a massacre, an elite Triad assassin is targeted by an onslaught of murderous gangsters."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Seorang tukang pukul bernama Ito (Joe Taslim) kembali ke keluarga kriminalnya di Jakarta setelah bekerja dengan sebuah Triad Asia Tenggara yang kejam. Dia terperangkap dalam sebuah intrik pengkhianatan dan kekacauan saat Triad tersebut memulai sebuah kampanye berdarah untuk ekspansi teritorial mereka."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"","runtime":121,"tagline":"En busca de la salvación, hará llover sangre sobre la ciudad.","homepage":"","overview":"Un antiguo sicario debe proteger a una joven mientras trata de escapar de la tríada a la que pertenecía. En su fuga, desatará una violenta batalla en las calles de Djakarta. Una hiperbólica cinta de acción urbana, indispensable para cualquier fan de la adrenalina."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Ночь идёт за нами","runtime":121,"tagline":"","homepage":"","overview":"История жестокого и беспощадного противостояния, разразившегося между азиатскими преступниками."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Przychodzi po Nas Noc","runtime":0,"tagline":"","homepage":"","overview":"Darował życie pewnej dziewczynie podczas masakry. Teraz sam jest celem niebezpiecznych gangsterów. Czy elitarnemu zabójcy uda się przetrwać?"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"La notte su di noi","runtime":120,"tagline":"In cerca di redenzione, farà soffrire questa città","homepage":"","overview":"Ito, un ex scagnozzo della Triade, al suo ritorno a casa dopo un periodo all’estero deve proteggere una giovane ragazza. Dovrà tentare così di tenersi lontano dal mondo criminale di cui faceva parte e dalla violenta guerra che si sta combattendo tra le strade di Giacarta…"},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"밤이 온다","runtime":0,"tagline":"","homepage":"","overview":"참혹한 학살의 현장. 폭력 조직 최고의 킬러가 어린 소녀를 살려준다. 이 일로 배신자라 낙인찍힌 그는 조직의 표적이 되어 끝없이 죽음의 위협에 쫓긴다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"A Noite nos Persegue","runtime":120,"tagline":"Em busca da salvação, ele fará chover sangue na cidade.","homepage":"","overview":"Após poupar a vida de uma garota durante um massacre, um assassino de elite se torna o alvo do ataque de criminosos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":120,"tagline":"","homepage":"","overview":"Après avoir épargné la vie d'une fillette pendant un massacre, un assassin membre d'une triade est pris pour cible par un groupe de gangsters meurtriers."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Όταν Πέσει η Νύχτα","runtime":0,"tagline":"","homepage":"https://www.netflix.com/gr/title/80148162","overview":"Ο Iko Uwais εδώ πρωταγωνιστεί ως ο ‘Arian’, ένας σκληροτράχηλος εκτελεστής της “Τριάδας”, ένα από τα πολλά παρακλάδια διεθνών συνδικάτων του οργανωμένου εγκλήματος που εδρεύουν στην Κίνα. Ο άνδρας αυτός καλείται να αντιμετωπίσει ορδές από φονικούς γκάνγκστερ για να προστατέψει ένα νεαρό κορίτσι που κυνηγάει η μαφία. Όλα αρχίζουν αφότου ο ίδιος σώζει την μικρούλα κατά την διάρκεια μίας σφαγής, και μπαίνει με την σειρά του στο στόχαστρο καθώς βάζει σκοπό της ζωής του να την κρατήσει ζωντανή εμποδίζοντας άτομα του υποκόσμου να την πιάσουν."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Gece Bizim İçin Gelir","runtime":121,"tagline":"","homepage":"","overview":"Bir katliam sırasında bir kızın hayatını bağışlayan özel Triad tetikçisi, kana susamış gangsterlerin saldırısına uğrar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":120,"tagline":"","homepage":"","overview":"Ein ehemaliger Elite-Attentäter der Triaden, der während eines Massakers das Leben eines Mädchens verschonte, muss nun vor gleichfalls mörderischen Gangstern fliehen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"黑夜降臨","runtime":120,"tagline":"","homepage":"","overview":"一名地下秘密組織的菁英殺手，在一場屠殺中放過一個女孩的性命，卻因此遭到兇殘匪幫的瘋狂追殺。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Нощта идва за нас","runtime":120,"tagline":"","homepage":"","overview":"В спасяването от наказателна акция на малко момиче, елитен килър на триадите вижда шанса си за изкупление, но това е свързано със сериозни последствия и той става мишена на цялата организация."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"嗜人之夜","runtime":121,"tagline":"","homepage":"","overview":"《嗜人之夜》围绕伊托（乔·塔斯利姆饰演）展开，他曾经是一名三合会打手，他的神秘消失在雅加达引发了一场激战。而现在他要保护一位少女，还要逃离前帮派的追杀。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Az éjszaka eljön értünk","runtime":121,"tagline":"","homepage":"","overview":"Miután a triád elit bérgyilkosa megkíméli egy lány életét egy mészárlás során, vérengző gengszterek célkeresztjébe kerül."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"La noche nos persigue","runtime":121,"tagline":"","homepage":"","overview":"Un antiguo sicario debe proteger a una joven mientras trata de escapar de la tríada a la que pertenecía. En su fuga, desatará una violenta batalla en las calles de Djakarta. Una hiperbólica cinta de acción urbana, indispensable para cualquier fan de la adrenalina."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"עם רדת ליל","runtime":0,"tagline":"עם רדת ליל","homepage":"","overview":"כשמתנקש בכיר של ארגון הטריאדה חס על חייה של ילדה במהלך טבח, עשרות גנגסטרים צמאים לדם יוצאים בעקבותיו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Jde si pro nás noc","runtime":0,"tagline":"","homepage":"","overview":"Ito v roli vymahače podsvětí, který se vrací do své organizace. Ovšem už po návratu ho potká zrada a ocitá se v chaosu, ve kterém neví, komu věřit."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"A Noite nos Persegue","runtime":0,"tagline":"","homepage":"","overview":"Após poupar a vida de uma garota durante um massacre, um assassino de elite se torna o alvo do ataque de criminosos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":121,"tagline":"","homepage":"","overview":"Ito, een afperser, keert terug naar zijn lokale misdaadfamilie in Jakarta na een gevaarlijke opdracht in het buitenland. Hij werkte daar enige tijd voor beruchte Zuid-Aziatische bendes. Hij raakt nu verwikkeld in een wereld van verraad en chaos als de Triade een bloedige campagne van territoriale expansie begint."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Ніч йде за нами","runtime":121,"tagline":"","homepage":"","overview":"При виконанні чергового завдання кілер тріади порушив правила - не зміг змусити себе прибрати останню свідка. У порятунку життя дівчинки він побачив знак і шанс на спокутування, але у такого вчинку будуть серйозні наслідки, і тепер відступника і його старим друзям доведеться мати справу з усією убивчою силою цієї злочинної організації."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Màn Đêm Kéo Đến","runtime":0,"tagline":"","homepage":"","overview":"Sau khi tha mạng cho một cô bé trong một cuộc thảm sát do mình dẫn đầu, gã sát thủ của hội Tam Hoàng Ito (Joe Taslim) trở thành tầm ngắm của hàng loạt sát thủ khác."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"ღამე ჩვენთვის მოდის","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"ค่ำคืนแห่งการไล่ล่า","runtime":120,"tagline":"","homepage":"","overview":"หลังจากที่ไว้ชีวิตเด็กสาวจากเหตุการณ์สังหารหมู่ นักฆ่าฝึมือฉกาจจากแก๊งหนึ่งก็ถูกเป็นเป้าสังหารของกลุ่มอันธพาลกระหายเลือด"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Triadin huipputappaja teurastaa kasapäin porukkaa, mutta jättää yhden tytön henkiin ja saa siitä hyvästä peräänsä liudan murhanhimoisia gangstereita."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Naktis ateina mūsų","runtime":0,"tagline":"","homepage":"","overview":"Atlikinėdamas vieną iš savo užduočių, triados žudikas pažeidė taisykles - jo vidinis balsas neleido pašalinti paskutinio liudytojo. Jam apsireiškė ženklas, taigi gelbėdamas mergaitės gyvybę jis pasmerkė save mirčiai ir toks jo poelgis sukėlė rimtų pasekmių ir dabar jam teks susidoroti su visa jo buvusios nusikalstamos organizacijos žmogžudžių grupe."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Efter at have skånet en piges liv under en massakre bliver en af Triadernes bedste lejemordere selv målet for morderiske gangstere."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"يأتي الليل من أجلنا","runtime":0,"tagline":"","homepage":"","overview":"بعد أن أبقى قاتل بارع من عصابة \"الثالوث\" على حياة إحدى الفتيات أثناء مذبحة في قريتها، يستهدفه هجوم يشنّه عليه أفراد عصابات دمويّة."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"În umbra nopții","runtime":120,"tagline":"În căutarea mântuirii, el va face ca orașul să plouă cu sânge.","homepage":"","overview":"După ce cruță viața unei fete în timpul unui masacru, un asasin de elită al Triadei devine ținta unui grup de gangsteri nemiloși."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"黑夜降臨","runtime":0,"tagline":"","homepage":"","overview":"一名地下秘密組織的菁英殺手，在一場屠殺中放過一個女孩的性命，卻因此遭到兇殘匪幫的瘋狂追殺。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"シャドー・オブ・ナイト","runtime":0,"tagline":"","homepage":"","overview":"ある日少女の命を見逃したため、組織から追われる身になった元トライアッドのエリート殺し屋。少女を守るため、残虐な闇社会を敵に回し、凄惨な闘いに身を投じる。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"}],"reviews_tmdb":[{"id":"5c43f94fc3a36819fd23b8c6","url":"https://www.themoviedb.org/review/5c43f94fc3a36819fd23b8c6","author":"Gimly","content":"_The Night Comes for Us_ features levels of gore not found anywhere else but your most gratuitous horror flicks, so if you can't handle that sort of thing, I suggest you give it a wide berth. If some blood and guts aren't an issue for you though, WHAT ARE YOU DOING? WHY ARE YOU SPENDING VALUABLE TIME READING THIS REVIEW THAT COULD BE SPENT WATCHING _THE NIGHT COMES FOR US_?\r\n\r\n_Final rating:★★★★ - Very strong appeal. A personal favourite._","created_at":"2019-01-20T04:30:07.410Z","updated_at":"2021-06-23T15:58:15.923Z","author_details":{"name":"Gimly","rating":8,"username":"Ruuz","avatar_path":"/xUObnJSvHrFPsIpoDmb1jiQZLq7.jpg"}},{"id":"6516ae629b861600ff68a3ac","url":"https://www.themoviedb.org/review/6516ae629b861600ff68a3ac","author":"jw","content":"$11","created_at":"2023-09-29T11:00:50.297Z","updated_at":"2023-09-29T11:01:16.949Z","author_details":{"name":"","rating":5,"username":"jw","avatar_path":null}}],"recommendations":[{"id":403605,"adult":false,"title":"Headshot","video":false,"overview":"A young man washes ashore, his memory gone - but his past comes back to haunt him after he is nursed back to health and his killing ability is needed when he takes on a powerful drug lord.","genre_ids":[28,53,18],"media_type":"movie","popularity":2.2413,"vote_count":473,"poster_path":"/dpdmO3PNKwCOzf68y8J4Gu19i3r.jpg","release_date":"2016-09-24","vote_average":6.431,"backdrop_path":"/sEyYwNHJ6AO1Wnh0JuRTBmlZ8No.jpg","original_title":"Headshot","original_language":"id"},{"id":347392,"adult":false,"title":"Slice","video":false,"overview":"In a spooky small town, when a slew of pizza delivery boys are slain on the job, two daring survivors set out to catch the culprits behind the cryptic crime spree.","genre_ids":[35,27],"media_type":"movie","popularity":0.4628,"vote_count":121,"poster_path":"/bznkSqWqj43DhzHrbLehsr6ncb0.jpg","release_date":"2018-09-10","vote_average":4.455,"backdrop_path":"/ymjOGuWAe1yv1ZUR5XFTbmDWBOR.jpg","original_title":"Slice","original_language":"en"},{"id":425507,"adult":false,"title":"Crown Heights","video":false,"overview":"When Colin Warner was wrongfully convicted of murder, his best friend Carl King devoted his life to proving his innocence.","genre_ids":[18],"media_type":"movie","popularity":0.3357,"vote_count":72,"poster_path":"/ksTHqOb8bPPdbIsZXHnWX3NrgfH.jpg","release_date":"2017-08-25","vote_average":6.5,"backdrop_path":"/8kT4NFQfNZ2ig6Nj7FVeACTH9v1.jpg","original_title":"Crown Heights","original_language":"en"},{"id":31112,"adult":false,"title":"Bon Voyage, Charlie Brown (and Don't Come Back!)","video":false,"overview":"Charlie Brown, Linus, Peppermint Patty and Marcie travel to France as foreign exchange students. Also along is Snoopy and Woodstock. While everyone is excited about the opportunity to travel to a foreign country, Charlie is disturbed by a letter he receives from a mysterious girl from France who invites him as a her guest only to find that he does not seem welcomed to her Chateau.","genre_ids":[10751,16,35],"media_type":"movie","popularity":0.4921,"vote_count":101,"poster_path":"/eds4cxarUjHn7OdDd26SauphUnR.jpg","release_date":"1980-05-30","vote_average":6.4,"backdrop_path":"/cL7KkB2lVgFP5Fs8ISAxYYI65YF.jpg","original_title":"Bon Voyage, Charlie Brown (and Don't Come Back!)","original_language":"en"},{"id":468735,"adult":false,"title":"Madeline's Madeline","video":false,"overview":"Madeline has become an integral part of a prestigious physical theater troupe. When the workshop's ambitious director pushes the teenager to weave her rich interior world and troubled history with her mother into their collective art, the lines between performance and reality begin to blur. The resulting battle between imagination and appropriation rips out of the rehearsal space and through all three women's lives.","genre_ids":[18],"media_type":"movie","popularity":0.4351,"vote_count":102,"poster_path":"/8PcvYO5SHmPUFzdXpI2kzj3JtXN.jpg","release_date":"2018-08-10","vote_average":6,"backdrop_path":"/y00OqbAb2AZMz8JM19vmjjCN1KU.jpg","original_title":"Madeline's Madeline","original_language":"en"},{"id":565255,"adult":false,"title":"Struggle: The Life and Lost Art of Szukalski","video":false,"overview":"Artists in LA discover the work of forgotten Polish sculptor Stanislav Szukalski, a mad genius whose true story unfolds chapter by astounding chapter.