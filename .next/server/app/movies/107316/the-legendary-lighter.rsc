5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Legendary Lighter\",\"description\":\"A man who used to be called Lighter cleans up his act from his days as a gangster and struggles to start over.\",\"image\":\"https://image.tmdb.org/t/p/w500/h5fCwKCnKAKxdX6onTnrU6MeYe8.jpg\",\"datePublished\":\"2019-10-29\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"action film\",\"Action\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6,\"bestRating\":10,\"ratingCount\":3}}"}}],["$","$L10",null,{"initialDrama":{"id":"6ff2de3e-9c00-4fe3-b4f9-b4cd6bcd316d","tmdb_id":646315,"imdb_id":"tt34510565","content_type":"movie","title":"The Legendary Lighter","original_title":"전설의 라이타","overview":"A man who used to be called Lighter cleans up his act from his days as a gangster and struggles to start over.","poster_path":"/h5fCwKCnKAKxdX6onTnrU6MeYe8.jpg","backdrop_path":"/pe3cTrUeAHHLycZVEmFjT9kEV7a.jpg","release_date":"2019-10-29","first_air_date":null,"status":"published","original_language":"ko","origin_country":["KR"],"genres":[{"name":"action film"},{"id":28,"name":"Action"},"action film"],"popularity":2.59,"vote_average":6,"vote_count":3,"runtime":109,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-31T22:01:53.053068+00:00","updated_at":"2026-02-23T13:43:04.01+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":144669,"name":"Fiveday","logo_path":"/tLkb4DyX0VeTa0adDl3cdrJeq1r.png","origin_country":"KR"},{"id":144667,"name":"Gnos","logo_path":null,"origin_country":"KR"},{"id":144668,"name":"Kkuljam Company","logo_path":null,"origin_country":"KR"}],"production_countries":[{"name":"South Korea","iso_3166_1":"KR"}],"spoken_languages":[{"name":"한국어/조선말","iso_639_1":"ko","english_name":"Korean"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[{"id":14955,"name":"fighting"},{"id":219404,"name":"action hero"}],"alternative_titles":[{"type":"Hangul","title":"jeon-seil-eui ra-i-ta","iso_3166_1":"KR"},{"type":"","title":"传说的拉一大","iso_3166_1":"CN"}],"videos":[{"id":"5dc5bca49c24fc0015bf4ffd","key":"8QxypypwPGU","name":"The Legendary Lighter - Trailer (전설의 라이타 예고편)","site":"YouTube","size":1080,"type":"Trailer","official":false,"iso_639_1":"en","iso_3166_1":"US","published_at":"2019-10-28T10:45:37.000Z"}],"watch_providers":{"results":{"KR":{"buy":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":6}],"link":"https://www.themoviedb.org/movie/646315/watch?locale=KR","rent":[{"logo_path":"/hPcjSaWfMwEqXaCMu7Fkb529Dkc.jpg","provider_id":356,"provider_name":"wavve","display_priority":3},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":6}]}}},"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"KR","main_poster":"/h5fCwKCnKAKxdX6onTnrU6MeYe8.jpg","images":{"logos":[],"posters":[{"width":760,"height":1089,"file_path":"/h5fCwKCnKAKxdX6onTnrU6MeYe8.jpg","iso_639_1":"ko","vote_average":3.334},{"width":1319,"height":1890,"file_path":"/kn4VWnQaHY5gR9lrhRlciZmFiek.jpg","iso_639_1":"ko","vote_average":3.334},{"width":600,"height":860,"file_path":"/oETmM9HxajySeWzbkHdIvPJNErt.jpg","iso_639_1":"ko","vote_average":0}],"backdrops":[{"width":1500,"height":843,"file_path":"/pe3cTrUeAHHLycZVEmFjT9kEV7a.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T05:19:53.469+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Legendary Lighter","runtime":109,"tagline":"","homepage":"","overview":"A man who used to be called Lighter cleans up his act from his days as a gangster and struggles to start over."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"전설의 라이타","runtime":0,"tagline":"너…라이타라고 들어봤냐? 라이타 쥔 주먹으로 20명을 묵사발 낸 전설이지","homepage":"","overview":"맨주먹계의 전설적인 인물 채성빈(라이타). 아버지 같은 남자 마석준의 충고를 받아들여 이제는 평범한 삶을 살기로 결심한다. 그러던 중 우연히 골목에서 일진들에게 괴롭힘을 당하는 박주민을 구해주게 되고, 그를 계기로 박주민의 누나 박진아와 가까운 사이가 된다. 한편 박진아는 지역개발 이권 다툼에 휘말려 고통 받고 있었고 그 강도가 심해져 목숨까지 위협받는 처지가 된다. 끊임없는 조폭들의 위협으로 하루하루가 지옥 같던 박진아의 곁에 전설의 주먹 채성빈이 등장하게 되고, 채성빈은 사랑하는 박진아를 위해 마지막으로 다시 한번 라이타를 손에 쥐게 된다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"传说的拉一大","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"傳説的拉一大","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":96826,"adult":false,"title":"Ben 10: Destroy All Aliens","video":false,"overview":"Based on the original animated series Ben 10.  Ben becomes targeted by an evil Mechamorph Warrior, named \"Retaliator,\" who mistakenly blames Ben for something he did not do and attempts to destroy all aliens.","genre_ids":[16,878,10751,28,10770],"media_type":"movie","popularity":1.1082,"vote_count":103,"poster_path":"/fE9MXUsbNzG14e6rHcOTNVJi2r0.jpg","release_date":"2012-03-11","vote_average":6.476,"backdrop_path":"/cSMMrcFXHsnieG78TXOZwUx5GFa.jpg","original_title":"Ben 10: Destroy All Aliens","original_language":"en"},{"id":172386,"adult":false,"title":"Return to Nim's Island","video":false,"overview":"Fourteen year old Nim, more determined than ever to protect her island and all the wildlife that call it home, faces off against resort developers and animal poachers. Soon she realizes she can’t depend on her animal cohorts alone and must make her first human friend – Edmund, who’s run away to the island from the mainland – to save her home.","genre_ids":[10751,12],"media_type":"movie","popularity":0.4688,"vote_count":642,"poster_path":"/9LPDKDZQyGlQQphTna5kRHe4nrE.jpg","release_date":"2013-03-15","vote_average":6.5,"backdrop_path":"/auLEgC09Pvwkzul8lwEkcWnlSC2.jpg","original_title":"Return to Nim's Island","original_language":"en"},{"id":73108,"adult":false,"title":"Teen Spirit","video":false,"overview":"Amber, a mean popular girl who gets electrocuted and dies, is not allowed to enter into heaven unless she helps the least popular girl in school become Prom Queen within a week, but things do not go as planned.","genre_ids":[18,14,35,10770],"media_type":"movie","popularity":3.3321,"vote_count":298,"poster_path":"/8mmxoEBzTMX4ziYgveeEx35ltNY.jpg","release_date":"2011-08-07","vote_average":5.94,"backdrop_path":"/s75xYQOo4Hy2fy229CEfj5jgC2B.jpg","original_title":"Teen Spirit","original_language":"en"},{"id":202059,"adult":false,"title":"I could have been offended!","video":false,"overview":"Live stage recording of the stand-up comedy show, with sketches and videos of old skits from 'Mai dire Gol'.","genre_ids":[35],"media_type":"movie","popularity":0.1796,"vote_count":86,"poster_path":"/2D8YJpmK6L9fSLX43hkDhHvvers.jpg","release_date":"2001-10-18","vote_average":6.7,"backdrop_path":"/bpSNlvgrNiCCunelnx5BOUAuPVS.jpg","original_title":"Potevo rimanere offeso!","original_language":"it"},{"id":30178,"adult":false,"title":"Stuart Little 3: Call of the Wild","video":false,"overview":"With school out for the summer,  The Littles are vacationing in a cabin by the lake, and Stuart is so excited he could burst! But when Snowbell the cat is captured by a mean-spirited creature known simply as the Beast, it's up to Stuart and a skunk named Reeko to rescue him and a few other friends.","genre_ids":[16,35,10751],"media_type":"movie","popularity":1.1368,"vote_count":519,"poster_path":"/zImw7IVg8dxPkqMfT0L33sdsIHC.jpg","release_date":"2005-07-14","vote_average":5.2,"backdrop_path":"/mwJ99qv48tE5Km7fLkeoOU1uVfK.jpg","original_title":"Stuart Little 3: Call of the Wild","original_language":"en"},{"id":229408,"adult":false,"title":"Training Wheels","video":false,"overview":"When Margo, Edith, and Agnes chase after an ice cream truck, little Agnes struggles to keep up and takes a tumble while pedaling her bike. Seeing her disappointment, the Minions spring into action to lift her spirits. Using their quirky ingenuity, they construct a unicorn-themed motorcycle to help Agnes ride in style. With her new wheels, Agnes embarks on a whimsical and heartwarming ride through town, showcasing the Minions’ unwavering dedication to bringing joy to the girls’ lives. This short captures the charm of teamwork, creativity, and pure delight.","genre_ids":[16,35,10751],"media_type":"movie","popularity":2.3169,"vote_count":194,"poster_path":"/5irlpcx6tmpQ5sq42nojwICZrHN.jpg","release_date":"2013-12-10","vote_average":7.036,"backdrop_path":"/wPgAh9xtJL10WcFy93uTqD6sl1l.jpg","original_title":"Training Wheels","original_language":"en"},{"id":77887,"adult":false,"title":"Hawaiian Vacation","video":false,"overview":"The toys throw Ken and Barbie a Hawaiian vacation in Bonnie's room.","genre_ids":[16,10751,35],"media_type":"movie","popularity":2.2128,"vote_count":692,"poster_path":"/4BQHDbU0JgiNS1QkMknKHhvNjcG.jpg","release_date":"2011-06-16","vote_average":6.95,"backdrop_path":"/Tvn4W6qdbqhW5qcL7FZgb6570b.jpg","original_title":"Hawaiian Vacation","original_language":"en"},{"id":56288,"adult":false,"title":"Spy Kids: All the Time in the World","video":false,"overview":"Eight years after the third film, the OSS has become the world's top spy agency, while the Spy Kids department has since become defunct. Retired spy Marissa is called back into action, and to bond with her new stepchildren Rebecca and Cecil, she invites them along to stop the evil Timekeeper from taking over the world.","genre_ids":[10751,35,28,12,18,14,878],"media_type":"movie","popularity":1.8719,"vote_count":1048,"poster_path":"/9pUVarhiXfCu8amjmyadzJJJITi.jpg","release_date":"2011-08-18","vote_average":4.688,"backdrop_path":"/3COCz2DMRNefY4a3lfUHrNj4tl0.jpg","original_title":"Spy Kids: All the Time in the World","original_language":"en"},{"id":715892,"adult":false,"title":"I Want to Return Return Return","video":false,"overview":"A depiction of the Wrangelkiez neighbourhood in Berlin. The people portrayed tell their life stories. One woman came to the neighbourhood a decade ago to work in Berlin’s still unfinished Brandenburger Airport, one man reminisces his childhood on a Tobacco farm in Kentucky, another speaks of an exceptional day in an otherwise monotonous workplace. These portraits are interwoven with the story of Elpi, a Greek woman who is waiting for the long overdue visit of an old important friend. The outcome of this mixture is a film which captures the lives and perspectives of some of Wrangelkiez’s most commanding citizens, while at the same time evoking the loss that change and time passing means for places and for people.","genre_ids":[99],"media_type":"movie","popularity":0.0628,"vote_count":80,"poster_path":"/goHjKTGvOR2MTgv9PAvltaXxsNY.jpg","release_date":"2020-09-19","vote_average":6.7,"backdrop_path":null,"original_title":"I Want to Return Return Return","original_language":"en"},{"id":496274,"adult":false,"title":"The Thinning: New World Order","video":false,"overview":"Blake Redding is trapped in this dark room wanting to protect his love so the only thing he will do is escape like no failed student has done before.","genre_ids":[28,18,53,27],"media_type":"movie","popularity":0.5831,"vote_count":125,"poster_path":"/uQtYfyldOV3mPzclKr0K90FTS0n.jpg","release_date":"2018-10-17","vote_average":6.84,"backdrop_path":"/vhJ4WmM7RZtjRuTGeRLgNTjoIVl.jpg","original_title":"The Thinning: New World Order","original_language":"en"},{"id":23398,"adult":false,"title":"Alvin and the Chipmunks: The Squeakquel","video":false,"overview":"Pop sensations Alvin, Simon and Theodore end up in the care of Dave Seville's twenty-something nephew Toby. The boys must put aside music super stardom to return to school, and are tasked with saving the school's music program by winning the $25,000 prize in a battle of the bands. But the Chipmunks unexpectedly meet their match in three singing chipmunks known as The Chipettes - Brittany, Eleanor and Jeanette. Romantic and musical sparks are ignited when the Chipmunks and Chipettes square off.","genre_ids":[35,10751,16,14,10402],"media_type":"movie","popularity":4.4495,"vote_count":3084,"poster_path":"/8mdPqOga5fty15nXmaNcK1fsNMa.jpg","release_date":"2009-12-21","vote_average":5.653,"backdrop_path":"/3lf6YCItKcF3Wrrs7tp1PL0eyOT.jpg","original_title":"Alvin and the Chipmunks: The Squeakquel","original_language":"en"},{"id":279229,"adult":false,"title":"Sapphire Blue","video":false,"overview":"Gwen has just discovered, that she's the final member of the secret time-traveling Circle of Twelve. Now she has to juggle with constant trips to the past, her relationships with Gideon and figuring out dark secrets surrounding the Circle.","genre_ids":[14,10749,18],"media_type":"movie","popularity":3.1171,"vote_count":1020,"poster_path":"/kxRqokSkj6HWuwVCbnddPFg73CM.jpg","release_date":"2014-08-14","vote_average":7.106,"backdrop_path":"/y95HIJdesNQQaujZkGZczX7ejp2.jpg","original_title":"Saphirblau","original_language":"de"},{"id":11211,"adult":false,"title":"Bring It On: All or Nothing","video":false,"overview":"A transfer student at a rough high school tries joining the cheer-leading squad and finds that she not only has to face off against the head cheerleader, but also against her former school in preparation for a cheer-off competition.","genre_ids":[35],"media_type":"movie","popularity":0.2722,"vote_count":854,"poster_path":"/3UqEB9uR3z3BDxYFyn7YDZRLFZ6.jpg","release_date":"2006-07-18","vote_average":6.74,"backdrop_path":"/1C8aqNN4LG8RAOdWtj3HkeI3hhd.jpg","original_title":"Bring It On: All or Nothing","original_language":"en"},{"id":482408,"adult":false,"title":"Harry Potter: A History Of Magic","video":false,"overview":"A thrilling journey through legends, belief and folklore, this film goes behind the scenes with the British Library as they search to tell that story through objects in their collection, in an ambitious new exhibition: Harry Potter: A History Of Magic.  J.K. Rowling, who is lending unseen manuscripts, drawings and drafts from her private archives (which will sit alongside treasures from the British Library, as well as original drafts and drawings from Jim Kay) talks about some of the personal items she has lent to the exhibition and gives new insight into her writing, looking at some of the objects from the exhibition that have fired her imagination.","genre_ids":[99],"media_type":"movie","popularity":0.7651,"vote_count":94,"poster_path":"/kkzDng2S8w2hT1gap7MdMdx7uUE.jpg","release_date":"2017-10-28","vote_average":7.3,"backdrop_path":"/mjCYpJXCBYDZgMr1U1KZcFgFDfC.jpg","original_title":"Harry Potter: A History Of Magic","original_language":"en"},{"id":10829,"adult":false,"title":"Tremors 3: Back to Perfection","video":false,"overview":"Survivalist Burt Gummer returns home to Perfection, to find that the little town has been shaken up again by morphing, man-eating Graboids.","genre_ids":[28,35,27,878,53],"media_type":"movie","popularity":1.7752,"vote_count":690,"poster_path":"/mnMryfLgC2fuW3nfY36QfWx0hBL.jpg","release_date":"2001-10-02","vote_average":5.794,"backdrop_path":"/yoq6WVqA2kB8nDNG0xX16kPBvfB.jpg","original_title":"Tremors 3: Back to Perfection","original_language":"en"},{"id":15969,"adult":false,"title":"The Return of Jafar","video":false,"overview":"The evil Jafar escapes from the magic lamp as an all-powerful genie, ready to plot his revenge against Aladdin. From battling elusive villains atop winged horses, to dodging flames inside an exploding lava pit, it's up to Aladdin - with Princess Jasmine and the outrageously funny Genie by his side - to save the kingdom once and for all.","genre_ids":[10751,12,16,10749],"media_type":"movie","popularity":2.6043,"vote_count":3421,"poster_path":"/7SC793qtORB6YL4mu0F5o3hfjDQ.jpg","release_date":"1994-12-15","vote_average":6.2,"backdrop_path":"/mOOJm3tamy9iHg2mOEA77CM6ufZ.jpg","original_title":"The Return of Jafar","original_language":"en"},{"id":41233,"adult":false,"title":"Step Up 3D","video":false,"overview":"A tight-knit group of New York City street dancers, including Luke and Natalie, team up with NYU freshman Moose, and find themselves pitted against the world's best hip-hop dancers in a high-stakes showdown that will change their lives forever.","genre_ids":[18,10749],"media_type":"movie","popularity":3.4234,"vote_count":1970,"poster_path":"/rPcqa5TZ7S63RNmCuY45ZizFBen.jpg","release_date":"2010-08-04","vote_average":6.818,"backdrop_path":"/fboRjKzLF62ONXXen4e7D0msqTW.jpg","original_title":"Step Up 3D","original_language":"en"},{"id":463520,"adult":false,"title":"The Return","video":false,"overview":"The Return is a 2016 documentary directed by Emmy Award winning director Erich Joiner chronicling Ford GT's return to 24 Hours of Le Mans after their 1966 1-2-3 victory.","genre_ids":[99,28],"media_type":"movie","popularity":0.1957,"vote_count":93,"poster_path":"/ROvTxTwcCN8CyxrV4Rhun9MhYD.jpg","release_date":"2017-06-15","vote_average":6.6,"backdrop_path":"/bOTts5qHl3qiRUpsGYcwVYuOQ1H.jpg","original_title":"The Return","original_language":"en"},{"id":14873,"adult":false,"title":"The Jungle Book 2","video":false,"overview":"Mowgli has been living in the man-village with his little stepbrother Ranjan and his best friend Shanti. But the man-cub still has that jungle rhythm in his heart, and he misses his old buddies Baloo and Bagheera. When Mowgli wanders back to the wild for some swingin' fun, he soon finds the man-eating tiger Shere Khan is lurking in the shadows and planning his revenge.","genre_ids":[10751,16,12],"media_type":"movie","popularity":2.399,"vote_count":1181,"poster_path":"/21GanxizOIL1CN0HLx7j3je8k87.jpg","release_date":"2003-02-07","vote_average":5.893,"backdrop_path":"/bMcXBBkLHgh60Z8OnpIX4GdMN6m.jpg","original_title":"The Jungle Book 2","original_language":"en"},{"id":55301,"adult":false,"title":"Alvin and the Chipmunks: Chipwrecked","video":false,"overview":"Playing around while aboard a cruise ship, the Chipmunks and Chipettes accidentally go overboard and end up marooned in a tropical paradise. They discover their new turf is not as deserted as it seems.","genre_ids":[35,14,10751,10402,16],"media_type":"movie","popularity":3.7151,"vote_count":2316,"poster_path":"/npOXWVoZyl8UrF2wtByHtfmsWSX.jpg","release_date":"2011-12-14","vote_average":5.697,"backdrop_path":"/iHDgL6vulhP9j8ygG47gnOEyybf.jpg","original_title":"Alvin and the Chipmunks: Chipwrecked","original_language":"en"}],"similar_content":[{"id":5174,"adult":false,"title":"Rush Hour 3","video":false,"overview":"After a botched assassination attempt, the mismatched duo finds themselves in Paris, struggling to retrieve a precious list of names, as the murderous crime syndicate's henchmen try their best to stop them. Once more, Lee and Carter must fight their way through dangerous gangsters; however, this time, the past has come back to haunt Lee. Will the boys get the job done once and for all?","genre_ids":[28,35,80],"popularity":6.5597,"vote_count":3615,"poster_path":"/mp9CzKxLa2i7yblMXUrzVfGqsCo.jpg","release_date":"2007-08-08","vote_average":6.483,"backdrop_path":"/ozsLB1HRCN6ZAmJN89pWtoiAwnb.jpg","original_title":"Rush Hour 3","original_language":"en"},{"id":5175,"adult":false,"title":"Rush Hour 2","video":false,"overview":"It's vacation time for Carter as he finds himself alongside Lee in Hong Kong wishing for more excitement. While Carter wants to party and meet the ladies, Lee is out to track down a Triad gang lord who may be responsible for killing two men at the American Embassy. Things get complicated as the pair stumble onto a counterfeiting plot. The boys are soon up to their necks in fist fights and life-threatening situations. A trip back to the U.S. may provide the answers about the bombing, the counterfeiting, and the true allegiance of sexy customs agent Isabella.","genre_ids":[28,35,80],"popularity":7.7866,"vote_count":4477,"poster_path":"/aBQf2vMiCINeVC9v6BGVYKXurTh.jpg","release_date":"2001-08-03","vote_average":6.754,"backdrop_path":"/vPJwn9pp5f58CqdaXU3eOSLoJkl.jpg","original_title":"Rush Hour 2","original_language":"en"},{"id":5503,"adult":false,"title":"The Fugitive","video":false,"overview":"Wrongfully convicted of murdering his wife and sentenced to death, Richard Kimble escapes from the law in an attempt to find the real killer and clear his name.","genre_ids":[28,53,18],"popularity":6.548,"vote_count":4674,"poster_path":"/b3rEtLKyOnF89mcK75GXDXdmOEf.jpg","release_date":"1993-08-06","vote_average":7.469,"backdrop_path":"/7WVRxZ7KZmzoHnUkAjnEFT4o6Dw.jpg","original_title":"The Fugitive","original_language":"en"},{"id":5470,"adult":false,"title":"Beowulf","video":false,"overview":"Beowulf is a wanderer who learns about a man-eating creature called Grendel, which comes in the night to devour warriors trapped at the Outpost. The Outpost is ruled by Hrothgar. He has a daughter, whose husband may have been murdered by the Outpost's master of arms.","genre_ids":[12,14,28,27],"popularity":0.9193,"vote_count":243,"poster_path":"/ktX5naCHfERaoDVaCUOITPIFrFd.jpg","release_date":"1999-03-31","vote_average":4.348,"backdrop_path":"/9bdTdaqxT2ZEVGZwXsMvG7410cT.jpg","original_title":"Beowulf","original_language":"en"},{"id":9103,"adult":false,"title":"The Quest","video":false,"overview":"Ghang-gheng, the ancient winner-take-all competition in which the deadliest fighters from around the world employ the most spectacular feats of martial arts skills ever displayed in order to win the prized Golden Dragon. But fighting prowess alone will not be enough for Chris to triumph over such daunting foes.","genre_ids":[28,12,18]