"/3lb8Ey02ez5YyNLA6NsmbSz5DfQ.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/wKqTPrR2zTp15p6kUKBxrM5Mt9y.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/5sHJwXD8eR30WN8HxmQV6mEoHrw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":2560,"height":1440,"file_path":"/tGb044NgQYQJr58fta5O3OB6SpQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":1.434},{"width":3840,"height":2160,"file_path":"/wQivPkRjRwDsUk9NL2H5F14GF8q.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":1.434},{"width":1920,"height":1080,"file_path":"/qScq6ZNmLVQ9BovqEDLJr7lVdTV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/cVd5jWij8YERFxL88D1R9XVxwzy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/jERxuINN7xlBNu7AfYyjypqjvy2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/b8o8Lp0vg3HBiYPOxBPHc05y9Ev.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/o0lBoLMYJtkFgDOTAwWmYIWHdD9.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/vYySr4TKcNcr3fa60xn2Ux77mK2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/4cHmKn3eG7KIpi7ipAU4KHSmpXc.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1980,"height":1113,"file_path":"/978ALxGu5TGwg06ffGnatmJkZ1D.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.779,"vote_average":0.958},{"width":1600,"height":900,"file_path":"/hdYBWhJLXrWJwPrNH1d34nKR5MU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":1600,"height":900,"file_path":"/tlV9dM8Ev9ZydIJuLzEdnyIDn53.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":1280,"height":720,"file_path":"/tvYXncceRs67Hu63ZemQrISOS9T.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/toTvLL9gJs6g12wY5pdjSrU5nTf.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/tSRgKE6x9iiibhjD3vNiLCBEQ3U.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/q9cmkjkK0IOT1d1pAGIU0JxTQEz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1081,"file_path":"/bdSGL60KX99g1PWt7Pondmd19fJ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.776,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/nYdZUbNPgrphcdZ6dr9diqp2fiI.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/pstB0q2QloZBU8csDurLwR0fYdN.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/gHmXht8qwuD5a4JlQlekFJUE4l0.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/6sRoTybWjN6Lush427TsB1DIHrp.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/3K57OmEEdmfChsgcvN4QgdbXQB4.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T04:15:53.386+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Elite Squad","runtime":115,"tagline":"On the streets of Rio only the elite survive","homepage":"http://www.tropadeeliteofilme.com.br/","overview":"In 1997, before the visit of the pope to Rio de Janeiro, Captain Nascimento from BOPE (Special Police Operations Battalion) is assigned to eliminate the risks of the drug dealers in a dangerous slum nearby where the pope intends to be lodged."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Tropa de elite - Gli squadroni della morte","runtime":0,"tagline":"","homepage":"","overview":"Rio De Janeiro 1997. Qualche mese prima della visita del Papa in Brasile. Il capitano Nascimento è un membro del Bope, la squadra speciale di 100 uomini nata a Rio per combattere i narcotrafficanti nelle favelas e impedire che la polizia comune, corrotta fino al midollo, lasci la città in balìa di se stessa. Nascimento è stanco di questa vita sempre al limite, ed ora che sta per diventare padre ha deciso di lasciare. Non prima, però, di aver trovato un sostituto all'altezza. I candidati più quotati sembrano essere le reclute Matias e Neto, proprio i due che Nascimento ha appena salvato dai guai durante una pericolosa incursione nelle favelas. Ora si tratta solo di scegliere. Un compito che si rivelerà per lui drammaticamente semplice."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Tropa de élite","runtime":114,"tagline":"En las calles de Río, solo la élite sobrevive.","homepage":"","overview":"Inspirada en hechos reales del Batallón de Operaciones Policiales Especiales (BOPE). En 1997, el capitán Nascimento tiene que encontrara su sucesor,  entre tanto continúa intentando limpiar las calles de Río de narcos y criminales antes de la llegada del Papa."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Tropa de Elite","runtime":115,"tagline":"Missão dada é missão cumprida.","homepage":"","overview":"Dois amigos de infância reencontram-se e tornam-se recrutas do BOPE, a polícia de elite do Rio de Janeiro. Ambos são honestos e íntegros, mas movidos por razões bastante pessoais. Ao mesmo tempo, o capitão da recruta procura discretamente um substituto para poder reformar-se da polícia e passar o resto dos seus dias com a família que negligenciou."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Elitní jednotka","runtime":100,"tagline":"Drsný, nekompromisní film z reálného života v dnešní Jižní Americe.","homepage":"","overview":"Drsný, nekompromisní film z reálného života v dnešní Jižní Americe. V roce 1997, těsně před návštěvou papeže v Riu de Janeiru, dostane speciální policejní jednotka příkaz zlikvidovat drogové dealery v městských chudinských čtvrtích. Kapitán Nascimento se snaží najít náhradníka k této akci, protože má těhotnou manželku a chce odejít z aktivní služby. Kamarádi Neto a Matias, kteří právě vstoupili do policejních řad, idealisticky věří ve spravedlnost a boj proti zločinu, ale vidí kolem sebe jen korupci a nekompetentnost. Osudy těchto tří policistů se začnou proplétat a každý z nich ví, že v ulicích Ria přežijí jen ti nejschopnější…"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Özel Tim","runtime":0,"tagline":"","homepage":"","overview":"1997 yılında papa Brezilya'ya bir ziyaret yapacaktır. Özel Polis Harekatları Birliği BOPE'ye Papa'nın ziyaretinden önce favelalardaki bir mahallenin temizlenmesi görevi verilir. Bu operasyonu yürütmekle görevli Yüzbaşı Nascimento, karısının hamile olduğunu öğrenince birliğinden ayrılmaya karar verir, ama önce kendi yerine geçmeye layık birini bulmalıdır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Troupe d'Élite","runtime":115,"tagline":"Dans l'enfer des favelas.","homepage":"","overview":"1997. Les milices armées liées au trafic de drogue contrôlent les favelas de Rio. Rongée par la corruption, la police n'intervient plus sur le terrain. Les forces d'élite du BOPE (Bataillon des opérations spéciales de police) sont livrées à elles-mêmes dans leur lutte sans merci contre les trafiquants. Mais le maintien de l'ordre a un prix : il est de plus en plus difficile de distinguer le bien du mal, de faire la différence entre l'exigence de justice et le désir de vengeance. Le Capitaine du BOPE Nascimento est en pleine crise : en plus de risquer sa vie sur le terrain, il doit choisir et former son successeur, dans l'espoir de quitter cette vie de violence et de rester auprès de son épouse, qui s'apprête à donner naissance à leur premier enfant. Neto et Matias, deux de ses recrues les plus récentes, sont amis d'enfance : l'un est un as de la gâchette, l'autre refuse de transiger sur ses idéaux."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Элитный отряд","runtime":113,"tagline":"","homepage":"","overview":"В 1997 году, перед визитом Папы Римского в Рио де-Жанейро, капитан Насцименто из БОПО (Батальона особых полицейских операций) получает задание устранить опасность, исходящую от наркоторговцев, действующих в опасных трущобах поблизости от резиденции Папы. Капитан Насцименто ищет человека, способного заменить его, так как жена капитана беременна, и он собирается оставить БОПО и стать наставником новобранцев. Тем временем, два друга-идеалиста Нето и Матиас начинают службу в военной полиции, рассчитывая стать честными полицейскими и бороться с криминалом. Однако они сталкиваются в военной полиции с коррупцией, недостатком профессионализма и бюрократическим идиотизмом. После серьёзного инцидента в Моро да Бабилония они решают вступить в ряды БОПО."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Elite Squad","runtime":115,"tagline":"","homepage":"","overview":"Nascimento jagt als Hauptmann einer Polizei-Eliteeinheit in den Favelas von Rio de Janeiro im Jahr 1997 Drogenbosse und Gangmitglieder. Nach der Geburt seines ersten Kindes will der Mann die Einheit verlassen, muss aber zuvor noch einen geeigneten Nachfolger finden. Zudem hat der Papst seinen Besuch in der Metropole angekündigt und will in Schussweite der brandgefährlichen Slums nächtigen. Nascimento hat also alle Hände voll zu tun, mit weisser Weste aus dem Schlamassel herauszukommen, und schreckt auch vor drastischen Mitteln nicht zurück."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"精英部队","runtime":0,"tagline":"在里约的街上只有精英才能生存","homepage":"","overview":"　　时1997年，教皇即将来此视察，高层要求纳斯西蒙（Wagner Moura 饰）所率领的这支精英部队在最短时间内肃清贫民窟内的毒品链。厌倦刀光血影的纳斯西蒙将心思放在了妻子和尚未出世的婴儿身上，他将任务交给了两个热血且充满理想的年青人——内图（Caio Junqueira 饰）和马提阿斯（André Ramiro 饰）。他们俩都不满警察队伍的腐败，决心在精英部队中大展身手……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Trope de Elite","runtime":115,"tagline":"","homepage":"","overview":"Två barndomsvänner blir poliser i staden Rio de Janeiro. Efter att ha funderat på att antingen läsa på högskola eller fortsätta sina polisjobb väljer de att söka till en speciell piketstyrka vars uppgift är att ta död på drogproblemen i staden. Påven ska komma på besök, hans logi ligger bara något kvarter från de problematiska slummen, läget är akut."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Elitarni","runtime":118,"tagline":"Na ulicach Rio przeżyją tylko najlepsi.","homepage":"","overview":"Jest rok 1997, do Rio de Janeiro ma przylecieć Papież Jan Paweł II. Przełożeni wyznaczają kapitanowi Nascimento (Wagner Moura) - należącego do oddziałów specjalnych policji, eliminację dilerów ze slumsów. Kapitan bardzo angażuje się w zadanie, jednocześnie pragnąc odejść ze służby, gdyż żona spodziewa się dziecka i naciska na niego, żeby ten odszedł z policji. Nascimento jest zmuszony znaleźć godnego sobie następcę. Potencjalnymi kandydatami zostają dwaj przyjaciele z dzieciństwa: skrupulatny, ale też lekko wybuchowy Neto (Caio Junqueira), a także spokojny Matias (André Ramiro). Obydwaj dopiero co wstąpili do służby."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Elit halálosztók","runtime":118,"tagline":"Nincs szabály. Nincs irgalom. Nincs kiút.","homepage":"","overview":"Két gyerekkori jó barát úgy dönt, hogy csatlakozik a Rio De Jaineróban működő katonai rendőrség alakulatához. Miután mindketten hamar belerázódnak a kemény mindennapokba, egy speciális alakulat létrehozásába fognak, hogy a helyi kábítószer kereskedők méregfogait kihúzzák. Tervük véghezvitele sokkal nehezebb, mint gondolnák - rengeteg életveszélyes helyzetből kell kimászniuk, hogy felszámolják a maffia örökösen újjáformálódó hálózatát."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Eliittijoukot","runtime":115,"tagline":"","homepage":"","overview":"Kaksi juuri poliisikoulutuksen läpäissyttä nuorta miestä joutuu keskelle Rio de Janeiron slummeissa riehuvaa huumesotaa. Siellä murhat, jengien välienselvittelyt ja poliisin liiallinen voimankäyttö ovat arkipäivää. Tulokkaiden idealismi karisee nopeasti, ja ystävysten on tehtävä oma valintansa korruption ja ihanteiden välillä. Valinta uhkaa repiä hajalle lapsuudesta saakka kestäneen ystävyyden..."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"1997. Kapitein Nascimento van de BOPE krijgt te horen dat hij moet stoppen met werken vanwege de risico's die gepaard gaan met zijn werk en hij de aankomende geboorte van zijn eerste kind niet wil missen. Voordat hij definitief kan ophouden met het werk moet hij eerst voor een vervanger zorgen. Tegelijkertijd concentreert de film zich op twee jeugdvrienden, \"Matias\" en \"Neto\", die kadetten bij de militaire politie worden, maar wanhopig worden van de omringende corruptie. Wanneer het pad van Nascimento met die van Matias en Neto kruist hoopt hij in een van de twee een opvolger te vinden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Οι Επίλεκτοι","runtime":0,"tagline":"","homepage":"","overview":"Βασισμένo σε αληθινά γεγονότα, το Tropa de Elite αποκαλύπτει το τεράστιο και σύνθετο δίκτυο διαφθοράς του Ρίο Ντε Τζανέιρο. Η ταινία περιγράφει την ιστορία δύο νέων αστυνομικών, του Νέτο και του Ματίας, οι οποίοι είναι φίλοι από παιδιά. Ο ένας ονειρευόταν από μικρός να ασχοληθεί με την απονομή δικαιοσύνης, ενώ ο άλλος έχει ως κίνητρό του την αστική αναδόμηση. Ο ένας θα υποκύψει στις άγριες και διεφθαρμένες διαθέσεις της ομάδας και ο άλλος θα αγωνιστεί για να διατηρήσει τις ιδέες του. Πέρα από την ιστορία των δύο αντρών, η ταινία ρίχνει μια διεισδυτική ματιά στην άγνωστη, μέχρι σήμερα, πλευρά της ζωής στις περιβόητες φαβέλες του Ρίο, από την οπτική της αστυνομίας."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"יחידת עילית","runtime":0,"tagline":"","homepage":"","overview":"בשנת 1997, לפני ביקור האפיפיור בריו-דה-ז'נרו (ברזיל), קפטן נסקימנטו מהגממ\"מ (גדוד מבצעי משטרתי מיוחד) מונה לחסל את הסיכונים של סוחרי הסמים בשכונת עוני מסוכנת ליד המקום שבו האפיפיור מתכוון להתאכסן. קפטן נסקימנטו מנסה למצוא אדם שיחליף אותו מפני שאשתו בהריון והוא מתכוון להתפטר מהפיקוד ולהפוך להיות מתאמן בחיילים המתגייסים. בינתיים, שני החברים האידיאליסטים נטו ומטיאס מצטרפים לחייל המשטרה הצבאית בכוונה להיות אנשי משטרה הגונים ולהילחם בפשע. אולם, הם רואים רק שחיתות, אנשים חסרי כושר וביורוקרטיה מטופשת במשטרה הצבאית, ואחרי תקרית רצינית, הם מחליטים להצטרף לגממ\"מ. החיים של קפטן נסקימטו, נטו ומטיאס משתלבים בין החודשים, בהתחלה בתקופת האימונים הקשים ואחר כך בפעולה נגד סוחרי סמים. נסקימנטו מאמין שנטו יכול להיות המחליף שלו, אבל ההתייחסות האימפולסיבית שלו מסכנת את ההחלטה שלו. אחר כך, מטיאס הנבון נראה כבחירה הנכונה, אבל הוא צריך להוכיח שיש לו לב."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Trupa de Elită","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":115,"tagline":"Missão dada é missão cumprida.","homepage":"","overview":"Rio de Janeiro, 1997. Nascimento, capitão da Tropa de Elite do Rio de Janeiro, é designado para chefiar uma das equipes que tem como missão \"apaziguar\" o Morro do Turano por um motivo que ele considera insensato. Mas ele tem que cumprir as ordens enquanto procura por um substituto. Sua mulher, Rosane, está no final da gravidez e todos os dias lhe pede para sair da linha de frente do batalhão. Pressionado, o capitão sente os efeitos do estresse.Neste clima, é chamado para mais uma emergência num morro. Em meio a um tiroteio em um baile funk, Nascimento e sua equipe têm que resgatar dois aspirantes a oficiais da PM: Neto e Matias. Ansiosos por entrar em ação e impressionados com a eficiência de seus salvadores, os dois se candidatam ao curso de formação da Tropa de Elite."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Елітний загін","runtime":0,"tagline":"","homepage":"","overview":"Капітан Насцименто збирається відійти від активних операцій і зайнятися тренуванням молодих поліцейських. Але для цього потрібно знайти собі заміну для служби в БОПО (батальйон особливих поліцейських операцій). Один з двох молодих і наполегливих поліцейських Нето і Матіаса зможе стати підходящим кандидатом. Але перед цим всім трьом необхідно зануритися в морок нетрів, щоб знешкодити наркоторговців напередодні візиту в Ріо Папи Римського."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"엘리트 스쿼드","runtime":115,"tagline":"","homepage":"","overview":"1980년대 중반 폴란드 출신 교황 바오로 6세가 브라질 리우데자네이로에 세 번째 방문을 하는데 하필 유명한 슬럼가 favela 역의 한 호텔에 묵는다고 고집을 피운다. 국민의 95% 이상이 천주교인이기 때문에 교황이 위태로워져서도 안되고 한 방의 총소리도 근처에서 들리지 않게 하기 위해 브라질 정부는 몸살이 난다.  교황방문 6개월 전, 극심한 부패로 경외와 경멸을 동시에 받으며 경찰 위신은 바닥에 떨어져 있는 상태에 언제 어디서 총을 맞을지 모르는 이 지역에 두 명의 경찰 신참이 들어오는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Filmen handler om kampen mellem narkokartellerne og politiets elitestyrke i Favelas – de berygtede slumområder i verdens farligste by, Rio de Janeiro, og beskriver 'Tropa de Elita', et ubestikkeligt elitekorps af politifolk, der ikke alene skal holde styr på de uendeligt mange narkopushere i Rio de Janeiros slum, men også skal holde øje med korrupte politifolk, og dem er der, ifølge filmen, betydeligt flere af, end der er renfærdige kolleger. Tropa de Elita er blevet en stor succes i hjemlandet, hvor det mildt sagt indignerede billede af politiet i Rio de Janeiro har skabt en stor politisk velvilje til at rydde op i korruptionen."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Elites vienība","runtime":0,"tagline":"","homepage":"","overview":"Riodežaneiro policijas kapteinis saņem pavēli \"iztīrīt\" rajonu pie Romas pāvesta rezidences no narkodīleriem. Kapteinim tas būs pēdējais uzdevums specvienībā, tādēļ viņš meklē uzticamu cilvēku, kas viņu varētu aizstāt."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"精銳部隊","runtime":0,"tagline":"","homepage":"","overview":"本片曾獲柏林影展金熊獎，以1997年巴西里約熱內盧為故事背景。巴西本土票房累積收益，突破千萬美金大關 。貪污腐敗的巴西，警察個個以權謀私，無法無天的毒販霸據整個貧民窟，導致黑白兩道利益輸送關係錯綜複雜。直到教宗即將造訪，精銳部隊隊長納西門圖奉命橫掃貧民窟毒梟。速戰速決以換取短暫的和平，取勝的捷徑，就是以暴制暴。 一場爆發在即的浴血戰，令將為人父而不願涉入火線的納西門圖陷於極度焦慮，於是乎，他必須先迅速訓練出最有能力擔下重任的接班人。在BOPE地獄特訓營，最有潛質的接班人選就包括崇尚暴力以終結犯罪的的尼度，以及不斷掙扎於正義信念與現實之間的馬提亞斯，這兩個同樣傑出的菜鳥，順理成章成了納西門圖心目中理想的人選。但烽火連天的里約熱內盧，保住自己的性命要緊？還是睹上一命奮力投身虛有其表的掃毒任務呢？ 本片露骨地呈現出警里約熱內盧嚴重的警察操守與種族歧視問題，諸多寫實的貧民窟景象，讓人觸目心驚，導演荷西柏迪夏(Jose Padilha)曾以《裡約公車174路》獲得慕尼黑影展獎項。他語重心長地說：「在裡約，沒有善惡二分法，我只看得到灰色。」擬真的手法加上凌厲敏快的剪接，震撼性十足，亦發人省思。 菁英部隊，Elite Squad，精英部隊1，Tropa de Elite"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Елитен отряд","runtime":114,"tagline":"","homepage":"","overview":"Двама дългогодишни приятели решават да постъпят във военната полиция на Рио Де Жанейро. Когато успяват да влязат в Елитния Отряд от специално обучавани войници, те са изправят пред мисия, чиято цел е залавяне на нарко бос, тероризиращ града. Докато двамата се борят за животите си, те са притиснати от напрежението в дома си и от войната, която водят на улицата."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Elitinis būrys","runtime":0,"tagline":"","homepage":"","overview":"Rio de Žaneiras, 1997 m. Elitinės komandos viršininkas Nasimento atsiduria keblioje situacijoje: jis paskiriamas vadovauti greitojo reagavimo būriui ir prižiūrėti skurdų, pagal džiunglių ir narkotikų baronų įstatymus gyvenantį rajoną. Bet tinkamų pasekėjų nėra. O dar žmona jam pagimdo kūdikį...\r Tačiau kartą Nasimento būrys išgelbsti du jaunus policininkus, ir šie, sužavėti komandos darbu, patys įstoja į elitinį būrį. Vienas jų stebina drąsa, kitas – protu. Jei tik Nasimento galėtų sujungti šias savybes į vieną, jis turėtų tobulą pasekėją."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Tropa de Élite","runtime":0,"tagline":"","homepage":"","overview":"Brasil, 1997. El capitán Nascimento (Wagner Moura) está al mando de un escuadrón del Batallón de Operaciones Policiales Especiales (BOPE), un cuerpo de élite de la policía de Río de Janeiro. Su misión es actuar en las favelas, en las que la policía, por miedo o por corrupción, no interviene. Nascimento quiere dejar su puesto, ya que está a punto de ser padre, pero antes necesita encontrar un sustituto adecuado. Con ese fin comienza a instruir a dos policías honestos y amigos desde la infancia: Neto, que es un hombre de acción, y Matías, que estudia Derecho porque cree en la ley. Juntos entrarán en el BOPE y cumplirán sus misiones hasta las últimas consecuencias."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"ელიტარული რაზმი","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Biệt Đội Tinh Nhuệ","runtime":0,"tagline":"","homepage":"","overview":"Bộ phim mô tả tình trạng tham nhũng, bạo lực và giết chóc chung quanh cuộc đấu tranh của đội cảnh sát đặc nhiệm của Rio de Janero chống lại các băng nhóm buôn lậu ma túy có trang bị vũ khí trong thành phố. Nhiều thập niên, thủ phủ người Nam Mỹ ở de Janeiro Rio, Brasil đã choáng váng với những vụ chết. Strewn khu ổ chuột bị thành sẹo bởi bạo lực và máu. Đều đặn là patrolled bởi những tốp thuốc điên mà có trận đánh lửa với cảnh sát thường căng ở ngoài lên trên những đường phố lớn chính và sự quay lại bình thường của những thường dân vào trong những tổn thất"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"エリート・スクワッド","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"精鋭暴隊","runtime":0,"tagline":"前軍警戳破毒品戰 真實駭人黑幕 激烈血戰震撼感官極限 非常部隊挑戰正邪底線 以終極暴力清洗血腥罪惡！","homepage":"","overview":"1997 年，巴西裏約熱內盧。警察貪汙腐敗，令佔據貧民窟的毒犯變得無法無天。由於教宗即將到訪，BOPE 精鋭部隊隊長 Nascimento 奉命深入 Turano 貧民窟掃蕩毒犯，誓要將毒梟、罪犯一網打盡。黑白兩道大戰一觸即發，精鋭部唯一取勝的途徑就是以暴易暴！這場極度危險的血戰令 Nascimento 陷於精神崩潰的邊緣，將為人父的他急於退下火線，但他必須先找到接班人。此時，兩名份屬好友的新紮警員加入了 BOPE 的地獄特訓營 - 熱血的 Neto 為人衝動，冷靜的 Matias 則優柔寡斷。他們中間誰有資格成為 Nascimento 的接班人？\r BOPE 和毒犯的終極大戰又會如何了斷？\r 一場死傷無數的血洗罪惡城戰役，就是行使公義的最佳諷刺……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Elitná jednotka","runtime":0,"tagline":"","homepage":"","overview":"V meste Rio de Janeiro je množstvo slumov, ktoré sú ovládané gangami drogových dílerov. Vlastnia zbrane, s ktorými s v iných krajinách bojuje vo vojnách a neváhajú ich použiť. Použitiu sily sa však nebráni ani kapitán Nascimento, veliteľ elitnej jednotky brazílskej polície, ktorý s nimi vedie vojnu už dlhé roky. Je krutá, vedie sa nevyberanými prostriedkami a Nascimento jej začína mať už dosť. Potrebuje však vychovať svojich nástupcov..."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Elite Squad","runtime":0,"tagline":"","homepage":"","overview":"ရီယို ဒီဂျနေယိုဆိုတာ ကမ္ဘာပေါ်မှာ အန္တရာယ်အများဆုံးမြို့တော်တွေထဲကတစ်ခုဖြစ်ပြီး၊ဆင်းရဲသားရပ်ကွက်တွေမှာဆိုရင် မူးယစ်ရာဇာတွေ၊ မူးယစ်ဂိုဏ်းသားတွေက မူးယစ်ရောင်းဝယ်ပြီး လက်နက်ကိုယ်စီကိုင်ကာအုပ်ချုပ်ပါတယ်။ ဒီကရဲတွေဆိုတာကလည်း အကျင့်ပျက်ခြစားကာ မူးယစ်ဂိုဏ်းတွေနဲ့ပေါင်းစားငွေညစ်ဖို့သာ ခြေဆန့်ပြီး မှုခင်းတိုက်ဖျက်ဖို့ဆိုရင်တော့ကိုယ့်နယ်မြေမှာဖြစ်တဲ့လူသေအလောင်းကို အခြားနယ်မြေကိုရွှေ့ပြီး မှုခင်းကျဆင်းရေးကို ဒီလိုစွမ်းဆောင်ကြသူတွေပါ။ ဒီလိုနေရာမျိုးမှာ ပစ်ကြခတ်ကြ ရဲတွေလည်း မထိန်းသိမ်းနိုင်ဖြစ်လာပြီဆိုရင် ဝင်ပါရသူတွေကတော့ တိုက်ပွဲဝင်အထူးတပ်ဖွဲ့ BOPEတပ်ဖွဲ့ပါပဲ။ ဒီတပ်ဖွဲ့ခေါင်းဆောင်ဖြစ်သူ နက်စီမန်တိုဟာဆိုရင် ဖခင်ဖြစ်တော့မှာမလို့ တပ်ဖွဲ့ကနေလူစားထိုးရှာပြီး အနားယူဖို့ပြင်ဆင်နေချိန်၊ဆင်းရဲသားရပ်ကွက်တွေကို ပုပ်ရဟန်းမင်းကြီးလာလည်မယ်ဆိုတော့ လုံခြုံရေးကို ဦးစားပေးကာစစ်ဆင်ရေးဆင်းလုပ်ဖို့ ပြင်ဆင်ရပါတော့တယ် အဲ့ဒီနောက်မှာတော့ ဒီဇာတ်ကားဟာ ဆုတံဆိပ်တွေများစွာရရှိထားတဲ့ ဘရာဇီး၊ ရီယီုရဲ့အခြေအနေတွေကိုမြင်တွေ့ရမယ့်အက်ရှင်ဇာတ်ကားကောင်းမို့လက်မလွှတ်တမ်းကြည့်ရှုလိုက်ပါဗျ။"},"name":"","iso_639_1":"my","iso_3166_1":"MY","english_name":"Burmese"},{"data":{"title":"Tropa d’elit","runtime":0,"tagline":"","homepage":"","overview":"Brasil, any 1997. El capità Nascimento està al comandament d’un esquadró del Batalló d’Operacions Policials Especials (BOPE), un cos d’elit de la policia de Rio de Janeiro. La seva missió és actuar en les favelas, en les que la policia per por o per corrupció, no intervé. Nascimento vol deixar el seu lloc, ja que és a punt de ser pare, però abans necessita trobar un substitut adequat."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"คนล้างคนเลว","runtime":0,"tagline":"","homepage":"","overview":"ก่อนเกษียณ เจ้าหน้าที่ตำรวจผู้หมดไฟจากรีโอเดจาเนโร ต้องหาผู้สืบทอดงานต่อที่ไว้วางใจได้ เพื่อให้ทำภารกิจสุดอันตราย"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Елитна јединица","runtime":0,"tagline":"","homepage":"","overview":"Међутим, они виде само корупцију, недостатак стручности и глупу бирократију и одлучују да се придруже капетану Наскименту у акцији против нарко дилера."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Elitni vod","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Elitna postrojba","runtime":0,"tagline":"Na ulicama Rija preživljavaju samo elitni.","homepage":"","overview":"Uoči papinog posjeta Riju de Janeiru, 1997. godine kapetan Nascimento iz posebne vojne jedinice dobiva zadatak suzbiti preprodavače droge iz favele koja se nalazi pored četvrti u kojoj bi papa trebao odsjesti. Istodobno, dvojica prijatelja, Neto i Matias, pridružuju se vojnoj policiji očekujući da će postati borci za pravdu i suzbijanje kriminala. Naime, oni u svojoj okolini vide samo korupciju i nedostatak stručnosti, a nakon teškog incidenta u faveli Morro da Babilônia odlučuju se pridružiti Nascimentovoj postrojbi. Sljedećih će se mjeseci njihovi životi ispreplesti, prvo u razdoblju teške vojne obuke, a potom u akcijama protiv preprodavača droge..."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"}],"reviews_tmdb":[{"id":"561272a1c3a3686814016662","url":"https://www.themoviedb.org/review/561272a1c3a3686814016662","author":"Andres Gomez","content":"Decent movie with lots of strongly violent action. It stands up because it is staged in Rio and created by Brazilians.\r\n\r\nThe plot is not very surprising but good enough.","created_at":"2015-10-05T12:52:49.757Z","updated_at":"2021-06-23T15:57:37.627Z","author_details":{"name":"Andres Gomez","rating":7,"username":"tanty","avatar_path":null}},{"id":"639ac7dda4af8f007d05bd93","url":"https://www.themoviedb.org/review/639ac7dda4af8f007d05bd93","author":"Filipe Manuel Neto","content":"$11","created_at":"2022-12-15T07:08:13.967Z","updated_at":"2022-12-15T07:08:14.046Z","author_details":{"name":"Filipe Manuel Neto","rating":8,"username":"FilipeManuelNeto","avatar_path":"/nidqITf735x9xxHfncXkT9BmOQ7.png"}},{"id":"6743e28ecc1d69986bd9c75c","url":"https://www.themoviedb.org/review/6743e28ecc1d69986bd9c75c","author":"Abrazilliancheeze","content":"**As a brazilian, i can approve this movie as relatable**\r\n\r\nAs a brazilian, this movie i can agree with. I love the drama, the action parts are good. But best of all, THE POLICE. In Rio de Janeiro, there are favelas that have drugs. THE WHOLE COUNTRY IS RUN BY CORRUPTION AND GREED. If you are portuguese, download the app called Globo and read the news. There are a bunch of cartels, gangs, and worst of all: MAFIAS. They've spread to the U.S. In Brazil, you cant trust the police, nor the government. The president of Brazil (bolconario or whatever his name is) got arrested for corruption because he stole from the government! This movie is relatable.","created_at":"2024-11-25T02:35:58.435Z","updated_at":"2024-11-25T16:00:27.214Z","author_details":{"name":"","rating":null,"username":"Abrazilliancheeze","avatar_path":null}}],"recommendations":[{"id":47931,"adult":false,"title":"Elite Squad: The Enemy Within","video":false,"overview":"After a bloody invasion of the BOPE in the High-Security Penitentiary Bangu 1 in Rio de Janeiro to control a rebellion of interns, the Lieutenant-Colonel Roberto Nascimento and the second in command Captain André Matias are accused by the Human Right Aids member Diogo Fraga of execution of prisoners. Matias is transferred to the corrupted Military Police and Nascimento is exonerated from the BOPE by the Governor.","genre_ids":[18,28,80],"media_type":"movie","popularity":1.6393,"vote_count":1994,"poster_path":"/c7yCrf3PTSdp6RMGktZQhzFcFFM.jpg","release_date":"2010-10-08","vote_average":7.828,"backdrop_path":"/tmowA51oykuOdiyqRCP0jGYU1mB.jpg","original_title":"Tropa de Elite 2","original_language":"pt"},{"id":8440,"adult":false,"title":"Carandiru","video":false,"overview":"When a doctor decides to carry out an AIDS prevention program inside Latin America’s largest prison: the Casa de Detenção de São Paulo - Carandiru, he meets the future victims of one of the darkest days in Brazilian History when the State of São Paulo’s Military Police, with the excuse for law enforcement, shot to death 111 people. Based on real facts and on the book written by Dráuzio Varella.","genre_ids":[18],"media_type":"movie","popularity":3.1432,"vote_count":594,"poster_path":"/kKAgIMwQWQ6u4s0c56XKSDX3vAs.jpg","release_date":"2003-03-21","vote_average":7.577,"backdrop_path":"/rhrBU761a5B4w7hhpA9og3fNBCH.jpg","original_title":"Carandiru","original_language":"pt"},{"id":20268,"adult":false,"title":"Last Stop 174","video":false,"overview":"Sandro was a boy who loved to sing rap, to kiss, to stare the statue of Christ the Redeemer and dreamed to go visit Copacabana. Growing up on streets, the story culminates at the infamous episode of 12th June 2000, when Sandro hijacked bus 174.","genre_ids":[18,80],"media_type":"movie","popularity":0.485,"vote_count":187,"poster_path":"/qvSZA7HIJMelYSaQ7ObBCylDnsX.jpg","release_date":"2008-10-24","vote_average":7.195,"backdrop_path":"/xhK1B9ilRCvOKdEs6JofFQj5JDf.jpg","original_title":"Última Parada 174","original_language":"pt"},{"id":11174,"adult":false,"title":"Pelle the Conqueror","video":false,"overview":"In the late 19th century, two Swedish emigrants, Lasse Karlsson and his son Pelle, arrive on the Danish island of Bornholm hoping to find work on a farm and save enough money to travel to the United States of America.","genre_ids":[18],"media_type":"movie","popularity":0.7101,"vote_count":156,"poster_path":"/oSsu4khg459yTR1sw4qjEC4LO5J.jpg","release_date":"1987-12-21","vote_average":7.26,"backdrop_path":"/dXUiiryxCk1QqvS9F4MhIAPjpF3.jpg","original_title":"Pelle Erobreren","original_language":"da"},{"id":598,"adult":false,"title":"City of God","video":false,"overview":"In the poverty-stricken favelas of Rio de Janeiro in the 1970s, two young men choose different paths. Rocket is a budding photographer who documents the increasing drug-related violence of his neighborhood, while José “Zé” Pequeno is an ambitious drug dealer diving into a dangerous life of crime.","genre_ids":[18,80],"media_type":"movie","popularity":8.1472,"vote_count":8021,"poster_path":"/k7eYdWvhYQyRQoU2TB2A2Xu2TfD.jpg","release_date":"2002-08-30","vote_average":8.427,"backdrop_path":"/uvitbjFU4JqvMwIkMWHp69bmUzG.jpg","original_title":"Cidade de Deus","original_language":"pt"},{"id":157354,"adult":false,"title":"Fruitvale Station","video":false,"overview":"Oakland, California. Young Afro-American Oscar Grant crosses paths with family members, friends, enemies and strangers before facing his fate on the platform at Fruitvale Station, in the early morning hours of New Year's Day 2009.","genre_ids":[18],"media_type":"movie","popularity":1.6849,"vote_count":1397,"poster_path":"/oXSy3nEKFtfw5iRxdG8ouEFAnxs.jpg","release_date":"2013-07-26","vote_average":7.355,"backdrop_path":"/u0nAnvRdzAGgDYLyfIbAUBDOcpb.jpg","original_title":"Fruitvale Station","original_language":"en"},{"id":1368,"adult":false,"title":"First Blood","video":false,"overview":"When former Green Beret John Rambo is harassed by local law enforcement and arrested for vagrancy, he is forced to flee into the mountains and wage an escalating one-man war against his pursuers.","genre_ids":[28,12,53,10752],"media_type":"movie","popularity":8.6105,"vote_count":6765,"poster_path":"/a9sa6ERZCpplbPEO7OMWE763CLD.jpg","release_date":"1982-10-22","vote_average":7.502,"backdrop_path":"/teCZlGivejMw4rVzyxBSYQNr6XI.jpg","original_title":"First Blood","original_language":"en"},{"id":516329,"adult":false,"title":"Antlers","video":false,"overview":"A small-town Oregon teacher and her brother, the local sheriff, discover a young student is harbouring a dangerous secret that could have frightening consequences.","genre_ids":[18,27,9648],"media_type":"movie","popularity":2.073,"vote_count":1207,"poster_path":"/cMch3tiexw3FdOEeZxMWVel61Xg.jpg","release_date":"2021-10-28","vote_average":6.222,"backdrop_path":"/10sdvlxjeTZNBxPg0PLl4CKU7v0.jpg","original_title":"Antlers","original_language":"en"},{"id":310569,"adult":false,"title":"The Second Mother","video":false,"overview":"After leaving her daughter Jessica in a small town in Pernambuco to be raised by relatives, Val spends the next 13 years working as a nanny to Fabinho in São Paulo. She has financial stability but has to live with the guilt of having not raised Jessica herself. As Fabinho’s university entrance exams approach, Jessica reappears in her life and seems to want to give her mother a second chance. However, Jessica has not been raised to be a servant and her very existence will turn Val’s routine on its head. With precision and humour, the subtle and powerful forces that keep rigid class structures in place and how the youth may just be the ones to shake it all up.","genre_ids":[18],"media_type":"movie","popularity":0.7881,"vote_count":769,"poster_path":"/u1tDQun2iJAzersd94S8P47WEOL.jpg","release_date":"2015-06-04","vote_average":8,"backdrop_path":"/9h5BsxRmxLAvASADo2VcTlTUdb0.jpg","original_title":"Que Horas Ela Volta?","original_language":"pt"},{"id":45317,"adult":false,"title":"The Fighter","video":false,"overview":"Boxer \"Irish\