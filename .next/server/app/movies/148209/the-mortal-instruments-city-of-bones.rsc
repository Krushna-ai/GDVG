1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/nAiEBnzFLaWBsat7lDDjQdgdrEq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/bQaKYkfS0GHv52LCxlsG71wdbYo.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/h8Xw59QnoOvEch7ndJglKY9j5ux.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/4pVEHW0D08K1pVqrAV82AbPfa1Q.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/8TDxqJfKyGyx2quC4SugJdS1SrI.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/ybfVrbxnnUHqp9D4NkT5RXSA8OY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/6ASkOQj7VXLLE8EO90xUG8W2Ojm.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/5QJO58x5xkeoaOxGCBqk2PT9LPW.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/iNxbmrXodokKgs0T4MAWc5fOwjt.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/aQY4afYiOKMbabhMIXf9yXTCc1K.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/yfgU0cNe93S8gqmPxDGKlKvBkhZ.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/ocrWNIyPKMigid18hLprfwzXoKk.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/wKwFwsWjS8q1goht4fp6EgfzsjU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/bLViXtZci8thkkfPRfNfJ4sKvEj.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:44:23.057+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":130,"tagline":"There is a world hidden within our own.","homepage":"https://www.sonypictures.com/movies/themortalinstrumentscityofbones","overview":"In New York City, Clary Fray, a seemingly ordinary teenager, learns that she is descended from a line of Shadowhunters — half-angel warriors who protect humanity from evil forces. After her mother disappears, Clary joins forces with a group of Shadowhunters and enters Downworld, an alternate realm filled with demons, vampires, and a host of other creatures. Clary and her companions must find and protect an ancient cup that holds the key to her mother's future."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Shadowhunters - Città di ossa","runtime":130,"tagline":"Siete stati scelti","homepage":"","overview":"Clary Fray è un'adolescente newyorkese che, in un locale, assiste ad un omicidio che solo lei sembra in grado di poter vedere. Più tardi, scopre che la madre viene rapita da un misterioso uomo chiamato Valentine, che è alla ricerca della cosiddetta Coppa Mortale. Catapultata quindi in un mondo di cui ignorava l'esistenza, in cui demoni, stregoni, vampiri, licantropi e altre creature leggendarie sono realtà, si affida agli Shadowhunters, guerrieri semi-angeli che le persone normali non possono vedere, per iniziare un viaggio alla ricerca della madre e alla scoperta di quell'universo di cui anche lei sembra far parte. Dopo aver scoperto verità nascoste sul suo passato e sui suoi antenati, si renderà conto di avere anche lei dei poteri. Nel mezzo di una battaglia tra forze che a fatica riesce a capire, continuerà quindi la sua corsa contro il tempo per salvare la madre prima che sia troppo tardi."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Cazadores de sombras: Ciudad de hueso","runtime":130,"tagline":"Hay un mundo oculto dentro del nuestro.","homepage":"","overview":"Clary Fray es una adolescente ordinaria de Brooklyn hasta la noche que conoce al misterioso chico de los tatuajes Jace, quién resulta ser un guerrero medio ángel conocido como cazador de sombras. Cuando Clary descubre que su madre Jocelyn ha sido raptada, desesperadamente espera que Jace pueda ayudarla. Después de entrar en un portal dorado que la transporta a través del tiempo y espacio en un latido de corazón, Clary se da cuenta que ella también tiene poderes para los cazadores de sombras. ¿Pero puede aprovecharlos a tiempo para salvar a su madre?"},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"The Mortal Instruments : La Cité des Ténèbres","runtime":130,"tagline":"Deux mondes vont s'affronter...","homepage":"","overview":"New York, de nos jours. Alors que sa mère est kidnappée par d'étranges créatures, Clary, 15 ans, est témoin d'un meurtre commis lors d'une soirée. Elle est terrifiée lorsque le corps de la victime disparait mystérieusement devant ses yeux... Elle découvre alors l'existence d'un monde obscur et parallèle et y fait la rencontre de Jace, un chasseur de vampires. Lorsqu'ils se retrouvent au milieu d'une guerre entre des forces démoniaques et la société secrète des chasseurs d'ombres, Jace lui viendra en aide. Elle jouera alors dans cette aventure un rôle qu'elle ne soupçonne pas."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"A végzet ereklyéi: Csontváros","runtime":130,"tagline":"Két világ csap össze.","homepage":"","overview":"Clary Fray egy fiatal tinédzserlány, akinek a különleges története egy diszkóban kezdődik. Szemtanúja lesz egy gyilkosságnak, csakhogy végül semmi bizonyíték nem marad, ráadásul az elkövetők nem is e világról származnak…"},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"圣杯神器：骸骨之城","runtime":0,"tagline":"","homepage":"","overview":"克拉蕾（莉莉·科林斯）原本是个平凡的布鲁克林女孩，有天她发现了一个神秘的男孩JACE（杰米·坎贝尔·鲍尔），JACE有很多纹身，是个半天使的混血战士，被称为“影子猎人”。克拉蕾的母亲被神秘组织绑架，她向JACE求助，但随后发现自己似乎也具有影子猎人的能力，她能凭借自己的力量救出母亲吗？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"The Mortal Instruments - Stad av skuggor","runtime":130,"tagline":"","homepage":"","overview":"På en nattklubb i New York blir Clary vittne till ett mord som begås av tre tonåringar som bär svärd och vars kroppar är täckta av märkliga tatueringar. Offrets kropp går upp i rök och Clary inser att det bara är hon som kan se mördarna. Dagen efter försvinner även hennes mamma spårlöst. Det visar sig att tonåringarna är Skuggjägare, ett släkte vilkas uppgift är att försvara mänskligheten mot demoner, och att Clarys mamma har burit på en hemlighet – även hon är en Skuggjägare."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Os Instrumentos Mortais: Cidade dos Ossos","runtime":130,"tagline":"Tu foste escolhido.","homepage":"","overview":"Na Nova Iorque contemporânea, Clary Fray, uma adolescente aparentemente normal, descobre que é descendente de uma linhagem de caça demónios, os Caçadores de Sombras, um grupo secreto de jovens guerreiros semi-anjos, envolvidos numa antiga batalha para proteger o nosso mundo dos demónios. Após o desaparecimento da sua mãe, Clary é forçada a unir-se a um grupo de Caçadores de Sombras, que lhe apresentam uma Nova Iorque perigosa e alternativa chamada Mundo-à-Parte, repleta de demónios, feiticeiros, vampiros, lobisomens e outras criaturas mortíferas."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":129,"tagline":"","homepage":"","overview":"Clary Fray denkt een doodgewoon tienermeisje uit New York te zijn. Dit verandert allemaal wanneer haar moeder wordt aangevallen en ontvoerd door een demon. Wanneer ze aan een zoektocht begint om haar moeder terug te vinden, doet ze ontdekkingen over haar afkomst en haar verleden. Deze ontdekkingen zullen haar toekomst gaan bepalen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Орудия смерти: Город костей","runtime":130,"tagline":"Миры столкнутся","homepage":"","overview":"Клэри Фрэй всегда считала себя самой обыкновенной девушкой, пока не выяснилось, что она — потомок древнего рода Сумеречных Охотников, тайной касты воинов-полуангелов, защищающих наш мир от демонов. Когда мама Клэри исчезает, девушка объединяется с Сумеречными охотниками, чтобы спасти ее. Так начинается ее опасное знакомство с иной реальностью, в которой существуют демоны, маги, вампиры, оборотни и другие смертоносные существа."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Chroniken der Unterwelt - City of Bones","runtime":130,"tagline":"Es gibt eine verborgene Welt, in unserer eigenen.","homepage":"","overview":"Gerade noch war Clary ein typischer Teenager mit familiären Kommunikationsstörungen und einer starken Bindung zu ihrem besten Freund Simon. Doch als Dämonen ihre Mutter entführen, entdeckt Clary eine unbekannte, gefährliche Welt und die Lüge ihres bisherigen Lebens. Von ihrem neuen Beschützer, dem Schattenjäger Jace, erfährt Clary, dass ihre Mutter sie nicht grundlos täuschte, sie dazu bestimmt ist, Dämonen zu jagen und den Schlüssel in sich trägt, mit ihren großen Kräften die geschwächten Schattenjäger wieder zu stärken."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Реликвите на смъртните: Град от кости","runtime":110,"tagline":"Друг свят дебне отвъд нашия","homepage":"","overview":"Ню Йорк, в наши дни. Привидно обикновената тийнейджърка Клери Фрей разбира, че е потомък на т. нар. Ловци на сенки - древна каста ангели воини, защитаващи света ни от силите на Злото. След изчезването на майка си, Клери е принудена да обедини сили с преследвача на сенки Джейс и неговите партньори Алек и Изабел, които ѝ разкриват тъмната страна на Ню Йорк и я въвеждат в една паралелна вселена, известна като Долната земя и обитавана от демони, магьосници, вампири, върколаци и други безмилостни кръвожадни изчадия..."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Θανάσιμα Εργαλεία: Πόλη των Οστών","runtime":130,"tagline":"Όλα όσα έχεις ακούσει είναι αληθινά.","homepage":"","overview":"Όταν η Κλέρι Φρέι πηγαίνει στο κλαμπ Πανδαιμόνιο στη Νέα Υόρκη, δεν περιμένει να βρεθεί μάρτυρας σε ένα φόνο. Πολύ λιγότερο μάλιστα ένα φόνο που διαπράττουν τρεις έφηβοι, καλυμμένοι με παράξενα σημάδια. Αυτή θα είναι η πρώτη συνάντηση της Κλέρι με τους Κυνηγούς των Σκιών, πολεμιστές ταγμένους στο ξεκλήρισμα των δαιμόνων που βρίσκονται στη γη - και τη διατήρηση της τάξης μεταξύ βρικολάκων και λυκανθρώπων. Είναι επίσης η πρώτη της συνάντηση με τον πανέμορφο πολεμιστή Τζέις. Μέσα σε 24 ώρες, η Κλέρι θα βρεθεί βαθιά μέσα στον κόσμο του Τζέις, όταν η μητέρα της εξαφανίζεται και η ίδια δέχεται επίθεση από ένα δαίμονα. Γιατί όμως να ενδιαφερθούν οι δαίμονες για μια συνηθισμένη θνητή όπως η Κλέρι; Και πώς απέκτησε ξαφνικά την Ενόραση; Οι Κυνηγοί των Σκιών είναι αποφασισμένοι να το μάθουν..."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Ölümcül Oyuncaklar: Kemikler Şehri","runtime":0,"tagline":"İki dünya çarpışacak.","homepage":"","overview":"Vampirler, kurtadamlar, periler, gerçek aşk ve aklınızı başınızdan alacak daha birçok şey. Ölümcül Oyuncaklar hafızanıza kazınacak. On beş yaşındaki Clary Fray, New York'ta Pandemonium Kulüp'e doğru yola çıktığında bir cinayete tanıklık edeceği hiç aklına gelmezdi. Hele ki bu cinayetin daha önce hiç görmediği acayip silahlara sahip tuhaf dövmeli üç genç tarafından işleneceğini hayatta düşünemezdi. Clary, polisi arayabileceğini biliyordu fakat ceset bir anda ortadan yok olunca ve canileri Clary'den başka kimse göremediği için durumu açıklamak pek kolay olmayacaktı. Clary'nin onları görebilmesine çok şaşıran katiller kendilerini Gölgeavcıları olarak tanıtacaktı. Yani dünyayı şeytanlardan arındırmaya ant içmiş gizli bir kabile."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Dary Anioła: Miasto Kości","runtime":130,"tagline":"Odkryj swoje przeznaczenie","homepage":"","overview":"Ekranizacja światowego bestsellera, będącego pierwszą częścią serii sprzedanej w Polsce w ilości ponad 100 tysięcy egzemplarzy. Otwórz wrota do innego świata. Współczesny Nowy Jork. Zwyczajna na pozór nastolatka Clary Fray przypadkiem odkrywa, iż należy do niezwykłej kasty Nocnych Łowców, pół aniołów, którzy toczą odwieczną walkę w obronie naszego świata przed atakami demonów. Wkrótce w tajemniczych okolicznościach znika matka dziewczyny. Clary przyłącza się do grupyy Nocnych Łowców i wkracza do alternatywnego podziemnego świata, zamieszkałego przez wampiry, wilkołaki, wiedźmy, wróżki i demony. Obdarzona wyjątkowym darem dziewczyna będzie musiała stanąć do walki nie tylko o życie matki, ale o bezpieczeństwo ludzkiej rasy, która żyje w nieświadomości nadciągającego zagrożenia…"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Nástroje smrteľníkov: Mesto kostí","runtime":129,"tagline":"Dva svety sa tretnú","homepage":"","overview":"Na prvý pohľad obyčajná dievčina odhalí tajomný, skrytý svet a postupne aj svoj mimoriadny osud. To však len do okamihu, keď odrazu začne vidieť zdanlivo nemožné a zároveň znepokojujúce veci. Rovnako znenazdania jedného dňa zmizne po zúrivom zápase jej mama. Keď sa Clary so svojím kamarátom Simonom pustia do pátrania po zmiznutej matke, začína odhaľovať temné tajomstvá a hrozby zo skrytého sveta Lovcov tieňov. Zároveň spoznáva bojovníkov, ktorí sú spolovice anjelmi, spolovice ľuďmi a ktorí už po celé stáročia ochraňujú ľudstvo pred silami zla. Obklopená démonmi, černokňažníkmi, vampírmi, vlkolakmi a ďalšími nadprirodzenými bytosťami zo sveta tieňov, sa Clary spojí s mladými Lovcami tieňov aby našli a zachránili tajomný prastarý pohár, ktorý je kľúčom k budúcnosti Clarinej matky. Clary je sama veľmi prekvapená, keď odhalí svoju odvahu a schopnosti, o ktorých ani netušila a vďaka ktorým je pre svojich démonických nepriateľov protivníkom, ktorého nemožno podceňovať."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Знаряддя смерті: Місто кісток","runtime":0,"tagline":"","homepage":"","overview":"Дія відбувається в сучасному Нью-Йорку, де, здавалося б, абсолютно звичайна дівчина Клері Фрей виявляє, що вона – нащадок древнього роду Сутінкових Мисливців, таємної касти воїнів-напівангелів, що з прадавніх часів захищають наш світ від демонів. Після зникнення своєї матері Клері повинна об'єднатися із Сутінковими Мисливцями, які відкривають їй небезпечний потойбічний світ Нью-Йорка, повний демонів, магів, вампірів, перевертнів і іншої нечисті."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"The Mortal Instruments: Dæmonernes By","runtime":130,"tagline":"","homepage":"","overview":"Clary Fray er en tilsyneladende ganske almindelig teenager, der helt tilfældigt opdager, at hun er efterkommer af en gammel slægt af Skyggejægere - en hemmelig klan af unge krigere, der kæmper en evig kamp for at beskytte menneskenes verden fra underverdenens dæmoner. Da Clarys mor pludselig forsvinder, må hun slutte sig til gruppen af Skyggejægere. Her møder hun Jace, som introducerer hende for en farlig og mystiske underverden - et sted fyldt med dæmoner, vampyrer, varulve og andre dødbringende skabninger."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"นักรบครึ่งเทวดา","runtime":0,"tagline":"","homepage":"","overview":"ดัดแปลงจากนิยายขายดีของ Cassandra Clare เป็นเรื่องราวเด็กหญิงคนหนึ่งชื่อว่า แคลลีย์ (รับบทโดย Lily Collins)  ได้พบกับเด็กหนุ่มประหลาดชื่อเจซ (รับบทโดย Jamie Campbell Bower) ที่บอกว่าตัวเขาเองเป็น นักล่าเงา ลูกครึ่งเทพ ครึ่งมนุษย์  มีหน้าที่คอยออกตามล่าและกำจัดพวกปิศาจจาก 173 ทั่วโลก ที่คนธรรมดาไม่สามารถมองเห็นได้ แล้วจู่ๆแม่ของแคลลีย์ ก็ถูกจับตัวไป  ที่สุดแล้วเธอก็ได้รู้ว่า เรื่องราวลึกลับที่เกี่ยวกับปีศาจบนโลกนี้ 173 ทั้งหมดที่เคยถูกเล่าขานมาเป็นเรื่องจริง  และแม่ของเธอก็มีเรื่องราวซับซ้อนเกี่ยวกับความเป็นมาของตัวเธอ เจซจึงพาแคลลีย์ไปยังเมืองโครงกระดูกเพื่อไขปริศนาลึกลับทั้งหมด"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Varjojen kaupungit: Luukaupunki","runtime":130,"tagline":"","homepage":"","overview":"Kun Clary Fray lähtee New Yorkin Pandemonium-yökerhoon, hän ei todellakaan odota joutuvansa todistamaan nuoren pojan murhaa – varsinkaan murhaa, jonka tekee kolme outoihin tatuointeihin verhottua ja merkillisiä aseita käyttävää nuorta. Lisäksi ruumiskin katoaa vielä jäljettömiin. Tapauksesta on hankala ilmoittaa poliisille, kun kukaan muu ei ole nähnyt tappajia eikä jäljellä ole mitään – ei edes veritahraa – jolla voisi todistaa pojan kuolleen. Vai oliko uhrina poika?"},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Mortal Instruments: Město z kostí","runtime":0,"tagline":"","homepage":"","overview":"Clary je obyčejná patnáctiletá holka, která žije v New Yorském Brooklynu se svou mámou. Má poklidný život jako ostatní, až do okamžiku, kdy se večer v klubu stane vražda a ona je jediná, která ji v zaplněném klubu vidí. Tělo zavražděného se navíc hned vypaří. Clary začne vidět to, co ostatní ne a slyšet to, co ostatní ne. Hned na to po náhlém a nevysvětlitelném zápase s podivným stvořením zmizí i její máma. Při pátrání po ní začíná Clary odhalovat temná tajemství o skrytém světě stínů, který odedávna existuje hned vedle toho našeho. Potkává bojovníky – Lovce stínů - napůl lidi a napůl anděly, kteří po staletí plní roli strážců a ochraňují lidstvo před dalšími obyvateli jejich světa. Před vlkodlaky, upíry a dalšími démony a silami zla. Tváří v tvář všem legendárním tvorům hrůzy se Clary přidává k Lovcům stínů a objevuje v sobě odvahu, sílu a schopnosti, o nichž neměla dosud nejmenší tušení."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"בני הנפילים: עיר של עצמות","runtime":0,"tagline":"אתם הנבחרים","homepage":"","overview":"קליירי פריי, נערה בת חמש-עשרה אשר יצאה לבלות במועדון לילה בניו יורק, אך היא לא חשבה שהיא תהיה עדה לרצח שבוצע ע\"י שלושה בני נוער מקועקעים שרק היא יכולה לראות אותם. זהו המפגש הראשון של קליירי עם בני הנפילים הידועים גם כציידי הצללים; כת לוחמים סודית שנשבעה להגן על האנושות מפני השדים החיים בקרבה. ביחד עם חברה הטוב סיימון ועם לוחם הצללים יפה התואר ג'ייס, קליירי עומדת לגלות שרחובות ניו יורק מלאים במכשפים, פיות, ערפדים ואנשי זאב אשר החיים בדו-קיום עם בני האדם. גם אמה של קליירי הייתה מעורבת פעם בעולם הצללים. על קליירי לפענח את סודות עברה או שאותו אחד שחטף את אמה, עלול לחטוף גם את קליירי."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"Os Instrumentos Mortais: Cidade dos Ossos","runtime":130,"tagline":"Há um mundo escondido dentro do nosso.","homepage":"","overview":"A vida de Clary muda completamente quando sua mãe é sequestrada e ela descobre, ao conhecer Jace, que é uma caçadora de sombras. Para salvar sua mãe, ela deve encontrar a Taça da Mortalidade, mas primeiro deve descobrir sua força interior."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"섀도우 헌터스: 뼈의 도시","runtime":0,"tagline":"“모탈잔에 따른 천사의 피를 마신 자! 악마사냥의 운명으로 다시 태어나리라!”","homepage":"","overview":"뉴욕의 평범한 소녀 클레리는 어느 날 제이스, 알렉, 이사벨을 만나게 되고, 자신이 그들과 같이 특별한 능력을 가진 섀도우 헌터임을 알게 된다. 뿐만 아니라 발렌타인이 세상을 지배하기 위해 찾고 있는 모탈잔의 행방이 봉인된 클레리의 기억 속에 있다는 비밀이 밝혀지는데…  인간세상과 다운월드, 두 세계를 구하기 위한 그들의 전쟁이 시작된다!"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Mirties įrankiai: Kaulų miestas","runtime":0,"tagline":"","homepage":"","overview":"Šiuolaikiniame Niujorke gyvena iš pažiūros paprasta paauglė Klerė Frei, tačiau jos gyvenimas akimirksniu apsiverčia. Kiek maištinga ir į meną linkusi raudonplaukė netikėtai tampa paslaptingo nužudymo liudininke – nukeliavusi su geriausiu draugu į naktinį klubą ji pamato ginkluotą trijulę. Tačiau tiek nusikaltimą, tiek žudikus, kurių kūnai išmarginti nepažįstamais ženklais, matė tik ji viena. Netikėta liudininkė sudomina paslapčia veikti besitikėjusius jaunuolius. Įvyksta lemtinga Klerės pažintis su tvirtu, žavingu ir kraują stingdančiu Džeisu. Paaiškėja, kad auksaplaukis drauge su bičiuliais priklauso jauniems kovotojams, turintiems angelų kraujo. Jie – Prieblandos medžiotojai, rizikuojantys gyvybėmis ir išeinantys į gatves grumtis su demonais, kad išlaikytų gėrio ir blogio balansą. Jau netrukus vienas iš demonų taikosi užpulti ir Klerę, kurią spėja išgelbėti tik Džeiso vikrumas."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Cazadores de sombras: Ciudad de hueso","runtime":130,"tagline":"","homepage":"","overview":"Clary Fray, una adolescente de Brooklyn, conoce una noche a Jace, un chico misterioso, lleno de tatuajes, que resulta ser un ángel guerrero que ejerce como cazador de sombras. Cuando raptan a la madre de Clary, la chica espera que Jace la ayude a liberarla. Después de entrar en un portal dorado, Clary se ve transportada a través del tiempo y del espacio, y descubre algo sorprendente sobre sí misma."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Caçadors d’ombres: Ciutat d’ossos","runtime":0,"tagline":"","homepage":"","overview":"Clary Fray és una adolescent ordinària de Brooklyn fins a la nit que coneix al misteriós noi dels tatuatges Jace, qui resulta ser un guerrer mig àngel conegut com a caçador d'ombres. Quan Clary descobreix que la seva mare Jocelyn ha estat raptada, desesperadament espera que Jace pugui ajudar-la. Després d'entrar en un portal daurat que la transporta a través del temps i espai en un batec de cor, Clary s'adona que ella també té poders dels caçadors d'ombres. Però pot aprofitar-los a temps per salvar a la seva mare?"},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"シャドウハンター","runtime":0,"tagline":"","homepage":"","overview":"あるクラブを訪れた少女クラリーは、そこで謎めいたジェイスという少年に遭遇する。彼は地下世界に潜む、吸血鬼、人狼、妖魔などを始末するシャドウハンターと呼ばれる一族の者であった。やがて、ジョイスは母ジョスリンもシャドウハンターである上に、強大な力を授けるとされる聖杯を隠し持っていることを知る。衝撃の事実に動揺する中、母が聖杯を狙う反逆者ヴァレンタインに拉致されてしまう。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Kaulu pilsēta","runtime":0,"tagline":"","homepage":"","overview":"Dodoties uz Ņujorkas klubu \"Pekle\", piecpadsmitgadīgajai Klerijai ne prātā nenāk, ka viņa kļūs par slepkavības liecinieci. Tā ir Klerijas pirmā tikšanās ar Ēnu Medniekiem un Džeiku.\"Kaulu pilsēta\" ir rakstnieces Kasandras Klēras plašu popularitāti ieguvušā bestsellera The Mortal Instruments pirmās daļas ekranizācija."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"魔都獵人：骸骨之城","runtime":0,"tagline":"妖．魔．人．狼 闖開凡間秘境 正邪陣營 破凶出世","homepage":"","overview":"克萊莉．費芮 (莉莉歌蓮絲) 是個平凡的少女，直到遇上神秘紋身男子傑斯 (佔美保華)：一個半人半天使、被稱為「闇影獵人」的戰士，她被迫走進另一個世界。克萊莉的媽媽被神秘人挾持，她希望傑斯能夠幫她拯救母親。克萊莉無意間發現自己與傑斯擁有相同的超能力，她必須加入「闇影獵人」，與一眾戰士對抗多個邪惡勢力，才能營救母親。\r 在戰鬥的過程中，眾人揭開克萊莉母親隱藏多年的驚世秘密，而且她擁有邪惡勢力全力追捕的強大武器 – 聖杯 (mortal cup)，輾轉落到身世癒來癒神秘迷離的克萊莉手中…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Инструменти смрти: Град костију","runtime":0,"tagline":"","homepage":"","overview":"Наизглед обична девојка Клери Фрај налети на надприродни свет када посети ноћни клуб Пандемонијум и на тежак начин сазна истину о своме пореклу.\r Зли демон јој отима мајку и она ће учинити све како би је спасила, пригрлиће своје крвно наследство и упустити се у авантуру већу од свега замисливог. Уз помоћ интригантног ловца на сенке у кога почиње да се заљубљује и свог најбољег пријатеља с којим не престаје да се свађа, она постаје особа за коју се њена мајка бојала да ће постати."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"天使聖物：骸骨之城","runtime":130,"tagline":"","homepage":"","overview":"本片改編自同名的美國青少年小說「天使聖物」系列的第一集「骸骨之城」，這部作品融合了人類、天使、吸血鬼和狼人等角色，找來《魔鏡，魔鏡》的莉莉柯林斯（著名歌手菲爾柯林斯之女）出飾女主角，華人演員高以翔也在片中飾演布魯克林大巫師。  在現代的紐約市，一名看起來十分常見的青少年Clary Fray（莉莉柯林斯飾），在一間酒吧外頭目睹了一件謀殺案，而兇手是三名有著特殊打扮的年輕人。可是無論是兇手還是被害者，除了Clary Fray自己之外，其他人都看不見那四個人..."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Skyggejegerne: Demonenes by","runtime":130,"tagline":"","homepage":"","overview":"Et mord begås på en nattklubb i New York av tre tenåringer utstyrt med sverd og kropper dekket av mystiske tatoveringer. Clary blir vitne til ugjerningen men offerets kropp går opp i røyk og hun ser ut til å være den eneste som kan se hva som skjer. Dagen etter forsvinner Clarys mor sporløst. Det viser seg at tenåringen og hennes mor er Skyggejegere. En slekt med oppgave å forsvare menneskeheten mot demoner. Plutselig åpnes en helt ny verden av demoner, vampyrer og varulver for Clary."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Vũ Khí Bóng Đêm: Thành Phố Xương","runtime":0,"tagline":"Bạn đã được chọn.","homepage":"","overview":"Nhân vật chính của phim là cô gái trẻ xinh đẹp Clary Fray. Cũng giống như bao nữ sinh đồng trang lứa khác, Clary sống yên bình cùng gia đình ở thành phố New York hoa lệ, sôi động. Một ngày, cô phát hiện ra khả năng đặc biệt của mình - nhìn thấy những thanh niên mang kiếm với trang phục kỳ lạ. Những người này đi khắp thành phố để tiêu diệt ma cà rồng, người sói, phù thủy đội lốt con người. Một buổi tối tình cờ, Clary đến vui chơi ở bar và vô tình trở thành nhân chứng vụ giết người do ba thiếu niên có hình xăm kỳ quái gây ra. Từ ngạc nhiên tới sững sờ, Clary phát hiện ra mình là một chiếc binh mang trong mình nửa dòng máu người thường, nửa dòng máu thiên thần và có tên gọi là “shadowhunter” (thợ săn bóng tối). Khi mẹ của Clary bị lũ quỷ bắt cóc để tìm chén thánh, cô gia nhập đội quân chiến binh chống lại thế lực xấu xa bảo vệ cho Trái Đất và tìm lại mẹ…"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Kronike podzemlja: Mesto kosti","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Instrumente mortale: Orașul oaselor","runtime":130,"tagline":"","homepage":"","overview":"O adolescentă dotată cu vedere supranaturală strânge o trupă de tineri hibrizi om-înger pentru a-și salva mama răpită de un necunoscut sinistru."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Surmav arsenal: Luude linn","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"Instrumentarij smrtnika: Grad od kostiju","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"La Cité des Ténèbres: la coupe mortelle","runtime":0,"tagline":"","homepage":"","overview":"Le jour de la mystérieuse disparition de sa mère, Clary Fray, une adolescente new-yorkaise, découvre qu'elle appartient à une confrérie millénaire de chasseurs de démons. La jeune fille apprend également qu'elle est la seule à connaître l'endroit où sa mère a caché une coupe aux pouvoirs magiques, convoitée par l'ex-amoureux de cette dernière, le machiavélique Valentine, un renégat mégalomane. Sa mémoire ayant été effacée, l'adolescente obtient l'aide des chasseurs de démons Jace, Alec et Isabelle pour retrouver la précieuse coupe puis délivrer sa mère. Par un concours de circonstances, Simon, le meilleur ami de Clary, prend part à l'équipée, bien qu'il ne possède aucun pouvoir surnaturel lui permettant de lutter contre les vampires, monstres démoniaques et autres loups-garous peuplant cet univers invisible au commun des mortels. Secrètement amoureux de Clary, qui l'a toujours considéré comme un frère, Simon se rebiffe quand elle s'éprend du séduisant et ténébreux Jace."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"","runtime":130,"tagline":"","homepage":"","overview":"Als haar moeder ontvoerd wordt door een gevaarlijk sujet, roept een tiener met onwereldse afkomst de hulp in van andere jonge half engelen-half mensen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"სიკვდილის იარაღი: ძვლების ქალაქი","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"ابزار های مرگبار : شهر استخوان‌ ها","runtime":130,"tagline":"","homepage":"","overview":"دختری نوجوان و معمولی اهل شهر نیویورک به نام کلاری فری ( لیلی کالینز ) پس از اینکه مادرش بطور ناگهانی مفقود می شود، متوجه حقیتی درباره خود می شود و آن اینکه وی در اصل نه یک انسان، بلکه عضو گروه جنگجویان نیمه انسان – فرشته هست که همواره در حال مبارزه با پلیدی ها به منظور دفاع از دنیا هستند. حال کلاری ..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"}],"reviews_tmdb":[{"id":"5340f8b40e0a2679bf001707","url":"https://www.themoviedb.org/review/5340f8b40e0a2679bf001707","author":"Per Gunnar Jonsson","content":"$11","created_at":"2014-04-06T06:48:20.623Z","updated_at":"2024-05-16T15:21:14.458Z","author_details":{"name":"Per Gunnar Jonsson","rating":6,"username":"Dark Jedi","avatar_path":null}},{"id":"561270c492514106150082ea","url":"https://www.themoviedb.org/review/561270c492514106150082ea","author":"Andres Gomez","content":"Bad and disjointed movie created at the warmth of Harry Potter and Hunger Games series. Only, this time doesn't work at all. Lot's of FX for an incoherent and boring story.\r\n\r\nWorst of all, no reason to call this episode \"City of Bones\" since it doesn't play a major role, at all. At least, not in the movie.","created_at":"2015-10-05T12:44:52.509Z","updated_at":"2021-06-23T15:57:37.618Z","author_details":{"name":"Andres Gomez","rating":5,"username":"tanty","avatar_path":null}},{"id":"66529229cb9d2f74f434b9e3","url":"https://www.themoviedb.org/review/66529229cb9d2f74f434b9e3","author":"ekaari","content":"I absolutely love this movie and I will die on this hill. Yes it's campy and a bit predictable, but it's light hearted, fun, and entertaining.\r\n\r\nThe acting isn't the best I've seen, but the casting is still perfect. It doesn't align perfectly with the books, but I don't think that scores against it.\r\n\r\n\r\nI've lost track of how many times I've rewatched it. 10/10 flawless","created_at":"2024-05-26T01:36:41.189Z","updated_at":"2024-05-26T19:18:03.372Z","author_details":{"name":"","rating":10,"username":"ekaari","avatar_path":"/uUaXEg0PVmSlMBjbFe0L0YWbvss.png"}}],"recommendations":[{"id":62764,"adult":false,"title":"Mirror Mirror","video":false,"overview":"After she spends all her money, an evil enchantress queen schemes to marry a handsome, wealthy prince. There's just one problem - he's in love with a beautiful princess, Snow White. Now, joined by seven rebellious dwarves, Snow White launches an epic battle of good vs. evil...","genre_ids":[12,35,10751,14],"media_type":"movie","popularity":3.6109,"vote_count":3252,"poster_path":"/4xiB9KTg6wCaA2OJw4pT44MJaau.jpg","release_date":"2012-03-15","vote_average":5.9,"backdrop_path":"/5YoGHani2oaNxRhFlqvnvoQsmBY.jpg","original_title":"Mirror Mirror","original_language":"en"},{"id":76285,"adult":false,"title":"Percy Jackson: Sea of Monsters","video":false,"overview":"In their quest to confront the ultimate evil, Percy and his friends battle swarms of mythical creatures to find the mythical Golden Fleece and to stop an ancient evil from rising.","genre_ids":[12,10751,14],"media_type":"movie","popularity":2.866,"vote_count":5312,"poster_path":"/tAu90qEpLqwqiZLsMqpaMVr55oN.jpg","release_date":"2013-08-07","vote_average":6.025,"backdrop_path":"/fvrGb6zfQaQ8RD9pC8o9vv1b7W2.jpg","original_title":"Percy Jackson: Sea of Monsters","original_language":"en"},{"id":59965,"adult":false,"title":"Abduction","video":false,"overview":"For many years, Nathan Harper has had the uneasy feeling that life with his family isn't quite what it seems. As he draws closer to uncovering the truth, he is hunted by assassins, forcing him to flee with his neighbor, Karen, the only person he can trust.","genre_ids":[53,28,9648],"media_type":"movie","popularity":3.4742,"vote_count":2989,"poster_path":"/d0TIDrwnMFVjg2EO4LsXQn1mbbc.jpg","release_date":"2011-09-22","vote_average":5.845,"backdrop_path":"/6wWIirFFZPQx7Lamh1iKMgbVezr.jpg","original_title":"Abduction","original_language":"en"},{"id":109491,"adult":false,"title":"Beautiful Creatures","video":false,"overview":"Ethan Wate just wants to get to know Lena Duchannes better, but unbeknownst to him, Lena has strange powers.  As Lena's 16th birthday approaches she might decide her fate, to be good or evil.  A choice which will impact her relationship forever.","genre_ids":[14,18,10749],"media_type":"movie","popularity":1.9013,"vote_count":2922,"poster_path":"/t7PWQHpJHb2ozALCfaPaC5aHxBs.jpg","release_date":"2013-02-13","vote_average":6,"backdrop_path":"/6eDiL5UvFBnbalrxzrLKbIKwg8t.jpg","original_title":"Beautiful Creatures","original_language":"en"},{"id":146227,"adult":false,"title":"Getaway","video":false,"overview":"Former race car driver Brent Magna is pitted against the clock. Desperately trying to save the life of his kidnapped wife, Brent commandeers a custom Ford Shelby GT500 Super Snake, taking it and its unwitting owner on a high-speed race against time, at the command of the mysterious villain holding his wife hostage.","genre_ids":[28,80],"media_type":"movie","popularity":1.0412,"vote_count":657,"poster_path":"/z4sEWm1ykf9WX5WJU4XMD4oI5sI.jpg","release_date":"2013-08-29","vote_average":5,"backdrop_path":"/7FmaBXCV2CS6pQn6g6irigk5c6J.jpg","original_title":"Getaway","original_language":"en"},{"id":111969,"adult":false,"title":"Stuck in Love","video":false,"overview":"An acclaimed writer, his ex-wife, and their teenaged children come to terms with the complexities of love in all its forms over the course of one tumultuous year.","genre_ids":[18,35,10749],"media_type":"movie","popularity":2.2316,"vote_count":1992,"poster_path":"/byic4VFVrpPyjDWK54CcsxYWW85.jpg","release_date":"2013-06-14","vote_average":7.377,"backdrop_path":"/so5jtbB00IiW3dKbeI5JTdGNmK2.jpg","original_title":"Stuck in Love","original_language":"en"},{"id":59859,"adult":false,"title":"Kick-Ass 2","video":false,"overview":"After Kick-Ass’ insane bravery inspires a new wave of self-made masked crusaders, he joins a patrol led by the Colonel Stars and Stripes. When these amateur superheroes are hunted down by Red Mist — reborn as The Mother Fucker — only the blade-wielding Hit-Girl can prevent their annihilation.","genre_ids":[28,12,80],"media_type":"movie","popularity":4.0802,"vote_count":6475,"poster_path":"/1go2A3gdQjaMuHWquybgoJlQRcX.jpg","release_date":"2013-07-17","vote_average":6.403,"backdrop_path":"/dHBYguQvCDa00GMoidNYa7IOD8y.jpg","original_title":"Kick-Ass 2","original_language":"en"},{"id":200727,"adult":false,"title":"Love, Rosie","video":false,"overview":"Since the moment they met at age 5, Rosie and Alex have been best friends, facing the highs and lows of growing up side by side. A fleeting shared moment, one missed opportunity, and the decisions that follow send their lives in completely different directions. As each navigates the complexities of life, love, and everything in between, they always find their way back to each other - but is it just friendship, or something more?","genre_ids":[10749,18,35],"media_type":"movie","popularity":4.6845,"vote_count":6444,"poster_path":"/8Mf9GgyNv5jjLAAPGsom9skH2Du.jpg","release_date":"2014-10-16","vote_average":7.8,"backdrop_path":"/rpsHpJj7FgnNBXhaO2KFthPwqH6.jpg","original_title":"Love, Rosie","original_language":"en"},{"id":72710,"adult":false,"title":"The Host","video":false,"overview":"A parasitic alien soul is injected into the body of Melanie Stryder. Instead of carrying out her race's mission of taking over the Earth, \"Wanda\" (as she comes to be called) forms a bond with her host and sets out to aid other free humans.","genre_ids":[28,12,878],"media_type":"movie","popularity":3.2518,"vote_count":4040,"poster_path":"/1mfIZw6WgkCX310eoe0Ys14c3Fi.jpg","release_date":"2013-03-22","vote_average":6.285,"backdrop_path":"/1bDa2d9VqqBQlk42Gduu37Rz1ob.jpg","original_title":"The Host","original_language":"en"},{"id":76170,"adult":false,"title":"The Wolverine","video":false,"overview":"Wolverine faces his ultimate nemesis - and tests of his physical, emotional, and mortal limits - in a life-changing voyage to modern-day Japan.","genre_ids":[28,878,12],"media_type":"movie","popularity":1.2367,"vote_count":10130,"poster_path":"/8lzmovtARDXnE7kTDOum02i6fXv.jpg","release_date":"2013-07-21","vote_average":6.429,"backdrop_path":"/bEAQfLTykGg232kJogBlxRYaRqU.jpg","original_title":"The Wolverine","original_language":"en"},{"id":174321,"adult":false,"title":"The English Teacher","video":false,"overview":"Small-town Pennsylvania schoolteacher Linda Sinclair balances her staid home life with an incredible passion for her subject. Then a former star pupil reenters her life after failing as a playwright in New York City. Seeing in his script the inspiration that she has always longed to instill in her students, this dyed-in-the-wool romantic enlists the help of long-suffering drama teacher Carl to mount the work as the high school’s next and riskiest production.","genre_ids":[35,18,10749],"media_type":"movie","popularity":1.4095,"vote_count":370,"poster_path":"/mF14chZNzgDRZffs8Wk8lPwdNQA.jpg","release_date":"2013-05-16","vote_average":5.545,"backdrop_path":"/rMrtoZfd0B0jDc1IW6r7MHELAtt.jpg","original_title":"The English Teacher","original_language":"en"},{"id":57201,"adult":false,"title":"The Lone Ranger","video":false,"overview":"The Texas Rangers chase down a gang of outlaws led by Butch Cavendish, but the gang ambushes the Rangers, seemingly killing them all. One survivor is found, however, by an American Indian named Tonto, who nurses him back to health. The Ranger, donning a mask and riding a white stallion named Silver, teams up with Tonto to bring the unscrupulous gang and others of that ilk to justice.","genre_ids":[28,12,37],"media_type":"movie","popularity":3.509,"vote_count":6075,"poster_path":"/yDuJGq8biNMW7zM3w95UaDJv0KG.jpg","release_date":"2013-07-03","vote_average":6.119,"backdrop_path":"/vHd8RTXTGFwexUC2Mj1HOgSy9J3.jpg","original_title":"The Lone Ranger","original_language":"en"},{"id":38117,"adult":false,"title":"Beastly","video":false,"overview":"A modern-day take on the \"Beauty and the Beast\" tale where a New York teen is transformed into a hideous monster in order to find true love.","genre_ids":[10749,14,18],"media_type":"movie","popularity":2.0285,"vote_count":2849,"poster_path":"/uSAXWZsSD0pE4HYVUiDgusnEyyl.jpg","release_date":"2011-01-21","vote_average":6.308,"backdrop_path":"/hU4OdICqRXj3JFnSJsrR0SJejZy.jpg","original_title":"Beastly","original_language":"en"},{"id":96936,"adult":false,"title":"The Bling Ring","video":false,"overview":"Inspired by actual events, a group of fame-obsessed teenagers use the Internet to track celebrities' whereabouts in order to rob their homes.","genre_ids":[18,80],"media_type":"movie","popularity":1.5182,"vote_count":3119,"poster_path":"/6yh55qCcdgPRJweDWM2CiEubJCL.jpg","release_date":"2013-06-12","vote_average":5.4,"backdrop_path":"/ouN0GyE7mtIT6wyJeilaggyvgNj.jpg","original_title":"The Bling Ring","original_language":"en"},{"id":46529,"adult":false,"title":"I Am Number Four","video":false,"overview":"A teenage fugitive with an incredible secret races to stay one step ahead of the mysterious forces seeking destroy him in this sci-fi action thriller. With three dead and one on the run, the race to find the elusive Number Four begins. Outwardly normal teen John Smith never gets too comfortable in the same identity, and along with his guardian, Henri, he is constantly moving from town to town. With each passing day, John gains a stronger grasp on his extraordinary new powers, and his bond to the beings that share his fantastic fate grows stronger.","genre_ids":[28,53,878,12],"media_type":"movie","popularity":4.0395,"vote_count":4889,"poster_path":"/2NrP3h3GEsrPXX60bmjKuYWAvl9.jpg","release_date":"2011-02-18","vote_average":6.179,"backdrop_path":"/zGKDR7bYPo14MXmzpj8c4AErhtt.jpg","original_title":"I Am Number Four","original_language":"en"},{"id":203739,"adult":false,"title":"Vampire Academy","video":false,"overview":"Rose, a rebellious half-vampire/half-human guardian-in-training and her best friend, Lissa -- a mortal, royal vampire Princess - have been on the run when they are captured and returned to St. Vladamirs Academy, the very place where they believe their lives may be in most jeopardy. Rose will sacrifice everything to protect Lissa from those who intend to exploit her from within the Academy walls and the Strigoi (immortal, evil vampires) who hunt her kind from outside its sanctuary.","genre_ids":[35,28,14],"media_type":"movie","popularity":1.7902,"vote_count":1803,"poster_path":"/cJZpKgiFfjDZ6L5aOJvbmDhsGqY.jpg","release_date":"2014-02-07","vote_average":6.321,"backdrop_path":"/ttb2OaMIWpuq8Y0bTIOSXlOvyEk.jpg","original_title":"Vampire Academy","original_language":"en"},{"id":1934,"adult":false,"title":"Shakespeare in Love","video":false,"overview":"Young William Shakespeare is forced to stage his latest comedy, 'Romeo and Ethel, the Pirate's Daughter', before it's even written. When lovely noblewoman Viola de Lesseps auditions for a role, they fall into forbidden love — and Shakespeare's play finds a new life (and title). As their relationship intensifies, the comedy soon transforms into tragedy.","genre_ids":[10749,36,35],"media_type":"movie","popularity":3.2575,"vote_count":3156,"poster_path":"/zdW7jdzPi4J9KZR3TyY2jn3Xh5e.jpg","release_date":"1998-12-11","vote_average":6.8,"backdrop_path":"/i16MjvM9YsQ85ejdB63gtGXDu4W.jpg","original_title":"Shakespeare in Love","original_language":"en"},{"id":68724,"adult":false,"title":"Elysium","video":false,"overview":"In the year 2159, two classes of people exist: the very wealthy who live on a pristine man-made space station called Elysium, and the rest, who live on an overpopulated, ruined Earth. Secretary Rhodes, a hard line government official, will stop at nothing to enforce anti-immigration laws and preserve the luxurious lifestyle of the citizens of Elysium. That doesn’t stop the people of Earth from trying to get in, by any means they can. When unlucky Max is backed into a corner, he agrees to take on a daunting mission that, if successful, will not only save his life, but could bring equality to these polarized worlds.","genre_ids":[878,28,18,53],"media_type":"movie","popularity":5.4902,"vote_count":9412,"poster_path":"/uiiXHBd9oUrtUa4YqZiAoy05cRz.jpg","release_date":"2013-08-07","vote_average":6.514,"backdrop_path":"/oo9GyiNKvR4CU1etuYl081UJ1LE.jpg","original_title":"Elysium","original_language":"en"},{"id":93837,"adult":false,"title":"So Undercover","video":false,"overview":"When the FBI hires her to go undercover at a college sorority, Molly Morris must transform herself from a tough, streetwise private investigator to a refined, sophisticated university girl to help protect the daughter of a one-time Mobster. With several suspects on her list, Molly unexpectedly discovers that not everyone is who they appear to be, including herself.","genre_ids":[28,35],"media_type":"movie","popularity":4.9857,"vote_count":1150,"poster_path":"/abR6e0FaWwwcEJEM4PY5VvjwBr1.jpg","release_date":"2012-12-06","vote_average":6.1,"backdrop_path":"/dFGbu1lJZFmiiGI5J9sQHAvhG5p.jpg","original_title":"So Undercover","original_language":"en"},{"id":175774,"adult":false,"title":"Ruby Red","video":false,"overview":"On her 16th birthday, Gwendolyn Shepherd finds out that instead of her cousin, she has inherited a rare gene that allows her to travel through time.","genre_ids":[14,18,10749],"media_type":"movie","popularity":1.6162,"vote_count":1140,"poster_path":"/lCfUO2be7jlskyTXRnf1bQtdIes.jpg","release_date":"2013-03-14","vote_average":6.943,"backdrop_path":"/6NZMN7XRb0TDRloST3P8T9W2z0W.jpg","original_title":"Rubinrot","original_language":"de"}],"similar_content":[{"id":8338,"adult":false,"title":"Blindness","video":false,"overview":"When a sudden plague of blindness devastates a city, a small group of the afflicted band together to triumphantly overcome the horrific conditions of their imposed quarantine.","genre_ids":[18,9648,878,53],"popularity":5.8895,"vote_count":1340,"poster_path":"/deBsx5IxyqCC217j3VY24TkkE0Z.jpg","release_date":"2008-05-14","vote_average":6.514,"backdrop_path":"/sN0czEtCT1jEFQVajWBsKwdFBKm.jpg","original_title":"Blindness","original_language":"en"},{"id":8844,"adult":false,"title":"Jumanji","video":false,"overview":"When siblings Judy and Peter discover an enchanted board game that opens the door to a magical world, they unwittingly invite Alan -- an adult who's been trapped inside the game for 26 years -- into their living room. Alan's only hope for freedom is to finish the game, which proves risky as all three find themselves running from giant rhinoceroses, evil monkeys and other terrifying creatures.","genre_ids":[12,14,10751],"popularity":3.3118,"vote_count":11122,"poster_path":"/vgpXmVaVyUL7GGiDeiK1mKEKzcX.jpg","release_date":"1995-12-15","vote_average":7.244,"backdrop_path":"/qSxeCfWUUyht9hZgaaYmtPtTkw2.jpg","original_title":"Jumanji","original_language":"en"},{"id":8871,"adult":false,"title":"How the Grinch Stole Christmas","video":false,"overview":"The Grinch decides to rob Whoville of Christmas - but a dash of kindness from little Cindy Lou Who and her family may be enough to melt his heart...","genre_ids":[10751,35,14],"popularity":5.4667,"vote_count":8163,"poster_path":"/1WZbbPApEivA421gCOluuzMMKCk.jpg","release_date":"2000-11-17","vote_average":6.8,"backdrop_path":"/sy0vo1cmpKqwPRiMUiJ45jyLsX7.jpg","original_title":"How the Grinch Stole Christmas","original_language":"en"},{"id":8512,"adult":false,"title":"Devil in a Blue Dress","video":false,"overview":"In late 1940s Los Angeles, Easy Rawlins is an unemployed black World War II veteran with few job prospects. At a bar, Easy meets DeWitt Albright, a mysterious white man looking for someone to investigate the disappearance of a missing white woman named Daphne Monet, who he suspects is hiding out in one of the city's black jazz clubs. Strapped for money and facing house payments, Easy takes the job, but soon finds himself in over his head.","genre_ids":[53,80,9648],"popularity":3.3593,"vote_count":444,"poster_path":"/5lcJhwKGavLbPva17QkTBhLfqEk.jpg","release_date":"1995-09-29","vote_average":6.45,"backdrop_path":"/n6SFCz0OsyZ800ZSlaD5WpNmqCj.jpg","original_title":"Devil in a Blue Dress","original_language":"en"},{"id":9920,"adult":false,"title":"Ultraviolet","video":false,"overview":"In the late 21st century, a subculture of humans have emerged who have been modified genetically by a vampire-like disease, giving them enhanced speed, incredible stamina and acute intelligence. As they are set apart from \"normal\" and \"healthy\" humans, the world is pushed to the brink of worldwide civil war  aimed at the destruction of the \"diseased\" population. In the middle of this crossed-fire is - an infected woman - Ultraviolet, who finds herself protecting a nine-year-old boy who has been marked for death by the human government as he is believed to be a threat to humans.","genre_ids":[878,28,53],"popularity":2.2128,"vote_count":1690,"poster_path":"/27OzQ2BBahQHYPiPEAXRXMbhnPQ.jpg","release_date":"2006-03-03","vote_average":5.224,"backdrop_path":"/dSMWw6rNIKqtHyWEIkDa8u7Mboa.jpg","original_title":"Ultraviolet","original_language":"en"},{"id":9922,"adult":false,"title":"The Postman","video":false,"overview":"In 2013, there are no highways, no I-ways, no dreams of a better tomorrow, only scattered survivors across what was once the United States. Into this apocalyptic wasteland comes an enigmatic drifter with a mule, a knack for Shakespeare, and something yet undiscovered: the power to inspire hope.","genre_ids":[878,12,28],"popularity":2.392,"vote_count":1166,"poster_path":"/piVzOuKFLHNGLxnjwNtibC26lTy.jpg","release_date":"1997-12-25","vote_average":6.25,"backdrop_path":"/5mwd1quVNkdwImOF2RGm90hKZ5P.jpg","original_title":"The Postman","original_language":"en"},{"id":9945,"adult":false,"title":"Vampires","video":false,"overview":"The church enlists a team of vampire-hunters to hunt down and destroy a group of vampires searching for an ancient relic that will allow them to exist in sunlight.","genre_ids":[28,14,27],"popularity":1.8494,"vote_count":1333,"poster_path":"/4JhaFBPwyC5IM1rKaRR07Gzutse.jpg","release_date":"1998-10-30","vote_average":6.311,"backdrop_path":"/uzlGbsQkpK6C3ZiqRqKw9CwK0Do.jpg","original_title":"Vampires","original_language":"en"},{"id":9954,"adult":false,"title":"The Covenant","video":false,"overview":"Four young men who belong to a supernatural legacy are forced to battle a fifth power long thought to have died out. Another great force they must contend with is the jealousy and suspicion that threatens to tear them apart.","genre_ids":[14,27,12,28],"popularity":2.4175,"vote_count":1077,"poster_path":"/skHRXm3m0BDp2E2uHkAWKT6OlQH.jpg","release_date":"2006-09-07","vote_average":5.6,"backdrop_path":"/vn9BFSlvwILE4wPUITi4XDD3fEK.jpg","original_title":"The Covenant","original_language":"en"},{"id":9978,"adult":false,"title":"Stormbreaker","video":false,"overview":"Alex Rider thinks he is a normal school boy, until his uncle is killed. He discovers that his uncle was actually spy on a mission, when he was killed. Alex is recruited by Alan Blunt to continue the mission. He is sent to Cornwall to investigate a new computer system, which Darrius Sayle has created. He plans to give the new computer systems to every school in the country, but Mr. Blunt has other ideas and Alex must find out what it is.","genre_ids":[12,28,10751],"popularity":1.1913,"vote_count":663,"poster_path":"/7uYi3be7gwoPMoIAi76vSd4Ci1i.jpg","release_date":"2006-07-21","vote_average":5.235,"backdrop_path":"/sWO8C8QlyodOZU6eOdVxsGfSQvv.jpg","original_title":"Stormbreaker","original_language":"en"},{"id":1260649,"adult":false,"title":"Jumanji 3","video":false,"overview":"The third film in the Jumanji reboot franchise. Plot TBA.","genre_ids":[14,12,35,28],"popularity":2.4557,"vote_count":0,"poster_path":null,"release_date":"2026-12-02","vote_average":0,"backdrop_path":null,"original_title":"Jumanji 3","original_language":"en"},{"id":9782,"adult":false,"title":"The Night Listener","video":false,"overview":"In the midst of his crumbling relationship, a radio show host begins speaking to his biggest fan—a young boy—via the telephone. But when questions about the boy's identity come up, the host's life is thrown into chaos.","genre_ids":[80,27,9648,53],"popularity":0.6324,"vote_count":283,"poster_path":"/xIQgviGRTxZ6o0iPooGUSn4Q1PW.jpg","release_date":"2006-02-12","vote_average":5.5,"backdrop_path":"/2hX2Ku8spIy8LrAbuBxAfjRQMpw.jpg","original_title":"The Night Listener","original_language":"en"},{"id":278927,"adult":false,"title":"The Jungle Book","video":false,"overview":"A man-cub named Mowgli fostered by wolves. After a threat from the tiger Shere Khan, Mowgli is forced to flee the jungle, by which he embarks on a journey of self discovery with the help of the panther, Bagheera and the free-spirited bear, Baloo.","genre_ids":[10751,12,14],"popularity":6.1651,"vote_count":8394,"poster_path":"/2Epx7F9X7DrFptn4seqn4mzBVks.jpg","release_date":"2016-04-07","vote_average":6.866,"backdrop_path":"/8oYykF1Qhrb8fC2qZqD71EzRywg.jpg","original_title":"The Jungle Book","original_language":"en"},{"id":278971,"adult":false,"title":"Angel in Training","video":false,"overview":"Thirteen-year-old Desi has two big problems: her cartoonist father is being duped by a sexy, money-hungry agent, and she needs to find a date for a friend's birthday party. An apprentice angel is sent to Earth to help Desi deal with the situation.","genre_ids":[14,10751],"popularity":0.2126,"vote_count":3,"poster_path":"/s5q0SRyAU1jfIUI3MajG3wHsqjo.jpg","release_date":"1999-04-13","vote_average":6,"backdrop_path":"/ua20xg7lNMA1azIuobJOBYkynUl.jpg","original_title":"Angel in Training","original_language":"en"},{"id":9838,"adult":false,"title":"King Solomon's Mines","video":false,"overview":"Ever in search of adventure, explorer Allan Quatermain agrees to join the beautiful Jesse Huston on a mission to locate her archaeologist father, who has been abducted for his knowledge of the legendary mines of King Solomon. As the kidnappers, led by sinister German military officer Bockner, journey into the wilds of Africa, Allan and Jesse track the party and must contend with fierce natives and dangerous creatures, among other perils.","genre_ids":[28,12,35],"popularity":1.4905,"vote_count":456,"poster_path":"/kpaW2gh0hjMPwoz30JL3gRKi2Ho.jpg","release_date":"1985-11-22","vote_average":5.419,"backdrop_path":"/aVgqxRQ8M8aJnfO1eUZEmNJSTxm.jpg","original_title":"King Solomon's Mines","original_language":"en"},{"id":9869,"adult":false,"title":"Patriot Games","video":false,"overview":"When CIA Analyst Jack Ryan interferes with an IRA assassination, a renegade faction targets Jack and his family as revenge.","genre_ids":[18,28,53,80],"popularity":2.5064,"vote_count":1776,"poster_path":"/9IT7gnszrRthduYxCLqaIkM55Un.jpg","release_date":"1992-06-04","vote_average":6.7,"backdrop_path":"/3YnJdVdCy7s2FvJoMpH4V2dEE3U.jpg","original_title":"Patriot Games","original_language":"en"},{"id":9871,"adult":false,"title":"Ginger Snaps","video":false,"overview":"The story of two outcast sisters, Ginger and Brigitte, in the mindless suburban town of Bailey Downs. On the night of Ginger's first period, she is savagely attacked by a wild creature. Ginger's wounds miraculously heal but something is not quite right. Now Brigitte must save her sister and save herself.","genre_ids":[14,27,18,53],"popularity":1.7818,"vote_count":966,"poster_path":"/ozohDiJd7Oi65NEf8B0ya7lR9Fr.jpg","release_date":"2000-08-10","vote_average":6.925,"backdrop_path":"/7GAgYVK29A4NADWhPbqC9c44X7P.jpg","original_title":"Ginger Snaps","original_language":"en"},{"id":1260794,"adult":false,"title":"Resurrection Road","video":false,"overview":"An elite squad of six Black soldiers, led by ex-slave Barabbas, have been sent on a suicide mission; to infiltrate a Confederate fort deep in the Arkansas woods and blow up its long-range guns, altering the course of the war.","genre_ids":[28,27,37],"popularity":0.462,"vote_count":8,"poster_path":"/x5KSZ4TXPKWTnQNdzHZFrlvy1t9.jpg","release_date":"2025-06-06","vote_average":4.9,"backdrop_path":"/AcLKdztolhIBySNuWZRLPYNzm8x.jpg","original_title":"Resurrection Road","original_language":"en"},{"id":279013,"ad