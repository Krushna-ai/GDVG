5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Pretty Woman\",\"description\":\"While working alone late at the office one night, Veronica is raped by a returning male colleague, who accidentally kills her in the process (she falls back and hits her head on a sharp object). Later that same evening, he comes across a bar hostess who looks identical to the woman that he has just murdered. He eventually talks her into showing up for work in Veronica's place on the very next day, and handing in her resignation. Unfortunately for him, she is persuaded to stay, and decides to continue impersonating the deceased secretary.\",\"image\":\"https://image.tmdb.org/t/p/w500/dvcarc7TMrRp1C3jXPpn7PKce99.jpg\",\"datePublished\":\"1991-12-06\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"cn\",\"genre\":[\"Comedy\",\"Crime\",\"Romance\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.1,\"bestRating\":10,\"ratingCount\":15}}"}}],["$","$L10",null,{"initialDrama":{"id":"4235a284-f24e-484f-b343-d6329051e739","tmdb_id":360731,"imdb_id":"tt0105196","content_type":"movie","title":"Pretty Woman","original_title":"Pretty Woman","overview":"While working alone late at the office one night, Veronica is raped by a returning male colleague, who accidentally kills her in the process (she falls back and hits her head on a sharp object). Later that same evening, he comes across a bar hostess who looks identical to the woman that he has just murdered. He eventually talks her into showing up for work in Veronica's place on the very next day, and handing in her resignation. Unfortunately for him, she is persuaded to stay, and decides to continue impersonating the deceased secretary.","poster_path":"/dvcarc7TMrRp1C3jXPpn7PKce99.jpg","backdrop_path":"/1V24ur6YTXcAEca0a6kKjq7zgrw.jpg","release_date":"1991-12-06","first_air_date":null,"status":"publish