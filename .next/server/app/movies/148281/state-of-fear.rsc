so_639_1":"uk","iso_3166_1":"UA","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T05:55:47.996+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":0,"tagline":"Quando a violência vira caos, só os fortes sobrevivem.","homepage":"https://www.netflix.com/br/title/81758092","overview":"Durante uma onda de violência sem precedentes em São Paulo, uma advogada ligada ao crime precisa fazer um acordo com a polícia para resgatar a sobrinha sequestrada."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"State of Fear","runtime":103,"tagline":"","homepage":"https://www.netflix.com/title/81758092","overview":"As São Paulo erupts in an unprecedented wave of violence, a lawyer with underworld ties must strike a deal with the police to rescue her kidnapped niece."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Brotherhood: Angstzustand","runtime":104,"tagline":"","homepage":"https://www.netflix.com/de/title/81758092","overview":"Inmitten einer Welle der Gewalt muss eine Anwältin in São Paulo mit Verbindungen zur Unterwelt einen Deal mit der Polizei machen, um ihre entführte Nichte zu retten."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"L'Appel du chaos","runtime":0,"tagline":"","homepage":"https://www.netflix.com/fr/title/81758092","overview":"Alors qu'une vague de violence sans précédent secoue São Paulo, une avocate liée au milieu criminel doit négocier avec la police pour sauver sa nièce qui a été enlevée."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Hermandad: Estado de terror","runtime":0,"tagline":"","homepage":"https://www.netflix.com/es/title/81758092","overview":"En medio de una ola de violencia inédita que sacude São Paulo, una abogada ligada al mundo criminal debe pactar con la policía para salvar a su sobrina secuestrada."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Aviso general: Hermandad","runtime":0,"tagline":"","homepage":"https://www.netflix.com/mx/title/81758092","overview":"Mientras una ola de violencia golpea São Paulo, una abogada con nexos peligrosos debe negociar con la policía para rescatar a su sobrina secuestrada."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Thành phố sợ hãi","runtime":0,"tagline":"","homepage":"https://www.netflix.com/vn/title/81758092","overview":"Khi São Paulo bùng lên làn sóng bạo lực chưa từng có, một nữ luật sư có mối liên hệ với thế giới ngầm buộc phải thỏa thuận với cảnh sát để giải cứu cháu gái bị bắt cóc."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Irmandade: Kardeşlik İsyanı","runtime":0,"tagline":"","homepage":"https://www.netflix.com/tr/title/81758092","overview":"São Paulo'da daha önce hiç görülmemiş bir şiddet dalgası yaşanırken yeraltı dünyasıyla bağları olan bir avukatın kaçırılan yeğenini kurtarmak için polisle anlaşma yapması gerekir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"แดนจลาจล","runtime":0,"tagline":"","homepage":"https://www.netflix.com/th/title/81758092","overview":"เมื่อเหตุการณ์ที่เซาเปาลูเริ่มรุนแรงขึ้นอย่างที่ไม่เคยมีมาก่อน ทนายความสาวซึ่งมีสายสัมพันธ์กับโลกใต้ดินจึงต้องทำข้อตกลงกับตำรวจ เพื่อช่วยหลานสาวที่ถูกลักพาตัวไป"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"惊城之乱","runtime":104,"tagline":"","homepage":"https://www.netflix.com/ua/title/81758092","overview":"这部电影是 Netflix 热门巴西犯罪影集**《黑狱悲歌》**（Brotherhood / Irmandade）的衍生长篇电影。故事背景设定在圣保罗。当犯罪组织首领的女儿被腐败警察绑架后，该组织发起了大规模的报复行动，使整座城市陷入暴力与混乱的边缘。影集版的主角克里斯蒂娜（由 Naruna Costa 饰演）在片中必须在法律边缘挣扎，试图在局势失控前救出侄女。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"브라더후드: 총공세","runtime":0,"tagline":"","homepage":"https://www.netflix.com/kr/title/81758092","overview":"전례 없는 폭력 사태로 혼란에 빠진 상파울루. 암흑가와 연결된 변호사가 납치된 조카를 구하기 위해 경찰과 거래를 시도한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Місто страху","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ua/title/81758092","overview":"Сан-Паулу охоплює безпрецедентна хвиля насильства. Пов’язана з кримінальним світом адвокатка укладає угоду з поліцією, щоб урятувати викрадену племінницю."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Състояние на страха","runtime":0,"tagline":"","homepage":"","overview":"Сао Пауло е обхванат от вълна насилие, а адвокат с връзки в подземния свят трябва да сключи сделка с полицията, за да спаси отвлечената си племенница."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Brotherhood - Stato di paura","runtime":0,"tagline":"","homepage":"https://www.netflix.com/it/title/81758092","overview":"San Paolo è travolta da un'ondata di violenza senza precedenti e un'avvocata collegata alla malavita deve stringere un accordo con la polizia per salvare la nipote rapita."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Vérző város","runtime":0,"tagline":"","homepage":"https://www.netflix.com/hu/title/81758092","overview":"Miközben sosem látott erőszakhullám söpör végig São Paulón, egy alvilági kapcsolatokkal rendelkező ügyvédnek alkut kell kötnie a rendőrséggel, hogy megmentse elrabolt unokahúgát."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Σε Κατάσταση Φόβου","runtime":0,"tagline":"","homepage":"https://www.netflix.com/gr/title/81758092","overview":"Εν μέσω πρωτοφανούς κύματος βίας στο Σάο Πάολο, μια δικηγόρος με επαφές στον υπόκοσμο πρέπει να κάνει συμφωνία με την αστυνομία για να σώσει την απαχθείσα ανιψιά της."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Frăția fricii","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ro/title/81758092","overview":"São Paulo este cuprins de un val de violență fără precedent, iar o avocată cu legături în lumea interlopă face o înțelegere cu poliția pentru a-și salva nepoata răpită."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"האחים: עיר הפחד","runtime":0,"tagline":"","homepage":"https://www.netflix.com/il/title/81758092","overview":"מהומות ענק אלימות פורצות בסאו פאולו, ועורכת דין עם קשרים בעולם התחתון נאלצת לסגור עסקה עם המשטרה כדי להציל את אחייניתה שנחטפה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"V sevření strachu","runtime":0,"tagline":"","homepage":"https://www.netflix.com/cz/title/81758092","overview":"V São Paulu vypukne nevídaná vlna násilí. Právnička s vazbami na podsvětí tam musí uzavřít dohodu s policií, aby zachránila unesenou neteř."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"驚城之亂","runtime":0,"tagline":"","homepage":"https://www.netflix.com/hk/title/81758092","overview":"一波前所未有的暴力事件導致聖保羅陷入動盪，一名與黑社會有所牽連的律師必須和警方談妥條件，好救出被綁架的姪女。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"حالة ذعر","runtime":0,"tagline":"","homepage":"https://www.netflix.com/sa/title/81758092","overview":"تجتاح مدينة \"ساو باولو\" موجة عنف غير مسبوقة، فتضطر محامية تربطها صلات بعالم الجريمة إلى عقد اتفاق مع الشرطة لإنقاذ ابنة أختها المخطوفة."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"حالة ذعر","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ae/title/81758092","overview":"تجتاح مدينة \"ساو باولو\" موجة عنف غير مسبوقة، فتضطر محامية تربطها صلات بعالم الجريمة إلى عقد اتفاق مع الشرطة لإنقاذ ابنة أختها المخطوفة."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"U raljama straha","runtime":0,"tagline":"","homepage":"https://www.netflix.com/hr/title/81758092","overview":"Kad se São Paulom proširi neviđeni val nasilja odvjetnica s vezama u podzemlju mora se nagoditi s policijom kako bi spasila svoju otetu nećakinju."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"惊城之乱","runtime":0,"tagline":"","homepage":"https://www.netflix.com/sg-zh/title/81758092","overview":"圣保罗爆发前所未有的暴力浪潮，一名与地下犯罪世界有联系的律师试图与警方达成交易，以救出被绑架的侄女。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"Et broderskab: I frygtens greb","runtime":0,"tagline":"","homepage":"https://www.netflix.com/dk/title/81758092","overview":"Da São Paulo rammes af en hidtil uset bølge af vold, må en advokat med forbindelser til underverdenen indgå en aftale med politiet for at redde sin kidnappede niece."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"驚城之亂","runtime":0,"tagline":"","homepage":"https://www.netflix.com/tw/title/81758092","overview":"一波前所未有的暴力事件導致聖保羅陷入動盪，一名與黑社會有所牽連的律師必須和警方談妥條件，好救出被綁架的姪女。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Pelon kaupunki","runtime":0,"tagline":"","homepage":"https://www.netflix.com/fi/title/81758092","overview":"Ennennäkemätön väkivalta-aalto puhkeaa São Paulossa. Alamaailmaan sekaantuneen asianajajan on tehtävä sopimus poliisin kanssa kidnapatun sukulaistyttönsä pelastamiseksi."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"State of Fear","runtime":0,"tagline":"","homepage":"https://www.netflix.com/id/title/81758092","overview":"Saat gelombang kerusuhan terbesar melanda São Paulo, pengacara dengan koneksi dunia kriminal harus bersepakat dengan polisi demi menyelamatkan keponakannya yang diculik."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"L'Appel du chaos","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ca-fr/title/81758092","overview":"Alors qu'une vague de violence sans précédent frappe São Paulo, une avocate qui a des liens avec le monde interlope doit s'allier avec la police pour retrouver sa nièce kidnappée."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.netflix.com/nl/title/81758092","overview":"Tijdens een ongekende golf van geweld in São Paulo moet een advocaat die banden met de onderwereld heeft, een deal sluiten met de politie om haar ontvoerde nichtje te redden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"State of Fear","runtime":0,"tagline":"","homepage":"https://www.netflix.com/in-hi/title/81758092","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.netflix.com/pt/title/81758092","overview":"Ao mesmo tempo que São Paulo assiste a uma onda de violência sem precedentes, uma advogada ligada ao submundo é obrigada a um acordo com a polícia para salvar a sobrinha."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"State of Fear","runtime":0,"tagline":"","homepage":"https://www.netflix.com/my/title/81758092","overview":"Siri keganasan yang luar biasa tercetus di São Paulo, memaksa peguam yang terlibat dalam dunia jenayah berunding dengan polis untuk menyelamatkan anak saudaranya."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"フィアー・オブ・エンパイア","runtime":0,"tagline":"","homepage":"https://www.netflix.com/jp/title/81758092","overview":"サンパウロの街がかつてないほどの暴力の渦に飲み込まれるなか、裏社会とつながりのある弁護士は、誘拐された姪を救うために警察との取引を迫られる。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Brorskap: Uro","runtime":0,"tagline":"","homepage":"https://www.netflix.com/no/title/81758092","overview":"São Paulo rammes av en voldsbølge uten sidestykke, og en advokat med tilknytning til underverdenen inngår en avtale med politiet for å redde den kidnappede niesen sin."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"W mieście strachu","runtime":0,"tagline":"","homepage":"https://www.netflix.com/pl/title/81758092","overview":"Gdy São Paulo pogrąża się w przemocy, prawniczka powiązana ze światem przestępczym musi zawrzeć układ z policją, by uratować porwaną bratanicę."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Группировка: общий сбор","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ru/title/81758092","overview":"Сан-Паулу захлестывает беспрецедентная волна насилия. Чтобы спасти похищенную племянницу, ее тетя-адвокат, связанная с преступным миром, заключает сделку с полицией."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Irmandade – Uppror","runtime":0,"tagline":"","homepage":"https://www.netflix.com/se/title/81758092","overview":"När São Paulo skakas av en våldsvåg tvingas en jurist med kopplingar till den undre världen att samarbeta med polisen för att rädda sin kidnappade brorsdotter."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"State of Fear","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ph/title/81758092","overview":"Nang masadlak sa sunod-sunod na karahasan ang São Paulo, isang abogadang may kaugnayan sa underworld ang kailangang makipagkasundo sa mga pulis para sa pamangkin niya."},"name":"","iso_639_1":"tl","iso_3166_1":"PH","english_name":"Tagalog"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[{"id":8488,"adult":false,"title":"Hitch","video":false,"overview":"Dating coach Alex 'Hitch' Hitchens mentors a bumbling client, Albert, who hopes to win the heart of the glamorous Allegra Cole. While Albert makes progress, Hitch faces his own romantic setbacks when proven techniques fail to work on Sara Melas, a tabloid reporter digging for dirt on Allegra Cole's love life. When Sara discovers Hitch's connection to Albert – now Allegra's boyfriend – it threatens to destroy both relationships.","genre_ids":[35,18,10749],"popularity":4.5774,"vote_count":6120,"poster_path":"/x3W9H3nhGQbWSlyI8Amp2F6Z6cz.jpg","release_date":"2005-02-11","vote_average":6.575,"backdrop_path":"/a6tIX4fGgp60w2d9pqYRbFM91ne.jpg","original_title":"Hitch","original_language":"en"},{"id":9799,"adult":false,"title":"The Fast and the Furious","video":false,"overview":"Dominic Toretto is a Los Angeles street racer suspected of masterminding a series of big-rig hijackings. When undercover cop Brian O'Conner infiltrates Toretto's iconoclastic crew, he falls for Toretto's sister and must choose a side: the gang or the LAPD.","genre_ids":[28,80,53],"popularity":1.1483,"vote_count":10654,"poster_path":"/gqY0ITBgT7A82poL9jv851qdnIb.jpg","release_date":"2001-06-22","vote_average":7.002,"backdrop_path":"/jY9ef5nqY4xIIMu3yzW3qamUCoi.jpg","original_title":"The Fast and the Furious","original_language":"en"},{"id":9762,"adult":false,"title":"Step Up","video":false,"overview":"Delinquent Tyler Gage receives the opportunity of a lifetime after vandalizing a performing arts school, gaining him the chance to earn a scholarship and dance with up-and-coming dancer Nora.","genre_ids":[10402,18,10749,80],"popularity":4.0876,"vote_count":3849,"poster_path":"/fmw52kXk2kN8AQil7tgOD41gt4Q.jpg","release_date":"2006-08-11","vote_average":6.872,"backdrop_path":"/k3AGi4UD8Ql2dKosXh6FrBSKm0s.jpg","original_title":"Step Up","original_language":"en"},{"id":1261555,"adult":false,"title":"Promised Hearts","video":false,"overview":"A young woman's future is jeopardized by a secret arrangement that throws her life into chaos — but it may be the only way to save her family.","genre_ids":[18,10749],"popularity":0.3405,"vote_count":24,"poster_path":"/shQW1KFEAEHCX9GytczYCDSXG6L.jpg","release_date":"2025-03-30","vote_average":5.7,"backdrop_path":"/wk0vWuxCNKmFWHhaqEAtBVRhUkY.jpg","original_title":"Setetes Embun Cinta Niyala","original_language":"id"},{"id":664300,"adult":false,"title":"Shiva Baby","video":false,"overview":"College student Danielle must cover her tracks when she unexpectedly runs into her sugar daddy at a shiva - with her parents, ex-girlfriend and family friends also in attendance.","genre_ids":[35,18],"popularity":1.62,"vote_count":752,"poster_path":"/4sdqVsT6SHqtbCYZS7bhVoEftlL.jpg","release_date":"2021-03-26","vote_average":7.113,"backdrop_path":"/feQvRl67oc4AOWN4LhAwkrMWdX4.jpg","original_title":"Shiva Baby","original_language":"en"},{"id":10641,"adult":false,"title":"Autumn in New York","video":false,"overview":"Will Keane, a Manhattan restaurateur, is content with his playboy lifestyle until he meets Charlotte Fielding, a free-spirited young woman. Together the pair pursue a passionate affair that forces them both to reevaluate what they want out of life, even as fate threatens to steal away their future.","genre_ids":[18,10749],"popularity":1.1907,"vote_count":750,"poster_path":"/avtPZ5vGvFugnY0NK8d3Przx6P7.jpg","release_date":"2000-08-11","vote_average":6.115,"backdrop_path":"/9t8zSBYMSV8fc51FV4xCdmK7oyP.jpg","original_title":"Autumn in New York","original_language":"en"},{"id":10660,"adult":false,"title":"It Could Happen to You","video":false,"overview":"Charlie Lang is a simple, kindhearted New York City cop. When he realizes he has no money to tip waitress Yvonne Biasi, Lang offers her half the winnings of his lottery ticket. Amazingly, the ticket happens to be a winner, in the sum of $4 million. True to his word, Lang proceeds to share the prize money with Biasi, which infuriates his greedy wife, Muriel. Not content with the arrangement, Muriel begins scheming to take all the money.","genre_ids":[35,18,10749],"popularity":3.1238,"vote_count":894,"poster_path":"/6UOaeLDOdwwTMQtbl5YL6EGjqy0.jpg","release_date":"1994-07-16","vote_average":6.711,"backdrop_path":"/rHqIKBrvmRTExmi7XN31OjRSPKT.jpg","original_title":"It Could Happen to You","original_language":"en"},{"id":10938,"adult":false,"title":"Beautiful Thing","video":false,"overview":"During a long, hot summer on the Thamesmead Estate in Southeast London, three teenagers edge towards adulthood.","genre_ids":[35,18,10749],"popularity":1.3416,"vote_count":335,"poster_path":"/34fPI0phWQ189lc5O7aNf12jWPm.jpg","release_date":"1996-06-21","vote_average":7.3,"backdrop_path":"/2qGHNcU8YBIbvNc8HR1YczBeejA.jpg","original_title":"Beautiful Thing","original_language":"en"},{"id":9326,"adult":false,"title":"Romancing the Stone","video":false,"overview":"Though she can spin wild tales of passionate romance, novelist Joan Wilder has no life of her own. Then one day adventure comes her way in the form of a mysterious package. It turns out that the parcel is the ransom she'll need to free her abducted sister, so Joan flies to South America to hand it over. But she gets on the wrong bus and winds up hopelessly stranded in the jungle.","genre_ids":[10749,35,28,12],"popularity":2.8268,"vote_count":1994,"poster_path":"/qaCLbDs6Ace4I1lAbBNWPQAm75h.jpg","release_date":"1984-03-30","vote_average":6.8,"backdrop_path":"/fHDAbqV14BX13K21e2bO9wX9dB5.jpg","original_title":"Romancing the Stone","original_language":"en"},{"id":9062,"adult":false,"title":"Love Story","video":false,"overview":"Harvard Law student Oliver Barrett IV and music student Jennifer Cavilleri share a chemistry they cannot deny - and a love they cannot ignore. Despite their opposite backgrounds, the young couple put their hearts on the line for each other. When they marry, Oliver's wealthy father threatens to disown him. Jenny tries to reconcile the Barrett men, but to no avail.","genre_ids":[10749,18],"popularity":4.9803,"vote_count":725,"poster_path":"/5A7SGcT1GlhWfHsCRQQtGe0TpJB.jpg","release_date":"1970-12-16","vote_average":6.828,"backdrop_path":"/sIOIhwdWqplSpq62f1uP8yUpS2r.jpg","original_title":"Love Story","original_language":"en"},{"id":9087,"adult":false,"title":"The American President","video":false,"overview":"Widowed U.S. president Andrew Shepherd, one of the world's most powerful men, can have anything he wants -- and what he covets most is Sydney Ellen Wade, a Washington lobbyist. But Shepherd's attempts at courting her spark wild rumors and decimate his approval ratings.","genre_ids":[18,10749],"popularity":2.5976,"vote_count":767,"poster_path":"/yObOAYFIHXHkFPQ3jhgkN2ezaD.jpg","release_date":"1995-11-17","vote_average":6.534,"backdrop_path":"/62BnXyJtVEq4WKNSpnPG7QPYYDI.jpg","original_title":"The American President","original_language":"en"},{"id":861427,"adult":false,"title":"Last Twilight in Phuket","video":false,"overview":"The story of Oh Aew's last day in Phuket. Teh will take him to places they will remember before traveling to Bangkok. A short film follow-up to part 1 of the series \"I Told Sunset About You\".","genre_ids":[18],"popularity":0.2155,"vote_count":14,"poster_path":"/sygDHIZImICRSDqhkCtUAjSEMN2.jpg","release_date":"2021-05-20","vote_average":7.1,"backdrop_path":"/eb4wpx3EwVKbRIxuaEnxVcY8tqr.jpg","original_title":"แปลรักฉันด้วยใจเธอ Side Story","original_language":"th"},{"id":9410,"adult":false,"title":"Great Expectations","video":false,"overview":"Loosely based on the Charles Dickens' classic novel, \"Great Expectations\" is a sensual tale of a young man's unforgettable passage into manhood, and the three individuals who will undeniably change his life forever. Through the surprising interactions of these vivid characters, \"Great Expectations\" takes a unique and contemporary look at life's great coincidences.","genre_ids":[35,18,10749],"popularity":2.5523,"vote_count":665,"poster_path":"/djLsfl3lm7BZKWsKfVZ2wM1ZMrP.jpg","release_date":"1998-01-30","vote_average":6.623,"backdrop_path":"/laXkVCU5DE8Dib0QVHUUUsE7FM6.jpg","original_title":"Great Expectations","original_language":"en"},{"id":10013,"adult":false,"title":"Peggy Sue Got Married","video":false,"overview":"At her 25th high school reunion, Peggy Sue faints and awakens in 1960—back in her senior year, before her marriage and all her regrets. Given a second chance to relive her youth, she must decide whether to change the choices that shaped her life or embrace the past that made her who she is.","genre_ids":[35,18,14],"popularity":1.4034,"vote_count":639,"poster_path":"/tfuQcvQmURiMqB2VPwytU3cPpEm.jpg","release_date":"1986-10-10","vote_average":6.115,"backdrop_path":"/xCtyGEn5VGMKV7S9xRbQJyojgYf.jpg","original_title":"Peggy Sue Got Married","original_language":"en"},{"id":1261250,"adult":false,"title":"I am the Secret in Your Heart","video":false,"overview":"In school, Wang Hsiao-hsia and her childhood friend Yuzu are seen as a couple, but Hsiao-hsia secretly longs for the transfer student Cheng Yih. Cheng Yih, admired for his exceptional grades, talent, and fighting skills, captivates her heart. Despite her poor academic performance, Hsiao-hsia tries various methods to win his affection, but nothing works. Unbeknownst to her, Cheng Yih harbors feelings for Hsiao-hsia as well. Meanwhile, Yuzu, fiercely protective of Hsiao-hsia, is wary of anyone trying to get close to her. As summer arrives, a fragrant first love begins to bloom among the three of them, reminiscent of lemongrass.","genre_ids":[10749,35,18],"popularity":1.902,"vote_count":7,"poster_path":"/9y77aA6rHE09gxzNzt79b7cyf3M.jpg","release_date":"2024-08-02","vote_average":7.286,"backdrop_path":"/77Y5xGcQieZXQ7UlkLOYujh40P0.jpg","original_title":"夏日的檸檬草","original_language":"zh"},{"id":10215,"adult":false,"title":"Sliding Doors","video":false,"overview":"Helen, a London ad executive, is fired from her job and rushes out to catch a train, but, as she runs down, her life suddenly splits off. In one version she catches the train; in the second, she misses it. Her whole life changes in that one second, and the rest of the film depicts what happens in each scenario.","genre_ids":[35,18,14,10749],"popularity":1.2759,"vote_count":1395,"poster_path":"/s8VOVTywXZIIHqdEjkCZziH0ebq.jpg","release_date":"1998-04-23","vote_average":6.564,"backdrop_path":"/1dApwEEMrk7QnUb1EpyYWrG6nRh.jpg","original_title":"Sliding Doors","original_language":"en"},{"id":10236,"adult":false,"title":"The Way We Were","video":false,"overview":"Opposites attract when, during their college days, Katie Morosky, a politically active Jew, meets Hubbell Gardiner, a feckless WASP. Years later, in the wake of World War II, they meet once again and, despite their obvious differences, attempt to make their love for each other work.","genre_ids":[18,10749],"popularity":2.6776,"vote_count":504,"poster_path":"/o5x563ze56iI4iNsCBxTnDkt28i.jpg","release_date":"1973-10-17","vote_average":6.983,"backdrop_path":"/7mRpaVetpIde0f3Ebk2ipCAqDls.jpg","original_title":"The Way We Were","original_language":"en"},{"id":10229,"adult":false,"title":"A Walk to Remember","video":false,"overview":"When the popular, restless Landon Carter is forced to participate in the school drama production, he falls in love with Jamie Sullivan, the daughter of the town's minister. Jamie has a \"to-do\" list for her life, as well as a very big secret she must keep from Landon.","genre_ids":[18,10749],"popularity":4.0043,"vote_count":4210,"poster_path":"/8lUYMvWdHA0Q0k5F76RQCeCBUkA.jpg","release_date":"2002-01-25","vote_average":7.756,"backdrop_path":"/eYheokDlNmjGbG3AQAKaI0Er0Cc.jpg","original_title":"A Walk to Remember","original_language":"en"},{"id":11104,"adult":false,"title":"Chungking Express","video":false,"overview":"Two melancholic Hong Kong policemen fall in love: one with a mysterious underworld figure, the other with a beautiful and ethereal server at a late-night restaurant.","genre_ids":[1