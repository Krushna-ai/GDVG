9:{"metadata":[["$","title","0",{"children":"Bicycle Thieves | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Unemployed Antonio is elated when he finally finds work hanging posters around war-torn Rome. However on his first day, his bicycle—essential to his work—gets stolen. His job is doomed unless he can find the thief. With the help of his son, Antonio combs the city, becoming desperate for justice."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148562/bicycle-thieves"}],["$","meta","5",{"property":"og:title","content":"Bicycle Thieves"}],["$","meta","6",{"property":"og:description","content":"Unemployed Antonio is elated when he finally finds work hanging posters around war-torn Rome. However on his first day, his bicycle—essential to his work—gets stolen. His job is doomed unless he can find the thief. With the help of his son, Antonio combs the city, becoming desperate for justice."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148562/bicycle-thieves"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/iPdVqIpmR3bRvOQJPrn4pr2KR3q.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Bicycle Thieves"}],["$","meta","12",{"name":"twitter:description","content":"Unemployed Antonio is elated when he finally finds work hanging posters around war-torn Rome. However on his first day, his bicycle—essential to his work—gets stolen. His job is doomed unless he can find the thief. With the help of his son, Antonio combs the city, becoming desperate for justice."}],["$","meta","13",{"name":"twitter:image","content":"https://