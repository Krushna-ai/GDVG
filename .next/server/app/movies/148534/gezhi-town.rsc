ight":2800,"file_path":"/X5BoxpnBqWkFV6TncQd2K4cDDT.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.714,"vote_average":0},{"width":1280,"height":1920,"file_path":"/dRboxWAPjsvja8I0Xa5abPW5TRv.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":2800,"file_path":"/AmrBYJhis48bUwIFPZjgyGN74zM.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.714,"vote_average":0},{"width":1280,"height":1920,"file_path":"/yZ0bkYoDmbQZv5AwuN5uy2Cn99l.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":2800,"file_path":"/rcIOZAT3DB4nbEf6DcdedDUuYjd.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.714,"vote_average":0},{"width":2000,"height":2800,"file_path":"/mCw7f0GH8006eXytTxGdEpJ3uXU.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.714,"vote_average":0},{"width":2000,"height":2800,"file_path":"/l9vL471VhJwH2Z4oKHKvTlq28sw.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.714,"vote_average":0},{"width":2000,"height":3000,"file_path":"/3uP5IxEbGWdfQseSD5VpI791Cjn.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":2800,"file_path":"/9XzunbcYyK4SbLapZohP4Svi5ff.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.714,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/7YYEgFuUrK4piSwGQY9nosvHCWw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/dFmIQfvjjs4Yn8jA8GoT3QkI7pv.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/iwZORH6XiNCcWLF0lWLet5AC1Eb.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/6xu3IyWOqSVxZE0S3jPxVz3A1Bt.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166}]},"enriched_at":"2026-04-21T07:07:46.893+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":121,"tagline":"","homepage":"","overview":"一个桃花源般的小镇，一群因南京沦陷而逃难至此安居数年的百姓，偶有一日数名日军误入此地，百姓被日军逼到绝境后奋起直面迎战。一场双方武器相差悬殊的战斗，一次智慧与意志的比拼，就此展开。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Gezhi Town","runtime":122,"tagline":"","homepage":"","overview":"A group of Chinese refugees and straggler soldiers, led by a machinist, defend their mountain town, \"Gezhi,\" against a surprise attack by Japanese reconnaissance troops in a desperate fight using civilian ingenuity against a trained military force."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"得閑謹制","runtime":0,"tagline":"","homepage":"","overview":"金陵機械廠鉗工莫得閒（肖戰 飾）拖家帶口隨逃難隊伍躲進山區，與被大部隊遺忘的防空炮長肖衍（彭昱暢 飾）及手下殘兵在“戈止鎮”落腳。然而莫得閒和妻子夏橙（周依然 飾）、太爺（楊新鳴 飾）以及兒子莫等閒的桃源生活未能長久，日本偵查兵大河原（尹正 飾）率三人小隊意外到來。一場民間智慧對抗正規武裝的生死較量悄然展開。面對懸殊的實力差距，他們能否守護這片安身立命的家園？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"得閑謹制","runtime":121,"tagline":"","homepage":"","overview":"機械廠鉗工莫得閑（肖戰 飾）拖家帶口隨逃難隊伍躲進山區，與被大部隊遺忘的防空炮長肖衍（彭昱暢 飾）及手下在“戈止鎮”落腳。然而，莫得閑和妻子夏橙（周依然 飾）、老太爺（楊新鳴 飾）以及兒子莫等閑（嚴知度 飾）的平靜生活因為一小隊日本偵察兵的意外到來被打破。全鎮百姓不忍不退，拼死守護家園，一場民間智慧對抗正規武裝的殊死較量轟然展開。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Thị Trấn Gezhi","runtime":0,"tagline":"","homepage":"","overview":"Một nhóm người tị nạn và binh lính lạc ngũ Trung Quốc, do một thợ máy dẫn đầu, đã bảo vệ thị trấn miền núi \"Gezhi\" của họ trước cuộc tấn công bất ngờ của quân trinh sát Nhật Bản trong một cuộc chiến tuyệt vọng, sử dụng sự khéo léo của thường dân để chống lại một lực lượng quân sự được huấn luyện bài bản."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"}],"reviews_tmdb":[{"id":"694ddf5a5950358f20811b41","url":"https://www.themoviedb.org/review/694ddf5a5950358f20811b41","author":"RoeRoberts","content":"Well acted and constructed script, I have never seen an account of this historical event in a movie before. The actors ALL did a great job. I especially loved the great-granddad and his great grandson,'the fixer'(Xiao Zhan). My only criticism was, it seemed to short, I wanted to learn more about the main 3 adult characters.","created_at":"2025-12-26T01:05:30.728Z","updated_at":"2025-12-26T04:53:35.716Z","author_details":{"name":"","rating":10,"username":"RoeRoberts","avatar_path":null}}],"recommendations":[],"similar_content":[{"id":103,"adult":false,"title":"Taxi Driver","video":false,"overview":"Suffering from insomnia, disturbed loner Travis Bickle takes a job as a New York City cabbie, haunting the streets nightly, growing increasingly detached from reality as he dreams of cleaning up the filthy city.","genre_ids":[80,18],"popularity":13.4122,"vote_count":13213,"poster_path":"/ekstpH614fwDX8DUln1a2Opz0N8.jpg","release_date":"1976-02-09","vote_average":8.127,"backdrop_path":"/9uddYYTNcLWpzUkl5iw1RUYhLhY.jpg","original_title":"Taxi Driver","original_language":"en"},{"id":275,"adult":false,"title":"Fargo","video":false,"overview":"Jerry, a small-town Minnesota car salesman is bursting at the seams with debt... but he's got a plan. He's going to hire two thugs to kidnap his wife in a scheme to collect a hefty ransom from his wealthy father-in-law. It's going to be a snap and nobody's going to get hurt... until people start dying. Enter Police Chief Marge, a coffee-drinking, parka-wearing - and extremely pregnant - investigator who'll stop at nothing to get her man. And if you think her small-time investigative skills will give the crooks a run for their ransom... you betcha!","genre_ids":[80,18,53],"popularity":8.1869,"vote_count":8900,"poster_path":"/rt7cpEr1uP6RTZykBFhBTcRaKvG.jpg","release_date":"1996-03-08","vote_average":7.847,"backdrop_path":"/747dgDfL5d8esobk7h4odaOFhUq.jpg","original_title":"Fargo","original_language":"en"},{"id":1887,"adult":false,"title":"Marie Antoinette","video":false,"overview":"A retelling of the story of France’s iconic but ill-fated queen, Marie Antoinette - from her betrothal and marriage to Louis XVI at fifteen to her reign as queen at nineteen and ultimately the fall of Versailles.","genre_ids":[18,36],"popularity":3.7327,"vote_count":2905,"poster_path":"/cybXGmv8Rjd5Os8Xml6YxMBQ0Zt.jpg","release_date":"2006-05-24","vote_average":6.7,"backdrop_path":"/9hxBNoRjEDZGjyR1JpmmtxJWmVU.jpg","original_title":"Marie Antoinette","original_language":"en"},{"id":659959,"adult":false,"title":"Summer of 85","video":false,"overview":"What do you dream of when you're 16-years-old and in a seaside resort in Normandy in the 1980s? A best friend? A lifelong teen pact? Scooting off on adventures on a boat or a motorbike? Living life at breakneck speed? No. You dream of death. Because you can't get a bigger kick than dying. And that's why you save it till the very end. The summer holidays are just beginning, and this story recounts how Alexis grew into himself.","genre_ids":[10749,18],"popularity":1.8594,"vote_count":891,"poster_path":"/etH2pm1eMxEjY2dlltpQGLVspv.jpg","release_date":"2020-07-14","vote_average":7.41,"backdrop_path":"/hGc9gAIywD3pR7n6xtgkeBpkoIs.jpg","original_title":"Été 85","original_language":"fr"},{"id":1257667,"adult":false,"title":"#Fitspo","video":false,"overview":"A perfectionistic fitness influencer faces judgement, distractions and insecurities as she races to finish a \"Get Ready With Me\" video before a long-awaited cheat night.","genre_ids":[18],"popularity":0.2896,"vote_count":0,"poster_path":"/wOFhj3zNHWvrhXRBj9J39Fy1eh2.jpg","release_date":"2025-03-31","vote_average":0,"backdrop_path":"/f1LRt6RuCWYMQkD2Y1nn1Povdgs.jpg","original_title":"#Fitspo","original_language":"en"},{"id":6171,"adult":false,"title":"Dreamcatcher","video":false,"overview":"Four boyhood pals perform a heroic act and are changed by the powers they gain in return. Years later, on a hunting trip in the Maine woods, they're overtaken by a vicious blizzard that harbors an ominous presence. Challenged to stop an alien force, the friends must first prevent the slaughter of innocent civilians by a military vigilante ... and then overcome a threat to the bond that unites the four of them.","genre_ids":[18,27,878,53],"popularity":3.7425,"vote_count":1874,"poster_path":"/lLhvwLNU4pLgvaNREVFaQ4n3lCf.jpg","release_date":"2003-03-21","vote_average":5.63,"backdrop_path":"/fKEF2MD4tA8G9Eywqq0k9E76sxw.jpg","original_title":"Dreamcatcher","original_language":"en"},{"id":4836,"adult":false,"title":"Layer Cake","video":false,"overview":"When a seemingly straight-forward drug deal goes awry, XXXX has to break his die-hard rules and turn up the heat, not only to outwit the old regime and come out on top, but to save his own skin...","genre_ids":[18,53,80],"popularity":2.6715,"vote_count":2311,"poster_path":"/rDOxXteqxALBaSa3V3zTjGJuyWB.jpg","release_date":"2004-09-30","vote_average":6.912,"backdrop_path":"/a8230eNW59hSOkj5XrRpzMMh0WT.jpg","original_title":"Layer Cake","original_language":"en"},{"id":12093,"adult":false,"title":"Lilya 4-ever","video":false,"overview":"In a struggling post-Soviet community, Lilya a teenage girl is abandoned when her mother moves to the United States with her boyfriend. Facing neglect and poverty, she meets Andrei, who offers her a job in Sweden, giving her hope for a better life — and a journey that will change everything.","genre_ids":[18,80],"popularity":2.2666,"vote_count":646,"poster_path":"/5i1uhvcdv2Iogx0Bb1znvUmkCvN.jpg","release_date":"2002-08-23","vote_average":7.619,"backdrop_path":"/fJeOpfzQSkzESNPmEXpyNLMmOtI.jpg","original_title":"Lilja 4-ever","original_language":"sv"},{"id":8327,"adult":false,"title":"The Holy Mountain","video":false,"overview":"The Alchemist assembles together a group of people from all walks of life to represent the planets in the solar system. The occult adept's intention is to put his recruits through strange mystical rites and divest them of their worldly baggage before embarking on a trip to Lotus Island. There they ascend the Holy Mountain to displace the immortal gods who secretly rule the universe.","genre_ids":[18],"popularity":2.3971,"vote_count":998,"poster_path":"/mP5FGQbNjFkrjcZ6AVHrvokPRe5.jpg","release_date":"1973-11-29","vote_average":7.537,"backdrop_path":"/oUceCsSe255ZKXCMsHhqXM1xuUp.jpg","original_title":"La montaña sagrada","original_language":"es"},{"id":8055,"adult":false,"title":"The Reader","video":false,"overview":"The story of Michael Berg, a German lawyer who, as a teenager in the late 1950s, had an affair with an older woman, Hanna, who then disappeared only to resurface years later as one of the defendants in a war crimes trial stemming from her actions as a concentration camp guard late in the war. He alone realizes that Hanna is illiterate and may be concealing that fact at the expense of her freedom.","genre_ids":[18,10749],"popularity":3.1528,"vote_count":3329,"poster_path":"/r0WURbmnhgKeBpHcpDULBgRedQM.jpg","release_date":"2008-12-10","vote_average":7.466,"backdrop_path":"/waMGsUEoHfYj3A1uRMUUgpBa71d.jpg","original_title":"The Reader","original_language":"en"},{"id":12900,"adult":false,"title":"Conspiracy","video":false,"overview":"At the Wannsee Conference on January 20, 1942, senior Nazi officials meet to determine the manner in which the so-called \"Final Solution to the Jewish Question\" can be best implemented.","genre_ids":[36,18,10752,10770],"popularity":2.141,"vote_count":457,"poster_path":"/77uU3sPxufJEgK5SmqeJIdHeNSU.jpg","release_date":"2001-05-19","vote_average":7.248,"backdrop_path":"/8eVxRHRegqbFL2ugnJlvOGIarX1.jpg","original_title":"Conspiracy","original_language":"en"},{"id":9270,"adult":false,"title":"Brick","video":false,"overview":"A teenage loner pushes his way into the underworld of a high school crime ring to investigate the disappearance of his ex-girlfriend.","genre_ids":[18,9648,80],"popularity":1.3209,"vote_count":1343,"poster_path":"/5WVk8JpNIxepn4fpZzQeCumkOL5.jpg","release_date":"2006-03-31","vote_average":6.823,"backdrop_path":"/sDr2KjWpEbJ8M1F88rEmhoczLkX.jpg","original_title":"Brick","original_language":"en"},{"id":9344,"adult":false,"title":"Kids","video":false,"overview":"A group of bored, disaffected New York City teenagers spend a day skating, smoking, drinking, partying, deflowering virgins, and getting into fights.","genre_ids":[18,80],"popularity":3.7336,"vote_count":1246,"poster_path":"/8qV8hUVCUnFIQKewzlhaFWhdszK.jpg","release_date":"1995-07-28","vote_average":6.895,"backdrop_path":"/c6TjV0i5NzUV4MF8N5wxBW7NcrW.jpg","original_title":"Kids","original_language":"en"},{"id":9400,"adult":false,"title":"Set It Off","video":false,"overview":"Four inner-city Black women, determined to end their constant struggle, decide to live by one rule — get what you want or die trying. So the four women take back their lives and take out some banks in the process.","genre_ids":[80,18,53],"popularity":2.0504,"vote_count":388,"poster_path":"/wpiARyUqTfabzakAXHMIUY6Tl1A.jpg","release_date":"1996-11-06","vote_average":7.189,"backdrop_path":"/8ebAtpx6YVfRGrxPrs4nTTWSbT9.jpg","original_title":"Set It Off","original_language":"en"},{"id":11399,"adult":false,"title":"Look at Me","video":false,"overview":"Talented 20-year-old Lolita dreams of a singing career. But her self-esteem is low due to her weight problem and her narcissistic father, Étienne, a literary star with scant interest in his daughter's life. Lolita finds little comfort in the attentions of her vocal coach, suspecting the woman is using her to meet her influential father. Étienne's second wife proves to be Lolita's only trustworthy ally in her private battle to find a sense of worth.","genre_ids":[35,18],"popularity":0.7665,"vote_count":101,"poster_path":"/kRtLMLdf6PkOjWCvhTpa811aMZy.jpg","release_date":"2004-11-18","vote_average":6.337,"backdrop_path":"/jf2FtZmfwURp9IfD6p7zAtCJkUs.jpg","original_title":"Comme une image","original_language":"fr"},{"id":1262725,"adult":false,"title":"Milano","video":false,"overview":"Alain raises his deaf son Milano alone and wants to give him a better life than he has, but despite the best intentions, his failure becomes apparent. Their father-son relationship comes under pressure when Milano wants to meet his biological mother.","genre_ids":[18],"popularity":0.7448,"vote_count":5,"poster_path":"/bpYIfiGFZDC5U1kEPBN4jiVto00.jpg","release_date":"2024-11-06","vote_average":6.6,"backdrop_path":"/lPwM6DdhvIxw0XVk2ofeiCxVLX.jpg","original_title":"Milano","original_language":"nl"},{"id":11506,"adult":false,"title":"The Silence","video":false,"overview":"Traveling through an unnamed European country on the brink of war, sickly, intellectual Ester, her sister Anna and Anna's young son, Johan, check into a near-empty hotel. A basic inability to communicate among the three seems only to worsen during their stay. Anna provokes her sister by enjoying a dalliance with a local man, while the boy, left to himself, has a series of enigmatic encounters that heighten the growing air of isolation.","genre_ids":[18,10749],"popularity":0.5486,"vote_count":394,"poster_path":"/2KkHAsBVZVoMO1Zauvm5rFSxp09.jpg","release_date":"1963-09-23","vote_average":7.5,"backdrop_path":"/mNpd8763X64KKGXnrdnBHdON9np.jpg","original_title":"Tystnaden","original_language":"sv"},{"id":11545,"adult":false,"title":"Rushmore","video":false,"overview":"When a beautiful first-grade teacher arrives at a prep school, she soon attracts the attention of an ambitious teenager named Max, who quickly falls in love with her. Max turns to the father of two of his schoolmates for advice on how to woo the teacher. However, the situation soon gets complicated when Max's new friend becomes involved with her, setting the two pals against one another in a war for her attention.","genre_ids":[35,18],"popularity":4.6598,"vote_count":2670,"poster_path":"/hSJ6swahAuZ8wM96lHDTwQPXUvZ.jpg","release_date":"1998-12-11","vote_average":7.39,"backdrop_path":"/asC4h9U7pD72bkYcqzgTB7VJYLy.jpg","original_title":"Rushmore","original_language":"en"},{"id":1263091,"adult":false,"title":"The House of Bernarda Alba","video":true,"overview":"In the domain of Bernarda Alba, a daughter who disobeys is no longer a daughter.  Forced to live under their mother’s tight grip as they mourn their father’s death, can five sisters survive when young Adela dares for passion and freedom?","genre_ids":[18],"popularity":0.2344,"vote_count":2,"poster_path":"/bEL5Io5ckfecXTxoTTuTrNgwPaU.jpg","release_date":"2024-03-22","vote_average":4.5,"backdrop_path":"/m0pWi9owKVwQqKBzf8zoEaDRKuU.jpg","original_title":"The House of Bernarda Alba","original_language":"en"},{"id":1213,"adult":false,"title":"The Talented Mr. Ripley","video":false,"overview":"Tom Ripley is a calculating young man who believes it's better to be a fake somebody than a real nobody. Opportunity knocks in the form of a wealthy U.S. shipbuilder who hires Tom to travel to Italy to bring back his playboy son, Dickie. Ripley worms his way into the idyllic lives of Dickie and his girlfriend, plunging into a daring scheme of duplicity, lies and murder.","genre_ids":[53,80,18],"popularity":4.5301,"vote_count":4062,"poster_path":"/6ojHgqtIR41O2qLKa7LFUVj0cZa.jpg","release_date":"1999-12-25","vote_average":7.201,"backdrop_path":"/51UDa3IuGyiKGe2MgMcLGvJE2Fm.jpg","original_title":"The Talented Mr. Ripley","original_language":"en"}],"external_ids":{"imdb_id":"tt33014233","twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148534,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades"