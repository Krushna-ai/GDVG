5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Gezhi Town\",\"description\":\"A group of Chinese refugees and straggler soldiers, led by a machinist, defend their mountain town, \\\"Gezhi,\\\" against a surprise attack by Japanese reconnaissance troops in a desperate fight using civilian ingenuity against a trained military force.\",\"image\":\"https://image.tmdb.org/t/p/w500/nE8jhTs48DKb65z0hLk0Akd3GK4.jpg\",\"datePublished\":\"2025-12-06\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Drama\",\"War\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.8,\"bestRating\":10,\"ratingCount\":21}}"}}],["$","$L10",null,{"initialDrama":{"id":"8972a888-247c-41b9-97be-630c805cd038","tmdb_id":1356454,"imdb_id":"tt33014233","content_type":"movie","title":"Gezhi Town","original_title":"得闲谨制","overview":"A group of Chinese refugees and straggler soldiers, led by a machinist, defend their mountain town, \"Gezhi,\" against a surprise attack by Japanese reconnaissance troops in a desperate fight using civilian ingenuity against a trained military force.","poster_path":"/nE8jhTs48DKb65z0hLk0Akd3GK4.jpg","backdrop_path":"/7YYEgFuUrK4piSwGQY9nosvHCWw.jpg","release_date":"2025-12-06","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":18,"name":"Drama"},{"id":10752,"name":"War"}],"popularity":8.5356,"vote_average":4.8,"vote_count":21,"runtime":122,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-25T23:29:32.59516+00:00","updated_at":"2026-02-25T23:29:32.441+00:00","tagline":null,"homepage":null,"budget":0,"revenue":49627843,"production_companies":[{"id":148869,"name":"Daylight Entertainment Co., Ltd.","logo_path":"/1uiCvFIkqy90sifkKMAMFF2efUi.png","origin_country":"CN"}],"production_countries":[{"name":"China","iso_3166_1":"CN"}],"spoken_l