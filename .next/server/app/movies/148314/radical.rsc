_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":8.034},{"width":3840,"height":2160,"file_path":"/iar2PK8ht2ghc3vX0tjw2rYKAMr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/v4nTyU8HRsr70fjFChcxEXcyEOB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/p9DKeXp6FPJtAQ1k13Z4zPWrCbN.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/5ocJeIZuHtE6Eqky3D9hoA5DCXE.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/bQjq21IVXM7Z39Rtn3oF7VSWVF9.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":1540,"height":864,"file_path":"/2WY8lDXJSK3hR4uvVlTABdEOF30.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.782,"vote_average":0.166},{"width":1540,"height":864,"file_path":"/xaPeiBmeXt0Iudsj2IlLIt2AZew.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.782,"vote_average":0.166},{"width":1540,"height":864,"file_path":"/qPi0lecRpPt5vG9Vh6f6ZR4Ndlh.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.782,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/qzTIdzLVzn334u1P6fXah1ZQtRo.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/i3Tb65xqTHaOkPKo1l0VvTYtFNP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:51:42.904+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":125,"tagline":"Think for yourself.","homepage":"https://www.radical.movie","overview":"In a Mexican border town plagued by neglect, corruption, and violence, a frustrated teacher tries an unorthodox new method to break through his students’ apathy and unlock their curiosity, their potential... and perhaps even their genius."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":127,"tagline":"Basada en una historia real.","homepage":"","overview":"En una ciudad fronteriza mexicana plagada de negligencia, corrupción y violencia, un maestro frustrado intenta un nuevo método radical para romper con la apatía de sus alumnos y desbloquear su curiosidad, su potencial... y tal vez incluso su genio."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":127,"tagline":"","homepage":"","overview":"En una ciudad fronteriza mexicana plagada de abandono, corrupción y violencia, un profesor frustrado prueba un nuevo método radical para romper la apatía de sus alumnos y desbloquear su curiosidad, su potencial... y puede que incluso su genialidad. Basada en una historia real."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"רדיקלי","runtime":0,"tagline":"","homepage":"","overview":"מבוסס על סיפור אמיתי, \"רדיקלי\" הוא סיפורו של סרג'יו, מורה בבית ספר באיזור עני במטמורוס שבמקסיקו. תלמידי בית הספר, שמגיעים מרקעים קשים, מדורגים באופן קבוע בתחתית רשימות ההישגים במדינה, ונדמה שהאווירה בכיתה נוטה להתרכז במשמעת ולא באפשרויות לצמיחה. נשמע כמו מבוי סתום, או, בשביל סרג'יו – הזדמנות לנסות משהו חדש. יש רק בעיה אחת – אין לו מושג מה הוא עושה...  \"רדיקלי\" הוא סיפור כנה, מלא שמחת חיים ומעורר השראה, על מורה שמחליט לשנות את הגישה ולגרום לתלמידיו ללמוד ולחקור, ולא פחות חשוב – ליהנות בזמן שהם עושים את זה. הסרט הוקרן בפסטיבל סאנדנס וזכה בפרס חביב הקהל."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Numa cidade fronteiriça mexicana atormentada pela negligência, corrupção e violência, um professor frustrado tenta um novo método radical para romper a apatia dos seus alunos e desbloquear a sua curiosidade, o seu potencial... e talvez até a sua genialidade."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":127,"tagline":"","homepage":"","overview":"En 2011, un nouveau professeur arrive à l'école élémentaire mal gérée de Matamoros. Dans un environnement oppressif et marqué par la violence des cartels de la drogue , les élèves de l'école ont les pires résultats scolaires de tout le Mexique. Étant donné le délabrement des installations et le manque de ressources pédagogiques telles que les ordinateurs, la majorité des enseignants sont peu motivés pour enseigner et se concentrent principalement sur la réussite de leurs classes aux tests standardisés imposés par le gouvernement, qui ne contribuent en rien à l'encouragement de l'apprentissage.  Sergio surprend ses élèves en adoptant une approche pédagogique peu orthodoxe et en les encourageant à résoudre les problèmes de manière créative..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Радикальный","runtime":125,"tagline":"","homepage":"","overview":"В мексиканском приграничном городке, страдающем от нигилизма, коррупции и насилия, разочарованный в мире учитель пробует радикально новый метод, чтобы преодолеть апатию своих учеников и раскрыть их любознательность, их потенциал… и, возможно, даже их гениальность."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"激进教学","runtime":122,"tagline":"","homepage":"","overview":"在一个充满忽视、腐败和暴力的墨西哥边境小镇，一名老师决定尝试一种激进的新方法来释放学生的潜力与好奇心，甚至发掘出他们的天才之处。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":125,"tagline":"","homepage":"","overview":"In een Mexicaanse grensstad geplaagd door verwaarlozing, corruptie en geweld probeert een gefrustreerde leraar een radicaal nieuwe methode om de apathie van zijn leerlingen te doorbreken en hun nieuwsgierigheid, hun potentieel... en misschien zelfs hun genialiteit te ontsluiten."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"في بلدة على الحدود المكسيكية تُعاني من الفساد والإهمال والعنف، يسعى مُدرس لاستخدام طريقة جديدة في التدريس لتطوير مستوى طلابه وإيقاظ شغفهم التعليمي."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"래디컬","runtime":0,"tagline":"","homepage":"","overview":""},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"癲狂世代","runtime":0,"tagline":"","homepage":"","overview":"在一個飽受忽視、腐敗和暴力困擾的墨西哥邊境小鎮，一位沮喪的老師嘗試一種非正統的新方法來打破學生的冷漠態度，釋放他們的好奇心、潛力……甚至可能是他們的天才。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Radikální metoda","runtime":120,"tagline":"","homepage":"","overview":"V mexickém pohraničním městě sužovaném zanedbáváním, korupcí a násilím zkouší frustrovaný učitel novou radikální metodu, aby prolomil apatii svých žáků a uvolnil jejich zvědavost, potenciál... a možná i genialitu."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"In una città di confine messicana afflitta da abbandono, corruzione e violenza, un insegnante frustrato tenta un nuovo metodo radicale per superare l'apatia dei suoi studenti e sbloccare la loro curiosità, il loro potenziale... e forse anche il loro genio."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Radical: Ensinamentos de Um Professor","runtime":127,"tagline":"Pense por si mesmo.","homepage":"","overview":"Um professor numa cidade fronteiriça mexicana vítima de negligência, corrupção e violência, tenta um novo método radical para desbloquear a curiosidade, o potencial dos seus alunos - e talvez até a sua genialidade."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Radical - Eine Klasse für sich","runtime":126,"tagline":"","homepage":"","overview":"Die Sechstklässler der Jose Urbina Lopez-Grundschule in Matamoros staunen nicht schlecht als die erste Unterrichtsstunde ihres neuen Lehrers Sergio Juarez (gespielt von Latin-Megastar Eugenio Derbez) beginnt. Sie gelten als leistungsschwächste Schüler Mexikos und ihre Welt ist geprägt von Gewalt, Vernachlässigung und Korruption. Im Klassenzimmer herrscht eine Atmosphäre der Härte und Disziplin.  Doch Sergio wählt einen anderen Weg, um den Schülern aus der Sackgasse der Perspektivlosigkeit zu helfen: Er wendet sich mit Freiheit und Empathie an die Klasse, um ihre Neugierde, ihr Potenzial und vielleicht sogar ihr Genie zu entfesseln. Sergios' unkonventioneller Lehrplan stößt allerdings nicht nur auf überraschte und verwunderte Gesichter der Kinder, sondern auch auf wenig Akzeptanz und Unterstützung im Lehrerzimmer…"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Σε μια συνοριακή πόλη του Μεξικού που μαστίζεται από παραμέληση, διαφθορά και βία, ένας απογοητευμένος δάσκαλος δοκιμάζει μια ριζοσπαστική νέα μέθοδο για να ξεπεράσει την απάθεια των μαθητών του και να ξεκλειδώσει την περιέργειά τους, τις δυνατότητές τους… και ίσως ακόμη και την ιδιοφυΐα τους"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Radikális","runtime":0,"tagline":"","homepage":"","overview":"Az igaz történeten alapuló film egy elhanyagoltsággal, korrupcióval és erőszakkal teli mexikói határvárosban ered egy tanár nyomába, aki egy radikálisan új módszerrel próbálja felszabadítani diákjai kíváncsiságát, képességeit – és talán még a zsenialitásukat is."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Radykalna metoda","runtime":0,"tagline":"","homepage":"","overview":"Uczniowie szkoły podstawowej w przygranicznym meksykańskim miasteczku nie radzą sobie dobrze z nauką. Znany jest im świat pełen przemocy, korupcji i pogardy. Nie mają praktycznie żadnych perspektyw. Nowy nauczyciel Sergio Juarez (Eugenio Derbez), kreatywny idealista, postanawia wyprowadzić ich na prostą. Sięga po niekonwencjonalne metody, ale niczego się nie boi."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"En una ciutat fronterera mexicana plena d'abandó, corrupció i violència, un professor frustrat prova un nou mètode radical per trencar l'apatia dels seus alumnes i desbloquejar-ne la curiositat, el potencial... i potser fins i tot la seva genialitat. Basada en una història real."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"رادیکال","runtime":0,"tagline":"خودت فکر کن.","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Radikal","runtime":0,"tagline":"Pomislite sami.","homepage":"","overview":"Učenci osnovne šole v obmejnem mehiškem mestu sodijo med najslabše v državi. Njihov svet je poln nasilja, revščine in korupcije, v razredu pa vlada vzdušje strogosti in discipline. Toda novi učitelj Sergio se odloči poskusiti nekaj povsem drugačnega. Da bi prebudil radovednost učencev in pomagal uresničiti njihov potencial, vpelje radikalno novo metodo poučevanja. Rezultati presenetijo vse …"},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"ครูชายแดน","runtime":0,"tagline":"","homepage":"","overview":"ในเมืองชายแดนเม็กซิโกที่เต็มไปด้วยการเมินเฉย การทุจริต และความรุนแรง ครูผู้ท้อแท้พยายามใช้วิธีใหม่สุดขั้วเพื่อฝ่าฟันความไม่สนใจของนักเรียน และปลดล็อกความอยากรู้อยากเห็น ศักยภาพของพวกเขา… และแม้กระทั่งความเป็นอัจฉริยะของพวกเขาด้วยซ้ำ สร้างจากเรื่องจริง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"型破りな教室","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"癲狂世代","runtime":0,"tagline":"","homepage":"","overview":"在一個飽受忽視、腐敗和暴力困擾的墨西哥邊境小鎮，一位沮喪的老師嘗試一種非正統的新方法來打破學生的冷漠態度，釋放他們的好奇心、潛力……甚至可能是他們的天才。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[{"id":"66bdbb12e13f121fcf82840f","url":"https://www.themoviedb.org/review/66bdbb12e13f121fcf82840f","author":"CinemaSerf","content":"$11","created_at":"2024-08-15T08:23:46.437Z","updated_at":"2024-08-15T08:23:46.701Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}},{"id":"66bded2f17d2e86a085588ea","url":"https://www.themoviedb.org/review/66bded2f17d2e86a085588ea","author":"Giovanni","content":"$12","created_at":"2024-08-15T11:57:35.008Z","updated_at":"2024-08-15T11:57:35.138Z","author_details":{"name":"Giovanni","rating":8,"username":"bastag","avatar_path":"/h9FkucYmSN3YH5OmrNRWO5rdquS.jpg"}}],"recommendations":[{"id":848187,"adult":false,"title":"Role Play","video":false,"overview":"Emma has a wonderful husband and two kids in the suburbs of New Jersey – she also has a secret life as an assassin for hire – a secret that her husband David discovers when the couple decide to spice up their marriage with a little role play.","genre_ids":[28,35,10749],"media_type":"movie","popularity":2.9798,"vote_count":614,"poster_path":"/7MhXiTmTl16LwXNPbWCmqxj7UxH.jpg","release_date":"2023-12-14","vote_average":5.957,"backdrop_path":"/a6brwNObG0sFNtZVOstOXpTkpMu.jpg","original_title":"Role Play","original_language":"en"},{"id":918692,"adult":false,"title":"Granit","video":false,"overview":"Mozambique requests from Russia is being helped in the fight against militants of the \"Islamic State\" and a special group led by a commander with the call sign Granit is coming to the country.","genre_ids":[28,10752],"media_type":"movie","popularity":1.5382,"vote_count":45,"poster_path":"/zLJn4U2qlWIzlFP5SsyFJUDQjfs.jpg","release_date":"2021-12-29","vote_average":7,"backdrop_path":"/oQ429AcD85ttxvOxAaYpETnAsW0.jpg","original_title":"Гранит","original_language":"ru"},{"id":1110859,"adult":false,"title":"Hambre","video":false,"overview":"Leni and Paul are „all good!“, as Paul likes to emphasise. But on this evening even he realises that this is not true at all. Their new neighbours, Mariam and Ayla, who come over for dinner embody exactly what Leni and Paul have not been for one another as a couple for years. While finishing up dessert, the relationship of the perfect couple, centered on their fluffy dog Amor, unfolds.","genre_ids":[18],"media_type":"movie","popularity":1.2919,"vote_count":38,"poster_path":"/rCvHEU3mioUf51DngTBG05JHNYJ.jpg","release_date":"2023-01-27","vote_average":7.026,"backdrop_path":"/A048jIRzQHCIqjX3hBMQOwyWMKD.jpg","original_title":"Hambre","original_language":"de"},{"id":1183699,"adult":false,"title":"The Wingwalker","video":false,"overview":"A young widower is deported as his daughter is scheduled for a heart transplant, this will lead him to orchestrate the boldest border crossing plan in history.","genre_ids":[18,53],"media_type":"movie","popularity":0.4936,"vote_count":40,"poster_path":"/tROfq1PDlMAWAGKAdgaeweobsJ.jpg","release_date":"2024-10-10","vote_average":8.063,"backdrop_path":"/g7cIVHEdgADI3YjI4oCH6xk6vj2.jpg","original_title":"Un Viaje Al Corazón","original_language":"es"},{"id":1145810,"adult":false,"title":"I Don't Expect Anyone to Believe Me","video":false,"overview":"A writer's career — and entire life — suddenly goes off script when he falls prey to a dangerous web of criminals right before moving to Barcelona.","genre_ids":[35,80,18],"media_type":"movie","popularity":0.4676,"vote_count":28,"poster_path":"/5JyivjFm8WzZU2jhzjMWdbWdOwj.jpg","release_date":"2023-11-22","vote_average":6.5,"backdrop_path":"/uA3cuKXb7ELKiXyBo7Fb47kSeZw.jpg","original_title":"No voy a pedirle a nadie que me crea","original_language":"es"},{"id":418533,"adult":false,"title":"Three Christs","video":false,"overview":"Dr. Alan Stone breaks new ground for treatment of the mentally ill through an experiment on three paranoid schizophrenic patients who believe they are Jesus Christ.","genre_ids":[18],"media_type":"movie","popularity":0.815,"vote_count":151,"poster_path":"/4FuSQ9klymXIppnfNUTBg9rOEPf.jpg","release_date":"2017-09-23","vote_average":6.613,"backdrop_path":"/pdHpcFxkU6VmUNsnytbz7u7Xc8A.jpg","original_title":"Three Christs","original_language":"en"},{"id":1175351,"adult":false,"title":"Bosco","video":false,"overview":"Based on the true story of Quawntay “Bosco” Adams. Sentenced to 35 years for attempted possession of marijuana, Adams miraculously escaped from a Federal maximum-security prison while under 24-hour surveillance in solitary confinement with the help of an older woman he met through a lonely-hearts ad.","genre_ids":[18,53],"media_type":"movie","popularity":1.128,"vote_count":48,"poster_path":"/dXjSeS3w97setnrNv4m6tlqqXzn.jpg","release_date":"2024-02-02","vote_average":6.854,"backdrop_path":"/hHw7qug8ka3eppjwTm2aDpOKAUd.jpg","original_title":"Bosco","original_language":"en"},{"id":411268,"adult":false,"title":"Line Walker","video":false,"overview":"The details of undercover police officers are deleted from a police database and a senior officer is left struggling to know who are the undercover officers and who are the criminals.","genre_ids":[28,80,18],"media_type":"movie","popularity":0.8552,"vote_count":73,"poster_path":"/ePNjPe80sb1NitOLHTGh1DxDkWO.jpg","release_date":"2016-08-11","vote_average":6.466,"backdrop_path":"/7q1DrXVUVCHTm6rMGtRcLSqDO3D.jpg","original_title":"使徒行者","original_language":"cn"},{"id":785544,"adult":false,"title":"We Couldn't Become Adults","video":false,"overview":"Prodded by a friend request, a feckless forty-something recalls his past relationships from the 90s onward, looking for his vanished hopes and dreams.","genre_ids":[18,10749],"media_type":"movie","popularity":0.7257,"vote_count":53,"poster_path":"/z3ul9VzWk8Vk5ic7EKujLn8eDeP.jpg","release_date":"2021-11-05","vote_average":6.4,"backdrop_path":"/y7PsnD6oe00OVpDesy0bo0lhQQ3.jpg","original_title":"ボクたちはみんな大人になれなかった","original_language":"ja"},{"id":1184894,"adult":false,"title":"A Flower in the Mud","video":false,"overview":"A teacher arrives at a humble school in the Buenos Aires suburbs to serve as a substitute. There he meets Sofía, a gifted 7-year-old girl. The teacher quickly notices that Sofía may be a case of hidden talent in that environment and decides to do something to help her.","genre_ids":[18],"media_type":"movie","popularity":0.3389,"vote_count":16,"poster_path":"/uSWLOkjSTcQJfaoDrCPzJlVIoVB.jpg","release_date":"2023-09-28","vote_average":7.8,"backdrop_path":"/xitLiFKehBd6snFWYxpvGHlfMVj.jpg","original_title":"Una flor en el barro","original_language":"es"},{"id":1058692,"adult":false,"title":"Love Liz","video":false,"overview":"An aspiring pop star travels to Hollywood to meet a music producer she met over Instagram.","genre_ids":[],"media_type":"movie","popularity":0.0418,"vote_count":1,"poster_path":"/qIUmr0BWhCM6kHMKJzDvYhBrqyA.jpg","release_date":"","vote_average":7,"backdrop_path":null,"original_title":"Love Liz","original_language":"en"},{"id":8340,"adult":false,"title":"Turtles Can Fly","video":false,"overview":"Turtles Can Fly tells the story of a group of young children near the Turkey-Iraq border. They clean up mines and wait for the Saddam regime to fall.","genre_ids":[18],"media_type":"movie","popularity":0.6003,"vote_count":236,"poster_path":"/iNJxHYyFpmqRjgZ4oa5qQna904i.jpg","release_date":"2004-09-10","vote_average":7.7,"backdrop_path":"/3W6CWf6FkSv3wzBdyKZuzwkXz6l.jpg","original_title":"کیسەڵەکانیش دەفڕن","original_language":"ku"},{"id":982940,"adult":false,"title":"Due Justice","video":false,"overview":"An attorney with a military past hunts down the gang who killed his wife and took his daughter.","genre_ids":[28,53,80],"media_type":"movie","popularity":1.7856,"vote_count":81,"poster_path":"/osUFKfa5D1wskPHahUM3GAm1HVh.jpg","release_date":"2023-11-24","vote_average":5.951,"backdrop_path":"/y3A08SqEHqIvelH304qz4GUTLnx.jpg","original_title":"Due Justice","original_language":"en"},{"id":973468,"adult":false,"title":"WILL","video":false,"overview":"Two young police officers find themselves torn between collaboration and resistance as they navigate the Nazi-occupied Antwerp during World War II.","genre_ids":[18,10752,36],"media_type":"movie","popularity":0.9866,"vote_count":110,"poster_path":"/qAhD2oipCFMUXcZ5YDtQg0pwbUY.jpg","release_date":"2023-09-27","vote_average":6.6,"backdrop_path":"/hycr8NAoZgCtLxiSNYZL9kCQcCr.jpg","original_title":"WIL","original_language":"nl"},{"id":1081291,"adult":false,"title":"Faraway","video":false,"overview":"Zeynap Altin is at the end of her tether: she works far too much and is not valued at all by her husband, daughter and father. To make matters worse, the funeral home dressed her beloved late mother in a man's suit instead of her favorite dress. Enough is enough: Zeynep flees from Munich to the previously unknown holiday home on a Croatian island that her mother secretly bought years ago - with the hope of finding quiet, peace and herself there. If only the previous owner Josip, a rough islander, didn't still live on the same property and annoy her with his views and wisdom.","genre_ids":[10749,35],"media_type":"movie","popularity":1.0212,"vote_count":132,"poster_path":"/v4czyy4HQuOMQtGCCB9N6JcvJwT.jpg","release_date":"2023-03-08","vote_average":6.549,"backdrop_path":"/pUptUgPYwdNVSzMNRcUUs7WZ2Ap.jpg","original_title":"Faraway","original_language":"de"},{"id":542928,"adult":false,"title":"The Endless Trench","video":false,"overview":"A small village in Huelva, Andalusia, Spain, 1936. Higinio and Rosa have been married only for a few months when the Civil War breaks out. Higinio, being afraid of possible reprisals from the rebel faction, decides to use a hole dug in his own house as a temporary hideout.","genre_ids":[18,36,53],"media_type":"movie","popularity":0.6765,"vote_count":258,"poster_path":"/rgS3e3sTUHeVgKzKmFhIJcl9tVA.jpg","release_date":"2019-10-31","vote_average":6.862,"backdrop_path":"/r73j0zjtTOsOCStHLby23NNDJyI.jpg","original_title":"La trinchera infinita","original_language":"es"},{"id":799155,"adult":false,"title":"Attack","video":false,"overview":"With the Parliament under siege, India’s first super soldier Arjun Shergill is tasked to get hold of the terrorists in time, save the Prime Minister from their clutches and stop a dirty bomb from exploding and destroying Delhi.","genre_ids":[28,878,53],"media_type":"movie","popularity":4.2874,"vote_count":216,"poster_path":"/A9FjibQFfkPVrfQcM3dlY6fkYpJ.jpg","release_date":"2022-04-01","vote_average":6.8,"backdrop_path":"/AaYfsgRcgU00n0MNVsn1604bfcu.jpg","original_title":"Attack","original_language":"hi"},{"id":928833,"adult":false,"title":"Craig Before the Creek","video":false,"overview":"Before he was Craig of the Creek, he was just Craig — a new kid in a new town. All Craig wants is to go back to his old friends at his old home. But when he learns that the nearby creek is hiding a lost treasure that could make his wish come true, Craig sets off on a journey to find it — navigating the perilous suburban wilderness, forging new friendships, all while being pursued by a fearsome band of pirates who are bent on destroying the Creek itself.","genre_ids":[16,10751,10770,12,35,14],"media_type":"movie","popularity":1.2187,"vote_count":68,"poster_path":"/9CCNNJyhOxGdSoFuBjWHA1c4HPT.jpg","release_date":"2023-12-11","vote_average":7.8,"backdrop_path":"/kB20saHQL6hXyd00vAvHmA7JYLg.jpg","original_title":"Craig Before the Creek","original_language":"en"},{"id":1014209,"adult":false,"title":"Suncoast","video":false,"overview":"While caring for her brother along with her audacious mother, a teenager strikes up an unlikely friendship with an eccentric activist who is protesting one of the most landmark medical cases of all time.","genre_ids":[18,35],"media_type":"movie","popularity":0.7329,"vote_count":135,"poster_path":"/nmPLUp5lVMiGomkN3db1WPeNrz3.jpg","release_date":"2024-02-02","vote_average":6.7,"backdrop_path":"/cJOYsYSz3b3u0JpIWLBEfRam1eR.jpg","original_title":"Suncoast","original_language":"en"}],"similar_content":[{"id":1838,"adult":false,"title":"We Shall Overcome","video":false,"overview":"A drama about a boy who's inspired by Dr. Martin Luther King Jr. and challenges repressive school authority in 1969 Denmark.","genre_ids":[18],"popularity":0.2476,"vote_count":41,"poster_path":"/n0MQPx5v2gCWqe9XbHKY6FFzuYl.jpg","release_date":"2006-03-24","vote_average":7.2,"backdrop_path":"/a0FdVLFrrNuoATac7IIpLF8ycY1.jpg","original_title":"Drømmen","original_language":"da"},{"id":1847,"adult":false,"title":"The Long Goodbye","video":false,"overview":"In 1970s Hollywood, Detective Philip Marlowe tries to help a friend who is accused of murdering his wife.","genre_ids":[9648,18,80],"popularity":1.2943,"vote_count":738,"poster_path":"/oBhUK54yBJ0aH6u9zCzSV5iV7OP.jpg","release_date":"1973-03-08","vote_average":7.406,"backdrop_path":"/g3KOnOycUThwV4PRjtiAK0CuzID.jpg","original_title":"The Long Goodbye","original_language":"en"},{"id":1890,"adult":false,"title":"Children of a Lesser God","video":false,"overview":"Starting his new job as an instructor at a New England school for the deaf, James Leeds meets Sarah Norman, a young deaf woman who works at the school as a member of the custodial staff. In spite of Sarah's withdrawn emotional state, a romance slowly develops between the pair.","genre_ids":[18,10749],"popularity":1.5115,"vote_count":336,"poster_path":"/tWMuw7YWWDpD9Iv652vfKELPZPR.jpg","release_date":"1986-09-13","vote_average":6.9,"backdrop_path":"/fiC5azwRjJmrwI59BlVpLqIegU1.jpg","original_title":"Children of a Lesser God","original_language":"en"},{"id":1900,"adult":false,"title":"Traffic","video":false,"overview":"An exploration of the United States of America's war on drugs from multiple perspectives. For the new head of the Office of National Drug Control Policy, the war becomes personal when he discovers his well-educated daughter is abusing cocaine within their comfortable suburban home. In Mexico, a flawed, but noble policeman agrees to testify against a powerful general in league with a cartel, and in San Diego, a drug kingpin's sheltered trophy wife must learn her husband's ruthless business after he is arrested, endangering her luxurious lifestyle.","genre_ids":[53,18,80],"popularity":3.264,"vote_count":2345,"poster_path":"/jbccmnqE4oAPI67bApgt2JiRPz8.jpg","release_date":"2000-12-27","vote_average":7.084,"backdrop_path":"/nkMgY1XFLWr91najzfvwie8LyYF.jpg","original_title":"Traffic","original_language":"en"},{"id":10697,"adult":false,"title":"The Taste of Others","video":false,"overview":"Unpolished and ultra-pragmatic industrialist Jean-Jacques Castella reluctantly attends Racine's tragedy \"Berenice\" in order to see his niece play a bit part. He is taken with the play's strangely familiar-looking leading lady Clara Devaux. During the course of the show, Castella soon remembers that he once hired and then promptly fired the actress as an English language tutor. He immediately goes out and signs up for language lessons. Thinking that he is nothing but an ill-tempered philistine with bad taste, Clara rejects him until Castella charms her off her feet.","genre_ids":[18,35,10749],"popularity":1.1797,"vote_count":360,"poster_path":"/k9R6Omadvp57EoQ4x9nNneig1Nv.jpg","release_date":"2000-03-01","vote_average":6.804,"backdrop_path":"/tcsHNAMeZubqcAEbCQHd41WvEOA.jpg","original_title":"Le Goût des autres","original_language":"fr"},{"id":4410,"adult":false,"title":"Risky Business","video":false,"overview":"A teenage girl accuses her primary schoolteacher, Jean Doucet (Jacques Brel), of trying to rape her. The police and the mayor investigate, but Doucet denies the charges. Two other students come forward to reveal more of Doucet's misconduct – one confessing to be his mistress. Doucet faces trial and hard labor if convicted.","genre_ids":[18],"popularity":0.1689,"vote_count":37,"poster_path":"/xCt8O9Vcy4gkwBxR0XedcqynroN.jpg","release_date":"1967-12-21","vote_average":7.4,"backdrop_path":"/ruOpBs7sFSKI68DCG1SFXRnqF2h.jpg","original_title":"Les Risques du métier","original_language":"fr"},{"id":4955,"adult":false,"title":"Girls in Uniform","video":false,"overview":"A new student, Manuela, enters a strict girls' boarding school after her mother’s death, where she finds comfort in a kind teacher, stirring complex emotions within her.","genre_ids":[18],"popularity":0.7131,"vote_count":57,"poster_path":"/snsC0lkDugHhhcP64Iyu0x47hBn.jpg","release_date":"1958-07-07","vote_average":6.1,"backdrop_path":"/pq7vwYmOibt9XUsF4rhxHaHyjSq.jpg","original_title":"Mädchen in Uniform","original_language":"de"},{"id":1480,"adult":false,"title":"Touch of Evil","video":false,"overview":"A border-town bombing draws Mexican investigator Miguel Vargas into a corruption-ridden police investigation led by crooked captain Hank Quinlan, setting off a deadly struggle over power, justice, and truth.","genre_ids":[80,53,18],"popularity":2.3898,"vote_count":1559,"poster_path":"/1pvRgmfBaoMczIJBOi9gCOZ4FMC.jpg","release_date":"1958-03-30","vote_average":7.8,"backdrop_path":"/ousBoWTm1CltjAGSYOELYP0jFFC.jpg","original_title":"Touch of Evil","original_language":"en"},{"id":7214,"adult":false,"title":"Coach Carter","video":false,"overview":"Based on a true story, in which Richmond High School head basketball coach Ken Carter made headlines in 1999 for benching his undefeated team due to poor academic results.","genre_ids":[18,36],"popularity":3.1054,"vote_count":3208,"poster_path":"/y3HOTTyM5nLsdUzXFtFCohG28qj.jpg","release_date":"2005-01-14","vote_average":7.57,"backdrop_path":"/n4CvA50GBtIPrSqCl8nMNZCliYI.jpg","original_title":"Coach Carter","original_language":"en"},{"id":7987,"adult":false,"title":"Head Under Water","video":false,"overview":"Something terrible is about to happen in a small town in Germany. Nobody knows the reason why, except one person: Rico Bartsch. The 15-year old grammar school pupil, an absolute outsider, is in love with the most beautiful girl at his school. What in the beginning is a longing that can never be fulfilled will come true at the end of the story. Beautiful Regine will beg for Rico’s love. Until then several inhabitants of the town will die an unnatural death...","genre_ids":[35,53,18],"popularity":0.4477,"vote_count":9,"poster_path":"/na4QzVq5MwUiGf9Bo1a49xuBsPi.jpg","release_date":"2007-09-05","vote_average":5.111,"backdrop_path":"/ApiidJ6mHwZzJjqmGaqs2xXCjAH.jpg","original_title":"Freischwimmer","original_language":"de"},{"id":8053,"adult":false,"title":"The Three Burials of Melquiades Estrada","video":false,"overview":"When brash Texas border officer Mike Norton wrongfully kills and buries the friend and ranch hand of Pete Perkins, the latter is reminded of a promise he made to bury his friend, Melquiades Estrada, in his Mexican home town. He kidnaps Norton and exhumes Estrada's corpse, and the odd caravan sets out on horseback for Mexico.","genre_ids":[12,80,18,9648,37],"popularity":0.8133,"vote_count":630,"poster_path":"/uHOEb6mo45qMSJaZqbkVa7oW1Y7.jpg","release_date":"2005-11-17","vote_average":7,"backdrop_path":"/3n4Bfg390okuusER56enINib0kL.jpg","original_title":"The Three Burials of Melquiades Estrada","original_language":"en"},{"id":7508,"adult":false,"title":"Like Stars on Earth","video":false,"overview":"Ishaan Awasthi is an eight-year-old whose world is filled with wonders that no one else seems to appreciate. Colours, fish, dogs, and kites don't seem important to the adults, who are much more interested in things like homework, marks, and neatness. Ishaan cannot seem to get anything right in class; he is then sent to boarding school, where his life changes forever.","genre_ids":[18],"popularity":3.9722,"vote_count":1292,"poster_path":"/puHRt6Raovm5ujGCdwLWvRv4NHU.jpg","release_date":"2007-12-21","vote_average":7.952,"backdrop_path":"/bPwdy3zaNnMdZ22u0WCcYu0xxgt.jpg","original_title":"तारे ज़मीन पर","original_language":"hi"},{"id":8388,"adult":false,"title":"¡Three Amigos!","video":false,"overview":"A trio of unemployed silent film actors are mistaken for real heroes by a small Mexican village in search of someone to stop a malevolent bandit.","genre_ids":[35,37,18],"popularity":2.7558,"vote_count":1108,"poster_path":"/keQ4ra50w1nktSPRPauxpLaAM2F.jpg","release_date":"1986-12-12","vote_average":6.328,"backdrop_path":"/yMlk79kLF4GrqqP1OY0KccYB787.jpg","original_title":"¡Three Amigos!","original_language":"en"},{"id":8618,"adult":false,"title":"The History Boys","video":false,"overview":"The story of an unruly class of bright, funny history students at a Yorkshire grammar school in pursuit of an undergraduate place at Oxford or Cambridge. Bounced between their maverick English master, a young and shrewd teacher hired to up their test scores, a grossly out-numbered history teacher, and a headmaster obsessed with results, the boys attempt to pass.","genre_ids":[18],"popularity":0.5679,"vote_count":211,"poster_path":"/klybhTU75GUcQbzdVXUhsZgq1EV.jpg","release_date":"2006-10-02","vote_average":6.626,"backdrop_path":"/A159OAi9EAU9v4l3sfMhpMqSK5v.jpg","original_title":"The History Boys","original_language":"en"},{"id":8841,"adult":false,"title":"The Class","video":false,"overview":"Teacher and novelist François Bégaudeau plays a version of himself as he negotiates a year with his racially mixed students from a tough Parisian neighborhood.","genre_ids":[18],"popularity":0.8222,"vote_count":708,"poster_path":"/8yFgK1YgfrnbsRXTg4Hko98nIUt.jpg","release_date":"2008-09-24","vote_average":7,"backdrop_path":"/vGtICaExlrMmQwMPlzt6HLiRKV1.jpg","original_title":"Entre les murs","original_language":"fr"},{"id":8490,"adult":false,"title":"Borderline","video":false,"overview":"Jeb Maynard is a patrolman guarding the U.S.-Mexican border, whose partner and buddy Scooter has just been murdered. Maynard knows that a smuggler of illegal aliens is responsible for Scooter's death, but the feds insist that drug dealers committed the crime.","genre_ids":[28,80,18],"popularity":3.373,"vote_count":48,"poster_path":"/2waGlqv59q6CyzcYozsBh8BNqfx.jpg","release_date":"1980-12-19","vote_average":6,"backdrop_path":"/k6TwVdyLvBL6G4Go4WZBjXEjnAN.jpg","original_title":"Borderline","original_language":"en"},{"id":9918,"adult":false,"title":"Glory Road","video":false,"overview":"In 1966, Texas Western coach Don Haskins led the first all-black starting line-up for a college basketball team to the NCAA national championship.","genre_ids":[18,36],"popularity":1.8684,"vote_count":772,"poster_path":"/bGRSV5tStxDNPRLCewnOeeiZzrY.jpg","release_date":"2006-01-13","vote_average":7.42,"backdrop_path":"/bWN6ZBr6nJNEuHigL9fQWhZ78hd.jpg","original_title":"Glory Road","original_language":"en"},{"id":11518,"adult":false,"title":"Mohabbatein","video":false,"overview":"At a prestigious all-male university, three friends seek love outside of the school grounds; at the same time, a newly-hired music teacher seeks to befriend and loosen up the militantly strict headmaster.","genre_ids":[18,10749],"popularity":2.3178,"vote_count":280,"poster_path":"/dDsYaBazrYKg9bv8qgsEohZQMat.jpg","release_date":"2000-10-27","vote_average":7,"backdrop_path":"/s3IfP462ibiQkfU767D4YcMbKTt.jpg","original_title":"मोहब्बतें","original_language":"hi"},{"id":17435,"adult":false,"title":"El Norte","video":false,"overview":"Brother and sister Enrique and Rosa flee persecution at home in Guatemala and journey north, through Mexico and on to the United States, with the dream of starting a new life.","genre_ids":[12,18],"popularity":1.0026,"vote_count":77,"poster_path":"/bgpz7gTpWmmBb26CcjVtiPE7Kfo.jpg","release_date":"1983-10-11","vote_average":7.117,"backdrop_path":"/5G54yKy3A6MFfwzQ5Q6rrYyjvrY.jpg","original_title":"El Norte","original_language":"es"},{"id":2539,"adult":false,"title":"Spanglish","video":false,"overview":"Mexican immigrant and single mother Flor Moreno finds housekeeping work with Deborah and John Clasky, a well-off couple with two children of their own. When Flor admits she can't handle the schedule because of her daughter, Cristina, Deborah decides they should move into the Clasky home. Cultures clash and tensions run high as Flor and the Claskys struggle to share space while raising their children on their own, and very different, terms.","genre_ids":[18,35],"popularity":2.0269,"vote_count":1361,"poster_path":"/x3OTaBvjqzhRL53Q39fOoIYqxyO.jpg","release_date":"2004-12-17","vote_average":6,"backdrop_path":"/uXJgpBBOxD21X5Q93bZmjNHHdGA.jpg","original_title":"Spanglish","original_language":"en"}],"external_ids":{"imdb_id":"tt14570440","twitter_id":"radicalthemovie","facebook_id":"RadicalTheMovie","wikidata_id":"Q117705982","instagram_id":"radicalthemovie"},"social_ids":{"twitter":"radicalthemovie","facebook":"RadicalTheMovie","instagram":"radicalthemovie"},"gdvg_id":148314,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AU","release_dates":[{"note":"Melbourne International Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2023-08-03T00:00:00.000Z","certification":""},{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2024-05-23T00:00:00.000Z","certification":"M"},{"note":"","type":5,"iso_639_1":"","descriptors":[],"release_date":"2024-08-14T00:00:00.000Z","certification":"M"}]},{"iso_3166_1":"DE","release_dates":[{"note":"","type":3,"