_path":"/dNbfnIhXztzt3mFDHH2RIJWghON.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1600,"height":2400,"file_path":"/diXkLouTDacErlsWC4RfiUjOv74.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/oT5Iz5Sylv7DD6CELVeuLoW5LNo.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/zKiMLdszs1CVIObYQ1q7tso0A8z.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":940,"height":1410,"file_path":"/sQ8cOKO0FyTKgCfLObDpFLRwbAn.jpg","iso_639_1":"uk","iso_3166_1":"UA","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1650,"height":2475,"file_path":"/eBy6D5KSU6U3qEZx7QpYLvAfRO7.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1181,"height":1771,"file_path":"/acWyjQKH8zizphRjh1Ow4CQ4CQC.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/cnmQ86KEX7OeWJlsg38Cu7zNRF1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":3.334},{"width":2100,"height":1182,"file_path":"/2mxu0266fRC6QHFchLHmsZGIFRf.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.777,"vote_average":2.278},{"width":1920,"height":1080,"file_path":"/tNhgMd1A3L39e4V3Ha5Qr4oVNzb.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/puOG0XycWNCeYLihHYq5zGUDPlr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/gQl49yeF5obPM4V0jaAZjBcxMgc.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/o2sV2iXQe6fCOvikVdln0Y3kD8H.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2100,"height":1182,"file_path":"/tGJJw8BZVz0cR1CFcb17aLy3coa.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2100,"height":1182,"file_path":"/yTiTplD5WysSAX0Mi57szwq2OWm.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2100,"height":1181,"file_path":"/lhLbWiWy96NLIzfzz39q7EVPKHi.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2103,"height":1183,"file_path":"/6fBQ1NYEVE63CSYLBQf2ZpiDRvI.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2100,"height":1181,"file_path":"/bxOU4Nh40RqskWoEHQyi2VLjfTy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2100,"height":1182,"file_path":"/9391wFTz5YksN7OmuApVNycX0MX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3840,"height":2160,"file_path":"/kDFEC5pjh224bMUTeethBqHVEnq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/tlwzvQjVGlBcxLPgxxMQEjXVEO1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/5WBxY7zWGCLEGBd4KgiiB3w7Xsh.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/vqqaWmy27VMz2lb20Rg3OEkGSRs.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":null,"enrichment_cycle":0,"translations":[{"data":{"title":"","runtime":120,"tagline":"Aurora had a farm in Africa, at the foot of Mount Tabu…","homepage":"https://www.the-match-factory.com/catalogue/films/tabu.html","overview":"Lisbon, Portugal, 2010. Pilar, a pious woman devoted to social causes, maintains a peculiar relationship with her neighbor Aurora, a temperamental old woman obsessed with gambling who lives tormented by a mysterious past."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Tabú","runtime":120,"tagline":"","homepage":"","overview":"Lisboa, Portugal, 2010. Pilar, una piadosa mujer dedicada a causas sociales, mantiene una peculiar relación con su vecina Aurora, una temperamental anciana obsesionada con el juego que vive atormentada por un misterioso pasado."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Tabou","runtime":120,"tagline":"","homepage":"","overview":"Une vieille dame au fort tempérament, sa femme de ménage Cap-Verdienne et sa voisine dévouée à de bonnes causes partagent le même étage d’un immeuble à Lisbonne. Lorsque la première meurt, les deux autres prennent connaissance d’un épisode de son passé : une histoire d’amour et de crime dans une Afrique de film d’aventures."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Табу","runtime":120,"tagline":"","homepage":"","overview":"Умирая, эксцентричная старушка просит двух соседок разыскать некоего мужчину. Женщины находят незнакомца, который рассказывает им трогательную историю их любви в колониальной Африке и их преступления, после которого они больше никогда не виделись."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":120,"tagline":"","homepage":"","overview":"Hikayede günümüz Lizbon’unda yaşayan düşüncesizce davranan huysuz bir kadın olan Aurora’ya odaklanılıyor. Aurora hastaneye kaldırılınca, komşusu Pilar’a Gian Luca isimli bir adamı durumundan haberdar etmesini söylüyor. Pilar’ın arkadaşının dileğini gerçekleştirmek için çıktığı macera bizi elli yıl öncesine Afrika’ya götürüyor. Orada Aurora’yı tekrar görüyoruz. Bu kez Aurora zengin ve genç bir çiftçinin güzeller güzeli karısı. Ancak Aurora burada kocasının en yakın arkadaşı Gian Luca ile yasak bir ilişki yaşamakta. Duygulu, şairane hikayeleri yaşlı Gian Luca’nın sesinden aktarılıyor…"},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":120,"tagline":"Aurora tinha uma quinta em África, no sopé do Monte Tabu...","homepage":"","overview":"Uma idosa temperamental, a sua empregada cabo-verdiana e uma vizinha dedicada a causas sociais partilham o andar num prédio em Lisboa. Quando a primeira morre, as outras duas passam a conhecer um episódio do seu passado: uma história de amor e crime passada numa África de filme de aventuras."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"禁忌","runtime":120,"tagline":"","homepage":"","overview":"本部影片分为两个章节《失乐园》和《乐园》，讲述了女主人公奥罗拉（劳拉·索维拉尔 Laura Soveral饰）一生波澜壮阔的爱情史诗。喜怒无常的奥罗拉已经年迈，跟自己的黑人女管家住在一起。他们的邻居是一个叫皮拉（特蕾莎·马杜加 Teresa Madruga饰）的热心老妇人。皮拉常常向奥罗拉表达她的善意，可奥罗拉并不领情。在奥罗拉死后，皮拉跟女管家发现了她的一个秘密——一封她生前写给旧情人的信。皮拉决定把这封信寄给奥罗拉的情人，由此引出了奥罗拉一段尘封已久的往事——一段发生在非洲殖民地的难以忘却的爱情和冒险故事。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":120,"tagline":"","homepage":"","overview":"De oudere Portugese dame Aurora en haar Kaapverdische hulp in de huishouding wonen naast Pilar, wier doel in het leven is om goed te doen. Niet dat ze enige erkenning krijgt voor haar inspanningen. En al helemaal niet van de wantrouwende Aurora, die in de haar resterende jaren het liefst haar beetje spaargeld erdoor jaagt in het casino in Estoril. Als de oude Aurora sterft, komt Pilar achter een geheimzinnige brief, die haar op het spoor brengt van een oude geliefde van Aurora."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Tabu - Eine Geschichte von Liebe und Schuld","runtime":120,"tagline":"","homepage":"","overview":"Die streng gläubige Pilar hat es sich zur Lebensaufgabe gemacht, andere Menschen glücklich zu machen. Die alte Nachbarin Aurora ist für diese Mission wie gemacht. Die notorische Rentnerin verspielt ihr ohnehin schon weniges Geld im Casino von Estoril und verdächtigt Haushälterin Santa des Voodoo-Zaubers. Doch als die alte Dame todkrank ans Bett gebunden ist, eröffnet sie Pilar ihren letzten Wunsch. Ihr verschollener Liebhaber Gian Luca Ventura soll wiedergefunden werden. Auf der Suche nach ihm begibt sich Pilar auf die Fährte einer leidenschaftlichen Romanze der Vegangenheit und setzt sich mit Portugal zu Zeiten des Kolonialkrieges auseinander."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"טאבו","runtime":120,"tagline":"","homepage":"","overview":"סרט זכה במקום הראשון בפסטיבל הסרטים בברלין 2012, עלילת הסרט מתחלקת לשני חלקים מאת הבמאי הפורטוגזי העולה, מיגל גומס (Our Beloved Month Of August). בחלקו הראשון, המצולם ב-35 מ\"מ ובשחור-לבן, מתואר משולש יחסים בהווה בין פילאר, אורורה המידרדרת והעוזרת של אורורה, סנטה. חלקו השני של הסרט לוקח את הצופה לקשר הרומנטי שהיה לאורורה הצעירה באפריקה, חמישים שנה קודם לכן. חלק זה צולם ב-16 מ\"מ ומהדהד את הקולנוע האילם (גם בגלל שהוא ממעיט בדיאלוגים), תוך מחווה ברורה למורנאו ופלאהרטי. זוכה שני פרסים בפסטיבל ברלין."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Χαμένος Παράδεισος","runtime":120,"tagline":"","homepage":"","overview":"Η Aurora είναι μια ηλικιωμένη Πορτογαλέζα που ζει μαζί με τον σύζυγό της από το Πράσινο Ακρωτήρι. Στη διπλανή πόρτα μένει η Pilar, μια γυναίκα που σκοπό έχει να κάνει το καλό, παρά το γεγονός ότι δεν λαμβάνει καμία ευγνωμοσύνη για τις προσπάθειές της και κυρίως από την Aurora, που προτιμά να σπαταλά τις οικονομίες της στο πλλησιέστερο καζίνο. Όταν η Aurora πεθάνει, η Pilar ψάχνει τα ίχνη ενός παλιού εραστή."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Табу","runtime":120,"tagline":"","homepage":"","overview":"Историята от първата част на филма Табу - Изгубеният рай се развива в днешен Лисабон и разказва за Пилар, петдесетгодишна жена, членка на християнската общност в Тезе. Тя посвещава времето си на другите хора и на различни добри дела. От време на време се грижи за възрастната си съседка Аурора, която страда от старческа деменция, въобразява си, че е преследвана от цветнокожата си домашна помощница Санта и че е изоставена от дъщеря си. Но всеотдайността на Пилар като че ли не намира истински отзвук нито у околните, нито у хванатата в капана на своите мании възрастна жена. Неочакваната смърт на Аурора ще открехне вратата към едно дълбоко погребано минало във втората част на филма - Раят. Джан-Лука Вентура, отдавна изчезнал любовник на Аурора, е човекът, който ще открие на Пилар и Санта историята на възрастната жена - една тайна любов, която ги събира в Африка, в португалска колония, станала жертва на първите катаклизми на борбата за независимост."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":120,"tagline":"","homepage":"","overview":"Aurora, jej pokojówka Santa i troskliwa Pilar mieszkają na jednym piętrze. Kiedy Aurora podupada na zdrowiu, prosi przyjaciółki, by odnalazły tajemniczego Gianlucę."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Табу","runtime":120,"tagline":"","homepage":"","overview":"Вмираючи, ексцентрична старенька просить двох сусідок розшукати якогось чоловіка. Жінки знаходять незнайомця, який розповідає їм зворушливу історію їхнього кохання в колоніальній Африці і їх злочини, після якого вони більше ніколи не бачилися."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"타부","runtime":120,"tagline":"","homepage":"","overview":"사랑, 강박관념 그리고 기억에 관한 이야기. 과거로부터 멀어질수록 그것은 우리 마음에서 더욱 환하게 불타오른다. 총 3부로 구성된 21세기에 만나는 아주 특별한 흑백 영화."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Tabù","runtime":120,"tagline":"","homepage":"","overview":"Una vecchia signora dal forte temperamento, la sua badante capoverdiana e una vicina di casa da sempre impegnata in cause civili condividono lo stesso pianerottolo di un condominio di Lisbona. Alla morte dell'anziana, le altre due vengono a conoscenza di un episodio del suo passato, legato a un'intrigante storia d'amore e di crimine che questa aveva vissuto tempo prima nella lontana Africa, rompendo ogni convenzione sociale."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":119,"tagline":"Aurora tinha uma fazenda na África, no sopé do Monte Tabu…","homepage":"","overview":"Aurora, uma idosa de opiniões contraditórias, convive com uma empregada cabo-verdiana e uma amiga engajada em causas sociais. Após sua morte, fatos obscuros de seu passado surgem, e as companheiras de Aurora conhecem sua trágica aventura na África."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"禁忌","runtime":0,"tagline":"","homepage":"","overview":"本部影片分為兩個章節《失樂園》和《樂園》，講述了女主人公奧羅拉（勞拉·索維拉爾 Laura Soveral 飾）一生波瀾壯闊的愛情史詩。喜怒無常的奧羅拉已經年邁，跟自己的黑人女管家住在一起。他們的鄰居是一個叫皮拉（特蕾莎·馬杜加 Teresa Madruga 飾）的熱心老婦人。皮拉常常向奧羅拉表達她的善意，可奧羅拉並不領情。在奧羅拉死後，皮拉跟女管家發現了她的一個秘密——一封她生前寫給舊情人的信。皮拉決定把這封信寄給奧羅拉的情人，由此引出了奧羅拉一段塵封已久的往事——一段發生在非洲殖民地的難以忘卻的愛情和冒險故事。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":44754,"adult":false,"title":"Margaret","video":false,"overview":"17-year-old Lisa feels certain that she inadvertently played a role in causing a traffic accident that claimed a woman's life. In her attempts to set things right, she meets with opposition at every step. Torn apart with frustration, she begins emotionally brutalizing her family, her friends, her teachers, and, most of all, herself. She has been confronted quite unexpectedly with a basic truth: that her youthful ideals are on a collision course with the realities and compromises of the adult world.","genre_ids":[18],"media_type":"movie","popularity":3.9482,"vote_count":319,"poster_path":"/zqBao8uRH6TQAJd13tqC22vPB76.jpg","release_date":"2011-09-30","vote_average":6.304,"backdrop_path":"/ugDpO1cu2RxL1URucxPLkT31KG3.jpg","original_title":"Margaret","original_language":"en"},{"id":489990,"adult":false,"title":"Pity","video":false,"overview":"The story of a man who feels happy only when he is unhappy: addicted to sadness, with such need for pity, that he’s willing to do everything to evoke it from others. This is the life of a man in a world not cruel enough for him.","genre_ids":[18],"media_type":"movie","popularity":0.3455,"vote_count":63,"poster_path":"/6mFqRhVAvQTNCMzRBlBRZtXFL3h.jpg","release_date":"2018-09-12","vote_average":6.294,"backdrop_path":"/5ViKlq7AObQ19Q0g1Mf0YMfzA3S.jpg","original_title":"Οίκτος","original_language":"el"},{"id":48392,"adult":false,"title":"Sound of Noise","video":false,"overview":"A tone-deaf cop works to track down a group of guerilla percussionists whose anarchic public performances are terrorizing the city.","genre_ids":[35,80],"media_type":"movie","popularity":0.4399,"vote_count":177,"poster_path":"/fD4WnzQH0YrvqXXon9RDTnOVPUw.jpg","release_date":"2010-12-25","vote_average":7.189,"backdrop_path":"/d6IpPxxsDtKqc9b3QOjtkA40zQB.jpg","original_title":"Sound of Noise","original_language":"sv"},{"id":39504,"adult":false,"title":"Moolaadé","video":false,"overview":"When a woman shelters a group of girls from suffering female genital mutilation, she starts a conflict that tears her village apart.","genre_ids":[18],"media_type":"movie","popularity":0.9081,"vote_count":74,"poster_path":"/9S7lWdLExHw6LP3Vq7smiyGY5MR.jpg","release_date":"2004-08-04","vote_average":7.2,"backdrop_path":"/3v7Y2bx5gSSlQGBUz9O0QX9RyRB.jpg","original_title":"Moolaadé","original_language":"bm"},{"id":467539,"adult":false,"title":"The Sower","video":false,"overview":"In 1852, the mountain village in Provence where Violette lives is brutally deprived of all its men after the repression of the republicans ordered by Napoleon III. Women spend months in total isolation, desperate to see their men again. In this situation, they make an oath in case a man arrives in the village.","genre_ids":[18],"media_type":"movie","popularity":0.792,"vote_count":41,"poster_path":"/kNBJRN1ksEGbYH7SMnviHu7vjJD.jpg","release_date":"2017-10-26","vote_average":5.9,"backdrop_path":"/bRJ9CKZkfCU1kMaF4US1Nd4kv8t.jpg","original_title":"Le Semeur","original_language":"fr"},{"id":436167,"adult":false,"title":"The Divine Order","video":false,"overview":"Nora is a young housewife and mother, living in a quaint little village with her husband and their two sons. The Swiss countryside is untouched by the major social upheavals the movement of 1968 has brought about. Nora’s life is not affected either; she is a quiet person who is liked by everybody – until she starts to publicly fight for women’s suffrage, which the men are due to vote on in a ballot on February 7, 1971.","genre_ids":[35,18],"media_type":"movie","popularity":0.3022,"vote_count":137,"poster_path":"/xkdnTSj3Zia0rik1wh6agIf2jNF.jpg","release_date":"2017-03-09","vote_average":7.3,"backdrop_path":"/1Zf8KuRm1yJhvZJi7QNxV8yjclz.jpg","original_title":"Die göttliche Ordnung","original_language":"de"},{"id":28955,"adult":false,"title":"First Man into Space","video":false,"overview":"The first pilot to leave Earth's atmosphere lands, then vanishes; but something with a craving for blood prowls the countryside...","genre_ids":[878,27,18],"media_type":"movie","popularity":0.211,"vote_count":57,"poster_path":"/lKBIGRetSbZ6cBRWqaNzwHvkgy9.jpg","release_date":"1959-02-01","vote_average":4.982,"backdrop_path":"/mUMttVYif1VVyeYhigkBHLb8K2b.jpg","original_title":"First Man into Space","original_language":"en"},{"id":286330,"adult":false,"title":"Mau Mau Maria","video":false,"overview":"Three brothers are confronted with an imposing father who avail them the heritage, identity and emotional intelligence: seven weeks is the deadline for each of them find the respect and love of a woman.","genre_ids":[35],"media_type":"movie","popularity":0.175,"vote_count":10,"poster_path":"/o168O5miZpz0c4ZmFnoLy4ozODO.jpg","release_date":"2014-10-30","vote_average":5.5,"backdrop_path":"/gGfkixSH04GOK7LsiQdClKdPKYR.jpg","original_title":"Mau Mau Maria","original_language":"pt"},{"id":433356,"adult":false,"title":"The Ottoman Lieutenant","video":false,"overview":"Lillie, a determined American woman, ventures overseas to join Dr. Jude at a remote medical mission in the Ottoman Empire (now Turkey). However, Lillie soon finds herself at odds with Jude and the mission’s founder, Woodruff, when she falls for the titular military man, Ismail, just as the war is about to erupt.","genre_ids":[10749,18,10752],"media_type":"movie","popularity":1.1535,"vote_count":274,"poster_path":"/keHVpf7x6Na3KK7ep2BXzd2jlCv.jpg","release_date":"2017-03-28","vote_average":6.082,"backdrop_path":"/7RJmCyuTPbckzian3DvSbfgWSYE.jpg","original_title":"The Ottoman Lieutenant","original_language":"en"},{"id":78480,"adult":false,"title":"Monsieur Lazhar","video":false,"overview":"During a harsh Montréal winter, an elementary-school class is left reeling after its teacher commits suicide. Bachir Lazhar, a charismatic Algerian immigrant, steps in as the substitute teacher for the classroom of traumatized children. All the while, he must keep his personal life tucked away: the fact that he is seeking political refuge in Québec – and that he, like the children, has suffered an appalling loss.","genre_ids":[18,35],"media_type":"movie","popularity":3.6171,"vote_count":341,"poster_path":"/qcSXbOP1iv859kgQgqZ4Ib9yqKG.jpg","release_date":"2011-09-10","vote_average":7.172,"backdrop_path":"/bMdKv4K2QgAStm0PLQIHNsgMpND.jpg","original_title":"Monsieur Lazhar","original_language":"fr"},{"id":266082,"adult":false,"title":"Girlhood","video":false,"overview":"Oppressed by her family setting, dead-end school prospects and the boys law in the neighborhood, Marieme starts a new life after meeting a group of three free-spirited girls. She changes her name, her dress code, and quits school to be accepted in the gang, hoping that this will be a way to freedom.","genre_ids":[18],"media_type":"movie","popularity":0.4435,"vote_count":394,"poster_path":"/qZ52DlSVguX0WHYoiOD464IIONd.jpg","release_date":"2014-10-22","vote_average":6.445,"backdrop_path":"/yJ9HQ4OrFouSj8kRF9opf8s7yGE.jpg","original_title":"Bande de filles","original_language":"fr"},{"id":186992,"adult":false,"title":"Stranger by the Lake","video":false,"overview":"Frank spends his summer days hopelessly searching for companionship at a popular cruising spot on the shores of a lake in rural France. One day, he meets Michel, an attractive yet darkly mysterious man and falls blindly in love.","genre_ids":[18,53],"media_type":"movie","popularity":1.0199,"vote_count":459,"poster_path":"/ug6IbPt19J8YIW9vh87Xw9FOTaJ.jpg","release_date":"2013-06-12","vote_average":6.3,"backdrop_path":"/kwhZU5VYcikvoGMejg6gBo4kpwx.jpg","original_title":"L'Inconnu du lac","original_language":"fr"},{"id":558582,"adult":false,"title":"First Cow","video":false,"overview":"In the 1820s, a taciturn loner and skilled cook travels west to Oregon Territory, where he meets a Chinese immigrant also seeking his fortune. Soon the two team up on a dangerous scheme to steal milk from the wealthy landowner’s prized Jersey cow—the first, and only, in the territory.","genre_ids":[18,37],"media_type":"movie","popularity":1.4173,"vote_count":521,"poster_path":"/yS41crZ1i0fFxCQbuL7I1Y1VBwm.jpg","release_date":"2020-03-06","vote_average":7.1,"backdrop_path":"/8P3qur5Xh6dsH6xmZ1O2XS7vnc2.jpg","original_title":"First Cow","original_language":"en"},{"id":2517,"adult":false,"title":"Nobody Knows","video":false,"overview":"In a small Tokyo apartment, twelve-year-old Akira must care for his younger siblings after their mother leaves them and shows no sign of returning.","genre_ids":[18],"media_type":"movie","popularity":2.2156,"vote_count":617,"poster_path":"/kDUUdWrbBBVqzSmm27pHFJcTvCU.jpg","release_date":"2004-08-07","vote_average":7.981,"backdrop_path":"/gCD0eMZW1pUitLzH93WYWJYQgGk.jpg","original_title":"誰も知らない","original_language":"ja"},{"id":84175,"adult":false,"title":"Beasts of the Southern Wild","video":false,"overview":"Hushpuppy, an intrepid six-year-old girl, lives with her father, Wink, in 'the Bathtub', a southern Delta community at the edge of the world. Wink’s tough love prepares her for the unraveling of the universe—for a time when he’s no longer there to protect her. When Wink contracts a mysterious illness, nature flies out of whack—temperatures rise and the ice caps melt, unleashing an army of prehistoric creatures called aurochs. With the waters rising, the aurochs coming, and Wink’s health fading, Hushpuppy goes in search of her lost mother.","genre_ids":[18,14],"media_type":"movie","popularity":0.856,"vote_count":1126,"poster_path":"/nQJmWekGYlXhezGUb21xFfEfwhH.jpg","release_date":"2012-06-29","vote_average":6.83,"backdrop_path":"/7LWLPvyfLSb2oOlgWwAwUqA8uKo.jpg","original_title":"Beasts of the Southern Wild","original_language":"en"},{"id":892,"adult":false,"title":"Delicatessen","video":false,"overview":"In a post-apocalyptic world, the residents of an apartment above the butcher shop receive an occasional delicacy of meat, something that is in low supply. A young man new in town falls in love with the butcher's daughter, which causes conflicts in her family, who need the young man for other business-related purposes.","genre_ids":[35,878,14],"media_type":"movie","popularity":2.4423,"vote_count":1590,"poster_path":"/gNtOgQHxE5B8e08zuNRAdDpmK5Z.jpg","release_date":"1991-04-17","vote_average":7.302,"backdrop_path":"/A3qvUUd36LUF5sfPYOHEd3ahDp2.jpg","original_title":"Delicatessen","original_language":"fr"},{"id":86837,"adult":false,"title":"Amour","video":false,"overview":"Georges and Anne are in their eighties. They are cultivated, retired music teachers. Their daughter, who is also a musician, lives abroad with her family. One day, Anne has a stroke, and the couple's bond of love is severely tested.","genre_ids":[18,10749],"media_type":"movie","popularity":4.1844,"vote_count":1742,"poster_path":"/19hyCudualHxCD0GrEngqsi0wBF.jpg","release_date":"2012-09-20","vote_average":7.756,"backdrop_path":"/w7Z4BVMin49voNN61IUWyN9DopV.jpg","original_title":"Amour","original_language":"fr"},{"id":92321,"adult":false,"title":"Hotarubi no Mori e","video":false,"overview":"One hot summer day a little girl gets lost in an enchanted forest of the mountain god where spirits reside. A young boy appears before her, but she cannot touch him for fear of making him disappear. And so a wondrous adventure awaits...","genre_ids":[10749,16,14],"media_type":"movie","popularity":0.0043,"vote_count":1200,"poster_path":"/mDqzHV8UXWWNpZkoAbKmKX1ZxEE.jpg","release_date":"2011-09-17","vote_average":8.256,"backdrop_path":"/qknxyRgP6UTmwJ4B9tDAmzHMq7u.jpg","original_title":"蛍火の杜へ","original_language":"ja"},{"id":727745,"adult":false,"title":"The Kissing Booth 3","video":false,"overview":"It’s the summer before Elle heads to college, and she has a secret decision to make. Elle has been accepted into Harvard, where boyfriend Noah is matriculating, and also Berkeley, where her BFF Lee is headed and has to decide if she should stay or not.","genre_ids":[10749,35],"media_type":"movie","popularity":3.4333,"vote_count":1999,"poster_path":"/c7xcqnMDVQ5v1hJBm3AZ5YikNe6.jpg","release_date":"2021-08-11","vote_average":6.862,"backdrop_path":"/oOZM1C3wZtsZtdidVgEazeas7U4.jpg","original_title":"The Kissing Booth 3","original_language":"en"},{"id":1013850,"adult":false,"title":"A Real Pain","video":false,"overview":"Mismatched cousins David and Benji reunite for a tour through Poland to honor their beloved grandmother. The adventure takes a turn when the pair's old tensions resurface against the backdrop of their family history.","genre_ids":[35,18],"media_type":"movie","popularity":5.8407,"vote_count":1316,"poster_path":"/67xRIXm5TxXRT4nV2V4AEJ9yq2d.jpg","release_date":"2024-11-01","vote_average":6.767,"backdrop_path":"/fViElUGfdoZjtnVxvSpJX8TwxY6.jpg","original_title":"A Real Pain","original_language":"en"}],"similar_content":[{"id":261,"adult":false,"title":"Cat on a Hot Tin Roof","video":false,"overview":"An alcoholic ex-football player drinks his days away, having failed to come to terms with his sexuality and his real feelings for his football buddy who died after an ambiguous accident. His wife is crucified by her desperation to make him desire her: but he resists the affections of his wife. His reunion with his father—who is dying of cancer—jogs a host of memories and revelations for both father and son.","genre_ids":[18],"popularity":1.0242,"vote_count":819,"poster_path":"/5djZZECgqDGuSI1INmrdAcGRBb0.jpg","release_date":"1958-08-29","vote_average":7.6,"backdrop_path":"/3Yz8IcUBPZ8zDff0ktHZk24Rot0.jpg","original_title":"Cat on a Hot Tin Roof","original_language":"en"},{"id":272,"adult":false,"title":"Batman Begins","video":false,"overview":"Driven by tragedy, billionaire Bruce Wayne dedicates his life to uncovering and defeating the corruption that plagues his home, Gotham City.  Unable to work within the system, he instead creates a new identity, a symbol of fear for the criminal underworld - The Batman.","genre_ids":[18,80,28],"popularity":12.5976,"vote_count":22281,"poster_path":"/sPX89Td70IDDjVr85jdSBb4rWGr.jpg","release_date":"2005-06-10","vote_average":7.721,"backdrop_path":"/9IIBboV7MCT0bTxzXHmWK1Hq558.jpg","original_title":"Batman Begins","original_language":"en"},{"id":194,"adult":false,"title":"Amélie","video":false,"overview":"At a tiny Parisian café, the adorable yet painfully shy Amélie accidentally discovers a gift for helping others. Soon Amelie is spending her days as a matchmaker, guardian angel, and all-around do-gooder. But when she bumps into a handsome stranger, will she find the courage to become the star of her very own love story?","genre_ids":[35,10749],"popularity":6.8113,"vote_count":12227,"poster_path":"/nSxDa3M9aMvGVLoItzWTepQ5h5d.jpg","release_date":"2001-04-25","vote_average":7.916,"backdrop_path":"/6n53UI4mX9QMfe2S0Pgt8mGebY1.jpg","original_title":"Le Fabuleux Destin d'Amélie Poulain","original_language":"fr"},{"id":1651,"adult":false,"title":"Mississippi Mermaid","video":false,"overview":"A tobacco planter on Réunion island in the Indian Ocean becomes engaged through correspondence to a French woman he does not know. The woman that arrives does not look like the picture he received, but he marries her anyway.","genre_ids":[10749,18,80,53],"popularity":0.8488,"vote_count":214,"poster_path":"/l2jsT4bWzGZry34x4k5eNiSquhv.jpg","release_date":"1969-06-18","vote_average":6.61,"backdrop_path":"/bEe4xvjFr9kObNeBCw8kce3o047.jpg","original_title":"La Sirène du Mississipi","original_language":"fr"},{"id":1719,"adult":false,"title":"The Soft Skin","video":false,"overview":"Pierre Lachenay is a well-known publisher and lecturer, married to Franca and father of Sabine. He starts a love affair with air hostess Nicole, which Pierre is hiding, but he cannot stay away from her.","genre_ids":[18,10749],"popularity":0.4266,"vote_count":212,"poster_path":"/nYo083NgJCAQQByHzYrayxQ5xBV.jpg","release_date":"1964-04-20","vote_average":7.1,"backdrop_path":"/9yPgh3v4itb0ah4XWgGM4BdAtNa.jpg","original_title":"La Peau douce","original_language":"fr"},{"id":1951,"adult":false,"title":"Manderlay","video":false,"overview":"In 1933, a young woman and her father discover an Alabama plantation whose inhabitants live as if slavery had never been abolished. Feeling a sense of duty to those behind the heavy gates, she stays to liberate the people and see them through their first harvest. With four of her father's colleagues and a lawyer, she faces the daunting task of resurrecting the place known as Manderlay.","genre_ids":[18],"popularity":4.2026,"vote_count":389,"poster_path":"/6HYoHEcLNgETHlJDyQrC4Y7e01.jpg","release_date":"2005-06-03","vote_average":6.882,"backdrop_path":"/dbAAQhptC6FyxBJx91IQv9zRiki.jpg","original_title":"Manderlay","original_language":"da"},{"id":859912,"adult":false,"title":"Autumn Road","video":false,"overview":"10 years after a young girl goes missing on Halloween night, her sister returns to their hometown to look for answers. Along the way she becomes entangled with two mysterious identical twins who run the town's roadside haunted house.","genre_ids":[27,18,9648,53],"popularity":0.216,"vote_count":6,"poster_path":"/nV6kTHNwU7M9CgzFNQrycXKTbix.jpg","release_date":"2021-11-23","vote_average":3.333,"backdrop_path":"/n8AAx3kafkNOHHyXUdzdsGxFmP8.jpg","original_title":"Autumn Road","original_language":"en"},{"id":4738,"adult":false,"title":"You're Not Alone","video":false,"overview":"Master painter Hans Moll and his wife, the television announcer Ms. Wellinek and her husband, and the German-Russian Jew Yevgenia have many things to live on: food, drink, an apartment. What they do not have is work. They all discover the yearning for a chance to start all over again and bring themselves back to life.","genre_ids":[35,18],"popularity":0.2053,"vote_count":7,"poster_path":"/mvpla1RyHdZoIQfbfPm8RuG8ZNx.jpg","release_date":"2007-07-19","vote_average":5.3,"backdrop_path":"/5I0BXbrDTl6aL9ApFCKK2O8rUik.jpg","original_title":"Du bist nicht allein","original_language":"de"},{"id":14748,"adult":false,"title":"Boy A","video":false,"overview":"Freed after a lengthy term in a juvenile detention center, convicted child killer Jack Burridge finds work as a deliveryman and begins dating co-worker Michelle. While out on the road one day, Jack notices a distressed child, and, after reuniting the girl with her family, becomes a local celebrity. But when a local newspaper unearths his past, Jack must cope with the anger of citizens who fear for the safety of their children.","genre_ids":[80,18],"popularity":2.8142,"vote_count":486,"poster_path":"/wrQQUjeiHFPvTfaaB3vtNLLZ8kv.jpg","release_date":"2008-07-23","vote_average":7.117,"backdrop_path":"/gCPaaz5fkbHBaU2DIK2rhNIIxZF.jpg","original_title":"Boy A","original_language":"en"},{"id":11050,"adult":false,"title":"Terms of Endearment","video":false,"overview":"Aurora, a finicky woman, is in search of true love while her daughter faces marital issues. Together, they help each other deal with problems and find reasons to live a joyful life.","genre_ids":[18,35],"popularity":3.0678,"vote_count":812,"poster_path":"/l77DRjJuykqKMtD9GTK4YT7qKHW.jpg","release_date":"1983-11-20","vote_average":7.123,"backdrop_path":"/kz22OnVmpexRQmDXzoBwveOmuWd.jpg","original_title":"Terms of Endearment","original_language":"en"},{"id":1072805,"adult":false,"title":"Lyvia's House","video":false,"overview":"When a young journalist suspects the disappearance of a beautiful artist is connected to murders that took place 20 years earlier, she uncovers a reality she never could have imagined. Inspired by true events.","genre_ids":[53,9648,14,18],"popularity":0.1871,"vote_count":5,"poster_path":"/j5kOuFOQ84DPH94RJ6U1MWT9UJX.jpg","release_date":"2024-01-13","vote_average":6,"backdrop_path":"/A47ST56xzw6zuHhHZiylLgfNRIu.jpg","original_title":"Lyvia's House","original_language":"en"},{"id":14138,"adult":false,"title":"Black Water","video":false,"overview":"Based on true events, Grace, her boyfriend Adam, and her younger sister, Lee, are on holiday in Northern Australia when they decide to take a tour down a river. As they drift into a swamp, their boat suddenly capsizes. Stranded in the flooded swamp, the three tourists must figure out what to do to survive as they realize they are being watched through the black water.","genre_ids":[12,18,27],"popularity":1.0703,"vote_count":376,"poster_path":"/7hd6iyViluCMOqIJz5TsiyBFqp9.jpg","