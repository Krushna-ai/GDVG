io":0.705,"vote_average":0},{"width":853,"height":1280,"file_path":"/ajv99fDULy90GXvxWtl6a9FVRK9.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":0.666,"vote_average":0},{"width":2000,"height":3000,"file_path":"/qJLUqFXoGOr7mSeiM5FYNN3chlF.jpg","iso_639_1":"uk","iso_3166_1":"UA","vote_count":1,"aspect_ratio":0.667,"vote_average":0},{"width":1852,"height":2778,"file_path":"/n0Xw9kDKgQfgxl6BZmjFzvOK14L.jpg","iso_639_1":"hu","iso_3166_1":"HU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":700,"height":1050,"file_path":"/su5EPNiDxEtuL7eYvRs6AzCY0lD.jpg","iso_639_1":"pl","iso_3166_1":"PL","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/sY7dcqyvUKbVKwaNFOPaPgljyj0.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/91ieSOfKpEvMZoZVl4QZudlcT1Y.jpg","iso_639_1":"el","iso_3166_1":"GR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1372,"height":2057,"file_path":"/jkRMoYK3X1Dh92RfA2jxZvNcpiU.jpg","iso_639_1":"sv","iso_3166_1":"SE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/ts4cvZCzCplcJEvpxXt9X6AarEU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1280,"height":1810,"file_path":"/1q2kNizeHMPBRxvJOWdwRzKLo3x.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.707,"vote_average":0},{"width":675,"height":1000,"file_path":"/l95rWGhOG9cm5XkKiYRBr2KdZu2.jpg","iso_639_1":"et","iso_3166_1":"EE","vote_count":0,"aspect_ratio":0.675,"vote_average":0},{"width":680,"height":924,"file_path":"/oNMGpJcfgrX6OSidp3NpQHTfD5R.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.736,"vote_average":0},{"width":1067,"height":1600,"file_path":"/1qMqikaGRuOGWMLusa7AXdQSvzL.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":896,"height":1279,"file_path":"/4H1UpxVy6UYXBGwLX4mwkJLiYxz.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":0.701,"vote_average":0},{"width":2000,"height":3000,"file_path":"/zCS4GN2DxsVz54rogDNVSyBtOGH.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/2UXrkv2G1aXMyn3VY70krD9Anid.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":3109,"height":1749,"file_path":"/uy4jbDEavQfrMKRV4BMetMZXvUe.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/3OGzBIBpcvG4Facmmo8R0o13sKv.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/inJ4UQWt8WXg82ADgGW46h7MedT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":1.434},{"width":1920,"height":1080,"file_path":"/kStM4ybSFKHtpdudcFZbDDrlT9Z.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/lAZM3dLd1wFyBJXmfcFB2CyuyCc.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/zGNnZNmJGW7EQTS8ZZyA1q4QBti.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/ad4qGJwzDRuSO211fusfbcOJ1AX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-01T10:16:04.682+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Blue Trail","runtime":86,"tagline":"","homepage":"https://pt.desvia.com.br/O-ULTIMO-AZUL","overview":"In the name of economic recovery, the Brazilian Government created a perennial system of compulsory vertical isolation for seniors over 80 to be confined in a colony. Teca is 77 and lives in the village of Muriti, in the Amazon, when she is surprised by the announcement of the age reduction, including her age group. Cornered, Teca makes an intriguing journey hidden from the officers amidst rivers, boats and the underworld to clandestinely try to fulfill her last dream, to take a plane ride."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":87,"tagline":"","homepage":"https://pt.desvia.com.br/O-ULTIMO-AZUL","overview":"Em meio à busca pela recuperação econômica, o governo institui colônias compulsórias, confinando os idosos para que possam desfrutar seus últimos anos de vida. Teresa, residente em uma cidade industrializada na Amazônia, surpreende-se ao ser incluída no programa quando a idade mínima é alterada. Com poucos dias restantes, Teresa decide desafiar seu destino, embarcando numa jornada pelos rios e afluentes da Amazônia para realizar um último desejo."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"마지막 푸른빛","runtime":86,"tagline":"","homepage":"","overview":"77세의 테레사는 ‘은퇴 구역’으로 이송되기 직전 자유를 찾아 탈출을 감행한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"天空的另一面","runtime":0,"tagline":"","homepage":"","overview":"77岁的特蕾莎一生居住在亚马逊雨林旁的一座工业化小镇。某天，她突然接到政府指令，要求搬迁至一处老年安置区——那是一个与世隔绝的区域，老年人被集中安置以“安享”晚年，以便年轻一代能完全专注于生产力与发展。特蕾莎拒绝接受强加于她的命运。她毅然踏上旅程，沿亚马逊的河流与支流开启了一场蜕变之旅，决心在被剥夺自由前实现最后一个愿望——这个决定将永远改变她的命运。[柏林电影节]"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Błękitny szlak","runtime":0,"tagline":"Ironiczna i dowcipna opowieść o walce o wolność i szczęście.","homepage":"https://aurorafilms.pl/film/blekitny-szlak/","overview":"W ramach programu odbudowy gospodarki rząd Brazylii wprowadza obowiązkową izolację seniorów – osoby po 80. roku życia mają zostać przymusowo przeniesione do specjalnych kolonii. Teca ma 77 lat i mieszka w amazońskiej wiosce Muriti. Gdy władze niespodziewanie obniżają granicę wieku, obejmując programem również jej rocznik, kobieta staje pod ścianą. Zamiast się poddać, ucieka i wyrusza w podróż przez rzeki i małe porty Amazonii, zahaczając o półświatek. Chce spełnić swoje ostatnie marzenie – choć raz w życiu polecieć samolotem."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Das tiefste Blau","runtime":90,"tagline":"","homepage":"","overview":"Die 77-jährige Tereza lebt in einer kleinen Industriestadt im Amazonasgebiet. Eines Tages erhält sie die offizielle Anweisung der Regierung, in eine Seniorenkolonie in einer entlegenen Gegend zu ziehen. Hier sollen die Alten ihre letzten Jahre „genießen“, während die junge Generation sich voll und ganz auf Produktivität und Wirtschaftswachstum konzentrieren kann. Doch Tereza widersetzt sich. Sie begibt sich auf eine Reise immer weiter hinein in das Amazonasgebiet, durch die Nebenflüsse und den Dschungel. Einen letzten Wunsch will sie sich erfüllen, bevor man ihr die Freiheit nimmt. Einen letzten Wunsch, der Tereza verändern und ihr Leben in eine neue Richtung lenken wird."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Les voyages de Tereza","runtime":87,"tagline":"","homepage":"","overview":"Tereza a vécu toute sa vie dans une petite ville industrielle d’Amazonie. Le jour venu, elle reçoit l'ordre officiel du gouvernement de s’installer dans une colonie isolée pour personnes âgées, où elles sont amenées à « profiter » de leurs dernières années. Tereza refuse ce destin imposé et décide de partir seule à l'aventure, découvrir son pays et accomplir son rêve secret…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Блакитна стежка","runtime":0,"tagline":"","homepage":"","overview":"Бразилія, недалеке майбутнє. Уряд переселяє літніх людей до ізольованих колоній, щоб молоде покоління могло зосередитися на продуктивності та розвитку. Тереза, якій майже 80 років, вирішує кинути виклик системі. Замість того щоб змиритися зі своєю долею, вона рушає в подорож Амазонією, щоб здійснити останнє бажання перед втратою свободи."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"藍色亞馬遜","runtime":0,"tagline":"","homepage":"","overview":"為了促進經濟發展，政府在偏遠地區為 80 歲以上的老人建立了隔離安養院，確保他們衣食無憂地度過晚年。77 歲的德蕾莎一生在亞馬遜的穆里蒂村度過，直到某天接到政府的命令，因為年齡門檻下修，要求她搬遷到隔離區。距離轉移的日子只剩幾天，德蕾莎決定挑戰命運，踏上穿越亞馬遜的旅程，實現她人生的最後一個願望：搭飛機。在躲避政府追捕的過程中，德蕾莎穿梭於亞馬遜的河流之間，卻未曾想過這趟旅程將遠比她想像的更加不可思議。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"藍色亞馬遜","runtime":0,"tagline":"","homepage":"","overview":"為了促進經濟發展，政府在偏遠地區為 80 歲以上的老人建立了隔離安養院，確保他們衣食無憂地度過晚年。77 歲的德蕾莎一生在亞馬遜的穆裏蒂村度過，直到某天接到政府的命令，因為年齡門檻下修，要求她搬遷到隔離區。距離轉移的日子只剩幾天，德蕾莎決定挑戰命運，踏上穿越亞馬遜的旅程，實現她人生的最後一個願望：搭飛機。在躲避政府追捕的過程中，德蕾莎穿梭於亞馬遜的河流之間，卻未曾想過這趟旅程將遠比她想像的更加不可思議。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":86,"tagline":"","homepage":"","overview":"De 77-jarige Tereza, geboren en getogen in een industriestadje aan de rand van het Amazonegebied, krijgt plots het bevel haar huis te verlaten. De staat dwingt haar te verplaatsen naar een zogenaamde ‘seniorenkolonie’, een plek waar ouderen geacht worden van hun laatste jaren te 'genieten' zodat de jonge generatie zich volledig op groei en productiviteit kan storten. Maar Tereza legt zich niet neer bij deze onmenselijke maatregel. In plaats van haar vrijheid op te geven, begint ze aan een clandestiene bootreis door de Amazone. Wat volgt is een tocht door weelderige landschappen vol obstakels, onverwachte ontmoetingen en een groeiend besef dat vrijheid geen leeftijd kent."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Il sentiero azzurro","runtime":0,"tagline":"Non è mai troppo tardi per sognare una nuova vita","homepage":"","overview":"In un Brasile del futuro prossimo, la parte più anziana della popolazione viene al tempo stesso celebrata e ostracizzata, in una serie di attività cerimoniali di facciata che nascondono un tentativo di controllo e di rimozione forzata dalla società. È il caso di Tereza, che come molti altri è costretta a smettere di lavorare finendo sotto la custodia della figlia, senza poter nemmeno comprare cose in autonomia. Ancora fieramente indipendente, la donna non vuole rassegnarsi a trascorrere il resto dei suoi giorni nell'inquietante \"colonia\" in cui la vorrebbe il governo, e con il sogno di volare a bordo di un aereo si incammina in un clandestino viaggio di scoperta."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"El Sendero Azul","runtime":0,"tagline":"","homepage":"","overview":"Tereza, de 77 años, ha vivido siempre en una pequeña ciudad industrial de Brasil. Un día recibe una notificación oficial del gobierno para trasladarse a una colonia remota, creada para que los jubilados pasen \"sus últimos años” y así dejar espacio a los más jóvenes para que sigan siendo plenamente productivos. Pero en lugar de aceptar este destino impuesto, Tereza se rebela y decide embarcarse en un viaje transformador por el Amazonas, para cumplir un último deseo antes de que le arrebaten su libertad. Esto marcará su vida para siempre."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Bezgalīgā zilgme","runtime":85,"tagline":"","homepage":"","overview":"Pāri Brazīlijas koši zilajām debesīm lasāms sauklis \"Nākotne pieder visiem!” Šajā distopiskajā labklājības valstī sabiedrības uzplaukuma nosacījums ir tāds, ka visi vecāka gadagājuma cilvēki ir jāizmitina attālās kolonijās. Terēzai, kas strādā aligatoru fermā, draud pārcelšanās. Viņai ir noteikta aizbildne - pašas meita. Ne soli viņa nedrīkst spert bez atļaujas. Asprātīgajai sievietei ir sapnis, un drīz vien viņa izprāto, kā izvairīties no “labdaru” tvēriena. Sākas jauna nodaļa Terēzas dzīvē - distopija pārvēršas eksotiskā ceļojumā. Jo pārgalvīgāka, baudot brīvību, kļūst piedzīvojumu meklētāja, jo vairāk pārsteigumu, burvīgu tikšanos, dramatisku pavērsienu un komisku epizožu viņu sagaida noslēpumainās Amazones krastos. Ne Terēza, ne skatītāji nezina, kas slēpjas aiz nākamā līkuma, bet viens ir skaidrs: nekad nav par vēlu kļūt par sevi pašu, nekad nav par vēlu atrast laimi."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Modrou stezkou","runtime":85,"tagline":"","homepage":"","overview":"Sedmasedmdesátiletá Tereza žije celý život v malém průmyslovém městečku v Amazonii, dokud jednoho dne nedostane úřední příkaz přestěhovat se do obytné kolonie pro seniory. Kolonie je izolovaná oblast, kam jsou přiváženi starší lidé, aby si „užili“ poslední roky života a uvolnili tak prostor mladší generaci, která se bude moci plně soustředit na produktivitu a růst. Tereza se s tímto vnuceným osudem odmítá smířit. Místo toho se vydává na transformační cestu po řekách a přítocích amazonské krajiny, aby si splnila poslední přání, než jí bude svoboda odebrána – cestu, která navždy změní její osud. (Film Europe)"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Γαλάζιο Μονοπάτι","runtime":0,"tagline":"","homepage":"","overview":"Σε ένα κοντινό μέλλον, στη Βραζιλία, οι ηλικιωμένοι υποχρεώνονται σε συνταξιοδότηση και αποκλείονται από την ενεργό κοινωνική συμμετοχή μέσω ακραίας επιτήρησης. Κάποιοι στέλνονται στην Αποικία, από όπου λέγεται ότι οι περισσότεροι δεν επιστρέφουν ποτέ.  Η Τερέζα, μια 77χρονη γυναίκα της εργατικής τάξης που έχει περάσει μια ζωή δουλεύοντας σε ένα εργοστάσιο επεξεργασίας κρέατος αλιγάτορα, αρνείται να συμμορφωθεί σε αυτό το οριζόντιο μέτρο και να παραδοθεί στην μοίρα της. Αποδρά καβαλώντας τα κινούμενα νερα του Αμαζονίου με ένα σκάφος, και ξεκινά ένα ταξίδι χωρίς επιστροφή. Η ηλικιωμένη γυναίκα επαναστατεί ενάντια στο πεπρωμένο της και ακολουθεί τον ρου του ποταμού, σε μια απρόβλεπτη διαδρομή αυτογνωσίας. Οι χαρακτήρες που συναντά στην πορεία της αποκαλύπτουν τις ελευθερίες που δεν βίωσε ποτέ."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Голубая тропа","runtime":0,"tagline":"","homepage":"","overview":"Чтобы повысить экономическую эффективность, бразильское правительство предписывает пожилым людям переезжать в отдаленные поселения. 77-летняя женщина отказывается и отправляется в путешествие по Амазонке, которое навсегда изменит ее судьбу."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Sinisest sinisem","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"مسیر آبی","runtime":0,"tagline":"","homepage":"","overview":"برای بهره‎وری بیشتر در اقتصاد، دولت برزیل دستور داده تا افراد مسن به خانه‎های سالمندان بیرون شهر نقل مکان کنند. در این بین زنی 77 ساله از این امر امتناع می‎کند و تصمیم می‎گیرد عازم سفری به آمازون شود."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"}],"reviews_tmdb":[],"recommendations":[{"id":999142,"adult":false,"title":"Rabia","video":false,"overview":"Driven by the promise of a new life, Jessica and her best friend Laila left for Syria to join Daech. But when they arrive, they find themselves locked up in a women’s house run by the authoritarian and charismatic Madame.","genre_ids":[18,53],"media_type":"movie","popularity":0.744,"vote_count":37,"poster_path":"/h05EsRVWWrmLDlEsXhRIUWUSogH.jpg","release_date":"2024-11-27","vote_average":6.5,"backdrop_path":"/tZ7ki6JMgEliY4u4XJmABZfAT2g.jpg","original_title":"Rabia","original_language":"fr"},{"id":1242669,"adult":false,"title":"Mr. K","video":false,"overview":"Mr. K, a traveling magician, finds himself in a Kafkaesque nightmare when he can’t find the exit of his hotel. His attempts to get out only pull him deeper, entangling him further with the hotel and its curious inhabitants.","genre_ids":[18,9648,14],"media_type":"movie","popularity":1.058,"vote_count":40,"poster_path":"/lRpGcAYC7cm1QnInz8P3xHvm7cV.jpg","release_date":"2025-01-16","vote_average":6.325,"backdrop_path":"/jvbJwfl9nIHGSZoWjvh9LO2Vtt0.jpg","original_title":"Mr. K","original_language":"en"},{"id":1175842,"adult":false,"title":"Momo","video":false,"overview":"Momo is a young orphan girl who lives in the ruins of an old Roman amphitheater and becomes friends with everybody in the neighborhood. But when a powerful international corporation starts stealing everybody’s time, nobody has any time left for her, let alone their friends or families. Momo, together with Master Hora, the custodian of time, are the only ones who can go up against the time thieves before all is lost forever.","genre_ids":[10751,14,12,18],"media_type":"movie","popularity":6.911,"vote_count":24,"poster_path":"/t3igABxx2wkslwdlTBDYHzyNfL6.jpg","release_date":"2025-10-02","vote_average":7.292,"backdrop_path":"/yxcbiZEaVzQqWSRWVIa4OzSK0Ug.jpg","original_title":"Momo","original_language":"de"},{"id":1480424,"adult":false,"title":"Karla","video":false,"overview":"Twelve-year-old Karla testifies in court. She makes serious accusations against her own father, who should have guaranteed her safety. Judge Lamy supports her in this difficult trial and becomes her most important confidant.","genre_ids":[18],"media_type":"movie","popularity":2.8057,"vote_count":5,"poster_path":"/dF199PpplhGi3cE2XZhoJFsj0yW.jpg","release_date":"2025-10-02","vote_average":8.3,"backdrop_path":"/ztwFWXeYnDQ9JQ57aRBnOoC6Sh.jpg","original_title":"Karla","original_language":"de"},{"id":1378938,"adult":false,"title":"Phoenix: The Story","video":false,"overview":"The film celebrates the 50th anniversary of the legendary Romanian rock band Phoenix. It features interviews with key members like Nicolae Covaci, the band's founder, and Mircea Baniciu, one of its iconic voices. The documentary includes rare archival footage and offers a comprehensive look at the band's history, its impact on Romanian culture, and its journey through various political and cultural landscapes.","genre_ids":[99,10402],"media_type":"movie","popularity":0.0261,"vote_count":2,"poster_path":"/2qUh3QdN0X7rmYm2ygPlnHehBr8.jpg","release_date":"2022-10-16","vote_average":10,"backdrop_path":null,"original_title":"Phoenix: Povestea","original_language":"ro"},{"id":1267905,"adult":false,"title":"The Roses","video":false,"overview":"Life seems easy for picture-perfect couple Ivy and Theo: successful careers, a loving marriage, great kids. But beneath the façade of their supposed ideal life, a storm is brewing – as Theo's career nosedives while Ivy's own ambitions take off, a tinderbox of fierce competition and hidden resentment ignites.","genre_ids":[35,18],"media_type":"movie","popularity":6.658,"vote_count":584,"poster_path":"/99O8HLHklXGzvF2TqiRqr7WddzT.jpg","release_date":"2025-08-27","vote_average":6.708,"backdrop_path":"/tK3zER0850mxditEoepTOmIeYKq.jpg","original_title":"The Roses","original_language":"en"},{"id":1245993,"adult":false,"title":"Caught Stealing","video":false,"overview":"Burned-out ex-baseball player Hank Thompson unexpectedly finds himself embroiled in a dangerous struggle for survival amidst the criminal underbelly of late 1990s New York City, forced to navigate a treacherous underworld he never imagined.","genre_ids":[80,53,35],"media_type":"movie","popularity":7.6442,"vote_count":770,"poster_path":"/cvda8s5J8YaHjTyEyXQpvD6f3iV.jpg","release_date":"2025-08-26","vote_average":6.913,"backdrop_path":"/41043LV7mfluH8iXEUPVseCDAv5.jpg","original_title":"Caught Stealing","original_language":"en"},{"id":842924,"adult":false,"title":"The Life of Chuck","video":false,"overview":"In this extraordinary story of an ordinary man, Charles 'Chuck' Krantz experiences the wonder of love, the heartbreak of loss, and the multitudes contained in all of us.","genre_ids":[14,18],"media_type":"movie","popularity":7.9986,"vote_count":867,"poster_path":"/oumprkO9bThExP8NwxBIBnvBu2v.jpg","release_date":"2025-06-05","vote_average":7.277,"backdrop_path":"/6e2yeFZgtD7RKpUYEOjj5v7oAUz.jpg","original_title":"The Life of Chuck","original_language":"en"},{"id":1233575,"adult":false,"title":"Black Bag","video":false,"overview":"When intelligence agent Kathryn Woodhouse is suspected of betraying the nation, her husband – also a legendary agent – faces the ultimate test of whether to be loyal to his marriage, or his country.","genre_ids":[18,9648,53],"media_type":"movie","popularity":6.0302,"vote_count":1117,"poster_path":"/hHPovtU4b96LHcoeEwRkGHI5btw.jpg","release_date":"2025-03-12","vote_average":6.337,"backdrop_path":"/gxO51FVgADhYGGnnRPIlutVqb30.jpg","original_title":"Black Bag","original_language":"en"},{"id":1054867,"adult":false,"title":"One Battle After Another","video":false,"overview":"Washed-up revolutionary Bob exists in a state of stoned paranoia, surviving off-grid with his spirited, self-reliant daughter, Willa. When his evil nemesis resurfaces after 16 years and she goes missing, the former radical scrambles to find her, father and daughter both battling the consequences of his past.","genre_ids":[53,80,28],"media_type":"movie","popularity":44.979,"vote_count":2890,"poster_path":"/lbBWwxBht4JFP5PsuJ5onpMqugW.jpg","release_date":"2025-09-23","vote_average":7.412,"backdrop_path":"/gre7gyocZSuwd7M51CGlqsJqBmB.jpg","original_title":"One Battle After Another","original_language":"en"},{"id":1038392,"adult":false,"title":"The Conjuring: Last Rites","video":false,"overview":"Paranormal investigators Ed and Lorraine Warren take on one last terrifying case involving mysterious entities they must confront.","genre_ids":[27],"media_type":"movie","popularity":21.9161,"vote_count":1657,"poster_path":"/byWgphT74ClOVa8EOGzYDkl8DVL.jpg","release_date":"2025-09-03","vote_average":6.902,"backdrop_path":"/tcBX2dtkNozZ0uDLVaxXrE6rqyN.jpg","original_title":"The Conjuring: Last Rites","original_language":"en"},{"id":549509,"adult":false,"title":"The Brutalist","video":false,"overview":"When an innovative modern architect flees post-war Europe, he is given the opportunity to rebuild his legacy. Set during the dawn of the modern United States (in Pennsylvania), his wife joins him, and their lives are forever changed by a demanding, wealthy patron.","genre_ids":[18],"media_type":"movie","popularity":7.7736,"vote_count":1555,"poster_path":"/vP7Yd6couiAaw9jgMd5cjMRj3hQ.jpg","release_date":"2024-12-20","vote_average":6.96,"backdrop_path":"/hmZnqijPaaACjenDkrbWcCmcADI.jpg","original_title":"The Brutalist","original_language":"en"},{"id":1278263,"adult":false,"title":"The Seed of the Sacred Fig","video":false,"overview":"Investigating judge Iman grapples with paranoia amid political unrest in Tehran. When his gun vanishes, he suspects his wife and daughters, imposing draconian measures that strain family ties as societal rules crumble.","genre_ids":[18,53,80],"media_type":"movie","popularity":2.5979,"vote_count":427,"poster_path":"/ifOazNzv2cNJ5CQjMV7cPXG2Lmy.jpg","release_date":"2024-09-18","vote_average":7.563,"backdrop_path":"/zqZzYVE4DWv92xrYSCEELPcLnUP.jpg","original_title":"Les Graines du figuier sauvage","original_language":"fr"},{"id":1084199,"adult":false,"title":"Companion","video":false,"overview":"During a weekend getaway at a secluded lakeside estate, a group of friends finds themselves entangled in a web of secrets, deception, and advanced technology. As tensions rise and loyalties are tested, they uncover unsettling truths about themselves and the world around them.","genre_ids":[27,878,53],"media_type":"movie","popularity":12.805,"vote_count":2098,"poster_path":"/oCoTgC3UyWGfyQ9thE10ulWR7bn.jpg","release_date":"2025-01-22","vote_average":7.012,"backdrop_path":"/qA6MHDGDY0LyutjLUgFJRbPXLpW.jpg","original_title":"Companion","original_language":"en"},{"id":1233413,"adult":false,"title":"Sinners","video":false,"overview":"Trying to leave their troubled lives behind, twin brothers return to their hometown to start again, only to discover that an even greater evil is waiting to welcome them back.","genre_ids":[27,28,53],"media_type":"movie","popularity":37.799,"vote_count":3774,"poster_path":"/qTvFWCGeGXgBRaINLY1zqgTPSpn.jpg","release_date":"2025-04-16","vote_average":7.489,"backdrop_path":"/nAxGnGHOsfzufThz20zgmRwKur3.jpg","original_title":"Sinners","original_language":"en"},{"id":1130402,"adult":false,"title":"Not Without My Shrink","video":false,"overview":"A successful psychoanalyst's life is turned upside down by a very anxious and extremely clingy patient who starts dating his daughter.","genre_ids":[35,10751],"media_type":"movie","popularity":1.1729,"vote_count":123,"poster_path":"/chl53EeJLqg7gkpiuay0Gf0SXL1.jpg","release_date":"2024-12-11","vote_average":4.9,"backdrop_path":"/8gULQzYQtlTKdchPCKbQAb5tBjG.jpg","original_title":"Jamais sans mon psy","original_language":"fr"},{"id":1102493,"adult":false,"title":"Small Things Like These","video":false,"overview":"In 1985, while working as a coal merchant to support his family, Bill Furlong discovers disturbing secrets kept by the local convent and uncovers truths of his own; forcing him to confront his past and the complicit silence of a small Irish town controlled by the Catholic Church.","genre_ids":[18],"media_type":"movie","popularity":6.0637,"vote_count":494,"poster_path":"/rdcO38cbWFg002nXg5QYtk7Tz4L.jpg","release_date":"2024-11-01","vote_average":6.7,"backdrop_path":"/rtpFIgy1YYw3kx7PCyNhi6xmEFb.jpg","original_title":"Small Things Like These","original_language":"en"},{"id":574475,"adult":false,"title":"Final Destination Bloodlines","video":false,"overview":"Plagued by a violent recurring nightmare, college student Stefanie heads home to track down the one person who might be able to break the cycle and save her family from the grisly demise that inevitably awaits them all.","genre_ids":[27,9648],"media_type":"movie","popularity":19.0109,"vote_count":2651,"poster_path":"/6WxhEvFsauuACfv8HyoVX6mZKFj.jpg","release_date":"2025-05-14","vote_average":7.067,"backdrop_path":"/uIpJPDNFoeX0TVml9smPrs9KUVx.jpg","original_title":"Final Destination Bloodlines","original_language":"en"},{"id":1241470,"adult":false,"title":"Osiris","video":false,"overview":"Special Forces commandos on a mission are abducted mid-operation by a mysterious spacecraft. Upon waking aboard, they find themselves prey to a relentless alien race in a fight for survival.","genre_ids":[878,28,27],"media_type":"movie","popularity":22.5229,"vote_count":186,"poster_path":"/3YtZHtXPNG5AleisgEatEfZOT2w.jpg","release_date":"2025-07-25","vote_average":6.013,"backdrop_path":"/ySHUoK4utUOiSfCinw81H1TsV0E.jpg","original_title":"Osiris","original_language":"en"},{"id":666277,"adult":false,"title":"Past Lives","video":false,"overview":"After decades apart, childhood friends Nora and Hae Sung are reunited in New York for one fateful weekend as they confront notions of destiny, love, and the choices that make a life.","genre_ids":[18,10749],"media_type":"movie","popularity":7.2645,"vote_count":2204,"poster_path":"/k3waqVXSnvCZWfJYNtdamTgTtTA.jpg","release_date":"2023-06-02","vote_average":7.719,"backdrop_path":"/7HR38hMBl23lf38MAN63y4pKsHz.jpg","original_title":"Past Lives","original_language":"en"}],"similar_content":[{"id":48706,"adult":false,"title":"Josh & S.A.M.","video":false,"overview":"Josh and Sam are two brothers facing change, their mother is about to marry a French accountant and the kids are sent to go live with their father in Florida. Meanwhile, Josh tells Sam that he is a \"S.A.M.\" that is going to be sent to Africa to fight in a war and that Canada is a safe haven for any S.A.M. unwilling to fight. Will Josh & S.A.M. make it to Canada or will they wish they should have never left home?","genre_ids":[12,28,35],"popularity":0.3933,"vote_count":17,"poster_path":"/dWggqpyiZzhvpIyef5ZPB4Lsscu.jpg","release_date":"1993-11-24","vote_average":4.7,"backdrop_path":"/eXHznh4SCFOAaU92Ix23rBnzKEG.jpg","original_title":"Josh & S.A.M.","original_language":"en"},{"id":1109237,"adult":false,"title":"The Monk and the Gun","video":false,"overview":"An American travels to Bhutan searching for a valuable antique rifle and crosses paths with a young monk who wanders through the serene mountains, instructed by his teacher to make things right again.","genre_ids":[35,18],"popularity":0.5648,"vote_count":108,"poster_path":"/nhGaCXeBvFo7495aIZr261l6kb0.jpg","release_date":"2023-10-17","vote_average":7.282,"backdrop_path":"/8nDmmnksfkTqwVa1en54KXDMRtg.jpg","original_title":"The Monk and the Gun","original_language":"dz"},{"id":48481,"adult":false,"title":"Five","video":false,"overview":"The film's storyline involves five survivors, one woman and four men, of an atomic bomb disaster. The five come together at a remote, isolated hillside house, where they try to figure out how to survive.","genre_ids":[878,18],"popularity":0.2914,"vote_count":38,"poster_path":"/awMJBJpywUl7u75rLGohrRZ41wl.jpg","release_date":"1951-04-25","vote_average":6.592,"backdrop_path":"/5eLRW1lwivUdoflnb3wt0PcqAQc.jpg","original_title":"Five","original_language":"en"},{"id":49037,"adult":false,"title":"Hellevator: The Bottled Fools","video":false,"overview":"Luchino's routine morning elevator ride up from her subterranean home on level 138 to her school many stories above turns horrific when the elevator operator is ordered to pick up two passengers from floor 99, the maximum security level. What starts as psychological manipulation soon turns wholly physical as both the cruel convicts and Luchino's own dysfunctional past are unleashed. And then every passenger must fight for his or her survival.","genre_ids":[878,27],"popularity":0.2485,"vote_count":55,"poster_path":"/1dr7hmURza1r2Dxhit2wraeFkJX.jpg","release_date":"2004-02-28","vote_average":5.4,"backdrop_path":"/icCdJnjPt2RaazHBG7JbcSGwfId.jpg","original_title":"グシャノビンヅメ","original_language":"ja"},{"id":49049,"adult":false,"title":"Dredd","video":false,"overview":"In the future, America is a dystopian wasteland. The latest scourge is Ma-Ma, a prostitute-turned-drug pusher with a dangerous new drug and aims to take over the city. The only possibility of stopping her is an elite group of urban police called Judges, who combine the duties of judge, jury and executioner to deliver a brutal brand of swift justice. But even the top-ranking Judge, Dredd, discovers that taking down Ma-Ma isn’t as easy as it seems in this explosive adaptation of the hugely popular comic series.","genre_ids":[28,878],"popularity":5.7209,"vote_count":5418,"poster_path":"/wLx65gtGVnUFCxceHWGszcruCZj.jpg","release_date":"2012-09-07","vote_average":6.857,"backdrop_path":"/jUqDBi02CDjqrroC3Zl8hroBbSr.jpg","original_title":"Dredd","original_language":"en"},{"id":1109870,"adult":false,"title":"HappyHead","video":false,"overview":"When Seb is offered a place on a radical retreat designed to solve the national crisis of teenage unhappiness, he is determined to change how people see him and make his parents proud. But as he finds himself drawn to the enigmatic Finn, Seb starts to question the true nature of the challenges they must undergo. The deeper into the programme the boys get, the more disturbing the assessments become, until it’s clear there may be no escape...","genre_ids":[878,53,10749],"popularity":0.2708,"vote_count":0,"poster_path":"/nuloij5SwlS7OfpZcth0AwEeRPh.jpg","release_date":"","vote_average":0,"backdrop_path":null,"original_title":"HappyHead","original_language":"en"},{"id":49126,"adult":false,"title":"Audrey Rose","video":false,"overview":"A man is convinced that 11-year old girl, Ivy, is the reincarnation of his own daughter Audrey Rose, who died in a fiery car accident, along with his wife, two minutes before Ivy was born.","genre_ids":[18,27,53],"popularity":0.4849,"vote_count":145,"poster_path":"/omtHuaCwKRX20x5R8xnqxWYq8Xp.jpg","release_date":"1977-04-06","vote_average":5.641,"backdrop_path":"/9ylZRaHbbbVjaLCvTy7CfDbtu9w.jpg","original_title":"Audrey Rose","original_language":"en"},{"id":314095,"adult":false,"title":"The Lost City of Z","video":false,"overview":"A true-life drama in the 1920s, centering on British explorer Col. Percy Fawcett, who discovered evidence of a previously unknown, advanced civilization in the Amazon and disappeared whilst searching for it.","genre_ids":[12,18,36],"popularity":2.8115,"vote_count":3043,"poster_path":"/dgDVkGFltTm1MCoFtlq91r7jwi9.jpg","release_date":"2017-03-15","vote_average":6.393,"backdrop_path":"/upatBMqiS0gSiNy52cwxKKcNne2.jpg","original_title":"The Lost City of Z","original_language":"en"},{"id":49521,"adult":false,"title":"Man of Steel","video":false,"overview":"A young boy learns that he has extraordinary powers and is not of this earth. As a young man, he journeys to discover where he came from and what he was sent here to do. But the hero in him must emerge if he is to save the world from annihilation and become the symbol of hope for all mankind.","genre_ids":[28,12,878],"popularity":9.7733,"vote_count":15956,"poster_path":"/8GFtkImmK0K1VaUChR0n9O61CFU.jpg","release_date":"2013-06-12","vote_average":6.639,"backdrop_path":"/69EFgWWPFWbRNHmQgYdSnyJ94Ge.jpg","original_title":"Man of Steel","original_language":"en"},{"id":49530,"adult":false,"title":"In Time","video":false,"overview":"In the not-too-distant future, the aging gene has been switched off. To avoid overpopulation, time has become the currency and the way people pay for luxuries and necessities. The rich can live forever, while the rest struggle to negotiate for their immortality. A poor young man who suddenly comes into a fortune of time finds himself on the run from a corrupt police force known as the \"time keepers\".","genre_ids":[28,53,878],"popularity":8.4209,"vote_count":11972,"poster_path":"/3Mwj2sIONQckOZP3YwsUXF7U5I4.jpg","release_date":"2011-10-27","vote_average":6.97,"backdrop_path":"/pxL08w7Eq0vKrQ3mJzYp0VHGaKG.jpg","original_title":"In Time","original_language":"en"},{"id":514547,"adult":false,"title":"White Chamber","video":false,"overview":"The United Kingdom. Soon. Civil war rages. A woman wakes up in a blindingly white cuboid cell. Using its sophisticated functionality, her captor tortures her for information; information she claims not to have - or does she?","genre_ids":[878],"popularity":1.115,"vote_count":61,"poster_path":"/yZjmCwmfHMjCE2ojON2dgeTkvDP.jpg","release_date":"2018-04-05","vote_average":4.459,"backdrop_path":"/mR0FxUh6ghmR3gZTyq3gFtQtXmy.jpg","original_title":"White Chamber","original_language":"en"},{"id":496743,"adult":false,"title":"Aniara","video":false,"overview":"A ship carrying settlers to a new home on Mars after Earth is rendered uninhabitable is knocked off-course, causing the passengers to consider their place in the universe.","genre_ids":[878,18],"popularity":0.9696,"vote_count":419,"poster_path":"/pEpEJe8NTmwWL0hwYkZguTzEqzt.jpg","release_date":"2019-02-01","vote_average":6.091,"backdrop_path":"/z9qfbeDAyNNwv6mxZ573mce2aMA.jpg","original_title":"Aniara","original_language":"sv"},{"id":1282445,"adult":false,"title":"What do You Want Now of This Metaphysical Love?","video":false,"overview":"Struggling if the existence of his love is real or not, Matthew embarks on a train journey to find it. As he travels without a fixed destination and searches for his beloved, he begins to hallucinate between imagination and reality, trying to realize which is which. Was it true love or just metaphysical?","genre_ids":[18],"popularity":0.1709,"vote_count":0,"poster_path":"/yY6WAs1ywzmS2nooLXfZ37TPQEj.jpg","release_date":"","vote_average":0,"backdrop_path":"/ghc4GujMbevWFzpQeCiwD5u7o1J.jpg","original_title":"What do You Want Now of This Metaphysical Love?","original_language":"en"},{"id":1282429,"adult":false,"title":"Mercury","video":false,"overview":"A broken refugee must brave the poisoned ruins of a nation to secure medicine for a dying child.","genre_ids":[18,53,878],"popularity":0.1894,"vote_count":0,"poster_path":"/zPp47UCn2RmxBDOjkq4zrSVpG3U.jpg","release_date":"2024-04-29","vote_average":0,"backdrop_path":null,"original_title":"Mercury","original_language":"en"},{"id":308457,"adult":false,"title":"Advantageous","video":false,"overview":"In a near-future city where soaring opulence overshadows economic hardship, Gwen and her daughter, Jules, do all they can to hold on to their joy, despite the instability surfacing in their world.","genre_ids":[878,18],"popularity":2.9512,"vote_count":164,"poster_path":"/xVJdSbDxKTanwZtD6qUyc7cGNpG.jpg","release_date":"2015-06-23","vote_average":5.97,"backdrop_path":"/9eVx87O18kLs7LpsOrruOU45jXA.jpg","original_title":"Advantageous","original_language":"en"},{"id":896096,"adult":false,"title":"The Mysterious Gaze of the Flamingo","video":false,"overview":"As an unknown and deadly disease begins to spread, legend has it that it is transmitted between two men, through a simple glance, when they fall in love. While people are accusing her family, Lidia must find out whether this myth is real or not.","genre_ids":[18],"popularity":1.8983,"vote_count":12,"poster_path":"/xfPhni21LIEmuV8HiDfrLhcmTwr.jpg","release_date":"2025-09-11","vote_average":6.75,"backdrop_path":"/kAwN3UWRUWauNK1l4oh7TfdOsJ7.jpg","original_title":"La misteriosa mirada del flamenco","original_language":"es"},{"id":43933,"adult":false,"title":"Monsters","video":false,"overview":"Six years ago NASA discovered the possibility of alien life within our solar system. A probe was launched to collect samples, but crashed upon re-entry over Central America. Soon after, new life forms began to appear and half of Mexico was quarantined as an infected zone. Today, the American and Mexican military still struggle to contain \"the creatures,\" while a journalist agrees to escort a shaken tourist through the infected zone in Mexico to the safety of the U.S. border.","genre_ids":[18,53,878],"popularity":1.6561,"vote_count":1732,"poster_path":"/qpJyTxR33KG9qFmXoCD5AUTToPl.jpg","release_date":"2010-06-18","vote_average":6.186,"backdrop_path":"/imiBIsvNU3TbMB3sbqKanKODS33.jpg","original_title":"Monsters","original_language":"en"},{"id":508713,"adult":false,"title":"Juna","video":false,"overview":"A dream shows Juna that she has only one last day to live. Ignorantly she initiated the process itself. The attempt to avert her fate failed. A story about the problem of artificial life.","genre_ids":[18,878],"popularity":0.2573,"vote_count":1,"poster_path":"/7aTsGraUWFVijdfHPpHzMrQ1uRR.jpg","release_date":"2018-03-20","vote_average":10,"backdrop_path":null,"original_title":"Juna","original_language":"de"},{"id":308762,"adult":false,"title":"Quito 2023","video":false,"overview":"Is the year 2023. Quito has been walled by Leonardo Ponce, a military dictator that took control of the city in the early 2010's. A group of revolutionaries led by Marcos and Santiago are on the verge of giving a coup d'état. Just hours before the strike, Santiago steps forward and starts asking tough questions that led everybody to rethink why are they really doing this. Meanwhile at Ponce's palace, he is trying to decipher what is going on at the city wall. There's unusual movement and one of the revolutionaries is captured. Ponce tries to get as much information as he can from him. Confined to just 2 locations, Quito 2023 shows the human side of the revolution, the internal conflicts of their leaders and the hopelessness of a region that cannot be governed.","genre_ids":[53,878],"popularity":0.3672,"vote_count":6,"poster_path":"/hwUSJ5EUDkLhMRwwdKWT3NoaZmB.jpg","release_date":"2014-02-21","vote_average":4.5,"backdrop_path":"/wbRnEN2E5H7FnPcvYops2jTSG1e.jpg","original_title":"Quito 2023","original_language":"es"},{"id":912506,"adult":false,"title":"Quarantine","video":false,"overview":"The main character of the film writes a diary. For over 20 years he has lived in a bunker and has not ventured outside. His only companions are ghosts of the past. He tries to find an explanation for the fateful course of events, which has destroyed the whole earth. The feeling of guilt does not leave him, as he believes that he could have prevented the apocalypse and the death of his beloved.","genre_ids":[18,878],"popularity":0.1544,"vote_count":4,"poster_path":"/8k7la09CxMVhBovRaVssue5yg2M.jpg","release_date":"2021-10-04","vote_average":9,"backdrop_path":"/ilDfU4WSuGAYlX66XvPD7TGjjwL.jpg","original_title":"КАРАнтин","original_language":"ru"}],"external_ids":{"imdb_id":"tt35340614","twitter_id":null,"facebook_id":null,"wikidata_id":"Q131840191","instagram_id":null,"metacritic_id":"movie/the-blue-trail","rotten_tomatoes_id":"m/the_blue_trail"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148221,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AT","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-09-25T00:00:00.000Z","certification":""}]},{"iso_3166_1":"AU","release_dates":[{"note":"Sydney Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-06-13T00:00:00.000Z","certification":""},{"note":"Melbourne International Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-08-13T00:00:00.000Z","certification":""},{"note":"Perth Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-12-15T00:00:00.000Z","certification":""}]},{"iso_3166_1":"BR","release_dates":[{"note":"Festival de Cinema de Gramado","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-08-15T00:00:00.000Z","certification":""},{"note":"","type":3,"iso_639_1":"","descriptors":["Legal Drugs","Sensitive Themes","Violence"],"release_date":"2025-08-28T00: