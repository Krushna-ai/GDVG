5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Hunting Season\",\"description\":\"When a reclusive survivalist and his daughter rescue a mysterious, wounded woman from a river, they become entangled in a deadly web of violence and revenge, forcing them to confront a brutal criminal to survive.\",\"image\":\"https://image.tmdb.org/t/p/w500/cbryTyaWdqrKpQCw6K7zm2jrB5v.jpg\",\"datePublished\":\"2025-12-05\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"US\",\"inLanguage\":\"en\",\"genre\":[\"Action\",\"Drama\",\"Thriller\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.102,\"bestRating\":10,\"ratingCount\":137}}"}}],["$","$L10",null,{"initialDrama":{"id":"fd762f2e-8621-4acd-9307-d5faef9d06a6","tmdb_id":1387382,"imdb_id":"tt32537226","content_type":"movie","title":"Hunting Season","original_title":"Hunting Season","overview":"When a reclusive survivalist and his daughter rescue a mysterious, wounded woman from a river, they become entangled in a deadly web of violence and revenge, forcing them to confront a brutal criminal to survive.","poster_path":"/cbryTyaWdqrKpQCw6K7zm2jrB5v.jpg","backdrop_path":"/eJ0HooOOD1uzI39CfOQNWIiWKlJ.jpg","release_date":"2025-12-05","first_air_date":null,"status":"published","original_language":"en","origin_country":["US"],"genres":[{"id":28,"name":"Action"},{"id":18,"name":"Drama"},{"id":53,"name":"Thriller"}],"popularity":29.5154,"vote_average":7.102,"vote_count":137,"runtime":93,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-08T23:35:37.965655+00:00","updated_at":"2026-02-23T16:59:17.55+00:00","tagline":"It takes an awful lot to kill a person.","homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":231139,"name":"Beno Films (US)","logo_path":null,"origin_country":""},{"id":63611,"name":"ETA films","logo_path":"/bHPC39cG5aAcuFnViWmRD59gzZ8.png","origin_country":"US"},