39_1":null,"vote_average":0.166},{"width":1600,"height":900,"file_path":"/iViA2jIczwFaDxZg8pCiIjkV00q.jpg","iso_639_1":null,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/tTXN5mlKm4W5mdqgo8Y6mo2Bz0t.jpg","iso_639_1":"en","vote_average":0},{"width":3840,"height":2160,"file_path":"/2Hx3VZsTZMdJtqOHNXJC26tWh5E.jpg","iso_639_1":"ru","vote_average":0},{"width":1920,"height":1080,"file_path":"/2kalldeSmVqScbMbDGkxnZd8jz5.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/hug0N6p22bxb6Ul87JGb2sdsrvO.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/lfMjvzrWwXqLSc7Gsox9648QdV1.jpg","iso_639_1":"ka","vote_average":0},{"width":3840,"height":2160,"file_path":"/7PUrWbjh2X6XJ8HdrCsWI42rsmZ.jpg","iso_639_1":"pt","vote_average":0}]},"enriched_at":"2026-04-21T06:10:49.157+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":93,"tagline":"It takes an awful lot to kill a person.","homepage":"","overview":"When a reclusive survivalist and his daughter rescue a mysterious, wounded woman from a river, they become entangled in a deadly web of violence and revenge, forcing them to confront a brutal criminal to survive."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Сезон охоты","runtime":0,"tagline":"","homepage":"","overview":"Отец-одиночка и его дочь-подросток решают приютить у себя таинственную девушку, найденную ими на берегу реки неподалеку от дома, не подозревая что за незнакомкой охотится безжалостный наркобарон."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Сезон полювання","runtime":0,"tagline":"","homepage":"","overview":"Батько-одинак і його донька-підлітка вирішують прихистити загадкову дівчину, яку вони знаходять на березі річки неподалік від дому, навіть не підозрюючи, що за незнайомкою полює безжальний наркобарон."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Hunting Season","runtime":93,"tagline":"Potrzeba wiele, by zabić człowieka.","homepage":"","overview":"Nadopiekuńczy ojciec i jego zadziorna dwunastoletnia córka przygarniają tajemniczą młodą kobietę, która zostaje wyrzucona na brzeg lokalnej rzeki. Życie duetu ojciec-córka zmienia się na zawsze wraz z przybyciem nieznajomego i bezwzględnego barona narkotykowego, który nie cofnie się przed niczym, by ją posiąść."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Une jeune fille et son père, vivant au fin fond des bois, recueillent une jeune femme blessée échouée sur les rives de la rivière voisine. Leurs vies basculent à jamais à cause de cet inconnu mystérieux et du dangereux trafiquant de drogue prêt à tout pour l'éliminer définitivement."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Sezona Lova","runtime":0,"tagline":"","homepage":"","overview":"Kada povučeni stručnjak za preživljavanje i njegova kćerka spase misterioznu, ranjenu ženu iz rijeke, bivaju uvučeni u smrtonosnu mrežu nasilja i osvete, zbog čega su prisiljeni da se suoče sa brutalnim kriminalcem kako bi preživjeli."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Als ein zurückgezogen lebender Überlebenskünstler und seine Tochter eine mysteriöse, verletzte Frau aus einem Fluss retten, werden sie in einem tödlichen Netz aus Gewalt und Rache verstrickt, das sie zwingt, sich einem brutalen Verbrecher zu stellen, um zu überleben."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Temporada de Sangue","runtime":0,"tagline":"","homepage":"","overview":"Um pai solteiro fará o que for preciso para proteger sua filha de 13 anos do mundo corrupto que a cerca."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Sezona lova","runtime":0,"tagline":"Za ubijanje je potrebno veliko več, kot si misliš.","homepage":"","overview":"Ko samotarski mojster preživetja in njegova hči iz reke rešita skrivnostno ranjeno žensko, se zapleteta v smrtonosno mrežo nasilja in maščevanja. Da bi preživela, se morata soočiti z brezobzirnim kriminalcem in se boriti za lastna življenja."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"狩獵季","runtime":0,"tagline":"","homepage":"","overview":"一對住在森林深處的父女，救起了一位被沖到當地河岸邊的受傷年輕女子。一位神祕的陌生人和一位冷酷無情的毒梟，從此徹底改變了他們的生活。毒梟為了徹底除掉她，不惜一切代價。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Cuando una misteriosa joven aparece en la orilla de un río local, tanto la niña de doce años que la descubre como su sobreprotector padre cambian para siempre con la llegada de esta extraña a su hogar. Mientras, un despiadado capo de la droga no se detendrá ante nada para matarla de una vez por todas."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Cuando una misteriosa joven aparece en la orilla de un río local, tanto la niña de doce años que la descubre como su sobreprotector padre cambian para siempre con la llegada de esta extraña a su hogar. Mientras, un despiadado capo de la droga no se detendrá ante nada para matarla de una vez por todas."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"موسم الصيد","runtime":0,"tagline":"","homepage":"","overview":""},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"狩猎季","runtime":0,"tagline":"","homepage":"","overview":"当一位隐居的生存主义者与女儿从河中救起一名神秘的受伤女子后，他们便陷入了一场充满暴力与复仇的致命漩涡，被迫直面残暴的罪犯以求生存。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"فصل شکار","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Ловен сезон","runtime":100,"tagline":"","homepage":"","overview":"Филмът разказва за баща и дъщеря, които живеят изолирано в дива планинска местност, далеч от цивилизацията. Тяхното спокойно, но сурово ежедневие е нарушено, когато те спасяват тежко ранена млада жена, намерена край реката. Постепенно става ясно, че жената бяга от безмилостен наркокартел, ръководен от опасен престъпен бос, който е готов на всичко, за да я елиминира. Така бащата и дъщерята се оказват въвлечени в кървава битка за оцеляване, където добротата им ги изправя срещу жестока реалност."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Sezonul de vânătoare","runtime":0,"tagline":"","homepage":"","overview":"După ce un barbat retras în sălbăticie și fiica sa salvează o femeie misterioasă și rănită dintr - un râu, cei doi devin implicați într - o poveste mortală plină de violență și răzbunare, fiind forțați să înfrunte un criminal brutal pentru a supraviețui."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Lovecká sezóna","runtime":0,"tagline":"Na zabitie človeka treba strašne veľa.","homepage":"","overview":"V odľahlých lesoch Oklahomy žije Bowdrie (Mel Gibson), drsný samotár s temnou minulosťou, tichý život so svojou dcérou Tag (Sofia Hublitz) mimo spoločenského života. Ich jednoduchú existenciu naruší Tag, keď počas rybolovu narazí na ťažko zranenú ženu menom January (Shelley Hennig). Bowdrie a Tag ju vezmú k sebe a ošetria jej zranenia. Ako sa January pomaly zotavuje v ich chate, začína sa vynárať nebezpečná pravda..."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Bűnös vadászidény","runtime":0,"tagline":"Borzasztó sok kell ahhoz, hogy valakit megöljenek.","homepage":"","overview":"Egy férfi és lánya segítséget és menedéket nyújtanak egy sérült nőnek az erdőben álló eldugott házukban. Hamarosan azonban kétségbeesett küzdelmet kell vívniuk a túlélésért, amikor egy kegyetlen drogbáró és emberei megérkeznek, hogy elvigyék a nőt."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"עונת הציד","runtime":93,"tagline":"","homepage":"","overview":"שורד קשוח שחי בבקתה מבודדת ביער עם בתו מציל יחד איתה אישה פצועה שנשטפת בנהר. כשהם מנסים לעזור לה הם מגלים שהיא במנוסה מפני עבריין אכזרי וחבורת שכירי חרב שמוכנים לעשות הכל כדי להשתיק אותה. בתוך היער נסגר עליהם מעגל של אלימות ונקמה והאב נאלץ לחזור לכישורי הלחימה מעברו כדי להגן על בתו האישה המסתורית ועל הבית שלהם לפני שיהפכו בעצמם לציד."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Όταν ένας μοναχικός επιχειρηματίας επιβίωσης και η κόρη του διασώζουν μια μυστηριώδη, τραυματισμένη γυναίκα από ένα ποτάμι, μπλέκονται σε ένα θανατηφόρο δίκτυο βίας και εκδίκησης, αναγκάζοντάς τους να αντιμετωπίσουν έναν βάναυσο εγκληματία για να επιβιώσουν."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"","runtime":93,"tagline":"Er is heel wat voor nodig om iemand te doden.","homepage":"","overview":"Wanneer een teruggetrokken survivalist en zijn dochter een mysterieuze, gewonde vrouw uit een rivier redden, raken ze verstrikt in een dodelijk web van geweld en wraak. Om te overleven, worden ze gedwongen de confrontatie aan te gaan met een meedogenloze crimineel."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"헌팅시즌","runtime":0,"tagline":"","homepage":"","overview":"은둔하며 살아가던 생존 전문가와 그의 딸은 강가에서 상처 입은 정체불명의 여자를 구조하게 된다. 그러나 이로 인해 그들은 폭력과 복수의 잔혹한 소용돌이에 휘말리게 되고 살아남기 위해 잔혹한 범죄자와 맞서야만 한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"ნადირობის სეზონი","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"เมื่อชายผู้สันโดษและเอาตัวรอดเก่งคนหนึ่งกับลูกสาวของเขาช่วยหญิงปริศนาที่ได้รับบาดเจ็บจากแม่น้ำ พวกเขากลับต้องเข้าไปพัวพันกับวังวนแห่งความรุนแรงและการแก้แค้นที่อันตรายถึงชีวิต บังคับให้พวกเขาต้องเผชิญหน้ากับอาชญากรโหดเหี้ยมเพื่อเอาชีวิตรอด"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[],"external_ids":{"imdb_id":"tt32537226","twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":null,"rotten_tomatoes_id":"m/hunting_season_2025"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":100442,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"HU","release_dates":[{"note":"Telekom FilmPremier","type":4,"iso_639_1":"hu","descriptors":[],"release_date":"2026-01-30T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"KR","release_dates":[{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-01-23T00:00:00.000Z","certification":"15"}]},{"iso_3166_1":"US","release_dates":[{"note":"","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-12-03T00:00:00.000Z","certification":""},{"note":"","type":2,"iso_639_1":"","descriptors":[],"release_date":"2025-12-05T00:00:00.000Z","certification":""},{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":"2025-12-05T00:00:00.000Z","certification":""}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc