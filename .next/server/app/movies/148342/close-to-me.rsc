logos":[{"width":2000,"height":224,"file_path":"/bGouFqEdzRDUMNlEj0o344In97U.png","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":8.929,"vote_average":0}],"posters":[{"width":1706,"height":2560,"file_path":"/zRsQgmJRCCHXAm1Ls5Q72ziVYBh.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":1,"aspect_ratio":0.666,"vote_average":3.334},{"width":1280,"height":1920,"file_path":"/jwGxoVEbHrNdZlMvyTsY1u4xYOv.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":1333,"height":2000,"file_path":"/rsobl1j8F3c5eaO5jO7tKs5eNxL.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":1,"aspect_ratio":0.666,"vote_average":0.166},{"width":1920,"height":2560,"file_path":"/bxi67SrP9GWG2YiTtb1o5VM7OkM.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":1,"aspect_ratio":0.75,"vote_average":0.166},{"width":1400,"height":2000,"file_path":"/sWfDBOzNUNwyMnJEPeFkbR4iK6n.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":2000,"height":3000,"file_path":"/eDKpRkNcdr8beAgzNZ5hMLcFJjj.jpg","iso_639_1":"el","iso_3166_1":"GR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1240,"height":1754,"file_path":"/7Sw1yOZl9KlUvNK9YZTDPFtnWRb.jpg","iso_639_1":"ko","iso_3166_1":"KR","vote_count":0,"aspect_ratio":0.707,"vote_average":0},{"width":2000,"height":3000,"file_path":"/nLPwh0yAlT6RH5hqxRF0ZxJD5tL.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/igntlLb5MeAHplP8CYk5gNcnDTV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/qlNGrq9npnRZHC3wln9AzXLybFl.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/taadJ4zglriEnP8z4wla73xWDeK.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/jHDczXDoze03wW8tiextMCk5REA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2560,"height":1440,"file_path":"/kaBW3ueUPq67q8gBpCvWUtVjsez.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/sJP0QCf7rOQJxTQSny7jKZ0WJWC.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:06:53.261+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":104,"tagline":"Bisogna stare attenti a quello che si desidera","homepage":"","overview":"Quando inizia il lockdown a Roma, Luca (Riccardo Scamarcio), insegnante di filosofia del liceo, si ritrova a viverlo da solo perché la moglie Sara (Maria Chiara Giannetta), medico, vive praticamente in ospedale per fronteggiare l'emergenza. Mentre il mondo si ferma, la sua attenzione si concentra sulla nuova vicina, Amanda (Mariela Garriga). Quando il desiderio lo spinge a rompere la distanza che li separa, Luca è travolto da una passione incontrollata che sconvolgerà la sua vita con conseguenze inaspettate. Durante il lockdown al protagonista del film accade qualcosa di travolgente con l'apparizione di Amanda che scatenerà una passione più pericolosa della stessa pandemia."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Close To Me","runtime":103,"tagline":"","homepage":"","overview":"Luca is a forty-year-old teacher experiencing a relationship crisis with his wife, Sara, who is much wealthier than him. During the lockdown, Luca finds himself a bystander in the life of his new neighbor, Amanda, and decides to bridge the distance between them, with disastrous consequences."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Умри от неё","runtime":0,"tagline":"","homepage":"","overview":"Пандемия переворачивает привычный ритм жизни преподавателя философии Луки. Его жена Сара, врач, уходит работать в переполненные римские госпитали, а сам он остаётся в квартире, полной тишины и одиночества. В это время в соседнюю квартиру въезжает загадочная Аманда. Их случайные взгляды через балконы перерастают в нечто большее — Лука теряет контроль над своими чувствами. Чем больше он узнаёт о ней, тем сильнее размывается грань между реальностью и страстью. Карантин становится не просто изоляцией, а ловушкой, где разгорается роман, угрожающий разрушить всё, что у него было."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"祸水","runtime":0,"tagline":"","homepage":"","overview":"讲述了一个“窥视者”的故事。卢卡（里卡尔多·斯卡马乔饰）与萨拉（玛丽亚·基娅拉·詹内塔饰）结婚，萨拉比他富有，且刚满40岁。卢卡是一名饱受危机困扰的教师，在封锁期间，他最终成为了一名旁观者，窥视着新邻居阿曼达（玛丽拉·加里加饰）的生活。他决定缩小他们之间的距离，却带来了灾难性的后果。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Επικίνδυνα κοντά σου","runtime":0,"tagline":"","homepage":"","overview":"Ένας καθηγητής πανεπιστημίου στην εποχή της καραντίνας λόγω covid, παραδίδει μαθήματα με τηλεκπαίδευση. Κλεισμένος στο σπίτι και με τη γιατρό γυναίκα του να λείπει σε εξοντωτικές βάρδιες στο νοσοκομείο, αρχίζει να παρατηρεί από το παράθυρο την νέα γειτόνισσα, μια εντυπωσιακή και σέξι καθηγήτρια χορού. Δεν αργούν να γοητευτούν ο ένας από τον άλλο και να παρασυρθούν σε έναν παθιασμένο έρωτα. Όμως, τίποτα δεν είναι όπως φαίνεται, τίποτα δεν έχει γίνει τυχαία και οι αναπάντεχες ανατροπές διαδέχονται η μία την άλλη."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"유리창 너머의 유혹","runtime":104,"tagline":"이 끌림의 끝은 어디일까","homepage":"","overview":"코로나19 팬데믹이 한창인 로마, 팔불출 아버지를 둔 의사 ‘사라’와 고등학교 교사 ‘루카’는 비록 아이는 없지만 안정적인 결혼 생활을 이어가고 있다. 어느 날, 옆집으로 이사 온 매혹적인 댄서 ‘아만다’. 루카는 우연한 계기로 그녀와 대화를 나누게 되고 점차 알 수 없는 끌림에 빠져들어 몰래 작업실에서 건너편 그녀의 방을 엿보기 시작한다. 며칠 후, 수상한 불청객이 아만다의 집을 방문하고 루카는 그가 아만다에게 폭력을 행사하는 것을 목격하게 되는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"禍水","runtime":0,"tagline":"","homepage":"","overview":"講述了一個“窺視者”的故事。盧卡（裏卡爾多·斯卡馬喬飾）與薩拉（瑪麗亞·基婭拉·詹內塔飾）結婚，薩拉比他富有，且剛滿 40 歲。盧卡是一名飽受危機困擾的教師，在封鎖期間，他最終成為了一名旁觀者，窺視著新鄰居阿曼達（瑪麗拉·加里加飾）的生活。他決定縮小他們之間的距離，卻帶來了災難性的後果。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Close To Me","runtime":0,"tagline":"","homepage":"","overview":"Luca, ein vierzigjähriger Lehrer, steckt in einer Beziehungskrise mit seiner Frau Sara, die deutlich wohlhabender ist als er. Während des Lockdowns gerät Luca in das Leben seiner neuen Nachbarin Amanda und beschließt, die Kluft zwischen ihnen zu überbrücken – mit verheerenden Folgen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Muero por ella","runtime":0,"tagline":"","homepage":"","overview":"Luca, un profesor casado, se siente atrapado durante el confinamiento por la pandemia. Todo cambia cuando conoce a Amanda, su encantadora vecina, y se enamora de ella. Lo que comienza como un romance se convierte en un thriller lleno de secretos y revelaciones inesperadas."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"En Luca, un professor casat, se sent atrapat durant el confinament per la pandèmia. Tot canvia quan coneix l'Amanda, la seva encantadora veïna, i se n'enamora. El que comença com un idil·li es converteix en un thriller ple de secrets i revelacions inesperades."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Perto de Mim","runtime":103,"tagline":"Ela está mais perto do que você imagina.","homepage":"","overview":"Luca, um professor de quarenta anos, enfrenta uma crise no relacionamento com sua esposa, Sara, que é muito mais rica do que ele. Durante o confinamento, Luca se vê como um mero espectador na vida de sua nova vizinha, Amanda, e decide tentar aproximá-los, com consequências desastrosas."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"}],"reviews_tmdb":[],"recommendations":[{"id":9063,"adult":false,"title":"The Element of Crime","video":false,"overview":"Fisher, an ex-detective, decides to take one final case when a mysterious serial killer claims the lives of several young girls. Fisher, unable to find the culprit, turns to Osbourne, a writer who was once respected for his contributions to the field of criminology. Fisher begins to use Osbourne's technique, which involves empathizing with serial killers; however, as the detective becomes increasingly engrossed in this method, things take a disturbing turn.","genre_ids":[80,18,878],"media_type":"movie","popularity":0.6236,"vote_count":220,"poster_path":"/sfg5KUOdR4bfoPiDf63LVG7mlfw.jpg","release_date":"1984-05-14","vote_average":6.3,"backdrop_path":"/zpkSkHXm81jlFgXmTmmGQ4TuUzo.jpg","original_title":"Forbrydelsens element","original_language":"da"},{"id":1198877,"adult":false,"title":"The Body","video":false,"overview":"Rich entrepreneur Rebecca Zuin has died from an alleged heart attack, raising suspicions on the part of a police inspector after her body disappears from the morgue. When her handsome young husband becomes a suspect, he starts thinking she may have faked her death to sadistically torment him.","genre_ids":[53,9648],"media_type":"movie","popularity":0.6236,"vote_count":101,"poster_path":"/AdimvmZwDiItYRzMerSiSakX0q4.jpg","release_date":"2024-11-28","vote_average":6.574,"backdrop_path":"/rIz8OJVJJbZNDXOrXPW7MVXePqi.jpg","original_title":"Il corpo","original_language":"it"},{"id":666622,"adult":false,"title":"Breaking Up in Rome","video":false,"overview":"Aspiring writer Tommaso makes a living by penning the self-help column of a women's magazine. One day he receives a letter from a reader asking for advice on how to break up with her man: it is none other than Zoe, his partner of ten years, unaware of his pseudonymous side job. Tommaso can't believe his eyes and answers her in private to learn more.","genre_ids":[10749,35,18],"media_type":"movie","popularity":0.1981,"vote_count":215,"poster_path":"/QBRtW9mFjbcginDFQWAL3Q0Lhh.jpg","release_date":"2021-11-30","vote_average":6.605,"backdrop_path":"/mVM9zFpGHHRQ1pS4iPXzenr5EcK.jpg","original_title":"Lasciarsi un giorno a Roma","original_language":"it"},{"id":1254624,"adult":false,"title":"Night Always Comes","video":false,"overview":"Facing eviction in a city her family can no longer afford, a woman plunges into a desperate and increasingly dangerous all-night search to raise $25,000.","genre_ids":[53,18,80],"media_type":"movie","popularity":17.1329,"vote_count":246,"poster_path":"/1jDo1nG7rtjaaQGpr6e73x9i9Xp.jpg","release_date":"2025-08-15","vote_average":6.061,"backdrop_path":"/cVqQdzqo0ymSFJqU87bIiHV8bA7.jpg","original_title":"Night Always Comes","original_language":"en"},{"id":1042834,"adult":false,"title":"Eden","video":false,"overview":"A group of disillusioned outsiders abandon modern society in search of a new beginning. Settling on a remote, uninhabited island, their utopian dream quickly unravels as they discover that the greatest threat isn’t the brutal climate or deadly wildlife, but each other.","genre_ids":[53,18],"media_type":"movie","popularity":7.3211,"vote_count":566,"poster_path":"/jbFEESMVbpJU8IjZBjiWGJdEsxR.jpg","release_date":"2025-04-03","vote_average":6.719,"backdrop_path":"/rz8NcfTRczvn94vpnmMx42zt6EC.jpg","original_title":"Eden","original_language":"en"},{"id":11660,"adult":false,"title":"Following","video":false,"overview":"Bill, an idle, unemployed aspiring writer, walks the crowded streets of London following randomly chosen strangers, a seemingly innocent entertainment that becomes dangerous when he crosses paths with a mysterious character.","genre_ids":[18,53],"media_type":"movie","popularity":3.7723,"vote_count":1798,"poster_path":"/3bX6VVSMf0dvzk5pMT4ALG5A92d.jpg","release_date":"1999-05-06","vote_average":7.125,"backdrop_path":"/yf5I5VHllK4h5VdbxHfQ40RBTe8.jpg","original_title":"Following","original_language":"en"},{"id":64678,"adult":false,"title":"The Art of Getting By","video":false,"overview":"George, a lonely and fatalistic teen who's made it all the way to his senior year without ever having done a real day of work, is befriended by Sally, a popular but complicated girl who recognizes in him a kindred spirit.","genre_ids":[18,10749],"media_type":"movie","popularity":1.569,"vote_count":1341,"poster_path":"/3ahdKyzHbYhvqJdtpsEWipEai98.jpg","release_date":"2011-06-17","vote_average":6.6,"backdrop_path":"/aOBIon675l54MET558A3m6xj6yY.jpg","original_title":"The Art of Getting By","original_language":"en"},{"id":9319,"adult":false,"title":"The Last Boy Scout","video":false,"overview":"Somewhere in Los Angeles, the city of broken dreams, a stripper is murdered. Now, the private detective she had hired and her ex-footballer boyfriend are going to find her murderer... if they don't kill each other first. But the more they dig, the deeper they become enmeshed in a web of extortion, blackmail and corrupt politics hidden beneath the surface of professional football.","genre_ids":[28,53],"media_type":"movie","popularity":2.9371,"vote_count":2085,"poster_path":"/glPswihcZYoAQ4YM2uJF4UACy8T.jpg","release_date":"1991-12-13","vote_average":6.83,"backdrop_path":"/8AZ8Hjcr4Jr1eR93OW70g9jjUr9.jpg","original_title":"The Last Boy Scout","original_language":"en"},{"id":1140066,"adult":false,"title":"Paradise","video":false,"overview":"A man sees the dark side of the time-manipulating biotech company he works for when a crushing debt forces his wife to give up 40 years of her own life.","genre_ids":[878,53],"media_type":"movie","popularity":1.7876,"vote_count":683,"poster_path":"/yGz88hNPcHUJkUx7MPm0Ue6GZt7.jpg","release_date":"2023-06-24","vote_average":6.474,"backdrop_path":"/df8ya9FKghk0U45G2nJru6ZOuUK.jpg","original_title":"Paradise","original_language":"de"},{"id":645710,"adult":false,"title":"The Voyeurs","video":false,"overview":"When Pippa and Thomas move into their dream apartment, they notice that their windows look directly into the apartment opposite – inviting them to witness the volatile relationship of the attractive couple across the street. But what starts as a simple curiosity turns into full-blown obsession with increasingly dangerous consequences.","genre_ids":[53],"media_type":"movie","popularity":10.6731,"vote_count":1127,"poster_path":"/8Y4XOIWhpOvSOEn8XrxbkH9yAXO.jpg","release_date":"2021-08-25","vote_average":6.511,"backdrop_path":"/5KGrBXvE0cYDwqfEaymvNBVspkJ.jpg","original_title":"The Voyeurs","original_language":"en"},{"id":1137350,"adult":false,"title":"The Phoenician Scheme","video":false,"overview":"Wealthy businessman Zsa-zsa Korda appoints his only daughter, a nun, as sole heir to his estate. As Korda embarks on a new enterprise, they soon become the target of scheming tycoons, foreign terrorists, and determined assassins.","genre_ids":[35,12,80],"media_type":"movie","popularity":5.6177,"vote_count":808,"poster_path":"/u2jxeYLXTYfu0bqJmnLGIgZswib.jpg","release_date":"2025-05-23","vote_average":6.527,"backdrop_path":"/bajke0ThKJ2V2iHE9DDYOJGdS7a.jpg","original_title":"The Phoenician Scheme","original_language":"en"},{"id":375366,"adult":false,"title":"The Girl with All the Gifts","video":false,"overview":"In the future, a strange fungus has changed nearly everyone into thoughtless, flesh-eating monsters. When a scientist and a teacher find a girl who seems to be immune to the fungus, they all begin a journey to save humanity.","genre_ids":[28,27,878],"media_type":"movie","popularity":2.1645,"vote_count":2115,"poster_path":"/vdCD8z55a4RNmHQDPIpuMFqoY2B.jpg","release_date":"2016-09-23","vote_average":6.6,"backdrop_path":"/rrAMFTuTFHYI6INtyPnOYyoGTO2.jpg","original_title":"The Girl with All the Gifts","original_language":"en"},{"id":755898,"adult":false,"title":"War of the Worlds","video":false,"overview":"Will Radford is a top analyst for Homeland Security who tracks potential threats through a mass surveillance program, until one day an attack by an unknown entity leads him to question whether the government is hiding something from him... and from the rest of the world.","genre_ids":[878,53],"media_type":"movie","popularity":112.9817,"vote_count":899,"poster_path":"/yvirUYrva23IudARHn3mMGVxWqM.jpg","release_date":"2025-07-29","vote_average":4.197,"backdrop_path":"/iZLqwEwUViJdSkGVjePGhxYzbDb.jpg","original_title":"War of the Worlds","original_language":"en"},{"id":1195506,"adult":false,"title":"Novocaine","video":false,"overview":"When the girl of his dreams is kidnapped, everyman Nate turns his inability to feel pain into an unexpected strength in his fight to get her back.","genre_ids":[28,35,53],"media_type":"movie","popularity":8.286,"vote_count":1461,"poster_path":"/xmMHGz9dVRaMY6rRAlEX4W0Wdhm.jpg","release_date":"2025-03-12","vote_average":6.8,"backdrop_path":"/lyBH2mFFU6qrHwD5QKotL2JnEb6.jpg","original_title":"Novocaine","original_language":"en"},{"id":1079091,"adult":false,"title":"It Ends with Us","video":false,"overview":"When a woman's first love suddenly reenters her life, her relationship with a charming, but abusive neurosurgeon is upended, and she realizes she must learn to rely on her own strength to make an impossible choice for her future.","genre_ids":[18,10749],"media_type":"movie","popularity":6.9615,"vote_count":1839,"poster_path":"/AjV6jFJ2YFIluYo4GQf13AA1tqu.jpg","release_date":"2024-08-07","vote_average":6.948,"backdrop_path":"/8yPSYhooj8nyBbmV3GVdLDwuE7e.jpg","original_title":"It Ends with Us","original_language":"en"},{"id":1100988,"adult":false,"title":"28 Years Later","video":false,"overview":"Twenty-eight years after the Rage virus outbreak, a heavily-defended island survives connected to the mainland by a single causeway. When one of the group leaves the island into the dark heart of the mainland, he discovers secrets, wonders, and horrors that have mutated not only the infected but other survivors as well.","genre_ids":[27,53,878],"media_type":"movie","popularity":27.1978,"vote_count":2251,"poster_path":"/n5FygjEppOvac6yEaowi26nTyw3.jpg","release_date":"2025-06-18","vote_average":6.612,"backdrop_path":"/6WqqEjiycNvDLjbEClM1zCwIbDD.jpg","original_title":"28 Years Later","original_language":"en"},{"id":1064213,"adult":false,"title":"Anora","video":false,"overview":"A young sex worker from Brooklyn gets her chance at a Cinderella story when she meets and impulsively marries the son of an oligarch. Once the news reaches Russia, her fairytale is threatened as his parents set out to get the marriage annulled.","genre_ids":[18,35,10749],"media_type":"movie","popularity":11.8488,"vote_count":2972,"poster_path":"/cgXk2tNYhJZLXdBDO5DidAVzQ82.jpg","release_date":"2024-10-14","vote_average":7.057,"backdrop_path":"/qvyOfwTC3qdbzkqdXWSSEMHtjBZ.jpg","original_title":"Anora","original_language":"en"},{"id":50014,"adult":false,"title":"The Help","video":false,"overview":"Aibileen Clark is a middle-aged African-American maid who has spent her life raising white children and has recently lost her only son; Minny Jackson is an African-American maid who has often offended her employers despite her family's struggles with money and her desperate need for jobs; and Eugenia \"Skeeter\" Phelan is a young white woman who has recently moved back home after graduating college to find out her childhood maid has mysteriously disappeared. These three stories intertwine to explain how life in Jackson, Mississippi revolves around \"the help\"; yet they are always kept at a certain distance because of racial lines.","genre_ids":[18],"media_type":"movie","popularity":7.2864,"vote_count":8875,"poster_path":"/3kmfoWWEc9Vtyuaf9v5VipRgdjx.jpg","release_date":"2011-08-09","vote_average":8.201,"backdrop_path":"/k2ZdjMXmqnw4RJeh8cwxCvcznJZ.jpg","original_title":"The Help","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":23.0611,"vote_count":11386,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":30.0131,"vote_count":26824,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.9,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"}],"similar_content":[],"external_ids":{"imdb_id":"tt32478708","twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148342,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"DE","release_dates":[{"note":"","type":5,"iso_639_1":"","descriptors":[],"release_date":"2025-11-28T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"GR","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-08-07T00:00:00.000Z","certification":""}]},{"iso_3166_1":"IT","release_dates":[{"note":"","type":3,"iso_639_1":"","d