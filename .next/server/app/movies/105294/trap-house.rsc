:1920,"file_path":"/csrgVNrgHJ3B80PCLgTKPh09vSr.jpg","iso_639_1":"ru","vote_average":0}],"backdrops":[{"width":2560,"height":1440,"file_path":"/oIJjO1CvEdTMFNkWfHaV0RB584G.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/fAjYaSd9DzSaPMa5SAARW4jG1QY.jpg","iso_639_1":"en","vote_average":3.334},{"width":3840,"height":2160,"file_path":"/t98ZZtgdBC2yi7XBiT9nYBH6BrK.jpg","iso_639_1":null,"vote_average":2.542},{"width":1600,"height":900,"file_path":"/dZDQkUGMAINYsZPqV2HhclXMEnF.jpg","iso_639_1":null,"vote_average":1.222},{"width":1280,"height":720,"file_path":"/4HcT50CvtUtyorKrgkstJfPZwYj.jpg","iso_639_1":"en","vote_average":0.166},{"width":2560,"height":1440,"file_path":"/jKXWln8BKBMp2VE6laBCykAeDGg.jpg","iso_639_1":"vi","vote_average":0},{"width":1280,"height":720,"file_path":"/bG1643rKJZRzW9c6MhIlOvSvhR3.jpg","iso_639_1":"uk","vote_average":0},{"width":3840,"height":2160,"file_path":"/pBl8TIMZ68TtbPznl0G1dHMYPxw.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/g8w8IPvAEfwDD4sHv2aChrJWijD.jpg","iso_639_1":"es","vote_average":0},{"width":1920,"height":1080,"file_path":"/8cT5Qmdy8Gw3jCjZfBvf41agn6o.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/kIQiW9lSbEzA8QqwK7GdfiUfxne.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/zMMINvFleiLJJLbrzpajSv5VaV0.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/4CEZ6TSrekAP7V6aZJv8eZYRK3D.jpg","iso_639_1":"ca","vote_average":0},{"width":3840,"height":2160,"file_path":"/t82noxAQacNIZcOQyto0D1g4ZUB.jpg","iso_639_1":"pt","vote_average":0},{"width":3840,"height":2160,"file_path":"/5AxqgkFdVx0ZuTSYvdp3m9eUIfl.jpg","iso_639_1":"tr","vote_average":0}]},"enriched_at":"2026-04-21T06:02:05.639+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":102,"tagline":"This isn't a raid. It's a reckoning.","homepage":"","overview":"An undercover DEA agent and his partner embark on a game of cat and mouse with an audacious, and surprising group of thieves - their own rebellious teenagers, who have begun robbing from a dangerous cartel, using their parents' tactics and top-secret intel to do it."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Een undercover DEA-agent en zijn partner beginnen aan een kat-en-muisspel met een gedurfde en verrassende groep dieven: hun eigen opstandige tieners, die zijn begonnen met beroven van een gevaarlijk kartel, waarbij ze de tactieken en uiterst geheime informatie van hun ouders gebruiken."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":102,"tagline":"","homepage":"","overview":"Un agente de la DEA y su compañero persiguen un peculiar grupo de ladrones: sus propios hijos adolescentes rebeldes, que han empezado a robar a un peligroso cártel, utilizando para ello las tácticas de sus padres y la información de alto secreto."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"À El Paso, au Texas, un agent infiltré de la DEA et son partenaire se lancent dans un jeu du chat et de la souris avec un groupe de voleurs audacieux : leurs propres adolescents rebelles. Les ados ont décidé de voler de l'argent à un dangereux cartel en utilisant les tactiques de leurs parents et leurs informations top secrètes."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Джекпот","runtime":0,"tagline":"","homepage":"","overview":"Суперагент Сил и команда охотятся на мексиканский картель по обе стороны границы. Преступники отвечают им взаимностью — палят из всех стволов. Неожиданно в игру вступает третья сторона. Кто-то дерзко грабит склады картеля. За несколько дней исчезают миллионы долларов. Но деньги не исчезают бесследно. Неизвестный открывает в банке счет и начинает раздавать награбленное всем нуждающимся. Теперь его жизнь зависит от того, кто найдет его первым — спецы или головорезы картеля."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Інсайдери","runtime":0,"tagline":"","homepage":"","overview":"Агенти Управління боротьби з наркотиками переслідують злодіїв, що пограбували картель. Несподівано ними виявились їхні власні бунтівні дітки, які використовуючи батьківську тактику і секретну інформацію, вивели гру на новий рівень..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Refugio mortal","runtime":102,"tagline":"","homepage":"","overview":"Un agente de la DEA y su compañero persiguen un peculiar grupo de ladrones: sus propios hijos adolescentes rebeldes, que han empezado a robar a un peligroso cártel, utilizando para ello las tácticas de sus padres y la información de alto secreto."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"To nie jest nalot. To rozrachunek.","homepage":"","overview":"Tajny agent DEA i jego partner rozpoczynają grę w kotka i myszkę z odważną i zaskakującą grupą złodziei –  zbuntowanymi nastolatkami, którzy zaczęli okradać niebezpieczny kartel, wykorzystując w tym celu taktykę swoich rodziców i ściśle tajne informacje."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"ดักแผนล่า ท้าทรชน","runtime":0,"tagline":"","homepage":"","overview":"ที่เอลพาโซ รัฐเท็กซัส สายลับปปส.แฝงตัวและคู่หูของเขาต้องเข้าสู่เกมแมวจับหนู กับกลุ่มโจรสุดอุกอาจซึ่งก็คือเหล่าลูกๆ วัยรุ่นจอมขบถของพวกเขาซึ่งไปปล้นเงินจากแก๊งค้ายาสุดอันตราย โดยใช้ทั้งกลยุทธ์และข่าวกรองลับสุดยอดที่ได้มาจากพ่อแม่ของตน"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"毒窟風暴","runtime":0,"tagline":"","homepage":"","overview":"緝毒局探員搭檔在德州艾爾帕索與一群大膽竊賊展開貓捉老鼠遊戲，沒想到這群竊賊竟是他們自己叛逆的青少年子女。這些年輕人利用父母的戰術和最高機密情報，開始搶劫危險的販毒集團。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"青出于蓝","runtime":127,"tagline":"","homepage":"","overview":"一名美国缉毒局卧底特工和他的搭档与一群大胆且令人意想不到的窃贼展开了一场猫捉老鼠的游戏——这些窃贼竟是他们叛逆的青少年子女，这些孩子开始从一个危险的贩毒集团那里行窃，还运用了他们父母的策略和绝密情报。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Báo Thủ Báo Nhà","runtime":102,"tagline":"Đây không phải là một cuộc đột kích. Đây là một sự tính toán.","homepage":"","overview":"Một đặc vụ DEA chìm và cộng sự của anh ta bắt đầu cuộc rượt đuổi mèo vờn chuột với một nhóm trộm táo tợn và đáng ngạc nhiên – chính là những đứa con tuổi teen nổi loạn của họ, những kẻ đã bắt đầu cướp bóc từ một băng đảng ma túy nguy hiểm, sử dụng chiến thuật và thông tin tình báo tối mật của cha mẹ chúng để thực hiện điều đó."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"خانه تله","runtime":0,"tagline":"","homepage":"","overview":"یک مأمور مخفی اداره مبارزه با مواد مخدر و همکارش، وارد یک بازی موش و گربه با یک گروه از سارقان جسور و غافلگیرکننده می‌شوند: نوجوانان سرکش خودشان. این نوجوانان شروع به سرقت از یک کارتل خطرناک کرده‌اند و برای انجام این کار از تاکتیک‌ها و اطلاعات فوق سری والدین خود استفاده می‌کنند و ..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Boca de Fumo","runtime":0,"tagline":"Isto não é uma invasão. É um acerto de contas.","homepage":"","overview":"Em El Paso, Texas, um agente disfarçado da Narcóticos e seu parceiro brincam de gato e rato com um grupo ousado de ladrões: seus próprios filhos adolescentes. Usando as táticas e as informações secretas dos pais, eles começam a roubar de um cartel perigoso."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Jocul generațiilor","runtime":0,"tagline":"","homepage":"","overview":"Un agent sub acoperire al DEA și partenerul său se angajează într - un joc de - a șoarecele și pisica cu un grup de hoți îndrăzneți și surprinzători: propriii lor adolescenți rebeli, care au început să jefuiască un cartel periculos, folosindu - se de tacticile părinților lor și de informații strict secrete."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"بيت الفخ","runtime":0,"tagline":"","homepage":"","overview":"ينطلق عميل سري في إدارة مكافحة المخدرات وشريكه في لعبة كر وفر مع مجموعة من اللصوص المراهقون المتمردون، حيث تشتعل الأمور حينما تبدأ العصابة في السرقة من عصابة خطيرة."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"A Casa da Armadilha","runtime":0,"tagline":"","homepage":"","overview":"Centra-se num agente da DEA, Ray Seale (Dave Bautista), e seu parceiro que perseguem um grupo de ladrões adolescentes que usam táticas e informações confidenciais dos pais para roubar um cartel, descobrindo que os criminosos são, na verdade, seus próprios filhos, incluindo o filho de Ray, Cody, que lidera o grupo para vingar a morte de um colega de trabalho do pai. É um jogo de gato e rato onde pais e filhos se enfrentam com informações sigilosas."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"מאורת הסמים","runtime":0,"tagline":"","homepage":"","overview":"באל פאסו שבטקסס, סוכן סמוי של הרשות למלחמה בסמים והשותף שלו יוצאים למרדף של חתול ועכבר עם קבוצת גנבים נועזת: הנערים המרדנים שלהם עצמם. הנערים מתחיל לשדוד קרטל מסוכן, בעזרת הטקטיקות והמודיעין הסודי ביותר של הוריהם."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"트랩 하우스","runtime":0,"tagline":"이것은 단순한 급습이 아니다. 거대한 심판의 시작이다.","homepage":"","overview":"텍사스주 엘패소에서 마약단속국 비밀 요원이 파트너와 대담하기 짝이 없는 도적단을 추격한다. 도둑의 정체는 요원들의 반항심 가득한 10대 자녀들로, 이들은 부모의 전략과 극비 정보를 이용하여 위험한 카르텔을 강탈하기 시작한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Hiša pasti","runtime":0,"tagline":"To ni napad. To je obračun.","homepage":"","overview":"Tajni agent DEA in njegov partner se zapleteta v igro mačke in miši z drzno in presenetljivo skupino tatov – lastnimi uporniškimi najstniki, ki so začeli ropati nevaren kartel, pri tem pa uporabljajo taktike in strogo zaupne informacije svojih staršev."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Ein Undercover-DEA-Agent und sein Partner spielen Katz-und-Maus mit einer überraschenden Gruppe von Dieben – ihren eigenen rebellischen Teenagern, die das Kartell bestehlen, ausgestattet mit den Tricks und Geheiminfos ihrer Eltern."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Drogtanya","runtime":0,"tagline":"","homepage":"","overview":"A texasi El Pasóban egy fedett DEA-ügynök és társa egy csapat vakmerő tolvajjal keveredik macska-egér játékba: saját lázadó tinédzsereik a szüleik taktikáit és titkos információit felhasználva lopnak meg egy veszélyes kartellt."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"V pasti","runtime":0,"tagline":"","homepage":"","overview":"Agent DEA v utajení a jeho partner v texaském El Pasu hrají hru kočky s myší s odvážnou skupinou zlodějů. Ti nejsou jen obyčejní zločinci — jejich rebelskými dospívajícími dětmi začínají okrádat nebezpečný kartel využitím taktik a přísně tajných informací, které získali od svých rodičů."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":102,"tagline":"","homepage":"","overview":"En undercover DEA-agent og hans partner kaster sig ud i en katten-efter-musen-leg med en dristig og overraskende gruppe tyve - deres egne oprørske teenagere, der er begyndt at røve fra et farligt kartel ved hjælp af deres forældres taktikker og tophemmelige oplysninger."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Tuzak Evi","runtime":0,"tagline":"","homepage":"","overview":"El Paso, Teksas'ta gizli bir DEA ajanı ve ortağı, kendi asi çocuklarından oluşan cesur bir hırsız grubuyla kedi fare oyununa girişir. Gençler, ebeveynlerinin yöntemleri ve gizli istihbaratlarını kullanarak tehlikeli bir uyuşturucu kartelini soymaya başlar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"トラップハウス","runtime":0,"tagline":"","homepage":"","overview":"テキサス州エルパソで、DEA（麻薬取締局）捜査官とその相棒は、大胆不敵な窃盗団とのいたちごっこを始める。その窃盗団とは彼らの反抗期の子供たちだ。若者たちは親の戦術と極秘情報を駆使し、危険なカルテルから盗みを働き始める。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"El narcopís","runtime":0,"tagline":"","homepage":"","overview":"A El Paso, Texas, un agent d'incògnit de la brigada antidrogues i el seu company s'embarquen en un joc de persecucions amb un grup de lladres intrèpids: els seus fills rebels adolescents. Els joves comencen a robar un càrtel perillós utilitzant la informació confidencial i les tàctiques dels seus pares."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"მახე","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"El Paso, Texas. DEA-agentti Ray Seale ja hänen kollegansa yrittävät pitää huumekartellin liiketoimintaa kurissa. Tilanne lähtee kuitenkin lapasesta, kun heidän teini-ikäiset lapsensa sekaantuvat peliin. Nuoret, jotka ovat kasvaneet vanhempiensa salaisen työn varjossa, päättävät käyttää DEA:n tietoja ja taktiikoita omiin tarkoituksiinsa. He alkavat ryöstää kartellin ”trap house” -kohteita suurten rahojen toivossa ja hakevat samalla oikeutta ystävälleen, jonka isä kuoli kartellin toimesta.  Vanhemmat joutuvat nyt kamppailemaan kahden tulen välissä: lain velvoitteiden ja lastensa turvallisuuden välillä. Tilanne kärjistyy nopeasti väkivaltaiseksi, sillä ”trap house” -huumetukikohtien maailmassa mikään ei ole sitä miltä näyttää."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"I El Paso, Texas, ger sig en DEA-agent under täckmantel och hans partner in i en katt-och-råtta-lek med en grupp fräcka tjuvar: sina egna trotsiga tonåringar. Med hjälp av sina föräldrars taktik och topphemliga information börjar tonåringarna stjäla från en farlig kartell."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Капанът","runtime":0,"tagline":"","homepage":"","overview":"В Ел Пасо, Тексас, агент под прикритие от Агенцията за борба с наркотиците (в ролята Дейв Батиста) и партньорът му се впускат в игра на котка и мишка със собствените си деца тийнейджъри, които използват тактиките на родителите си - наблюдение, инфилтрация и несмъртоносни оръжия - за да ограбят опасен наркокартел."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"}],"reviews_tmdb":[],"recommendations":[{"id":807223,"adult":false,"title":"Re-Births","video":false,"overview":"A documentary film depicting five intimate portraits of migrants who fled their country of origin to seek refuge in France and find a space of freedom where they can fully experience their sexuality and their sexual identity: Giovanna, woman transgender of Colombian origin, Roman, Russian transgender man, Cate, Ugandan lesbian mother, Yi Chen, young Chinese gay man…","genre_ids":[99],"media_type":"movie","popularity":0.5221,"vote_count":50,"poster_path":"/dC3y4IJW0yClaKBaMqXxVQ6nOXr.jpg","release_date":"2017-12-01","vote_average":7.4,"backdrop_path":"/njPvpcxJu8PBNl5eVe8R6YF8SHJ.jpg","original_title":"Re-naissances","original_language":"fr"},{"id":844613,"adult":false,"title":"Sonic 30th Anniversary Symphony","video":false,"overview":"30 years ago, on June 23rd, 1991, Sonic the Hedgehog was released on the SEGA Genesis, beginning a new era of gaming.  Since then, Sonic has been running through countless zones, beating badniks, and saving the world with the help of his friends.  This performance is to thank you, all of you, for being there every step of the way, and to remind us all of the amazing journey we've been on.  Happy 30th Anniversary, Sonic!","genre_ids":[99,10402],"media_type":"movie","popularity":0.3887,"vote_count":13,"poster_path":"/nhbXu6nIBV6lP4L93eHi7PJcILE.jpg","release_date":"2021-06-23","vote_average":7.115,"backdrop_path":"/h3lW1GzRqwVxfbTAddlNgWY9lNa.jpg","original_title":"Sonic 30th Anniversary Symphony","original_language":"en"},{"id":23666,"adult":false,"title":"Ross Noble: Sonic Waffle","video":false,"overview":"Here it is folks... another classic comedy DVD from stand-up master Ross Noble. This packed DVD features an uncut live performance filmed in London on the last night of Ross' Sonic Waffle tour. Along with the main feature Ross has also included his guest performance from BBC's Jack Dee Live at the Apollo, plus his own commentaries on both shows and a stack of other extras","genre_ids":[35],"media_type":"movie","popularity":0.2375,"vote_count":2,"poster_path":"/nk7e8RnX9ikpZnycoLRx48ieQ8A.jpg","release_date":"2005-10-03","vote_average":6.5,"backdrop_path":null,"original_title":"Ross Noble: Sonic Waffle","original_language":"en"},{"id":44874,"adult":false,"title":"Barbie: A Fashion Fairytale","video":false,"overview":"Barbie, a popular actress on a sabbatical, learns that her fashion designer aunt Millicent has sold her business to a rival. With the help of a few magical beings, Barbie steps in to save the day.","genre_ids":[10751,16],"media_type":"movie","popularity":1.5315,"vote_count":786,"poster_path":"/bFnf8f8DXdCANQ7Y62djgubhh4P.jpg","release_date":"2010-09-14","vote_average":7.253,"backdrop_path":"/vlCXMFuSmQLXKzUIrNYoONwqggv.jpg","original_title":"Barbie: A Fashion Fairytale","original_language":"en"},{"id":701933,"adult":false,"title":"Sonic Soldier Borgman: Madnight☆Gigs!","video":false,"overview":"A music clip OVA using full versions of songs that were from the anime.","genre_ids":[16,10402],"media_type":"movie","popularity":0.5343,"vote_count":5,"poster_path":"/jxZLhLy92Q3TliwoSUkGiiTcWqq.jpg","release_date":"1989-02-08","vote_average":5.8,"backdrop_path":null,"original_title":"超音戦士ボーグマン Madnight☆gigs!","original_language":"ja"},{"id":413223,"adult":false,"title":"Sonic Soldier Borgman: Last Battle","video":false,"overview":"It has been three years since the end of the series. Ryo works for NASA as an engineer on a large rocket project. Anise, fellow Borgman and lover, has been reduced to flipping burgers in a restaurant. So naturally, when she gets a letter offering her a professional job in a big, Japanese, high-tech project, she jumps at the chance. Ryo, however, is as indecisive as ever and so she leaves for Japan without him. Chuck Sweager, the third Borgman, is a police officer, as is his girlfriend Miki...","genre_ids":[18,878,28,16],"media_type":"movie","popularity":0.392,"vote_count":8,"poster_path":"/l8ssJrew5Lz4oUAYJuiMDuwhKF0.jpg","release_date":"1989-09-16","vote_average":6.1,"backdrop_path":null,"original_title":"超音戦士ボーグマン ザ・ボーグマン ラストバトル","original_language":"ja"},{"id":56288,"adult":false,"title":"Spy Kids: All the Time in the World","video":false,"overview":"Eight years after the third film, the OSS has become the world's top spy agency, while the Spy Kids department has since become defunct. Retired spy Marissa is called back into action, and to bond with her new stepchildren Rebecca and Cecil, she invites them along to stop the evil Timekeeper from taking over the world.","genre_ids":[10751,35,28,12,18,14,878],"media_type":"movie","popularity":1.9066,"vote_count":1047,"poster_path":"/9pUVarhiXfCu8amjmyadzJJJITi.jpg","release_date":"2011-08-18","vote_average":4.689,"backdrop_path":"/3COCz2DMRNefY4a3lfUHrNj4tl0.jpg","original_title":"Spy Kids: All the Time in the World","original_language":"en"},{"id":15016,"adult":false,"title":"Barbie of Swan Lake","video":false,"overview":"Barbie as Odette, the young daughter of a baker, follows a unicorn into the Enchanted Forest and is transformed into a swan by an evil wizard intent on defeating the Fairy Queen.","genre_ids":[16,10751],"media_type":"movie","popularity":2.5752,"vote_count":1125,"poster_path":"/sLpCLVQWTU7BI4yAL6kIFM9J3eX.jpg","release_date":"2003-09-27","vote_average":7.032,"backdrop_path":"/tonrulTmO9ZyZmsAsr5yr9ciE4c.jpg","original_title":"Barbie of Swan Lake","original_language":"en"},{"id":1059673,"adult":false,"title":"Avatar: The Deep Dive - A Special Edition of 20/20","video":false,"overview":"An inside look at one of the most anticipated movie sequels ever with James Cameron and cast.","genre_ids":[99],"media_type":"movie","popularity":2.0971,"vote_count":88,"poster_path":"/pzZGqIyrrSqIfrkPLJnN1tvCGnV.jpg","release_date":"2022-12-13","vote_average":7.188,"backdrop_path":"/eoAvHxfbaPOcfiQyjqypWIXWxDr.jpg","original_title":"Avatar: The Deep Dive - A Special Edition of 20/20","original_language":"en"},{"id":564177,"adult":false,"title":"Njan Prakashan","video":false,"overview":"Pining for a lavish life abroad, a lazy but lovable guy next door crafts a scam to avoid a career in nursing and find a wealthy spouse to secure a visa.","genre_ids":[35],"media_type":"movie","popularity":0.3946,"vote_count":52,"poster_path":"/cCgltVXS9pnhuwEsN8saOFeievO.jpg","release_date":"2018-12-21","vote_average":6.913,"backdrop_path":"/A0INSzDxWnUjvkzWcF7quP59Oxz.jpg","original_title":"ഞാൻ പ്രകാശൻ","original_language":"ml"},{"id":963954,"adult":false,"title":"123 Hugs","video":false,"overview":"If hugs are tangible why am I hugging the void","genre_ids":[],"media_type":"movie","popularity":0.0861,"vote_count":11,"poster_path":"/lfgmWyWWV3WPJ53jxWUQa3NtJ8f.jpg","release_date":"2022-05-11","vote_average":6.3,"backdrop_path":"/xKCpH9xF4JReTL5NsWm4wtafPQP.jpg","original_title":"123 Peluk","original_language":"en"},{"id":1059116,"adult":false,"title":"g","video":true,"overview":"A disgruntled couple sets on a road trip, as the boyfriend is hiding something mysterious from his girlfriend. The suspicion grows bigger when she begins to fear her boyfriends next move.","genre_ids":[9648],"media_type":"movie","popularity":0.0618,"vote_count":9,"poster_path":null,"release_date":"","vote_average":6.8,"backdrop_path":null,"original_title":"g","original_language":"en"},{"id":13459,"adult":false,"title":"Barbie in 'A Christmas Carol'","video":false,"overview":"On Christmas Eve, Kelly is reluctant to go to a Christmas Eve ball, so Barbie tells her the story of Eden Starling, a glamorous singing diva in the Victorian England and the owner of a theatre house. However, Eden is self-centered and loves only herself. She is frequently accompanied by her snooty cat, Chuzzlewit. She does not believe in Christmas and orders all her employees to work on Christmas.","genre_ids":[16,10751],"media_type":"movie","popularity":1.3876,"vote_count":579,"poster_path":"/fX9g1AE1JIqjX3LPPKVjcmHs6fd.jpg","release_date":"2008-11-03","vote_average":7.177,"backdrop_path":"/vYjZEw6g76pDXSoXTwtypr42Iyz.jpg","original_title":"Barbie in 'A Christmas Carol'","original_language":"en"},{"id":284821,"adult":false,"title":"Winnie the Pooh: 123's","video":false,"overview":"Winnie the Pooh and friends teach counting.","genre_ids":[16],"media_type":"movie","popularity":0.2899,"vote_count":20,"poster_path":"/9gLYHG3n5GUW8KPHmAlbqI3M8lY.jpg","release_date":"2004-10-12","vote_average":6.9,"backdrop_path":"/f9TCzinjI8q3ibfdjotgIyWNqjz.jpg","original_title":"Winnie the Pooh: 123's","original_language":"en"},{"id":368834,"adult":false,"title":"The Latin Explosion: A New America","video":false,"overview":"With more than 50 million Latinos now living in the United States, Latinos are taking their seat at the table as the new American power brokers in the world of entertainment, business, politics and the arts. As Latinos’ influence in American society has soared, they have entered mainstream American culture, and the proof is in the music. Executive produced by legendary music mogul Tommy Mottola, THE LATIN EXPLOSION: A NEW AMERICA features a dazzling array of artists at the center of Latino cultural power and influence, including Marc Anthony, Emilio Estefan Jr., Gloria Estefan, José Feliciano, Eva Longoria, George Lopez, Jennifer Lopez, Los Lobos, Cheech Marin, Ricky Martin, Rita Moreno, Pitbull, Romeo Santos, Shakira, Thalía and Sofía Vergara. Narrated by John Leguizamo.","genre_ids":[99],"media_type":"movie","popularity":0.4446,"vote_count":17,"poster_path":"/cvZmJeepQTRdg3t9e1oeuivZgDA.jpg","release_date":"2015-11-16","vote_average":8,"backdrop_path":"/qInp9Cm0r3r4zLc9PCKdlUEoaxP.jpg","original_title":"The Latin Explosion: A New America","original_language":"en"},{"id":423248,"adult":false,"title":"Moon Young","video":false,"overview":"Mute Moon-young records people's faces with her small camcorder on the subway. One day, she avoids her drunk father at home and films Hee-soo who is crying over saying goodbye to her boyfriend and gets caught. The two feel some sort of kinship and become closer.","genre_ids":[18],"media_type":"movie","popularity":0.567,"vote_count":19,"poster_path":"/6gvSLdOVW7Xy3zbZbrYDT6x180.jpg","release_date":"2017-01-12","vote_average":6.7,"backdrop_path":"/n4uP0r6piqZdueiLWjZYbYsjHay.jpg","original_title":"문영","original_language":"ko"},{"id":7085,"adult":false,"title":"The Desperado Trail","video":false,"overview":"Rollins' gang wants to grab land by inciting the settlers in a war against the Indians but Winnetou and Old Shatterhand try to keep the peace, until Rollins frames Winnetou up for the murder of Jicarilla Chief's son.","genre_ids":[12,37],"media_type":"movie","popularity":0.7721,"vote_count":121,"poster_path":"/2pGKMW4QpvljuS2AiEcxyP9RwCk.jpg","release_date":"1965-10-14","vote_average":6.897,"backdrop_path":"/8viekHLJISuhitoskhrENyNhUKZ.jpg","original_title":"Winnetou 3. Teil","original_language":"de"},{"id":129533,"adult":false,"title":"Barbie: The Princess & the Popstar","video":false,"overview":"Tori is a blonde princess who is bored of living her royal life, and has dreams of becoming a popstar. Keira, on the other hand, is a brunette popstar who dreams of being a princess. When the two meet, they magically trade places, but after realising it is best to be themselves.","genre_ids":[10751,16],"media_type":"movie","popularity":2.0461,"vote_count":629,"poster_path":"/hab6ZMC3eXj9pQHlSxNUjonphCR.jpg","release_date":"2012-09-13","vote_average":7.167,"backdrop_path":"/kCQKdkfNc7Smox53QRalBO3Doe0.jpg","original_title":"Barbie: The Princess & the Popstar","original_language":"en"},{"id":108752,"adult":false,"title":"Return of the Outlaws","video":false,"overview":"Miraculously escaping a painful demise in the gallows, a notorious outlaw cons a crooked judge, an attractive saloon girl, and an old partner into carrying out the heist of a lifetime. As the plan gets underway, a small town sheriff makes it his personal mission to capture the outlaw and ensure that justice is served.","genre_ids":[37],"media_type":"movie","popularity":0.2482,"vote_count":20,"poster_path":"/uIQvG3oc6ZM3g3hBBObUxIAcs1p.jpg","release_date":"2009-03-17","vote_average":5.675,"backdrop_path":null,"original_title":"Return of the Outlaws","original_language":"en"},{"id":23154,"adult":false,"title":"The Garden of Sinners: The Hollow Shrine","video":false,"overview":"June 1998: After spending two years in a coma caused by a traffic accident, Shiki Ryougi awakens with amnesia. She is visited by Touko Aozaki, a wizard and proprietor of a studio called Garan no Dou. Shiki has lost not only the memory of her accident, but also any real sense that she's even alive. Strangely, enigmatic beings begin to attack her...","genre_ids":[16