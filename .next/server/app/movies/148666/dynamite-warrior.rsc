5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Dynamite Warrior\",\"description\":\"The story is set in 1890s Siam. Siang is a young Muay Thai warrior and rocketry expert who steals back water buffalo taken from poor Isan farmers by unscrupulous cattle raiders. He is searching for a man with a tattoo who killed his parents.\",\"image\":\"https://image.tmdb.org/t/p/w500/7yRZYBeYJgM49MGWEX1LQNgzqza.jpg\",\"datePublished\":\"2006-12-21\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"TH\",\"inLanguage\":\"th\",\"genre\":[\"Action\",null,null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.3,\"bestRating\":10,\"ratingCount\":51}}"}}],["$","$L10",null,{"initialDrama":{"id":"efdbf83d-905f-472d-a2bd-76f1c25e1798","tmdb_id":14818,"imdb_id":"tt0963915","content_type":"movie","title":"Dynamite Warrior","original_title":"ฅนไฟบิน","overview":"The story is set in 1890s Siam. Siang is a young Muay Thai warrior and rocketry expert who steals back water buffalo taken from poor Isan farmers by unscrupulous cattle raiders. He is searching for a man with a tattoo who killed his parents.","poster_path":"/7yRZYBeYJgM49MGWEX1LQNgzqza.jpg","backdrop_path":"/4aqCW6eXcRXovWJc8yNNbB3rXYr.jpg","release_date":"2006-12-21","first_air_date":null,"status":"published","original_language":"th","origin_country":["TH"],"genres":[{"id":28,"name":"Action"},"fantasy film","martial arts film","action film"],"popularity":2.2931,"vote_average":6.3,"vote_count":51,"runtime":98,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-26T00:57:29.503124+00:00","updated_at":"2026-02-26T00:57:29.305+00:00","tagline":"One will stand and fight.","homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":4207,"name":"Sahamongkolfilm","logo_path":"/v5BSFwIXQmZEO16bClILNrbv4Kl.png","origin_country":"TH"}],"production_countries":[{"name":"Thailand","iso_31