OW6Jo5IWuyJV3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.705,"vote_average":0},{"width":2000,"height":3000,"file_path":"/rKd17XUeq19UGLdoi0c45uzZpwI.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1280,"height":721,"file_path":"/mnWV0FHiRPHTaWkyxgelUGIPROy.jpg","iso_639_1":"id","iso_3166_1":"ID","vote_count":0,"aspect_ratio":1.775,"vote_average":0},{"width":1280,"height":720,"file_path":"/1LSMstNHwJnJD7tpnb8gZcgGNQR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/rjhTx37IbjJ1vOMfFSJ0ApxzpiJ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/a9PVDXZ9dk69lYU8PmZTE0w2BmQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/rnrrE2IYxwKTQSUMjGzOwuNheru.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/qYK6nQvOyoDyOZO9Iemq6zVZYjM.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/fZngPAMhWnIO9r5u95W35iQz0oP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/kVsXhzYKwgKmHkxfjir0h3r7Z8e.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/2meg5I7mDOmjHsERnJkRHgvuATY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/3rUXmZUfj5X4AhKlEfTGzOLhOye.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/nSUb8sgRC1gsVJDBP8YUuLoM8c8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/4mzDahANtmrrWNSEkJbofuIYz2x.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/feTPKgV229rUl7KLApPOlxMO12P.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:05:40.794+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":123,"tagline":"","homepage":"","overview":"Arum and Pica, who wanted to complete their internship at Lembayung hospital, had to face mysterious terror from a woman satan who was suspected of hanged herself in the bathroom. The situation became even more tense after they asked others for help to the point where they threatened their own lives and those closest to them."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Pica (Taskya Namya) dan Arum (Yasamin Jasem), mahasiswi keperawatan, menjalani masa PKL di Klinik Lembayung yang baru dibuka kembali setelah lama ditutup karena kasus bunuh diri. Suatu malam, pasien misterius yang menyeramkan, berambut panjang muncul di poli gigi, membuat Pica dan Arum sangat ketakutan. Sosok itu terus menghantui mereka hingga terbawa ke mimpi Arum. Peristiwa janggal mulai terjadi, diikuti dengan runutan kejadian tragis di Klinik Lembayung. Saat Arum kerasukan, Pica berusaha mengungkap misteri Klinik Lembayung sebelum sahabatnya menjadi korban berikutnya."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"لمبایونگ","runtime":0,"tagline":"","homepage":"","overview":"آروم و پیکا، که می‌خواستند کارآموزی خود را در بیمارستان لمبایونگ به پایان برسانند، مجبور می‌شوند با وحشت راز آلود زنی شیطانی روبرو شوند که گمان می‌رود خود را در حمام حلق‌آویز کرده است. وضعیت حتی پس از آنکه آن‌ها از دیگران درخواست کمک کردند، تنش‌آمیزتر شد، تا جایی که زندگی خود و نزدیکانشان را هم به خطر می‌اندازند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Arum y Pica, que querían completar sus prácticas en el hospital de Lembayung, tuvieron que enfrentarse al misterioso terror de una mujer satán, sospechosa de haberse ahorcado en el cuarto de baño. La situación se volvió aún más tensa después de que pidieran ayuda a otras personas, hasta el punto de amenazar sus propias vidas y las de sus allegados."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"โรงพยาบาท","runtime":0,"tagline":"","homepage":"","overview":"อารุม และ พิคา นักศึกษาฝึกงานที่โรงพยาบาลเล็มบายุง ต้องเผชิญกับความสยองขวัญลึกลับจากปีศาจในร่างของผู้หญิงที่เชื่อกันว่าได้เสียชีวิตจากการผูกคอตายในห้องน้ำ สถานการณ์ดังกล่าวยิ่งเลวร้ายมากขึ้นเมื่อพวกเธอเริ่มขอความช่วยเหลือจากคนใกล้ตัว ทำให้มันกลายเป็นภัยคุกคามต่อชีวิตของทั้งสองและคนใกล้ชิด"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"鬼診所","runtime":0,"tagline":"","homepage":"","overview":"琵卡和雅羅來到一間日惹郊區的牙科診所實習，有天一名神祕的長髮女子在深夜造訪，使她們被迫面對過往一樁上吊事件，過程中琵卡似乎遭到附身，診所的黑暗祕密也將隨之揭開…。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Lembayung: Oan Hồn Sản Phụ","runtime":0,"tagline":"","homepage":"","overview":"Arum và Pica, những người muốn hoàn thành kỳ thực tập tại bệnh viện Lembayung, đã phải đối mặt với nỗi khiếp sợ bí ẩn từ một người phụ nữ mà họ nghi ngờ đã treo cổ trong nhà tắm. Tình huống trở nên gay cấn hơn khi họ nhờ người khác giúp đỡ đến mức đe dọa cả tính mạng của chính mình và những người thân cận nhất."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Arum și Pica, care doreau să își finalizeze stagiul la spitalul Lembayung, au fost nevoiți să înfrunte teroarea misterioasă a unei femei demon, despre care se bănuiește că s-a spânzurat în baie. Situația a devenit și mai tensionată după ce au cerut ajutor altor persoane, ajungând să-și pună în pericol propriile vieți și pe cele ale celor apropiați lor."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Arum e Pica, que queriam completar seu estágio no hospital Lembayung, tiveram que enfrentar o terror misterioso de uma mulher satanás que era suspeita de ter se enforcado na casa de banho.  A situação ficou ainda mais tensa depois que eles pediram ajuda a outros a ponto de ameaçarem suas próprias vidas e as daqueles mais próximos a eles."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Улыбка. Зарождение зла","runtime":123,"tagline":"","homepage":"","overview":"Пика и Арюм — студентки медицинского колледжа, которые готовятся пройти стажировку в недавно открывшейся клинике Лембаюнг, долгое время находившейся на закрытии. Ходят слухи, что несколько лет назад здесь покончил с собой один из врачей. Однажды ночью в стоматологическую клинику приходит таинственный пациент с жуткой улыбкой, напугавший Пику и Арюм. Это событие становится лишь началом серии трагических смертей среди персонала, а сам загадочный пациент продолжает преследовать девушек. Когда Арюм начинает проявлять странные, пугающие симптомы одержимости, Пика решает разгадать тайну клиники Лембаюнг, прежде чем ее подруга станет следующей жертвой."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"렘바융","runtime":0,"tagline":"","homepage":"","overview":"​\"그들이 마주한 병원, 그곳에 숨겨진 공포의 실체\"​\r 간호학과 학생인 피카와 아룸은 인턴십을 위해 '렘바융' 병원에서 근무를 시작한다. 한때 폐쇄되었던 이 병원은 최근에야 다시 문을 열었지만, 과거 이곳에서 한 의사가 자살했다는 소문이 돌고 있다. 어느 날 밤, 섬뜩한 미소를 지닌 수수께끼의 환자가 치과 클리닉을 찾아오면서 피카와 아룸은 알 수 없는 공포에 휩싸이게 된다. 이후 병원 직원들의 연이은 비극적인 죽음과 계속해서 피카와 아룸을 괴롭히는 그 환자. 아룸이 점점 이상한 행동을 보이기 시작하자, 피카는 친구를 구하기 위해 '렘바융' 병원의 숨겨진 비밀을 파헤치게 되는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"猩红诊所","runtime":0,"tagline":"","homepage":"","overview":"　　琵卡和雅罗来到一间日惹郊区的牙科诊所实习，有天一名神秘的长发女子在深夜造访，使她们被迫面对过往一桩上吊事件，过程中琵卡似乎遭到附身，诊所的黑暗秘密也将随之揭开…。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"მეწამული","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"}],"reviews_tmdb":[],"recommendations":[{"id":1219685,"adult":false,"title":"An Ideal Father","video":false,"overview":"Michel, the jovial owner of the only café in a small Normandy town, sees his life turned upside down when his teenage daughter is murdered. The community has his back but soon rumor spreads and Michel is singled out. From the ideal father, he becomes the ideal culprit.","genre_ids":[18,10770],"media_type":"movie","popularity":0.536,"vote_count":121,"poster_path":"/4xJd3uwtL1vCuZgEfEc8JXI9Uyx.jpg","release_date":"2024-04-21","vote_average":6.3,"backdrop_path":"/e0qpg4etbAOysm5MD8QQNOSZXwo.jpg","original_title":"Un père idéal","original_language":"fr"},{"id":1222064,"adult":false,"title":"River of Blood","video":false,"overview":"Four kayakers take the wrong river into a jungle inhabited by a tribe of merciless cannibals.","genre_ids":[27,53],"media_type":"movie","popularity":2.0736,"vote_count":95,"poster_path":"/7lkm4eAvHy1uCs48GEwMxgwNdgd.jpg","release_date":"2024-12-12","vote_average":6.168,"backdrop_path":"/5o4iH2N4jX3HmNCBbC6rJqxtWj2.jpg","original_title":"River of Blood","original_language":"en"},{"id":1154762,"adult":false,"title":"His Three Daughters","video":false,"overview":"Emotions run high when three estranged sisters reunite in a cramped New York City apartment to watch over their ailing father during his final days.","genre_ids":[18,35],"media_type":"movie","popularity":1.2173,"vote_count":266,"poster_path":"/yTIHBPLQyzhgz1c2spak3btJxsg.jpg","release_date":"2024-09-05","vote_average":6.85,"backdrop_path":"/7QZCkr6hvQM0PDqsAOguUqOETNt.jpg","original_title":"His Three Daughters","original_language":"en"},{"id":1322522,"adult":false,"title":"Poison Sangga: The Homewrecker's Curse","video":false,"overview":"Soon after getting married, couple Maya and Andi begin to experience eerie disturbances from unseen malevolent forces.","genre_ids":[27,53,9648],"media_type":"movie","popularity":0.5174,"vote_count":10,"poster_path":"/ujsWad6uVjOifcQiUJ9kDzzjXIb.jpg","release_date":"2024-12-12","vote_average":6.3,"backdrop_path":"/9KJbq86NRU5nvVlqpziHdC7IcnE.jpg","original_title":"Racun Sangga: Santet Pemisah Rumah Tangga","original_language":"id"},{"id":402431,"adult":false,"title":"Wicked","video":false,"overview":"In the land of Oz, ostracized and misunderstood green-skinned Elphaba is forced to share a room with the popular aristocrat Glinda at Shiz University, and the two's unlikely friendship is tested as they begin to fulfill their respective destinies as Glinda the Good and the Wicked Witch of the West.","genre_ids":[18,10749,14],"media_type":"movie","popularity":16.6175,"vote_count":2876,"poster_path":"/xDGbZ0JJ3mYaGKy4Nzd9Kph6M9L.jpg","release_date":"2024-10-16","vote_average":6.918,"backdrop_path":"/fyZ6SDUS4o9jp2EHxfZa3qS9ean.jpg","original_title":"Wicked","original_language":"en"},{"id":945961,"adult":false,"title":"Alien: Romulus","video":false,"overview":"While scavenging the deep ends of a derelict space station, a group of young space colonizers come face to face with the most terrifying life form in the universe.","genre_ids":[27,878],"media_type":"movie","popularity":14.05,"vote_count":4307,"poster_path":"/2uSWRTtCG336nuBiG8jOTEUKSy8.jpg","release_date":"2024-08-13","vote_average":7.169,"backdrop_path":"/iYqSQaWDttQIQzsxg9xHyg0bttG.jpg","original_title":"Alien: Romulus","original_language":"en"},{"id":693134,"adult":false,"title":"Dune: Part Two","video":false,"overview":"Follow the mythic journey of Paul Atreides as he unites with Chani and the Fremen while on a path of revenge against the conspirators who destroyed his family. Facing a choice between the love of his life and the fate of the known universe, Paul endeavors to prevent a terrible future only he can foresee.","genre_ids":[878,12],"media_type":"movie","popularity":24.0699,"vote_count":7549,"poster_path":"/1pdfLvkbY9ohJlCjQH2CZjjYVvJ.jpg","release_date":"2024-02-27","vote_average":8.13,"backdrop_path":"/ylkdrn23p3gQcHx7ukIfuy2CkTE.jpg","original_title":"Dune: Part Two","original_language":"en"},{"id":1140817,"adult":false,"title":"As","video":false,"overview":"Three years after the death of her beloved child, Elouise, Mara still feels her presence when she sits on the butterfly bedding in front of the jar with her ashes in it. Mara arranges a twelfth birthday party for Elouise, further alienating her from her husband, Richter, and remaining daughter, Hannah. Although Mara eventually vacates Elouise's room at the insistence of her husband, she does find a way to stay close to Elouise. Before long, however, Hannah discovers her mother's secret.","genre_ids":[],"media_type":"movie","popularity":0.2105,"vote_count":185,"poster_path":null,"release_date":"2023-01-01","vote_average":7.054,"backdrop_path":null,"original_title":"As","original_language":"en"},{"id":975902,"adult":false,"title":"Boudica","video":false,"overview":"Inspired by events in A.D. 60, Boudica follows the eponymous Celtic warrior who rules the Iceni people alongside her husband Prasutagus. When he dies at the hands of Roman soldiers, Boudica’s kingdom is left without a male heir and the Romans seize her land and property.  Driven to the edge of madness and determined to avenge her husband’s death, Boudica rallies the various tribes from the region and wages an epic war against the mighty Roman empire.","genre_ids":[28,10752],"media_type":"movie","popularity":2.4009,"vote_count":175,"poster_path":"/g57hTF2TYytHMveoKDpUN8iFk1p.jpg","release_date":"2023-10-26","vote_average":5.9,"backdrop_path":"/zhaMys3Ej1KK32zb5qEOZCi06IH.jpg","original_title":"Boudica","original_language":"en"},{"id":977331,"adult":false,"title":"Cat and Dog","video":false,"overview":"While about to take off, Monica, the owner of a famous influencer cat named Diva, and Jack, an international thief whose dog Chichi swallowed a stolen ruby, dis- cover that their pets have gotten lost on the tarmac. The owners – and their pets – must team up to find their loved ones. But they don’t know that Brandt, a cop hot on their heels, will do anything to get his hands on the ruby!","genre_ids":[12,35],"media_type":"movie","popularity":0.8875,"vote_count":131,"poster_path":"/3SYqAvxQIddxY5Bd6sWV9Q9kMTw.jpg","release_date":"2024-02-14","vote_average":5.744,"backdrop_path":"/rUONctvx2KhEKSPz1ybzkwu0rP.jpg","original_title":"Chien et Chat","original_language":"fr"},{"id":533535,"adult":false,"title":"Deadpool & Wolverine","video":false,"overview":"A listless Wade Wilson toils away in civilian life with his days as the morally flexible mercenary, Deadpool, behind him. But when his homeworld faces an existential threat, Wade must reluctantly suit-up again with an even more reluctant Wolverine.","genre_ids":[28,35,878],"media_type":"movie","popularity":24.3599,"vote_count":8293,"poster_path":"/8cdWjvZQUExUUTzyp4t6EDMubfO.jpg","release_date":"2024-07-24","vote_average":7.558,"backdrop_path":"/ufpeVEM64uZHPpzzeiDNIAdaeOD.jpg","original_title":"Deadpool & Wolverine","original_language":"en"},{"id":889737,"adult":false,"title":"Joker: Folie à Deux","video":false,"overview":"While struggling with his dual identity, Arthur Fleck not only stumbles upon true love, but also finds the music that's always been inside him.","genre_ids":[18,80,53],"media_type":"movie","popularity":8.9037,"vote_count":2795,"poster_path":"/if8QiqCI7WAGImKcJCfzp6VTyKA.jpg","release_date":"2024-10-01","vote_average":5.397,"backdrop_path":"/AVWlQpVhpudyFsSh3OQIieHHYf.jpg","original_title":"Joker: Folie à Deux","original_language":"en"},{"id":1209450,"adult":false,"title":"National Family","video":false,"overview":"Don Poli, the patriarch of a family embedded in politics, faces the change of party in his state - after a hundred years in power - losing all his privileges. Humiliated and angry, he threatens to disinherit his family and leave to rebuild his life. This forces his children (Kippy, Ramses and Belén) to take extreme measures to ensure their future, causing everything that could go wrong to turn out worse.","genre_ids":[35,28],"media_type":"movie","popularity":0.3595,"vote_count":90,"poster_path":"/oSAzrJ0AjFZLUCcHT8YAnuD7egp.jpg","release_date":"2023-12-28","vote_average":6.7,"backdrop_path":"/2qaFnZxMkj5nKz1MWinaVNfg7T7.jpg","original_title":"Familia Nacional","original_language":"es"},{"id":912649,"adult":false,"title":"Venom: The Last Dance","video":false,"overview":"Eddie and Venom are on the run. Hunted by both of their worlds and with the net closing in, the duo are forced into a devastating decision that will bring the curtains down on Venom and Eddie's last dance.","genre_ids":[28,878,12],"media_type":"movie","popularity":17.6767,"vote_count":4023,"poster_path":"/1RaSkWakWBxxYOWRrqmwo2my5zg.jpg","release_date":"2024-10-22","vote_average":6.663,"backdrop_path":"/3V4kLQg0kSqPLctI5ziYWabAZYF.jpg","original_title":"Venom: The Last Dance","original_language":"en"},{"id":726139,"adult":false,"title":"Project Silence","video":false,"overview":"Due to sudden deteriorating weather conditions, visibility on the Airport Bridge is severely impaired, leaving people stranded and at risk of the bridge collapsing due to a series of chain collisions and explosions. Amidst the chaos, the canine subjects \"Echo\" from the military experiment \"Project Silence,\" who were being transported in secret, break free, and all human survivors become targets of relentless attacks.","genre_ids":[53,28,27,878,12],"media_type":"movie","popularity":4.3874,"vote_count":380,"poster_path":"/55jsexep1uh1ieMwyJMVapTETMM.jpg","release_date":"2024-07-11","vote_average":6.913,"backdrop_path":"/39CRS71VP0d9VOsJ5TVgD8IaQnT.jpg","original_title":"탈출: 프로젝트 사일런스","original_language":"ko"},{"id":1094403,"adult":false,"title":"Malum","video":false,"overview":"A rookie police officer willingly takes the last shift at a newly decommissioned police station in an attempt to uncover the mysterious connection between her father's death and a vicious cult.","genre_ids":[27],"media_type":"movie","popularity":3.1616,"vote_count":156,"poster_path":"/m1rcLLs0KmS8Cg60sLoMZC2OyDR.jpg","release_date":"2023-03-31","vote_average":5.51,"backdrop_path":"/jgGP3HxKUrYM7sPIFVH7L0k8Mmq.jpg","original_title":"Malum","original_language":"en"},{"id":653346,"adult":false,"title":"Kingdom of the Planet of the Apes","video":false,"overview":"Several generations following Caesar's reign, apes – now the dominant species – live harmoniously while humans have been reduced to living in the shadows. As a new tyrannical ape leader builds his empire, one young ape undertakes a harrowing journey that will cause him to question all he's known about the past and to make choices that will define a future for apes and humans alike.","genre_ids":[878,12,28],"media_type":"movie","popularity":9.4287,"vote_count":4102,"poster_path":"/gKkl37BQuKTanygYQG1pyYgLVgf.jpg","release_date":"2024-05-08","vote_average":7.054,"backdrop_path":"/iHYh4cdO8ylA3W0dUxTDVdyJ5G9.jpg","original_title":"Kingdom of the Planet of the Apes","original_language":"en"},{"id":918692,"adult":false,"title":"Granit","video":false,"overview":"Mozambique requests from Russia is being helped in the fight against militants of the \"Islamic State\" and a special group led by a commander with the call sign Granit is coming to the country.","genre_ids":[28,10752],"media_type":"movie","popularity":1.5382,"vote_count":45,"poster_path":"/zLJn4U2qlWIz