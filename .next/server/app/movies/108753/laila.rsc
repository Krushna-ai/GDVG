"display_priority":0}]},"VE":{"link":"https://www.themoviedb.org/movie/1403735/watch?locale=VE","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":2}]},"YE":{"link":"https://www.themoviedb.org/movie/1403735/watch?locale=YE","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1}]},"ZA":{"link":"https://www.themoviedb.org/movie/1403735/watch?locale=ZA","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1}]},"ZM":{"link":"https://www.themoviedb.org/movie/1403735/watch?locale=ZM","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1}]},"ZW":{"link":"https://www.themoviedb.org/movie/1403735/watch?locale=ZW","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":2}]}}},"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"IN","main_poster":"/l4gsNxFPGpzbq0D6QK1a8vO1lBz.jpg","images":{"logos":[],"posters":[{"width":800,"height":1200,"file_path":"/l4gsNxFPGpzbq0D6QK1a8vO1lBz.jpg","iso_639_1":"te","vote_average":3.334},{"width":500,"height":750,"file_path":"/y0aAQrmgx5bw6J5JHQpa2A1Nn8n.jpg","iso_639_1":"tt","vote_average":0.166},{"width":2000,"height":3000,"file_path":"/aFogllaRGlAhk1nqvVGFpZpl4qU.jpg","iso_639_1":"en","vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/vNUwK5P42m81uG57kKI1WxSZwIQ.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T02:48:39.683+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Laila","runtime":134,"tagline":"","homepage":"","overview":"Sonu Model, a renowned beautician from the old city, is forced to disguise himself as Laila, leading to a series of comedic, romantic, and action-packed events. Chaos ensues in this hilarious laugh riot"},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"莱拉","runtime":133,"tagline":"","homepage":"","overview":"Sonu (Vishwak Sen) 是一家美容院的老板，受到附近许多女性的羡慕。然而，他发现自己与当地流氓 Rustum (Abhimanyu Singh) 和 SI Shankar (Babloo Prithviraj) 不和。为了逃避他们的威胁，Sonu 以 Laila 的身份接受了新身份。这一转变如何展开以及它会导致什么后果构成了故事的其余部分。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"萊拉","runtime":133,"tagline":"","homepage":"","overview":"Sonu (Vishwak Sen) 是一家美容院的老闆，受到附近許多女性的羨慕。然而，他發現自己與當地流氓 Rustum (Abhimanyu Singh) 和 SI Shankar (Babloo Prithviraj) 不和。為了逃避他們的威脅，Sonu 以 Laila 的身份接受了新身份。這一轉變如何展開以及它會導致什麼後果構成了故事的其餘部分。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Laila","runtime":0,"tagline":"","homepage":"","overview":"Sonu Model, un celebru cosmetician din orașul vechi, este nevoit să se deghizeze în Laila, declanșând o succesiune de evenimente amuzante, romantice și pline de acțiune. Haosul care izbucnește transformă totul într-un adevărat festin de râs."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Лейла","runtime":0,"tagline":"","homepage":"","overview":"Сону Модел, знаменитый косметолог из старого города, вынужден притвориться Лайлой, что становится причиной череды забавных, романтических и динамичных происшествий. Всё оборачивается настоящим хаосом в этой уморительной комедии."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"Laila","runtime":165,"tagline":"","homepage":"","overview":"Sonu Model, um renomado cabeleireiro da cidade velha, é forçado a se disfarçar de Laila, o que leva a uma série de eventos cômicos, românticos e repletos de ação. O caos se instala nesta hilariante comédia."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"}],"reviews_tmdb":[],"recommendations":[{"id":317190,"adult":false,"title":"Doctor Who: The Next Doctor","video":false,"overview":"The Doctor arrives in Victorian London. It's Christmas, but snow isn't the only thing descending on the tranquil and jubilant civilization, as familiar silver giants from an alternate reality are amassing in numbers. The Cybermen are on the move again, and the only beings who can stop them are the Doctor and... another Doctor?","genre_ids":[878,10770,9648,12,14],"media_type":"movie","popularity":0.6642,"vote_count":227,"poster_path":"/kDqIMVtDx9UuexVJVNXUxUrHfJl.jpg","release_date":"2008-12-25","vote_average":7.383,"backdrop_path":"/lbjFL4zFzloqZPySgoIDuWgLzto.jpg","original_title":"Doctor Who: The Next Doctor","original_language":"en"},{"id":928980,"adult":false,"title":"Grade","video":false,"overview":"The film follows the daily experiences and dreams of the residents of a specific type of seclusion of freedom in which the convicts assume the maintenance of the space, the control of their own activities and their security. With a multifaceted approach, it proposes a reflection on the creative potential of incarcerated people, the documentary genre itself and its truth.","genre_ids":[99],"media_type":"movie","popularity":0.9708,"vote_count":1,"poster_path":"/kyBPx8zJ9LZd3LvU13D1WSO0a48.jpg","release_date":"2022-01-28","vote_average":4,"backdrop_path":null,"original_title":"Grade","original_language":"pt"},{"id":315505,"adult":false,"title":"Scooby-Doo's Greatest Mysteries","video":true,"overview":"SCOOBY-DOO fans have spoken! 4 of SCOOBY-DOO'S most popular mysteries - selected by the fans themselves - are now available in this fun DVD.  Watch as Scooby-Doo gets into a mixed-up mystery when he unexpectedly meets the seaweed-covered ghost of Captain Cutler in \"A Clue for Scooby-Doo!\" Next, see the seafaring sleuths collide with a mystery ship and try to uncover clues to a vanished crew in \"Hassle in the Castle!\" Then, follow Scooby-Doo and the Mystery, Inc. gang as they outwit a bank robber in \"Jeepers, It's the Creeper!\" And finally, see them take to the stage to crack some crazy capers in \"The Backstage Rage.\"","genre_ids":[35,16,9648],"media_type":"movie","popularity":0.2022,"vote_count":35,"poster_path":"/rJ6Wr1KjcDJf5EviORODkjNM5Xt.jpg","release_date":"1999-05-23","vote_average":9.1,"backdrop_path":null,"original_title":"Scooby-Doo's Greatest Mysteries","original_language":"en"},{"id":1383823,"adult":false,"title":"Taylor Swift, la première puissance américaine","video":false,"overview":"","genre_ids":[99,10402],"media_type":"movie","popularity":0.0814,"vote_count":1,"poster_path":"/4bqWuWi5k6Z6LsVRWVyJ7dUn7t6.jpg","release_date":"2024-11-06","vote_average":8,"backdrop_path":"/xdDVkOdrxcjWqOCyHiktoUQ0zFj.jpg","original_title":"Taylor Swift, la première puissance américaine","original_language":"fr"},{"id":579838,"adult":false,"title":"The FGM Detectives","video":false,"overview":"The horrific crime of female genital mutilation is banned in the UK but it is estimated that nearly 20,000 young women a year are still at risk of the procedure. And despite being banned more than 30 years ago, there have been no successful convictions. This harrowing documentary, from reporter Cathy Newman, follows the work of DCI Leanne Pook and her team, who are tackling the crime in Bristol.","genre_ids":[99,80],"media_type":"movie","popularity":0.0692,"vote_count":16,"poster_path":"/wCfwXb0q3mL2ilIyOSnEoEcThkN.jpg","release_date":"2018-02-27","vote_average":6.5,"backdrop_path":null,"original_title":"The FGM Detectives","original_language":"en"},{"id":767865,"adult":false,"title":"Hjärtrud - the Woman of Your Life","video":false,"overview":"A twisted story about love.","genre_ids":[],"media_type":"movie","popularity":0.0629,"vote_count":15,"poster_path":"/lntOw6JfCj7Lmba1Pyp3M7a38vS.jpg","release_date":"2008-01-27","vote_average":5.633,"backdrop_path":null,"original_title":"Hjärtrud - kvinnan i ditt liv","original_language":"sv"},{"id":860869,"adult":false,"title":"It Came from Below","video":false,"overview":"Jessie and her friends go deep underground to find out what happened to her father who claimed a monster lurks in the caves and has killed his friends. Wanting to uncover the truth, they will soon be hunted by a deadly creature from another world.","genre_ids":[27,53],"media_type":"movie","popularity":0.2538,"vote_count":14,"poster_path":"/atcScspT9Hpyic05bchtHyevQR.jpg","release_date":"2021-08-23","vote_average":5,"backdrop_path":"/xyWtcPWG3zxKE0B9B98YejrdZLA.jpg","original_title":"It Came from Below","original_language":"en"},{"id":1103508,"adult":false,"title":"Andrew Bennett","video":false,"overview":"Andrew Bennett, a hunter of cursed books and banned grimoires, arrives in town after a series of violent murders that police cant solve. With Inspector Hobbs, Bennett pursues the brain that strives to achieve a magical ritual. Its dark outcome could be a disaster.","genre_ids":[14],"media_type":"movie","popularity":0.0561,"vote_count":3,"poster_path":"/qs63UfbeTS5K2YLiu0pJbNsE9eY.jpg","release_date":"2018-12-01","vote_average":5.2,"backdrop_path":"/fthxAWLV8wbPbSmvFPR8dtEhf9A.jpg","original_title":"Andrew Bennett","original_language":"en"},{"id":659756,"adult":false,"title":"Service","video":false,"overview":"All Ted wants to do is pay for his shopping, but the shoddy self-service and eerily elusive shop workers have other, far more sinister, ideas. A twisted horror-comedy about just how dark a customer service nightmare can get.","genre_ids":[27,35],"media_type":"movie","popularity":0.5753,"vote_count":1,"poster_path":"/9DREzs2dcZXvXg28NHtZFhyxXbw.jpg","release_date":"2019-06-27","vote_average":6,"backdrop_path":null,"original_title":"Service","original_language":"en"},{"id":1165689,"adult":false,"title":"Ado 2nd LIVE: Campanella","video":true,"overview":"This is Ado's first live video work, featuring all the songs from her legendary Saitama Super Arena concert held on August 11, 2022!  Included are 24 songs in total, including her smash hits \"Usseewa,\" \"Odori,\" and \"Shinjidai,\" as well as her favorite Vocaloid songs \"Darling Dance\" and \"Zaneri\".","genre_ids":[10402],"media_type":"movie","popularity":0.377,"vote_count":2,"poster_path":"/44wtvyMtE0t8fEv5JMN7ANQAl6f.jpg","release_date":"2023-06-21","vote_average":9.5,"backdrop_path":"/7AXeff0zyja8ZpnKsVOBfPhR3rD.jpg","original_title":"Ado 2nd LIVE: カムパネルラ","original_language":"ja"},{"id":171688,"adult":false,"title":"Aftermath","video":false,"overview":"A dark comedy about one man's overreaction! Roma's (Anthony Michael Hall) perfect life unravels when his foreman goes missing and he chooses to fire the wrong guy.","genre_ids":[53,80],"media_type":"movie","popularity":0.3268,"vote_count":12,"poster_path":"/s7WInfX0FzBcTH8EUMMJSnX1EZd.jpg","release_date":"2013-11-01","vote_average":4.8,"backdrop_path":null,"original_title":"Aftermath","original_language":"en"},{"id":875300,"adult":false,"title":"Dreamover","video":false,"overview":"When life turns unbearably miserable, a lonely old man takes part in a medical experiment, reviving a long-forgotten story of his love.","genre_ids":[18,10749,878],"media_type":"movie","popularity":0.0698,"vote_count":1,"poster_path":"/mlDe6qgAhTaPYZDu3xG0a7GaVrm.jpg","release_date":"2021-06-16","vote_average":6,"backdrop_path":"/sKutruf2yUOoGGnDxE36InZs9OU.jpg","original_title":"Приснись мне","original_language":"ru"},{"id":516001,"adult":false,"title":"3 peonies","video":false,"overview":"A brief, poetic 16mm film on a simple sculptural action. What becomes apparent is the humor possible in material interactions and the tender and sometimes melodramatic symbolism of cut flowers. What begins as a reverence for natural beauty ends up pointing towards the abstract expressionism and color field work of high modernism which, in many cases eschewed the banality of such 'natural' beauty. The collaged soundtrack suggests weightier concerns, gently insistent behind the flatness of the utilitarian sounds of ripping tape.","genre_ids":[],"media_type":"movie","popularity":0.0256,"vote_count":1,"poster_path":"/d0cKtrzFmq71QAomJU27yGZYNAr.jpg","release_date":"2018-11-07","vote_average":10,"backdrop_path":null,"original_title":"3 peonies","original_language":"en"},{"id":695839,"adult":false,"title":"Panda! Go Panda!","video":false,"overview":"Cheerful Mimiko has a wonderfully strange family—a Panda for her Papa; and his son Panny, calls her Mom! When Panny follows Mimiko to school, he must pretend to be a teddy bear so Mimiko won't get into trouble. Despite his efforts to behave, Panny causes trouble in school and now the school is after Panny! Then, Panny makes a new friend, Tiny, a baby tiger who's wandered off from the circus.","genre_ids":[35,14,16],"media_type":"movie","popularity":0.7658,"vote_count":3,"poster_path":"/ja31iFPODZSXwMnEEG4dpZC9S37.jpg","release_date":"1972-12-17","vote_average":7.7,"backdrop_path":"/zmYkGaak1X76lkP4Q9zobaOa70J.jpg","original_title":"パンダコパンダ","original_language":"ja"},{"id":294287,"adult":false,"title":"Devil's Island","video":false,"overview":"After Italian capitulation in WW2, German forces are rushing to take control of the Dalmatian coast, forcing thousands of people to take refuge. One partisan boat, filled with refugees, tries to reach a safe area, but because of a storm it must stop near a small island. While the crew tries to repair it, a German gunboat comes from nearby.","genre_ids":[28,10752],"media_type":"movie","popularity":1.5313,"vote_count":4,"poster_path":"/wgLYQqFt1IzhILDur67TnPRQlCA.jpg","release_date":"1979-01-01","vote_average":5.2,"backdrop_path":null,"original_title":"Pakleni otok","original_language":"sh"},{"id":269380,"adult":false,"t