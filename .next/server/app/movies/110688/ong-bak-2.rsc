vdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"TH","main_poster":"/cGwavRLlZ3M3eQcNReTIDM4fL4n.jpg","images":{"logos":[{"width":960,"height":249,"file_path":"/6Xn7ve0MD6eYGsJMQhPBZBNsFdi.png","iso_639_1":"pt","vote_average":3.334},{"width":522,"height":300,"file_path":"/9Av1EcnMJtIl4JAg19x37rL20uY.png","iso_639_1":"en","vote_average":0},{"width":933,"height":535,"file_path":"/5FKiTEtHtUzHYtXvYRNWyIp8dEC.png","iso_639_1":"th","vote_average":0},{"width":941,"height":540,"file_path":"/xgSnL2SmabZONhNCQN4YpNFLofT.png","iso_639_1":"en","vote_average":0},{"width":785,"height":201,"file_path":"/9TizI8jRE5fSAhfZLEzR8f49dbY.png","iso_639_1":"es","vote_average":0}],"posters":[{"width":1000,"height":1500,"file_path":"/cGwavRLlZ3M3eQcNReTIDM4fL4n.jpg","iso_639_1":"ru","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/oNGz9bpkkbOMA8KugB1oRSwMr38.jpg","iso_639_1":"th","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/5Iue46Q6d1EGMPl7XraeRAMdMoY.jpg","iso_639_1":"en","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/7CngJNoDfMJtTMzDKeLUb6dHsnG.jpg","iso_639_1":"th","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/tcRn28ziclxlYsN4MS6iGrLySRq.jpg","iso_639_1":"fr","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/ftGTYdALL91q7kJUsQaWDKR99v3.jpg","iso_639_1":"pt","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/l6bfgohUpmhQtlhL0qREEuTLxjA.jpg","iso_639_1":"en","vote_average":3.334},{"width":1400,"height":2100,"file_path":"/sTgedLJZjCuiyz5gX6uK0V3PNY6.jpg","iso_639_1":"hu","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/sGyB8kVPQsofyQV1T0jE2d6k4q4.jpg","iso_639_1":"en","vote_average":2.278},{"width":789,"height":1080,"file_path":"/2yb5KUuojISi0iYrDX5VxExJILM.jpg","iso_639_1":"en","vote_average":1.75},{"width":960,"height":1440,"file_path":"/ohlebuI95t8lLc6ukIN06L1vZ89.jpg","iso_639_1":"en","vote_average":1.75},{"width":1000,"height":1500,"file_path":"/dAOREYQcl0qWwpN2SPp4yDUk1VG.jpg","iso_639_1":"cs","vote_average":0.166},{"width":1000,"height":1500,"file_path":"/lqNBRQIpdDcjKKqa5HMoRjsOWCm.jpg","iso_639_1":"de","vote_average":0.166},{"width":1080,"height":1920,"file_path":"/kHQaopE5c781P86GfkMvDifNXME.jpg","iso_639_1":"th","vote_average":0.166},{"width":744,"height":1075,"file_path":"/8041eMViVCzSLrvPx28mBlqVLi8.jpg","iso_639_1":"pt","vote_average":0.166}],"backdrops":[{"width":3840,"height":2160,"file_path":"/3ZH69oLWaAmnR0WNGnTQkituwSF.jpg","iso_639_1":null,"vote_average":3.334},{"width":1334,"height":750,"file_path":"/AcXAzpJDq0wtj2seW1EBUgRSy0v.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/7ePgU7UIblwVVhj0eM0GXW6O04l.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/904qZsabDNXo6fJCFNCEKKgZGoF.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/pT7Lj4ZjNFQaiaFQC3ICM9GAcrx.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/ngNIonUKP1F2EtdQlyfUNxvMpCd.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/o3hFHhZtxV6vA1pF7w7DP4RAXlE.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/9XmTERImFxETLDycgMUptKaGqXu.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/v0ZMUHC0IHuwWd7DFC59u5qVqel.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/sKd4Jx3iQfU5IjNgxEN1CgjBuX8.jpg","iso_639_1":"en","vote_average":0},{"width":1280,"height":720,"file_path":"/6cUxdJOW3AGl3RxeUedr8Yfgbur.jpg","iso_639_1":"th","vote_average":0},{"width":2304,"height":1296,"file_path":"/2cqDDRie1EPTduk5b2iLlpwNQNZ.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-02-21T14:44:37.318+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Ong Bak 2","runtime":98,"tagline":"Warrior. Conqueror. Legend.","homepage":"http://www.ongbak2themovie.com/","overview":"Tien, the son of Lord Sihadecho — a murdered nobleman — is taken under the wing of Chernang, a renowned warrior and leader of the Pha Beek Krut."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Ong Bak 2","runtime":94,"tagline":"Real Fight is back!","homepage":"http://www.ongbak2themovie.com/","overview":"Der machtgierige Lord Rachasana entfacht einen blutigen Kampf, um Herrscher über das gesamte Königreich zu werden. Seine furchterregenden Krieger töten schließlich auch General Sidhadeco und dessen Frau. Ihr Sohn Tien muss den brutalen Mord an seinen Eltern hautnah miterleben und flüchtet in den Dschungel. Als ihn unbarmherzige Sklavenhändler entdecken, foltern und einer tödlichen Bestie opfern wollen, wird er von dem weisen Anführer Chernang befreit, der ihn fortan aufzieht. Unter dessen schützender Obhut lebend vergehen die Jahre und Tien erlernt durch hartes Training neben den Fertigkeiten der Kampfkunst auch Khon, die Kunst des siamesischen Maskentanzes. Dadurch revolutioniert er seine Technik und ist bereit für einen gnadenlosen Rachefeldzug gegen die Mörder seiner Familie."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Ong-Bak 2 : La naissance du dragon","runtime":88,"tagline":"Guerrier. Conquérant. Légende.","homepage":"","overview":"Thaïlande, XVème siècle. Prisonnier de marchands d'esclaves qui comptent se débarrasser de lui en le livrant aux crocodiles, le jeune Tien est sauvé par le mystérieux Chernang, commandant des bandits de Garuda. Sous son aile, l'enfant va bientôt apprendre à maîtriser une multitude d'arts martiaux, les techniques guerrières et le maniement de nombreuses armes blanches. Désormais adulte, Tien passe avec brio les épreuves faisant de lui un combattant accompli, et devient l'un des membres les plus respectés des Garuda. Mais le jeune homme est animé depuis son enfance par un sombre désir de vengeance que rien ne pourra arrêter. Sa cible : le terrible seigneur Rajasena, responsable de ses malheurs passés, et qu'il ne pourra atteindre qu'une fois ses redoutables lieutenants vaincus..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Ong-Bak 2 - La nascita del dragone","runtime":98,"tagline":"","homepage":"","overview":"XV secolo, siamo in Thailandia, dove Lord Sihadecho e sua moglie sono brutalmente assassinati nel corso di un ammutinamento. Fortunatamente il figlio Tien riesce a fuggire ma viene rapito da dei balordi che vendono schiavi. Gettato in una fossa e costretto a combattere contro i coccodrilli, il ragazzo viene salvato dall'intervento di Chernang, il capo dei banditi della Scogliera dell'Ala di Garuda che lo prende sotto la sua protezione. Dal valoroso guerriero Tien impara i segreti delle arti marziali, diventando un combattente insuperabile e quando diventa abbastanza grande, decide di andare alla ricerca degli assassini dei suoi genitori..."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Онг Бак 2: Непревзойденный","runtime":0,"tagline":"","homepage":"","overview":"В 1974 году по Буддийскому календарю и в 1421 году от рождества христова влияние королевского двора Аюттаия, времен правления короля Рама II, который сам был родом из этих мест стало более могущественным, чем Сукхотаи. И оно росло с каждым днем, расширяя свои владения на восток. Армия Аюттаия покорила Город Ангелов за 7 месяцев. Год и 3 месяца спустя городской глава Ратчасена, который долгое время вынашивал планы захвата трона начал уничтожать неугодных ему военноначальников. Одним из таких и стал генерал Сингхадачо, сын которого Тиан чудом остался жив и попал в деревню повстанцев Пха Пик Крут, где командир Чер Нан воспитал его, как родного сына. Прошли годы. Но Тиан, который возмужал и стал прекрасным бойцом так и не обрел покоя, омрачая каждый прожитый день черными мыслями о мести жестокому тирану Ратчасене. И день настал…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Ong Bak 2 - A Lenda","runtime":97,"tagline":"Guerreiro. Conquistador. Lenda.","homepage":"","overview":"Um jovem, no período Ayutthaya, cresce entre os aldeões que preservam o legado da tradicional dança mascarada Khon. Ele se torna um paria quando considera que seu grupo não segue as tradições de seus antepassados. Mas, seguindo o conselho de um misterioso guru, ele começa a desenvolver um novo estilo de luta que mistura a força das artes marciais com a elegância da dança Khon."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Ong Bak 2","runtime":98,"tagline":"","homepage":"","overview":"Kral Naresuan hükümdarlığı sırasında, Tien küçük yaşta ailesi öldürülmüş bir çocuktur. Krallık sınırları içerisinde sadece asillerin kullandığı bir dans türü olan Khon adı verilen bir dansı öğrenen Tien, ilerde bunu kullanacaktır. Hırsızlar tarafından büyütülen ve çalmayı öğrenen Tien, kısa zamanda aynı hırsızlar sayesinde savaşmayı da öğrenerek krallık şövalyelerinden biri olur. Şimdi sıra ailesini katledenlere gelmiştir, kendisini yetiştirenlerin yardımıyla katillerin peşine takılır. Tony Jaa’nın sürükleyici aksiyon sahneleriyle Ong Bak 2 nefeslerinizi kesecek, sakın kaçırmayın."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Ong Bak 2: La leyenda del Rey Elefante","runtime":110,"tagline":"Guerrero. Conquistador. Leyenda.","homepage":"","overview":"Tien es un niño que huye para salvar su vida. No entiende por qué, pero toda su familia ha sido asesinada y no tiene dónde esconderse. Capturado por comerciantes de esclavos, su coraje y su espíritu de luchador le salvarán de una muerte segura. Tien es rescatado por una cuadrilla de bandoleros que lo acogerán y lo instruirán en las artes marciales, convirtiéndose en un gran guerrero. Ya adulto, Tien (Tony Jaa) quiere encontrar respuesta a los misterios de su infancia y, sobre todo, quiere saciar su sed de venganza por la cruel muerte de sus padres... Continuación de la aclamada película de artes marciales \"Ong Bak\". En esta ocasión el protagonista, Tony Jaa, también se encargará de la dirección."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Ong Bak 2","runtime":98,"tagline":"","homepage":"","overview":"En föräldralös pojke undkommer sin död och räddas av en grupp krigare. Han växer upp i en by där han får kunskaper och lärdom av uråldrig stridskonst. Genom att hjälpa folket och hitta sina föräldrars mördare beger han sig iväg. Men sanningen om hans föräldrars död ligger närmare honom än vad han tror..."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Ong Bak 2 - A Sárkány Bosszúja","runtime":0,"tagline":"","homepage":"","overview":"Siha Decho nagyurat brutálisan meggyilkolják. Fia, az ifjú Tien rabszolgasorba kerül. A gonosz kereskedők hatalmaskodásaival dacoló ifjút végül halálra ítélik. Pillanatokkal halála előtt azonban egy titkos ellenálló csoport vezetője, Cher Nung meglátja a hihetetlen lelki és szellemi képességeket a fiúban és megmenti őt. Ettől kezdve Tien élete a bosszú jegyében telik. Mestere és bajtársai megtanítják őt az összes létező harci stílusra, Tien pedig kiváló tanulónak bizonyul. Közeledik az idő, mikor végre útra kelhet és szembeszállhat a gonosz rabszolgakereskedőkkel, akik meggyilkolták apját. A fékezhetetlen lelkű harcos azonban nem tudja, hogy Rajasena nagyúr - apja gyilkosa - egy egész hadsereget tart irányítása alatt."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":110,"tagline":"การกลับมาพร้อมปรากฏการณ์การต่อสู้ที่ไม่มีใครเคยสัมผัส","homepage":"","overview":"เทียน เด็กหนุ่มที่หวังเติบใหญ่เป็นนักรบผู้แกร่งกล้าเฉกเช่นบิดา ออกญาสีหเดโช นายทหารผู้ซื่อสัตย์ซึ่งจงรักภักดีต่อเหนือหัวผู้ซึ่งยอมได้ แม้กระทั่งสละชีวิตตนเอง เพื่อปกป้องผืนแผ่นดินจากเหล่าผู้ฉ้อฉล และคนทรยศแต่จากคำทำนายที่ว่าเมื่อใดที่เทียนซึ่งถือกำเนิดในฤกษ์พระกาฬเติบใหญ่ภายใต้วังวนแห่งคมดาบ และกลิ่นคาวเลือด เมื่อนั้นผู้คนจำนวนมากจักต้องล้มตายกันอย่างพร้อมเพรียง ทำให้ออกญาสีหเดโชตัดสินใจส่งเทียนไปให้ ครูบัว เพื่อนสนิทซึ่งต่างเป็นลูกศิษย์ของพระครูปั้นมาด้วยกันช่วยบ่มเพาะสมาธิ เรียนรู้การฝึกจิตให้นิ่ง และศึกษาในด้านวิชาโขนนาฏศิลป์ เพื่อหวังว่าสิ่งเหล่านี้จะช่วยจรรโลงจิตใจให้เกิดแต่สิ่งที่ดีงามขึ้น โดยมี พิม เด็กสาวที่ครูบัวเก็บมาเลี้ยงคอยให้ความช่วยเหลือ และมี ไอ้เหม็น ชายบ้าเสียสติ แต่หลงใหลในนาฏศิลป์ เป็นเพื่อนเล่น"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Ong-Bak 2: Pomsta","runtime":0,"tagline":"","homepage":"","overview":"Thajsko, 15. storočie, kráľovstvo Ayutthaya. K moci sa cez mŕtvoly dostáva jeden z generálov a tak sa vysoko postavený aristokrat, ktorý sa snaží generála zastaviť, rozhodne poslať svojho syna Tinga preč z kráľovstva do bezpečia. Ale aj tam ho prisluhovači generála nájdu a Tinga pri úteku zajmú otrokári. Vďaka svojej odvahe a odhodlanosti k boju zapôsobí na skupinu bojovníkov, ktorí prišli otrokára odstrániť a tí ho vezmú medzi seba. Ting začína trénovať bojové umenia a čoskoro sa púšťa na cestu pomsty, ktorá bude krvavá a plná mŕtvol..."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"拳霸2","runtime":0,"tagline":"","homepage":"","overview":"　　距今五、六百年前的泰国，时局动荡，阴阳逆反。邪恶阴险的军官Rajasena发动叛乱，夺取政权，为此展开大规模的血腥屠杀。少年泰恩出身于一个正直的武将家庭，他的父母双亲皆被叛军杀害。泰恩侥幸逃脱，然而才出龙潭，又入虎穴，他被迫与凶猛的鳄鱼同处一池。泰恩面对鳄鱼时的果敢引起夫毕克匪帮的头目车南的注意，车南将少年留在部落里，延请各路流派的好手教习泰恩格斗技巧。经过多年的磨练，泰恩（托尼·贾 Tony Jaa 饰）终于成长为身怀绝技的高手，并接任车南晋升为匪帮的新任首领。  　　虽然数年过去，但他始终没有忘记Rajasena加诸在其家族身上的厄运，他开始走上一条充满血腥和艰险的复仇之路……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Ong Bak 2, La llegenda del Rei Elefant","runtime":0,"tagline":"","homepage":"","overview":"Tien és un nen que fuig per salvar la seva vida. No entén per què, però tota la seva família ha estat assassinada i no té on amagar-se. Capturat per comerciants d'esclaus, el seu coratge i el seu esperit de lluitador el salvaran d'una mort segura. Tien és rescatat per una quadrilla de bandolers que ho acolliran i l'instruiran en les arts marcials, convertint-se en un gran guerrer. Ja adult, Tien (Tony Jaa) vol trobar resposta als misteris de la seva infància i, sobretot, vol sadollar la seves ganes de venjança per la cruel mort dels seus pares... Continuació de l'aclamada pel·lícula d'arts marciales \"Ong Bak\". En aquesta ocasió el protagonista, Tony Jaa, també s'encarregarà de la direcció."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"אונג באק 2","runtime":0,"tagline":"","homepage":"","overview":"טיין יוצא למצוא את האנשים שרצחו בברוטאליות את הוריו בילדותו. טיאנג הילד מאומץ על ידי פיראטים שמעבירים אותו כמה מבחנים לקראת הפיכתו ללוחם-קוסם."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Ong Bak 2: Pomsta","runtime":0,"tagline":"","homepage":"","overview":"Thajsko, 15. století, království Ayutthaya. K moci se přes mrtvoly dostává jeden z generálů, a tak se vysoce postavený aristokrat, který se snaží generála zastavit, rozhodne poslat sveho syna Tinga do bezpečí pryč z království. Ale i tam ho přisluhovači generála najdou a Tinga při útěku zajmou otrokáři. Díky své odvaze a odhodlanosti k boji zapůsobí na skupinu bojovníku, kteří přišli otrokáře odstranit a ti ho vezmou mezi sebe. Ting začíná trénovat bojová umění a brzy se pouští na cestu pomsty, která bude krvavá a plná mrtvol..."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Ong Bak 2","runtime":0,"tagline":"","homepage":"","overview":"Το 1974, όταν ο Tien (Tony Jaa) ήταν ακόμα μικρό παιδί έγινε μάρτυρας της ανελέητης σφαγής της οικογενείας του και των στρατιωτών από μισθωμένους δολοφόνους του λόρδου Rajasena, ο οποίος ήθελε να πάρει τον έλεγχο της χώρας στα χέρια του. Μόνο ο μικρός Τιεν σώθηκε αφού κατάφερε να δραπετεύσει από τα χέρια τους και υπό την προστασία του Chernang, αρχηγoύ των \"Pha Beek Khrut\" (Garuda Wing Cliff), μιας ομάδας «στρατιωτών» που πολεμούν τους δουλεμπόρους, θα μετατραπεί μετά από χρόνια εκπαίδευσης σε μια πολεμική μηχανή , έχοντας πάντα χαραγμένο μέσα του το μίσος και την επιθυμία για εκδίκηση. Χρησιμοποιώντας σαν όπλα κάθε μέρος του σώματός του δε θα δείξει κανένα έλεος σε όποιον προσπαθήσει να τον σταματήσει."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Ong-Bak 2: O Guerreiro Sagrado Voltou","runtime":98,"tagline":"Guerreiro. Conquistador. Lenda.","homepage":"","overview":"Um jovem, no período Ayutthaya, cresce entre os aldeões que preservam o legado da tradicional dança mascarada Khon.  Ele se torna um paria quando considera que seu grupo não segue as tradições de seus antepassados.  Mas, seguindo o conselho de um misterioso guru, ele começa a desenvolver um novo estilo de luta que mistura a força das artes marciais com a elegância da dança Khon."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"옹박: 더 레전드","runtime":0,"tagline":"","homepage":"","overview":"1400년, 미지의 땅 태국. 권력에 의해 온 가족이 처참히 살해당하는 모습을 지켜본 ‘티엔’. 복수를 다짐하던 그는 반군의 지도자 ‘처낭’의 눈에 띄게 되고, 그로부터 세계 각지의 무술을 전수받는다. 마침내 절대 무공의 소유자가 된 ‘티엔’은 복수의 길을 떠나지만, 과거에 대한 새로운 사실을 알게 되면서 무수한 암살자들과 마주하게 되는데…실전 살상 고대 무에타이의 부활!! 이제, 그가 펼칠 액션 신화의 문이 열린다!"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Ong Bak 2: The Beginning","runtime":98,"tagline":"","homepage":"","overview":"Teean is de zoon van één van de vier politieke leiders. Vanwege onrustigheid wordt hij door zijn vader en moeder achtergelaten bij een traditionele dansschool, om zo zijn veiligheid zeker te stellen. Op een dag wordt deze dansschool aangevallen en ziet Teean hoe zijn vader en moeder vermoord worden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Онг Бак 2","runtime":0,"tagline":"","homepage":"","overview":""},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Tiang (Tony Jaa) jako młody chłopiec dostaje się do niewoli. Na targu niewolników zostaje poddany próbie: by przeżyć musi pokonać krokodyla. Dzięki pomocy piratów udaje mu się to i zostaje adoptowany. Wychowywany w surowych warunkach doskonali swój talent w sztukach walki. W międzyczasie zostaje drugim dowódcą piratów. Jednak jego prawdziwym celem jest zemsta za śmierć rodziców, oraz odnalezienie przyjaciółki z dzieciństwa.  [opis dystrybutora dvd]"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Ong Bak 2","runtime":0,"tagline":"","homepage":"","overview":"Tien es un niño que huye para salvar su vida. No entiende por qué, pero toda su familia ha sido asesinada y no tiene dónde esconderse. Capturado por comerciantes de esclavos, su coraje y su espíritu de luchador le salvarán de una muerte segura. Tien es rescatado por una cuadrilla de bandoleros que lo acogerán y lo instruirán en las artes marciales, convirtiéndose en un gran guerrero. Ya adulto, Tien (Tony Jaa) quiere encontrar respuesta a los misterios de su infancia y, sobre todo, quiere saciar su sed de venganza por la cruel muerte de sus padres... Continuación de la aclamada película de artes marciales \"Ong Bak\". En esta ocasión el protagonista, Tony Jaa, también se encargará de la dirección."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Ong Bak: Tajų karys 2","runtime":0,"tagline":"","homepage":"","overview":"Pradedančiojo režisieriaus bei veiksmo filmų aktoriaus Tony Jaa trileris \"Ong bak 2\" – dar viena duoklė garbingam kovos menui. Turime pripažinti, kad juostos scenarijus nėra originalus, tačiau kai kurios kovos scenos nėra visiškai eilinės. Juosta \"Ong-Bak: Muay Thai karys\" (Ong-bak) pasirodė dar 2003 metais. Jos herojus, kurį suvaidino Tony Jaa, iškeliavo į pavogtos Budos statulėles paieškas. Antroje dalyje aktorius nusprendė stoti ir prie režisieriaus vairo."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"拳霸2","runtime":0,"tagline":"","homepage":"","overview":"距今五、六百年前的泰國，時局動盪，陰陽逆反。邪惡陰險的軍官Rajasena發動叛亂，奪取政權，為此展開大規模的血腥屠殺。少年泰恩出身於一個正直的武將家庭，他的父母雙親皆被叛軍殺害。泰恩僥倖逃脫，然而才出龍潭，又入虎穴，他被迫與兇猛的鱷魚同處一池。泰恩面對鱷魚時的果敢引起夫畢克匪幫的頭目車南的注意，車南將少年留在部落裡，延請各路流派的好手教習泰恩格鬥技巧。經過多年的磨練，泰恩（托尼·賈 Tony Jaa 飾）終於成長為身懷絕技的高手，並接任車南晉陞為匪幫的新任首領。\r 　　雖然數年過去，但他始終沒有忘記Rajasena加諸在其家族身上的厄運，他開始走上一條充滿血腥和艱險的復仇之路"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Legenda Regelui Elefant 2","runtime":98,"tagline":"Războinic. Cuceritor. Legendă.","homepage":"","overview":"Un băiat, aparținând casei regale, reușește să scape din atentatul asupra familiei sale. Însă este găsit și capturat. Deoarece marea plăcere a mercenarilor asupritori este tortura, eroul reușește să scape cu greu din sfârșitul tragic care i s-a pregătit, ajutat de o grupare de luptători pirați. Aceștia îl vor pregăti de luptă și viață, conform principiilor lor."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Truy Tìm Tượng Phật 2","runtime":0,"tagline":"","homepage":"","overview":"Ong bak 2 không phải là tập tiếp theo của bộ phim gốc năm 2003. Câu chuyện đưa ta về thế kỷ 15 tại Thái Lan với nhân vật chính là Tien. Mang trong mình dòng máu quí tộc, nên ngay từ nhỏ Tien đã không được cha cho luyện tập võ thuật. Thay vào đó cậu được đưa tới một lớp dậy múa Khon truyền thống.Không may cả gia đình cậu bị kẻ thù giết hại. Sau khi đau đớn chứng kiến cái chết của cả cha lẫn mẹ, Tien bị truy sát gắt gao bởi một nhóm người hành tung bí ẩn. Lưu lạc khắp nơi, thậm chí còn bị bắt làm nô lệ, cậu được Chernung thủ lĩnh của băng cướp Garuda Wing Cliff khét tiếng cưu mang."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"拳霸 2","runtime":0,"tagline":"","homepage":"","overview":"距今五、六百年前的泰國，時局動盪，陰陽逆反。邪惡陰險的軍官 Rajasena 發動叛亂，奪取政權，為此展開大規模的血腥屠殺。少年泰恩出身於一個正直的武將家庭，他的父母雙親皆被叛軍殺害。泰恩僥倖逃脱，然而才出龍潭，又入虎穴，他被迫與兇猛的鱷魚同處一池。泰恩面對鱷魚時的果敢引起夫畢克匪幫的頭目車南的注意，車南將少年留在部落裏，延請各路流派的好手教習泰恩格鬥技巧。經過多年的磨練，泰恩（託尼·賈 Tony Jaa 飾）終於成長為身懷絕技的高手，並接任車南晉陞為匪幫的新任首領。\r 雖然數年過去，但他始終沒有忘記 Rajasena 加諸在其家族身上的厄運，他開始走上一條充滿血腥和艱險的復仇之路"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"اونگ بک ۲","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Tajlandski ratnik 2","runtime":0,"tagline":"Dječak iz plemićke obitelji kojega odgoji grupa pobunjenika kreće osvetiti smrt roditelja","homepage":"","overview":"Nekoć davno u Tajlandu, Tienu, dječaku iz plemićke obitelji, osvajači ubiju roditelje, a sam zamalo izbjegne smrt. Prihvaćaju ga pripadnici velike pobunjeničke grupe čije se skrovište nalazi usred prašume, pa Tien uz njih uči kako lopovske tako i borilačke vještine, koje oni koriste u borbi protiv lokalnih vlastelina, a kad odraste postaje vođa skupine. No, jednoga dana doznaje da se traže natjecatelji za turnir na kojem će najbolji biti izabrani za elitne vojnike u službi čovjeka koji je ubio njegove roditelje. Došlo je vrijeme osvete."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"マッハ!弐","runtime":0,"tagline":"","homepage":"","overview":"アユタヤ王国による侵略が進むタイ。東の王国では家臣ラーチャセーナによるクーデターがおき、国王とその妻が殺されるが、息子のティン（トニー・ジャー）だけが、悪名高い山賊「ガルーダの翼峰」のリーダー、チューナンに救われ、彼らの住む山奥の村で生活することになる。そこには、ムエタイ、剣術、カンフーなどありとあらゆる格闘技の使い手たちがいた。ティンは彼らから十数年にわたり徹底的な教えを受け、やがて究極の戦士へと成長する。チューナンはティンを自分の跡目にと考え、ティンもチューナンを父のように慕っていたが、ティンにはどうしてもやり遂げなければならないことがあった。それは父と母を殺したラーチャセーナへの復讐。そんなある日、ラーチャセーナがティンの親から奪い取った領土に王朝を設立し、初代王に就くという知らせが入る。想いを果たすべく、ティンは即位式に一人乗り込んでいく。本物の戦いが、今始まる！"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"}],"reviews_tmdb":[],"recommendations":[{"id":43209,"adult":false,"title":"Ong Bak 3","video":false,"overview":"Tien is captured and almost beaten to death before he is saved and brought back to the Kana Khone villagers. There he is taught meditation and how to deal with his Karma, but very soon his arch rival returns challenging Tien for a final duel.","genre_ids":[28,12,36],"media_type":"movie","popularity":1.7445,"vote_count":479,"poster_path":"/sIVrOJVeLqPz9NwNa0e4FpqJCWK.jpg","release_date":"2010-05-05","vote_average":6.072,"backdrop_path":"/rtScIZjSyI0oV7YFCtUUthFNvqj.jpg","original_title":"องค์บาก 3","original_language":"th"},{"id":9316,"adult":false,"title":"Ong-Bak","video":false,"overview":"When the head of a statue sacred to a village is stolen, a young martial artist goes to the big city and finds himself taking on the underworld to retrieve it.","genre_ids":[28,80],"media_type":"movie","popularity":4.8387,"vote_count":1829,"poster_path":"/oagqAwp48dMPoCT94yDJUDOCVPi.jpg","release_date":"2003-01-31","vote_average":7.13,"backdrop_path":"/wdHIYawEp7lnf1XNzp6rWxLYgUG.jpg","original_title":"องค์บาก","original_language":"th"},{"id":55377,"adult":false,"title":"Amityville: The Evil Escapes","video":false,"overview":"After moving into their matriarch's gothic seaside mansion, the Evans family soon becomes host to an uninvited demonic force in the form of a mysterious lamp that once resided in the Amityville house.","genre_ids":[27,10770],"media_type":"movie","popularity":1.7838,"vote_count":134,"poster_path":"/kbR4WSOG87BqFgBExKya2abgUrf.jpg","release_date":"1989-05-12","vote_average":4.556,"backdrop_path":"/A8bGWMCZSM5QIsMR4yVU1vdUltE.jpg","original_title":"Amityville: The Evil Escapes","original_language":"en"},{"id":20264,"adult":false,"title":"The Bodyguard 2","video":false,"overview":"The best agent of Vieng, the country near the boundary of Thailand received the important mission that he had to catch two armed dealers who could be the dangerous for his country.","genre_ids":[28,35],"media_type":"movie","popularity":0.8137,"vote_count":36,"poster_path":"/A5Ldoa9WhvN6Uz4RHYk7hBUPAB7.jpg","release_date":"2007-03-08","vote_average":5.7,"backdrop_path":"/1tSGflRKF6WOXM2nvMKAsVnSKNd.jpg","original_title":"บอดี้การ์ดหน้าเหลี่ยม 2","original_language":"th"},{"id":30806,"adult":false,"title":"Out for a Kill","video":false,"overview":"An unsuspecting university professor is an unwitting accomplice in a foiled Chinese cocaine deal. Wrongly imprisoned, he escapes to take his revenge and prove his innocence.","genre_ids":[28,53],"media_type":"movie","popularity":0.7122,"vote_count":154,"poster_path":"/7YIdZK06KAmbaNCeUy79zjteHmO.jpg","release_date":"2003-08-14","vote_average":4,"backdrop_path":"/74cUvovyoMQ1S9zy5f5JmRm4TgU.jpg","original_title":"Out for a Kill","original_language":"en"},{"id":141010,"adult":false,"title":"And the Crows Will Dig Your Grave","video":false,"overview":"Wells Fargo hires bounty hunters to protect its gold transports from the notorious outlaw Glenn Kovacs. Jeff Sullivan, one of the hired gunmen, buys the freedom of Dan Barker, a prisoner who may lead him to Kovacs. When Barker escapes from Sullivan, the other bounty hunters pursue him also, leading to the ultimate showdown between all parties.","genre_ids":[37],"media_type":"movie","popularity":0.1669,"vote_count":7,"poster_path":"/68fBGpX9iLxattJhfVYc1zFtfzG.jpg","release_date":"1971-08-11","vote_average":7,"backdrop_path":"/q8drek2twqnld6lRaI9k9bsu5EQ.jpg","original_title":"Los buitres cavarán tu fosa","original_language":"es"},{"id":48119,"adult":false,"title":"Retrieval","video":false,"overview":"19 year old Wojtek lives in a poverty stricken Polish town. He is in love with an older woman, an illegal emigrant from Ukraine. He boxes in illegal matches to get money and is spotted by a man running a security business. Accepting this man's offer means becoming a gangster, but this could allow him to a residence permit for his girlfriend Katya.","genre_ids":[18],"media_type":"movie","popularity":0.2167,"vote_count":12,"poster_path":"/2SKzV3CE1MTWEmL65L2Isb8uuOm.jpg","release_date":"2006-11-17","vote_average":5.583,"backdrop_path":"/9wbBJXQGcY1ex7rcWIG2TLCkmgQ.jpg","original_title":"Z odzysku","original_language":"pl"},{"id":294644,"adult":false,"title":"Invasion","video":false,"overview":"INVASION is a documentary about the collective memory of a country. The invasion of Panama by the U.S in 1989 serves as an excuse to explore how a people remember, transform, and often forget their past in order to re-define their identity and become who they are today.","genre_ids":[99,36,10752],"media_type":"movie","popularity":0.3488,"vote_count":33,"poster_path":"/wtz4HMUrvl787a6QBkD9owcDFf7.jpg","release_date":"2014-04-06","vote_average":7.3,"backdrop_path":null,"original_title":"Invasión","original_language":"es"},{"id":28090,"adult":false,"title":"Maniac Cop 2","video":false,"overview":"Undead cop Matt Cordell rises from the grave, and is after the criminals who murdered him in prison.","genre_ids":[28,27,53,80],"media_type":"movie","popularity":0.6798,"vote_count":258,"poster_path":"/NWeLUBpxn7lcMpCPvnTGmtHwmj.jpg","release_date":"1990-07-18","vote_average":5.9,"backdrop_path":"/c6NEPu9EKzk6Ukv0rjzDpcpSg7a.jpg","original_title":"Maniac Cop 2","original_language":"en"},{"id":462593,"adult":false,"title":"What the Waters Left Behind","video":false,"overview":"Epecuén was one of the most important touristic villages of Argentina. Thousands of people concurred, attracted by the healing properties of its thermal waters. On November 10th 1985, a huge volume of water broke the protecting embankment and the village was submerged under ten meters of salt water. Epecuén disappeared. Thirty years later, the waters receded and the ruins of Epecuén emerged exposing a bleak and deserted landscape. The residents never returned.  The plot revolves around a group of young people that take a trip to the ruins in order to film a documentary about Epecuén. Ignoring the warnings, and after a brief tour, they get stranded in the abandoned village. Contrary to what they thought, they begin to realize that they are really not alone…","genre_ids":[27],"media_type":"movie","popularity":0.2512,"vote_count":112,"poster_path":"/tnqblwjW48fkZh99jQYWziMnhr9.jpg","release_date":"2017-10-28","vote_average":4.688,"backdrop_path":"/ufyPovbgRKlKTWrlzDFgULfgfyi.jpg","original_title":"Los olvidados","original_language":"es"},{"id":45699,"adult":false,"title":"The Butterfly","video":false,"overview":"An old man who has one interest in life, collecting butterflies, has his life changed by an eight year old girl.","genre_ids":[10751,18],"media_type":"movie","popularity":0.462,"vote_count":136,"poster_path":"/4tZCGXqlEPSGxNWZup6YxxCzS5G.jpg","release_date":"2002-12-18","vote_average":6.809,"backdrop_path":"/rpShcpjf3EwJqnTzPPi9vVoHubR.jpg","original_title":"Le Papillon","original_language":"fr"},{"id":1534,"adult":false,"title":"Pathfinder","video":false,"overview":"A Viking boy is left behind after his clan battles a Native American tribe. Raised within the tribe, he ultimately becomes their savior in a fight against the Norsemen.","genre_ids":[12,28],"media_type":"movie","popularity":1.6466,"vote_count":760,"poster_path":"/mME7efKNTU7jzXTgFkI1t0aQUiz.jpg","release_date":"2007-01-11","vote_average":5.666,"backdrop_path":"/x1iHrvnxB3IuNBiTvqdfQqeh2mk.jpg","original_title":"Pathfinder","original_language":"en"},{"id":8982,"adult":false,"title":"The Protector","video":false,"overview":"A young fighter named Kham must go to Australia to retrieve his stolen elephant. With the help of a Thai-born Australian detective, Kham must take on all comers, including a gang led by an evil woman and her two deadly bodyguards.","genre_ids":[28,80,18,53],"media_type":"movie","popularity":4.4912,"vote_count":908,"poster_path":"/uKE9BxgtT5g2pE3ZKC7MnzsAbTZ.jpg","release_date":"2005-08-11","vote_average":7.119,"backdrop_path":"/b2NxliGN77rdu78HQv5peZBmkw4.jpg","original_title":"ต้มยำกุ้ง","original_language":"th"},{"id":8938,"adult":false,"title":"Tokyo!","video":false,"overview":"Three distinct tales unfold in the bustling city of Tokyo. Merde, a bizarre sewer-dweller, emerges from a manhole and begins terrorizing pedestrians. After his arrest, he stands trial and lashes out at a hostile courtroom. A man who has resigned himself to a life of solitude reconsiders after meeting a charming pizza delivery woman. And finally, a happy young couple find themselves undergoing a series of frightening metamorphoses.","genre_ids":[35,18,14,10749],"media_type":"movie","popularity":4.5256,"vote_count":257,"poster_path":"/6xbq2EBAOwy0V7bzd1um3sJX1jd.jpg","release_date":"2008-08-16","vote_average":6.891,"backdrop_path":"/hUpP1NUVKCg66xFBWjSSxaLzJx9.jpg","original_title":"TOKYO!","original_language":"ja"},{"id":10183,"adult":false,"title":"Frozen River","video":false,"overview":"After her husband deserts her, working-class mother Ray Eddy is in great need of money to find a home. Lured by the possibility of easy cash, she joins Lila, a widowed Mohawk who earns a living by smuggling immigrants from Canada to the U.S. across the St. Lawrence.","genre_ids":[18,80],"media_type":"movie","popularity":0.8959,"vote_count":344,"poster_path":"/qZRcN4JLwYQWTxKlycZPLQb37mO.jpg","release_date":"2008-03-26","vote_average":6.6,"backdrop_path":"/gOhtvGwrVkEM5hCFdyyWKJEOBk8.jpg","original_title":"Frozen River","original_language":"en"},{"id":16225,"adult":false,"title":"Heavy Metal 2000","video":false,"overview":"Upon discovery of a shard of what could be the Loc-Nar, a miner named Tyler becomes possessed with an insatiable hunger for power and a thirst for immortality. On his way to the planet of youth, Tyler wipes out most of a space colony and kidnaps a beautiful young woman. His only mistake is that he doesn't kill her sister, Julie, who then sets out on a mission of rescue and revenge.","genre_ids":[28,12,16,14,878],"media_type":"movie","popularity":1.1348,"vote_count":244,"poster_path":"/dCggUkmi3Fyc1HrSnyaSxKPrG4n.jpg","release_date":"2000-04-19","vote_average":6.025,"backdrop_path":"/f5C03doOWiauu37bToKXtpgP5bS.jpg","original_title":"Heavy Metal 2000","original_language":"en"},{"id":19106,"adult":false,"title":"Round Da Way","video":false,"overview":"It’s summer in the hood. As every year, there are those who stay, those who leave, and... those who should have left. Some, like Joe Hustleton, work «under the table» in the rich neighborhoods and fall head over heels for a pretty girl. Some, like Tony Pepperoni, play businessman and spend the summer fleeing a local gang leader and a psychopathic girlfriend. Some, like Sammy and Harvey, pretend to have left. Tropics are far for the homies... and summer promises to be very hot!","genre_ids":[16,35],"media_type":"movie","popularity":1.9788,"vote_count":221,"poster_path":"/myw0jbvci1Z84dMKMtQkCLBaY5u.jpg","release_date":"2009-06-17","vote_average":6.7,"backdrop_path":"/6nUQxbLI0MT44tyuy9CbwrxDg1T.jpg","original_title":"Lascars","original_language":"fr"},{"id":508422,"adult":false,"title":"Penguin Highway","video":false,"overview":"A fourth-grader investigates the mysterious reason behind the sudden appearance of penguins in his village, which is somehow related to a power from a young woman working at a dental clinic.","genre_ids":[16,12,35,14],"media_type":"movie","popularity":2.091,"vote_count":248,"poster_path":"/wMJJk4kkXfqwP5W7wYHWvDXhTlw.jpg","release_date":"2018-08-17","vote_average":7.129,"backdrop_path":"/ujNMvDCrKVlVkDMzfaoBCaZJVuE.jpg","original_title":"ペンギン・ハイウェイ","original_language":"ja"},{"id":2487,"adult":false,"title":"Lady Snowblood","video":false,"overview":"Yuki's family is nearly wiped out before she is born due to the machinations of a band of criminals. These criminals kidnap and brutalize her mother but leave her alive. Later her mother ends up in prison with only revenge to keep her alive. She creates an instrument for this revenge by purposefully getting pregnant. Yuki never knows the love of a family but only killing and revenge.","genre_ids":[28,80,18],"media_type":"movie","popularity":1.2129,"vote_count":403,"poster_path":"/wkcbaqCoYEXDUnSQ6NTnB2C7H05.jpg","release_date":"1973-12-01","vote_average":7.5,"backdrop_path":"/u2fkLndVDFA0ie4a8k6GpWWsm0N.jpg","original_title":"修羅雪姫","original_language":"ja"},{"id":19004,"adult":false,"title":"The Land Before Time III: The Time of the Great Giving","video":false,"overview":"When a sudden shortage of water threatens all life in the great valley, The gang of young dinosaur must cooperate with a group of bullies to make a risky journey outside the valley and find the cause.","genre_ids":[16,12,10751],"media_type":"movie","popularity":0.8501,"vote_count":403,"poster_path":"/abcJUBDHi6hxibSgm2bxYK1wAZK.jpg","release_date":"1995-03-16","vote_average":6.2,"backdrop_path":"/iH3w4JwrsslnDKkNi5kLtiNh7DN.jpg","original_title":"The Land Before Time III: The Time of the Great Giving","original_language":"en"}],"similar_content":[{"id":154,"adult":false,"title":"Star Trek II: The Wrath of Khan","video":false,"overview":"The starship Enterprise and its crew is pulled back into action when old nemesis, Khan, steals a top secret device called Project Genesis.","genre_ids":[28,12,878,53],"popularity":3.4007,"vote_count":2076,"poster_path":"/uPyLsKl8Z0LOoxeaFXsY5MxhR5s.jpg","release_date":"1982-06-04","vote_average":7.4,"backdrop_path":"/meqmvZjKpQ7WRhpZvIoKIAvioSD.jpg","original_title":"Star Trek II: The Wrath of Khan","original_language":"en"},{"id":163,"adult":false,"title":"Ocean's Twelve","video":false,"overview":"Despite pulling off one of the biggest heists in Las Vegas history and splitting the $160 million take, each of the infamous Ocean's crew have tried to go straight, lay low and live a legit life ... but that's proven to be a challenge. Casino owner Terry Benedict demands that Danny Ocean return the money, plus millions more in interest. Unable to come up the cash, the crew is forced to come together to pull off another series of heists, this time in Rome, Paris, and Amsterdam – but a Europol agent is hot on their heels.","genre_ids":[53,80],"popularity":5.8129,"vote_count":7751,"poster_path":"/pE5anFf7nf6ah7V3VRezQ1KSovi.jpg","release_date":"2004-12-09","vote_average":6.565,"backdrop_path":"/5b5HrewiViLWEdMR4dmbd7ajQ8Q.jpg","original_title":"Ocean's Twelve","original_language":"en"},{"id":165,"adult":false,"title":"Back to the Future Part II","video":false,"overview":"Marty and Doc are at it again as the time-traveling duo head to 2015 to nip some McFly family woes in the bud. But things go awry thanks to bully Biff Tannen and a pesky sports almanac. In a last-ditch attempt to set things straight, Marty finds himself bound for 1955 and face to face with his teenage parents -- again.","genre_ids":[12,35,878],"popularity":7.1854,"vote_count":13683,"poster_path":"/YBawEsTkUZBDajKbd5LiHkmMGf.jpg","release_date":"1989-11-22","vote_average":7.775,"backdrop_path":"/w6tPctxWAsHoQXeKxxNOT6lYKpx.jpg","original_title":"Back to the Future Part II","original_language":"en"},{"id":178,"adult":false,"title":"Blown Away","video":false,"overview":"Blown Away tells the story of Jimmy Dove, who works for the Boston bomb squad. Shortly after Dove leaves the force, his partner is killed by a bomb that Dove thinks might have been made by someone he knows.","genre_ids":[28],"popularity":1.6277,"vote_count":600,"poster_path":"/fD23iryzdjfRU05nQAQriD0A3AR.jpg","release_date":"1994-07-01","vote_average":6.2,"backdrop_path":"/8d6kHxFAIE2P54WpxAssgpm5W0Z.jpg","original_title":"Blown Away","original_language":"en"},{"id":179,"adult":false,"title":"The Interpreter","video":false,"overview":"After Silvia Broome, an interpreter at United Nations headquarters, overhears plans of an assassination, an American Secret Service agent is sent to investigate.","genre_ids":[80,53],"popularity":2.4155,"vote_count":1531,"poster_path":"/wTidq3J9fh8sEOAlD8WZFHVLSuB.jpg","release_date":"2005-04-08","vote_average":6.309,"backdrop_path":"/A5mBIAtZOqVpAVUXolwtOnaQcZc.jpg","original_title":"The Interpreter","original_language":"en"},{"id":196,"adult":false,"title":"Back to the Future Part III","video":false,"overview":"The final installment finds Marty digging the trusty DeLorean out of a mineshaft and looking for Doc in the Wild West of 1885. But when their time machine breaks down, the travelers are stranded in a land of spurs. More problems arise when Doc falls for pretty schoolteacher Clara Clayton, and Marty tangles with Buford Tannen.","genre_ids":[12,35,878],"popularity":6.747,"vote_count":11311,"poster_path":"/crzoVQnMzIrRfHtQw0tLBirNfVg.jpg","release_date":"1990-05-25","vote_average":7.489,"backdrop_path":"/AtF7TESJEMmImBRUj9Z7HmW2ZH0.jpg","original_title":"Back to the Future Part III","original_language":"en"},{"id":418927,"adult":false,"title":"Discreet","video":false,"overview":"After years in hiding and struggling to control his demons, an eccentric drifter returns home and discovers that his childhood abuser, the center of his pain, is still alive.","genre_ids":[9648,53,18],"popularity":0.1164,"vote_count":12,"poster_path":"/u64zo6uaxexc0gaQcS3nwDQar7L.jpg","release_date":"2017-02-11","vote_average":4.2,"backdrop_path":"/5ueOmNSvWjDx3IwjReSshuLOLUH.jpg","original_title":"Discreet","original_language":"en"},{"id":246926,"adult":false,"title":"Bruce and Shaolin Kung Fu","video":false,"overview":"Japanese forces in Shanghai attempt to destroy the patriotic spirit of the Chinese by closing down all Kung Fu gyms. Chang Ling (Bruce Le), a top Chinese Kung Fu practitioner, is forced to flee to Korea. The Japanese forces pursue him there, and so Chang Ling fights back, defeating many Japanese fighters before finally encountering the Japanese commander.","genre_ids":[28],"popularity":0.1667,"vote_count":3,"poster_path":"/zCwQKc6BnPP1cnSMsQZkJnMOOEv.jpg","release_date":"1977-03-19","vote_average":7,"backdrop_path":"/jSuxiXIYDIBHv4qioYXVRozDhqQ.jpg","original_title":"Bruce and Shaolin Kung Fu","original_language":"cn"},{"id":1291785,"adult":false,"title":"Twilight of the Warriors: Dragon Throne","video":false,"overview":"The second installment of the Twilight of the Warriors trilogy.\r In 1950s Hong Kong, brothers Lui Cheng-tung and Chen Jim fled to the lawless Kowloon Walled City at the peak of their careers. They endured hardships, waiting for a chance to reclaim their losses. During this time, they encountered a man who significantly influenced their struggle to regain what they had lost.","genre_ids":[28,53,80,12],"popularity":0.7488,"vote_count":0,"poster_path":"/5D4Ss05hIbV7E8fjO4ZThLbGa6J.jpg","release_date":"","vote_average":0,"backdrop_path":null,"original_title":"九龍城寨之龍頭","original_language":"cn"},{"id":1291787,"adult":false,"title":"Twilight of the Warriors: The Final Chapter","video":false,"overview":"The final installment of the Twilight of the Warriors trilogy.","genre_ids":[28,53,80],"popularity":0.2766,"vote_count":0,"poster_path":"/5D4Ss05hIbV7E8fjO4ZThLbGa6J.jpg","release_date":"","vote_average":0,"backdrop_path":null,"original_title":"九龍城寨之終章","original_language":"cn"},{"id":665,"adult":false,"title":"Ben-Hur","video":false,"overview":"In 26 AD, Judah Ben-Hur, a Jew in ancient Judea, opposes the occupying Roman empire.  Falsely accused by a Roman childhood friend-turned-overlord of trying to kill the Roman governor, he is put into slavery and his mother and sister are taken away as prisoners.","genre_ids":[36,18,12],"popularity":8.8819,"vote_count":3042,"poster_path":"/m4WQ1dBIrEIHZNCoAjdpxwSKWyH.jpg","release_date":"1959-11-18","vote_average":7.883,"backdrop_path":"/sU3gFo7Gn67zjtKXIvzJ4omcUbH.jpg","original_title":"Ben-Hur","original_language":"en"},{"id":670,"adult":false,"title":"Oldboy","video":false,"overview":"With no clue how he came to be imprisoned, drugged and tortured for 15 years, a desperate man seeks revenge on his captors.","genre_ids":[18,53,9648,28],"popularity":13.138,"vote_count":9582,"poster_path":"/pWDtjs568ZfOTMbURQBYuT4Qxka.jpg","release_date":"2003-11-21","vote_average":8.241,"backdrop_path":"/sdwjQEM869JFwMytTmvr6ggvaUl.jpg","original_title":"올드보이","original_language":"ko"},{"id":674,"adult":false,"title":"Harry Potter and the Goblet of Fire","video":false,"overview":"When Harry Potter's name emerges from the Goblet of Fire, he becomes a competitor in a grueling battle for glory among three wizarding schools—the Triwizard Tournament. But since Harry never submitted his name for the Tournament, who did? Now Harry must confront a deadly dragon, fierce water demons and an enchanted maze only to find himself in the cruel grasp of He Who Must Not Be Named.","genre_ids":[12,14],"popularity":17.271,"vote_count":21865,"poster_path":"/fECBtHlr0RB3foNHDiCBXeg9Bv9.jpg","release_date":"2005-11-16","vote_average":7.801,"backdrop_path":"/8f9dnOtpArDrOMEylpSN9Sc6fuz.jpg","original_title":"Harry Potter and the Goblet of Fire","original_language":"en"},{"id":682,"adult":false,"title":"The Man with the Golden Gun","video":false,"overview":"Cool government operative James Bond searches for a stolen invention that can turn the sun's heat into a destructive weapon. He soon crosses paths with the menacing Francisco Scaramanga, a hitman so skilled he has a seven-figure working fee. Bond then joins forces with the swimsuit-clad Mary Goodnight, and together they track Scaramanga to a Thai tropical isle hideout where the killer-for-hire lures the slick spy into a deadly maze for a final duel.","genre_ids":[12,28,53],"popularity":4.9709,"vote_count":2220,"poster_path":"/xVkbKwGnBVNQ122GN5bCTMyPbWz.jpg","release_date":"1974-12-04","vote_average":6.456,"backdrop_path":"/3tpNEbRahT8smy7RraaWa0xg9Gv.jpg","original_title":"The Man with the Golden Gun","original_language":"en"},{"id":754,"adult":false,"title":"Face/Off","video":false,"overview":"In order to foil a terrorist plot, an FBI agent undergoes facial transplant surgery and assumes the identity of a criminal mastermind. The plan turns sour when the criminal wakes up prematurely and seeks revenge.","genre_ids":[28,80,878],"popularity":6.5992,"vote_count":5766,"poster_path":"/69Xzn8UdPbVnmqSChKz2RTpoNfB.jpg","release_date":"1997-06-27","vote_average":7.052,"backdrop_path":"/tsSWHgaFlzzkp3o976juBZbmcs2.jpg","original_title":"Face/Off","original_language":"en"},{"id":767,"adult":false,"title":"Harry Potter and the Half-Blood Prince","video":false,"overview":"As Lord Voldemort tightens his grip on both the Muggle and wizarding worlds, Hogwarts is no longer a safe haven. Harry suspects perils may even lie within the castle, but Dumbledore is more intent upon preparing him for the final battle fast approaching. Together they work to find the key to unlock Voldemorts defenses and to this end, Dumbledore recruits his old friend and colleague Horace Slughorn, whom he believes holds crucial information. Even as the decisive showdown looms, romance blossoms for Harry, Ron, Hermione and their classmates. Love is in the air, but danger lies ahead and Hogwarts may never be the same again.","genre_ids":[12,14],"popularity":13.7456,"vote_count":20501,"poster_path":"/z7uo9zmQdQwU5ZJHFpv2Upl30i1.jpg","release_date":"2009-07-15","vote_average":7.7,"backdrop_path":"/ze6Mx4QE5mQVXRYmG2flncqqle4.jpg","original_title":"Harry Potter and the Half-Blood Prince","original_language":"en"},{"id":772,"adult":false,"title":"Home Alone 2: Lost in New York","video":false,"overview":"Instead of flying to Florida with his folks, Kevin ends up alone in New York, where he gets a hotel room with his dad's credit card—despite problems from a clerk and meddling bellboy. But when Kevin runs into his old nemeses, the Wet Bandits, he's determined to foil their plans to rob a toy store on Christmas Eve.","genre_ids":[35,10751,12],"popularity":10.9577,"vote_count":10446,"poster_path":"/9CAkQ9nfrDaIAyncWndwg0tfC8g.jpg","release_date":"1992-11-15","vote_average":6.779,"backdrop_path":"/8fnYJPoXxwAN4valDLgz2whMGTH.jpg","original_title":"Home Alone 2: Lost in New York","original_language":"en"},{"id":1969,"adult":false,"title":"Bandidas","video":false,"overview":"When a ruthless robber baron takes away everything they cherish, a rough-and-tumble, idealistic peasant and a sophisticated heiress embark on a quest for justice, vengeance…and a few good heists.","genre_ids":[28,35,37,80],"popularity":1.7194,"vote_count":1156,"poster_path":"/31wgXG6OxDaXbp5IzyNoUJdVS5e.jpg","release_date":"2006-01-18","vote_average":6.027,"backdrop_path":"/vmDpLofmDgDx3KXTNzRc6dYROim.jpg","original_title":"Bandidas","original_language":"en"},{"id":1979,"adult":false,"title":"Fantastic Four: Rise of the Silver Surfer","video":false,"overview":"The Fantastic Four return to the big screen as a new and all powerful enemy threatens the Earth. The seemingly unstoppable 'Silver Surfer', but all is not what it seems and there are old and new enemies that pose a greater threat than the intrepid superheroes realize.","genre_ids":[878,12,28],"popularity":5.4216,"vote_count":8291,"poster_path":"/1rxTraSO45jbvTrCeSvJ6RmOu1b.jpg","release_date":"2007-06-13","vote_average":5.6,"backdrop_path":"/o2wYH40zW0JIYiYUTu6L4gsNy7E.jpg","original_title":"Fantastic Four: Rise of the Silver Surfer","original_language":"en"},{"id":2004,"adult":false,"title":"Kebab Connection","video":false,"overview":"In Hamburg, Ibrahim \"Ibo\" Secmez, of Turkish descent, wants to direct the first German kung-fu movie. For now, he makes commercials for his uncle's kebab restaurant. Titzie, an aspiring actress and Ibo's German girlfriend, finds she's pregnant. Ibo is uncertain about fatherhood - compounded by his father's disowning him for getting a German girl pregnant - so Titzie sends him packing. He makes attempts at getting it right, but as the birth approaches, he's still not ready. In the background are three thugs in search of good tripe soup and a Capulet-Montegue feud between the kebab joint and a Greek taverna across the street. Can Ibo be the glove upon that hand?","genre_ids":[35,28,10749],"popularity":0.3216,"vote_count":71,"poster_path":"/jNHsAVtJEzAGQJnv3AGagBSAFLu.jpg","release_date":"2004-04-21","vote_average":6.655,"backdrop_path":"/s2XyJwZ2nmtbCT8ZE3oPlm0yq1j.jpg","original_title":"Kebab Connection","original_language":"de"}],"external_ids":{"imdb_id":"tt0785035","twitter_id":null,"facebook_id":null,"wikidata_id":"Q653564","instagram_id":null,"metacritic_id":"movie/ong-bak-2","mydramalist_id":"161426","rotten_tomatoes_id":"m/10011457-ong_bak_2_2009"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":110688,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AU","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2008-12-05T00:00:00.000Z","certification":"MA15+"}]},{"iso_3166_1":"DE","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2009-02-06T00:00:00.000Z","certification":"18"}]},{"iso_3166_1":"FR","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2009-07-22T00:00:00.000Z","certification":"TP"}]},{"iso_3166_1":"GB","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2009-10-16T00:00:00.000Z","certification":"15"}]},{"iso_3166_1":"NL","release_dates":[{"note":"DVD","type":5,"iso_639_1":"","descriptors":[],"release_date":"2009-05-28T00:00:00.000Z","certification":"16"},{"note":"RTL 7","type":6,"iso_639_1":"","descriptors":[],"release_