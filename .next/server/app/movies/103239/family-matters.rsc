5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Family Matters\",\"description\":\"Elder sister, Spring, seeks her origins before heading to university, Autumn, the mother, grapples with conceiving a child through artificial insemination, Summer, the younger brother, tries to engage with a paternal figure he barely knows just before his military service, and Winter, the father, desperately tries to change his fate as problems mount up.\",\"image\":\"https://image.tmdb.org/t/p/w500/nmTk4v2f6d2Bgeiq049xSMV0Dgt.jpg\",\"datePublished\":\"2025-09-12\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"TW\",\"inLanguage\":\"zh\",\"genre\":[\"Drama\",\"Family\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7,\"bestRating\":10,\"ratingCount\":1}}"}}],["$","$L10",null,{"initialDrama":{"id":"ae3308da-d08f-46e4-9488-e18013cb7c21","tmdb_id":1047884,"imdb_id":"tt35834522","content_type":"movie","title":"Family Matters","original_title":"我家的事","overview":"Elder sister, Spring, seeks her origins before heading to university, Autumn, the mother, grapples with conceiving a child through artificial insemination, Summer, the younger brother, tries to engage with a paternal figure he barely knows just before his military service, and Winter, the father, desperately tries to change his fate as problems mount up.","poster_path":"/nmTk4v2f6d2Bgeiq049xSMV0Dgt.jpg","backdrop_path":"/bA8FtjVOQGfHoUZpK4wnOMlKSr3.jpg","release_date":"2025-09-12","first_air_date":null,"status":"published","original_language":"zh","origin_country":["TW"],"genres":[{"id":18,"name":"Drama"},{"id":10751,"name":"Family"}],"popularity":1.9605,"vote_average":7,"vote_count":1,"runtime":99,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:50:12.431299+00:00","updated_at":"2026-02-21T08:43:05.914+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":253482,"name":"Key In Films Ltd.","logo_path":null,"origin_country":""},{"id":175745,"name":"KOKO Entertainment","logo_path":null,"origin_country":"TW"},{"id":182169,"name":"TAICCA","logo_path":"/9nbEMaERHUziUZAxsuSbCLcVPaM.png","origin_country":"TW"}],"production_countries":[{"name":"Taiwan","iso_3166_1":"TW"}],"spoken_languages":[{"name":"普通话","iso_639_1":"zh","english_name":"Mandarin"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[],"alternative_titles":[{"type":"","title":"Wo Jia De Shi","iso_3166_1":"TW"}],"videos":[],"watch_providers":{"results":{}},"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/vraxtg8boiMMjEu6bvaoAKpYkCv.jpg","images":{"logos":[{"width":787,"height":337,"file_path":"/kbry6zxAlcgwjDD8A8UjQ1pnHt.png","iso_639_1":"zh","vote_average":0},{"width":478,"height":1944,"file_path":"/rXmzCSSSGag2MEEpdpzCOyDv0pI.png","iso_639_1":"zh","vote_average":0}],"posters":[{"width":1200,"height":1800,"file_path":"/vraxtg8boiMMjEu6bvaoAKpYkCv.jpg","iso_639_1":"zh","vote_average":3.334},{"width":2000,"height":2829,"file_path":"/rms2HpZTpd4D10q8AfLTNpVgqAK.jpg","iso_639_1":"zh","vote_average":0.166},{"width":1448,"height":2048,"file_path":"/kLI40epleDwfcpLRC6hAAQUerA4.jpg","iso_639_1":null,"vote_average":0},{"width":2000,"height":3000,"file_path":"/nmTk4v2f6d2Bgeiq049xSMV0Dgt.jpg","iso_639_1":"en","vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/bA8FtjVOQGfHoUZpK4wnOMlKSr3.jpg","iso_639_1":null,"vote_average":3.334},{"width":1440,"height":810,"file_path":"/y0VkevEaXZAEgDW83iwrelTeBKK.jpg","iso_639_1":null,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/8XmmOCVWaxRTqCxR7lWbIQBpswB.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/p4zmT2bGJSHLjHCO7dmHvdZq03t.jpg","iso_639_1":null,"vote_average":0},{"width":2000,"height":1125,"file_path":"/1JkRiQUzPYNgEoUTP38TPHjCSGB.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/ci1KTyEKAPchYQcWt8yHa65QuU5.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/1MHJpAKA2EzTGXU96RlqUYP0XHm.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/qXoSINqPy7IXKSwQ4d1QjzlJlDv.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/44qczb6LAdwfQD8XhmjMe3ItYnN.jpg","iso_639_1":null,"vote_average":0},{"width":2000,"height":1125,"file_path":"/eHDjWQo4sANk56wGZzJ9efuNw50.jpg","iso_639_1":"zh","vote_average":0},{"width":1500,"height":844,"file_path":"/e7cDqdq1kzgIOrdHEiNJBHCKwea.jpg","iso_639_1":null,"vote_average":0},{"width":2000,"height":1125,"file_path":"/jFfbaLZXX6KACUL27BXKZVCMGvU.jpg","iso_639_1":"zh","vote_average":0},{"width":2000,"height":1125,"file_path":"/rShrzRMk2JJo06zr1RjgF30AQP1.jpg","iso_639_1":null,"vote_average":0},{"width":2000,"height":1125,"file_path":"/se2jjJnFVSeg957aN2aqc8b7xEM.jpg","iso_639_1":null,"vote_average":0},{"width":2237,"height":1258,"file_path":"/dYscMeR8736LLEH9ZcWEK4nXOxB.jpg","iso_639_1":"zh","vote_average":0}]},"enriched_at":"2026-04-21T09:12:04.678+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Family Matters","runtime":99,"tagline":"","homepage":"","overview":"Elder sister, Spring, seeks her origins before heading to university, Autumn, the mother, grapples with conceiving a child through artificial insemination, Summer, the younger brother, tries to engage with a paternal figure he barely knows just before his military service, and Winter, the father, desperately tries to change his fate as problems mount up."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"貼心的姊姊小春為了申請學費減免，意外發現自己是家中收養的孩子；弟弟夏仔在入伍前遇見了爸爸阿冬同梯的好友阿淵，卻發現阿淵跟媽媽阿秋之間的憋扭。小春跟夏仔逐漸發現隱藏在家人之間的秘密⋯⋯。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"我が家の事","runtime":0,"tagline":"","homepage":"","overview":"ごく普通の家族の歴史に脈々と引き継がれる秘密。その秘密によって苦しみ、引き裂かれ、再び結ばれる姿を、家族それぞれの視点から丁寧かつ滑稽に描く。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Starsza siostra Spring próbuje odnaleźć swoje korzenie przed pójściem na studia, Autumn, matka, zmaga się z poczęciem dziecka poprzez sztuczną inseminację, Summer, młodszy brat, tuż przed służbą wojskową próbuje nawiązać kontakt z ojcem, którego ledwo zna, a Winter, ojciec, rozpaczliwie próbuje zmienić swój los, gdy narastają problemy."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"我家的事","runtime":98,"tagline":"","homepage":"","overview":"贴心的姐姐小春为了申请学费减免，意外发现自己是家中收养的孩子；弟弟夏仔在入伍前遇见了爸爸阿冬同梯的好友阿渊，却发现阿渊跟妈妈阿秋之间的憋扭。小春跟夏仔逐渐发现隐藏在家人之间的秘密⋯⋯"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"我家的事","runtime":0,"tagline":"","homepage":"","overview":"每個家庭，都有些不能説的事。姊姊春琇申請學費減免，意外發現自己的身世秘密；弟弟子夏想在停水的日子洗個澡，遇見爸爸以前當兵的同袍；媽媽勵秋年輕時一再嘗試人工受孕，總事與願違；嗜賭的爸爸順冬試圖逆轉人生，看雪的承諾不知何時兑現。看似平凡的一家四口，經歷生命四季，在四個人生片段裏，家人間縱有牽絆及矛盾，始終流露濃得化不開的思念與親情。潘客印首部長片，延續其得獎短片《姊姊》的細膩感情，從不同家庭成員的視角，揭示要多拼命，才可成為家人。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Family Matters","runtime":0,"tagline":"","homepage":"","overview":"Über zwei Jahrzehnte und vier verschiedene Zeiträume hinweg folgt FAMILY MATTERS dem scheinbar gewöhnlichen Leben einer taiwanesischen Familie. Jedes Mitglied steht vor einer lebensverändernden Herausforderung: Die ältere Schwester sucht nach ihrer wahren Herkunft, die Mutter ringt mit künstlicher Befruchtung, der jüngere Bruder weint heimlich um Mitternacht und der Vater versucht verzweifelt, sein Schicksal zu ändern. Um einen Erlass der Studiengebühren zu beantragen, entdeckt die fürsorgliche ältere Schwester Xiaochun zufällig, dass sie adoptiert ist; bevor er zur Armee geht, trifft der jüngere Bruder Xiazai Ayuan, einen guten Freund seines Vaters Adong, entdeckt aber die schwierige Beziehung zwischen Ayuan und seiner Mutter Aqiu. Xiaochun und Xiazai entdecken nach und nach die Geheimnisse ihrer Familienmitglieder."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Šeimos reikalai","runtime":0,"tagline":"","homepage":"","overview":"Apimantis dvidešimt ketverius metus ir keturis skirtingus laikotarpius, filmas „Šeimos reikalai“ seka, iš pirmo žvilgsnio, įprastus motinos, tėvo, dukters ir sūnaus gyvenimus. Tačiau filmo eigoje, pasakojimui vystantis iš skirtingų šeimos narių perspektyvų, sužinome, jog kiekvieno iš jų gyvenimus paveikia skaudžios, sudėtingos patirtys: vyresnioji sesuo atsitiktinai sužino, jog yra įvaikinta, jaunesnysis brolis to nežinodamas sutinka savo biologinį tėvą, motina susiduria su vaisingumo problemomis, o tėvas kenčia nuo priklausomybės. Filmas gilinasi į sudėtingą šeimos tarpusavio santykių dinamiką, kurią veikia ne tik skirtingos patirtys, bet ir išoriniai, iš visuomenės ir kultūrinių normų kylantys lūkesčiai."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"}],"reviews_tmdb":[],"recommendations":[{"id":1368096,"adult":false,"title":"Vodu Between two worlds","video":false,"overview":"Voodoo tradition is too often victim of misperceptions and stereotypes in the Western imagination. In Togo, Voodoo is revealed in all its splendour and complexity. Through spectacular ceremonies, consultations and rites, an intimate connection is revealed that unites the visible world with that of invisible forces. By giving a voice to those who live and practise Voodoo, an authentic and nuanced perspective emerges, revealing the richness of this mysterious spirituality. It's a genuine burst of curiosity about a living heritage and the sumptuousness of its traditions.","genre_ids":[99],"media_type":"movie","popularity":0.0828,"vote_count":3,"poster_path":"/pgFFAiInWaxkK3DDceITw3wUPKM.jpg","release_date":"2025-03-15","vote_average":7.5,"backdrop_path":"/n8HIfpC7nsVOrK8dWb8DHl01jQM.jpg","original_title":"Vodu Entre deux mondes","original_language":"fr"},{"id":467004,"adult":false,"title":"Pick the Youth","video":false,"overview":"A-Sen is born in an aristocratic family. His family has a long tradition of practicing medicine. Before the high school entrance exam, A-Sen is transferred from a music class to a normal class, which his father believes would lead A-Sen to a better future. Unexpectedly, A-Sen joins a rock band for a music.","genre_ids":[18],"media_type":"movie","popularity":0.2873,"vote_count":1,"poster_path":"/mgCqZPhtDczKupggOX4Tv4TzX3F.jpg","release_date":"2011-10-28","vote_average":10,"backdrop_path":null,"original_title":"皮克青春","original_language":"zh"},{"id":1374685,"adult":false,"title":"Silent City Driver","video":false,"overview":"In a city rife with corruption and scandals, surrounded by indifference, the solitary and enigmatic Myagmar lives in isolation after enduring 14 brutal years in prison. Scarred both physically and emotionally, his only companions are the stray dogs he has rescued over time.","genre_ids":[18,53],"media_type":"movie","popularity":0.208,"vote_count":6,"poster_path":"/4l5UK4XZYd1xf9DD4bHYln7EClP.jpg","release_date":"2024-11-21","vote_average":7.5,"backdrop_path":"/wpf4SD4ea1KB1pYafxO2SeMokVa.jpg","original_title":"Чимээгүй хотын жолооч","original_language":"mn"},{"id":1420492,"adult":false,"title":"Jenuh Eksistensialisme","video":false,"overview":"Three female students discusses existentialism while trapped in their classroom.","genre_ids":[],"media_type":"movie","popularity":0.0214,"vote_count":2,"poster_path":"/kJGpgrsxW7ggv87vMQ1sJ6BQbAj.jpg","release_date":"2025-03-15","vote_average":8.5,"backdrop_path":"/yZAZEIin8xhg7Jy3ABVQLJlCy88.jpg","original_title":"Jenuh Eksistensialisme","original_language":"id"},{"id":323667,"adult":false,"title":"Florence Fight Club","video":false,"overview":"Intertwined stories from the gladiator/athletes participating to the Calcio Storico Fiorentino yearly championship.","genre_ids":[35,18],"media_type":"movie","popularity":0.5181,"vote_count":31,"poster_path":"/rPCOC0myV3Vr7nYGMAOAOpUXgH3.jpg","release_date":"2015-06-21","vote_average":7.387,"backdrop_path":"/jbENtcxPaIohtUyeSzTiVnCLHpn.jpg","original_title":"Вставай и бейся","original_language":"ru"},{"id":718314,"adult":false,"title":"FILM","video":false,"overview":"A boy walks through an abandoned building and films the interior. Suddenly his camera disappears.","genre_ids":[],"media_type":"movie","popularity":0.2159,"vote_count":11,"poster_path":"/pMjTLiyPKs0kPlG8S3LS2zySqrp.jpg","release_date":"2020-04-18","vote_average":7.2,"backdrop_path":"/iiwWSq6pQmaEnIX5FYGg2uWe5qH.jpg","original_title":"FILM","original_language":"en"},{"id":39994,"adult":false,"title":"Deported Women of the SS Special Section","video":false,"overview":"Young women in Nazi-occupied countries are packed onto a train and shipped off to a prison camp, where the sadistic commandant uses them as rewards for his lesbian guards and perverted and deviate troops.","genre_ids":[18,53,10752,27],"media_type":"movie","popularity":0.5579,"vote_count":30,"poster_path":"/umCGAugyGPpGo2i1qBiDe8apZ7t.jpg","release_date":"1976-11-23","vote_average":4.6,"backdrop_path":"/yvFXA1uJucj2SiLCaNP3PGW0SJw.jpg","original_title":"Le deportate della sezione speciale SS","original_language":"it"},{"id":408843,"adult":false,"title":"64: Part 2","video":false,"overview":"1989: 64th and last year of the Showa era. A girl is kidnapped and killed. The unsolved case is called Case 64 ('rokuyon').  2002: Yoshinobu Mikami, who was the detective in charge of the Case 64, moves as a Public Relations Officer in the Police Affairs Department. His relation with the reporters is conflicted and his own daughter is missing. The statute of limitations for the Case 64 will expire in one year. Then a kidnapping case, similar to the Case 64, takes place. The rift between the criminal investigation department and police administration department deepens. Mikami challenges the case as a public relations secretary.","genre_ids":[9648],"media_type":"movie","popularity":0.5742,"vote_count":17,"poster_path":"/jaZPU1NiDb6mIdooT5d8jTfqooa.jpg","release_date":"2016-06-01","vote_average":7.5,"backdrop_path":"/uOnRZLa6iG7KaFd2EViqzwrRJ1s.jpg","original_title":"64-ロクヨン-後編","original_language":"ja"},{"id":1298238,"adult":false,"title":"Untamed Royals","video":false,"overview":"A group of wealthy teenagers commit crimes that escalate from petty mischief to dangerous plots, causing chaotic consequences — but not for themselves.","genre_ids":[53,80,18],"media_type":"movie","popularity":0.6116,"vote_count":84,"poster_path":"/iEe9RODlNgobupiksZ2vE4TZwUg.jpg","release_date":"2024-08-27","vote_average":6.25,"backdrop_path":"/sqfam7wEpmyG9Fx0AdVQYrLcIfy.jpg","original_title":"Príncipes salvajes","original_language":"es"},{"id":975902,"adult":false,"title":"Boudica","video":false,"overview":"Inspired by events in A.D. 60, Boudica follows the eponymous Celtic warrior who rules the Iceni people alongside her husband Prasutagus. When he dies at the hands of Roman soldiers, Boudica’s kingdom is left without a male heir and the Romans seize her land and property.  Driven to the edge of madness and determined to avenge her husband’s death, Boudica rallies the various tribes from the region and wages an epic war against the mighty Roman empire.","genre_ids":[28,10752],"media_type":"movie","popularity":2.1853,"vote_count":175,"poster_path":"/g57hTF2TYytHMveoKDpUN8iFk1p.jpg","release_date":"2023-10-26","vote_average":5.9,"backdrop_path":"/zhaMys3Ej1KK32zb5qEOZCi06IH.jpg","original_title":"Boudica","original_language":"en"},{"id":15742,"adult":false,"title":"Taxidermia","video":false,"overview":"Set over three generations and beginning with a sexually frustrated orderly during WWII who relieves his tensions in the most outlandish, gross ways. The result of his liaison is a glutton who grows up to be a champion speed eater. He produces a child who becomes obsessed with taxidermy.","genre_ids":[18,27,35],"media_type":"movie","popularity":1.0449,"vote_count":338,"poster_path":"/uRqxKim0Vr1JZPLYcR1rjFtu74p.jpg","release_date":"2006-08-23","vote_average":6.6,"backdrop_path":"/sZuuEKmEdd9Emn6QIW4WiHrRjSk.jpg","original_title":"Taxidermia","original_language":"hu"},{"id":742074,"adult":false,"title":"I Take a Step","video":false,"overview":"A dyslexic graduate of a pedagogical institute is forced to become a teacher of Russian language and literature in a secondary school. Despite the illness, he manages to establish contact with the students, who in the end will help him keep his job.","genre_ids":[10749],"media_type":"movie","popularity":0.2736,"vote_count":16,"poster_path":"/fT7K9B3ka9AOmqY9fWkVenM626D.jpg","release_date":"2023-09-07","vote_average":8.6,"backdrop_path":"/gC7mliOhehg4ErPPaCW9pgG7huo.jpg","original_title":"Я делаю шаг","original_language":"ru"},{"id":1191611,"adult":false,"title":"Camp Crasher","video":false,"overview":"In a bid to save her son's end-of-school camping trip, a single mom steps in as the bus driver while trying to show him she really can be a cool mom.","genre_ids":[35,10749],"media_type":"movie","popularity":0.9238,"vote_count":65,"poster_path":"/dsLTwYtpi7CtkA8ONH3CuYnjAXj.jpg","release_date":"2024-12-05","vote_average":6.885,"backdrop_path":"/5rDvw8ESyywu7ClZz15uDOSnm1h.jpg","original_title":"Campamento con mamá","original_language":"es"},{"id":314387,"adult":false,"title":"Scooby-Doo! Mecha Mutt Menace","video":false,"overview":"Mecha Mutt, a revolutionary remote-controlled lunar rover resembling a large canine, goes rogue at Houston's Annual Science Expo. Scooby-Doo! Mecha Mutt Menace is the fourth in a series of direct-to-video short films.","genre_ids":[10751,35,9648,16],"media_type":"movie","popularity":0.6131,"vote_count":79,"poster_path":"/6qLU4vChPzCFEkQnrZDlAYLX9BC.jpg","release_date":"2013-09-24","vote_average":8.4,"backdrop_path":"/iwYCaMuiYbAEsU0qCuClH9tNwMt.jpg","original_title":"Scooby-Doo! Mecha Mutt Menace","original_language":"en"},{"id":685,"adult":false,"title":"Olympia Part Two: Festival of Beauty","video":false,"overview":"Part two of Leni Riefenstahl's monumental examination of the 1938 Olympic Games, the cameras leave the main stadium and venture into the many halls and fields deployed for such sports as fencing, polo, cycling, and the modern pentathlon, which was won by American Glenn Morris.","genre_ids":[99],"media_type":"movie","popularity":0.2571,"vote_count":78,"poster_path":"/oleIfZJ4NZebY9ETjoaZoTXYDLb.jpg","release_date":"1938-06-02","vote_average":6.7,"backdrop_path":"/hbL5vWtqJrPCrLEcgQLT5lj2a8G.jpg","original_title":"Olympia - Fest der Schönheit","original_language":"de"},{"id":826740,"adult":false,"title":"Three Songs for Benazir","video":false,"overview":"The story of Shaista, a young man who—newly married to Benazir and living in a camp for displaced persons in Kabul—struggles to balance his dreams of being the first from his tribe to join the Afghan National Army with the responsibilities of starting a family. Even as Shaista’s love for Benazir is palpable, the choices he must make to build a life with her have profound consequences.","genre_ids":[99],"media_type":"movie","popularity":0.2515,"vote_count":78,"poster_path":"/4Q1P44IPm9FyxBH4vmxM7pRgopP.jpg","release_date":"2021-06-02","vote_average":6.2,"backdrop_path":"/9VmAvRUvy0cOTzGu7dHpAanMffk.jpg","original_title":"دری سندری د بینظیر لپاره","original_language":"ps"},{"id":572125,"adult":false,"title":"The 2019 Rose Parade with Cord & Tish","video":false,"overview":"Cord Hosenbeck and Tish Cattigan return for their annual round of live Rose Parade coverage. Cord Hosenbeck and Tish Cattigan are no strangers to the iconic New Year’s tradition of the Rose Parade, having covered the event for the past twenty-six years. After a whirlwind year that included traveling abroad to cover the Royal Wedding, the duo are more excited than ever to return to Pasadena. The esteemed Tim Meadows will also return for the festivities.","genre_ids":[35],"media_type":"movie","popularity":0.3981,"vote_count":24,"poster_path":"/11Qviuu3LOrGmoqyT59KeswM2N7.jpg","release_date":"2019-01-01","vote_average":6.2,"backdrop_path":null,"original_title":"The 2019 Rose Parade with Cord & Tish","original_language":"en"},{"id":860867,"adult":false,"title":"The Accursed","video":false,"overview":"Hana spends twenty years suppressing a maleficent curse that was placed upon her bloodline, only to have a family member knowingly release it forcing her to kill or to be killed.","genre_ids":[27],"media_type":"movie","popularity":0.9565,"vote_count":149,"poster_path":"/kBPkV6Gqvbmq6z25bpw3ofsk5ue.jpg","release_date":"2021-11-12","vote_average":6.5,"backdrop_path":"/6jKfr80IIClfEaHfvRXR0ebzUYA.jpg","original_title":"The Accursed","original_language":"en"},{"id":56162,"adult":false,"title":"Rosalie Goes Shopping","video":false,"overview":"Rosalie loves to shop too much to let a little thing like no money stop her. When the local shopkeepers no longer take her bad checks or bad credit cards, she's finds herself out of ways to please her consumerist tendencies… until she discovers The Internet! Master shopper becomes master hacker, and Rosalie is back on top.","genre_ids":[35],"media_type":"movie","popularity":0.5288,"vote_count":41,"poster_path":"/5d51JLVrRI1AswvIpQXnMScYRRb.jpg","release_date":"1989-11-09","vote_average":5.7,"backdrop_path":"/a45mHSLjJOknCUwFu20ZFMVBOtG.jpg","original_title":"Rosalie Goes Shopping","original_language":"en"},{"id":30790,"adult":false,"title":"Six Reasons Why","video":false,"overview":"In a desolate place called the Badlands, four men stand off with guns drawn, their fingers ready at the trigger. Among them are a fugitive seeking redemption, a son out to avenge his father's murder, a loyal servant with a secret and a murderous criminal hired to kill with a vengeance. This is their story...in a place where revenge, deception and cruelty are a way of life.","genre_ids":[28,878,37],"media_type":"movie","popularity":0.3204,"vote_count":12,"poster_path":"/7Hvd9DxJIys0lORQmf8syEIMzMi.jpg","release_date":"2008-07-15","vote_average":5.3,"backdrop_path":"/2hfNL0MtSSQLc4LAFzG4aQQB3rL.jpg","original_title":"Six Reasons Why","original_language":"en"}],"similar_content":[],"external_ids":{"imdb_id":"tt35834522","twitter_id":null,"facebook_id":"FAMILYMATTERS2025","wikidata_id":null,"instagram_id":"familymatters_film"},"social_ids":{"twitter":null,"facebook":"FAMILYMATTERS2025","instagram":"familymatters_film"},"gdvg_id":103239,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"DE","release_dates":[{"note":"Fünf Seen Filmfestival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-09-10T00:00:00.000Z","certification":""}]},{"iso_3166_1":"HK","release_dates":[{"note":"Summer International Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-08-16T00:00:00.000Z","certification":""}]},{"iso_3166_1":"IT","release_dates":[{"note":"Far East Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-04-29T00:00:00.000Z","certification":""}]},{"iso_3166_1":"JP","release_dates":[{"note":"Osaka Asian Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-03-15T00:00:00.000Z","certification":""}]},{"iso_3166_1":"LT","release_dates":[{"note":"Taivanas ekrane","type":1,"iso_639_1":"","descriptors":[],"release_date":"2026-02-11T00:00:00.000Z","certification":""}]},{"iso_3166_1":"PH","release_dates":[{"note":"QCinema International Film Festiva