5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Black Butler: Book of Murder\",\"description\":\"At the Queen’s request, Ciel and the demon butler Sebastian host an extravagant dinner party for the who’s who of the London underground. But an evening that begins with the promise of unmatched elegance quickly spirals into mayhem when their most distinguished guest is found murdered in his room. Now, trapped in the Phantomhive Manor by a dark and stormy night, Ciel and Sebastian must work together with their high-class guests, including the legendary author Sir Arthur Conan Doyle, to find the murderer in their midst before the blame falls on the host and his somewhat suspicious staff.\",\"image\":\"https://image.tmdb.org/t/p/w500/7N8os3UNezyfyY8FowkLbSzHDqW.jpg\",\"datePublished\":\"2014-10-25\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Mystery\",\"Animation\",\"Adventure\",\"Action\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.976,\"bestRating\":10,\"ratingCount\":62}}"}}],["$","$L10",null,{"initialDrama":{"id":"43fb86b8-211c-44d8-8002-132c8c9dde6b","tmdb_id":511082,"imdb_id":"tt5714216","content_type":"movie","title":"Black Butler: Book of Murder","original_title":"黒執事 Book of Murder","overview":"At the Queen’s request, Ciel and the demon butler Sebastian host an extravagant dinner party for the who’s who of the London underground. But an evening that begins with the promise of unmatched elegance quickly spirals into mayhem when their most distinguished guest is found murdered in his room. Now, trapped in the Phantomhive Manor by a dark and stormy night, Ciel and Sebastian must work together with their high-class guests, including the legendary author Sir Arthur Conan Doyle, to find the murderer in their midst before the blame falls on the host and his somewhat suspicious staff.","poster_path":"/7N8os3UNezyfyY8FowkLbSzHDqW.jpg","backdrop_path":"/pXefjYoqvxbedRYtfeSLHgxL3s2.jpg","release_date":"2014-10-25","first_air_date":null,"status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":9648,"name":"Mystery"},{"id":16,"name":"Animation"},{"id":12,"name":"Adventure"},{"id":28,"name":"Action"}],"popularity":5.9322,"vote_average":7.976,"vote_count":62,"runtime":116,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-28T21:53:53.711973+00:00","updated_at":"2026-02-22T22:50:28.026+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":13113,"name":"A-1 Pictures","logo_path":"/xV5tPYKZhP2Ko9dOh5A3FahuKsx.png","origin_country":"JP"},{"id":2883,"name":"Aniplex","logo_path":"/rDYExnBV61jGQnkhVVrPN4Yl7O1.png","origin_country":"JP"},{"id":10038,"name":"Square Enix","logo_path":"/nCueXKwYIEXrZ5ofqSJBO1YcmRr.png","origin_country":"JP"},{"id":3033,"name":"Asmik Ace","logo_path":"/AwgX2FHGJd54aSWfWJqptFvT1h.png","origin_country":"JP"},{"id":95336,"name":"DeNA","logo_path":"/xbmbcLZgVioNOZrVN94vJ3H6B8H.png","origin_country":"JP"},{"id":12385,"name":"RKB Mainichi Broadcasting Corporation","logo_path":"/piV4KOvWfuxhZUkDbdb5ZWDEpRJ.png","origin_country":"JP"},{"id":142186,"name":"Hakuhodo DY Music & Pictures","logo_path":"/bdXTOuU7PdsDtQngyM7vb47zePs.png","origin_country":"JP"}],"production_countries":[{"name":"Japan","iso_3166_1":"JP"}],"spoken_languages":[{"name":"日本語","iso_639_1":"ja","english_name":"Japanese"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":"NR","keywords":[{"id":703,"name":"detective"},{"id":1307,"name":"butler"},{"id":6152,"name":"supernatural"},{"id":8250,"name":"victorian england"},{"id":13141,"name":"based on manga"},{"id":210024,"name":"anime"},{"id":259583,"name":"original video animation (ova)"}],"alternative_titles":[{"type":"","title":"黒執事 Book of Murder","iso_3166_1":"JP"},{"type":"","title":"Black Butler: Book of Murder","iso_3166_1":"US"},{"type":"romaji","title":"Kuroshitsuji: Book of Murder","iso_3166_1":"JP"},{"type":"","title":"Black Butler: Book of Murder","iso_3166_1":"DE"},{"type":"Alternative","title":"Phantomhive Manor Murder Case","iso_3166_1":"US"}],"videos":[],"watch_providers":{"results":{}},"wikidata_id":"Q110460589","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"JP","main_poster":"/7N8os3UNezyfyY8FowkLbSzHDqW.jpg","images":{"logos":[],"posters":[{"width":1600,"height":2400,"file_path":"/7N8os3UNezyfyY8FowkLbSzHDqW.jpg","iso_639_1":"en","vote_average":3.334},{"width":1536,"height":2184,"file_path":"/5mYWotKuLNc6D2YlKJX31rxkszp.jpg","iso_639_1":"ja","vote_average":3.334},{"width":587,"height":835,"file_path":"/lQnZdSjxpCRfnLFNUSFDT734Wwx.jpg","iso_639_1":"ja","vote_average":0.166},{"width":522,"height":782,"file_path":"/bVrVDoJyg7cZp3g47YOfVAo1QcK.jpg","iso_639_1":"en","vote_average":0.166},{"width":750,"height":1064,"file_path":"/vXbDvbMWDol80mqdlQP4tvngAXC.jpg","iso_639_1":"ja","vote_average":0.166},{"width":750,"height":1064,"file_path":"/6QUoZw9ZiU7UaYO0ITvDGEZOogd.jpg","iso_639_1":"ja","vote_average":0.166},{"width":1449,"height":2048,"file_path":"/9G2Py8cOwoouicqrBQmB9lpZXCS.jpg","iso_639_1":"ja","vote_average":0.166},{"width":750,"height":1064,"file_path":"/gycO7pGK8xBOGa2dzMjYdXV0RRu.jpg","iso_639_1":"en","vote_average":0},{"width":735,"height":983,"file_path":"/4hz7360xh8bdlYdMX6ugvzclJlp.jpg","iso_639_1":"en","vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/4GgsOFGZCXatHqIqqjpBW5NBpJu.jpg","iso_639_1":"ja","vote_average":0},{"width":1280,"height":720,"file_path":"/8B2mkeNJ3chuoSemqSbbG8hkjJB.jpg","iso_639_1":"en","vote_average":0},{"width":2560,"height":1440,"file_path":"/pXefjYoqvxbedRYtfeSLHgxL3s2.jpg","iso_639_1":null,"vote_average":0},{"width":2560,"height":1440,"file_path":"/mSOIEB2InowuTEtrPelnVB2KDey.jpg","iso_639_1":"en","vote_average":0},{"width":1920,"height":1079,"file_path":"/fxe3VbirbjbG7U4DwP2ahmKtjmR.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1081,"file_path":"/kkfiEOHzbRCB5vFZW6ZoszycOno.jpg","iso_639_1":null,"vote_average":0},{"width":3837,"height":2160,"file_path":"/woWwm3OIYOBjQMql6xpw4c5KdUa.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2159,"file_path":"/r0lHv3gmT06oM4iFVsNEiTjsbad.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1079,"file_path":"/afjCn58cbccUWGiG52KvrhHloMF.jpg","iso_639_1":null,"vote_average":0},{"width":1820,"height":1023,"file_path":"/uTpA7S3ddAjot09a4uXkdJv2QcT.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/1KgT20iW80sdd9wmMXxJmhP7jMP.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2159,"file_path":"/qYACnDKqobm7lKbO8DLHmQmx0AG.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1079,"file_path":"/wSstTzguX06ZX1CZTjlajQGzGDa.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2159,"file_path":"/c6iFZeNZ62XdjAHHUbVUF1TBOu5.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1079,"file_path":"/gnugF80NCVAnQ4NUaRcQWHrGWNq.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T07:33:04.676+00:00","enrichment_cycle":0,"translations":[{"data":{"title":"Тёмный Дворецкий: Глава об убийстве","runtime":0,"tagline":"","homepage":"","overview":"В начале весны 1889 года, в честь Королевского мандата, известный граф Сиэль Фантомхайв принимает роскошный банкет с участием нескольких непревзойденных членов высшего общества, а также изо всех сил добивающегося признания писателя, сэра Артура Конан Дойла. Однако в самый разгар званого обеда происходит ужасающее убийство, в котором подозревают никого иного, как самого Графа! Непреодолимая буря продолжает бушевать вне усадьбы. Счет убитых увеличивается. Становится очевидно, что спастись просто так не получится. Слуги Фантомхайва и именитые гости должны вместе стремиться разрешить тайну, прежде чем их также настигнет погибель. К сожалению, даже неуязвимый дворецкий Себастьян Михаэлис не застрахован от смертельной участи."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Black Butler: Book of Murder","runtime":116,"tagline":"","homepage":"","overview":"At the Queen’s request, Ciel and the demon butler Sebastian host an extravagant dinner party for the who’s who of the London underground. But an evening that begins with the promise of unmatched elegance quickly spirals into mayhem when their most distinguished guest is found murdered in his room. Now, trapped in the Phantomhive Manor by a dark and stormy night, Ciel and Sebastian must work together with their high-class guests, including the legendary author Sir Arthur Conan Doyle, to find the murderer in their midst before the blame falls on the host and his somewhat suspicious staff."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"黑执事：幽鬼城杀人事件篇","runtime":0,"tagline":"","homepage":"","overview":"黑执事第三季OVA又译《幽鬼城杀人事件篇》，改编自漫画家枢梁创作漫画《黑执事》。  黑执事第三季OVA全集故事背景为19世纪末维多利亚女王统治时期的英国，具体时间是从1888年开始，19 世纪英国，一位人称邪恶贵族和女王的看门狗的名门少爷，为了达成自己的心愿，与恶魔结下契约，必有一位执事在其侧近。塞巴斯蒂安·米卡利斯是一名执事，是一名集知识、教养、品位、料理、武术等技能于 一身，堪称完美全能的执事。  由于少爷因商场上的诸多胁迫遭受众多贵族怨恨，执事除了照顾少爷的日常起居外，同时身兼少爷的保镖，献上与名门贵族相称的最优 质招待。今天的执事也是身着漆黑的燕尾服，执行他华丽的执务。负责照顾12岁的英国贵族夏尔·凡多姆海威伯爵。执事塞巴斯蒂安·米卡利斯是恶魔，他和夏尔·凡多姆海威订下了契约，契约代价是契约者的灵魂……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Black Butler: Book of Murder","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Black Butler: Book of Murder","runtime":0,"tagline":"","homepage":"","overview":"Peu de temps après le dénouement de l'affaire du Cirque, les majordomes de la Reine font intrusion dans le manoir de Phantomhive. Un drame se produit pendant le banquet organisé un soir de tempête. Le rideau écarlate retombe sur la silhouette du majordome, qui ferme les yeux, pressentant le sort qui l'attend..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Kuroshitsuji: Book of Murder","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Black Butler: Book of Murder","runtime":125,"tagline":"","homepage":"","overview":"Nach den Vorfällen rund um den Zirkus „Noahs Arche“ ist das Misstrauen der Königin von England geweckt. Auf Geheiß Ihrer Majestät soll Wachhund Ciel Phantomhive ein opulentes Bankett für den deutschen Bankier Georg von Siemens veranstalten, um seine Loyalität zu beweisen. An einem stürmischen Frühlingsabend findet sich schließlich nicht nur die Spitze der Londoner Oberschicht auf Ciels Anwesen ein, sondern auch ein aufstrebender Kriminalautor namens Arthur Conan Doyle. Dessen detektivisches Talent wird bald auf die Probe gestellt, denn in der Nacht wird von Siemens ermordet aufgefunden. Während draußen weiterhin der Sturm wütet, sind sich die Anwesenden sicher: Der Täter muss unter ihnen sein! Zunächst fällt der Verdacht auf Ciel, doch schon bald wird die Runde von weiteren mysteriösen Morden erschüttert ..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Op verzoek van de koningin organiseren Ciel en de demonenbutler Sebastian een extravagant etentje voor de who's who van de Londense underground. Maar een avond die begint met de belofte van ongeëvenaarde elegantie loopt al snel uit op chaos wanneer hun meest vooraanstaande gast vermoord wordt aangetroffen in zijn kamer. Nu ze door een donkere en stormachtige nacht gevangen zitten in de Phantomhive Manor, moeten Ciel en Sebastian samenwerken met hun eersteklas gasten, waaronder de legendarische auteur Sir Arthur Conan Doyle, om de moordenaar in hun midden te vinden voordat de schuld bij de gastheer ligt. en zijn enigszins achterdochtige staf."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Kuroshitsuji - Book of Murder","runtime":123,"tagline":"","homepage":"","overview":"A pedido da Rainha, o Conde Ciel Phantomhive organiza um magnífico jantar com a presença de vários dos melhores membros da alta sociedade, bem como do autor em dificuldades, Arthur. Mas à medida que a festa atinge o seu auge, um terrível assassinato ocorre e nada menos que o próprio Conde é suspeito do crime. Enquanto uma tempestade violenta ruge do lado de fora, o número de mortos continua a aumentar. A família Phantomhive e os seus eminentes convidados percebem que devem cooperar para resolver este mistério antes que também caiam nas garras do misterioso assassino. No entanto, parece que nem mesmo o perfeito mordomo, Sebastian Michaelis, está a salvo deste terror."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":116,"tagline":"","homepage":"https://www.kuroshitsuji.tv/bom/","overview":"A pedido da rainha, o jovem mestre Ciel Phantomhive organiza um luxuoso banquete com a presença do \"crème de la crème\" da elite de Londres. O que começa como um evento fabuloso rapidamente toma um rumo sombrio quando os convidados começam a aparecer mortos! Se Sebastian e Ciel quiserem voltar a ver a luz do dia, eles deverão unir forças com seus convidados, incluindo o lendário autor Sir Arthur Conan Doyle, para desvendar o mistério e prender o assassino antes que seja tarde demais!"},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"黑執事：幽鬼城殺人事件篇","runtime":0,"tagline":"","homepage":"","overview":"黑執事第三季 OVA 又譯《幽鬼城殺人事件篇》，改編自漫畫家樞梁創作漫畫《黑執事》。\r 黑執事第三季 OVA 全集故事背景為 19 世紀末維多利亞女王統治時期的英國，具體時間是從 1888 年開始，19 世紀英國，一位人稱邪惡貴族和女王的看門狗的名門少爺，為了達成自己的心願，與惡魔結下契約，必有一位執事在其側近。塞巴斯蒂安·米卡利斯是一名執事，是一名集知識、教養、品位、料理、武術等技能於 一身，堪稱完美全能的執事。\r 由於少爺因商場上的諸多脅迫遭受眾多貴族怨恨，執事除了照顧少爺的日常起居外，同時身兼少爺的保鏢，獻上與名門貴族相稱的最優 質招待。今天的執事也是身著漆黑的燕尾服，執行他華麗的執務。負責照顧 12 歲的英國貴族夏爾·凡多姆海威伯爵。執事塞巴斯蒂安·米卡利斯是惡魔，他和夏爾·凡多姆海威訂下了契約，契約代價是契約者的靈魂……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":432131,"adult":false,"title":"Black Butler: Book of the Atlantic","video":false,"overview":"Ciel learns of a \"Aurora Society\", that is rumored to be researching how to bring the dead back to life. Their next meeting is scheduled to be conducted on the ship Campania, voyaging across the Atlantic Ocean. Much to Ciel's dismay, Elizabeth \"Lizzy\" Midford, is taking the same ship, thus leaving him with no choice but to get aboard as well.","genre_ids":[16,28,35,14,9648],"media_type":"movie","popularity":0.9705,"vote_count":98,"poster_path":"/4jU2Bdk1MB2OvP4BBvTJIPQc0BF.jpg","release_date":"2017-01-21","vote_average":7.5,"backdrop_path":"/clFQR5zwzDrayMVVe7axo0YLFfh.jpg","original_title":"黒執事 Book of the Atlantic","original_language":"ja"},{"id":360737,"adult":false,"title":"Center of My World","video":false,"overview":"A strange family: 17-year-old Phil lives with his mother and twin sister in an old mansion on the outskirts of town. When he returns from summer camp, the mood in the mansion has soured somehow. Phil doesn’t worry about it, hanging out with his best friend Kat instead. When he starts to feel attracted to a mysterious new student at school, Phil is plunged into emotional turmoil only exacerbated by the trouble at home.","genre_ids":[18,10749],"media_type":"movie","popularity":1.1318,"vote_count":268,"poster_path":"/6gXgSBF3baQsHqDuIcuEzWt71Gv.jpg","release_date":"2016-11-10","vote_average":7.1,"backdrop_path":"/ag9NBmSc6CNTfvElzofOBWoWXSN.jpg","original_title":"Die Mitte der Welt","original_language":"de"},{"id":255413,"adult":false,"title":"anohana: The Flower We Saw That Day - The Movie","video":false,"overview":"A year has passed since Menma's ghostly return to the Super Peace Busters. Although the time they spent together during that summer was short, the five members reminisce about what happened as they each write a letter to their lost friend.","genre_ids":[16,18],"media_type":"movie","popularity":1.3305,"vote_count":188,"poster_path":"/m8sCa24YbFIatKlElTMdiH18A5N.jpg","release_date":"2013-08-31","vote_average":7.5,"backdrop_path":"/1OdbhfXCITceLYAzuYcpwerGDOO.jpg","original_title":"劇場版 あの日見た花の名前を僕達はまだ知らない。","original_language":"ja"},{"id":963825,"adult":false,"title":"Black","video":false,"overview":"The hopes and woes of a theater company in Africa.","genre_ids":[18],"media_type":"movie","popularity":0.1105,"vote_count":2,"poster_path":"/xixP7eiqaJDDQ9Mephwb709lKYw.jpg","release_date":"1987-03-30","vote_average":7.2,"backdrop_path":null,"original_title":"Black","original_language":"fr"},{"id":21705,"adult":false,"title":"The Barbie Diaries","video":false,"overview":"Barbie is disheartened when Todd breaks her heart and goes back to his former girlfriend. But things change when she comes across a diary, which makes her wishes come true.","genre_ids":[10751,16],"media_type":"movie","popularity":1.1959,"vote_count":389,"poster_path":"/zSCQBfNWsdiKaqDj7LQUgxnSaFi.jpg","release_date":"2006-05-17","vote_average":6.4,"backdrop_path":"/bACImU2OK8iFwDIIRBzLX4KOPL1.jpg","original_title":"The Barbie Diaries","original_language":"en"},{"id":347201,"adult":false,"title":"Boruto: Naruto the Movie","video":false,"overview":"The spirited Boruto Uzumaki, son of Seventh Hokage Naruto, is a skilled ninja who possesses the same brashness and passion his father once had. However, the constant absence of his father, who is busy with his Hokage duties, puts a damper on Boruto's fire. He ends up meeting his father's friend Sasuke, and requests to become... his apprentice!? The curtain on the story of the new generation rises!","genre_ids":[12,28,16,35,14],"media_type":"movie","popularity":2.7734,"vote_count"