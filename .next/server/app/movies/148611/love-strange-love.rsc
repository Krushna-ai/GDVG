tio":0.667,"vote_average":0.166},{"width":2000,"height":3000,"file_path":"/y2kt7qXmSuhg0SHCR3CNKvWnDjz.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":2,"aspect_ratio":0.667,"vote_average":0.166},{"width":1400,"height":2100,"file_path":"/lisRgee3xCWpkcfE2QXUFpHDf6O.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":2,"aspect_ratio":0.667,"vote_average":0.166},{"width":800,"height":1200,"file_path":"/h3dGk7uaqb0clgBOO6fP7rU0FFp.jpg","iso_639_1":"hr","iso_3166_1":"HR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":803,"height":1204,"file_path":"/zVnHY8AHv4IOdKCTJGn0hq9GRiO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/w6bY9DBThQYGZAslbSDE9QABV8o.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/76nz1TyXm0z2agqqkj1eTZeoYFy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":979,"height":1469,"file_path":"/wEHzav8KeiN0HEQSGdCgHpfpMDc.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.666,"vote_average":0},{"width":1000,"height":1500,"file_path":"/zvufMMqSQcIndLyTm8FJnqtE3sx.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/p1hXdYpaCN9mamlv7jABif7Fbzm.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/7EwzruqMhiXiVBntRoUjOhey8ap.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/lBEUCXI633mPdC4xz9r8H97Xmqb.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/uBGp2A9CwWpGHVtXqpJ4NnYU02S.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/nzqgBGOd8NjGDa3ggTv8AF6RefX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1908,"height":1073,"file_path":"/ePqwUMREAYqqSef479gw9U4pBmg.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166}]},"enriched_at":"2026-04-21T06:59:16.116+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Love Strange Love","runtime":123,"tagline":"For them, everything was permited.","homepage":"","overview":"A man remembers forty-eight crucial hours in his life when, as a child, he visited his mother, the favorite woman of an important politician, in a bordello owned by him, right before some important political changes in 1937 Brazil. In those hours, he discovers his own sexuality."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Amor Estranho Amor","runtime":120,"tagline":"","homepage":"","overview":"Hugo, um homem de meia idade, ainda guarda na memória a infância realmente singular. Ainda um garoto, sai do Sul do país com a avó e desembarca em São Paulo, onde é deixado na frente de um palacete. Ali mora e trabalha Ana, uma prostituta e amante do governador de São Paulo. O garoto irá conviver daí em diante nesse ambiente com outras garotas de programa como Tamara - uma ninfeta atrevida. Depois de ter leiloada a sua falsa virgindade entre os frequentadores mais ricos, ela seduz Hugo - então garoto com doze anos - e o molesta."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":97,"tagline":"Para eles tudo era permitido.","homepage":"","overview":"São Paulo, 1937. Hugo (Marcelo Ribeiro) é um jovem que veio de Santa Catarina, sendo trazido por sua avó para devolvê-lo à sua mãe, Anna (Vera Fisher), que é amante de Osmar Passos (Tarcísio Meira), o político mais influente do estado. Ela habita uma luxuosa mansão com várias outras jovens, todas comandadas por Laura (Íris Bruzzi) e a serviço das manobras políticas de Osmar, que utiliza a casa para festas e orgias a fim de impressionar e agradar possíveis aliados políticos. A chegada do menino coincide com o dia de uma grande festa de despedida que será dada a Benício Mattos (Mauro Mendonça), o político mais influente e poderoso de outro estado. Tal fato deixa Laura bem contrariada, pois não quer que nada saia de . Assim Hugo é acomodado num quarto no sótão, mas se perturba no casarão, onde as circunstâncias fazem com que ele esteja sempre rodeado de jovens, que começam a provocá-lo e até a desejá-lo. Tamara (Xuxa) é a jovem que mais se interessa por Hugo."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Love Strange Love","runtime":120,"tagline":"","homepage":"","overview":"En 1979, à Sao Paulo, un homme d'âge mûr revient sur les lieux de son enfance aux alentours de 1937...\r Envoyé par sa grand-mère chez sa mère Anna, Hugo, un jeune garçon de 12 ans découvre que celle-ci est une prostituée et vit dans un manoir qui sert les ambitions politiques de son compagnon..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":124,"tagline":"","homepage":"","overview":"Der Mittfünfziger Hugo, mit „Exzellenz“ angeredet und somit offenbar eine politische Autorität, besichtigt die prachtvolle Villa, die er geerbt hat und einer kulturellen Organisation überschreiben will. Mit dem Gebäude verbinden ihn unvergessliche Jugenderinnerungen, die als Rückblende an ihm vorüberziehen. – In den 1930er-Jahren ist Hugos Mutter Anna die Geliebte des Politikers Dr. Osmar, dem die Villa gehört. Das Haus beherbergt ein nobles Bordell, in dem die einflussreichsten Männer des Landes verkehren. Anna kümmert sich als rechte Hand der resoluten Bordellchefin Laura um organisatorische Dinge."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"1937'de Brezilya'daki bazı önemli siyasi değişikliklerin hemen öncesinde dinlenirken bazı şeyleri anımsar. Anımsadığı şey ise  ergenlik çağındayken, önemli bir politikacının gözde kadını olan annesini ziyaret ettiği 48 önemli saattir. Bu saatlerde , Kendi cinselliğini keşfeder.."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"爱，奇怪的爱","runtime":0,"tagline":"","homepage":"","overview":"20世纪30年代末，世界局势动荡不安，南美洲的巴西也处在风雨飘摇的前夕。十几岁的俊美少年雨果（Marcelo Ribeiro 饰）随着祖母薇薇从乡下来到首都，因为生计困难，祖母将雨果推给了他的生身母亲安娜（Vera Fischer 饰）。安娜美丽性感，是政客奥萨马博士（Tarcísio Meira 饰）的情人，她和另一个美丽的女子劳拉（Íris Bruzzi 饰）联合打理着奥萨马的豪华宅邸。这个华贵的地方住着许多姿色绝伦的女孩，他们全部是奥萨马用于笼络政客的工具。雨果那双纯洁忧郁的眼睛，目睹了许许多多成人世界的丑恶，也经历了自己心中最初的萌动……  　　本片荣获1982年巴西电影节最佳女演员奖（Vera Fischer）。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Amor, extraño amor","runtime":120,"tagline":"","homepage":"","overview":"Un hombre recuerda 48 horas cruciales en su vida, cuando era niño y descubrió el sexo en una visita a la mansión que su madre poseía a las afueras. Era el año 1937, y algunos importantes cambios políticos estaban ocurriendo en Brasil."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":120,"tagline":"","homepage":"","overview":"Dr. Osmar bezit een verlaten maar nog steeds schitterend herenhuis en blikt terug naar 1937 waar het herenhuis het meest luxueuze bordeel van Sao Paulo was. Er werd een groot feest voorbereid, waarbij gekonkeld en gehandeld werd om de macht op nationale schaal."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Любовь, Странная Любовь","runtime":121,"tagline":"","homepage":"","overview":"Мистер Хьюго возвращается туда, где прошло его детство. Там живыми образами наполняются его воспоминания. Он вспоминает этот дом, некогда служивший роскошным борделем, и некоторое время являлся единственным пристанищем, ему и его матери, которая была вынуждена там работать. Маленьким мальчиком он находиться при ней, очень часто оставаясь в одиночестве. Предоставленный самому себе в таком окружении, он не мог не найти приключений, кажущимися странными для ребенка его возраста.  Именно там его завораживает сумбур взрослой жизни, наполненной безудержным сексом. Жрицы любви не оставляют без внимания появление в их доме юного Хьюго. Устав от общества богатых стариканов они частенько заходят в его комнату, окружая Хьюго женской лаской, но мать ревностно охраняет своего сына от чрезмерного интереса к нему своих коллег. За этими волнительными воспоминаниям и возвращается к эти местам уже немолодой Хьюго..."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"愛，奇怪的愛","runtime":0,"tagline":"","homepage":"","overview":"20 世紀 30 年代末，世界局勢動蕩不安，南美洲的巴西也處在風雨飄搖的前夕。十幾歲的俊美少年雨果（Marcelo Ribeiro 飾）隨著祖母薇薇從鄉下來到首都，因為生計困難，祖母將雨果推給了他的生身母親安娜（Vera Fischer 飾）。安娜美麗性感，是政客奧薩馬博士（Tarcísio Meira 飾）的情人，她和另一個美麗的女子勞拉（Íris Bruzzi 飾）聯合打理著奧薩馬的豪華宅邸。這個華貴的地方住著許多姿色絕倫的女孩，他們全部是奧薩馬用於籠絡政客的工具。雨果那雙純潔憂鬱的眼睛，目睹了許許多多成人世界的醜惡，也經歷了自己心中最初的萌動……  本片榮獲 1982 年巴西電影節最佳女演員獎（Vera Fischer）。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":347413,"adult":false,"title":"Little Witch Academia: The Enchanted Parade","video":false,"overview":"In Enchanted Parade, Akko, Lotte and Sucy, having gotten in trouble yet again, are forced to team up with three other troublemakers; Amanda O'Neill, Constance Braunschweig Albrechtsburger and Jasmineka Antonenko, and must make an annual witch parade a success or else face expulsion.","genre_ids":[28,16,14,35],"media_type":"movie","popularity":0.7844,"vote_count":114,"poster_path":"/ubsZEiUtegc8dfVTsFQc9nvpHSX.jpg","release_date":"2015-07-03","vote_average":7.215,"backdrop_path":"/srcaBcAZVBEZqsFa9DlNTXWMHzj.jpg","original_title":"リトルウィッチアカデミア 魔法仕掛けのパレード","original_language":"ja"},{"id":768702,"adult":false,"title":"Love","video":false,"overview":"Love Hotel. The best place to spend your holiday on February 14th. So this time the doors of the hotel are open for everyone who wants to make Valentine's Day special, wants to believe in love again, or at least not be alone on this day. Former classmates meet at a restaurant in honor of the 40th anniversary of graduation and old feelings flare up with renewed vigor. A jealous man tries to enter all the rooms on the floor to find his missing wife. A private detective and his attractive client arrange a spy show with wiretaps to bring out the scoundrel husband. An immigrant maid from Uzbekistan chooses between love for her young boy and money from his mother, given for her immediate flight home. And the life of a humble student who dreams of becoming a man in just one hour will never be the same after meeting the most talkative night butterfly in the city ...","genre_ids":[35,10749],"media_type":"movie","popularity":0.3072,"vote_count":43,"poster_path":"/hS2eFigVGchssBaRlbt4hkRs09e.jpg","release_date":"2020-12-24","vote_average":6,"backdrop_path":"/zaShigpdqZugK8xe3sRdRgYV3SH.jpg","original_title":"Love","original_language":"ru"},{"id":34671,"adult":false,"title":"Olga","video":false,"overview":"Based upon the true story of Olga Benário, the German-born wife of Brazilian communist leader Luís Carlos Prestes. During the dictatorship of Getúlio Vargas (1930-1945) she was arrested and sent to Nazi Germany, where she was put to death in a concentration camp. After World War II began, Vargas decided to uphold the Allies.","genre_ids":[18,36,10752],"media_type":"movie","popularity":0.7009,"vote_count":201,"poster_path":"/zym9l0b5eu6fDeBXJzbDuVYMOVJ.jpg","release_date":"2004-08-20","vote_average":7.147,"backdrop_path":"/cvi87c0MElnvslK5asTyLCmx4jL.jpg","original_title":"Olga","original_language":"pt"},{"id":580077,"adult":false,"title":"Nothing to Lose 2","video":false,"overview":"After leaving prison in 1992, Edir Macedo goes through a series of trials: the inappropriate conduct of other bishops of the Church, the attack of politicians and Catholics, his mother's illness and the tragedy of the collapse of the roof of a Church in São Paulo .","genre_ids":[18],"media_type":"movie","popularity":0.2973,"vote_count":23,"poster_path":"/2UESbGhUBez8iu4CqVhhmpIueJh.jpg","release_date":"2019-08-15","vote_average":4.9,"backdrop_path":"/q6epM80HdPshyw36DXrV1WZfrp7.jpg","original_title":"Nada a Perder 2: Não Se Pode Esconder a Verdade","original_language":"pt"},{"id":44046,"adult":false,"title":"Wicked","video":false,"overview":"A cul-de-sac in an oppressive suburb becomes a literal dead end for wife and mother Karen Christianson when she is brutally murdered in her own home. In the wake of the event, Karen's teenage daughter Ellie begins to exhibit bizarre behaviors as she slowly acquires her mother's demeanor and mannerisms. Meanwhile, Karen's husband Ben nurtures a less-than-innocent interest in the family's sultry live-in nanny, Lena.","genre_ids":[53],"media_type":"movie","popularity":3.9444,"vote_count":56,"poster_path":"/13ix5ryXWE9l8UhtEKuJrkjmsTr.jpg","release_date":"1998-01-17","vote_average":5,"backdrop_path":"/5PYuy6PWovZHDLA4FuREKkDFzeA.jpg","original_title":"Wicked","original_language":"en"},{"id":325726,"adult":false,"title":"Xuxa Só Para Baixinhos","video":false,"overview":"Xuxa presents a series of musical educational videos dedicated exclusively to a new, much younger generation of kids.","genre_ids":[10402,10751],"media_type":"movie","popularity":0.0286,"vote_count":14,"poster_path":"/50nbg2qXQYYWfZrnHHKhIEKtBmm.jpg","release_date":"2000-10-05","vote_average":7.1,"backdrop_path":"/pbQTkQ1nZh4zoZI4mHreKLadjC3.jpg","original_title":"Xuxa Só Para Baixinhos","original_language":"pt"},{"id":80785,"adult":false,"title":"Amazon Jail","video":false,"overview":"Young women in the Amazon are kidnapped by a ring of devil-worshipers, who plan to sell them as sex slaves. Some of the women escape, but are pursued into the jungle by their captors. The women must band together to turn the tables on their kidnappers.","genre_ids":[53,12,28],"media_type":"movie","popularity":0.6801,"vote_count":24,"poster_path":"/ob0TfLdSvNvRCPM09a9E4iAbugX.jpg","release_date":"1982-01-01","vote_average":4.1,"backdrop_path":"/mPfy2cQto2GoahuLeknwcrUcE8M.jpg","original_title":"Curral de Mulheres","original_language":"pt"},{"id":142807,"adult":false,"title":"The Man from Karpazia","video":false,"overview":"Anestis is a nice guy but he doesn't have the courage to react when others bother him. When one of his close friends brings him some \"magic\" pills that give Anestis the superpowers of his dreams, everything is going to change...","genre_ids":[35],"media_type":"movie","popularity":0.2221,"vote_count":5,"poster_path":"/nB8pLODwGfoF00NFpQQGV2FKHwQ.jpg","release_date":"1969-01-01","vote_average":7,"backdrop_path":"/woyiCBoxyxuByci8PLEjVZje1jO.jpg","original_title":"Ο Άνθρωπος της Καρπαζιάς","original_language":"el"},{"id":234591,"adult":false,"title":"The Key","video":false,"overview":"A college professor wants to bring the joys of sex to his frigid wife. He convinces his son in law to sleep with her because the idea arouses him, while also making him insanely jealous. The professor keeps a journal of his fantasies in a locked cupboard and hopes that his wife will find the key and read it.","genre_ids":[],"media_type":"movie","popularity":0.331,"vote_count":6,"poster_path":"/AjjTay9inXBypbXyHasIreyzk7y.jpg","release_date":"1974-05-04","vote_average":3.333,"backdrop_path":"/iXnORP2zgDeN5ki1mAF81imHUHs.jpg","original_title":"鍵","original_language":"ja"},{"id":11713,"adult":false,"title":"Fist of Fury","video":false,"overview":"During the Japanese occupation of Shanghai, Chen Zhen, the star pupil of a recently-deceased martial arts teacher battles a Japanese dojo which seeks the demise of his master's fighting school.","genre_ids":[18,28,53],"media_type":"movie","popularity":4.9304,"vote_count":1045,"poster_path":"/dlcipCOa9hlfBBz7kCAyjsf3q0E.jpg","release_date":"1972-03-22","vote_average":7.217,"backdrop_path":"/v6wahTqcsU3kcQ1uz7wQpFTZbIb.jpg","original_title":"精武門","original_language":"zh"},{"id":436931,"adult":false,"title":"Pokémon the Movie: I Choose You!","video":false,"overview":"Ash Ketchum wakes up late one morning after having broken his alarm clock in his sleep. He eventually makes it to Professor Oak's lab, but is told that the three starter List of Pokémon (Bulbasaur, Squirtle, and Charmander) have already been taken by Trainers who were on time. However, Oak reveals that he has one more Pokémon, an Electric-type named Pikachu. Despite its volatile and feisty personality, as well as its refusal to get inside a Poké Ball, Ash happily takes Pikachu for his journey.","genre_ids":[10751,16,12,14],"media_type":"movie","popularity":3.0387,"vote_count":659,"poster_path":"/b4U689nUPUtER5Qh1MNlLRPeh8q.jpg","release_date":"2017-07-15","vote_average":7.1,"backdrop_path":"/dyDxxLRTwqGFNOCtLbpxD1QLlfJ.jpg","original_title":"劇場版 ポケットモンスター キミにきめた！","original_language":"ja"},{"id":262,"adult":false,"title":"The King of Comedy","video":false,"overview":"Aspiring comic Rupert Pupkin attempts to achieve success in show business by stalking his idol, a late night talk-show host who craves his own privacy.","genre_ids":[18,35],"media_type":"movie","popularity":4.1394,"vote_count":2527,"poster_path":"/3sGuQv0UxfjDODCC9IQG5S1jXK8.jpg","release_date":"1982-12-18","vote_average":7.8,"backdrop_path":"/7Mh1DM4kCMbN93C2MlUavYbH5YM.jpg","original_title":"The King of Comedy","original_language":"en"},{"id":4248,"adult":false,"title":"Scary Movie 2","video":false,"overview":"While the original parodied slasher flicks like Scream, Keenen Ivory Wayans's sequel to Scary Movie takes comedic aim at haunted house movies. A group of students visit a mansion called \"Hell House,\" and murderous high jinks ensue.","genre_ids":[35],"media_type":"movie","popularity":7.2621,"vote_count":5003,"poster_path":"/7Eb1JWK0Cb0rbfsYjwfc9g0PbQH.jpg","release_date":"2001-07-04","vote_average":5.813,"backdrop_path":"/cjSB3ZjaMpaa9oHFyeYha3KG0mp.jpg","original_title":"Scary Movie 2","original_language":"en"},{"id":797394,"adult":false,"title":"Secret Magic Control Agency","video":false,"overview":"The Secret Magic Control Agency sends its two best agents, Hansel and Gretel, to fight against the witch of the Gingerbread House.","genre_ids":[16,35,14],"media_type":"movie","popularity":2.1708,"vote_count":391,"poster_path":"/4ZSzEDVdxWVMVO4oZDvoodQOEfr.jpg","release_date":"2021-03-18","vote_average":7,"backdrop_path":"/tzJZaglq1hR7RS35BKG68Xz7KY0.jpg","original_title":"Ганзель, Гретель и Агентство Магии","original_language":"ru"},{"id":22537,"adult":false,"title":"Inuyasha the Movie 2: The Castle Beyond the Looking Glass","video":false,"overview":"With their most formidable foe vanquished, Inuyasha and his comrades begin returning to their everyday lives. But their peace is fleeting as another adversary emerges: Kaguya, the self-proclaimed princess from the Moon of Legend, hatches a plot to plunge the world into an eternal night of the full moon. Inuyasha, Kagome, Miroku, Sango and Shippou must reunite to confront the new menace.","genre_ids":[28,16,12,14],"media_type":"movie","popularity":1.3936,"vote_count":155,"poster_path":"/ceJsKxIcy4KOFp3MEqCcRkR7Daz.jpg","release_date":"2002-12-22","vote_average":7.671,"backdrop_path":"/40XTRnRRDZ4TzbjcrfW3WvtSsKW.jpg","original_title":"犬夜叉 鏡の中の夢幻城","original_language":"ja"},{"id":554279,"adult":false,"title":"Return to Christmas Creek","video":false,"overview":"As Christmas approaches, Amelia Hughes, a career-focused Chicago app developer lacking in holiday spirit, returns to her small hometown of Christmas Creek to rediscover the meaning of Christmas. There, she reunites with her childhood best friend Mike and her estranged uncle Harry, whose mysterious rift with Amelia’s father divided her family during the holiday season when she was a child.","genre_ids":[10749,10751,10770],"media_type":"movie","popularity":0.4032,"vote_count":120,"poster_path":"/gCdjZCWM9x9vAbtkvZiIIYL7tOB.jpg","release_date":"2018-11-18","vote_average":6.496,"backdrop_path":"/zNUmOf9vOk0f146jQBrBkdmrZyH.jpg","original_title":"Return to Christmas Creek","original_language":"en"},{"id":416494,"adult":false,"title":"Status Update","video":false,"overview":"After being uprooted by his parents' separation and unable to fit into his new hometown, a teenager stumbles upon a magical app that causes his social media updates to come true.","genre_ids":[35,14,878],"media_type":"movie","popularity":3.6843,"vote_count":563,"poster_path":"/E4twRNScyq3g6tRpvK6X8LdD1z.jpg","release_date":"2018-02-09","vote_average":7.28,"backdrop_path":"/qegwTsiVjrNY9nwkwzLJQ5r4204.jpg","original_title":"Status Update","original_language":"en"},{"id":850099,"adult":false,"title":"Risen","video":false,"overview":"Disaster unfolds when a meteor strikes a small town, turning the environment uninhabitable and killing everything in the surrounding area. Exobiologist Lauren Stone is called to find answers to the unearthly event. As she begins to uncover the truth, imminent danger awakens and it becomes a race against time to save mankind.","genre_ids":[878,18,53],"media_type":"movie","popularity":3.6821,"vote_count":174,"poster_path":"/hSmJrx26NLttonxQmO3hvjHa1gF.jpg","release_date":"2021-08-20","vote_average":5.046,"backdrop_path":"/iZNNQLV2uejoj89DQEh668EqO4j.jpg","original_title":"Risen","original_language":"en"},{"id":799546,"adult":false,"title":"Luckiest Girl Alive","video":false,"overview":"A successful woman in New York City finds her life upended when she is forced to confront a dark truth that threatens to unravel her meticulously crafted life.","genre_ids":[18,53,9648],"media_type":"movie","popularity":1.4971,"vote_count":906,"poster_path":"/e0vrbTmTf2ZcW5CIS9qJ8FDbsU9.jpg","release_date":"2022-09-30","vote_average":6.528,"backdrop_path":"/iHc14vucwUMl6WuvQa4iPfoEdy9.jpg","original_title":"Luckiest Girl Alive","original_language":"en"}],"similar_content":[{"id":8074,"adult":false,"title":"2 or 3 Things I Know About Her","video":false,"overview":"As the city of Paris and the French people grow in consumer culture, a housewife living in a high-rise apartment with her husband and two children takes to prostitution to help pay the bills.","genre_ids":[35,18],"popularity":0.427,"vote_count":210,"poster_path":"/w1LO1SIrpA4GCjK3ysANr7F3eAN.jpg","release_date":"1967-03-17","vote_average":6.2,"backdrop_path":"/6aurEdQ8fs4zevG4m46Lbhoc9Cu.jpg","original_title":"2 ou 3 choses que je sais d'elle","original_language":"fr"},{"id":8447,"adult":false,"title":"Angels and Insects","video":false,"overview":"In Victorian England, wealthy patriarch Sir Harald Alabaster invites an impoverished biologist, William Adamson, into his home. There, William tries to continue his work, but is distracted by Alabaster's seductive daughter, Eugenia. William and Eugenia begin a torrid romance, but as the couple become closer, the young scientist begins to realize that dark, disturbing things are happening behind the closed doors of the Alabaster manor.","genre_ids":[18,10749],"popularity":0.5752,"vote_count":56,"poster_path":"/w1i5JdddoLuzSmnKo5ORDoKdMm2.jpg","release_date":"1995-09-10","vote_average":6.134,"backdrop_path":"/h5PrPi1fnGACJiYoIJxBpAkqhGU.jpg","original_title":"Angels and Insects","original_language":"en"},{"id":1459256,"adult":false,"title":"All at Once","video":false,"overview":"On a journey across Central Park, an introspective high school senior develops unexpected feelings for her charismatic co-valedictorian as they discuss love, family, and their futures.","genre_ids":[18],"popularity":0.1254,"vote_count":0,"poster_path":"/agR17MkooVNSfbdbEH1vS0PboJd.jpg","release_date":"2025-08-08","vote_average":0,"backdrop_path":"/uqTyqeNF9g2A6wYEXWmXqnbxgRi.jpg","original_title":"All at Once","original_language":"en"},{"id":8462,"adult":false,"title":"Joyless Street","video":false,"overview":"In 1921, we follow two women - Marie and Grete - from the same poor Viennese neighborhood, as they try to better the lives of themselves and their families during the period of Austrian postwar hyperinflation.","genre_ids":[18],"popularity":0.3168,"vote_count":49,"poster_path":"/qmOQssz4GfbdtOmxwMP0jBj4P4F.jpg","release_date":"1925-03-01","vote_average":6.724,"backdrop_path":"/h4lY3dgzmtAZ5dl9mPO81S12S7W.jpg","original_title":"Die freudlose Gasse","original_language":"de"},{"id":661653,"adult":false,"title":"Oliverio and the Pool","video":false,"overview":"When something unexpected happens in Oliverio’s family, all he wants to do is walk away. He settles on a deckchair by the pool and decides there is no reason to move. Life swirls around him, revealing secrets and presenting new challenges. Through moments of death, excrement and basic physics, Oliverio learns that some truths cannot be ignored.","genre_ids":[18,35],"popularity":0.2066,"vote_count":8,"poster_path":"/nJlTuSCvg6GuI5Y21xN2cF9tzhT.jpg","release_date":"2022-02-03","vote_average":5,"backdrop_path":"/kpfOgz6u1AySqZTvMjfcod8NTcu.jpg","original_title":"Oliverio y la piscina","original_language":"es"},{"id":8219,"adult":false,"title":"Labyrinth of Passion","video":false,"overview":"An array of outrageous people, including a desperate nymphomaniac and a terrorist with an acute sense of smell, seek love and happiness in Madrid.","genre_ids":[35,18,10749],"popularity":0.4876,"vote_count":127,"poster_path":"/jkyRAC2RVfm65LPA6KdqdiobDe2.jpg","release_date":"1982-09-29","vote_average":6.055,"backdrop_path":"/4Pw8XRiNuuvUiczCJqPuYCTvVqZ.jpg","original_title":"Laberinto de pasiones","original_language":"es"},{"id":8332,"adult":false,"title":"Antibodies","video":false,"overview":"When a notorious German serial killer is captured after committing some of the most 