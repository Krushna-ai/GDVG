5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Love Strange Love\",\"description\":\"A man remembers forty-eight crucial hours in his life when, as a child, he visited his mother, the favorite woman of an important politician, in a bordello owned by him, right before some important political changes in 1937 Brazil. In those hours, he discovers his own sexuality.\",\"image\":\"https://image.tmdb.org/t/p/w500/9CNnxpI6H8ynyOlACRc25vqgJBY.jpg\",\"datePublished\":\"1982-01-11\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"BR\",\"inLanguage\":\"pt\",\"genre\":[\"Drama\",\"History\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.821,\"bestRating\":10,\"ratingCount\":67}}"}}],["$","$L10",null,{"initialDrama":{"id":"e7544a2e-c32e-446a-9cbc-860da0868ae4","tmdb_id":54989,"imdb_id":"tt0083552","content_type":"movie","title":"Love Strange Love","original_title":"Amor Estranho Amor","overview":"A man remembers forty-eight crucial hours in his life when, as a child, he visited his mother, the favorite woman of an important politician, in a bordello owned by him, right before some important political changes in 1937 Brazil. In those hours, he discovers his own sexuality.","poster_path":"/9CNnxpI6H8ynyOlACRc25vqgJBY.jpg","backdrop_path":"/7EwzruqMhiXiVBntRoUjOhey8ap.jpg","release_date":"1982-01-11","first_air_date":null,"status":"published","original_language":"pt","origin_country":["BR"],"genres":[{"id":18,"name":"Drama"},{"id":36,"name":"History"},"drama film"],"popularity":8.0825,"vote_average":5.821,"vote_count":67,"runtime":123,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-26T00:25:14.791779+00:00","updated_at":"2026-02-26T00:25:14.579+00:00","tagline":"For them, everything was permited.","homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":85315,"name":"Cinearte Produções Cinematográficas","logo_