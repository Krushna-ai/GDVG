5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Mom's Friend\",\"description\":\"Seong Soo, a twenty years old boy, decided to move to Seoul after being accepted into Seoul University. However, he was a victim of real estate scam. He then moves into his mother's friend's house. Moreover, it turns out that his mother's friend is a sexy self-employed mother and Seong Soo is attracted to her.\",\"image\":\"https://image.tmdb.org/t/p/w500/eLEqhVjleFUgxYWtgIgZ0gHdi3o.jpg\",\"datePublished\":\"2015-08-20\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"romance film\",\"erotic film\",\"Drama\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7,\"bestRating\":10,\"ratingCount\":24}}"}}],["$","$L10",null,{"initialDrama":{"id":"9b338e30-0aa2-4d3d-880d-8ef629ebd4a2","tmdb_id":387824,"imdb_id":null,"content_type":"movie","title":"Mom's Friend","original_title":"엄마친구","overview":"Seong Soo, a twenty years old boy, decided to move to Seoul after being accepted into Seoul University. However, he was a victim of real estate scam. He then moves into his mother's friend's house. Moreover, it turns out that his mother's friend is a sexy self-employed mother and Seong Soo is attracted to her.","poster_path":"/eLEqhVjleFUgxYWtgIgZ0gHdi3o.jpg","backdrop_path":"/4jnDdvXt9GAzePbUBMpGQ3gQtAg.jpg","release_date":"2015-08-20","first_air_date":null,"status":"published","original_language":"ko","origin_country":["KR"],"genres":[{"name":"romance film"},{"name":"erotic film"},{"id":18,"name":"Drama"}],"popularity":11.0952,"vote_average":7,"vote_count":24,"runtime":91,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-27T21:42:18.837088+00:00","updated_at":"2026-02-21T11:51:10.385+00:00","tagline":"“Did Mom ever have friends like this?!”","homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":108369,"name":"Four Seasons of Younghwasa","logo_path":null,"origin_country":"KR"}],"production_countries":[{"name":"South Korea","iso_3166_1":"KR"}],"spoken_languages":[{"name":"한국어/조선말","iso_639_1":"ko","english_name":"Korean"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[{"id":155477,"name":"softcore"}],"alternative_titles":[{"type":"","title":"Mother's Friend","iso_3166_1":"US"}],"videos":[],"watch_providers":{"results":{}},"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"KR","main_poster":"/eLEqhVjleFUgxYWtgIgZ0gHdi3o.jpg","images":{"logos":[],"posters":[{"width":700,"height":990,"file_path":"/eLEqhVjleFUgxYWtgIgZ0gHdi3o.jpg","iso_639_1":"ko","vote_average":3.334},{"width":1200,"height":1800,"file_path":"/uHTE5QiHfPQLfvqgfYsgISpaqD8.jpg","iso_639_1":"ko","vote_average":1.75},{"width":689,"height":1033,"file_path":"/8RZweiIEh1w8MC1666LN20EFYwy.jpg","iso_639_1":"ko","vote_average":0},{"width":1200,"height":1800,"file_path":"/d1o0VjxSJK8eU0ReKL7pxZ21aW3.jpg","iso_639_1":null,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/4jnDdvXt9GAzePbUBMpGQ3gQtAg.jpg","iso_639_1":null,"vote_average":3.334}]},"enriched_at":"2026-02-21T11:51:17.308+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":82,"tagline":"","homepage":"","overview":"“엄마한테 이런 친구도 있었어?!”  파란만장하고 판타스틱한 대학생활을 꿈꾸던 스무살 성수. 하지만 상경하자마자 부동산 사기를 당하고 만다. 얼떨결에 엄마 손에 이끌려 엄마친구 자영의 집에 얹혀 살게 된 성수는 자영을 보는 순간 믿을 수 없는 초절정 동안과 섹시한 바디 라인에 빠져 들고 만다. 매일 마주치는 자영을 보며 그녀를 향한 은밀한 상상이 점점 도를 넘는 수준에 이르던 성수는 어느 날, 그녀가 은밀하게 숨겨온 놀랍고도 화끈한 비밀을 알게 되는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Mom's Friend","runtime":91,"tagline":"“Did Mom ever have friends like this?!”","homepage":"","overview":"Seong Soo, a twenty years old boy, decided to move to Seoul after being accepted into Seoul University. However, he was a victim of real estate scam. He then moves into his mother's friend's house. Moreover, it turns out that his mother's friend is a sexy self-employed mother and Seong Soo is attracted to her."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"妈妈的朋友","runtime":82,"tagline":"","homepage":"","overview":"男主是一个约19岁的男生，妈妈要出去然后让他寄住在朋友家里，那个女人身材很好，男生意淫，后来偶然发现女人和其他男人偷情，结果更加欲罢不能，一路跟着女人偷窥，发现女人还和一个男人在试衣间激战，上演三里屯剧情，后来，男人经不住诱惑和女人上了床。后来他发现女人任然在和其他人搞，两人就大吵了一架，分手了，男主喜欢上了别的女人。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"媽媽的朋友","runtime":0,"tagline":"","homepage":"","overview":"二十歲的成洙夢想著花哨而夢幻的大學生活。然而，他在房地產上被敲詐了，所以他媽媽把他帶到她朋友 Ja-yeong 的家裡去住。成洙看到子英的那一刻，就愛上了她的美貌和性感的身材。他開始對她產生幻想，有一天，他發現了她一直隱藏的一個秘密……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Seong Soo, een twintigjarige jongen, besloot naar Seoul te verhuizen nadat hij was toegelaten tot de universiteit van Seoul. Hij was echter het slachtoffer van vastgoedfraude. Vervolgens verhuist hij naar het huis van zijn moeders vriend. Bovendien blijkt dat de vriend van zijn moeder een sexy zelfstandige moeder is en Seong Soo voelt zich tot haar aangetrokken."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"","iso_639_1":"my","iso_3166_1":"MY","english_name":"Burmese"},{"data":{"title":"Mom's Friend","runtime":0,"tagline":"","homepage":"","overview":"Seong Soo, un tânăr de 20 de ani, decide să se mute în Seul după ce este acceptat la Universitatea din Seul. Însă, cade victimă unei escrocherii imobiliare și rămâne fără locuință. În cele din urmă, se mută în casa unei prietene a mamei sale. Lucrurile devin și mai complicate când descoperă că aceasta este o femeie atractivă și independentă, iar Seong Soo începe să se simtă atras de ea."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"}],"reviews_tmdb":[],"recommendations":[{"id":1146972,"adult":false,"title":"Mobile Suit Gundam SEED FREEDOM","video":false,"overview":"In C.E.75, the fighting still continues. There are independence movements, and aggression by Blue Cosmos... In order to calm the situation, a global peace monitoring agency called COMPASS is established, with Lacus as its first president. As members of COMPASS, Kira and his comrades intervene into various regional battles. Then a newly established nation called Foundation proposes a joint operation against a Blue Cosmos stronghold.","genre_ids":[16,878,28,18],"media_type":"movie","popularity":1.4925,"vote_count":73,"poster_path":"/1EBnttleJaKnWWyyEqfiSn76ZjT.jpg","release_date":"2024-01-26","vote_average":6.9,"backdrop_path":"/fU3oaBud5SZadw6k1ycftYedmXJ.jpg","original_title":"機動戦士ガンダムSEED FREEDOM","original_language":"ja"},{"id":390845,"adult":false,"title":"A Delicious Flight","video":false,"overview":"An innocent actress runs away from the scandal with an idol, the impudent idol that ruined her career, a passionate manager who is devoted to her and his ex-girlfriend who is now a sexy stewardess. These four that should never be together run into each other in an airplane. No one can run away and the most cheeky and erotic things happen here.","genre_ids":[10749],"media_type":"movie","popularity":3.9112,"vote_count":69,"poster_path":"/kw7QEMiIFW7EjZQSRO9ebKls21k.jpg","release_date":"2015-11-01","vote_average":4.3,"backdrop_path":"/7MXxVfzj77qA6aV3cOnj1AZnyDg.jpg","original_title":"맛있는 비행","original_language":"ko"},{"id":386720,"adult":false,"title":"Private Tutor Advanced Course","video":true,"overview":"Seong-jin, the so-called expert of theory, who learned about women through text only, feels the thrilling excitement whenever he sees his academic advisor professor, Mi-ae. However, Mi-ae keeps ignoring his courtship, telling him to come back after growing up. He felt stuck and helpless and ends up revealing his distress to Yeon-hwa, a novelist who has recently moved to his next door. To his surprise, she says she will teach him about women and begins tutoring him with the real life lessons from kissing to sex.","genre_ids":[10749],"media_type":"movie","popularity":3.5462,"vote_count":10,"poster_path":"/5DVKMj93tCFLyV2a9mQ9Jwb8WSU.jpg","release_date":"2016-02-18","vote_average":6,"backdrop_path":"/aeiNw8apGq6ULUU0a9kAceMBbYD.jpg","original_title":"개인교수: 심화학습","original_language":"ko"},{"id":473924,"adult":false,"title":"Reunion Goals: The Beginning","video":false,"overview":"Are we dating? Even if I slept with her?  Is it alright for friends to sleep with each other?  Pretending not to know, pretending to know all the flirting going around.  The flirting goes on any time and at any place!  Today with this one, tomorrow with that one and who knows who the day after...","genre_ids":[35,10749],"media_type":"movie","popularity":1.6633,"vote_count":15,"poster_path":"/sqJD8nD2zjRaENBsdcqwpJiSGXj.jpg","release_date":"2017-02-02","vote_average":6.9,"backdrop_path":"/ji6mDx6xUAEsl65AZRrW6pWKxs4.jpg","original_title":"동창회의 목적: 더 비기닝","original_language":"ko"},{"id":1047925,"adult":false,"title":"Come Out Fighting","video":false,"overview":"In WWII, a squad of U.S. African-American soldiers are sent on a rescue mission behind enemy lines to locate their lost commanding officer and a downed fighter pilot.","genre_ids":[10752,18],"media_type":"movie","popularity":1.2144,"vote_count":51,"poster_path":"/sERwJxz0sqsbcUoTm66l9pI6HcH.jpg","release_date":"2023-05-19","vote_average":4.4,"backdrop_path":"/cdEVfwkVwFeL9LuTlGHTfezso8C.jpg","original_title":"Come Out Fighting","original_language":"en"},{"id":1052158,"adult":false,"title":"Monsternado","video":false,"overview":"When a tornado full of creatures bursts through the city, a group are held at a hotel trying to figure out a way to survive!","genre_ids":[27,878],"media_type":"movie","popularity":0.5239,"vote_count":68,"poster_path":"/txA4srjcxa4HiWEaMyrNtWHbR5a.jpg","release_date":"2023-11-14","vote_average":5.691,"backdrop_path":"/vLvKc1x7bDXV5N7RnGCnZRBng3q.jpg","original_title":"Monsternado","original_language":"en"},{"id":408349,"adult":false,"title":"My Neighbor's Wife","video":false,"overview":"Yoon-jeong asks her mother to take care of her daughter and then she leaves on a secret romantic trip with a man in her neighborhood while her husband is away from home for a business trip. The man and the woman on their secret two night three day trip forget about anything about law, morals, or common sense. They follow their instinct to satisfy the desire for each other’s body all day long. The endless desire would not drive away from her body.","genre_ids":[10749,18],"media_type":"movie","popularity":2.2743,"vote_count":7,"poster_path":"/qpW0myP5nCSZbSmOS0IhMJYXVkF.jpg","release_date":"2016-07-28","vote_average":4.4,"backdrop_path":"/7IzjzI50HpcIMZ6t0ZBxLUbU8ls.jpg","original_title":"내 이웃의 아내","original_language":"ko"},{"id":83345,"adult":false,"title":"The Mosquito Net","video":false,"overview":"Maria suffers from Alzheimer's disease. Luis, Maria's fifteen-year-old grandson, doesn't say very much either; he shuts himself off in his own silent world to escape his parent's marital crisis, spending time instead picking up stray cats and dogs off the street. His father, Miguel, wants to put a stop to this eccentric behavior, but his protective mother Alice indulges him. Nevertheless, the animals begin to appear at home in increasing numbers, making life complicated for the family in their flat.","genre_ids":[18,35],"media_type":"movie","popularity":0.4011,"vote_count":17,"poster_path":"/iJn1337MVElQA7LRLEHHoOLBavn.jpg","release_date":"2010-11-04","vote_average":5.235,"backdrop_path":"/fEZQnfST0SGoeHFI0tuhbS4eeAr.jpg","original_title":"La mosquitera","original_language":"es"},{"id":372049,"adult":false,"title":"My Friend's Wife","video":false,"overview":"I want to spend all night with my friend's wife who is extremely sexy. Jeong-woo is a husband who can't get an erection while his marriage is going down the drain.  A friend and his wife from the States suggest a couples trip and Jeong-woo meets his friend's wife Hye-sook who is extremely sexy. His 'package' keeps getting stimlated every time he sees her. He tries to ignore it but every time he sees her, he gets sexual fantasies. Finally, he suggests to his friend, to 'switch' partners...","genre_ids":[10749],"media_type":"movie","popularity":0.7272,"vote_count":13,"poster_path":"/6BZKRq3bvTOuG4G01H1jcE0F5TG.jpg","release_date":"2015-12-03","vote_average":6.4,"backdrop_path":"/2lY2NutDGAmqyNdNZcDm8REmKYt.jpg","original_title":"내 친구의 아내","original_language":"ko"},{"id":1388694,"adult":false,"title":"The Calendar Killer","video":false,"overview":"Klara is going to die today unless she kills her husband instead. The Calendar Killer has given her that impossible choice. When Jules starts his night shift at a telephone safety helpline for lonely women on their way home, Klara's call reaches him. He soon becomes her last hope for survival and races against time to save her.","genre_ids":[80,53],"media_type":"movie","popularity":0.9487,"vote_count":239,"poster_path":"/bnciRmZZSdyqp7HcrAwNG0mObaP.jpg","release_date":"2025-01-15","vote_average":6.222,"backdrop_path":"/haX32ZQxOgDWcJO5sTiTUEE1Ulr.jpg","original_title":"Sebastian Fitzeks Der Heimweg","original_language":"de"},{"id":783675,"adult":false,"title":"The First Slam Dunk","video":false,"overview":"Shohoku's “speedster” and point guard, Ryota Miyagi, always plays with brains and lightning speed, running circles around his opponents while feigning composure. In his second year of high school, Ryota plays with the Shohoku High School basketball team along with Sakuragi, Rukawa, Akagi, and Mitsui as they take the stage at the Inter-High School National Championship. And now, they are on the brink of challenging the reigning champions, Sannoh Kogyo High School.","genre_ids":[16,35,18],"media_type":"movie","popularity":2.7576,"vote_count":513,"poster_path":"/7i3EBXY87HdHagCoFbmjHQ8DlkG.jpg","release_date":"2022-12-03","vote_average":7.778,"backdrop_path":"/rBgzI1a126JWA7YJd7p1NBmC61z.jpg","original_title":"THE FIRST SLAM DUNK","original_language":"ja"},{"id":758009,"adult":false,"title":"Shotgun Wedding","video":false,"overview":"Darcy and Tom gather their families for the ultimate destination wedding but when the entire party is taken hostage, “’Til Death Do Us Part” takes on a whole new meaning. Now, Darcy and Tom must save their loved ones—if they don’t kill each other first.","genre_ids":[28,35,10749],"media_type":"movie","popularity":2.1388,"vote_count":1277,"poster_path":"/t79ozwWnwekO0ADIzsFP1E5SkvR.jpg","release_date":"2022-12-28","vote_average":6.249,"backdrop_path":"/zGoZB4CboMzY1z4G3nU6BWnMDB2.jpg","original_title":"Shotgun Wedding","original_language":"en"},{"id":10192,"adult":false,"title":"Shrek Forever After","video":false,"overview":"A midlife-crisis burdened Shrek, longing for the days when he felt like a real ogre, makes a pact with magic deal-maker Rumpelstiltskin. But when he's duped and sent to a twisted version of Far Far Away—where Rumpelstiltskin is king, ogres are hunted, and he and Fiona have never met—he sets out to restore his world and reclaim his true love.","genre_ids":[35,12,14,16,10751],"media_type":"movie","popularity":8.9834,"vote_count":7816,"poster_path":"/6HrfPZtKcGmX2tUWW3cnciZTaSD.jpg","release_date":"2010-05-20","vote_average":6.394,"backdrop_path":"/uzzTystB8lL0mRDII5Sfs5HxgkI.jpg","original_title":"Shrek Forever After","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":21.4528,"vote_count":11364,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.036,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":975902,"adult":false,"title":"Boudica","video":false,"overview":"Inspired by events in A.D. 60, Boudica follows the eponymous Celtic warrior who rules the Iceni people alongside her husband Prasutagus. When he dies at the hands of Roman soldiers, Boudica’s kingdom is left without a male heir and the Romans seize her land and property.  Driven to the edge of madness and determined to avenge her husband’s death, Boudica rallies the various tribes from the region and wages an epic war against the mighty Roman empire.","genre_ids":[28,10752],"media_type":"movie","popularity":2.1853,"vote_count":175,"poster_path":"/g57hTF2TYytHMveoKDpUN8iFk1p.jpg","release_date":"2023-10-26","vote_average":5.9,"backdrop_path":"/zhaMys3Ej1KK32zb5qEOZCi06IH.jpg","original_title":"Boudica","original_language":"en"},{"id":663712,"adult":false,"title":"Terrifier 2","video":false,"overview":"A year after the Miles County massacre, Art the Clown is resurrected by a sinister entity. Art returns home, where he must hunt down and destroy teenage Sienna and her younger brother Jonathan on Halloween. As the body count rises, the siblings fight to stay alive while uncovering the true nature of Art's evil intent.","genre_ids":[27,53],"media_type":"movie","popularity":5.8083,"vote_count":2423,"poster_path":"/qEAlwXbYk6IHA4ztoS2XFFaa7Xo.jpg","release_date":"2022-10-06","vote_average":6.686,"backdrop_path":"/4QJtcL4D3abqdX6Snrk8ciRkroa.jpg","original