5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Pianist\",\"description\":\"The true story of pianist Władysław Szpilman's experiences in Warsaw during the Nazi occupation. When the Jews of the city find themselves forced into a ghetto, Szpilman finds work playing in a café; and when his family is deported in 1942, he stays behind, works for a while as a laborer, and eventually goes into hiding in the ruins of the war-torn city.\",\"image\":\"https://image.tmdb.org/t/p/w500/2hFvxCCWrTmCYwfy7yum0GKRi3Y.jpg\",\"datePublished\":\"2002-09-17\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"GB\",\"inLanguage\":\"en\",\"genre\":[\"drama film\",\"biographical film\",\"historical film\",\"musical film\",\"war film\",\"Drama\",\"War\",null,null,null,null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.375,\"bestRating\":10,\"ratingCount\":9976}}"}}],["$","$L10",null,{"initialDrama":{"id":"f9cc7e77-84f0-452b-8b1a-b6b5d05ac750","tmdb_id":423,"imdb_id":"tt0253474","content_type":"movie","title":"The Pianist","original_title":"The Pianist","overview":"The true story of pianist Władysław Szpilman's experiences in Warsaw during the Nazi occupation. When the Jews of the city find themselves forced into a ghetto, Szpilman finds work playing in a café; and when his family is deported in 1942, he stays behind, works for a while as a laborer, and eventually goes into hiding in the ruins of the war-torn city.","poster_path":"/2hFvxCCWrTmCYwfy7yum0GKRi3Y.jpg","backdrop_path":"/c0fB9xk7D1aVb3Bg2rk2SVJcGn.jpg","release_date":"2002-09-17","first_air_date":null,"status":"published","original_language":"en","origin_country":["GB"],"genres":[{"name":"drama film"},{"name":"biographical film"},{"name":"historical film"},{"name":"musical film"},{"name":"war film"},{"id":18,"name":"Drama"},{"id":10752,"name":"War"},"historical film","war film","drama film","m