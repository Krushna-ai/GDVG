5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"East Palace, West Palace\",\"description\":\"A young gay man, identified as a writer, encounters a local policeman, who arrests him for public cruising in a park. The policeman is more than professionally curious about the young man, who seems to have the cop's number and suddenly kisses him.\",\"image\":\"https://image.tmdb.org/t/p/w500/dqGtaQdEziiwbeS5Krf2JpBjGbB.jpg\",\"datePublished\":\"1996-11-11\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Drama\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.24,\"bestRating\":10,\"ratingCount\":25}}"}}],["$","$L10",null,{"initialDrama":{"id":"565ad986-62ad-43ba-ac09-ce5b50364808","tmdb_id":44322,"imdb_id":"tt0119007","content_type":"movie","title":"East Palace, West Palace","original_title":"东宫西宫","overview":"A young gay man, identified as a writer, encounters a local policeman, who arrests him for public cruising in a park. The policeman is more than professionally curious about the young man, who seems to have the cop's number and suddenly kisses him.","poster_path":"/dqGtaQdEziiwbeS5Krf2JpBjGbB.jpg","backdrop_path":"/jWIysEX3nnhCTquIBm0q5UmY9c6.jpg","release_date":"1996-11-11","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":18,"name":"Drama"}],"popularity":27.6324,"vote_average":6.24,"vote_count":25,"runtime":95,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-03T22:26:03.880533+00:00","updated_at":"2026-02-03T22:26:03.880533+00:00","tagline":"Master and servant…","homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":13413,"name":"Hubert Bals Fund","logo_path":null,"origin_country":"NL"},{"id":2588,"name":"Ministère des Affaires Étrangères","logo_path":null,"origin_country":"FR"},{"id":263048,"name":"Que