ider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"link":"https://www.themoviedb.org/movie/1562-28-weeks-later/watch?locale=US","rent":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":6},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"flatrate":[{"logo_path":"/bxBlRPEPpMVDc4jMhSrTf2339DW.jpg","provider_id":15,"provider_name":"Hulu","display_priority":8},{"logo_path":"/oTQdXIqM9iewlN4MC2nhKB0gHw.jpg","provider_id":1854,"provider_name":"AMC Plus Apple TV Channel ","display_priority":20},{"logo_path":"/2ino0WmHA4GROB7NYKzT6PGqLcb.jpg","provider_id":528,"provider_name":"AMC+ Amazon Channel","display_priority":24},{"logo_path":"/ovmu6uot1XVvsemM2dDySXLiX57.jpg","provider_id":526,"provider_name":"AMC+","display_priority":29},{"logo_path":"/ptmbGSttkyzawLbxx9MElmxKuVo.jpg","provider_id":2383,"provider_name":"Philo","display_priority":52},{"logo_path":"/vEtdiYRPRbDCp1Tcn3BEPF1Ni76.jpg","provider_id":99,"provider_name":"Shudder","display_priority":55},{"logo_path":"/qb6Lj5BhNJavdmRVDzAqAjd4Tj3.jpg","provider_id":204,"provider_name":"Shudder Amazon Channel","display_priority":84},{"logo_path":"/kLfq0I2MwiUFUY9yI1GwOeKxX8f.jpg","provider_id":2049,"provider_name":"Shudder Apple TV Channel","display_priority":187}]},"UY":{"link":"https://www.themoviedb.org/movie/1562-28-weeks-later/watch?locale=UY","flatrate":[{"logo_path":"/jbe4gVSfRlbPTdESXhEKpornsfu.jpg","provider_id":1899,"provider_name":"HBO Max","display_priority":3},{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":25}]},"VE":{"buy":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3}],"link":"https://www.themoviedb.org/movie/1562-28-weeks-later/watch?locale=VE","rent":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3}],"flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":1},{"logo_path":"/jbe4gVSfRlbPTdESXhEKpornsfu.jpg","provider_id":1899,"provider_name":"HBO Max","display_priority":27}]},"ZA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}],"link":"https://www.themoviedb.org/movie/1562-28-weeks-later/watch?locale=ZA","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}]}}},"wikidata_id":"Q221102","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-20T22:22:14.960604+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":[{"data":{"title":"","runtime":99,"tagline":"When days turn to weeks...","homepage":"","overview":"Twenty-eight weeks after the spread of a deadly rage virus, the inhabitants of the British Isles have lost their battle against the onslaught, as the virus has killed everyone there. Six months later, a group of Americans dare to set foot on the Isles, convinced the danger has passed. But it soon becomes all too clear that the scourge continues to live, waiting to pounce on its next victims."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":100,"tagline":"Und Du glaubst, Du hast schon alles gesehen?","homepage":"","overview":"Nach 28 Wochen sieht alles so aus, als sei das \"Wutvirus\", das Menschen in Zombies verwandelte, ausgestorben. Die NATO und die amerikanische Regierung wollen England neu bevölkern. Sie gründen einen Distrikt, auf drei Seiten von Wasser umgeben und damit einfacher zu überwachen, in den die Flüchtlinge unter Aufsicht des Militärs zurückgebracht werden. Darunter sind auch Andy und Tammy, die Kinder von Distriktverwalter Don Harris. Trotz strenger Militärkontrolle gelingt es den beiden Geschwistern, zu ihrem Elternhaus durchzudringen. Dort machen sie eine beängstigende Entdeckung: Ihre tot geglaubte Mutter Alice hockt völlig apathisch in einer Ecke. Sie wird in Quarantäne verfrachtet. Obwohl sie mit dem \"Rage\"-Virus infiziert ist, zeigt sie keine Anzeichen der Krankheit. Doch nach einem Zwischenfall eskaliert die Lage und das Virus wird plötzlich erneut freigesetzt. Die Militärärztin Scarlet, die Alice betreut hat, versucht Andy und Tammy zu schützen.."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"28 Semaines plus tard","runtime":96,"tagline":"Quand les jours deviennent des semaines…","homepage":"https://filmsandfestivals.britishcouncil.org/projects/28-weeks-later","overview":"Il y a 6 mois, un virus a décimé l'Angleterre, transformant la population en monstres sanguinaires. Aujourd'hui, la situation est maîtrisée et Londres contrôlée par l'armée de l'OTAN sous commandement américain, et les rares survivants reviennent dans les quartiers sécurisés de la ville. Don a échappé de justesse a une attaque de zombies en s'enfuyant sous les yeux de sa femme, qui elle, n'a pas eu sa chance. Il retrouve ses enfants à Londres. Alors qu'ils tentent de se reconstruire, quelque part, un effroyable secret les attend. Tout n'est pas terminé…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"28 týdnů poté","runtime":96,"tagline":"Vyhlazení. Znovuosídlení. Další infekce","homepage":"","overview":"Dvacet osm týdnů poté, co virus vyhubil veškerý lidský život ve Spojeném království, je ostrov prohlášen za bezpečný a lidé se začínají stěhovat zpět. Jsou ale napadeni tisíci lidí, kteří se nakazili novou verzí viru přenášenou vzduchem."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"28 settimane dopo","runtime":99,"tagline":"È il più micidiale virus che esista e sta arrivando in città...","homepage":"","overview":"La diffusione dello sconosciuto virus che rende gli esseri umani zombie dalla sorprendente falcata ha gettato morte e panico sul Regno Unito, come visto in 28 giorni dopo, e portato alla completa evacuazione dei superstiti di tutta la Gran Bretagna, messa in quarantena delle nazioni unite. 28 settimane dopo la situazione sembra essere nuovamente sotto controllo: tutti gli infetti sono stati sterminati e il rimpatrio dei primi profughi può cominciare insieme ai lavori di ricostruzione. Il ritrovamento di una donna che sembra essere immune ai devastanti effetti del virus, pur essendone portatrice, è di grande interesse per gli scienziati che studiano la natura del contagio per tentare di produrre un antidoto. Ovviamente, basterà un imprevedibile incidente a dare il via a un nuovo incubo."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"28 Hafta Sonra","runtime":0,"tagline":"Hafta Bir: İz Yok. Hafta İki: Uyarı Yok. Hafta Sekiz: Kontrol Yok. Hafra Onaltı: Tedavi Yok. Hafta Yirmisekiz: Kaçış Yok.","homepage":"","overview":"Rage virüsünün Britanya adalarına yayılmasının yarattığı kaos kontrol altına alınmış ve insanlar yavaş yavaş boşaltmak zorunda kaldıkları evlerine geri dönmeye başlamışlardır. Amerikan ordusu da Londra'nın çeşitli yerlerinde düzenin sağlanması ve insanların güvenle evlerine yeniden yerleşebilmelerini sağlamak için yardım etmektedir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"28 semanas después","runtime":96,"tagline":"...Y pasaron las semanas, y el horror volvió.","homepage":"","overview":"Seis meses después de que la propagación del virus haya aniquilado las Islas Británicas, el ejército de los Estados Unidos declara que ha ganado la guerra contra la infección y que puede comenzar la reconstrucción del país. Con la primera ola de refugiados que vuelve al país, una familia consigue reencontrarse. Pero uno de los miembros guarda un terrible secreto sin ser consciente de ello. El virus aún no ha sido destruido y en esta ocasión, es más peligroso que nunca."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":100,"tagline":"","homepage":"","overview":"Zes maanden na de uitbraak van een virus in Groot-Brittannië verklaart het Amerikaanse leger de ziekte onder controle te hebben. Hoewel een groot deel van het land nog steeds in quarantaine is, wordt Londen langzaam heropgebouwd en nemen de overlevenden opnieuw hun intrek in de stad. Maar wanneer een drager van het virus zijn weg naar de hoofdstad vindt en ziek wordt, breekt de hel opnieuw los."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"28 Εβδομάδες μετά","runtime":100,"tagline":"Όταν οι μέρες γίνονται βδομάδες, ο τρόμος επιστρέφει.","homepage":"","overview":"Στο κοντινό μέλλον, έξι μήνες μετά από το σημείο που η πρώτη ταινία μας είχε αφήσει, ο θανατηφόρος ιός έχει πλέον εξοντώσει ολόκληρη τη Βρετανία. Οι αμερικανικές στρατιωτικές δυνάμεις ανακοινώνουν ότι είναι και πάλι ασφαλές να κατοικηθεί η περιοχή κι έτσι ξεκινά ένα κύμα μετανάστευσης προς τη Μεγάλη Βρετανία. Μία οικογένεια θα ενωθεί ξανά, όμως ένα μέλος της κουβαλά ένα τρομερό μυστικό... γιατί ο φρικιαστικός ιός δεν έχει εξοντωθεί τελείως..."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"28 Semanas Depois","runtime":113,"tagline":"As suas semanas estão contadas.","homepage":"","overview":"Passaram 28 semanas desde os incidentes que causaram o caos em toda a Grã-Bretanha - um vírus infectou a sua população, transformando-os em criaturas moribundas e esfomeadas por carne humana, conhecidos por os infectados. A NATO, liderada pelos EUA, fez de tudo para extinguir o vírus e encarrega-se em repovoar o país. Mas este vê-se agora ameaçado por uma suposta infecção de uma mutação mais resistente do vírus dentro da área de reabilitação."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"28 uger senere","runtime":0,"tagline":"","homepage":"","overview":"Seks måneder efter udbruddet af den uhyggelige sygdom, der fik englænderne til at slagte hinanden, har militæret fået bugt med virussen og dens ofre. Folk begynder at vende tilbage for at genopbygge London, men desværre er virussen ikke helt væk. Faktisk er den mere end klar til at forvandle folk til sultne zombier som aldrig før."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"28 недель спустя","runtime":100,"tagline":"«Сбежать невозможно! Вирус Повсюду!»","homepage":"","overview":"Действие фильма происходит спустя шесть месяцев после того, как вирус ярости опустошил Лондон. Армия США восстановила порядок и заселяет город, который находился под карантином..."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"28 tygodni później","runtime":100,"tagline":"Nie ma ucieczki.","homepage":"","overview":"Kontynuacja znakomitego horroru \"28 Dni Później\" rozgrywa się sześć miesięcy od czasu, gdy śmiercionośny wirus całkowicie spustoszył Wielką Brytanię. Kiedy po zwycięskiej bitwie z niszczycielską siłą, amerykańska armia przywraca porządek, a zdziesiątkowane miasta zaczynają się ponownie zaludniać, przyszłość świata znów staje pod znakiem zapytania. Jeden z powracających do Londynu uchodźców skrywa bowiem w sobie śmiertelną tajemnicę, która może na zawsze odmienić losy ludzkiej rasy."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"O 28 týždňov","runtime":0,"tagline":"","homepage":"","overview":"Pol roka po biologickej katastrofe, ktorá zabila 99% obyvateľov Británie, armáda vyhlási, že boj s vírusom úspešne vyhrala, takže utečenci sa môžu vrátiť a začať s obnovou krajiny. Patrí k nim aj Don Harris so svojou ženou Alicou a dvoma deťmi, ktorí nákazu prežili. Nikto však netuší, že vírus nebol zničený úplne..."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"28 veckor senare","runtime":100,"tagline":"","homepage":"","overview":"Ett mystiskt virus har ödelagt England. De som inte smittats har evakuerats och hela landet ligger nu tomt. Ingen bor där längre, allt är dött. Amerikanarna har räknat ut att viruset även det har försvunnit och planerar att återpopulera Storbritannien. Men viruset är inte utrotat än, utan har muterat och blivit ännu farligare."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"28 שבועות אחרי","runtime":0,"tagline":"שבוע 28: ללא מוצא","homepage":"","overview":"סרט ההמשך ללהיט \"28 יום אחרי\". שישה חודשים חלפו מאז שוירוס הזעם השמיד את האי הבריטי. הצבא האמריקאי הכריז על ניצחון, חיסול הוירוס האלים ותהליך שיקום האי החל. כבר לאחר תקופה קצרה החלו לחזור הפליטים ומשפחות התאחדו שוב. אך אחד מהם נשא עימו סוד נוראי. הוירוס עדיין לא הושמד והפעם הוא מסוכן ואלים יותר מתמיד."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"28 héttel később","runtime":99,"tagline":"Megsemmisülés. Újrakezdés. Újrafertőződés.","homepage":"","overview":"Fél év telt el azóta, hogy egy vírus néptelen metropolisszá változtatta Londont. Lakóit gyilkos dühre sarkallta: a fertőzöttek egymást irtották ki. Az Egyesült Államok megszálló hadserege azóta helyreállította a rendet, szigorúan ellenőrzött és védett körzeteket hozott létre, és a kevés túlélő visszaköltözhet a városba. Közöttük van Don is a gyerekeivel. A kiskamaszok az eltűnt anyjuk után kutatnak a romok között, és meglepetésükre meg is találják. Az orvosok vizsgálni kezdik az asszonyt, hogyan maradhatott életben a fertőzött területen. Közben újra felüti fejét a járvány."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"惊变28周","runtime":0,"tagline":"","homepage":"","overview":"在恐怖的致命病毒横行28周之后，英国境内已经空无一人。由于失去了载体，病毒也随之消亡。随着一架从美国飞来的运输机的降落，在病毒爆发前就离开英国的英国人，重新踏上了被病毒肆虐半年的土地。这可以说是地球上最后的一群英国人，重建家园的重担就落在了这群平民身上。然而，重建工作才开展不久，就有人报告发现了病毒感染的幸存者。科学家们也希望能从幸存者身上提取血清研究出对付病毒的疫苗。可是，万万没有想到的是，病毒并没有像大家想象中的那样已经消亡，反而进化后变得更加强大。这英伦三岛上最后的一群人们，将面对空前的危机……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"28 недеља касније...","runtime":100,"tagline":"28 недеља касније...","homepage":"","overview":"Седам месеци након што је вирус опустошио британска острва, америчка војска објављује да је рат против вируса добијен и да реконструкција земље може да почне. У првом таласу избеглица које се враћају, породица се поново окупља - али један од њих несвесно носи страшну тајну. Вирус још увек није истребљен, а овог пута је смртоноснији но икад."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"มหาภัยเชื้อนรกถล่มเมือง","runtime":0,"tagline":"มหาภัยเชื้อนรกถล่มเมือง","homepage":"","overview":"ภาพยนตร์เรื่อง 28 WEEKS LATER หรือ มหาภัยเชื้อนรกถล่มเมือง เป็นการสานต่อจาก 28 Days Later ที่ประสบความสำเร็จอย่างล้นหลาม โดยหยิบยกเหตุการณ์ช่วง 6 เดือนหลังจากที่มหาภัยเชื้อนรกถล่มดินแดนสหราชอาณาจักร (Mainland Britain) กองทัพสหรัฐประกาศชัยชนะเหนือสงครามปราบเชื้อไวรัส และพร้อมที่จะเริ่มฟื้นฟูสภาพบ้านเมืองขึ้นมาใหม่ เมื่อผู้อพยพกลุ่มแรกเดินทางกลับมาเหยียบบ้านเกิดเมืองนอน ครอบครัวก็ได้อยู่พร้อมหน้ากันอีกครั้ง แต่มีผู้รอดชีวิตรายหนึ่งกุมความลับสยองไว้โดยที่เจ้าหล่อนเองก็ไม่รู้ตัว เชื้อนรกยังไม่ตายสิ้นซาก และเมื่อมันหวนกลับมาถล่มเมืองครั้งใหม่ ก็อันตรายยิ่งกว่าเดิมหลายเท่านัก"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"28週後...","runtime":0,"tagline":"","homepage":"","overview":"ウイルスの発生から28週後、安全宣言が出されたロンドンでは米軍を主導としたNATO軍の保護下で都市の復興が進んでいた。そして保護地区で暮らし始めたドンのもとにスペインに旅行していた子供達、タミーとアンディが帰ってくる。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"După 28 de săptămâni","runtime":99,"tagline":"","homepage":"","overview":"La mai bine de șase luni de la pandemia care aproape a distrus Marea Britanie, forțele NATO declară că virusul a fost învins."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"28주 후","runtime":100,"tagline":"일이 주로 바뀌었을 때.. 공포가 돌아온다","homepage":"","overview":"인간을 좀비로 만드는 분노 바이러스가 영국을 휩쓸고 지나간 후 6개월이 지난 시점. 미국 군대가 바이러스와의 전쟁을 선언한 뒤 마치 그들이 승리를 거둔 듯해 보인다. 그리고 점차 도시는 질서를 되찾는다. 런던을 떠났던 시민들은 점차 도시로 돌아오고, 헤어졌던 가족은 재회의 기쁨을 나눈다. 하지만, 사실 바이러스는 죽지 않았고, 사람들이 모르는 사이 다시금 도시를 초토화 시키려고 하는데.."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Extermínio 2","runtime":100,"tagline":"Quando dias viram semanas...","homepage":"","overview":"Seis meses depois de um vírus ter destruído um grande número de pessoas na Grã-Betanha, o exército americano declara que o perigo já passou e começa a reconstrução da cidade. Os refugiados retornam, mas um deles carrega um segredo mortal. O vírus não está morto e agora está mais perigoso."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"28 Viikkoa Myöhemmin","runtime":0,"tagline":"Täydellinen tuho. Uudelleenasutus. Uusi epidemia.","homepage":"","overview":"Kauhu ja tuho, joka levisi elokuvassa 28 päivää myöhemmin jatkuu. Kuusi kuukautta sen jälkeen kun virus harvensi Lontoon asukasluvun olemattomiin. Järjestys on palautettu ja epidemia kukistettu. Yhdysvaltain armeija auttaa kotiuttamaan pakolaiset kotimaahansa ja asuttamaan saarivaltion uudelleen. Yksi siirtolaisista kantaa hirvittävää salaisuutta, joka uhkaa laukaista kuolemaa kylvävän, verenjanoisen epidemian uudelleen."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"28 тижнів по тому","runtime":100,"tagline":"Коли дні перетворюються на тижні… жах повертається.","homepage":"","overview":"Дія фільму відбувається через шість місяців після того, як вірус люті спустошив Лондон. Армія США відновила порядок і заселяє місто, яке перебувало під карантином…"},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"28週毀滅倒數：全球封閉","runtime":0,"tagline":"","homepage":"","overview":"發生重大病毒感染宛若死城的英國，全國人口僅剩500人。六個月後，美國軍隊宣稱情況已經控制，感染不會再蔓延，並開始展開重建、復原的工作。第一波之前逃難的民眾回來，其中兩個孩子在西班牙度假逃過劫難的唐恩一家人又再度重逢。然而，重逢回歸的家庭成員中，有個未被察覺的祕密…病毒尚未完全撲滅。眼看更大規模的災難即將爆發，此時美軍強勢並動用高單位火力嚴防疫區暴動…面對新世界更為嚴苛的生存法則，唐恩一家人發誓要平安活下來。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"28 uker senere","runtime":100,"tagline":"","homepage":"","overview":"28 uker senere, oppfølgeren til den enormt populære 28 dager senere, plukker opp tråden seks måneder etter at det forferdelige viruset har utslettet alt normalt liv på det britiske fastlandet. Den amerikanske hæren erklærer kampen mot smitten for vunnet og at gjenoppbyggingen av landet kan starte. Når den første strømmen av flyktninger vender tilbake, blir en familie gjenforent - men en av dem bærer uten å vite det på en fryktelig hemmelighet. Viruset er ikke ødelagt, og denne gangen er det farligere enn noensinne."},"name":"Bokmål","iso_639_1":"nb","iso_3166_1":"NO","english_name":"Norwegian Bokmål"},{"data":{"title":"28 седмици по-късно","runtime":91,"tagline":"","homepage":"","overview":"Редът е възстановен и войната срещу заразата изглежда спечелена. Американската армия е поела контрола върху завръщането на бежанците в островната държава. Но един от тях носи със себе си ужасяваща тайна, която заплашва да разпали нова смъртоносна експлозия от хаос и кръвопролития."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"28 uker senere","runtime":100,"tagline":"","homepage":"","overview":"28 uker senere, oppfølgeren til den enormt populære 28 dager senere, plukker opp tråden seks måneder etter at det forferdelige viruset har utslettet alt normalt liv på det britiske fastlandet. Den amerikanske hæren erklærer kampen mot smitten for vunnet og at gjenoppbyggingen av landet kan starte. Når den første strømmen av flyktninger vender tilbake, blir en familie gjenforent - men en av dem bærer uten å vite det på en fryktelig hemmelighet. Viruset er ikke ødelagt, og denne gangen er det farligere enn noensinne."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"28 semaines plus tard","runtime":100,"tagline":"Lorsque les jours se transforment en semaines... l'horreur revient.","homepage":"","overview":"Dans cette frissonnante suite de 28 jours plus tard, les habitants des îles britanniques semblent avoir perdu le combat contre la maladie, le virus meurtrier de la rage ayant tué tous les résidents. Six mois plus tard, un groupe d'américains ose mettre le pied sur l'île, convaincus que le danger est écarté. Mais de toute évidence, le fléaux n'est qu'endormi en attendant ses prochaines victimes..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Exterminio 2","runtime":101,"tagline":"Y pasaron las semanas, y el horror volvió.","homepage":"","overview":"Seis meses después de que el virus de la rabia fuera infligido a la población de Gran Bretaña, el ejército de los EE.UU. ayuda a asegurar una pequeña área de Londres para que los sobrevivientes se repoblen y comiencen de nuevo. Pero no todo va de acuerdo al plan."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"28 Tuần Sau","runtime":0,"tagline":"","homepage":"","overview":"28 tuần đã trôi qua kể từ ngày xảy ra sự kiện virus lan tràn khắp nước Anh, quật ngã những người dân đảo sương mù và biến họ thành những xác chết khát máu, dưới sự giúp sức mạnh mẽ từ quân đội Mỹ, giới cầm quyền Anh thở phào nhẹ nhõm tuyên bố nạn dịch đã được kiểm soát và tiêu diệt, người dân lại có thể trở về mái nhà của họ sau những tháng ngày khủng khiếp khi để sống sót họ phải giết ngay chính những người thân yêu của mình và cả việc che giấu mầm bệnh virus vẫn còn đang phát triển và biến đổi mạnh mẽ hơn trong cơ thể họ..."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"28 週後","runtime":100,"tagline":"","homepage":"","overview":"28 週後，英國政府在美國軍方協助下，「成功」將病毒消滅，並開始重建倫敦，這是噩夢的終結還是開始？首批倖存下來的災民，開始遷入隔離區，一個個破碎的家庭亦隨之團圓。沒想到艱辛的重建工作，卻因為一位病毒帶菌者的硬闖而令全國人民的性命再次危在旦夕！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"28 კვირის შემდეგ","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"28 savaitės po...","runtime":0,"tagline":"","homepage":"","overview":"Originaliame, pirmajame filme „28 dienos po...“ Didžiosios Britanijos sostinėje siautėja galingas virusas. Jo plitimui pakanka menkiausio kraujo lašelio, o virusas pasireiškia žiauria neapykanta visiems, kas dar neinfekuoti. Per keturias savaites Londonas iš klestinčio miesto pavirsta išprotėjusių žmonių nusiaubta dykyne. Likę sveikieji apsisprendžia palikti namus ir mažomis grupelėmis pabėga iš viruso karalyste tapusios sostinės.  Naujoje juostoje „28 savaitės po...“ vaizduojami įvykiai prasideda praėjus maždaug septyniems mėnesiams po pirmojo filmo istorijos. Jungtinės Valstijos paskelbia, jog nugalėjo virusą, o didžiulė Amerikos karių ir medikų grupė imasi užduoties sugrąžinti gyvenimą į Didžiosios Britanijos sostinę.  Tikėdamiesi vėl gyventi normalų gyvenimą, į Londoną ima grįžti pabėgėliai. Tačiau niekas nežino, kad vieno iš sugrįžtančiųjų organizme tūno mutavęs virusas. Dar galingesnis, dar klastingesnis ir pragaištingesnis. Londono gatvėse užverda tikras pragaras..."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"28 tjedana poslije","runtime":0,"tagline":"Zastrašujući virus koji ljude pretvara u zombije ponovo hara Velikom Britanijom","homepage":"","overview":"Nedaleko Londona, Don (Robert Carlyle) se sa svojom ženom Alice (Catherine McCormack) i nekolicinom preživjelih skriva na farmi. Kada ljudi zaraženi smrtonosnim virusom provale u kuću, Don se uspaniči te u bijegu zaboravi na suprugu koja ostane zarobljena u kući. Dvadeset i osam tjedana nakon pojave virusa koji je izbrisao gotovo čitavu populaciju Velike Britanije, London se čini siguran pa uz pomoć američke vojske preživjeli stanovnici polako naseljavaju grad. Tammy (Imogen Poots) i njen mlađi brat Andy vraćaju se iz Španjolske kako bi nastavili živjeti u Londonu zajedno s ocem Donom. Majka Alice im nedostaje pa se odluče vratiti na farmu kako bi uzeli stare slike i osobne stvari koje su morali ostaviti za sobom. Međutim, majku pronalaze živu."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"28 nedēļas vēlāk","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"28 nädalat hiljem","runtime":0,"tagline":"Kui päevadest saavad nädalad... õudus tuleb tagasi.","homepage":"","overview":"Kuus kuud peale tapva \"raevuviiruse\" levikut annab USA armee teada, et olukord on saadud kontrolli alla ja edasine oht puudub. Inimesi hakatakse tagasi Londonisse laskma, kuid peagi selgub, et linna on pääsenud ka keegi nakatunu. Tuleb välja, et viirus elab edasi, olles tapvam kui kunagi varem."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"28 tednov pozneje","runtime":0,"tagline":"","homepage":"","overview":"28 tednov pozneje je nadaljevanje strahovito uspešnih 28 dni pozneje. Začne se šest mesecev po tem, ko je smrtonosni virus besa kosil po osrednji Veliki Britaniji. Ameriška vojska razglasi, da je dobila vojno proti okužbi in da se obnova države lahko začne. Ob vrnitvi prvega vala beguncev se snide tudi ena družina – ampak eden od članov nevede nosi s seboj grozljivo skrivnost. Virus še ni mrtev, je nevarnejši kot kdajkoli."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"28 أسبوعا لاحقا","runtime":0,"tagline":"عندما تتحول الأيام إلى أسابيع... يعود الرعب من جديد.","homepage":"","overview":"لقد خسر سكان الجزر البريطانية معركتهم ضد هجوم المرض الفتاك، حيث قضى فيروس الغضب القاتل على كل مواطن هناك. وبعد ستة أشهر، تجرؤ مجموعة من الأمريكيين على وطء أرض الجزر، مقتنعين بأن الخطر قد زال. لكن سرعان ما يتضح لهم بشكل مؤلم أن الوباء لا يزال حياً، ينتظر بفارغ الصبر ضحاياه القادمين."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"28 Weeks Later","runtime":100,"tagline":"","homepage":"","overview":"Nach 28 Wochen sieht alles so aus, als sei das \"Wutvirus\", das Menschen in Zombies verwandelte, ausgestorben. Die NATO und die amerikanische Regierung wollen England neu bevölkern. Sie gründen einen Distrikt, auf drei Seiten von Wasser umgeben und damit einfacher zu überwachen, in den die Flüchtlinge unter Aufsicht des Militärs zurückgebracht werden. Darunter sind auch Andy und Tammy, die Kinder von Distriktverwalter Don Harris. Trotz strenger Militärkontrolle gelingt es den beiden Geschwistern, zu ihrem Elternhaus durchzudringen. Dort machen sie eine beängstigende Entdeckung: Ihre tot geglaubte Mutter Alice hockt völlig apathisch in einer Ecke. Sie wird in Quarantäne verfrachtet. Obwohl sie mit dem \"Rage\"-Virus infiziert ist, zeigt sie keine Anzeichen der Krankheit. Doch nach einem Zwischenfall eskaliert die Lage und das Virus wird plötzlich erneut freigesetzt. Die Militärärztin Scarlet, die Alice betreut hat, versucht Andy und Tammy zu schützen.."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"28 setmanes després","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"}],"reviews_tmdb":[{"id":"54d554879251416ba10001e7","url":"https://www.themoviedb.org/review/54d554879251416ba10001e7","author":"Andres Gomez","content":"Much worse than the original. It loses quite of the continuous tension. Many of the FX are bad quality. The script is really predictable and some scenes and conversations are too much of a cliche.","created_at":"2015-02-06T23:55:51.570Z","updated_at":"2021-06-23T15:57:32.055Z","author_details":{"name":"Andres Gomez","rating":4,"username":"tanty","avatar_path":null}},{"id":"57912ec8c3a36835700018d6","url":"https://www.themoviedb.org/review/57912ec8c3a36835700018d6","author":"talisencrw","content":"$11","created_at":"2016-07-21T20:21:28.546Z","updated_at":"2021-06-23T15:57:49.469Z","author_details":{"name":"","rating":8,"username":"talisencrw","avatar_path":null}},{"id":"5d9dab494772150041039029","url":"https://www.themoviedb.org/review/5d9dab494772150041039029","author":"John Chard","content":"$12","created_at":"2019-10-09T09:41:29.021Z","updated_at":"2024-05-16T15:22:25.437Z","author_details":{"name":"","rating":8,"username":"John Chard","avatar_path":"/utEXl2EDiXBK6f41wCLsvprvMg4.jpg"}},{"id":"5e06efa6eda4b700122b1c32","url":"https://www.themoviedb.org/review/5e06efa6eda4b700122b1c32","author":"Gimly","content":"The story is not quite up to snuff in comparison to _Days_, but the visual quality is **way** better. \r\n\r\n_Final rating:★★★½ - I really liked it. Would strongly recommend you give it your time._","created_at":"2019-12-28T06:01:10.325Z","updated_at":"2021-06-23T15:58:30.704Z","author_details":{"name":"Gimly","rating":7,"username":"Ruuz","avatar_path":"/xUObnJSvHrFPsIpoDmb1jiQZLq7.jpg"}},{"id":"640b2da741a5610113bd270c","url":"https://www.themoviedb.org/review/640b2da741a5610113bd270c","author":"Ricardo Oliveira","content":"$13","created_at":"2023-03-10T13:16:23.758Z","updated_at":"2023-03-10T13:16:23.839Z","author_details":{"name":"Ricardo Oliveira","rating":7,"username":"RSOliveira","avatar_path":"/23Cl7rhsknc7IIAcZZAGKzovjTu.jpg"}},{"id":"686728b1043445884c6771c1","url":"https://www.themoviedb.org/review/686728b1043445884c6771c1","author":"r96sk","content":"<em>'28 Weeks Later'</em> is passable in its own right for the majority, though the way it all concludes did disappoint me. I didn't care for the end all that much, which does damage how I view this unfortunately. Overall it fails to match the original, though does still offer OK post-apocalypse fare.\r\n\r\nIt is pretty strong in regards to the cast list, which is probably the only area that this can claim that it matches the predecessor (even if I prefer the 2002 cast, obvs). Rose Byrne, Jeremy Renner and Idris Elba were people I was happy to see appear, while Robert Carlyle & Co. are solid.\r\n\r\nThe locations aren't as cool or convincing as last time out, though the effects for the infected are satisfactory. I can appreciate the idea that they had with this sequel, for the most part I was content with what I was watching. However, by the credits, it left me underwhelmed.","created_at":"2025-07-04T01:04:49.147Z","updated_at":"2025-07-04T01:04:49.256Z","author_details":{"name":"","rating":6,"username":"r96sk","avatar_path":"/mwR7rFHoDcobAx1i61I3skzMW3U.jpg"}}],"recommendations":[{"id":170,"adult":false,"title":"28 Days Later","video":false,"overview":"Twenty-eight days after a killer virus was accidentally unleashed from a British research facility, a small group of London survivors are caught in a desperate struggle to protect themselves from the infected. Carried by animals and humans, the virus turns those it infects into homicidal maniacs -- and it's absolutely impossible to contain.","genre_ids":[27,53,878],"media_type":"movie","popularity":16.3382,"vote_count":8232,"poster_path":"/sQckQRt17VaWbo39GIu0TMOiszq.jpg","release_date":"2002-10-31","vote_average":7.2,"backdrop_path":"/aJFwk1clMal1prxAvKAgHxKPAf.jpg","original_title":"28 Days Later","original_language":"en"},{"id":1100988,"adult":false,"title":"28 Years Later","video":false,"overview":"Twenty-eight years after the Rage virus outbreak, Britain remains sealed off from the world. A fortified island community survives in isolation—until a young boy’s journey to the mainland reveals how both the infected and the survivors have evolved.","genre_ids":[27,53,878],"media_type":"movie","popularity":26.7281,"vote_count":2228,"poster_path":"/n5FygjEppOvac6yEaowi26nTyw3.jpg","release_date":"2025-06-18","vote_average":6.614,"backdrop_path":"/6WqqEjiycNvDLjbEClM1zCwIbDD.jpg","original_title":"28 Years Later","original_language":"en"},{"id":4513,"adult":false,"title":"30 Days of Night","video":false,"overview":"This is the story of an isolated Alaskan town that is plunged into darkness for a month each year when the sun sinks below the horizon. As the last rays of light fade, the town is attacked by a bloodthirsty gang of vampires bent on an uninterrupted orgy of destruction. Only the small town's husband-and-wife Sheriff team stand between the survivors and certain destruction.","genre_ids":[27,53],"media_type":"movie","popularity":4.4955,"vote_count":2993,"poster_path":"/7LwSrvFA0gz1KAlcrGcinoQPene.jpg","release_date":"2007-10-17","vote_average":6.431,"backdrop_path":"/w8VDpCcKezdBbXJEWMHwttI35mU.jpg","original_title":"30 Days of Night","original_language":"en"},{"id":8329,"adult":false,"title":"[REC]","video":false,"overview":"A television reporter and cameraman follow emergency workers into a dark apartment building and are quickly locked inside with something terrifying.","genre_ids":[27,9648],"media_type":"movie","popularity":4.1738,"vote_count":4760,"poster_path":"/hgyJR4sgMsee6xMFM3xYiG6cDCh.jpg","release_date":"2007-11-23","vote_average":7.223,"backdrop_path":"/xfrguTH6maYiGsC8FXiQ9N3lZXw.jpg","original_title":"[REC]","original_language":"es"},{"id":924,"adult":false,"title":"Dawn of the Dead","video":false,"overview":"A group of survivors take refuge in a shopping mall after the world is taken over by aggressive, flesh-eating zombies.","genre_ids":[27,28],"media_type":"movie","popularity":8.2173,"vote_count":4359,"poster_path":"/ttquyxStEEctzghtA2f4PUGprDr.jpg","release_date":"2004-03-19","vote_average":7.051,"backdrop_path":"/rspbS1E9wJtslrb8amfJgtMBUVh.jpg","original_title":"Dawn of the Dead","original_language":"en"},{"id":375366,"adult":false,"title":"The Girl with All the Gifts","video":false,"overview":"In the future, a strange fungus has changed nearly everyone into thoughtless, flesh-eating monsters. When a scientist and a teacher find a girl who seems to be immune to the fungus, they all begin a journey to save humanity.","genre_ids":[28,27,878],"media_type":"movie","popularity":3.4844,"vote_count":2114,"poster_path":"/vdCD8z55a4RNmHQDPIpuMFqoY2B.jpg","release_date":"2016-09-23","vote_average":6.57,"backdrop_path":"/rrAMFTuTFHYI6INtyPnOYyoGTO2.jpg","original_title":"The Girl with All the Gifts","original_language":"en"},{"id":19908,"adult":false,"title":"Zombieland","video":false,"overview":"Columbus has made a habit of running from what scares him. Tallahassee doesn't have fears. If he did, he'd kick their ever-living ass. In a world overrun by zombies, these two are perfectly evolved survivors. But now, they're about to stare down the most terrifying prospect of all: each other.","genre_ids":[35,27],"media_type":"movie","popularity":7.8819,"vote_count":12955,"poster_path":"/dUkAmAyPVqubSBNRjRqCgHggZcK.jpg","release_date":"2009-10-02","vote_average":7.26,"backdrop_path":"/oihWVx3imvRKujnGmSDYhfG1gI5.jpg","original_title":"Zombieland","original_language":"en"},{"id":82654,"adult":false,"title":"Warm Bodies","video":false,"overview":"After a zombie becomes involved with the girlfriend of one of his victims, their romance sets in motion a sequence of events that might transform the entire lifeless world.","genre_ids":[27,35,10749],"media_type":"movie","popularity":3.826,"vote_count":6306,"poster_path":"/i8vCO3uszvlfBJVEyuIZVUDlt60.jpg","release_date":"2013-01-31","vote_average":6.467,"backdrop_path":"/iNl1i8OJAaCf3ElkOPI9ud6CuXB.jpg","original_title":"Warm Bodies","original_language":"en"},{"id":9793,"adult":false,"title":"The Hills Have Eyes 2","video":false,"overview":"A group of National Guard trainees on a routine mission find themselves up against cannibalistic mutants in the New Mexico desert.","genre_ids":[27,53],"media_type":"movie","popularity":2.7036,"vote_count":1574,"poster_path":"/3SX2UGSmAjIZsVACpshPpKtjbDr.jpg","release_date":"2007-03-22","vote_average":5.571,"backdrop_path":"/9V529yHwmYay2wmYo0YcgUijeJO.jpg","original_title":"The Hills Have Eyes 2","original_language":"en"},{"id":313922,"adult":false,"title":"Green Room","video":false,"overview":"A punk rock band is forced to fight for survival after witnessing an act of violence at a skinhead bar.","genre_ids":[27,80,53],"media_type":"movie","popularity":3.197,"vote_count":2883,"poster_path":"/evZicaR7nXe4LiD9G6QYTorcJGO.jpg","release_date":"2016-04-15","vote_average":6.721,"backdrop_path":"/qRjahAq8JVoJBT2x18x2A01kxZT.jpg","original_title":"Green Room","original_language":"en"},{"id":9427,"adult":false,"title":"The Full Monty","video":false,"overview":"Sheffield, England. Gaz, a jobless steelworker in need of quick cash persuades his mates to bare it all in a one-night-only strip show.","genre_ids":[35],"media_type":"movie","popularity":2.9121,"vote_count":1757,"poster_path":"/xkMiZv2FPrhIAtxvEcN1jAbkHRY.jpg","release_date":"1997-08-13","vote_average":6.99,"backdrop_path":"/r8SwFiCeaADf0jIotMMtfNBzLEI.jpg","original_title":"The Full Monty","original_language":"en"},{"id":1683,"adult":false,"title":"The Reaping","video":false,"overview":"Katherine Morrissey, a former Christian missionary, lost her faith after the tragic deaths of her family. Now she applies her expertise to debunking religious phenomena. When a series of biblical plagues overrun a small town, Katherine arrives to prove that a supernatural force is not behind the occurrences, but soon finds that science cannot explain what is happening. Instead, she must regain her faith to combat the evil that waits in a Louisiana swamp.","genre_ids":[27],"media_type":"movie","popularity":1.8339,"vote_count":877,"poster_path":"/o8Vl4Vxp5LBth9J6Aa3k6PAefxt.jpg","release_date":"2007-04-04","vote_average":5.7,"backdrop_path":"/4eakTJuJD3sRGfv1qVWW46iPq82.jpg","original_title":"The Reaping","original_language":"en"},{"id":1212121,"adult":false,"title":"Latin Blood – The Ballad of Ney Matogrosso","video":false,"overview":"From a repressive childhood to artistic revolution, Ney Matogrosso transforms Brazil's stages — and himself — through music, creativity and inner fire.","genre_ids":[18,10402],"media_type":"movie","popularity":0.8992,"vote_count":132,"poster_path":"/uk2g9LNwSHEsDjwTEBLNb38kcRM.jpg","release_date":"2025-05-01","vote_average":8.125,"backdrop_path":"/38byjV1A8WpA05xiXl0AXZCnCfv.jpg","original_title":"Homem com H","original_language":"pt"},{"id":10856,"adult":false,"title":"Intacto","video":false,"overview":"An enigmatic tale of four people whose lives are intertwined by destiny are subject to the laws of fate. They discover that luck is something they cannot afford to be without as they gamble with the highest stakes possible in a deadly game from which only one of them will emerge intact.","genre_ids":[28,35,18,10749,878,53],"media_type":"movie","popularity":3.4742,"vote_count":196,"poster_path":"/gAe6KmVojjHLmdhPZhYDMTmaiM1.jpg","release_date":"2001-11-06","vote_average":6.6,"backdrop_path":"/orCqFI2ROrtr1ajUTIolzMmQiqP.jpg","original_title":"Intacto","original_language":"es"},{"id":1288998,"adult":false,"title":"1978","video":false,"overview":"During the World Cup final between Argentina and Holland, in times of military dictatorship, a group of torturers kidnap a group of young people. What begins as an inhumane interrogation turns into hell: the wrong group has been kidnapped.","genre_ids":[27,53,18],"media_type":"movie","popularity":1.5753,"vote_count":51,"poster_path":"/3LJuaTyiXUC5KHwixNKh3dgQNO6.jpg","release_date":"2025-03-06","vote_average":5.765,"backdrop_path":"/z7eV3zAAfQ4XVyKd61ymywZaSB3.jpg","original_title":"1978","original_language":"es"},{"id":14451,"adult":false,"title":"Dead Snow","video":false,"overview":"Eight medical students on a ski trip to Norway discover that Hitler's horrors live on when they come face to face with a battalion of zombie Nazi soldiers intent on devouring anyone unfortunate enough to wander into the remote mountains where they were once sent to die.","genre_ids":[27,35],"media_type":"movie","popularity":4.395,"vote_count":1203,"poster_path":"/sfwVo5cZJtO8VyDWTILDt4f69IT.jpg","release_date":"2009-01-09","vote_average":5.979,"backdrop_path":"/vz8H0z12dWoN8pzwIh6IwcpolP.jpg","original_title":"Død snø","original_language":"no"},{"id":12154,"adult":false,"title":"3 Men and a Baby","video":false,"overview":"Three bachelors find themselves forced to take care of a baby left by one of the guy's girlfriends.","genre_ids":[35],"media_type":"movie","popularity":1.9691,"vote_count":1065,"poster_path":"/oYetboAljWR2N5A7MU3i63DvUtd.jpg","release_date":"1987-11-27","vote_average":6.2,"backdrop_path":"/rVp4XrInBkLC37n64nk5g5Wpf7F.jpg","original_title":"3 Men and a Baby","original_language":"en"},{"id":1272,"adult":false,"title":"Sunshine","video":false,"overview":"Fifty years into the future, the sun is dying, and Earth is threatened by arctic temperatures. A team of astronauts is sent to revive the Sun — but the mission fails. Seven years later, a new team is sent to finish the mission as mankind’s last hope.","genre_ids":[878,53],"media_type":"movie","popularity":6.025,"vote_count":4133,"poster_path":"/oKGGeJ8qvm0UmClz43VJ31fzPP7.jpg","release_date":"2007-04-05","vote_average":6.963,"backdrop_path":"/5AIAnucJKZ3sHpm7r1ykFVIoUHK.jpg","original_title":"Sunshine","original_language":"en"},{"id":1992,"adult":false,"title":"Planet Terror","video":false,"overview":"Two doctors find their graveyard shift inundated with townspeople ravaged by sores. Among the wounded is Cherry Darling, a dancer whose leg was ripped from her body. As the invalids quickly become enraged aggressors, Cherry and her ex-boyfriend El Wray lead a team of accidental warriors into the night.","genre_ids":[27,28,53],"media_type":"movie","popularity":4.6917,"vote_count":3745,"poster_path":"/3705GxG0RN9XDV5y9IiXKYHw1fK.jpg","release_date":"2007-04-06","vote_average":6.685,"backdrop_path":"/iZBUOcku0xv9MMfiEMXiDqErPXl.jpg","original_title":"Planet Terror","original_language":"en"},{"id":24684,"adult":false,"title":"An Education","video":false,"overview":"Despite her sheltered upbringing, Jenny is a teen with a bright future; she's smart, pretty, and has aspirations of attending Oxford University. When David, a charming but much older suitor, motors into her life in a shiny automobile, Jenny gets a taste of adult life that she won't soon forget.","genre_ids":[18,10749],"media_type":"movie","popularity":1.6982,"vote_count":1401,"poster_path":"/gLIvvUdlocGjm8XVLxhWHAKWrRq.jpg","release_date":"2009-10-29","vote_average":6.946,"backdrop_path":"/9Cw5fOWLfHwFHjg88dC5oBZEmL4.jpg","original_title":"An Education","original_language":"en"}],"similar_content":[{"id":425827,"adult":false,"title":"The Last Scout","video":false,"overview":"In 2065, the crew of the Pegasus are searching for a new home for humanity. As they approach their potential new world, the discovery of another ship could be the key to their salvation, or doom them and the rest of humanity to extinction.","genre_ids":[878],"popularity":0.3339,"vote_count":44,"poster_path":"/kTS91njoMALTZh2nckLPr4y8GDa.jpg","release_date":"2017-07-17","vote_average":4.1,"backdrop_path":"/kqXtVGK7orcIupD3ydYPcjjy6Sr.jpg","original_title":"The Last Scout","original_language":"en"},{"id":425875,"adult":false,"title":"Kuşku","video":false,"overview":"A story about a tourist guide and a young girl whose father and mother were killed.","genre_ids":[27,12],"popularity":0.7783,"vote_count":0,"poster_path":"/7yfENIZoq9luEyyqElbzGovTQgZ.jpg","release_date":"1977-01-02","vote_average":0,"backdrop_path":null,"original_title":"Kuşku","original_language":"tr"},{"id":425935,"adult":false,"title":"Asylum of Darkness","video":false,"overview":"Mental patient Dwight Stroud escapes from an asylum and is mistaken for a motivational speaker named Artemis Finch who has money and women at his command. Dwight accepts the craziness of the situation, but as strange faceless figures begin to hunt him down, Dwight must deal with an escalating spiral of supernatural danger and hallucinations.","genre_ids":[27],"popularity":0.264,"vote_count":6,"poster_path":"/cBBHOgFctUv8wEvzm1aNSueJ34b.jpg","release_date":"2012-11-07","vote_average":4.8,"backdrop_path":"/bTxMyyFylE63HotajkQgi6dUqVs.jpg","original_title":"Asylum of Darkness","original_language":"en"},{"id":8810,"adult":false,"title":"Mad Max 2","video":false,"overview":"Max Rockatansky returns as the heroic loner who drives the dusty roads of a postapocalyptic Australian Outback in an unending search for gasoline. Arrayed against him and the other scraggly defendants of a fuel-depot encampment are the bizarre warriors commanded by the charismatic Lord Humungus, a violent leader whose scruples are as barren as the surrounding landscape.","genre_ids":[12,28,53,878],"popularity":6.8878,"vote_count":4075,"poster_path":"/l1KVEhkGDpWRzQ0VqIhZqDDuOim.jpg","release_date":"1981-12-24","vote_average":7.386,"backdrop_path":"/MMSI9WzRmOdqXarevQ3Kqnytrx.jpg","original_title":"Mad Max 2","original_language":"en"},{"id":8838,"adult":false,"title":"Mercury Rising","video":false,"overview":"Renegade FBI agent Art Jeffries protects a nine-year-old autistic boy who has cracked the government's new \"unbreakable\" code.","genre_ids":[28,80,18,53],"popularity":2.0619,"vote_count":1622,"poster_path":"/uB8qfwqvJA2adiVOwsN5clZS4Lo.jpg","release_date":"1998-04-03","vote_average":6.287,"backdrop_path":"/5EkowLSlfQT50KbeHzhvbdyaIoI.jpg","original_title":"Mercury Rising","original_language":"en"},{"id":8848,"adult":false,"title":"The Bank Job","video":false,"overview":"Terry is a small-time car dealer trying to leave his shady past behind and start a family. Martine is a beautiful model from Terry's old neighbourhood who knows that Terry is no angel. When Martine proposes a foolproof plan to rob a bank, Terry recognises the danger but realises this may be the opportunity of a lifetime.","genre_ids":[53,80,18],"popularity":4.975,"vote_count":2527,"poster_path":"/bfXjFTytfFTdo9WeO7lYqzkHG7g.jpg","release_date":"2008-02-28","vote_average":6.838,"backdrop_path":"/pqoYtQsD8xwKFB5FrJQAB5e7hg5.jpg","original_title":"The Bank Job","original_language":"en"},{"id":8867,"adult":false,"title":"The Punisher","video":false,"overview":"The avenging angel of Marvel Comics fame comes brilliantly to life in this searing action-adventure thriller! Dolph Lundgren stars as Frank Castle, a veteran cop who loses his entire family to a mafia car bomb. His ex-partner believes Castle survived the blast and became the Punisher, living in the sewers and exacting vigilante violence against mob bosses throughout the city. When the populace is caught in the midst of a gang war that he caused, Castle must again emerge from the shadows and save the innocent.","genre_ids":[28,80,18,53],"popularity":2.3945,"vote_count":653,"poster_path":"/tA0O0hYyHX7Hl2Fl8VEtGtfBtjI.jpg","release_date":"1989-10-05","vote_average":5.768,"backdrop_path":"/tFmrdnfXM0p6ihMTFpptYOKEfSl.jpg","original_title":"The Punisher","original_language":"en"},{"id":8884,"adult":false,"title":"Franklyn","video":false,"overview":"Set between the parallel worlds of contemporary London and the futuristic faith dominated metropolis of Meanwhile City, Franklyn weaves a tale of four souls, whose lives are intertwined by fate, romance and tragedy. As these worlds collide, a single bullet determines the destiny of these four characters.","genre_ids":[14,53,18],"popularity":1.355,"vote_count":382,"poster_path":"/5yns10om8I19j4OHy1zoVRilAnw.jpg","release_date":"2008-10-16","vote_average":6,"backdrop_path":"/6hQgTpZVNHrLafE6IeSAoThQwkH.jpg","original_title":"Franklyn","original_language":"en"},{"id":8913,"adult":false,"title":"Pet Sematary","video":false,"overview":"After the Creed family's cat is accidentally killed, a friendly neighbor advises its burial in a mysterious nearby cemetery.","genre_ids":[27],"popularity":5.0974,"vote_count":2337,"poster_path":"/a1gIACZb04bL8EvLqMpofW2Eqeo.jpg","release_date":"1989-04-21","vote_average":6.639,"backdrop_path":"/xWq3T9P4NU2pTdZ3hXFygsNnAq4.jpg","original_title":"Pet Sematary","original_language":"en"},{"id":8461,"adult":false,"title":"Funny Games","video":false,"overview":"When Ann, husband George, and son Georgie arrive at their holiday home they are visited by a pair of polite and seemingly pleasant young men. Armed with deceptively sweet smiles and some golf clubs, they proceed to terrorize and torture the tight-knit clan, giving them until the next day to survive.","genre_ids":[53,27],"popularity":5.6802,"vote_count":2212,"poster_path":"/zs92sAOh3Q0kDIJkgaJFTBzSFka.jpg","release_date":"2008-03-14","vote_average":6.554,"backdrop_path":"/6P4R7kYUdJprHpyBmOQO6aB85xX.jpg","original_title":"Funny Games","original_language":"en"},{"id":8471,"adult":false,"title":"Far North","video":false,"overview":"In the arctic, as Saiva is being born, a shaman declares that she is evil and will bring harm to all who become involved with her. Saiva is cast out of her tribe of herders and grows up to live a nomadic existence with Anja, a young woman she adopts as an infant. Then Loki, an injured and starving soldier, stumbles into their isolated lives. The women nurse him back to health, but treachery, violence and doom await them all.","genre_ids":[18,53,10749,80],"popularity":1.0588,"vote_count":56,"poster_path":"/d31sugp9MHWv7YHGxgM5iYQVmXB.jpg","release_date":"2008-10-09","vote_average":5.991,"backdrop_path":"/rOzQTb1CWIiRlDk8ILMULOSuktG.jpg","original_title":"Far North","original_language":"en"},{"id":8555,"adult":false,"title":"Creep","video":false,"overview":"Trapped in a London subway station, a woman who's being pursued by a potential attacker heads into the unknown labyrinth of tunnels beneath the city's streets","genre_ids":[27,53,9648],"popularity":1.78,"vote_count":822,"poster_path":"/w5oxV6MDEfL48FMK9BmYTD2wQRm.jpg","release_date":"2004-08-10","vote_average":5.998,"backdrop_path":"/ooPtDdWP2nuYCoyLJAVwdthf5dN.jpg","original_title":"Creep","original_language":"en"},{"id":8645,"adult":false,"title":"The Happening","video":false,"overview":"When a deadly airborne virus threatens to wipe out the northeastern United States, teacher Elliot Moore and his wife Alma flee from contaminated cities into the countryside in a fight to discover the truth. Is it terrorism, the accidental release of some toxic military bio weapon -- or something even more sinister?","genre_ids":[53,878],"popularity":4.3635,"vote_count":3874,"poster_path":"/fP4nBrtmc0teSDDHzYmDE7TLQBT.jpg","release_date":"2008-06-11","vote_average":5.395,"backdrop_path":"/6moXpp6y1EZ6pfnSxnKFMrbFnWv.jpg","original_title":"The Happening","original_language":"en"},{"id":8740,"adult":false,"title":"The Vanishing","video":false,"overview":"Rex and Saskia, a young couple in love, are on vacation when they stop at a busy service station. Saskia is abducted in broad daylight and three years pass with no answers or closure surrounding her disappearance. Rex has nearly given up all hope when he suddenly begins receiving letters from her abductor.","genre_ids":[53,9648],"popularity":3.0557,"vote_count":776,"poster_path":"/eE5bbuRJluooG2MjEAsLEYyuJoa.jpg","release_date":"1988-10-27","vote_average":7.4,"backdrop_path":"/gcXbxHjkUwLV4HrE2oJcbP7UGTA.jpg","original_title":"Spoorloos","original_language":"nl"},{"id":8743,"adult":false,"title":"At Point Blank","video":false,"overview":"A gang of highly efficient and cold hearted robbers strike against a number of banks in Stockholm. The investigation ends up with the criminal detective Klara and the SWAT commander Greger Krona, who together lead the hunt for the robbers. Their investigation takes them in a dangerous direction that proves to have unforeseen consequences. The hunt for the robbers is intense and their methods become more refined and terrifying. Klara ends up in the line of fire, both literally and figuratively, and the investigation takes her in a direction that she could never have imagined.","genre_ids":[28,53,80],"popularity":0.1977,"vote_count":20,"poster_path":"/qAcNXFeNffjTy5uE0ii3AVK51ua.jpg","release_date":"2003-12-13","vote_average":5.1,"backdrop_path":"/4jkmstOiSgAFUJ22Tcdjtof5K47.jpg","original_title":"Rånarna","original_language":"sv"},{"id":8744,"adult":false,"title":"Albino Alligator","video":false,"overview":"While escaping from a foiled robbery attempt, three thieves find themselves surrounded by police at a New Orleans bar--only they're not the people the police are searching for.","genre_ids":[80,18,53],"popularity":0.8305,"vote_count":160,"poster_path":"/jOyV5Rb1MaMUl6XrWWossVTm7BA.jpg","release_date":"1997-01-17","vote_average":5.731,"backdrop_path":"/vcafO6dnQT9bCXRwwZijkYHW9Q0.jpg","original_title":"Albino Alligator","original_language":"en"},{"id":257054,"adult":false,"title":"Dead Walkers: Rise of the 4th Reich","video":false,"overview":"In 1945 the Second World War came to an end and the Nazis fled. Scientists and military elite escaped across borders and found themselves in new worlds. Some fled to Russia, some the United States and others to South America. But there was another division, a forgotten group. A top secret and powerful team of men and women formed in the womb of the Nazi Occult. Now, decades after the war, their work is nearing completion. The 4th Reich is ready. It's more powerful and destructive than ever before. An army of hell is coming. Only one man knows the truth. His mission now, is to convince the world. Based on years of occult research and insider knowledge, Dead Walkers is a film packed with spies, soldiers, Nazis and secrets. But also a very dark and mysterious army raised in the pit of Nazi hell.","genre_ids":[27],"popularity":0.1757,"vote_count":4,"poster_path":"/zftjB6C3n5ilzHj3I4zt9BckmAr.jpg","release_date":"2014-04-01","vote_average":1.5,"backdrop_path":"/3HpgQLtfliAfmtJmMGRLMqGBfa0.jpg","original_title":"Dead Walkers: Rise of the 4th Reich","original_language":"en"},{"id":9570,"adult":false,"title":"The Black Hole","video":false,"overview":"The explorer craft USS Palomino is returning to Earth after a fruitless 18-month search for extra-terrestrial life when the crew comes upon a supposedly lost ship, the USS Cygnus, hovering near a black hole. The ship is controlled by Dr. Hans Reinhardt and his monstrous robot companion, but the initial wonderment and awe the Palomino crew feel for the ship and its resistance to the power of the black hole turn to horror as they uncover Reinhardt's plans.","genre_ids":[12,878,28],"popularity":2.4054,"vote_count":532,"poster_path":"/gCqOJWvOK5UPospyrLANKfwRBlG.jpg","release_date":"1979-12-18","vote_average":5.84,"backdrop_path":"/dfNNSNVdbaFgDt4DLJf55CZsB5L.jpg","original_title":"The Black Hole","original_language":"en"},{"id":9592,"adult":false,"title":"Open Water 2: Adrift","video":false,"overview":"A weekend cruise on a luxurious party yacht goes horribly wrong for a group of old high-school friends when they get stuck in the water many miles from shore and a happy reunion turns into a fight for survival.","genre_ids":[18,27,53],"popularity":1.3519,"vote_count":709,"poster_path":"/6bbQxUlPTBGYSWHMshG6K2MxtSl.jpg","release_date":"2006-07-10","vote_average":5.472,"backdrop_path":"/ApgpEdgtU9Y55mehnR9TV9wPyHd.jpg","original_title":"Open Water 2: Adrift","original_language":"en"},{"id":9594,"adult":false,"title":"Double Impact","video":false,"overview":"Jean Claude Van Damme plays a dual role as Alex and Chad, twins separated at the death of their parents. Chad is raised by a family retainer in Paris, Alex becomes a petty crook in Hong Kong. Seeing a picture of Alex, Chad rejoins him and convinces him that his rival in Hong Kong is also the man who killed their parents. Alex is suspicious of Chad, especially when it comes to his girlfriend.","genre_ids":[53,28,80,18],"popularity":4.1255,"vote_count":1174,"poster_path":"/tmzwvSqoMC37Tgqwj4mA2dHNSmw.jpg","release_date":"1991-07-31","vote_average":6.2,"backdrop_path":"/iI0n28l5vn3K1GdXHVoA54kRemv.jpg","original_title":"Double Impact","original_language":"en"}],"external_ids":{"imdb_id":"tt0463854","twitter_id":null,"facebook_id":null,"wikidata_id":"Q221102","instagram_id":null,"metacritic_id":"movie/28-weeks-later","mydramalist_id":"127023","rotten_tomatoes_id":"m/28_weeks_later"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":111045,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AU","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2007-05-10T00:00:00.000Z","certification":"MA 15+"}]},{"iso_3166_1":"BE","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2007-09-19T00:00:00.000Z","certification":""}]},{"iso_3166_1":"BR","release_d