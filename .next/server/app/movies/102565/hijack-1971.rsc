5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Hijack 1971\",\"description\":\"Based on a real event, an easy Korean domestic flight bound for Gimpo takes an ill-fated turn when one of the passengers, Yong-dae (Yeo Jin-goo), hijacks the plane with a bomb, demanding to change the flight’s path to North Korea, where his brother lives. With the captain (Sung Dong-il) losing his eyesight from the initial bomb blast, co-pilot Tae-in takes over the flight and fights to save the lives of the passengers, along with the flight attendant Ok-soon (Chae Soo-bin).\",\"image\":\"https://image.tmdb.org/t/p/w500/68jNkFi61MQjrJEqj2up5wZ4w5R.jpg\",\"datePublished\":\"2024-06-21\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"disaster film\",\"drama film\",\"thriller film\",\"action film\",\"Action\",\"Thriller\",\"Crime\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.643,\"bestRating\":10,\"ratingCount\":133}}"}}],["$","$L10",null,{"initialDrama":{"id":"45877258-5ed1-4194-8025-6f583ccc5574","tmdb_id":1147710,"imdb_id":"tt31624258","content_type":"movie","title":"Hijack 1971","original_title":"하이재킹","overview":"Based on a real event, an easy Korean domestic flight bound for Gimpo takes an ill-fated turn when one of the passengers, Yong-dae (Yeo Jin-goo), hijacks the plane with a bomb, demanding to change the flight’s path to North Korea, where his brother lives. With the captain (Sung Dong-il) losing his eyesight from the initial bomb blast, co-pilot Tae-in takes over the flight and fights to save the lives of the passengers, along with the flight attendant Ok-soon (Chae Soo-bin).","poster_path":"/68jNkFi61MQjrJEqj2up5wZ4w5R.jpg","backdrop_path":"/hQ9grQ2RjHS3X7crItJqhoGvUPm.jpg","release_date":"2024-06-21","first_air_date":null,"status":"published","original_language":"ko","origin_country":["KR"],"genres":[{"na