o3ZBJdF4NM7Hp1am.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2341,"height":1317,"file_path":"/8ppoqfTNmgoGIBOewSUSt8TOMVJ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2340,"height":1316,"file_path":"/1nKlIkYuDPef9R28PlGVjMQHlTA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2336,"height":1314,"file_path":"/4po4W7PBpxMHESAtlgTBWU28c1Q.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2288,"height":1287,"file_path":"/fjdHKYVCN366og3ESs3nYWlxTPV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2560,"height":1440,"file_path":"/xfoYt3JNFKTbG8PMVaI43PL93pt.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/bDQmC56odlzWdulAArJqetDEGEm.jpg","iso_639_1":"ca","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2187,"height":1230,"file_path":"/pBkOIqD9SKJniG5w1HJ0FU02BjP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:58:07.27+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":165,"tagline":"Life, liberty, and the pursuit of vengeance.","homepage":"http://www.unchainedmovie.com","overview":"With the help of a German bounty hunter, a freed slave sets out to rescue his wife from a brutal Mississippi plantation owner."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":165,"tagline":"Gli hanno tolto la libertà. Lui gli toglierà ogni cosa.","homepage":"http://unchainedmovie.com/","overview":"Stati Uniti del Sud, alla vigilia della guerra civile. Il cacciatore di taglie di origine tedesca dottor King Schultz, su un carretto da dentista, è alla ricerca dei fratelli Brittle, per consegnarli alle autorità piuttosto morti che vivi e incassare la ricompensa. Per scovarli, libera dalle catene lo schiavo Django, promettendogli la libertà a missione completata. Tra i due uomini nasce così un sodalizio umano e professionale che li conduce attraverso l'America delle piantagioni e degli orrori razzisti alla ricerca dei criminali in fuga e della moglie di Django, Broomhilda, venduta come schiava a qualche possidente negriero."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":165,"tagline":"Leben, Freiheit und die Verfolgung von Rache","homepage":"http://unchainedmovie.com/","overview":"Als das Sklavenpaar Django und seine Frau Broomhilda bei einer Auktion getrennt werden, hat Django nur noch ein Ziel vor Augen: seine Frau wiederzufinden. Die Gelegenheit ergibt sich für den in Fesseln Geschlagenen schneller als erwartet, als er vom früheren Zahnarzt und jetzigen Kopfgeldjäger Dr. Schultz befreit wird, damit er ihm bei der Identifikation steckbrieflich gesuchter Verbrecher behilflich sei. Zum Dank will Dr. Schultz ihn zum Kopfgeldjäger ausbilden und ihm helfen, seine Frau ausfindig zu machen. Schließlich führt Django und Dr. Schultz die Spur nach Candyland, wo Broomhilda in den Besitz des charismatischen und überaus gefährlichen Calvin Candie übergegangen ist. Sie erschleichen sich erfolgreich das Vertrauen von Candie. Doch der Haussklave Stephen durchschaut ihr Spiel…"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":165,"tagline":"Ils ont pris sa liberté. Il va tout leur prendre.","homepage":"","overview":"Dans le sud des États‐Unis, deux ans avant la guerre de Sécession, le Dr King Schultz, un chasseur de primes allemand, fait l’acquisition de Django, un esclave qui peut l’aider à traquer les frères Brittle, les meurtriers qu’il recherche. Schultz promet à Django de lui rendre sa liberté lorsqu’il aura capturé les Brittle – morts ou vifs. Alors que les deux hommes pistent les dangereux criminels, Django n’oublie pas que son seul but est de retrouver Broomhilda, sa femme, dont il fut séparé à cause du commerce des esclaves… Lorsque Django et Schultz arrivent dans l’immense plantation du puissant Calvin Candie, ils éveillent les soupçons de Stephen, un esclave qui sert Candie et a toute sa confiance. Le moindre de leurs mouvements est désormais épié par une dangereuse organisation de plus en plus proche… Si Django et Schultz veulent espérer s’enfuir avec Broomhilda, ils vont devoir choisir entre l’indépendance et la solidarité, entre le sacrifice et la survie…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Django desencadenado","runtime":165,"tagline":"La D es muda. La venganza no lo será","homepage":"","overview":"Dos años antes de estallar la Guerra Civil (1861-1865), Schultz, un cazarrecompensas alemán que le sigue la pista a unos asesinos, le promete al esclavo Django dejarlo en libertad si le ayuda a atraparlos. Terminado con éxito el trabajo, Django prefiere seguir al lado del alemán y ayudarle a capturar a los delincuentes más buscados del Sur. Se convierte así en un experto cazador de recompensas, pero su único objetivo es rescatar a su esposa Broomhilda, a la que perdió por culpa del tráfico de esclavos. La búsqueda llevará a Django y a Schultz hasta Calvin Candie, el malvado propietario de la plantación \"Candyland\". La presencia de ambos en los alrededores de la propiedad, despierta las sospechas de Stephen, el esclavo de confianza de Candie."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Джанго освобождённый","runtime":165,"tagline":"«Они забрали его свободу. Он заберёт у них всё»","homepage":"","overview":"Шульц — эксцентричный охотник за головами, который выслеживает и отстреливает самых опасных преступников. Он освобождает раба по имени Джанго, поскольку тот может помочь ему в поисках трёх бандитов. Джанго знает этих парней в лицо, ведь у него с ними свои счёты."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Django Libertado","runtime":165,"tagline":"Vida, liberdade e a procura de vingança.","homepage":"","overview":"Django é um escravo negro alforriado que, sob a tutela de um caçador de recompensas alemão, se torna num mercenário e parte para encontrar e libertar a sua esposa, ainda escrava, das garras de Calvin Candie, um inescrupuloso proprietário de uma plantação no Mississíppi onde escravas são negociadas como objetos sexuais e escravos são colocados para lutar até à morte."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"被解救的姜戈","runtime":163,"tagline":"生命、自由与复仇的追求。","homepage":"","overview":"1858年，美国南北战争前两年。德国赏金猎人金·舒尔茨（克里斯托弗·瓦尔兹 Christoph Waltz饰）从贩奴商人手中买下黑奴姜戈（杰米·福克斯 Jamie Foxx饰），让其重获自由。舒尔茨实则是要把姜戈培养成无法无天的赏金猎人，为其缉拿各种通缉犯以换取报酬。姜戈的唯一条件是：从暴虐的糖果庄园主卡尔文·坎迪（莱昂纳多·迪卡普里奥 Leonardo DiCaprio饰）手中解救出自己的妻子布鲁姆希尔达（凯丽·华盛顿 Kerry Washington饰）。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Django","runtime":165,"tagline":"Zabrali mu wolność. On zabrał im wszystko.","homepage":"","overview":"Rok 1858, południe Stanów Zjednoczonych. Niewolnik Django spotyka na swojej drodze doktora Kinga Schultza, pochodzącego z Niemiec łowcę nagród. Ten, obiecuje mu wolność i zapłatę w zamian za pomoc w odnalezieniu poszukiwanych przez prawo braci Brittle. Django zgadza się i wkrótce obaj wykonują robotę. Po wszystkim zawiązują spółkę. Schultz wprowadza Django w tajniki zawodu łowcy nagród. Ponadto, poruszony historią swojego nowego przyjaciela, postanawia pomóc mu w odszukaniu żony Broomhildy. Okazuje się, że znajduje się ona na niesławnej plantacji należącej do Calvina Candie, odrażającego dżentelmena pasjonującego się walkami niewolników."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Django elszabadul","runtime":165,"tagline":"Elvették a szabadságát,most elveszi mindenüket","homepage":"http://unchainedmovie.com/","overview":"Amerika déli része két évvel a polgárháború előtt. Egy különös módszereket követő profi fejvadász egy rabszolga segítségével nagy sikert ér el, és hálából felszabadítja Djangót. De a társak együtt maradnak, hogy megkeressék a fekete férfi feleségét, akit egy rabszolgapiacon láttak utoljára. A nyomok végül egy ültetvényre vezetik őket, melynek tulajdonosa rabszolgáit - trénere segítségével - egymás elleni gladiátorküzdelemre képezi ki. A fejvadászoknak sikerül bejutniuk a birtokra, de nem biztos, hogy ki is jutnak onnan: a földesúr hű szolgája gyanút fog, és a kalandorok csapdába esnek. Dönteniük kell, hogy az önfeláldozás vagy a túlélés-e a fontosabb számukra."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":165,"tagline":"","homepage":"","overview":"Django Unchained speelt zich af in het zuiden van Amerika, twee jaar voor het uitbreken van de Amerikaanse Burgeroorlog. Django is een slaaf, wiens brute verleden hem in contact brengt met Dr. King Schultz, een Duitse premiejager."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":166,"tagline":"","homepage":"","overview":"Django är en slav vars brutala historia med sin förre ägare tar honom ansikte mot ansikte med den tyskfödde prisjägaren Dr King Schultz i den amerikanska södern, två år före inbördeskriget. Schultz är på jakt efter de mordiska Brittle-bröderna och bara Django kan ta honom till dem. Den okonventionelle Schultz förvärvar Django med löfte om att frige honom när de fått fast Brittle-bröderna – döda eller levande."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Zincirsiz","runtime":165,"tagline":"Yaşam, intikam ve adalet arayışı.","homepage":"http://www.unchainedmovie.com/","overview":"Amerikan İç Savaşı’ndan iki yıl önce geçen hikâye, eski bir köle olan Django’nun Alman ödül avcısı Dr. King Schultz ile yollarının kesişmesini konu alıyor. Schultz, Django’nun yardımı karşılığında ona özgürlüğünü kazandırır ve zorlu bir görevde iş birliği yaparlar. Django’nun üstün avcılık yetenekleri, onları son hedeflerine götürür: Django’nun karısı Broomhilda’yı köle tüccarlarının elinden kurtarmak."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Nespoutaný Django","runtime":165,"tagline":"Život, svoboda a snaha o pomstu.","homepage":"","overview":"Jižanské drama z období před vypuknutím Občanské války, jehož hlavním hrdinou je otrok Django. Ten má šanci získat díky nájemnému lovci lidí dr. Schultzovi svobodu, pokud se mu povede dopadnout vraždící bratry Brittlovi. Djangovi se tak zároveň naskytne příležitost najít ženu, kterou musel před lety nedobrovolně opustit. Ani jeden z hlavních hrdinů však netuší, jak blízko jsou nejnebezpečnějšímu dobrodružství svého života."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":166,"tagline":"","homepage":"","overview":"Elokuva sijoittuu Yhdysvaltain etelävaltioihin juuri sisällissodan syttymistä edeltäville vuosille. Django on kovia kokenut orja, joka kohtaa pelastajansa saksalaisen Dr. King Schultzin muodossa. Schultz on palkkionmetsästäjä, joka rekrytoi vapauttamansa Djangon auttamaan etsintäkuulutettujen jäljittämisessä. Schultz on murhanhimoisten Brittlen veljesten jäljillä, ja vain Django voi johdattaa hänet heidän luokseen. Epätavallisia keinoja kaihtamaton Schultz lupaa vapauttaa Djangon ja lisäksi lupaa auttaa häntä löytämään vaimonsa Broomhildan, mutta ensin Brittlen sakki on napattava kiinni. Hioen elintärkeitä saalistustaitojaan, Django keskittyy löytämään ja pelastamaan vaimonsa, jonka orjakauppa riisti häneltä kauan sitten. Lopulta etsinnät johdattavat parivaljakon lopulta Candyland-plantaasin pahamaineisen ja julman omistajan Calvin Candien luo - löytääkö Django vaimonsa täältä?"},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"","runtime":166,"tagline":"","homepage":"","overview":"Den omrejsende tandlæge og dusørjæger dr. King Schulz er Det Vilde Vestens mest veltalende mand. Han er også lynende hurtig med en revolver, og da han befrier den sorte slave Django, har han tilmed fået en partner. Sammen går makkerparret i gang med jagte eftersøgte forbrydere, men den største udfordring bliver at redde Django's kone ud af den brutale plantageejer Calvin Candie's kløer."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":166,"tagline":"","homepage":"","overview":"En frigjort slave, med hjelp fra en tysk dusørjeger, forsøker å redde sin kone fra en brutal plantasjeeier i Mississippi."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Divoký Django","runtime":165,"tagline":"Vzali mu slobodu. On si vezme všetko.","homepage":"http://www.unchainedmovie.com/","overview":"Dej sa odohráva dva roky pred americkou občianskou vojnou Severu proti Juhu. V hlavnej úlohe s Jamie Foxxom ako otrokom Djangom, ktorý sa pod vplyvom nemeckého lovca ľudí, doktora Schultza v podaní Christophera Waltza, sám stane krutým lovcom ľudí za odmenu. Schultz je na stope vražedným bratom Brittlovcom, ku ktorým ho môže priviesť len a len Django. Neortodoxný Schultz získava Djanga s prísľubom vyslobodenia zo služieb bratov – či už mŕtvých alebo živých."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"ג'אנגו ללא מעצורים","runtime":0,"tagline":"הם לקחו ממנו את החופש. הוא ייקח מהם הכל.","homepage":"","overview":"כשהוא מלווה בצייד ראשים גרמני, עבד משוחרר בשם ג'אנגו חוצה את אמריקה כדי לשחרר את אשתו מבעל אחוזה סדיסטי."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Django: Ο Τιμωρός","runtime":165,"tagline":"Του πήραν την ελευθερία. Θα τους πάρει τα πάντα.","homepage":"","overview":"Δύο χρόνια πριν τον Εμφύλιο Πόλεμο, στον αμερικάνικο Νότο, ο Django ένας σκλάβος που έχει υποφέρει τα πάνδεινα από τα πρώην αφεντικά του, εκπαιδεύεται σαν κυνηγός επικηρυγμένων από τον γερμανικής καταγωγής Dr. King Schultz που τον χρειάζεται για να εντοπίσει τους φονικούς αδερφούς Brittles. Οι δυο τους τα καταφέρνουν και είναι η σειρά του Django να ζητήσει τη βοήθεια του Dr. Schultz για να βρει την Broomhilda, την γυναίκα του που έχασε σε σκλαβοπάζαρο. Η έρευνα τους οδηγεί στον Calvin Candie, τον ιδιοκτήτη της \"Candyland\" μιας κακόφημης φυτείας όπου οι άντρες σκλάβοι ανταγωνίζονται μεταξύ τους μέχρι θανάτου, ενώ οι γυναίκες σκλάβες κακοποιούνται σεξουαλικά."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"จังโก้ โคตรคนแดนเถื่อน","runtime":0,"tagline":"","homepage":"","overview":"เรื่องราวที่เกิดขึ้นในตอนใต้ของอเมริกา สองปีก่อนสงครามกลางเมือง ทาสชื่อ แจงโก้ (เจมี่ ฟอกซ์) ผู้มีอดีตอันเลวร้ายกับเจ้านายคนก่อน ได้พบกับนักล่าค่าหัวผู้ที่เกิดในเยอรมันนามว่า ดร.คิง ชุลซ์ (คริสตอฟ วอลซ์) ซึ่งชุลซ์นั้นต้องขอความช่วยเหลือจากแจงโก้ เพื่อตามล่าพี่น้องบริตเตอร์ผู้เหี้ยมโหด และสัญญาจะแบ่งค่าหัวให้กับแจงโก้ ไม่ว่าจะจับพี่น้องบริตเตอร์ได้เป็นหรือจับตาย หลังจากที่ทั้งสองทำภารกิจนั้นสำเร็จ ชุลซ์จึงช่วยให้แจงโก้เป็นไท ชุลซ์เองก็ไม่ได้แยกจากไป แต่ตัดสินใจจะช่วยแจงโก้ทำภารกิจใหม่ คือการตามหา บรูมฮิลด้า (เครี่ วอชิงตัน) ภรรยาของแจงโก้ที่หายไปตั้งแต่มีการซื้อขายทาสนานมาแล้ว ซึ่งภายหลัง แจงโก้และ ดร.ชุลซ์ พบว่าภรรยาของได้ตกเป็นทาสของ แคลวิน แคนดี้ (ลีโอนาร์โด ดิคาปริโอ) เจ้าของไร่ \"แคนดี้แลนด์\" ที่โด่งดังเรื่องความเหี้ยมโหด ซาดิสม์ ชอบจับให้ทาสต่อสู้กันเพื่อความสนุก ทั้งสองจะทำอย่างไรเมื่อพวกเขาพบว่าการจะพาภรรยาของเขาออกไปจากที่นี่ มีเพียงหนทางเดียวที่อาจจะชี้ความเป็นความตายของพวกเขา"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Джанго без окови","runtime":165,"tagline":"Те го оковаха, той ги закова","homepage":"","overview":"Джанго е мускулест роб, когото съдбата среща с немския ловец на глави д-р Кинг Шулц. Двамата бързо се превръщат в страховит тандем, от който треперят всички жестоки робовладелци."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"장고: 분노의 추적자","runtime":165,"tagline":"복수의 끝에서 놈을 만났다","homepage":"","overview":"흑인 노예 장고는 착한 사마리아인 같은 독일인 현금사냥꾼 닥터 킹의 도움을 받아 멋진 말을 타고 미국 평원을 달리며 헤어진 아내 브룸힐다를 찾아다니는 총잡이 낭만주의자로 변신한다. 그는 브룸힐다가 미시시피에서 가장 악독한 농장 캔디랜드의 노예로 일하고 있다는 소식을 듣고 농장주 캔디를 찾아간다. 아내를 구해야 하는 분노의 로맨티스트 장고, 그를 돕는 정의의 바운티 헌터 닥터 킹, 그리고 그들의 표적이 된 욕망의 마스터 캔디. 복수의 사슬이 풀리면, 세 남자의 피도 눈물도 없는 대결이 시작된다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"ジャンゴ 繋がれざる者","runtime":165,"tagline":"これがワイルドだ。","homepage":"","overview":"主人のもとで人間性を奪われ、妻を奪われた奴隷のジャンゴは、賞金稼ぎのシュルツと出会い、自由を与えられ、彼と共に銃の腕を磨き稼いだ金で妻を買い戻そうと決意。お尋ね者を追うアメリカ横断の旅の最終目的地は、妻が捕らわれているキャンディ・ランド。そこは残忍な若き暴君カルビン・キャンディが君臨する農園だ。ジャンゴとシュルツは奴隷商人を装いキャンディ・ランドに乗り込むが、見かけは黒人、心は白人の老獪な奴隷頭スティーブンが二人の正体を見破り！思いも寄らない一大死闘が展開する！！最後に生き残るのは果たして―――？"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Джанґо вільний","runtime":0,"tagline":"Джанґо мовчить. За нього говорить помста.","homepage":"","overview":"Фільм розповість історію звільненого раба Джанґо, який допомагає мисливцю за головами доктору Кінґу Шульцу, німцеві за національністю. Шульц, противник рабства, виручив Джанґо з важкої ситуації і тепер навчає його своєму ремеслу. Колишній раб розраховує на допомогу Шульца у вельми важкій справі - головний герой фільму жадає помститися жорстокому власнику плантації Келвіну Кенді, який утримує у себе дружину Джанґо."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Django dezlănțuit","runtime":165,"tagline":"Viață, libertate și urmărirea răzbunării.","homepage":"","overview":"Acțiunea are loc în sudul Statelor Unite, cu doi ani înainte de Războiul Civil. Django este un sclav al cărui trecut plin de violență îl aduce în serviciul lui King Schultz, un vânător de recompense aflat pe urmele a doi ucigași, frații Brittle. Django este singurul care poate să-l ajute să ajungă la ei. În schimb, Schultz îi promite să-l elibereze.  Când misiunea lor se încheie cu succes și Django este eliberat, el decide să rămână alături de Schultz și continuă să-i vâneze împreună pe cei mai căutați criminali. Însă scopul final al lui Django este găsirea și eliberarea Broomhildei, soția de care fusese despărțit cu mult timp în urmă."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":165,"tagline":"","homepage":"","overview":"Dr. King Schultz njemački je lovac na glave i bivši zubar koji kupuje Djanga kao svog roba kako bi mu ovaj pomogao identificirati ostale lovce na glave. Nakon što uspješno završe zadatak, Django biva oslobođen i regrutiran od strane Schultza kao poslovni partner. Django ubrzo od Schultza počinje učiti zanatske vještine pa zajedno odlaze u Mississippi kako bi oslobodili Djangovu ženu Broomhildu. Međutim, nakon što dogovor o kupnji njegove žene s nemilosrdnim vlasnikom plantaže Calvinom Candiejem propadne, Django će se naći uvučen u borbu za vlastiti život, život svoje žene, ali i mogućnošću za slatkom osvetom…"},"name":"Bosanski","iso_639_1":"bs","iso_3166_1":"BS","english_name":"Bosnian"},{"data":{"title":"Django Livre","runtime":165,"tagline":"O D é mudo, a revanche não será.","homepage":"","overview":"Django é um escravo, comprado pelo caçador de recompensas alemão Dr. King Schultz para auxiliá-lo em uma missão. A dupla acaba fazendo amizade e, após resolver os problemas do caçador, parte em busca por Broomhilda, esposa de Django. Para isso, eles devem enfrentar o vilão Calvin Candie, proprietário da escrava."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Django déchaîné","runtime":165,"tagline":"La vie, la liberté et la quête de vengeance.","homepage":"","overview":"Dans le sud des États-Unis, deux ans avant la guerre de Sécession, le Dr King Schultz, un chasseur de primes allemand, fait l’acquisition de Django, un esclave qui peut l’aider à traquer les frères Brittle, les meurtriers qu’il recherche. Schultz promet à Django de lui rendre sa liberté lorsqu’il aura capturé les Brittle – morts ou vifs. Alors que les deux hommes pistent les dangereux criminels, Django n’oublie pas que son seul but est de retrouver Broomhilda, sa femme, dont il fut séparé à cause du commerce des esclaves… Lorsque Django et Schultz arrivent dans l’immense plantation du puissant Calvin Candie, ils éveillent les soupçons de Stephen, un esclave qui sert Candie et a toute sa confiance. Le moindre de leurs mouvements est désormais épié par une dangereuse organisation de plus en plus proche… Si Django et Schultz veulent espérer s’enfuir avec Broomhilda, ils vont devoir choisir entre l’indépendance et la solidarité, entre le sacrifice et la survie…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"決殺令","runtime":0,"tagline":"不自由 殺無赦","homepage":"","overview":"在美國內戰爆發之前，德裔賞金獵人舒華茲〈克里斯多夫沃茲飾〉與備受虐待的黑奴決哥〈傑米福克斯飾〉，聯手合作抓到舒華茲兇殘的兄弟布里托，舒華茲必須還給決哥自由之身，以作為此次行動的代價。在這次任務成功之後，擺脫奴隸之身的決哥亦決定與舒華茲繼續合作，但潛藏於他內心的最終目標，是找回當年慘遭交易變賣的妻子布希達(凱莉華盛頓飾)。決哥和舒華茲在尋找布希達的過程之中，意外發現「糖果樂園」的猖狂富二代農場主人凱文康迪〈李奧納多狄卡皮歐飾〉，不僅凌虐奴隸，還將他們當成鬥雞訓練的娛樂對象。而他們此次的秘密任務也引起康迪家奴史提芬〈山謬傑克森飾〉的懷疑，他們如何在重重驚險之中，解救布希達而重現生命的光彩？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"جانگوی رها از بند","runtime":0,"tagline":"","homepage":"","overview":"دکتر «کینگ شولتز» (کریستوفر والتز) آزادی یک برده سیاه پوست بنام «جنگو» (جیمی فاکس) را می خرد، و به او کمک می کند تا همسرش را که در چنگ یک مزرعه دار ثروتمند و بی رحم بنام «کلوین کندی» (لئوناردو دی‌کاپریو) است، نجات دهد..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Django desencadenat","runtime":0,"tagline":"La D és muda. La venjança no ho serà","homepage":"","overview":"Dos anys abans d'esclatar la Guerra Civil (1861-1865), Schultz, un cazarrecompensas alemany que li segueix la pista a uns assassins, li promet a l'esclau Django deixar-lo en llibertat si l'ajuda a atrapar-los. Acabat amb èxit el treball, Django prefereix seguir al costat de l'alemany i ajudar-lo a capturar als delinqüents més buscats del Sud. Es converteix així en un expert caçador de recompenses, però el seu únic objectiu és rescatar a la seva esposa Broomhilda, a la qual va perdre per culpa del tràfic d'esclaus. La cerca portarà a Django i a Schultz fins a Calvin Candie, el malvat propietari de la plantació \"Candyland\". La presència de tots dos als voltants de la propietat, desperta les sospites de Stephen, l'esclau de confiança de Candie."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Ђангова освета","runtime":0,"tagline":"","homepage":"","overview":"Др. Кинг Шилц немачки је ловац на главе и бивши зубар који купује Ђанга као свог роба како би му помогао да идентификује остале ловце на главе. Након што успешно заврше задатак, Ђанго бива ослобођен и регрутиран од стране Шилца као пословни партнер. Ђанго убрзо од Шулца почиње да учи занатске вештине па заједно одлазе у Мисисипи како би ослободили Ђангову жену Брумхилду. Међутим, након што договор о куповини његове жене с немилосрдним власником плантаже Калвином Кендијем пропадне, Ђанго ће се наћи увучен у борбу за властити живот, живот своје жене, али и могућношћу за слатком осветом..."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Atsvabinātais Džango","runtime":0,"tagline":"","homepage":"","overview":"Džango ir vergs, kas ne īpaši labi satiek ar saviem saimniekiem. Liktenis viņu nejauši saved kopā ar vācieti - doktoru Šulcu, kas ir pasūtījuma slepkava. Šulcam ir uzdots darbiņš, taču viņam vajag kādu, kas viņam palīdz."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Ištrūkęs Džango","runtime":0,"tagline":"","homepage":"","overview":"Premijų medžiotojas Kingas Schultzas išgelbėja iš vergijos pagrindinį herojų Džango. Schultzas ieško dviejų žudikų, o buvęs vergas žino kur juos rasti. Premijų medžiotojas suteikia Džango galimybę tapti kažkuo daugiau, nei vergu ir pažada padėti iš žiauraus dvarininko Calvino išvaduoti pagrobtą sužadėtinę Brunhildą."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"黑殺令","runtime":0,"tagline":"奪我自由 要你早抖! 為復仇 槍槍打爆頭 出得嚟行 就要咁強橫","homepage":"","overview":"故事講述在內戰爆發前兩年的美國南部，周身刀張張利、但備受虐待的黑奴 Django（占美霍士 飾）被德籍懸紅獵人Dr. King Schultz（基斯托夫華薩 飾）買下，協助追捕臭名遠播的 Brittle brother，因為只有 Django才可以引領他成功追捕 Brittle brother，但代價是要讓 Django 重獲自由。事成後，已重獲自由的 Django，為了尋回妻子 Broomhilda（嘉莉華盛頓 飾），決定與 Dr. King Schultz 一同上路，獵捕把黑奴視作鬥狗的變態大地主Calvin Candie（里安度狄卡比奧 飾）。但在接近目標的同時，二人意外被 Calvin 心腹 Stephen（森姆積遜 飾）發現了行蹤，使拯救愛妻、捉拿重犯，以及解放黑奴的任務變得異常艱鉅，兩人更被逼押下性命和自由作為賭注！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Django sin Cadenas","runtime":165,"tagline":"","homepage":"","overview":"En Texas, dos años antes de estallar la Guerra Civil Americana, King Schultz, un cazarrecompensas alemán que sigue la pista a unos asesinos para cobrar por sus cabezas, le promete al esclavo negro Django dejarlo en libertad si le ayuda a atraparlos. Él acepta, pues luego quiere ir a buscar a su esposa Broomhilda, esclava en una plantación del terrateniente Calvin Candie."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Django brez okovov","runtime":0,"tagline":"Režiser nepozabnih kriminalnih trilerjev Šund in Neslavne barabe predstavlja brezkompromisni vestern o sužnju Djangu in njegovemu iskanju ter uveljavljanju pravice.","homepage":"","overview":"Django brez okovov se dogaja dve leti pred ameriško državljansko vojno. Django je suženj, ki ga brutalna preteklost z nekdanjimi lastniki pripelje do srečanja z v Nemčiji rojenim lovcem na glave dr. Kingom Schultzem . Schultz sledi morilskim bratom Brittle in samo Django ga lahko pripelje do njegovega plena. Nenavadni Schultz najame Djanga z obljubo, da ga bo osvobodil, ko ujameta Brittlove. Po uspehu Schultz osvobodi Djanga, a moška skleneta, da ne bosta šla vsak svojo pot, saj se Schultz odloči slediti najbolj iskanim kriminalcem juga. Django izpili ključne lovske veščine, a pred seboj ima samo en cilj: najti in rešiti Broomhildo, svojo ženo, ki jo je pred mnogimi leti izgubil zaradi trgovanja s sužnji. Iskanja ju nazadnje pripeljejo do Calvina Candieja , lastnika razvpite plantaže Candyland. Zemljišče raziščeta pod pretvezo, a vzbudita sum pri Stephenu, hišnemu sužnju, ki mu Candie zelo zaupa. Njune poteze so opažene in izdajalska organizacija okoli njiju sklepa obroč."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Ozod Django","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ozbek","iso_639_1":"uz","iso_3166_1":"UZ","english_name":"Uzbek"},{"data":{"title":"Hành Trình Django","runtime":0,"tagline":"Ngươi không biết nhưng ta sẽ buộc ngươi trả giá.","homepage":"","overview":"Tài tử 'Titanic' đóng vai một chủ nô quyến rũ nhưng tàn bạo trong tác phẩm cao bồi miền Tây, 'Django Unchained' - bộ phim đánh dấu sự trở lại của đạo diễn lừng danh Quentin Tarantino.Tuy lấy bối cảnh là miền Nam nước Mỹ nhưng phong cách của Django Unchained lại là cao bồi miền Tây. Phim nói về hành trình của một người nô lệ da màu (Jamie Foxx đóng) giải cứu người vợ khỏi tay tên chủ điền Calvin Candie nổi tiếng bệnh hoạn và độc ác."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"جانغو الحر","runtime":0,"tagline":"الحياة والحرية والسعي للانتقام.","homepage":"","overview":"الحياة والحرية والسعي وراء الانتقام.  بمساعدة صياد جوائز ألماني ، ينطلق عبد محرر لإنقاذ زوجته من مالك مزرعة وحشي في ولاية ميسيسيبي."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Odbjegli Django","runtime":0,"tagline":"Život, sloboda i potraga za osvetom.","homepage":"","overview":"Dr. King Schultz njemački je lovac na glave i bivši zubar koji kupuje Djanga kao svog roba kako bi mu ovaj pomogao identificirati ostale lovce na glave. Nakon što uspješno završe zadatak, Django biva oslobođen i regrutiran od strane Schultza kao poslovni partner. Django ubrzo od Schultza počinje učiti zanatske vještine pa zajedno odlaze u Mississippi kako bi oslobodili Djangovu ženu Broomhildu. Međutim, nakon što dogovor o kupnji njegove žene s nemilosrdnim vlasnikom plantaže Calvinom Candiejem propadne, Django će se naći uvučen u borbu za vlastiti život, život svoje žene, ali i mogućnošću za slatkom osvetom…"},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"ჯანგო","runtime":0,"tagline":"","homepage":"","overview":"ყოფილი მონა ცდილობს მეუღლის განთავისუფლებას, რომელიც სასტიკი მისისიპელი მიწათმფლობელის კელვინ ქენდის პლანტაციაზე იმყოფება."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":165,"tagline":"الحياة والحرية والسعي للانتقام.","homepage":"","overview":"يسافر عبد حرّ يُدعى \"جانغو\" عبر أمريكا برفقه صائد مكافآت ألماني لتحرير رقبة زوجته من مالك مزرعة سادي."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"","runtime":165,"tagline":"Leben, Freiheit und die Verfolgung von Rache","homepage":"","overview":"Gemeinsam mit einem deutschen Kopfgeldjäger reist der ehemalige Sklave Django durch Amerika, um seine Frau vor einem sadistischen Plantagenbesitzer zu retten."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"","runtime":165,"tagline":"Leben, Freiheit und die Verfolgung von Rache","homepage":"","overview":"Gemeinsam mit einem deutschen Kopfgeldjäger reist der ehemalige Sklave Django durch Amerika, um seine Frau vor einem sadistischen Plantagenbesitzer zu retten."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"CH","english_name":"German"},{"data":{"title":"被解救的姜戈","runtime":165,"tagline":"","homepage":"","overview":"在德国赏金猎人的陪伴下，获得解放的奴隶姜戈横跨美国，想从暴虐的庄园主手里救出他的妻子。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"खतरों का खिलाडी","runtime":165,"tagline":"","homepage":"","overview":"गुलामी से मुक्त होने के बाद जैंगो अपनी पत्नी को भी एक बागान के क्रूर मालिक से मुक्त कराना है. इसके लिए वह एक जर्मन इनामी शिकारी के साथ अमेरिका भर में घूमता है."},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"","runtime":165,"tagline":"","homepage":"","overview":"Ditemani oleh pemburu hadiah asal Jerman, seorang budak yang dibebaskan bernama Django melintasi Amerika demi membebaskan istrinya dari pemilik perkebunan yang sadis."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"","runtime":165,"tagline":"","homepage":"","overview":"Ditemani pemburu ganjaran Jerman, hamba yang dibebaskan bernama Django mengembara merentasi Amerika untuk membebaskan isterinya daripada pemilik ladang yang sadis."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"","runtime":165,"tagline":"","homepage":"","overview":"Ditemani pemburu ganjaran Jerman, hamba yang dibebaskan bernama Django mengembara merentasi Amerika untuk membebaskan isterinya daripada pemilik ladang yang sadis."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"SG","english_name":"Malay"},{"data":{"title":"","runtime":165,"tagline":"","homepage":"","overview":"Samen met een Duitse premiejager reist een bevrijde slaaf, Django, door Amerika om zijn vrouw te bevrijden uit de handen van een sadistische plantage-eigenaar."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"","runtime":165,"tagline":"","homepage":"","overview":"Den frigitte slaven Django streifer gjennom USA, sammen med en tysk dusørjeger, for å frigjøre kona fra en sadistisk plantasjeeier."},"name":"Bokmål","iso_639_1":"nb","iso_3166_1":"NO","english_name":"Norwegian Bokmål"},{"data":{"title":"","runtime":165,"tagline":"","homepage":"","overview":"Den frigitte slaven Django streifer gjennom USA, sammen med en tysk dusørjeger, for å frigjøre kona fra en sadistisk plantasjeeier."},"name":"","iso_639_1":"nn","iso_3166_1":"NN","english_name":"Norwegian Nynorsk"},{"data":{"title":"Џанго разузданиот","runtime":166,"tagline":"","homepage":"","overview":"Џанго е ослободен роб, кој под туторство на еден германски ловец на уценети глави и самиот станува опасен ловец на уценети. Откако ловат неколку лоши момци, тие ја наоѓаат жената на Џанго која е робинка и ја ослободуваат."},"name":"","iso_639_1":"mk","iso_3166_1":"MK","english_name":"Macedonian"},{"data":{"title":"Vabastatud Django","runtime":0,"tagline":"\"D\" on vaikne. Kättemaks aga mitte.","homepage":"","overview":"Filmi tegevustik toimub Ameerika lõunaosariikides, kaks aastat enne kodusõja algust. Oscari-võitja Jamie Foxx kehastab orja Djangot, kelle karm minevik eelmise omaniku omanduses viib ta kokku sakslasest pearahaküti dr King Schultziga (Oscari-võitja Christoph Waltz). Schultz ajab mõrtsukatest Brittle'i-vennaste jälgi ja vaevatasu kättesaamiseks vajab ta just nimelt Django abi. Tavatute meetoditega Schultz saab Django endale tingimusel, et vabastab viimase Brittle'i-vendade tabamisel - olgu siis elusalt või surnult."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"}],"reviews_tmdb":[{"id":"5207b0bb760ee36305225258","url":"https://www.themoviedb.org/review/5207b0bb760ee36305225258","author":"LastCaress1972","content":"$11","created_at":"2013-08-11T15:41:47.060Z","updated_at":"2021-06-23T15:57:22.131Z","author_details":{"name":"","rating":null,"username":"LastCaress1972","avatar_path":null}},{"id":"589cfcabc3a3681158003356","url":"https://www.themoviedb.org/review/589cfcabc3a3681158003356","author":"iamyenz","content":"A highly entertaining yet disturbing film with superb cast and performances for an audience who would likely never consider watching a film fundamentally about slavery, where Tarantino is masterfully and emphatically navigating and exposing the complex layers of the violent and dehumanizing system of slavery.","created_at":"2017-02-09T23:35:07.102Z","updated_at":"2021-06-23T15:57:53.753Z","author_details":{"name":"","rating":9,"username":"iamyenz","avatar_path":null}},{"id":"590b2c6e9251414fa10150d3","url":"https://www.themoviedb.org/review/590b2c6e9251414fa10150d3","author":"Shreyance Parakh","content":"**ENTERTAINING from start to finish !!**\r\n\r\nGiven I am a big fan of **Quentin's** works i knew this movie would be a treat to watch.But what i didn't know was violence can be so **COOL**... The movie is a treat to watch(including the blood and gore) from starting to end.The acting is superb.And the cinematography is just too good! The whole cast played their parts to perfection...Especially **Samuel L. Jackson** and **Jamie Foxx**..**Leo and Christopher Waltz** were superb too..And as Christopher said in the movie - \"It was hard to RESIST\".A must watch for everyone who likes QUALITY cinema..Even the ones who cant stand BOOMs and BANGs, you wouldn't regret spending about 3 hours watching this well written, well directed and well acted GREAT movie !!","created_at":"2017-05-04T13:28:14.365Z","updated_at":"2021-06-23T15:57:56.964Z","author_details":{"name":"Shreyance Parakh","rating":10,"username":"shiri4frnz","avatar_path":null}},{"id":"5ad7255c9251413b2b00d193","url":"https://www.themoviedb.org/review/5ad7255c9251413b2b00d193","author":"Per Gunnar Jonsson","content":"$12","created_at":"2018-04-18T11:00:44.822Z","updated_at":"2024-05-16T15:21:16.729Z","author_details":{"name":"Per Gunnar Jonsson","rating":10,"username":"Dark Jedi","avatar_path":null}},{"id":"5b72389dc3a3681899183b04","url":"https://www.themoviedb.org/review/5b72389dc3a3681899183b04","author":"Wuchak","content":"$13","created_at":"2018-08-14T02:04:13.047Z","updated_at":"2021-06-23T15:58:11.206Z","author_details":{"name":"","rating":9,"username":"Wuchak","avatar_path":"/4KVM1VkqmXLOuwj1jjaSdxbvBDk.jpg"}},{"id":"5f3bcc7829c626003485f9a1","url":"https://www.themoviedb.org/review/5f3bcc7829c626003485f9a1","author":"Peter McGinn","content":"$14","created_at":"2020-08-18T12:41:28.598Z","updated_at":"2021-06-23T15:58:42.761Z","author_details":{"name":"Peter McGinn","rating":7,"username":"narrator56","avatar_path":"/tVbrLJzA2RwRlE7dJLJG54UsAkq.jpg"}},{"id":"6339aaa4b0ba7e007c39bd68","url":"https://www.themoviedb.org/review/6339aaa4b0ba7e007c39bd68","author":"Sigeki Ogino","content":"Mandingo. D'Artagnan. Slave abuse. Tarantino's technique of capturing the painful discrimination against blacks head-on and, on the contrary, making it cathartic in the final scene is brilliant. Starting with the impressive theme song, nonstop violence replaces it, giving us a glimpse into the kaleidoscope of horrific American society. Leonardo DiCaprio's monstrous performance and Christoph Waltz's near-perfect supporting turn are the main reasons for the film's appeal, but Quentin Tarantino's screenplay, which deliberately intersects revenge and black racism and ends up making us sneer at those who looked down on the slaves, is nothing short of brilliant.\r\nNext to \"Pulp Fiction\" this is Quentin's best film.","created_at":"2022-10-02T15:13:40.900Z","updated_at":"2022-10-03T14:28:20.442Z","author_details":{"name":"Sigeki Ogino","rating":10,"username":"Sigeki_Ogino","avatar_path":"/gIfRqQD2zbZrpU0DQ8AdLPHFJhG.jpg"}}],"recommendations":[{"id":16869,"adult":false,"title":"Inglourious Basterds","video":false,"overview":"In Nazi-occupied France during World War II, a group of Jewish-American soldiers known as \"The Basterds\" are chosen specifically to spread fear throughout the Third Reich by scalping and brutally killing Nazis. The Basterds, lead by Lt. Aldo Raine soon cross paths with a French-Jewish teenage girl who runs a movie theater in Paris which is targeted by the soldiers.","genre_ids":[18,53,10752],"media_type":"movie","popularity":19.5593,"vote_count":23782,"poster_path":"/7sfbEnaARXDDhKm0CZ7D7uc2sbo.jpg","release_date":"2009-08-02","vote_average":8.215,"backdrop_path":"/hwNtEmmugU5Yd7hpfprNWI0DGIn.jpg","original_title":"Inglourious Basterds","original_language":"en"},{"id":87827,"adult":false,"title":"Life of Pi","video":false,"overview":"The story of an Indian boy named Pi, a zookeeper's son who finds himself in the company of a hyena, zebra, orangutan, and a Bengal tiger after a shipwreck sets them adrift in the Pacific Ocean.","genre_ids":[12,18],"media_type":"movie","popularity":6.1808,"vote_count":13609,"poster_path":"/iLgRu4hhSr6V1uManX6ukDriiSc.jpg","release_date":"2012-11-20","vote_average":7.406,"backdrop_path":"/8oeXbjMtaYYGgjJl9RJNe7umkuS.jpg","original_title":"Life of Pi","original_language":"en"},{"id":273248,"adult":false,"title":"The Hateful Eight","video":false,"overview":"Bounty hunters seek shelter from a raging blizzard and get caught up in a plot of betrayal and deception.","genre_ids":[18,9648,37],"media_type":"movie","popularity":9.3547,"vote_count":15035,"poster_path":"/jIywvdPjia2t3eKYbjVTcwBQlG8.jpg","release_date":"2015-12-25","vote_average":7.755,"backdrop_path":"/7g1zO5t0bd27Iqn5ZUDJmksOGPJ.jpg","original_title":"The Hateful Eight","original_language":"en"},{"id":680,"adult":false,"title":"Pulp Fiction","video":false,"overview":"A burger-loving hit man, his philosophical partner, a drug-addled gangster's moll and a washed-up boxer converge in this sprawling, comedic crime caper. Their adventures unfurl in three stories that ingeniously trip back and forth in time.","genre_ids":[53,80,35],"media_type":"movie","popularity":25.4546,"vote_count":29734,"poster_path":"/vQWk5YBFWF4bZaofAbv0tShwBvQ.jpg","release_date":"1994-09-10","vote_average":8.486,"backdrop_path":"/96hiUXEuYsu4tcnvlaY8tEMFM0m.jpg","original_title":"Pulp Fiction","original_language":"en"},{"id":37724,"adult":false,"title":"Skyfall","video":false,"overview":"When Bond's latest assignment goes gravely wrong, agents around the world are exposed and MI6 headquarters is attacked. While M faces challenges to her authority and position from Gareth Mallory, the new Chairman of the Intelligence and Security Committee, it's up to Bond, aided only by field agent Eve, to locate the mastermind behind the attack.","genre_ids":[28,12,53],"media_type":"movie","popularity":9.4396,"vote_count":15919,"poster_path":"/d0IVecFQvsGdSbnMAHqiYsNYaJT.jpg","release_date":"2012-10-24","vote_average":7.257,"backdrop_path":"/qB2eFmGEh5YCzhXUpz7As2PaDCh.jpg","original_title":"Skyfall","original_language":"en"},{"id":68728,"adult":false,"title":"Oz the Great and Powerful","video":false,"overview":"Oscar Diggs, a small-time circus illusionist and con-artist, is whisked from Kansas to the Land of Oz where the inhabitants assume he's the great wizard of prophecy, there to save Oz from the clutches of evil.","genre_ids":[14,12,10751],"media_type":"movie","popularity":3.6968,"vote_count":6732,"poster_path":"/tkzfAUEKoUp4YFNbZV9hfpZOz0z.jpg","release_date":"2013-03-07","vote_average":5.93,"backdrop_path":"/o6TYNmB1CT85j7lmyvSedoybyc9.jpg","original_title":"Oz the Great and Powerful","original_language":"en"},{"id":20352,"adult":false,"title":"Despicable Me","video":false,"overview":"Gru is a supervillain determined to prove he’s the greatest by stealing the Moon. To pull off his plan, he adopts three orphaned girls—Margo, Edith, and Agnes—intending to use them as part of his scheme. However, as Gru bonds with the girls, his cold, villainous exterior begins to melt.","genre_ids":[10751,35,16