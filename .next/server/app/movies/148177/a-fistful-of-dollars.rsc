nguage":"en"},{"id":46193,"adult":false,"title":"Ride, Vaquero!","video":false,"overview":"Two Mexican outlaws, Rio and Esqueda, raised as stepbrothers, have a showdown over the issue of whether to evict new settlers from their Texas border territory.","genre_ids":[37,18],"popularity":0.5309,"vote_count":18,"poster_path":"/pA9t01y8BvWMal5MwSIozinASu3.jpg","release_date":"1953-07-17","vote_average":5.9,"backdrop_path":"/9kKyVrQ9QNZpGzzlupJMXSlcBdq.jpg","original_title":"Ride, Vaquero!","original_language":"en"},{"id":46623,"adult":false,"title":"Cimarron","video":false,"overview":"The epic story of a family involved in the Oklahoma Land Rush of April 22, 1889.","genre_ids":[37],"popularity":0.823,"vote_count":71,"poster_path":"/9xPw8iIAWymvNBG0D7kSt45M9c2.jpg","release_date":"1960-12-01","vote_average":6,"backdrop_path":"/lepTHhiKVcnwLOLJ1NGTl143jz2.jpg","original_title":"Cimarron","original_language":"en"},{"id":54149,"adult":false,"title":"Duel at Sundown","video":false,"overview":"During a cattle drive, Don McGow leaves the herd in charge of his younger brother and rides off. When the herd is reported stolen he blames himself and goes in search of the thieves.","genre_ids":[37],"popularity":0.2107,"vote_count":3,"poster_path":"/3CGWTbRfcVT7bOIFBsNLfNKXpwk.jpg","release_date":"1965-09-17","vote_average":5,"backdrop_path":"/aD5UInz8x6tIGyH9RQtidhxDzNv.jpg","original_title":"Duell vor Sonnenuntergang","original_language":"de"},{"id":54164,"adult":false,"title":"Man of the East","video":false,"overview":"By his dying father's last wish Joe is sent to the Wild West to become a real guy. The dreamy young man despises guns and fights likes poems and prefers bicycles to horses. Now his three teachers footpads all of them shall teach him otherwise. This doesn't work until Joe has to defend himself against gunman Morton who's jealous of Joe's love to rancher Ohlsen's beautiful daughter.","genre_ids":[35,37,28],"popularity":0.6446,"vote_count":137,"poster_path":"/rFwKo4O14PydJjyUYbR9Y7c7R1O.jpg","release_date":"1972-09-28","vote_average":6.5,"backdrop_path":"/qAXUbHk03Skr3vdrL7aJM39jPlm.jpg","original_title":"E poi lo chiamarono il magnifico","original_language":"it"},{"id":54310,"adult":false,"title":"Tex and the Lord of the Deep","video":false,"overview":"Based on the adventures of the hero Tex from the comic strip by Bonelli. An interesting spaghetti-western/fantasy movie that blends magic and mythology with six-guns and stagecoaches.","genre_ids":[12,14,37],"popularity":0.3784,"vote_count":17,"poster_path":"/8jTpYTaEQc5UpAeGK5Dzyh5ybGg.jpg","release_date":"1985-09-06","vote_average":4.6,"backdrop_path":"/k0n97onxF2CuBMNN5tf6fUFNnOy.jpg","original_title":"Tex e il signore degli abissi","original_language":"it"},{"id":319662,"adult":false,"title":"Gunsmoke Trail","video":false,"overview":"Learning of Walters' inheritance, Larson kills him and assumes his identity. When Larson's men try to kill Walter's niece Lola, Jack Lane breaks it up. This leads to a showdown with Jack outnumbered by Larson and his gang. Having saved Loma's life earlier, he has Fuzzy ride for him and his men.","genre_ids":[37],"popularity":0.2238,"vote_count":1,"poster_path":"/3K5QViM6oEJEfNSw9PDt67poQ41.jpg","release_date":"1938-05-26","vote_average":5,"backdrop_path":"/rwvSZjAcSETIhO4PPRYMZRf8kQf.jpg","original_title":"Gunsmoke Trail","original_language":"en"},{"id":55308,"adult":false,"title":"Gunfighters","video":false,"overview":"Gunfighter \"Brazos\" Kane lays aside his guns \"forever\" when he is forced to shoot his best friend, and decides to join another friend, Bob Tyrell, as a cowhand on the Inskip ranch. Upon arriving there he finds the bullet-riddled body of his friend. He carries the body to the Banner ranch, the largest in the territory, and is accused by Banner of murdering Tyrell; Banner orders Deputy Sheriff Bill Yount, who is in Banner's pay, to arrest Kane. But Kane has the sympathy of Banner's daughter, Jane, who notifies Inskip of Kane's plight, and Inskip arrives in time to prevent a lynching. Sheriff Kiscade dismisses the murder charge for lack of evidence. Brazos then sets out to find the killer of his friend. Bess Bannister, Jane's sister, is in love with the Banner ranch foreman, Bard Macky, and knowing that Bard killed Tyrell and that Kane will track him down, then hampers Kane's mission somewhat by pretending to be in love with him.","genre_ids":[37],"popularity":2.4149,"vote_count":22,"poster_path":"/hmDENgQ11fgWfq4ExnWjVhI94qb.jpg","release_date":"1947-07-15","vote_average":5.6,"backdrop_path":"/gWtsmdYOBWCdr1S0wIObxZIi0y7.jpg","original_title":"Gunfighters","original_language":"en"},{"id":35200,"adult":false,"title":"The Return of a Man Called Horse","video":false,"overview":"Lord John Morgan has returned to civilized life in England, but finds he has nothing but disdain for that life. Yearning to embrace the simplicity of the American West, and the Sioux tribe he left behind, Morgan returns to the their land only to discover that they've been decimated by ruthless, government-backed fur traders. Led by Horse, they fight to repossess their land.","genre_ids":[37,12],"popularity":0.5999,"vote_count":57,"poster_path":"/qOoLZCDwt3tOyFNv4MRAVvrSFiM.jpg","release_date":"1976-06-28","vote_average":5.7,"backdrop_path":"/1Nas9syOK93PltBGVjXJi9QvxM3.jpg","original_title":"The Return of a Man Called Horse","original_language":"en"},{"id":37748,"adult":false,"title":"800 Bullets","video":false,"overview":"Almería, Tabernas desert, Spain, 2002. Texas Hollywood is a dilapidated and dusty town where Western movies have not been shot for decades. Julián Torralba and his partners, veteran film stuntmen, survive there, recreating pathetic action scenes for the pleasure of the few foreign tourists who visit the isolated region.","genre_ids":[35,28,37],"popularity":3.1931,"vote_count":108,"poster_path":"/f8tqwtxk0xUJA8fHaKqxZ0G8ey4.jpg","release_date":"2002-10-18","vote_average":5.856,"backdrop_path":"/63uPeGNzQSKOZchtM98uNukvBFw.jpg","original_title":"800 balas","original_language":"es"},{"id":44896,"adult":false,"title":"Rango","video":false,"overview":"When Rango, a lost family pet, accidentally winds up in the gritty, gun-slinging town of Dirt, the less-than-courageous lizard suddenly finds he stands out. Welcomed as the last hope the town has been waiting for, new Sheriff Rango is forced to play his new role to the hilt.","genre_ids":[16,35,10751,37,12],"popularity":6.8441,"vote_count":6957,"poster_path":"/A5MP1guV8pbruieG0tnpPIbaJtt.jpg","release_date":"2011-03-02","vote_average":6.888,"backdrop_path":"/mOtKQlXdL5J4lwqcSFlkZmgmFeZ.jpg","original_title":"Rango","original_language":"en"},{"id":45007,"adult":false,"title":"The Hunting Party","video":false,"overview":"A ruthless rancher, and his gang, use extremely long range rifles to kill the men who kidnapped his wife.","genre_ids":[37],"popularity":0.9797,"vote_count":71,"poster_path":"/wJOgMQk15rGmhfB3LOg3DJ1DSgj.jpg","release_date":"1971-07-16","vote_average":6.1,"backdrop_path":"/qjM7ROfFV3oBpnKseSm5AQHq6VP.jpg","original_title":"The Hunting Party","original_language":"en"},{"id":45211,"adult":false,"title":"Face to Face","video":false,"overview":"History Professor Brad Fletcher heads west for his health, but falls in with Solomon Bennett's outlaw gang. Fascinated by their way of life, Fletcher finally takes over the gang, leading with a new 'efficient' ruthlessness.","genre_ids":[37],"popularity":0.4272,"vote_count":106,"poster_path":"/tvvCChgjwqyzwcrHtqG1hMNlfv2.jpg","release_date":"1967-11-23","vote_average":7,"backdrop_path":"/aur68UIJEbXdQfW5nIqIzCIjhMS.jpg","original_title":"Faccia a faccia","original_language":"it"}],"external_ids":{"imdb_id":"tt0058461","twitter_id":null,"facebook_id":null,"wikidata_id":"Q76479","instagram_id":null,"metacritic_id":"movie/a-fistful-of-dollars","mydramalist_id":"2702","rotten_tomatoes_id":"m/fistful_of_dollars"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},