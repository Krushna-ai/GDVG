20,"height":1078,"file_path":"/j0VuCQFGnu5gV6DsfkOet1kU5ie.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.781,"vote_average":0},{"width":1920,"height":1080,"file_path":"/mmtB5ajtAO1IvVPwb7Q9QVseBFy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/hjlvYZm0M31YXlAzrd70HNlIweF.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/7kwhkynGL2vth3gVPcSr9iVQi4i.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/cezAeTyLeEIgaFNgIYU1gw9oSAY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/ww3Ob44KfNVe3S1OJmjF1FThjxS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/jiOdLF8BswSGn8fKvZeXMkceeZt.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/cnGJsu7sKDaIbJSEoAdKdb4QT0g.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2048,"height":1152,"file_path":"/hK9KyzmNg582yRPuzHuw4GNpxHN.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/bDq3R9JW7FBu4Tikz9TXpsCb4fL.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1677,"height":943,"file_path":"/wSgoY7u5HpiaNRBYhnw4E0KzErY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/3GFUuwMtWAzVGtlY6KHC2hxIXvY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/61sNPB2caQzSuNxCkMaYzd4UDus.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/rHco63e1G3aSMetY1GL9llYjDo8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/kYpuPOcjF2uiXYZthxr0u7wCMsR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1449,"height":815,"file_path":"/8AZyPrQ8CgPO91wu90rc2x5AI3P.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1449,"height":815,"file_path":"/Asm47Ga5ARhhTfPoJlleZBVzDqY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1449,"height":815,"file_path":"/CPViW5AJpH6RDeozfFN8ZFfvmW.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1449,"height":815,"file_path":"/bUwWIJeLU2585SJkq4nX63E8sss.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:24:31.813+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"A Fistful of Dollars","runtime":99,"tagline":"In his own way he is, perhaps, the most dangerous man who ever lived!","homepage":"","overview":"The Man With No Name enters the Mexican village of San Miguel in the midst of a power struggle among the three Rojo brothers and sheriff John Baxter. When a regiment of Mexican soldiers bearing gold intended to pay for new weapons is waylaid by the Rojo brothers, the stranger inserts himself into the middle of the long-simmering battle, selling false information to both sides for his own benefit."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Für eine Handvoll Dollar","runtime":99,"tagline":"","homepage":"","overview":"Das kleine und abgelegen Dorf San Miguel in Mexiko ist von zwei rivalisierenden Gangsterfamilien gespalten. Die angloamerikanische Baxter- und die mexikanische Rojo-Familie liefert sich einen Bandenkrieg, unter dem alle Einwohner des beschaulichen Städtchens zu leiden haben. Doch dann betritt ein einsamer Reiter namens Joe die Stadt, der mit dem Colt umzugehen weiß, wie kein Zweiter und bietet den beiden Klans an, für sie zu arbeiten. Ohne das sie davon wissen, kassiert der Fremde von beiden Seiten ein dicken Batzen Geld ein, doch als Ramón, der Anführer der Rojos-Familie, hinter den Bluff kommt, lässt er den Cowboy brutal foltern. In letzter Sekunde schafft es Joe sich zu befreien und zu fliehen. Nachdem er sich einige Zeit in einer entlegenen Höhle regeneriert hat, kehrt der Revolverheld zurück, um mit dem Klan und insbesondere mit Ramón abzurechnen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Pour une poignée de dollars","runtime":95,"tagline":"À sa manière, il est peut-être l’homme le plus dangereux qui ait jamais vécu !","homepage":"","overview":"Joe, un tireur d'élite, arrive dans une bourgade mexicaine proche de la frontière, San Miguel. Deux bandes rivales, les Baxter et les Rodos, se disputent le contrôle de la région. Joe, qui assiste à un massacre de soldats mexicains par les Rodos, décide de tirer profit de la situation pour gagner quelques dollars. Il incite les bandits à se battre entre eux dans l'espoir de récupérer l'or que détient Ramon, le chef des Rodos. Un premier affrontement entre les bandits élimine une bonne partie des Baxter. Joe se charge de tuer lui-même les Rodos survivants. Une opération d'autant plus facile à imaginer que Joe a découvert le point faible du plus farouche des fils Rodos, son amour pour Marisol, une jolie Mexicaine…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Por un puñado de dólares","runtime":99,"tagline":"Este corto cigarro, esta arma larga y este poncho pertenecen a un hombre sin nombre.","homepage":"","overview":"Tras la muerte de Juárez, en México dominan la injusticia y el terror. Joe, un pistolero vagabundo, llega al pueblo fronterizo de San Miguel, donde dos familias se disputan el control del territorio, y entra al servicio del clan Rojo. Una noche, Joe es testigo del intercambio de oro por armas entre mexicanos y soldados de la Unión..."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Per un pugno di dollari","runtime":101,"tagline":"A suo modo è forse l'uomo più pericoloso che sia mai vissuto!","homepage":"","overview":"Un pistolero senza nome giunge in una cittadina al confine tra Stati Uniti e Messico. Questo luogo è dominato da due famiglie rivali che si fronteggiano seminando il terrore tra la popolazione. Il pistolero, giocando d'astuzia, le farà sterminare a vicenda."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Pro hrst dolarů","runtime":110,"tagline":"První část dolarové trilogie","homepage":"","overview":"Jezdec odnikud, zarostlý cizinec Joe, přijíždí do mexického pohraničního městečka. Když zjistí, že zde vládnou dva znepřátelené rodinné gangy, Rojové a Baxterové, bez váhání se dá do služeb obou. Jediným měřítkem jeho činů je zisk; neváhá inscenovat spory, z nichž těží jen on sám. Všechno mu vychází, až do okamžiku, kdy se nechá unést soucitem. Stranění spravedlnosti se Joeovi krutě vymsti; poznává, že nedokáže sloužit dvěma pánům, a nezbývá mu než pracně očistit městečko od zla."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Por um Punhado de Dólares","runtime":99,"tagline":"","homepage":"","overview":"Um estrangeiro solitário chega a uma pequena cidade do oeste e encontra-a dividida ao meio por duas famílias de bandidos, os Rojo e os Baxter. Com o objectivo de enriquecer, propõem os seus serviços de pistoleiro a ambas as famílias, lançando uma contra a outra e beneficiando com a disputa. Um western pleno de acção, cobiça, orgulho e vingança."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Kourallinen dollareita","runtime":0,"tagline":"","homepage":"","overview":"Kourallinen dollareita (A Fistful of Dollars) on western-elokuva ja dollaritrilogian ensimmäinen osa. Se nosti ohjaaja Sergio Leonen, pääosan esittäjän Clint Eastwoodin ja elokuvaan musiikin säveltäneen Ennio Morriconen maailmanmaineeseen. Elokuva on lajityypiltään spagettiwestern ja se on väkivaltainen sekä karu. Dollaritrilogia toi elokuvamaailmaan myös antisankarin käsitteen. Leonen stilisoitu ja tiivistunnelmainen lähikuvien käyttö oli ennennäkemätöntä ja uutta.Elokuva on kuvattu Espanjassa, kaupungissa nimeltä Almeria, joka sijaitsee aivan maan etelärannikolla.Kourallisen dollareita juoni perustuu Akira Kurosawan samurai-elokuvaan Yojimbo – onnensoturi. Tapaus johti oikeusjuttuun, jonka Kourallinen dollareita -elokuvan tuotantoryhmä hävisi."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Bir Avuç Dolar","runtime":0,"tagline":"Kendi yolunda o belkide yaşamış en tehlikeli adam!","homepage":"","overview":"'İyi, Kötü, Çirkin' ve 'Bir Avuç Dolar İçin\"in tanınmış yönetmeninden, Clint Eastwood'un efsaneleşmiş 'isimsiz' karakterinin beyaz perdeye ilk defa çıktığı bu nefes kesici ve aksiyonla örülmüş western macerası sizi koltuklarınıza çivileyecek. Heyecanlı çatışma sahneleri, dinamik performanslar ve mükemmel görüntüleri ile türünün tartışmasız klasiklerinden biri. Gizemli bir silahşör (Eastwood) iki rakip kaçakçılık çetesinin korku saldığı kasvetli ve eski bir sınır kasabası olan San Miguel'e gelir ve macera başlar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"За пригоршню долларов","runtime":0,"tagline":"«За пригоршню долларов является первым кинофильм в своем роде. Это не будет последним! »","homepage":"","overview":"Фильм является вольным римейком самурайской драмы Акиры Куросавы «Телохранитель» (1961), действие которого перенесено на границу США и Мексики. В небольшой пограничный городок Сан-Мигель приезжает бродяга-стрелок (Клинт Иствуд). Жителей на улицах нет, первый, кого он встречает — усаженный на лошадь мертвец, к спине которого приколота издевательская записка «Adios, amigo» («Прощай, друг»). Со слов хозяина салуна стрелок узнаёт, что городок стал ареной противоборства двух банд, которые занимаются контрабандой — мексиканцев Рохо и американцев Бакстеров. Обе банды равно сильны, и ни одна не может взять верх над другой..."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"荒野大镖客","runtime":99,"tagline":"","homepage":"","overview":"　　镖客乔（克林特·伊斯特伍德 Clint Eastwood 饰）来到墨西哥边境小镇，伺机寻找挣钱机会的他得知镇上的两大帮派罗霍兄弟和镇长巴克斯特为了争夺小镇的控制权厮杀已久，便决定与两派斡旋，设计将镇上恶霸一网打尽。墨西哥士兵押送黄金经过小镇，罗霍劫持了黄金，并杀光了 士兵，一路跟踪的乔将其中两具尸体藏起来，并透露消息给两边：有两个士兵还活着。巴克斯特火速赶往现场想抓到存活士兵，来指证罗霍；罗霍则试图阻止他们，双方展开了一场激烈枪战。罗霍捕获巴克斯特的儿子安东尼奥。乔趁着两派在激战时，找到了黄金，并发现罗霍囚禁的女人玛利索，他将玛利索交给罗霍家，换回安东尼奥。后来他得知她是安东尼奥的妻子，又救出了她，帮助玛利索与安东尼奥逃出镇子。罗霍发现玛利索被乔放走，便放火烧死了巴克斯特一家，乔侥幸逃脱。  　　当乔孤身一人重现在镇口时，他与罗霍兄弟的生死决战开始了。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"För en handfull dollar","runtime":96,"tagline":"På sitt eget sätt är han kanske den farligaste mannen som någonsin levt!","homepage":"","overview":"En anonym men dödlig man rider in i en mexikansk by som är plågad av en familjefejd mellan Baxters och Rojos. Istället för att fly, som de flesta andra skulle ha gjort, bestämmer sig mannen för att spela ut de två sidorna mot varandra och bli rik på kuppen."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"За шаку долара","runtime":99,"tagline":"За шаку долара","homepage":"","overview":"Прича почиње кад јунак којег тумачи Клинт Иствуд (Човек без имена), стиже у мали градић Сан Мигел, у којем га убрзо упозоравају како у граду ратују две породице ради премоћи. Једни су браћа Рохос: Дон Мигел (шеф), Естебан (кукавица) и Рамон, који се једини може мерити са главним јунаком; друга породица су Бакстери, на чијем челу је Џон Бакстер, градски шериф.  Човек без имена одлучује да ће радити за обе породице као плаћеник \"за шаку долара\", а у исто време их наводи да се међусобно сукобе."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Egy maréknyi dollárért","runtime":0,"tagline":"","homepage":"","overview":"A messziről érkezett, titokzatos Joe a mexikói határon lévő kis településen akar meggazdagodni két csempészbanda háborújából, akik régóta rivalizálnak egymással. Helyesen okoskodik, ám jó szíve eltéríti az üzlettől. Jóságán majdnem rajtaveszít, s csupán lélekjelenlétének és józan eszének köszönheti, hogy kiszabadul a rettegett Ramón fogságából. Ezután azonban már csak a bosszú érdekli."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"בעבור חופן דולרים","runtime":0,"tagline":"בדרכו שלו, הוא כנראה האדם המסוכן ביותר עלי אדמות!","homepage":"","overview":"הראשון בטרילוגיית \"האיש ללא שם\". אקדוחן שמגיע לכפר המצוי תחת שליטת שתי כנופיות פושעים, מצליח בעורמה לסכסך בין היריבים."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"En nævefuld dollars","runtime":100,"tagline":"","homepage":"","overview":"Manden uden navn rider ind i en by, der er splittet mellem to familier. John Baxter og Ramon Rojo bekriger hinanden med alle midler, og fremmede plejer at rejse videre for ikke at blive dræbt. Men den fremmede bliver og planlægger, hvordan han bedst spiller de to grupper ud mod hinanden, så han selv kan blive rig."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Za garść dolarów","runtime":99,"tagline":"","homepage":"","overview":"Samotny wędrowiec Joe przybywa do miasteczka leżącego przy granicy meksykańsko-amerykańskiej. Wpływy dzielą tu między siebie dwie rywalizujące bandy przemytników. Przebiegły Joe dostrzega szansę na zarobek, lokując się pomiędzy skonfliktowanymi stronami, co realizuje zatrudniając się raz w jednej, raz w drugiej grupie. Wkrótce wtrąca się również w losy lokalnej rodziny, rozdzielonej przez bandytów. W rezultacie ściąga na siebie wrogość jednego z rodów, doprowadzając do eskalacji trwającego konfliktu."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Για Μια Χούφτα Δολάρια","runtime":99,"tagline":"Για Μια Χούφτα Δολάρια","homepage":"","overview":"Σε μια μικρή πόλη του Γουέστ, κάπου στα σύνορα με το Μεξικό, φτάνει ένας άγνωστος πιστολέρο. Μαθαίνει ότι οι οικογένειες των Μπάξτερ και των Ρόχο βρίσκονται σε πόλεμο και εμπλέκεται στη σύρραξη, παίρνοντας πότε το μέρος των μεν και πότε των δε."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"A Fistful of Dollars","runtime":99,"tagline":"","homepage":"","overview":"De gevaarlijke Man Zonder Naam rijdt een stad in, waar oorlog blijkt te zijn tussen twee groepen: de Baxters en de Rojo's. In plaats van te helpen, zoals veel anderen zouden doen, probeert hij de twee groepen tegen elkaar uit te spelen om hier financieel beter van te worden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"황야의 무법자","runtime":0,"tagline":"","homepage":"","overview":"로호 삼형제와 보안관 존 백스터가 주도권 싸움을 하는 멕시코의 한 마을 산 미구엘에 총잡이 조가 나타난다. 양 측은 조를 이용하는 것 처럼 보이지만 조는 그 가운데 자신의 잇속을 챙기려 하는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Pentru un pumn de dolari","runtime":0,"tagline":"În felul lui el este poate, cel mai periculos bărbat care a trăit vreodată!","homepage":"","overview":"Bărbatul fără nume intră în satul mexican San Miguel în mijlocul unei lupte pentru putere între cei trei frați Rojo și șeriful John Baxter. Atunci când un regiment de soldați mexicani care poartă aur pentru a plăti pentru arme noi este pândit de frații Rojo, străinul se introduce în mijlocul bătăliei cu foc lung, vânzând informații false ambelelor părți pentru propriul beneficiu."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"За жменю доларів","runtime":0,"tagline":"","homepage":"","overview":"У маленькому містечку йде війна між двома впливовими сім'ями, яких абсолютно не цікавить закон. Герой Клінта Іствуда - людина без імені, що вміє стріляти без промаху ..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"荒野の用心棒","runtime":0,"tagline":"","homepage":"","overview":"セルジオ・レオーネ監督＆クリント・イーストウッドによるマカロニ・ウエスタンの金字塔。無法者たちの勢力争いがやまない国境の町サン・ミゲルを舞台に、風来坊ガンマンが荒唐無稽な痛快アクションを繰り広げる。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Por um Punhado de Dólares","runtime":100,"tagline":"À sua maneira, ele talvez seja o homem mais perigoso que já existiu!","homepage":"","overview":"Joe é um pistoleiro barra pesada que chega a uma cidade que está em guerra. Quando percebem o potencial de Joe, ambas as partes se interessam por contratá-lo; é quando ele percebe que pode ganhar um dinheiro com a situação aceitando a proposta dos dois lados."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Per un grapat de dòlars","runtime":0,"tagline":"Aquest curt cigar, aquesta arma llarga i aquest ponxo pertanyen a un home sense nom.","homepage":"","overview":"Un pistoler gringo arriba a San Miguel, un poblet fronterer entre Mèxic i els Estats Units devastat pels enfrontaments successius entre dos poderosos clans rivals. D'una banda, els Rojo, tres germans dedicats al contraban d'alcohol, i de l'altra, els Baxter, que trafiquen amb armes. La destresa amb el revòlver i el seu enginy li serviran per llogar els seus serveis a tots dos bàndols sense que se n'assabentin. Mentre actua només en benefici propi tot va bé, però quan decideix fer costat a la dona que Ramón Rojo manté segrestada aquest joc perillós comença a trontollar."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"За шепа долари","runtime":99,"tagline":"","homepage":"","overview":"\"За шепа долари\" е първият филм от така наречената \"Доларова трилогия\" на Серджо Леоне, включваща филмите \"За няколко долара повече\" (1965) и \"Добрият, лошият и злият\" (1966). Една от ключовите роли изпълнява Клинт Истууд, а музиката е на Енио Мориконе.  Неизвестен, но смъртоносен човек, пристига в град, разкъсван от война между два рода - Рохе и Бакстър. Но вместо да избяга или да умре, както би се случило с мнозина други, човекът се опитва да играе двойна игра, извличайки полза от това."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"به خاطر یک مشت دلار","runtime":0,"tagline":"","homepage":"","overview":"فیلم یکی از فیلم های سه گانه دلار است که شامل دو فیلم «خوب، بد، زشت» و « بخاطر چند دلار بیشتر» نیز هست، ـ این فیلم جریان ساز بر اساس فیلم یوجیمبو اثر كوروساوا ساخته شده است و اولین وسترن ایتالیایی سرجیو لئونه می باشد. همین طور اولین اثر مشهور موریكونه (آهنگساز) و اولین نقش مهم كلینت ایستوود می باشد. هنوز كه هنوزاست پس از گذشت سالها هنوز از محبوب ترین و مشهور ترین فیلم های تاریخ سینما می باشد.داستان هوشمندانه,شخصیت پردازی منحصر به فرد,كلوزاپ ها و لانگ شات های استادانه ,میزانسن های پیچیده خاص لئونه به همراه موسیقی خیال انگیز و شاهكار موریكونه كه به شكل شگفت انگیزی روی تصاویر با شكوه فیلم می نشیند(خصوصا در سكانس دوئل پایانی) این فیلم را به یكی از جذاب ترین فیلم های تمام ادوار تاریخ سینما تبدیل كرده است. یک هفت تیر کش (کلینت ایستوود) به شهر کوچکی میرسد که دو خانواده اصلی شهر رابطه خوبی ندارند. تیزبازی درمیاورد و مخفیانه از این خانواده علیه آن خانواده و از آن خانواده علیه این یکی خانواده پول میگیرد. بالاخره گند قضیه درمیاید..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"For en neve dollars","runtime":0,"tagline":"","homepage":"","overview":"En ensom navnløs rytter (spilt av Clint Eastwood) ankommer den lille mexikanske byen San Miguel nær grensen til Arizona i 1872. Det er dødsstille i byen, men et barn løper tvers over gaten og roper på sin mor. Det er en spent og mystisk stemning, og snart blir det klart at dette skyldes to brutale bander som holder byen i et jerngrep. Joe blir snart innblandet i rivaliseringen og velger å ta opp kampen ved å spille bandene ut mot hverandre."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Por un puñado de dólares","runtime":99,"tagline":"El misterioso \"Hombre sin Nombre\" se involucra en una guerra entre bandas rivales, en un pueblo fronterizo mexicano.","homepage":"","overview":"Un forastero llega al pequeño pueblo de San Miguel. Silvanito, el posadero de la ciudad, le cuenta al forastero sobre una disputa entre dos familias que compiten por obtener el control de un pueblo de hombres muertos y mujeres viudas."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Už saują dolerių","runtime":0,"tagline":"","homepage":"","overview":"Į miestelį, kuriame kovoja dvi grupuotės, atvyksta nepažįstamasis. Jis pasiryžęs įvesti savo tvarką ir nenusileisti niekam."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Za hrsť dolárov","runtime":99,"tagline":"Svojím spôsobom je možno najnebezpečnejším mužom, aký kedy žil!","homepage":"","overview":"Do zaprášeného mexického mestečka San Miguel na hraniciach Mexika a USA príde muž, ktorému visia kolty prekliate nízko. Pištoľník Joe sa rýchlo spriatelí s majiteľom miestneho baru Silvanitom. Cudzinec odhalí, že mestečko terorizujú dve znepriatelené gangsterské rodiny - americkí Baxterovci, ktorých vedie John Baxter, a mexickí Rojovci, ktorým zase velí Ramón Rojo. Znepriatelené rodiny by mali vetriť nebezpečenstvo, obe sú však natoľko zamestnané vlastnou žabomyšou vojnou, že nevidia, ako pištoľník Joe rozohrá hru na obe strany. Keď Joe zastrelí štyroch mužov z Baxterovho gangu, Ramónov brat Esteban mu ponúkne, aby vstúpil do ich bandy. Joe naoko pre Rojovcov pracuje, ale súčasne robí aj pre Baxterovcov. Využíva tak vzájomnú nevraživosť oboch gangov vo svoj vlastný prospech a darí sa mu to až do bodky..."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"荒野大鏢客","runtime":99,"tagline":"","homepage":"","overview":"西部片中的經典之作，克林伊斯威特成名之作。  本片講述發生在墨西哥小鎮上的故事，一位大鏢客來到該鎮，看到鎮上的居民被兩個大私梟，一個販賣私械，一個販賣私酒，弄得妻離子散，家破人亡。  正義感使然，他運用計謀讓兩派火拼，把鎮上的惡勢力一網打盡，使鎮上的居民回復了平靜。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Một Nắm Đô La","runtime":0,"tagline":"","homepage":"","overview":"Một anh chàng cao bồi, vốn được coi là The Man with No Name, đi tới một thị trấn ở biên giới Mexico tên là San Miguel. Ở đây, anh bắt gặp một bầu không khí căng thẳng của những người dân thường trong thị trấn, lại bị một nhóm thanh niên nổ súng đe dọa và cười chế nhạo anh. Ông già chuyên bán quan tài thì nhìn anh để ước lượng số đo vì dự tính anh sẽ là khách hàng trong tương lai của mình. Bước vào một nhà trọ nhỏ, anh được ông chủ cho biết về tình trạng của thị trấn, vốn có 2 phe, vốn là 2 gia đình, hùng cứ và tranh chấp nhau. Đó là gia đình của an hem Rojo, gồm có Don Miguel (người anh cả), Esteban (người khỏe nhất) và Ramon (người giỏi nhất, thông minh nhất và hiểm ác nhất); gia đình kia là của cảnh sát trưởng thị trấn..."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"นักฆ่าเพชรตัดเพชร","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Pour une poignée de dollars","runtime":95,"tagline":"À sa manière, il est peut-être l'homme le plus dangereux qui ait jamais existé !","homepage":"","overview":"Joe, un tireur d'élite, arrive dans une bourgade mexicaine proche de la frontière, San Miguel. Deux bandes rivales, les Baxter et les Rodos, se disputent le contrôle de la région. Joe, qui assiste à un massacre de soldats mexicains par les Rodos, décide de tirer profit de la situation pour gagner quelques dollars. Il incite les bandits à se battre entre eux dans l'espoir de récupérer l'or que détient Ramon, le chef des Rodos. Un premier affrontement entre les bandits élimine une bonne partie des Baxter. Joe se charge de tuer lui-même les Rodos survivants. Une opération d'autant plus facile à imaginer que Joe a découvert le point faible du plus farouche des fils Rodos, son amour pour Marisol, une jolie Mexicaine..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Za šaku dolara","runtime":0,"tagline":"Na neki svoj način, on je možda i najopasniji čovjek koji je ikad postojao!","homepage":"","overview":"Revolveraš osamljenik Joe dolazi u zabito mjesto u New Mexicu u kojemu mir remete sukobi dviju suparničkih obitelji, Baxter i Rojo. Svjesne njegovih revolveraških sposobnosti, obje ga obitelji žele angažirati. Iako mu nijedna od njih nije simpatična, Joe prihvaća obje ponude i vješto manipulira sa sukobljenima, sve do kritičnog trenutka kad se i sam nađe u opasnosti."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"獨行俠連環奪命槍","runtime":0,"tagline":"","homepage":"","overview":"講述一個槍法出眾的牛仔來到墨西哥的一個小鎮，這個小鎮上存在著兩個勢均力敵的勢力，都試圖消滅對方獨自掌權。這個外鄉人同時受僱於兩個勢力，結局城鎮參興械鬥的幫派分子全部陣亡，只留下了和平的鎮民。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Za pest dolarjev","runtime":0,"tagline":"Špageti vestern","homepage":"","overview":"Prvi veliki uspeh Sergia Leoneja, s katerim je žanru špageti vesterna postavil temelje in ga tudi močno populariziral, zagotovo pomeni enega od vrhuncev v zgodovini italijanskega filma.\r V mehiško vas San Miguel prispe brezimni revolveraš. V vasi že dolgo tli spor med brati družine Rojo in vaškim šerifom Baxterjem. Ko bratje Rojo nekega dne postavijo zasedo regimentu mehiških vojakov, ki v vas prinese zlato za odkup orožja, brezimni revolveraš pri priči zasluti priložnost za zaslužek in se odloči, da bo z ukano zaostril odnose med sprtima stranema ter se tako sam dokopal do dobička."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"من اجل حزمة دولارات","runtime":0,"tagline":"","homepage":"","overview":"يدور الفيلم حول غريب يصل إلى بلدة (سان ميغيل) الصغيرة ليخبره صاحب الخان هناك عن العداوة والبغضاء بين عائلتين تسعيان للسيطرة على البلدة.  ويحاول الغريب الاستفادة من الوضع وجني المال، فيقرر التلاعب بالعائلتين ليجعل إحداهما ضد الأخرى، وتأتي فرصته مع مرور شحنة ذهب عبر المدينة برفقة سرية من الجيش المكسيكي."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Peotäis dollareid","runtime":0,"tagline":"","homepage":"","overview":"Nimetu mees ratsutab linnakesse, mis kannatab kahe osapoole omavahelise sõja tõttu. Nimetu mees aga ei põgene ega ka sure, ta näeb hoopis võimalust Baxterite ja Rojode vihavaenust omale kasumit lõigata ja asubki selle nimel tegutsema..."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"}],"reviews_tmdb":[{"id":"5fe1f79069eb9000409afcdc","url":"https://www.themoviedb.org/review/5fe1f79069eb9000409afcdc","author":"AshJohann","content":"Funny child acting, nonsense sense of distance, bad dubbing and weak dialogue bring down an otherwise magnificent film. A Western remake of Yojimbo, it's remarkable how such a simple story can lend itself to such a great experience. The atmosphere is built up masterfully - with stunning cinematography, striking close-ups, beautifully constructed mise-en-scene, a fantastic performance from Eastwood, Moricone's ever powerful music, and a lovely overabundance of laughing - all culminating in one of the best showdowns in cinematic history.","created_at":"2020-12-22T13:41:36.114Z","updated_at":"2021-06-23T15:58:49.051Z","author_details":{"name":"","rating":8,"username":"AshJohann","avatar_path":"/3BYGrkMQCX1psKVzOaDgi1wlYHb.jpg"}},{"id":"61117ce4344a8e005e2c23e6","url":"https://www.themoviedb.org/review/61117ce4344a8e005e2c23e6","author":"Venti_Pro","content":"Even better than I remember. The story was more interesting than I remembered. The Man With No Name is more fun in this movie than I remembered. The side characters are more interesting than I remembered. My only complaints are that some of the acting and parts of the script could be better. This is really epic movie that I would not mind watching again!","created_at":"2021-08-09T19:07:16.890Z","updated_at":"2021-08-10T18:05:04.641Z","author_details":{"name":"","rating":null,"username":"Venti_Pro","avatar_path":null}},{"id":"61dc6b2c665408001e4fd974","url":"https://www.themoviedb.org/review/61dc6b2c665408001e4fd974","author":"r96sk","content":"A supremely entertaining western from 1964!\r\n\r\nI will say the dubbing nature of <em>'A Fistful of Dollars'</em> is a little distracting early on, but by the time the opening portion concluded I was incredibly interested in what was happening onscreen. The pacing is excellent, thanks to some very fine cinematography, great action sequences and a top notch score.\r\n\r\nClint Westwood debuts as a leading movie star and is terrific throughout, portraying the wonderfully named J̶o̶e̶ \"the Man with No Name\". It's little surprise these are the films that truly made him. Away from Eastwood, I really enjoyed the trio that played the Rojo brothers - Gian Maria Volonté (aka Johnny Wels), Sieghardt Rupp and Antonio Prieto. They're just as important as the main man and play the roles superbly.\r\n\r\nBring on the sequels!","created_at":"2022-01-10T17:21:48.062Z","updated_at":"2022-01-10T17:21:48.062Z","author_details":{"name":"","rating":9,"username":"r96sk","avatar_path":"/mwR7rFHoDcobAx1i61I3skzMW3U.jpg"}},{"id":"643ed7aa8d22fc057126b048","url":"https://www.themoviedb.org/review/643ed7aa8d22fc057126b048","author":"drystyx","content":"$11","created_at":"2023-04-18T17:47:22.224Z","updated_at":"2023-04-18T17:47:22.308Z","author_details":{"name":"","rating":1,"username":"drystyx","avatar_path":"/hLLsAvAnVT0cFU7JuuaaItTWXv8.jpg"}},{"id":"654775d9fd4f8000c7fc9e57","url":"https://www.themoviedb.org/review/654775d9fd4f8000c7fc9e57","author":"CinemaSerf","content":"$12","created_at":"2023-11-05T11:00:41.285Z","updated_at":"2023-11-05T11:01:46.593Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}},{"id":"675977ebad918721d0dee876","url":"https://www.themoviedb.org/review/675977ebad918721d0dee876","author":"dfle3","content":"$13","created_at":"2024-12-11T11:30:51.237Z","updated_at":"2025-03-25T05:44:47.597Z","author_details":{"name":"","rating":8,"username":"dfle3","avatar_path":null}}],"recommendations":[{"id":938,"adult":false,"title":"For a Few Dollars More","video":false,"overview":"Two bounty hunters both pursue the brutal and sadistic bandit, El Indio, who has a large bounty on his head.","genre_ids":[37],"media_type":"movie","popularity":5.753,"vote_count":4332,"poster_path":"/ooqASvA7qxlTVKL3KwOzBwy57Dh.jpg","release_date":"1965-12-18","vote_average":8.015,"backdrop_path":"/x0bQvdpr88xVhMrVM93tEIKSM2q.jpg","original_title":"Per qualche dollaro in più","original_language":"it"},{"id":984,"adult":false,"title":"Dirty Harry","video":false,"overview":"When a madman dubbed 'Scorpio' terrorizes San Francisco, hard-nosed cop, Harry Callahan – famous for his take-no-prisoners approach to law enforcement – is tasked with hunting down the psychopath.","genre_ids":[28,80,53],"media_type":"movie","popularity":3.7687,"vote_count":2672,"poster_path":"/scl2JDHzYoIEs5xyYy5ITCfyY0G.jpg","release_date":"1971-12-23","vote_average":7.4,"backdrop_path":"/mJjOZSaTTqG3an5MkkOX3x18lYX.jpg","original_title":"Dirty Harry","original_language":"en"},{"id":336,"adult":false,"title":"Duck, You Sucker","video":false,"overview":"At the beginning of the 1913 Mexican Revolution, greedy bandit Juan Miranda and idealist John H. Mallory, an Irish Republican Army explosives expert on the lam from the British, fall in with a band of revolutionaries plotting to strike a national bank. When it turns out that the government has been using the bank as a hiding place for illegally detained political prisoners -- who are freed by the blast -- Miranda becomes a revolutionary hero against his will.","genre_ids":[37],"media_type":"movie","popularity":1.7196,"vote_count":1153,"poster_path":"/nWmAtZf83qpOai0fzehf7Hn1S3R.jpg","release_date":"1971-10-29","vote_average":7.7,"backdrop_path":"/tXjtTg1TcpqUePNgdFrBg56hMUC.jpg","original_title":"Giù la testa","original_language":"it"},{"id":422,"adult":false,"title":"8½","video":false,"overview":"Guido Anselmi, a film director, finds himself creatively barren at the peak of his career. Urged by his doctors to rest, Anselmi heads for a luxurious resort, but a sorry group gathers—his producer, staff, actors, wife, mistress, and relatives—each one begging him to get on with the show. In retreat from their dependency, he fantasizes about past women and dreams of his childhood.","genre_ids":[18],"media_type":"movie","popularity":2.3802,"vote_count":2484,"poster_path":"/nqOsvzEamX7AyNwSx48OOV2iidE.jpg","release_date":"1963-02-14","vote_average":8.113,"backdrop_path":"/y2FNZLHynsevBnVTocGW6c3pQpr.jpg","original_title":"8½","original_language":"it"},{"id":335,"adult":false,"title":"Once Upon a Time in the West","video":false,"overview":"As the railroad builders advance unstoppably through the Arizona desert on their way to the sea, Jill arrives in the small town of Flagstone with the intention of starting a new life.","genre_ids":[18,37],"media_type":"movie","popularity":7.4044,"vote_count":4778,"poster_path":"/qbYgqOczabWNn2XKwgMtVrntD6P.jpg","release_date":"1968-12-21","vote_average":8.28,"backdrop_path":"/aKZ9hDmLJTaGSxWdhxqMTcvXmk4.jpg","original_title":"C'era una volta il West","original_language":"it"},{"id":429,"adult":false,"title":"The Good, the Bad and the Ugly","video":false,"overview":"While the Civil War rages on between the Union and the Confederacy, three men – a quiet loner, a ruthless hitman, and a Mexican bandit – comb the American Southwest in search of a strongbox containing $200,000 in stolen gold.","genre_ids":[37],"media_type":"movie","popularity":13.9705,"vote_count":9434,"poster_path":"/bX2xnavhMYjWDoZp1VM6VnU1xwe.jpg","release_date":"1966-12-23","vote_average":8.467,"backdrop_path":"/Adrip2Jqzw56KeuV2nAxucKMNXA.jpg","original_title":"Il buono, il brutto, il cattivo","original_language":"it"},{"id":168,"adult":false,"title":"Star Trek IV: The Voyage Home","video":false,"overview":"When a huge alien probe enters the galaxy and begins to vaporize Earth's oceans, Kirk and his crew must travel back in time in order to bring back whales and save the planet.","genre_ids":[878,12],"media_type":"movie","popularity":3.8542,"vote_count":1613,"poster_path":"/xY5TzGXJOB3L9rhZ1MbbPyVlW5J.jpg","release_date":"1986-11-26","vote_average":7.166,"backdrop_path":"/2LiU13aDAWpU2mX25JdacTzBnyr.jpg","original_title":"Star Trek IV: The Voyage Home","original_language":"en"},{"id":966,"adult":false,"title":"The Magnificent Seven","video":false,"overview":"An oppressed Mexican peasant village hires seven gunfighters to help defend their homes.","genre_ids":[37,28,12],"media_type":"movie","popularity":5.3745,"vote_count":1943,"poster_path":"/e5ToxOyJwuZD4VOfI0qEn5uIjeJ.jpg","release_date":"1960-10-12","vote_average":7.508,"backdrop_path":"/2aC3284N1p86o6S4Uyj9AaryYeR.jpg","original_title":"The Magnificent Seven","original_language":"en"},{"id":10734,"adult":false,"title":"Escape from Alcatraz","video":false,"overview":"San Francisco Bay, January 18, 1960. Frank Lee Morris is transferred to Alcatraz, a maximum security prison located on a rocky island. Although no one has ever managed to escape from there, Frank and other inmates begin to carefully prepare an escape plan.","genre_ids":[18,53],"media_type":"movie","popularity":4.4215,"vote_count":3068,"poster_path":"/uORr2GXQnyqgBOg6tVsRCJD2qxc.jpg","release_date":"1979-06-22","vote_average":7.504,"backdrop_path":"/lfLVH3F8Xt8nITqG9cn97b54au1.jpg","original_title":"Escape from Alcatraz","original_language":"en"},{"id":9394,"adult":false,"title":"They Call Me Trinity","video":false,"overview":"The simple story has the pair coming to the rescue of peace-loving Mormons when land-hungry Major Harriman sends his bullies to harass them into giving up their fertile valley. Trinity and Bambino manage to save the Mormons and send the bad guys packing with slapstick humor instead of excessive violence, saving the day.","genre_ids":[28,35,37],"media_type":"movie","popularity":2.6566,"vote_count":1418,"poster_path":"/qY7iV4BJD5IXJU4iXlcZxKN8s9w.jpg","release_date":"1970-12-22","vote_average":7.559,"backdrop_path":"/FzjWIXu3n714sYxQHq3TPEWz16.jpg","original_title":"Lo chiamavano Trinità...","original_language":"it"},{"id":11533,"adult":false,"title":"Jason and the Argonauts","video":false,"overview":"Jason, a fearless sailor and explorer, returns to his home land of Thessaly after a long voyage to claim his rightful throne. He learns, however, that he must first find the magical Golden Fleece. To do so, he must embark on an epic quest fraught with fantastic monsters and terrible perils.","genre_ids":[12,10751,14],"media_type":"movie","popularity":2.7331,"vote_count":674,"poster_path":"/xHVxIgqD5CxlOI5GHxvVSt5Zh5Y.jpg","release_date":"1963-06-13","vote_average":7.164,"backdrop_path":"/xdefSJpYARFdW4jPhPsuvUlmt2M.jpg","original_title":"Jason and the Argonauts","original_language":"en"},{"id":23832,"adult":false,"title":"For Love and Gold","video":false,"overview":"A group of rogues steal a scroll granting its bearer the property of the land of Aurocastro in Apulia, a province in the south of Italy. They elect a shaggy knight, Brancaleone from Norcia, as their leader, and decide to get possession of this supposedly wealthy land. Many adventures will occurr during the journey.","genre_ids":[35,12],"media_type":"movie","popularity":0.5786,"vote_count":389,"poster_path":"/zRdd1qYJpxKKy57ufAK4E7gi13W.jpg","release_date":"1966-04-07","vote_average":7.711,"backdrop_path":"/dELiIRHrpNpncIApojSW67kPNdQ.jpg","original_title":"L'armata Brancaleone","original_language":"it"},{"id":11897,"adult":false,"title":"How the West Was Won","video":false,"overview":"The epic tale of the development of the American West from the 1830s through the Civil War to the end of the century, as seen through the eyes of one pioneer family.","genre_ids":[37],"media_type":"movie","popularity":2.2467,"vote_count":479,"poster_path":"/rmwc89VMQR4rUSDfakd0Z6GyF6q.jpg","release_date":"1962-11-02","vote_average":7,"backdrop_path":"/4hK1fDFO2u4MmvMK2isOAzyweTL.jpg","original_title":"How the West Was Won","original_language":"en"},{"id":11916,"adult":false,"title":"Two Mules for Sister Sara","video":false,"overview":"When a wandering mercenary named Hogan rescues a nun called Sister Sara from the unwanted attentions of a band of rogues on the Mexican plains, he has no idea what he has let himself in for. Their chance encounter results in the blowing up of a train and a French garrison, as well as igniting a spark between them that survives a shocking discovery.","genre_ids":[37,12,10749],"media_type":"movie","popularity":2.1197,"vote_count":642,"poster_path":"/2G9eM8UAM57TanLBhuPmz3jaNZG.jpg","release_date":"1970-03-02","vote_average":6.957,"backdrop_path":"/iV8t0tdgJXRp7oPgWo0o1j2DrDk.jpg","original_title":"Two Mules for Sister Sara","original_language":"en"},{"id":5176,"adult":false,"title":"3:10 to Yuma","video":false,"overview":"In Arizona in the late 1800s, infamous outlaw Ben Wade and his vicious gang of thieves and murderers have plagued the Southern Railroad. When Wade is captured, Civil War veteran Dan Evans, struggling to survive on his drought-plagued ranch, volunteers to deliver him alive to the \"3:10 to Yuma\", a train that will take the killer to trial.","genre_ids":[37],"media_type":"movie","popularity":3.6637,"vote_count":3929,"poster_path":"/voMB69AsLnPNmtfbrBl0lbeFKDH.jpg","release_date":"2007-09-06","vote_average":7.226,"backdrop_path":"/2eznGndOi8s9CGReAvcQ8PEULwm.jpg","original_title":"3:10 to Yuma","original_language":"en"},{"id":11485,"adult":false,"title":"Take the Money and Run","video":false,"overview":"Virgil Starkwell is intent on becoming a notorious bank robber. Unfortunately for Virgil and his not-so-budding career, he is completely incompetent.","genre_ids":[35,80],"media_type":"movie","popularity":1.5312,"vote_count":777,"poster_path":"/dT7cKFxsuHzSnDBxKeP5acoIpWZ.jpg","release_date":"1969-08-18","vote_average":7.114,"backdrop_path":"/dB9pJFYLvaf9w2sYtVH9TYOu6Vr.jpg","original_title":"Take the Money and Run","original_language":"en"},{"id":33,"adult":false,"title":"Unforgiven","video":false,"overview":"William Munny is a retired, once-ruthless killer turned gentle widower and hog farmer. To help support his two motherless children, he accepts one last bounty-hunter mission to find the men who brutalized a prostitute. Joined by his former partner and a cocky greenhorn, he takes on a corrupt sheriff.","genre_ids":[37],"media_type":"movie","popularity":5.3539,"vote_count":4835,"poster_path":"/54roTwbX9fltg85zjsmrooXAs12.jpg","release_date":"1992-08-07","vote_average":7.9,"backdrop_path":"/rvRGFevvZK48onX0PYI1eQLbuJd.jpg","original_title":"Unforgiven","original_language":"en"},{"id":1093,"adult":false,"title":"Elevator to the Gallows","video":false,"overview":"A self-assured businessman murders his employer, husband of his mistress, which unintentionally provokes an ill-fated chain of events.","genre_ids":[80,18,53],"media_type":"movie","popularity":1.2519,"vote_count":681,"poster_path":"/jgeZS97po2luaeElfUh07VAbVfV.jpg","release_date":"1958-01-29","vote_average":7.601,"backdrop_path":"/r8fEOeDjlbtvaxYZ3QDh21gzpKh.jpg","original_title":"Ascenseur pour l'échafaud","original_language":"fr"},{"id":4929,"adult":false,"title":"Hang 'em High","video":false,"overview":"Marshall Jed Cooper survives a hanging, vowing revenge on the lynch mob that left him dangling. To carry out his oath for vengeance, he returns to his former job as a lawman. Before long, he's caught up with the nine men on his hit list and starts dispensing his own brand of Wild West justice.","genre_ids":[37,18],"media_type":"movie","popularity":2.603,"vote_count":822,"poster_path":"/2J9QEqdJWjL2etOf6Kf7n33PUK4.jpg","release_date":"1968-04-12","vote_average":6.833,"backdrop_path":"/jRveokBXITqXhUAdyD0kqqBolZ0.jpg","original_title":"Hang 'em High","original_language":"en"},{"id":426284,"adult":false,"title":"Blade of the Immortal","video":false,"overview":"Manji, a highly skilled samurai, becomes cursed with immortality after a legendary battle. Haunted by the brutal murder of his sister, Manji knows that only fighting evil will regain his soul. He promises to help a young girl named Rin avenge her parents, who were killed by a group of master swordsmen led by ruthless warrior Anotsu. The mission will change Manji in ways he could never imagine.","genre_ids":[28,14,12],"media_type":"movie","popularity":1.8039,"vote_count":612,"poster_path":"/bFaxg006Dt6J1k7qa7a5YuqbAhe.jpg","release_date":"2017-04-29","vote_average":6.7,"backdrop_path":"/aP6MVLsZpQ51p93PwNsyy1TVUIW.jpg","original_title":"無限の住人","original_language":"ja"}],"similar_content":[{"id":313332,"adult":false,"title":"The Luck of Roaring Camp","video":false,"overview":"When the miners of Roaring Camp become Godfathers to a motherless baby, they name the boy Luck and promise to set aside money for him from their diggings. But when they strike it rich the money is gambled away instead.","genre_ids":[37,12],"popularity":0.2169,"vot