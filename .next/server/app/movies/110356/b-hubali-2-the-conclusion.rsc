wvR1GnHiIf.jpg","iso_639_1":null,"vote_average":0.166},{"width":1284,"height":721,"file_path":"/zjvvHGr0UWndAL8zvLpB2SVeGnb.jpg","iso_639_1":null,"vote_average":0.166},{"width":1566,"height":880,"file_path":"/qzyAvVnS8kcSZ8WDcoGqFTYcXJG.jpg","iso_639_1":null,"vote_average":0.166},{"width":1566,"height":880,"file_path":"/yGk5RLnWX53Jve7HHVCNQaLF28h.jpg","iso_639_1":null,"vote_average":0.166},{"width":1600,"height":900,"file_path":"/7q5KYw74THtisINQ0QJvhccjMpe.jpg","iso_639_1":null,"vote_average":0.166},{"width":1566,"height":880,"file_path":"/58OoTtcaG384r49vC0q6FwhwEEy.jpg","iso_639_1":null,"vote_average":0.166},{"width":1566,"height":880,"file_path":"/8dFZTpOdYTiE8eUsUTKQuzOb6Vr.jpg","iso_639_1":null,"vote_average":0.166},{"width":1920,"height":1079,"file_path":"/fC9CSxyfTXjXz2giTsgtiqxbitG.jpg","iso_639_1":null,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/b0HKEnOgClOCAf8y5tJSpCKpvwv.jpg","iso_639_1":null,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/5Uk0DeIpPnnPvSMjWGFirAtiYC7.jpg","iso_639_1":"ta","vote_average":0},{"width":1284,"height":721,"file_path":"/dp7ts4xbrlrIP1ayaQ7SxHtHcFK.jpg","iso_639_1":null,"vote_average":0},{"width":1566,"height":880,"file_path":"/jFJm7yA78CEsImrNHeYykUpgRWo.jpg","iso_639_1":"en","vote_average":0}]},"enriched_at":"2026-04-21T05:11:32.574+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Bāhubali 2: The Conclusion","runtime":167,"tagline":"","homepage":"http://baahubali.com","overview":"When Mahendra, the son of Bāhubali, learns about his heritage, he begins to look for answers. His story is juxtaposed with past events that unfolded in the Mahishmati Kingdom."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"ബാഹുബലി  2: ദ് കൺക്ലൂഷൻ","runtime":167,"tagline":"","homepage":"http://baahubali.com/the-conclusion/","overview":""},"name":"","iso_639_1":"ml","iso_3166_1":"IN","english_name":"Malayalam"},{"data":{"title":"Baahubali: The Conclusion","runtime":0,"tagline":"","homepage":"","overview":"El amor entre dos jóvenes se vera truncado,pero tendrán una segunda oportunidad en otra vida paralela."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"Baahubali 2: Die Schlussfolgerung","runtime":0,"tagline":"","homepage":"","overview":"Mit der indischen Fortsetzung Bahubali: The Conclusion wird die Geschichte um Baahubhali / Shivudu (Prabhas) beendet, die mit Bahubali: The Beginning (2015) ihren Anfang nahm. Nachdem der Vorgängerteil mit einem Cliffhanger endete, wird der mittelalterliche indische Konflikt in der Saga um zwei Brüder in einer epischen Schlacht sein Ende finden."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Baahubali 2: The Conclusion","runtime":161,"tagline":"O maior sucesso de bilheteira de sempre da Índia","homepage":"","overview":"Na Índia antiga, um homem aventureiro e ousado envolve-se numa disputa de décadas entre duas pessoas guerreiras."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Baahubali 2: Sonuç","runtime":0,"tagline":"","homepage":"","overview":"Şaşalı eski bir krallığın taht kavgaları sonucunda asıl varis olarak dünyaya gelen prensin kundakta uğradığı suikastten annesinin yardımı ile hayatta kalmayı başararır. Lakin bu başarı Baahubali’yi gerçek annesinden ve benliğinden habersiz büyümesine nedenn olur. Aradan uzun yıllar geçerek Baahubali yetişkin, güçlü, çevik, atik, zeki, gözü pek ve dövüş konusunda maheretli bir bir birey olarak yetişir. Sonrasında alında da yazılı olan kader yolunu takip ederek asıl benliğini bulması ile hakkı olan ülkesinin padişahlığına oturarak ülkesinin savaş eşiğine gelmesi ile olaylara hükmetmeye çalışıyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Baahubali 2: A befejezés","runtime":159,"tagline":"","homepage":"","overview":"Shiva, Bahubali fia megismeri örökségét ám ez rengeteg további kérdést vet fel benne, amelyre elindul megkeresni a válaszokat."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"巴霍巴利王2：终结","runtime":0,"tagline":"","homepage":"","overview":"　　根据印度神话传说改编而来，讲述勇猛、善良的巴霍巴利王和他的儿子希瓦，对抗邪恶的兄弟巴拉迪瓦，争夺摩西施末底王国控制权的故事。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Бахубали: Рождение легенды","runtime":167,"tagline":"","homepage":"","overview":"Старый Каттаппа рассказывает Шиве, почему убил его отца Амарендру. После того, как тот был усыновлён королевой Сивагами, старший сводный брат Бхаллаладева всегда ему завидовал. Зависть достигла апогея после битвы с дикими племенами, когда Сивагами нарекла младшего сына наследником королевства. Бхаллаладева и его хитрый дядя начинают плести грязные интриги, чтобы сжить Амарендру со свету."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"바후발리 2: 더 컨클루전","runtime":167,"tagline":"","homepage":"","overview":"선왕 바후발리와 데바세나와의 사랑 그리고 그의 죽음과 마히쉬마티 제국의 몰락에 대한 이야기가 스크린으로 펼쳐진다. 그리고 자신의 출생의 비밀을 알게 된 시부두는 과연 발랄라데바의 폭정으로부터 백성을 구할 수 있을 것인가."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Бахубали 2","runtime":167,"tagline":"","homepage":"","overview":"Когато Шива, синът на Бахубали, научава за наследството си, започва да търси отговори. Историята му е съпоставена с минали събития, случили се в царство Махишмати."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Бахубалі: Народження легенди","runtime":0,"tagline":"","homepage":"","overview":"Старий Каттаппа розповідає Шиві, чому вбив його батька Амарендру. Після того, як той був усиновлений королевою Сівагамі, старший зведений брат Бхаллаладева завжди йому заздрив. Заздрість досягла апогею після битви з дикими племенами, коли Сівагамі нарекла молодшого сина спадкоємцем королівства. Бхаллаладева і його хитрий дядько починають плести брудні інтриги, щоб зжити Амарендру зі світу."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Baahubali 2 : La conclusion","runtime":167,"tagline":"","homepage":"","overview":"Shivudu, un jeune villageois découvre sa vraie identité, de descendance royale. Il sauvera la Reine Devasena asservie par le terrible Bhalladeva dont le seul et unique objectif est de garder son trône et, de tuer le fils de son ennemi : le Roi BAAHUBALI."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"巴霍巴利王：磅礴终章","runtime":0,"tagline":"","homepage":"","overview":"仁德的巴霍巴利王之後──濕婆度，得知自己的身世後，開始尋找一切謎團的解答。巴霍巴利王為何被忠臣卡塔帕所殺？濕婆度有辦法戰勝權謀深算的叔叔帕拉提婆嗎？馬西馬帝王國的最終命運即將揭曉！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"באהובאלי 2: המסקנה","runtime":0,"tagline":"","homepage":"","overview":"לאחר שחשף את האמת על מורשתו, מהנדרה באהובאלי, נוקם את רצח אביו, כשהוא נשבע לנקום בשליט העריץ של ממלכת מהישמאטי, דודו, בהללאדווה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"เปิดตำนานบาฮูบาลี 2","runtime":0,"tagline":"","homepage":"","overview":"พระเจ้าอยู่หัวบาฮูบาลี เป็นกษัตริย์ที่ก้าวขึ้นสู่อำนาจโดยการแต่งตั้งของ มหาราชินีศิวากามี โดยตั้งขึ้นมาข้ามหัวภัลลาเทวะผู้พี่ ส่งผลให้ผู้พี่มีความอิจฉาริษยาน้องชายมาก ต่อมาบาฮูบาลีได้ปลอมตัวออกไปเที่ยวนอกวังแล้วไปตกหลุมรักเดวาเซน่า เจ้าหญิงเมืองประเทศราชเล็กๆ แต่เป็นคนที่มีจิตใจเข้มแข็งเย่อหยิ่งในศักดิ์ศรี พี่ชายของบาฮูบาลีทราบเรื่องเลยไปทูลขอให้ราชินีศิวากามีแต่งจดหมายไปสู่ขอเดวาเซน่ามาเป็นภรรยาของตัวเอง แต่ด้วยเนื้อความที่เขียนไปว่าขอให้ลูกชาย บาฮูบาลีกับเดวาเซน่าเลยเข้าใจผิดคิดว่าพระราชินีศิวากามีต้องการให้ทั้งสองแต่งงานกัน แต่พอไปถึงเข้าจริงๆเลยพบว่าเป็นเรื่องเข้าใจผิด บาฮูบาลีเลยจำต้องยกบัลลังก์ให้พี่ชายตัวเอง เพื่อให้ตัวเองได้แต่งงานกับเดวาเซน่า แล้วบาฮูบาลีก็ลดตำแหน่งตัวเองเป็นแม่ทัพ แต่ประชาชนทั้งแผ่นดินกลับจงรักภักดีต่อบาฮูบาลีมากกว่า โดยในวันพิธีบรมราชิภิเษก ไพร่ฟ้าหน้าใส และกองทัพช้างศึกแห่งแผ่นดินอินเดียต่างกู่ร้องกระทืบเท้าเอ่ยนามบาฮูบาลี จนแผ่นดินไหวสั่นสะเทือนไปจนฉัตรที่ประดับเหนือบัลลังก์ของภัลลาเทวะหักลงมา"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"バーフバリ 王の凱旋","runtime":141,"tagline":"王を称えよ！宇宙最強の愛と復讐、ここに完結。","homepage":"","overview":"ある日、シヴドゥは自分が今や人々の語り草となっている伝説のヒーロー、バーフバリの息子だと知る。彼は父親の家臣カッタッパから父はある人物の裏切り行為により命を落とし、王座を追われたという話を聞く。かつて父バーフバリはカーラケーヤとの戦いに勝利し、国母シヴァガミから王位継承者として認められ……。\r 伝説の戦士バーフバリの壮大な物語を描いたアクション『バーフバリ　伝説誕生』の完結編。インドの王国を舞台に、祖父から孫の三代にわたる愛と裏切りと復讐（ふくしゅう）を描く。前作同様プラバースが主人公を演じ、ラーナー・ダッグバーティ、アヌシュカ・シェッティ、タマンナー、ナーサルらも続投。監督・脚本のS・S・ラージャマウリ、撮影のK・K・センティル・クマール、音楽のM・M・キーラヴァーニらスタッフも再び集結した。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":167,"tagline":"","homepage":"","overview":"Wanneer Shiva, de zoon van Baahubali, hoort over zijn erfenis, gaat hij op zoek naar antwoorden. Ondertussen komt hij ook te weten waarom Kattappa zijn vader Baahubali heeft vermoord. Zijn verhaal wordt afgewisseld met gebeurtenissen uit het verleden die zijn gebeurd in het Mâhishmatî Koninkrijk."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Baahubali 2: A Conclusão","runtime":167,"tagline":"A conclusão da saga!","homepage":"","overview":"Shivudu, o filho de Bahubali, está cada vez mais perto de conhecer sua verdadeira herança e encarar de vez suas novas responsabilidades. Querendo respostas para questões que fogem de seu conhecimento, como o real motivo por trás da morte de seu pai, ele encontrará uma barreira para os seus planos devido aos fatos de seu próprio passado."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Baahubali 2: The Conclusion","runtime":0,"tagline":"","homepage":"","overview":"Baahubali a Bhallaldev  jsou bratři z mocného království Mahishmati, kteří se zamilují do krásné princezny Devaseny z malého království Kunt. Devasena se zamiluje do Baahubaliho, čímž naruší záměry královny Matky a způsobí rozkol v královském paláci. Ctižádostivý Bhallaldev se obává popularity svého bratra a přikáže proto otroku Kattappovi zabít Baahubaliho."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Baahubali 2: La conclusión","runtime":167,"tagline":"","homepage":"","overview":"Baahubali es coronado rey de Mahishmati pero las conspiraciones de su hermano no tardarán en amenazar al reino. La aparición de una princesa de un reino vecino abrirá las puertas de un gran conflicto."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"ბაჰუბალი 2: დასრულება","runtime":0,"tagline":"","homepage":"","overview":"მოხუცი კატაპა უამბობს შივას, თუ რატომ მოკლა მისი მამა ამარენდრუ. მას შემდეგ, რაც იგი იშვილა დედოფალმა შივაგამამ, უფროსი ნახევარ ძმა ბხალალადევა ყოველთვის შურდა მისი…"},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Baahubali a Bhallaldev sú bratia z mocného kráľovstva Mahishmati, ktorí sa zamilujú do krásnej princeznej Devaseny z malého kráľovstva Kunt. Devasena sa zamiluje do Baahubaliho, čím narušia zámery kráľovnej Matky a spôsobia rozkol v kráľovskom paláci. Ctižiadostivý Bhallaldev sa obáva popularity svojho brata a prikáže preto sluhovi Kattappovi zabiť Baahubaliho."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"巴霍巴利王：磅礡終章","runtime":0,"tagline":"","homepage":"","overview":"在這部以印度語敘事的歷史傳説最終篇中，一名年輕男子為了報殺父之仇，率領一支軍隊對抗一位殘酷的暴君。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Baahubali 2 The Conclusion","runtime":168,"tagline":"Quando Mahendra, il figlio di Baahubali, viene a conoscenza della sua eredità, inizia a cercare risposte.","homepage":"http://baahubali.com","overview":"Shivudu, un giovane abitante del villaggio scopre la sua vera identità, di discendenza reale. Salverà la regina Devasena schiava del terribile Bhalladeva il cui unico obiettivo è mantenere il suo trono e, uccidere il figlio del suo nemico: il re BAAHUBALI."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Baahubali 2: Finalul","runtime":167,"tagline":"","homepage":"","overview":"Cea mai scumpă saga indiană realizată vreodată are parte de un final epic. Când Şiva, fiul lui Baahubali, descoperă trecutul familiei sale, războinicul pornește într-o extraordinară călătorie pentru a obține răspunsuri. Povestea lui este inspirată de legendarele bătălii ale regatului Mahishmati."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Sử Thi Baahubali 2: Kết Thúc","runtime":0,"tagline":"","homepage":"","overview":"Nội dung của phim Baahubali 2 tiếp nối câu chuyện của phần 1, lúc này Kattappa (Sathyaraj) tiếp tục kể về câu chuyện mà ông đã giết Amarendra Baahubali (Prabhas) như thế nào. Sau khi đánh bại Kalakeyas, Amarendra chính thức trở thành vị vua kế tiếp của Mahishmati, trong khi đó Bhallaladeva (Rana Daggubati) được phong lên chức tướng quân. Trước lễ đăng quang, Rajamatha Sivagami (Ramya Krishnan) bắt đầu tìm cho Amarendra một nàng dâu ưng ý. Bà đưa Amarendra và Kattappa đi thị sát khắp vương quốc để hiểu hơn về tình trạng hiện tại của quốc gia cũng như cuộc sống của những người dân nơi đây. Tuy nhiên, Amarendra từ trước đã yêu Devasena (Anushka Shetty), công chúa của vương quốc Kuntala và là em gái của vua Kuntala. Mặc dù vậy, Sivagami không muốn 2 người này đến với nhau bởi những xung đột của 2 nước, vì vậy bà đã ra sức ngăn cản. Để rồi sau đó là những biến cố và những cuộc chiến xảy đến."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"తెలుగు","iso_639_1":"te","iso_3166_1":"IN","english_name":"Telugu"},{"data":{"title":"பாகுபலி 2","runtime":0,"tagline":"","homepage":"","overview":""},"name":"தமிழ்","iso_639_1":"ta","iso_3166_1":"IN","english_name":"Tamil"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Όταν ο Mahendra, ο γιος του Bāhubali, μαθαίνει για την κληρονομιά του, αρχίζει να ψάχνει για απαντήσεις. Η ιστορία του αντιπαρατίθεται με γεγονότα του παρελθόντος που εκτυλίχθηκαν στο βασίλειο Mahishmati."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"}],"reviews_tmdb":[],"recommendations":[{"id":256040,"adult":false,"title":"Bāhubali: The Beginning","video":false,"overview":"The young Shivudu is left as a foundling in a small village by his mother. By the time he’s grown up, it has become apparent that he possesses exceptional gifts. He meets the beautiful warrior princess Avanthika and learns that her queen has been held captive for the last 25 years. Shividu sets off to rescue her, discovering his own origins in the process.","genre_ids":[28,18],"media_type":"movie","popularity":3.1581,"vote_count":904,"poster_path":"/9BAjt8nSSms62uOVYn1t3C3dVto.jpg","release_date":"2015-07-10","vote_average":7.518,"backdrop_path":"/e9ZEuHGHZ06AToHlfN1L7nejJ7W.jpg","original_title":"బాహుబలి:ద బిగినింగ్","original_language":"te"},{"id":14163,"adult":false,"title":"Chak De! India","video":false,"overview":"A team of rag-tag girls with their own agenda form Team India competing for international fame in field hockey. Their coach, the ex-men's Indian National team captain, returns from a life of shame after being unjustly accused of match fixing in his last match. Can he give the girls the motivation required to win, while dealing with the shadows of his own past?","genre_ids":[18],"media_type":"movie","popularity":0.801,"vote_count":364,"poster_path":"/9wP26QtbLUADWsfZZ8v2sJDWKdZ.jpg","release_date":"2007-08-09","vote_average":7.198,"backdrop_path":"/wvmxctQLD1vHZvsP1Rhe0mZLb26.jpg","original_title":"चकदे! इंडिया","original_language":"hi"},{"id":564147,"adult":false,"title":"K.G.F: Chapter 1","video":false,"overview":"A period drama set in the 1970s, KGF follows the story of a fierce rebel who rises against the brutal oppression in Kolar Gold Fields and becomes the symbol of hope to legions of downtrodden people.","genre_ids":[28,53,12,80],"media_type":"movie","popularity":1.9477,"vote_count":264,"poster_path":"/ltHlJwvxKv7d0ooCiKSAvfwV9tX.jpg","release_date":"2018-12-20","vote_average":7.462,"backdrop_path":"/4i1ofsSpfTuswHXcgPtXbZrSnoe.jpg","original_title":"ಕೆಜಿಎಫ್ ಅಧ್ಯಾಯ ೧","original_language":"kn"},{"id":117751,"adult":false,"title":"Ustad Hotel","video":false,"overview":"When his father refuses to support his choice of a career, an aspiring chef tries to fulfil his dream by helping his grandfather run his small eatery.","genre_ids":[18,35],"media_type":"movie","popularity":0.3994,"vote_count":105,"poster_path":"/88QYspKRArRutF3t0Bzj0JYFlcI.jpg","release_date":"2012-06-29","vote_average":7.5,"backdrop_path":"/u792SfQyGVFpAsIAm44sILx2eLN.jpg","original_title":"ഉസ്‌താദ്‌ Hotel","original_language":"ml"},{"id":607885,"adult":false,"title":"Chanakya","video":false,"overview":"Arjun aka Ramakrishna is a RAW marshall from Delhi who has a 100% success rate at nabbing terrorists. What happens when he makes enemies out of India's most wanted Ibrahim Qureshi and his son Sohail?","genre_ids":[28,53],"media_type":"movie","popularity":0.3677,"vote_count":8,"poster_path":"/fTroJBj6IZE58OfCetvxRFiits5.jpg","release_date":"2019-10-31","vote_average":5.9,"backdrop_path":"/j1DfZWbDqRpdcC2fjAZat0CkKKa.jpg","original_title":"చాణక్య","original_language":"te"},{"id":456570,"adult":false,"title":"Hindi Medium","video":false,"overview":"Mita and Raj Batra, an affluent couple from Delhi’s Chandni Chowk, are grappling with getting their daughter admission into an English medium school. But there is one big problem. Their zubaan is Hindi, and the elitist snobs won’t let the Hindi speaking hoi-polloi fit in.","genre_ids":[35,18],"media_type":"movie","popularity":0.5502,"vote_count":201,"poster_path":"/2v0nQd3kYBV0iPNCVHiaLWGb1hg.jpg","release_date":"2017-05-19","vote_average":7.376,"backdrop_path":"/aSjOJMrQYz3EC5e7JzfGxy2Yhuh.jpg","original_title":"हिंदी मीडियम","original_language":"hi"},{"id":148265,"adult":false,"title":"Eega","video":false,"overview":"Nani is a flower decorator, madly in love with his neighbor Bindhu. He gets killed by the baddie, Sudeep, a powerful businessman. Nani comes back as a housefly to get his revenge.","genre_ids":[14,28],"media_type":"movie","popularity":1.0955,"vote_count":235,"poster_path":"/4Q5sQPJktfgXUhUS1kygGB4FUGZ.jpg","release_date":"2012-07-05","vote_average":7.1,"backdrop_path":"/fuCfQ0D2HtNa7kRLFDkPWl87Zs9.jpg","original_title":"ఈగ","original_language":"te"},{"id":496524,"adult":false,"title":"Simmba","video":false,"overview":"A corrupt police officer enjoys all the perks of being an immoral and unethical police officer until an event which transforms his life completely and forces him to choose the righteous path.","genre_ids":[28,35,18],"media_type":"movie","popularity":0.9405,"vote_count":94,"poster_path":"/ulQO4XJ1xlWdl4vX8Lr3SbWRfZw.jpg","release_date":"2018-12-28","vote_average":6.197,"backdrop_path":"/8YWqMobtBO1wFsBfZoiaFKpYiqV.jpg","original_title":"सिंम्बा","original_language":"hi"},{"id":411717,"adult":false,"title":"Bairavaa","video":false,"overview":"A loan recovery agent takes on a corrupt head of an educational institution to save his girlfriend.​","genre_ids":[28],"media_type":"movie","popularity":0.3735,"vote_count":58,"poster_path":"/qHWdlIGu1uZSgP9xSLg0L7yXuEP.jpg","release_date":"2017-01-12","vote_average":5.414,"backdrop_path":"/hCfbfQJrTvV9QybYysQucKqWCk5.jpg","original_title":"பைரவா","original_language":"ta"},{"id":353501,"adult":false,"title":"Pulimurugan","video":false,"overview":"Murugan, with his tools and expertise, protects Puliyoor's villagers from deadly tiger attacks. However, Daddy, an illegal drugs dealer, takes advantage of Murugan's innocence and wrongly frames him.","genre_ids":[28,12],"media_type":"movie","popularity":0.9428,"vote_count":59,"poster_path":"/onl4KNQ9Bso4sNRb3uM6RkRcVuj.jpg","release_date":"2016-10-07","vote_average":6.178,"backdrop_path":"/lcN7WbfHxqpNChWWBeV8T2HWlOC.jpg","original_title":"പുലിമുരുഗന്‍","original_language":"ml"},{"id":63376,"adult":false,"title":"Mr. Perfect","video":false,"overview":"Vicky breaks his engagement with Priya, his childhood friend, after he learns that she is making many compromises for his sake. However, time makes him realise the need for compromises in life.","genre_ids":[10749,35],"media_type":"movie","popularity":3.3278,"vote_count":35,"poster_path":"/pUYe5umIwPWUNWLQ7gfghHR7nCX.jpg","release_date":"2011-04-21","vote_average":6.529,"backdrop_path":"/gLa1gWXPTvVcnjKNNt7J9OSH9VL.jpg","original_title":"Mr. పర్‌ఫెక్ట్","original_language":"te"},{"id":442405,"adult":false,"title":"The Ghazi Attack","video":false,"overview":"India’s first underwater war film tries to decode the mystery behind the sinking of Pakistani submarine PNS Ghazi during the Indo-Pak war of 1971.","genre_ids":[28,10752,53,36],"media_type":"movie","popularity":0.3606,"vote_count":97,"poster_path":"/i7lITQa1v7dZZgLIdE8vZRnPhOC.jpg","release_date":"2017-02-17","vote_average":7.021,"backdrop_path":"/dZcr23O8nY6A0CXbkAdDVP9b05n.jpg","original_title":"ఘాజీ","original_language":"te"},{"id":118051,"adult":false,"title":"Cocktail","video":false,"overview":"A shy simple traditional girl leaves her family in India for her new husband in London, where she meets a shameless flirt and a complicated party girl.","genre_ids":[10749,18,35],"media_type":"movie","popularity":0.7222,"vote_count":123,"poster_path":"/v7jnxqLjarV8LXUXKPU6WKE78CK.jpg","release_date":"2012