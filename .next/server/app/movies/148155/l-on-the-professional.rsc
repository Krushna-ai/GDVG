2160,"file_path":"/rYvAkDyrCRsaK84UQDjO0aGsFQ2.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/pjA53zhPCvQAdsq9EjwgUIYoji6.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1406,"height":791,"file_path":"/en0MEmBIj1qKjhnLBbt0X49fIYI.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1441,"height":811,"file_path":"/gT9z9PYhiSZIFcw9DpkdO1s39Oo.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1417,"height":797,"file_path":"/78b1RT2ft8uSdsuuPosiDdLzPqE.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2238,"height":1259,"file_path":"/b9Yn5a5L9fFsSo5dPFpsrTX9xKb.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2236,"height":1258,"file_path":"/bNkXmnUyo1I0x4HZEgMsXCMp7rj.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2238,"height":1259,"file_path":"/pP9ukuAhSu52pzAplNugUAkDB32.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2256,"height":1269,"file_path":"/9JWNhF0WRqdqKRKv6gppXpaBPnr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2242,"height":1261,"file_path":"/b2zkARQJ6ocPr7fZJvuJ9wQVb22.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2233,"height":1256,"file_path":"/smhMMlzncdXHidQRcE140ph0Ngy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2223,"height":1250,"file_path":"/bavMfCd2VhZi0lHXVbV2zQuJMEx.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2247,"height":1264,"file_path":"/cgWmHDUw8e4OzLW4cWrrQ4C8mb3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2249,"height":1265,"file_path":"/tPYd23NekdHW0getiQNxbNozlfy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2252,"height":1267,"file_path":"/itV7SL1fZpK4Z8Ny2g22vNdC6bj.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2247,"height":1264,"file_path":"/fLyvQzVmWZC5m8sc3DBtkRKOEwL.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2254,"height":1268,"file_path":"/n3k84jfR3TYEKNf4ZTi8i4JTtTu.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2244,"height":1262,"file_path":"/xsxQ361DBgTZHAL02ckrHp4sbI2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":null,"enrichment_cycle":0,"translations":[{"data":{"title":"Léon: The Professional","runtime":111,"tagline":"If you want the job done right, hire a professional.","homepage":"","overview":"Léon, the top hit man in New York, has earned a rep as an effective \"cleaner\". But when his next-door neighbors are wiped out by a loose-cannon DEA agent, he becomes the unwilling custodian of 12-year-old Mathilda. Before long, Mathilda's thoughts turn to revenge, and she considers following in Léon's footsteps."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Léon - Der Profi","runtime":110,"tagline":"Léon: Ein Killer, ein Mädchen, ein tödlicher Plan.","homepage":"","overview":"Die 12-jährige Mathilda wächst nicht gerade in den besten Verhältnissen auf: Ihre Mutter arbeitet als Prostituierte, ihr Vater versteckt Drogen für den korrupten Polizisten Norman Stansfield. Als sich dieser eines Tages betrogen fühlt, richtet er kurzerhand die ganze Familie hin und nur Mathilda entgeht dem Massaker knapp. Verzweifelt bittet sie ihren wenig gesprächigen Nachbarn Léon um Hilfe, der sie nur widerwillig in die Wohnung lässt. Schon kurze Zeit später stellt sie fest, dass er sein Geld als Profikiller verdient. Sie beschließt ebenfalls Cleaner zu werden, um den Mord an ihrer Familie zu rächen..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":110,"tagline":"Si vous voulez un travail bien fait, faites appel à un professionnel.","homepage":"","overview":"Léon est un tueur professionnel redoutable et insaisissable. Il vit seul à New York avec sa plante verte et ses habitudes jusqu'au jour où une petite Mathilda de douze ans sonne à sa porte et fait irruption dans sa vie."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Léon: Profesionistul","runtime":0,"tagline":"Dacă vrei o treabă bine făcută, angajează un profesionist.","homepage":"","overview":"Leon, cel mai bun asasin plătit din New York, a câștigat reputația de  „curățător” eficient. Dar când vecinii săi de la poarta de alături sunt șterși de un agent DEA (brigada antidrog) scăpat de sub control, el devine fără voi un tutorea al lui Mathilda de 12 ani. Nu după mult timp, gândurile  Mathildei se transormă în răzbunare și ea se gândește să urmeze pe urmele lui Leon."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":111,"tagline":"","homepage":"","overview":"Yrkesmördaren Léon bor i Little Italy i New York. En dag knackar den tolvåriga Mathilda på hans dörr. Hennes familj har blivit mördad och av en slump har Mathilda kommit undan. Ytterst tveksamt släpper Leon in henne, medveten om att det kommer att förändra hans liv."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Леон","runtime":133,"tagline":"Вы не можете остановить того, кого не видно","homepage":"","overview":"Профессиональный убийца Леон неожиданно для себя самого решает помочь 12-летней соседке Матильде, семью которой убили коррумпированные полицейские."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":110,"tagline":"Dal momento del loro incontro, le loro vite non saranno più le stesse.","homepage":"","overview":"Léon è un killer che vive solo, avendo unicamente una pianta da vaso come compagnia. Mathilda è una ragazzina che abita nell'appartamento a fianco alla stanza di Léon. Quando la famiglia di Mathilda viene sterminata per una storia di droga, lei chiede aiuto a Léon. Tra i due nasce una tenera amicizia, fra scambi di lezioni sull'uso delle armi da una parte e di lettura dall'altra."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Leon","runtime":105,"tagline":"Nemilosrdný, nepolapitelný, nezničitelný, až dokud nepřijde ONA","homepage":"","overview":"Neobyčejný milostný příběh profesionálního vraha a mladé dívky. Leon je nájemný vrah, člověk, kterého nedokáže nic zastavit před splněním úlohy. Do jeho života vstoupí dvanáctiletá Matilda. Rodina nevinné Matildy byla vyvražděna zkorumpovaným policajtem a ona se rozhodla pro krutou pomstu."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Leon, a profi","runtime":110,"tagline":"","homepage":"","overview":"Leon, a magányos bérgyilkos New Yorkban él. A szomszédjában lakó család áldozatául esik Stansfield nyomozó kegyetlenségének, aki lemészárolja a szülőket. Az egyetlen túlélő, a 12 éves Mathilda Leonhoz menekül. Idővel a szenvtelen bérgyilkos úgy gondoskodik Mathildáról, mintha a saját lánya lenne. Stansfield azonban nagyszabású kommandós akció keretében készül megostromolni Leon lakását, hogy végezzen a kis szemtanúval. Ám nem számol Leon profizmusával, aki ráadásul az élete árán is hajlandó megvédeni a lányt..."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bokmål","iso_639_1":"nb","iso_3166_1":"NO","english_name":"Norwegian Bokmål"},{"data":{"title":"这个杀手不太冷","runtime":133,"tagline":"想把事情办的漂亮，就得请专业的","homepage":"","overview":"里昂是名孤独的职业杀手，受人雇佣。一天，邻居家小姑娘马蒂尔达敲开他的房门，要求在他那里暂避杀身之祸。原来邻居家的主人是警方缉毒组的眼线，只因贪污了一小包毒品而遭恶警杀害全家的惩罚。马蒂尔达得到里昂的留救，幸免于难，并留在里昂那里。里昂教小女孩使枪，她教里昂法文，两人关系日趋亲密，相处融洽。女孩想着去报仇，反倒被抓，里昂及时赶到，将女孩救回。混杂着哀怨情仇的正邪之战渐次升级，更大的冲突在所难免……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Leon: Sevginin Gücü","runtime":0,"tagline":"Profesyonel bir tetikçi, masum bir kız, çok ileri giden yozlaşmış bir dedektif.","homepage":"https://www.sonypictures.com/movies/theprofessional","overview":"Mathilda, New York’ta yaşayan ailesi dağılmış 12 yaşında küçük bir kızdır. Ailesini sevmeyen Mathilda için en değerli varlığı küçük kardeşidir. Babası uyuşturucu işlerine bulaşınca mafya ailenin tüm bireylerini öldürür. O sırada alışverişte olan Mathilda ise olaydan kılpayı kurtulur ve Leon’un kaldığı daireye saklanır. Leon ise çok soğukkanlı bir katildir. Ancak Mathilda’ya karşı içten bir sevgi besler ve ona kol kanat gerer. Aslında babalık, arkadaşlık gibi kavramlar ona çok yabancıdır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"El profesional (Léon)","runtime":110,"tagline":"Si quieres un trabajo bien hecho, contrata un profesional.","homepage":"","overview":"Stan es un corrupto agente de la DEA cuya codicia le lleva a cometer asesinatos en las calles de Nueva York. El mortal juego del gato y el ratón empieza cuando se cruza en su camino un solitario hombre, llamado León. León es asesino a sueldo, un personaje indestructible e indocumentado, que sólo bebe leche y se ocupa de sus plantas. En medio se encuentra una huerfanita de 12 años, que no puede olvidar al hombre que asesinó a su familia."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Leon","runtime":0,"tagline":"","homepage":"","overview":"Erakkomainen Léon asustelee New Yorkin rähjäisissä osissa ja tekee satunnaisia tappokeikkoja. Kun korruptoitunut poliisi murhaa naapurissa asuvan perheen, Léon ottaa hoiviinsa teurastuksesta selvinneen 12-vuotiaan tytön. Kahden yksinäisen välille kehittyy lämmin ystävyys."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Léon, o Profissional","runtime":110,"tagline":"Não podes parar o que não consegues ver.","homepage":"","overview":"Léon é um assassino profissional, silencioso e eficaz. Matar é o seu trabalho e manter-se vivo a sua preocupação, até ao dia em que se depara com Mathilda, uma adolescente que vive na porta ao lado. Os pais de Mathilda foram assassinados por um polícia corrupto, coisa que não parece afectar a jovem, que está mais interessada em aprender a arte de Léon. Em \"Léon, o Profissional\", a sua primeira longa-metragem realizada nos EUA, com Nova Iorque como cenário, o cineasta francês Luc Besson alia o género dramático ao filme de acção, numa espiral de violência excelentemente acompanhada pela música de Eric Serra, Sting e Björk."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":110,"tagline":"","homepage":"","overview":"1994, New York. Léon is huurmoordenaar van beroep. Hij observeert het komen en gaan van de inwoners van een gebouw. Op dezelfde verdieping van Léon woont er een gezin waarvan de vader drugshandelaar is."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Leon zawodowiec","runtime":110,"tagline":"Jeśli chcesz dobrze wykonać robotę, zatrudnij profesjonalistę.","homepage":"","overview":"Leon to płatny morderca z kodeksem honorowym. Jest najlepszy, jednak pewnego dnia łamie swoje reguły i otwiera drzwi Matyldzie, dziewczynce, której skorumpowani policjanci pod wodzą szalonego Stansfielda z DEA zabili całą rodzinę. Chcąc nie chcąc ci dwoje zostają skazani na siebie. Leon uczy Matyldę \"fachu\", a ta w zamian uczy Leona czytać. Między nimi rodzi się więź, która powoduje, że Leon staje się innym człowiekiem. Zobowiązuje się zabić Stansfielda i jego kolesi. Stansfield jednakże jest nieobliczalnym i przebiegłym przeciwnikiem..."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Леон","runtime":133,"tagline":"","homepage":"","overview":"Професійний вбивця Леон, що не знає пощади і жалості, знайомиться з своєю чарівною сусідкою Матільдою, сім’ю якій розстрілюють поліцейські, замішані в торгівлі наркотиками. Завдяки цьому знайомству він вперше переживає почуття любові, але... яке коротке життя професійного вбивці."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Léon","runtime":110,"tagline":"Han er professionel, den bedste og alene.","homepage":"","overview":"Léon er professionel hitman for mafiaen i New York. Da den småkriminelle nabofamilie udslettes af den psykopatiske narkopolitiagent Stansfield, redder Léon den 12-årige datter, Mathilda. Hun vil nu lære at blive lejemorder, så hun kan få hævn over Stansfield. Et varmt venskab opstår mellem de to, som hver på sin måde står alene i verden. Men Stansfield er på sporet af den morderiske duo."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Професионалац","runtime":110,"tagline":"Професионалац","homepage":"","overview":"Леон је имигрант, који живи повученим и мирним животом, пије само млеко, међутим, његово занимање је професионални убица. У његовој згради станује мала Матилда, дванаестогодишња Њујорчанка, која живи тужан живот с породицом. Њен отац је криминалац и чува дрогу за корумпираног полицајца Нормана. Једино због чега је девојчица срећна је њен млађи брат. Отац јој улети у несугласице с Норманом и из освете његов тим поубија целу породицу. Преживи једино Матилда, која је у том тренутку била у продавници. Убрзо сигурност налази у стану необичног суседа."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Λεόν: Ο Επαγγελματίας","runtime":110,"tagline":"Εάν θέλεις η δουλειά σου να γίνει καλά, προσέλαβε έναν επαγγελματία.","homepage":"","overview":"Η Ματίλντα είναι ένα 12χρονο κοριτσάκι που ζει στη Νέα Υόρκη, η οικογένεια του οποίου έχει διαλυθεί. Για τη Mathilda, που δεν συμπαθεί την οικογένειά της, το πιο πολύτιμο αγαθό της είναι ο μικρός της αδελφός. Όταν ο πατέρας της εμπλέκεται στα ναρκωτικά, η μαφία σκοτώνει όλα τα μέλη της οικογένειας. Η Ματίλντα, που εκείνη την εποχή ψώνιζε, γλιτώνει οριακά το περιστατικό και κρύβεται στο διαμέρισμα του Λεόν. Ο Λεόν είναι ένας πολύ ψυχρός δολοφόνος. Ωστόσο, τρέφει ειλικρινή αγάπη για τη Ματίλντα και την παίρνει υπό την προστασία του. Στην πραγματικότητα, έννοιες όπως η πατρότητα και η φιλία είναι πολύ ξένες γι' αυτόν."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"เพชฌฆาต..มหากาฬ","runtime":0,"tagline":"เพชฌฆาต..มหากาฬ","homepage":"","overview":"เรื่องราวของ ลีออง นักฆ่าชาวฝรั่งเศส ผู้เป็นมืออาชีพอย่างมากในงานของเขา เขาเป็นคนมีระเบียบแบบแผน และเป็นที่วางใจได้...ว่าจ้างเขาฆ่าใครแล้ว..ไม่มีพลาดแน่นอน !! แต่ในทางกลับกัน..เขาเป็นคนซื่อ ๆ ไม่ค่อยทันเล่ห์เหลี่ยมใคร จนเมื่อเขามีโอกาสย้ายมาเมืองใหญ่อย่างอเมริกาและที่นี่...ชีวิตของเขาต้องพบกับความเปลี่ยนแปลงมากมาย"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"레옹","runtime":0,"tagline":"소녀와 킬러의 만남","homepage":"","overview":"한 손엔 우유 2팩이 든 가방, 다른 한 손엔 화분을 들고 뿌리 없이 떠도는 킬러 레옹은 어느 날 옆 집 소녀 마틸다의 일가족이 몰살 당하는 것을 목격한다. 그 사이 심부름을 갔다 돌아 온 마틸다는 가족들이 처참히 몰살 당하자 레옹에게 도움을 청한다. 가족의 원수를 갚기 위해 킬러가 되기로 결심한 12세 소녀 마틸다는 레옹에게 글을 알려주는 대신 복수하는 법을 배우고, 그 사이 레옹에 대한 사랑을 키워나간다. 드디어 그녀는 가족을 죽인 사람이 부패한 마약 경찰 스탠스임을 알게 되고, 홀로 그의 사무실로 향하게 되는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Леон","runtime":133,"tagline":"Ако искате работата да бъде свършена добре, наемете си професионалист.","homepage":"","overview":"12-годишната Матилда има нерадостно детство. Родителите и се занимават с дрога и единственият светъл лъч в живота и са грижите за малкото и братче. Един ден тя става свидетел на кърваво отмъщение на корумпирано ченге от отдела за борба с наркотиците, който избива цялото ѝ семейство. Момичето се спасява по чудо като влиза в съседния апартамент, където живее Леон. Когато разбира, че мълчаливият и недружелюбен мъж е наемен убиец, тя го моли да ѝ помогне да отмъсти за погубеното си детство."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"לאון","runtime":0,"tagline":"","homepage":"","overview":"לאון הוא רוצח שכיר מיומן המתגורר בבידוד בדירה ניו-יורקית מוזנחת. בעל כורחו הוא הופך להיות למאמצה של בת השכנים בת ה-12 שמשפחתה מחוסלת בידי שוטר מושחת ומטורף. רנו מעצב באופן מדהים את דמות הרוצח המקצוען שחייו מאופינים במעין פיצול אישיות, משימות רצחניות המבוצעות במקצוענות עילאית מצד אחד וחיי שיגרה אפורים מאידך. הילדה שבחסותו - מיני-ניקיטה, ילדה-אשה היא הצלע השנייה בזיווג רומנטי יוצא דופן."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"لئون: حرفه ای","runtime":0,"tagline":"اگر می خواهید کارتان به خوبی انجام شود، یک حرفه ای را استخدام کنید.","homepage":"","overview":"آدم کشي حرفه اي به نام «لئون» (رنو) در آپارتماني در محله ي ايتاليايي هاي نيويورک زندگي مي کند. «استانسفيلد» (اولدمن)، مأمور فاسد پليس، تمام خانواده ي همسايه را مي کشد و تنها دختر دوازده ساله شان، «ماتيلدا» (پورتمن) که براي خريد بيرون رفته جان سالم به در مي برد.«ماتيلدا» به «ليون» پناه مي برد و خيلي زود اين دو با يک ديگر دوست مي شوند..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"O Profissional","runtime":111,"tagline":"Se quiser um trabalho bem feito, contrate um profissional.","homepage":"","overview":"Mathilda tem apenas 12 anos de idade mas já conhece o lado obscuro da vida: seu pai abusivo guarda drogas para policiais corruptos e a mãe a negligencia. O vizinho Léon gosta de cuidar de plantas, mas é um assassino de aluguel para o gângster Tony. Quando sua família é assassinada por um agente antidrogas desonesto, Mathilda se une a um relutante Léon para aprender o negócio mortal e vingar a morte da família."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Le professionnel","runtime":110,"tagline":"Si vous voulez un travail bien fait, faites appel à un professionnel.","homepage":"","overview":"Un tueur à gages répondant au nom de Léon prend sous son aile Mathilda, une petite fille de douze ans, seule rescapée du massacre de sa famille. Bientôt, Léon va faire de Mathilda une « nettoyeuse », comme lui. Et Mathilda pourra venger son petit frère..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"レオン","runtime":133,"tagline":"込めたのは、銃弾と愛。","homepage":"","overview":"リュック・ベッソンが初めてアメリカで製作したバイオレンス・アクション。ニューヨークを舞台に、凄腕の殺し屋レオンと12歳の少女マチルダの純愛と戦いを描く。大都会の片隅で出会った孤独なふたりの葛藤と壮絶なアクション・シーンがほどよくブレンドされた佳作。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"El Perfecto Asesino","runtime":110,"tagline":"","homepage":"","overview":"Stan es un corrupto agente de la DEA cuya codicia le lleva a cometer asesinatos en las calles de Nueva York. El mortal juego del gato y el ratón empieza cuando se cruza en su camino un solitario hombre, llamado León. León es asesino a sueldo, un personaje indestructible e indocumentado, que sólo bebe leche y se ocupa de su planta. En medio se encuentra una huerfana de 12 años, que no puede olvidar al hombre que asesinó a su familia. Ella acabará convirtiéndose en algo importante para León y tal vez en su perdición."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"終極追殺令","runtime":133,"tagline":"「我就像這株植物一樣，沒有根。」","homepage":"","overview":"一個12歲大漂亮無邪的小女孩瑪蒂達（娜塔莉波曼 飾），在一家慘遭殺害後，央求殺手里昂（尚雷諾 飾）訓練她，讓她成為和他一樣的殺手，以便為家人報仇。面對這個與自己本性極其矛盾的女孩，里昂試圖找到平衡的支點，而總是與他處於對立狀態的瑪蒂達，也就成了里昂的唯一致命傷……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Leon","runtime":0,"tagline":"","homepage":"","overview":"Neobyčajný príbeh profesionálneho vraha a mladého dievčaťa. Leon je nájomný vrah, človek, ktorého nedokáže nič zastaviť pred splnením úlohy. Do jeho života vstúpi dvanásťročná Matilda. Rodina nevinnej Matildy bola vyvraždená skorumpovaným policajtom a ona sa rozhodla pre krutú pomstu."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"","runtime":110,"tagline":"","homepage":"","overview":"En perfekt leiemorder. En uskyldig jente. De har ingenting å miste, bortsett fra hverandre. Han beveger seg uten en lyd. Dreper uten følelser. Forsvinner uten et spor. Bare en tolv år gammel jente vet hans svakheter! Jean Reno spiller Léon, en hensynsløs leiemorder, som utvikler et motvillig forhold til en 12 år gammel pike, Mathilda. Hennes familie er myrdet av den korrupte politimannen Stansfield, i forbindelse med en mislykket dophandel. Og nå er Stansfield ute etter Mathilda, det eneste vitnet til massakren."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Leonas","runtime":0,"tagline":"","homepage":"","overview":"Dvylikos metų mergaitė Matilda, grįžusi iš parduotuvės savo bute randa iššaudytą šeimą bei jame dar siautėjančius gangsterius. Mergaitę išgelbėja kaimynas Leonas, kuris yra samdomas žudikas. Matilda paprašo, kad vyras išmokytų ją šios profesijos subtilybių."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Leons","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"這個殺手不太冷","runtime":0,"tagline":"","homepage":"","overview":"里昂（尚聯奴 飾）是紐約的頂尖職業殺手。當他的鄰居一家因毒品問題被殺害後，他無奈成為唯一倖存者 ——12 歲小女孩瑪蒂達（妮妲莉寶雯 飾）的守護者。但瑪蒂達不僅想獲得保護，更要向斯坦菲爾德 (加利奧文 飾) 報仇。她遂央求里昂訓練她成為殺手，為弟弟報仇。當里昂遇上瑪蒂達後，讓孤獨安靜的他生活起了變化，也成了他的唯一致命傷……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Léon","runtime":127,"tagline":"","homepage":"","overview":"Ko 12-letna Mathilda v morilskem pohodu izgubi vse člane svoje družine, tudi ljubljenega bratca, se zateče v sosednje stanovanje. Tam živi Léon, profesionalni morilec in samotar, ki ima tudi nežno plat. Med moškim in odraščajočim dekletom se splete posebna vez. Mathilda sčasoma pregovori Léona, da jo nauči ubijalskih veščin, zato da se bo nekega dne maščevala morilcu, ki ji je odvzel brata."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Sát Thủ Chuyên Nghiệp","runtime":0,"tagline":"","homepage":"","overview":"Cô bé Mathilda có hoàn cảnh đặc biệt. Cả nhà buôn ma tuý, cha và chị gái không hề quan tâm gì đến mình, chỉ có cậu em trai là người mà Mathilda yêu thương nhất. Cuộc sống cứ tiếp diễn trôi và trong một bầu không khí đầy khủng hoảng của người chị mất nết cùng người cha buôn ma tuý, tưởng như tương lai Mathilda cũng trở thành một cô bé hư. Mãi cho đến một ngày, khi một cảnh sát tha hoá vì cạnh tranh làm ăn mà giết cả nhà Mathilda, cuộc sống của cô bé mới bắt đầu thay đổi. Cô chạy trốn và được Leon (Jean Reno), một tên giết thuê bảo bọc. Cô học bắn súng để trả thù, và đã được Leon giúp đỡ."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"ليون: المحترف","runtime":0,"tagline":"إذا كنت تريد عملًا جيدًا ، فقم بتعيين متخصص.","homepage":"","overview":"حصل ليون ، الرجل الأكثر نجاحًا في نيويورك ، على ممثل باعتباره \"عامل تنظيف\" فعال. ولكن عندما يتم القضاء على جيرانه المجاورين من قبل وكيل إدارة مكافحة المخدرات ، فإنه يصبح الوصي غير الراغب على ماتيلدا البالغة من العمر 12 عامًا. قبل مضي وقت طويل ، تتحول أفكار ماتيلدا إلى الانتقام ، وهي تفكر في اتباع خطى ليون."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"ლეონი: პროფესიონალი","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Leon Profesionalac","runtime":0,"tagline":"Profesionalni ubojica prima pod svoje okrilje djevojčicu kojoj su ubijeni roditelji.","homepage":"","overview":"Nakon što joj je cijela obitelj ubijena, jedini spas pred ubojicama je njezin samozatajni susjed Leon. On je, naime, profesionalni ubojica koji zavoli djevojčicu te se odluči osvetiti ubojicama njezine obitelji."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"El professional","runtime":0,"tagline":"","homepage":"","overview":"Stan és un corrupte agent de la DEA la cobdícia del qual el porta a cometre assassinats als carrers de Nova York. El mortal joc del gat i el ratolí comença quan es creua al seu camí un solitari home, anomenat Lleó. León és assassí a sou, un personatge indestructible i indocumentat, que només beu llet i s'ocupa de les plantes. Al mig hi ha una orfe de 12 anys, que no pot oblidar l'home que va assassinar la seva família."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Mathilda (Natalie Portman) on noor, 13. aastane, tüdruk. Kartmatu tüdruku elu muutub aga kardinaalselt kui ta vanemad, õde ning vend tapetakse. Ise mõrtsukate eest põgenedes leiab ta varjupaika teise profesionaalse palgamõrtsuka, Leoni (Jean Reno) juures. Leon tegutseb üksi, osavalt, haudvaikselt ning märkamatult - ta ei jää kunagi vahele ning üksi elades ei saa keegi ka ta lähedaste kaudu teda kätte, isegi mitte tema vaenlased. Leon tahab Mathildast kiiresti vabaneda, kuid tüdruk leiab temas üles hellad kohad ning suudab ta ümber veenda. Lisaks palub ta Leoni, et too õpetaks talle mõrtsuka töövõtteid, et ta saaks isiklikult enda pere mõrvamise eest kätte maksta."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"}],"reviews_tmdb":[{"id":"6132db33b3f6f500628ae571","url":"https://www.themoviedb.org/review/6132db33b3f6f500628ae571","author":"rozmiarek","content":"HOW TO MAKE A FEMALE ASSASSIN. TRAUMA, TRAINING THEN GET HER EXTRA ANGRY.  NATILIE PORTMANS FIRST ASSASSIN ROLE AND HOPEFULLY NOT HER LAST.  WE NEED A PART 2 TO THIS MOVIE.","created_at":"2021-09-04T02:34:27.637Z","updated_at":"2021-12-03T21:52:44.832Z","author_details":{"name":"","rating":10,"username":"rozmiarek","avatar_path":"/ivKbGJEkRG60zoHTsv3FnmHNBI6.png"}},{"id":"64cfc5f7303c8500e338fd33","url":"https://www.themoviedb.org/review/64cfc5f7303c8500e338fd33","author":"Niemand","content":"$11","created_at":"2023-08-06T16:10:31.909Z","updated_at":"2023-08-21T15:17:12.024Z","author_details":{"name":"","rating":null,"username":"Niemand","avatar_path":null}}],"recommendations":[{"id":807,"adult":false,"title":"Se7en","video":false,"overview":"Two homicide detectives are on a desperate hunt for a serial killer whose crimes are based on the \"seven deadly sins\" in this dark and haunting film that takes viewers from the tortured remains of one victim to the next. The seasoned Det. Somerset researches each sin in an effort to get inside the killer's mind, while his novice partner, Mills, scoffs at his efforts to unravel the case.","genre_ids":[80,9648,53],"media_type":"movie","popularity":19.8633,"vote_count":22659,"poster_path":"/191nKfP0ehp3uIvWqgPbFmI4lv9.jpg","release_date":"1995-09-22","vote_average":8.4,"backdrop_path":"/iwgl8zlrrfvfWp9k9Paj8lvFEvS.jpg","original_title":"Se7en","original_language":"en"},{"id":207,"adult":false,"title":"Dead Poets Society","video":false,"overview":"At an elite, old-fashioned boarding school in New England, a passionate English teacher inspires his students to rebel against convention and seize the potential of every day, courting the disdain of the stern headmaster.","genre_ids":[18],"media_type":"movie","popularity":11.8017,"vote_count":12318,"poster_path":"/l5NbiHKUmahlAT3Q1ig8Tyl9xrc.jpg","release_date":"1989-06-02","vote_average":8.301,"backdrop_path":"/yYvBNN96Ym3wtPxGCFl7F888WwB.jpg","original_title":"Dead Poets Society","original_language":"en"},{"id":510,"adult":false,"title":"One Flew Over the Cuckoo's Nest","video":false,"overview":"A petty criminal fakes insanity to serve his sentence in a mental ward rather than prison. He soon finds himself as a leader to the other patients—and an enemy to the cruel, domineering nurse who runs the ward.","genre_ids":[18],"media_type":"movie","popularity":8.094,"vote_count":11223,"poster_path":"/kjWsMh72V6d8KRLV4EOoSJLT1H7.jpg","release_date":"1975-11-19","vote_average":8.412,"backdrop_path":"/6Oa3zTiluBz2W8D2ou1MY16dUiF.jpg","original_title":"One Flew Over the Cuckoo's Nest","original_language":"en"},{"id":18,"adult":false,"title":"The Fifth Element","video":false,"overview":"In 2257, a taxi driver is unintentionally given the task of saving a young girl who is part of the key that will ensure the survival of humanity.","genre_ids":[878,28,12],"media_type":"movie","popularity":11.8876,"vote_count":11464,"poster_path":"/fPtlCO1yQtnoLHOwKtWz7db6RGU.jpg","release_date":"1997-05-02","vote_average":7.6,"backdrop_path":"/bx1W729hyWQqNQoiq9LsX30FBf.jpg","original_title":"Le Cinquième Élément","original_language":"fr"},{"id":335,"adult":false,"title":"Once Upon a Time in the West","video":false,"overview":"As the railroad builders advance unstoppably through the Arizona desert on their way to the sea, Jill arrives in the small town of Flagstone with the intention of starting a new life.","genre_ids":[18,37],"media_type":"movie","popularity":7.4044,"vote_count":4778,"poster_path":"/qbYgqOczabWNn2XKwgMtVrntD6P.jpg","release_date":"1968-12-21","vote_average":8.28,"backdrop_path":"/aKZ9hDmLJTaGSxWdhxqMTcvXmk4.jpg","original_title":"C'era una volta il West","original_language":"it"},{"id":857,"adult":false,"title":"Saving Private Ryan","video":false,"overview":"As U.S. troops storm the beaches of Normandy, three brothers lie dead on the battlefield, with a fourth trapped behind enemy lines. Ranger captain John Miller and seven men are tasked with penetrating German-held territory and bringing the boy home.","genre_ids":[10752,18,36],"media_type":"movie","popularity":10.9353,"vote_count":16904,"poster_path":"/uqx37cS8cpHg8U35f9U5IBlrCV3.jpg","release_date":"1998-07-24","vote_average":8.2,"backdrop_path":"/rW2xRFlJRbTnBJlQTSjQmjevIwb.jpg","original_title":"Saving Private Ryan","original_language":"en"},{"id":598,"adult":false,"title":"City of God","video":false,"overview":"In the poverty-stricken favelas of Rio de Janeiro in the 1970s, two young men choose different paths. Rocket is a budding photographer who documents the increasing drug-related violence of his neighborhood, while José “Zé” Pequeno is an ambitious drug dealer diving into a dangerous life of crime.","genre_ids":[18,80],"media_type":"movie","popularity":8.5683,"vote_count":8019,"poster_path":"/k7eYdWvhYQyRQoU2TB2A2Xu2TfD.jpg","release_date":"2002-08-30","vote_average":8.428,"backdrop_path":"/uvitbjFU4JqvMwIkMWHp69bmUzG.jpg","original_title":"Cidade de Deus","original_language":"pt"},{"id":629,"adult":false,"title":"The Usual Suspects","video":false,"overview":"Held in an L.A. interrogation room, Verbal Kint attempts to convince the feds that a mythic crime lord, Keyser Soze, not only exists, but was also responsible for drawing him and his four partners into a multi-million dollar heist that ended with an explosion in San Pedro harbor – leaving few survivors. Verbal lures his interrogators with an incredible story of the crime lord's almost supernatural prowess.","genre_ids":[18,80,53],"media_type":"movie","popularity":10.8379,"vote_count":11177,"poster_path":"/99X2SgyFunJFXGAYnDv3sb9pnUD.jpg","release_date":"1995-07-19","vote_average":8.169,"backdrop_path":"/hy0Hx9fMPk2fmw26Li60z1S2giU.jpg","original_title":"The Usual Suspects","original_language":"en"},{"id":9322,"adult":false,"title":"Nikita","video":false,"overview":"A beautiful felon, sentenced to life in prison for the murder of a policeman, is given a second chance – as a secret political assassin controlled by the government.","genre_ids":[28,53],"media_type":"movie","popularity":3.0474,"vote_count":2103,"poster_path":"/1ulQDewUG4KKHOhpXdGKm3GdLFq.jpg","release_date":"1990-02-21","vote_average":7.097,"backdrop_path":"/rk56vslwBXUCcNlQ74s6gmpJqxa.jpg","original_title":"Nikita","original_language":"fr"},{"id":680,"adult":false,"title":"Pulp Fiction","video":false,"overview":"A burger-loving hit man, his philosophical partner, a drug-addled gangster's moll and a washed-up boxer converge in this sprawling, comedic crime caper. Their adventures unfurl in three stories that ingeniously trip back and forth in time.","genre_ids":[53,80,35],"media_type":"movie","popularity":25.4546,"vote_count":29734,"poster_path":"/vQWk5YBFWF4bZaofAbv0tShwBvQ.jpg","release_date":"1994-09-10","vote_average":8.486,"backdrop_path":"/96hiUXEuYsu4tcnvlaY8tEMFM0m.jpg","original_title":"Pulp Fiction","original_language":"en"},{"id":752,"adult":false,"title":"V for Vendetta","video":false,"overview":"In a world in which Great Britain has become a fascist state, a masked vigilante known only as “V” conducts guerrilla warfare against the oppressive British government. When V rescues a young woman from the secret police, he finds in her an ally with whom he can continue his fight to free the people of Britain.","genre_ids":[28,53,878],"media_type":"movie","popularity":8.9248,"vote_count":15338,"poster_path":"/piZOwjyk1g51oPHonc7zaQY3WOv.jpg","release_date":"2006-02-23","vote_average":7.898,"backdrop_path":"/5EKplo61HbA5sMGAN0XAvzdo1MX.jpg","original_title":"V for Vendetta","original_language":"en"},{"id":274,"adult":false,"title":"The Silence of the Lambs","video":false,"overview":"Clarice Starling is a top student at the FBI's training academy.  Jack Crawford wants Clarice to interview Dr. Hannibal Lecter, a brilliant psychiatrist who is also a violent psychopath, serving life behind bars for various acts of murder and cannibalism.  Crawford believes that Lecter may have insight into a case and that Starling, as an attractive young woman, may be just the bait to draw him out.","genre_ids":[80,53,18],"media_type":"movie","popularity":3.9568,"vote_count":17607,"poster_path":"/uS9m8OBk1A8eM9I042bx8XXpqAq.jpg","release_date":"1991-02-14","vote_average":8.346,"backdrop_path":"/aYcnDyLMnpKce1FOYUpZrXtgUye.jpg","original_title":"The Silence of the Lambs","original_language":"en"},{"id":105,"adult":false,"title":"Back to the Future","video":false,"overview":"Eighties teenager Marty McFly is accidentally sent back in time to 1955, inadvertently disrupting his parents' first meeting and attracting his mother's romantic interest. Marty must repair the damage to history by rekindling his parents' romance and - with the help of his eccentric inventor friend Doc Brown - return to 1985.","genre_ids":[12,35,878],"media_type":"movie","popularity":18.3599,"vote_count":21417,"poster_path":"/vN5B5WgYscRGcQpVhHl6p9DDTP0.jpg","release_date":"1985-07-03","vote_average":8.324,"backdrop_path":"/qskzmLTbarKnXDbo2HRj4NJ3vcW.jpg","original_title":"Back to the Future","original_language":"en"},{"id":562,"adult":false,"title":"Die Hard","video":false,"overview":"NYPD cop John McClane's plan to reconcile with his estranged wife is thrown for a serious loop when, minutes after he arrives at her office's Christmas Party, the entire building is overtaken by a group of terrorists. With little help from the LAPD, wisecracking McClane sets out to single-handedly rescue the hostages and bring the bad guys down.","genre_ids":[28,53],"media_type":"movie","popularity":11.5424,"vote_count":12054,"poster_path":"/7Bjd8kfmDSOzpmhySpEhkUyK2oH.jpg","release_date":"1988-07-15","vote_average":7.806,"backdrop_path":"/bvk2AAH64lP2YZs02Q3jskfHT8j.jpg","original_title":"Die Hard","original_language":"en"},{"id":77338,"adult":false,"title":"The Intouchables","video":false,"overview":"A true story of two men who should never have met – a quadriplegic aristocrat who was injured in a paragliding accident and a young man from the projects.","genre_ids":[18,35],"media_type":"movie","popularity":11.6947,"vote_count":18172,"poster_path":"/1QU7HKgsQbGpzsJbJK4pAVQV9F5.jpg","release_date":"2011-11-02","vote_average":8.27,"backdrop_path":"/5ATSg3rufgIMfcrHd2gEi678hZu.jpg","original_title":"Intouchables","original_language":"fr"},{"id":194,"adult":false,"title":"Amélie","video":false,"overview":"At a tiny Parisian café, the adorable yet painfully shy Amélie accidentally discovers a gift for helping others. Soon Amelie is spending her days as a matchmaker, guardian angel, and all-around do-gooder. But when she bumps into a handsome stranger, will she find the courage to become the star of her very own love story?","genre_ids":[35,10749],"media_type":"movie","popularity":8.0293,"vote_count":12224,"poster_path":"/nSxDa3M9aMvGVLoItzWTepQ5h5d.jpg","release_date":"2001-04-25","vote_average":7.9,"backdrop_path":"/6n53UI4mX9QMfe2S0Pgt8mGebY1.jpg","original_title":"Le Fabuleux Destin d'Amélie Poulain","original_language":"fr"},{"id":184,"adult":false,"title":"Jackie Brown","video":false,"overview":"Jackie Brown is a flight attendant who gets caught in the middle of smuggling cash into the country for her gunrunner boss. When the cops try to use Jackie to get to her boss, she hatches a plan — with help from a bail bondsman — to keep the money for herself.","genre_ids":[80,18,53],"media_type":"movie","popularity":6.2492,"vote_count":6818,"poster_path":"/rOUx7qg4KmEh1juEDwqzbDSL1Nr.jpg","release_date":"1997-12-25","vote_average":7.359,"backdrop_path":"/gvaeY5kz3wHrMU6xLdnybziwYXw.jpg","original_title":"Jackie Brown","original_language":"en"},{"id":13,"adult":false,"title":"Forrest Gump","video":false,"overview":"A man with a low IQ has accomplished great things in his life and been present during significant historic events—in each case, far exceeding what anyone imagined he could do. But despite all he has achieved, his one true love eludes him.","genre_ids":[35,18,10749],"media_type":"movie","popularity":20.2801,"vote_count":29286,"poster_path":"/saHP97rTPS5eLmrLQEcANmKrsFl.jpg","release_date":"1994-06-23","vote_average":8.462,"backdrop_path":"/67HggiWaP9ZLv5sPYmyRV37yAJM.jpg","original_title":"Forrest Gump","original_language":"en"},{"id":603,"adult":false,"title":"The Matrix","video":false,"overview":"Set in the 22nd century, The Matrix tells the story of a computer hacker who joins a group of underground insurgents fighting the vast and powerful computers who now rule the earth.","genre_ids":[28,878],"media_type":"movie","popularity":24.788,"vote_count":27416,"poster_path":"/p96dm7sCMn4VYAStA6siNz30G1r.jpg","release_date":"1999-03-31","vote_average":8.238,"backdrop_path":"/tlm8UkiQsitc8rSuIAscQDCnP8d.jpg","original_title":"The Matrix","original_language":"en"},{"id":175,"adult":false,"title":"The Big Blue","video":false,"overview":"Childhood friends Jacques and Enzo share a passion for the danger of free diving. Professional diver Jacques opted to follow in the footsteps of his father, who died at sea when Jacques was a boy; to the bewilderment of scientists, Jacques harbors a remarkable ability to adjust his heart rate and breathing pattern in the water, so that his vital signs more closely resemble that of dolphins than men. As Enzo persuades a reluctant Jacques to compete against him in a free diving contest -- determining who can dive deeper and longer without scuba gear -- Jacques meets Johana, a beautiful American insurance investigator, and finds that he must choose between his love for her and his love of the sea.","genre_ids":[10749,12,18],"media_type":"movie","popularity":3.4377,"vote_count":1537,"poster_path":"/3t5t7yaFiTJQlqxiTkXJMFZdkh3.jpg","release_date":"1988-05-10",