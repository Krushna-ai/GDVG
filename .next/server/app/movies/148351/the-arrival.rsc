9:{"metadata":[["$","title","0",{"children":"The Arrival | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Zane Ziminski is an astrophysicist who receives a message that seems to have extraterrestrial origins. Eerily soon after his discovery, Zane is fired. He then embarks on a search to determine the origins of the transmission that leads him into a Hitchcockian labyrinth of paranoia and intrigue."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148351/the-arrival"}],["$","meta","5",{"property":"og:title","content":"The Arrival"}],["$","meta","6",{"property":"og:description","content":"Zane Ziminski is an astrophysicist who receives a message that seems to have extraterrestrial origins. Eerily soon after his discovery, Zane is fired. He then embarks on a search to determine the origins of the transmission that leads him into a Hitchcockian labyrinth of paranoia and intrigue."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148351/the-arrival"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/3051CM0SZfZJ3oOJG8P0YERQl1w.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"The Arrival"}],["$","meta","12",{"name":"twitter:description","content":"Zane Ziminski is an astrophysicist who receives a message that seems to have extraterrestrial origins. Eerily soon after his discovery, Zane is fired. He then embarks on a search to determine the origins of the transmission that leads him into a Hitchcockian labyrinth of paranoia and intrigue."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/30