o_639_1":"sk","iso_3166_1":"SK","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/jdUglzzCrqQK0sxk0lAAlPsyhK8.jpg","iso_639_1":"sk","iso_3166_1":"SK","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/tBuyO5rWqzo5lGqk4m4a42cTjL4.jpg","iso_639_1":"sk","iso_3166_1":"SK","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":660,"height":990,"file_path":"/rAGGy0hOhoh0gGMzoxvZKBCBcWu.jpg","iso_639_1":"cs","iso_3166_1":"CZ","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/ml0KBQSlYA2goT4rBadwB9lSR2w.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1470,"height":2100,"file_path":"/g0CJtSYRR1Tc1VNoR5ZjZBWr9Kb.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":1000,"height":1500,"file_path":"/tZvLjp09v7oPANXthC9RQCtinQP.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":2831,"file_path":"/3S0itB9OtDgybdktmVmO1yJ76zb.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.706,"vote_average":0},{"width":2000,"height":3000,"file_path":"/tPDBMu5fs9kDrb79x0tXhtAE5cK.jpg","iso_639_1":"ja","iso_3166_1":"JP","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/nybeYHt7aKJ6ARGb31mytQ5cGFx.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/cBjZsJwa1RlpHqTj4Gyci0E238V.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/4H3VwvIQC1dsMFb2DEGZpbS0JiI.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/fqGjwh4vmWUD4luen26Wtaf6xdd.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/dbFQUKS3jBOR61dQ3VDOk7FJff8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/oJ597dVjLMICx56clM7iy3AUUsA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":2.278},{"width":1920,"height":1080,"file_path":"/ofccLimkF3XSu675ra2tCV6mzh6.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":2560,"height":1440,"file_path":"/nAPCvVY0n7sepk3E8avbBTruDMk.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/mzEUmwRRIlRohKnlSZWnnwqlwzM.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/sTkfVOH3VSCENDFP0ikOB5ZLiwr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1833,"height":1032,"file_path":"/8DGHxyW5ej5rLR2ZMIRB4NjuzOI.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.776,"vote_average":0.166},{"width":1839,"height":1034,"file_path":"/h0oSAJaJ8aQQ3Yl2fO0VQFA1ybP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.779,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/hztr2mbtJpcAbdc1LuL5DO1vz6G.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/5UP1WoAbxsyG9ZuHViHyRzS0ia2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/2ZyFLgNiletK7b1F93AbMYz0Snp.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/gB3jsTeGfruHad3Qa2QuVb4ABzp.jpg","iso_639_1":"fi","iso_3166_1":"FI","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/jpCdFwXKFZciRFBhZnK1WBWHwu1.jpg","iso_639_1":"fi","iso_3166_1":"FI","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:54:08.815+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":115,"tagline":"The greatest danger facing our world has been the planet's best kept secret... until now.","homepage":"","overview":"Zane Ziminski is an astrophysicist who receives a message that seems to have extraterrestrial origins. Eerily soon after his discovery, Zane is fired. He then embarks on a search to determine the origins of the transmission that leads him into a Hitchcockian labyrinth of paranoia and intrigue."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"The Arrival - Die Ankunft","runtime":115,"tagline":"","homepage":"","overview":"Der NASA-Mitarbeiter Ziminski hört eines Tages an seinem Arbeitsplatz außerirdische Geräusche aus dem All. Als er seinen Chef davon in Kenntnis setzt, erhält er seine Entlassung. Nachdem dann noch sein Partner ermordet wird, ahnt Ziminski, dass etwas faul ist. Mit Hilfe seines eigenen Equipments verfolgt er das Signal bis nach Mexiko und macht dort eine ungeheure Entdeckung..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"天袭","runtime":0,"tagline":"","homepage":"","overview":"　　地球突然收到太阳系以外的无线电波，使各地天气变得无法预测，天文学家赞恩着手调查这个奇怪的现象，惊觉外星人不仅存在，还悄悄进驻地球的某个角落，变化成地球人的模样，计划将地球逐渐转换成不适合人类居住的环境……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Evrenin Sırrı","runtime":0,"tagline":"","homepage":"","overview":"California Çölü’nde, Derin Uzay Araştırma İstasyonu’nda 40 metrelik bir parabolik radar ile çalışan Zane Ziminski uzayın derinliklerinde hayat ışığı arayan bir bilim adamıdır. Araştırmaları sırasında shock sinyalleri saptar ve bunları DAT kasetlere kaydeder. Nasa’nın ilgisini çeken bu kasetler, gelişmelerin sadece başlangıcı olur. Çünkü Meksika’da bir yerde bu sinyallere, uzaya doğru cevap verildiği anlaşılır. Uzaylılar var mı? Varsa neredeler, Dünya’da mı?"},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Прибытие","runtime":0,"tagline":"Веками мы смотрели в небо, вместо того, чтобы оглянуться вокруг.","homepage":"","overview":"Однажды радиоастроном Зэйн Замински услышал сигнал из космоса. Однако за совершенное Зэйном «открытие века» его начальник Джордиан увольняет своего сотрудника, из чего Замински делает вывод, что существует грандиозный заговор с целью скрыть установление контакта с внеземной цивилизацией. В поисках доказательств своего предположения Зэйн приезжает в мексиканскую провинцию, где знакомится с Иланой Грин, специалисткой в области прогнозов погоды для всей планеты. Здесь, в Мексике, с риском для жизни Зэйн узнает, что инопланетяне у нас на Земле чувствуют себя хозяевами. Конечно, они пока еще не завоевали Землю, но, выбирая, каким путем им идти, чтобы решить проблемы жизни на своей, очевидно, гибнущей планете (путем переговоров с землянами или путем уничтожения нашей цивилизации), пришельцы предпочли второй вариант…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":115,"tagline":"Le plus grand danger auquel notre monde est confronté a été le secret le mieux gardé de la planète… jusqu'à présent.","homepage":"","overview":"Zane Zaminsky, radioastronome, sonde les fréquences aériennes afin de déceler la preuve d'une existence extraterrestre. Un jour, il entend des cris aigus sortant de ses enceintes. Il s'agit d'une onde de choc provenant d'au delà de notre système solaire, une preuve plausible de la vie extraterrestre. Son enquête le conduit au Mexique, où il découvre une base secrète habitée par des extraterrestres. Sous leur apparence humaine se cache une tout autre réalité."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Han llegado","runtime":115,"tagline":"El mayor peligro que acecha nuestro mundo es el secreto mejor guardado. Hasta ahora...","homepage":"","overview":"Un astrofísico que trabaja para la NASA, capta unas extrañas señales procedentes del espacio, que aparentemente encierran un mensaje inteligente. Pero cuando informa del hecho a sus superiores, es despedido. Después de localizar unas señales similares que se emiten desde México, el científico decide viajar a ese país con el fin de investigar el origen de las mismas. Allí descubre que los extraterrestres han llegado a la Tierra."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Zane är radioastronom. Han är säker på att det första tecknet på liv ute i rymden kommer i form av en radiosignal. Inte som en spektakulär massinvasion av flygande tefat. Så han lyssnar och hör! Men när han presenterar sina sensationella forskningsresultat för chefen blir han motarbetad. När Zane ändå fortsätter med sina efterforskningar får han sparken! Stärkt i sin övertygelse fortsätter Zane jakten på sanningen. Nu är han förföljd och mordhotad. Han vet inte längre vem som är vän eller fiende? Charlie Sheen från bl.a. 'Hot Shots' och 'Fritt Fall', spelar huvudrollen i den här actionladdade science fiction thrillern, av skaparen till bl.a. 'Jagad' och 'Alien'-filmerna!  Övriga roller: Ron Silver, 'Timecop' och Lindsay Crouse, från bl.a. 'The Verdict' och 'Alla presidentens män'."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":115,"tagline":"Il più grande pericolo per il nostro pianeta è nascosto nel suo più terribile segreto.","homepage":"","overview":"Dopo aver ricevuto via radio un segnale dallo spazio, un astronomo si mette in contatto con chi lo ha inviato. Lo scienziato - entrato a far parte del Seti, un programma che scandaglia l'universo alla ricerca di presenze aliene - si trova a lavorare con un meteorologo. Ma, un giorno, i due sembrano captare altre tracce..."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"Zane Ziminski er videnskabsmand. Han er besat af tanken om, at vi ikke er alene i universet. Konstant scanner han luftvejene for at få beviser. Pludseligt sker det, han har ventet på så længe. Han opfanger et signal fra et andet solsystem. Nogen kommunikerer med jorden. Zane sporer signalerne til en øde radarstation i Yucatan Mexico. I sin søgen efter radarstationen finder Zane en gigantisk anlagt fabrik, der er gjort alt for at skjule midt i junglen. Da han sniger sig ind på fabrikken, får han sit livs chok."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Invaze","runtime":115,"tagline":"","homepage":"","overview":"Astrofyzik Zane Zaminski objeví se svým kolegou Calvinem tajemné radiové signály, které pravidelně přicházejí z vesmíru. Když tento zajímavý objev oznámí svému nadřízenému Gordianovi z vedení speciálního oddělení NASA, čeká ho nepříjemné překvapení: dostává příkaz okamžitě ukončit další výzkum a důležité materiály z jejich astronomické laboratoře jsou zabaveny. Vzápětí je Zane ze svého zaměstnání propuštěn a nejen to - brzy zjistí, že někdo usiluje o jeho život. V té chvíli už tuší, že tajemné radiové signály mají něco společného s tepelnými elektrárnami zcela neznámé konstrukce..."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Galaktikus támadás","runtime":115,"tagline":"","homepage":"","overview":"Zane Zaminski (Charlie Sheen) rádiócsillagász legszívesebben az eget kutatja. Jeleket vár, választ az űrbe sugárzott földi üzenetekre. Ezért nem is lepődik meg amikor sikerül elkapnia egy a naprendszerünkön túlról érkező adást. A felfedezés jelentőségét azonban rajta kívül mintha senki sem értékelné, így napokon belül elveszti állását és az egyetlen szem- és fültanút, aki bizonyíthatná az igazát. Hamarosan saját megfigyelőállomást hoz létre és a következő idegen adás érkezésekor megdöbbentő titkot fedez fel: Az idegenek már megkezdték a föld meghódítását és az életkörülmények gyökeres megváltoztatását."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Eles Chegaram","runtime":0,"tagline":"","homepage":"","overview":"Zane Ziminski um astrônomo, capta sinais do espaço sideral. Como acredita que estejam sendo enviados por uma vida inteligente reporta ao seu superior, Phil Gordian (Ron Silver), que alega uma desculpa e o demite, destruindo em seguida a gravação dos sons. Mas Zane decide investigar os sinais por conta própria e capta sinais semelhantes vindos do México. Ele deduz então que estes sinais possam ser uma \"conversa\" com alienígenas escondidos na Terra e já em uma aldeia mexicana se une a Ilana Green (Lindsay Crouse), uma cientista que tem suspeitas de algo estranho após testemunhar uma aceleração do efeito estufa."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Zane Ziminski er en radioastronom som finner et rart signal fra ytre verdensrom. Troende at disse signalene kommer fra inntelligent liv, raporterer han dette til sine overordnende. Senere får han sparken. Nå begynner han å undersøke disse signalene på egenhånd, og nå finner han liknende signaler bli sendt fra Mexico. Utålmodig på å finne signalets opprinnelse dra han til Mexico, hvor han avslører en skremmende hemmelighet!"},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Η άφιξη","runtime":115,"tagline":"","homepage":"","overview":"Ο Ζέιν Ζιμίνσκι είναι ένας αστροφυσικός που λαβαίνει ένα μήνυμα το οποίο φαίνεται να έχει εξωγήινη προέλευση. Περιέργως, πολύ σύντομα απολύεται από τη δουλειά του. Τότε ξεκινάει να ανακαλύψει την προέλευση του μηνύματος, και βρίσκεται αντιμέτωπος με ένα λαβύρινθο παράνοιας και μυστηρίου."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"ההגעה","runtime":0,"tagline":"","homepage":"","overview":"אסטרונום צעיר מגלה בגלי הרדיו הפרעה קוסמית המגיעה להערכתו מחדירה של אינטליגנציה חוצנית למערכת כדור הארץ. חקירתו בנושא מובילה אותו למפעל חשמל נטוש במקסיקו, שם הוא נעצר על ידי המשטרה בחשד לרצח מדען אחר. ההוכחה היחידה הם גלי הרדיו והמסר הטמון בהם. האם יצליח להציל עצמו באמצעות עדות מכוכב אחר? (תקציר האוזן ה 3)"},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Mesaj din spațiu","runtime":115,"tagline":"Cel mai mare pericol cu ​​care se confruntă lumea noastră a fost secretul cel mai bine păstrat al planetei... până acum.","homepage":"","overview":"Zane Ziminski (Charlie Sheen), un astrofizician, descoperă un semnal ce pare a avea origine extraterestră. Imediat după această descoperire, Zane este concediat. Intrigat și neliniștit, el demarează o cercetare pe cont propriu, dorind să stabilească cu exactitate originea semnalului. Curând, el se trezește prins într-un labirint al intrigilor și paranoiei."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":109,"tagline":"","homepage":"","overview":"Zane Ziminski is een geleerde die op een dag een bericht ontvangt dat een buitenaardse oorsprong lijkt te hebben. Vlak na zijn ontdekking wordt Zane ontslagen. Hij begint een zoektocht naar de oorsprong van het bericht, wat hem in Mexico brengt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Spotkanie","runtime":0,"tagline":"Największym niebezpieczeństwem, przed którym stoi nasz świat, była najlepiej strzeżona tajemnica planety... aż do teraz.","homepage":"","overview":"Zane Ziminsy (Charlie Sheen - \"Pluton\", \"Na granicy ryzyka\") astronom pracujący na radiowym teleskopie wierzy, że udało mu się wyodrębnić sygnał pochodzący od jakiejś pozaziemskiej cywilizacji. Przekazuje taśmę z nagraniem swojemu szefowi Philipowi Gordianowi (Ron Silver) i natychmiast zostaje zwolniony z pracy. Desperacko poszukując odpowiedzi, Zane trafia do Meksyku, gdzie odkrywa tajną, ściśle strzeżoną elektrownię. Dzięki pomocy klimatologa Ilany Green (Lindsay Crouse) - starającej się wyjaśnić gwałtowne ocieplenie klimatu i zapobiec ekologicznej katastrofie, Zanowi udaje się włamać do elektrowni. Jego odkrycie jest wstrząsające..."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"A Invasão","runtime":115,"tagline":"Desta vez eles não vão invadir nosso planeta. Eles já estão aqui.","homepage":"","overview":"Zane Ziminski (Charlie Sheen), um astrônomo, capta sinais do espaço sideral. Como acredita que estejam sendo enviados por uma vida inteligente, reporta ao seu superior, Phil Gordian (Ron Silver), que alega uma desculpa e o demite, destruindo em seguida a gravação dos sons. Mas Zane decide investigar os sinais por conta própria e capta sinais semelhantes vindos do México. Ele deduz então que estes sinais possam ser uma \"conversa\" com alienígenas escondidos na Terra e já em uma aldeia mexicana se une a Ilana Green (Lindsay Crouse), uma cientista que tem suspeitas de algo estranho após testemunhar uma aceleração do efeito estufa."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"어라이벌","runtime":0,"tagline":"","homepage":"","overview":"외계 생명체가 보낸 신호를 찾는 천문학자인 제인 지민스키는 어느날 전파 망원경으로 45초에 걸친 이상한 신호를 포착하고 외계인의 신호라고 보고하지만, 상부에서는 철저하게 무시한다. 지구에서 보낸듯한 또다른 신호를 따라 멕시코로 간 그는 지구 식민지를 세우려는 외계인들의 기지를 발견한다. 하지만 그는 혼자이며 주변의 어느 누구도 믿을수 없는 상황에 놓이고 마는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"アライバル／侵略者","runtime":0,"tagline":"","homepage":"","overview":"宇宙観測所に務める科学者ゼインは、ある夜、正体不明の電波をキャッチする。地球外生命の証拠に間違いないとデータをNASAに提出するが、ボスであるゴーディはそれを黙殺し、ゼインも突然解雇されてしまう。納得のいかないゼインは自宅に観測所を作り、隣に住む黒人の少年キキと共に観測を続け、その電波がメキシコから発している事を突き止めた。到着した現地で謎の男に命を狙われながらも、ゼインは山奥に存在するオムニテック社の巨大プラントに行き当たる。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Hyytävät hetket","runtime":0,"tagline":"","homepage":"","overview":"Radioastronomi Zane Zaminsky uskoo havainneensa kosmisessa kohinassa älyllisen signaalin. Zane saa välittömästi potkut kertoessaan havainnoistaan esimiehelleen. Omin päin Zane yrittää epätoivoisesti selvittää signaalin alkuperää, mikä johdattaa hänet Meksikoon, jossa salaperäinen energiavoimala näyttäisi generoivan muutakin kuin sähköä. Kun mahdollista lähestyvää luonnonkatastrofia tutkiva tiedenainen Ilana Green löytyy kuolleena, alkaa Zane epäillä, että hän on salaliiton jäljillä."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Han llegado","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Пристигането","runtime":0,"tagline":"","homepage":"","overview":""},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"L'avènement","runtime":115,"tagline":"Le plus grand danger auquel notre monde est confronté a été le secret le mieux gardé de la planète... jusqu'à présent.","homepage":"","overview":"Zane Zaminsky, radioastronome, sonde les fréquences aériennes afin de déceler la preuve d'une éxistence extraterrestre. Un jour, il entend des cris aigus sortant de ses enceintes. Il s'agit d'une onde de choc provenant d'au-delà de notre système solaire, une preuve plausible de la vie extraterrestre. Son enquête le conduit au Mexique où il decouvre une base secrète habitée par des extraterrestres. Sous leur apparence humaine se cache une tout autre réalité."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Atvykimas","runtime":0,"tagline":"","homepage":"","overview":"Apsėstas astronomas, turintis radijo teleskopą, Zeinas Zaminskis išsiaiškina, kad ateiviai jau įsiveržė į Žemę.\r Visuotinis atšilimas yra jų parengto, mirtinai pavojingo sąmokslo dalis."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Dolazak","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Han arribat","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Прибуття","runtime":0,"tagline":"","homepage":"","overview":"Астроном записав сигнал цивілізації з іншої планети, після чого його звільнили. Разом з жінкою-екологом, занепокоєною парниковим ефектом, він переконується, що довгоочікуваний контакт вже відбувся... Пересічна фантастична стрічка, яка була однією з тих, завдяки яким Чарлі Шин випав з першої ліги зірок в середині 90-х."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"外星人入侵","runtime":0,"tagline":"","homepage":"","overview":"搜尋外太空訊息多年，科學家贊恩吉斯基（查理辛飾）一直自問：到底有沒有外星生物？有一天，毫無預警的，來自太陽系以外的無線電波就這麼出現了！贊恩追查來源，發現墨西哥尤卡坦州有某電控站和該電波發射處進行接觸。然後，地球臭氧層變稀薄，氣候開始產生變化，並影響九大行星生態。  贊恩為調查此事前往尤卡坦，在進入尤卡坦叢林的地下，目睹一切難以名狀的高科設備和詭異生物後，他終於了解；外星生物不但存在，而且已經進據地球，開創秘密基地，且深入人類權勢中心。它們打算藉著改造氣候型態，毀滅人類文明，全面接管地球！唯今之計，只有提出一切證據，技巧地躲過外星人，警告全球人類危機正迫在眉劫，才有機會逃過災難，時間不多了，贊恩辦得到嗎？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Invázia","runtime":0,"tagline":"","homepage":"","overview":"Astrofyzik Zane Zaminski objaví so svojim kolegom Calvinom tajomné rádiové signály, ktoré pravidelne prichádzajú z vesmíru. Keď tento zaujímavý objav oznámi svojmu nadriadenému Gordianovi z vedenia špeciálneho oddelenia NASA, čaká ho nepríjemné prekvapenie: dostáva príkaz okamžite ukončiť ďalší výskum a dôležité materiály z ich astronomického laboratória sú zabavené. Vzápätí je Zane zo svojho zamestnania prepustený a nielen to – čoskoro zistí, že niekto sa usiluje o jeho život. V tej chvíli už tuší, že tajomné rádiové signály majú niečo spoločné s tepelnými elektrárňami úplne neznámej konštrukcie."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Dolazak","runtime":0,"tagline":"Astronom Zane Ziminski (Charlie Sheen) opsjednut je signalima iz svemira","homepage":"","overview":"Charlie Sheen glumi astronoma koji misli da čuje signal iz svemira, ali kad ga donese svom šefu saznaje da se zbog smanjenja budžeta njegov odjel zatvara. Signal se ne može analizirati i zbog toga njegova teorija o signalu ostaje zanemarena. Nakon toga on više nikome ne govori šta se događa. Ne otkriva tajnu ljudima oko sebe. Ne može vjerovati što je otkrio i iskreno je uplašen pokazujući pravi ljudski karakter."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"สงครามแอบยึดโลก","runtime":0,"tagline":"","homepage":"","overview":"เมื่อถูกเจ้านายไล่ออก หลังพบหลักฐานพิสูจน์การมีอยู่ของสิ่งมีชีวิตที่มีสติปัญญานอกโลก นักบินอวกาศผู้มีประวัติด่างพร้อยจึงวางแผนจะขุดคุ้ยหาคำตอบ"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Prihod","runtime":0,"tagline":"","homepage":"","overview":"Zane Zaminsky je radioastronom, ki se ukvarja z iskanjem tujih oblik življenja zunaj našega planeta. Nekega dne s pomočnikom Calvinom ujameta signal s 14 svetlobnih let oddaljene zvezde. 42 sekund dolg posnetek neseta nadrejenemu, ta zanj ne pokaže zanimanja, še več, Zana odpusti in se pozneje vede, kot da vsega skupaj sploh ni bilo. Zane se odloči, da bo zadevo raziskal ..."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"外星人入侵","runtime":0,"tagline":"","homepage":"","overview":"搜尋外太空訊息多年，科學家贊恩吉斯基（查理辛飾）一直自問：到底有沒有外星生物？有一天，毫無預警的，來自太陽系以外的無線電波就這麼出現了！贊恩追查來源，發現墨西哥尤卡坦州有某電控站和該電波發射處進行接觸。然後，地球臭氧層變稀薄，氣候開始產生變化，並影響九大行星生態。\r 贊恩為調查此事前往尤卡坦，在進入尤卡坦叢林的地下，目睹一切難以名狀的高科設備和詭異生物後，他終於瞭解；外星生物不但存在，而且已經進據地球，開創秘密基地，且深入人類權勢中心。它們打算藉著改造氣候型態，毀滅人類文明，全面接管地球！唯今之計，只有提出一切證據，技巧地躲過外星人，警告全球人類危機正迫在眉劫，才有機會逃過災難，時間不多了，贊恩辦得到嗎？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[{"id":"57b14a48c3a3682c20003120","url":"https://www.themoviedb.org/review/57b14a48c3a3682c20003120","author":"Gimly","content":"Charlie Sheen channels his inner Kevin Smith in this unique take on the genre. Sure it's a little X-Files-y, and a lot of the twists are either glaringly obvious or make zero sense, but by and large it's pretty original. The climate-change message does beat you over the head a little, but only gently, which I can handle. Obviously it didn't take anyway, considering we're here twenty years later and the problem's only gotten worse.\r\n\r\n_Final rating:★★½ - Had a lot that appealed to me, didn’t quite work as a whole._","created_at":"2016-08-15T04:51:20.377Z","updated_at":"2021-06-23T15:57:50.321Z","author_details":{"name":"Gimly","rating":5,"username":"Ruuz","avatar_path":"/xUObnJSvHrFPsIpoDmb1jiQZLq7.jpg"}}],"recommendations":[{"id":394223,"adult":false,"title":"Sniper: Special Ops","video":false,"overview":"A Special Ops military Force, led by expert sniper Sergeant Jake Chandler, are sent to a remote Afghan village to extract an American congressman being held by the Taliban.","genre_ids":[28,10752],"media_type":"movie","popularity":0.6769,"vote_count":102,"poster_path":"/jgE31g7hqV9UVJKqz3LCwm5oDb8.jpg","release_date":"2016-04-03","vote_average":4.255,"backdrop_path":"/yj1HFRGCviH7Vh6Cmnylf7H3S5C.jpg","original_title":"Sniper: Special Ops","original_language":"en"},{"id":217337,"adult":false,"title":"Longwave","video":false,"overview":"It is April 1974 and Julie Dujonc-Renens, young feminist journalist and the cunning Joseph-Marie Cauvin, leading reporter for the Swiss radio, have been sent to Portugal to investigate Switzerland’s aid to poor countries. Sparks fly during the bus trip with Bob, sound engineer approaching retirement. The projects financed by Switzerland prove to be calamitous and the workers’ revolution that suddenly breaks out doesn’t help, obliging our heroes to disregard first the radio’s management, and then their own codes of conduct.","genre_ids":[35],"media_type":"movie","popularity":0.174,"vote_count":42,"poster_path":"/A8K6CdlRabohu57RqQpOoTkShGj.jpg","release_date":"2013-08-11","vote_average":5.6,"backdrop_path":"/dnga5TMlhv4DXnwLE4CeHkm3bgz.jpg","original_title":"Les grandes ondes (à l'ouest)","original_language":"fr"},{"id":6553,"adult":false,"title":"No More Mr. Nice Guy","video":false,"overview":"The brothers Kipp and Most set off to inherit their grandmother's estate. Along the way, they meet Viktor, a deserted Russian soldier who kidnaps them, and Nadine, who joins them voluntarily. On their way to their inheritance, the protagonists get into some seemingly hopeless situations.","genre_ids":[35],"media_type":"movie","popularity":0.2221,"vote_count":26,"poster_path":"/yR3XAi4V1KZyJxiYfeII6a6DpWX.jpg","release_date":"1993-04-01","vote_average":7.4,"backdrop_path":"/hihGYFKBZvu5TxBIPUegHAQQ4N5.jpg","original_title":"Wir können auch anders ...","original_language":"de"},{"id":141274,"adult":false,"title":"A Novel Romance","video":false,"overview":"Nate Shepherd, late 40's, and Jenny Sparks, early 30's, meet in a fancy New York eatery. Complete strangers who have had a rotten day, waiting for their better halves, they reveal to one another that they are going to meet new people tonight. They quickly realize they are waiting for each other. When Nate loses his girlfriend (after getting fired from his cushy job at an ad agency) and Jenny loses her boyfriend to a drug overdose, Nate's girlfriend suggests that they should move in together as friends to split the rent and ease each others pain. As their friendship grows into something more, their relationship becomes a loving but complicated experience.","genre_ids":[10749,35,18],"media_type":"movie","popularity":0.4352,"vote_count":8,"poster_path":"/kavYtS6y6PGPPtZ6ZVdxR3URLrx.jpg","release_date":"2011-11-11","vote_average":7.125,"backdrop_path":"/oNBBBybzHR3ZtBPMu0l3JGGVr3S.jpg","original_title":"A Novel Romance","original_language":"en"},{"id":75555,"adult":false,"title":"The Fear","video":false,"overview":"Richard, a college student who has decided to focus his attention on the study of fear, invites a group of friends up to his family's secluded mountain cabin for the weekend. Soon, a lifelike, wooden carving of a man begins stalking and killing them.","genre_ids":[27],"media_type":"movie","popularity":0.7777,"vote_count":40,"poster_path":"/qpb2TpcRWKxCDokeVHUAyfEL11P.jpg","release_date":"1995-01-20","vote_average":3.902,"backdrop_path":"/1tm1yizlkVTpAUxsk2ICkmLWxJt.jpg","original_title":"The Fear","original_language":"en"},{"id":19154,"adult":false,"title":"The Second Arrival","video":false,"overview":"After Zane Ziminski is found dead five people received envelopes with details of an alien invasion. This group of five includes 3 scientists, Zane's brother Jack, and a reporter. Quickly, the group is down to three and then Jack and Bridget, the reporter. With a small piece of alien technology, they must escape from the aliens, who take human form, and try to convince others that aliens exist.","genre_ids":[878,27],"media_type":"movie","popularity":0.6592,"vote_count":83,"poster_path":"/3mjqRwjs6KbmNuMHYIz2gualCZJ.jpg","release_date":"1998-11-06","vote_average":3.7,"backdrop_path":"/xGS06Ur3Etqzjf5D0xqKU6WqfeG.jpg","original_title":"The Second Arrival","original_language":"en"},{"id":43913,"adult":false,"title":"Postmortem","video":false,"overview":"The only thing James wants is to remain away from Scotland. One day, however, he receives a fax, a printout of an unknown person's obituary. The next day, he is charged and arrested for the murder of this person.","genre_ids":[53],"media_type":"movie","popularity":0.367,"vote_count":36,"poster_path":"/ktNGzAEsn37RHfdklJ7Vydz5vao.jpg","release_date":"1998-06-20","vote_average":5.5,"backdrop_path":"/gUu1973lUo4nJ0dKGpfuSHtGhD0.jpg","original_title":"Postmortem","original_language":"en"},{"id":45773,"adult":false,"title":"Aberration","video":false,"overview":"After stealing a fortune from the Russian mob, Alex Langdon tries to hide out in a remote cabin but discovers that the area is home to a dangerous species of mutant lizards that have developed a taste for human flesh.","genre_ids":[27,878],"media_type":"movie","popularity":0.2243,"vote_count":29,"poster_path":"/peiVAps7CevdPN6lvsabThtTK26.jpg","release_date":"1998-07-09","vote_average":4.759,"backdrop_path":"/6RbH6rqUFuKSFAHnzKEZ80VjT5h.jpg","original_title":"Aberration","original_language":"en"},{"id":505747,"adult":false,"title":"When Margaux Meets Margaux","video":false,"overview":"20-year-old Margaux makes the acquaintance of 45-year-old Margaux: they have a lot in common – so much so that it turns out they are one and the same person, at two different ages and stages of their life…","genre_ids":[35,14],"media_type":"movie","popularity":0.2771,"vote_count":61,"poster_path":"/3onSWigYspp34uqOnvVqT054OnG.jpg","release_date":"2018-03-14","vote_average":5.1,"backdrop_path":"/40fsiggKf6Edxm5irPova0TCnrC.jpg","original_title":"La Belle et la Belle","original_language":"fr"},{"id":66212,"adult":false,"title":"Righting Wrongs","video":false,"overview":"Jason Chan, a Hong Kong lawyer, is angry at the way the law protects criminals and decides to take the law into his own hands, dishing out vigilante justice when a key witness and his entire family are murdered. But hotshot cop Cindy Si is soon on Chan's case, and the situation unravels into a fight that only a few will survive.","genre_ids":[28,35,80,18,53],"media_type":"movie","popularity":1.3263,"vote_count":74,"poster_path":"/diXiT68DC6mIlzv3WsOS2iYkl36.jpg","release_date":"1986-11-27","vote_average":7.6,"backdrop_path":"/urmqanJmSjVReGhbJtv1iiCzKdg.jpg","original_title":"執法先鋒","original_language":"cn"},{"id":21241,"adult":false,"title":"Cannonball","video":false,"overview":"Coy \"Cannonball\" Buckman and his blazing red Pontiac enter the Trans-America Grand Prix, an underground road race spanning the continent in which there are no rules, no speed limits and no heed for the law. En route, Buckman jockeys with an international ensemble of racers for a $100,000 purse. But there are none more important than Cade Redman, his direct competition for a guaranteed spot on the elite Modern Motors racing team.","genre_ids":[28,35],"media_type":"movie","popularity":4.3609,"vote_count":120,"poster_path":"/u85Yi7wJRKS7lgLjQdpQqOxJNO7.jpg","release_date":"1976-07-06","vote_average":5.533,"backdrop_path":"/fV7Faf2J5DyPVSSkNCLh2TqSHRt.jpg","original_title":"Cannonball","original_language":"en"},{"id":22076,"adult":false,"title":"Alien Hunter","video":false,"overview":"Government agents find evidence of extraterrestrial life at the South Pole.","genre_ids":[878,28,12],"media_type":"movie","popularity":1.0353,"vote_count":145,"poster_path":"/cb58aaGnPJROoooFCXlR6o1ebw5.jpg","release_date":"2003-07-19","vote_average":5.1,"backdrop_path":"/hWTqjvMryjtCLMxo90iSqZ89tT4.jpg","original_title":"Alien Hunter","original_language":"en"},{"id":18158,"adult":false,"title":"Earth vs. the Flying Saucers","video":false,"overview":"Test space rockets exploding at liftoff and increased reporting of UFO sightings culminate in a direct attempt by alien survivors of a dead, extra-galactic civilization to invade Earth from impervious flying saucers, using ray-weapons of mass destruction.","genre_ids":[28,878],"media_type":"movie","popularity":1.0103,"vote_count":179,"poster_path":"/qCOLglZvQgQAyWMCZodBo3wmgqp.jpg","release_date":"1956-06-13","vote_average":6.084,"backdrop_path":"/rpazkJ87yIAcKbQ4IFbZ8y2uJIN.jpg","original_title":"Earth vs. the Flying Saucers","original_language":"en"},{"id":48197,"adult":false,"title":"The Town That Dreaded Sundown","video":false,"overview":"When two young lovers are savagely beaten and tortured on a back country road in Texarkana, local police are baffled and must find \"the Phantom Killer\" before he can kill again.","genre_ids":[27,9648,53,80],"media_type":"movie","popularity":0.6974,"vote_count":217,"poster_path":"/sI6kUePh4S3T1rDozPR0Etg7E8X.jpg","release_date":"1976-12-24","vote_average":5.775,"backdrop_path":"/18t6Zq6aEdZAfcQXilDi2NrMNJ7.jpg","original_title":"The Town That Dreaded Sundown","original_language":"en"},{"id":14527,"adult":false,"title":"Foolproof","video":false,"overview":"Kevin, Sam and Rob have an unusual hobby: planning foolproof heists, without intending to actually perform them. The game goes wrong when their latest plan is stolen and carried out. Things get even worse when a mysterious man approaches them with an offer: plan a heist for him, or go to jail. As the clock ticks, they find that the risk might be higher than just their freedom.","genre_ids":[28],"media_type":"movie","popularity":0.7421,"vote_count":196,"poster_path":"/gudhSz8sDzRXxHY5XchllQKxw77.jpg","release_date":"2003-10-03","vote_average":6.105,"backdrop_path":"/uookmLyx9dKDBrjXJDDp175meg4.jpg","original_title":"Foolproof","original_language":"en"},{"id":19851,"adult":false,"title":"Grey Gardens","video":false,"overview":"Based on the life stories of the eccentric aunt and first cousin of Jackie Onassis raised as Park Avenue débutantes but who withdrew from New York society, taking shelter at their Long Island summer home, \"Grey Gardens.\" As their wealth and contact with the outside world dwindled, so did their grasp on reality.","genre_ids":[36,18,10770],"media_type":"movie","popularity":0.565,"vote_count":149,"poster_path":"/9iO11PLhIGCzN6n2V92XcANQ8M9.jpg","release_date":"2009-06-21","vote_average":6.839,"backdrop_path":"/b88Q3GbYfKQAakyKDG2Vhw4BJ3A.jpg","original_title":"Grey Gardens","original_language":"en"},{"id":11067,"adult":false,"title":"Major League II","video":false,"overview":"After losing in the ALCS the year before, the Cleveland Indians are determined to make it into the World Series this time! However, they first have to contend with Rachel Phelps again when she buys back the team.","genre_ids":[35],"media_type":"movie","popularity":1.1794,"vote_count":354,"poster_path":"/2QAb0gZusyMsZ1W5ce85plVciDp.jpg","release_date":"1994-03-30","vote_average":5.723,"backdrop_path":"/y4nGjTJ4d0x5tQ7EFLhuDO81QaV.jpg","original_title":"Major League II","original_language":"en"},{"id":457249,"adult":false,"title":"Vixen: The Movie","video":false,"overview":"Originally from Africa, Mari McCabe grew up an orphan after her parents were killed by local greed, corruption and wanton violence. But Mari refuses to succumb to the terrors surrounding her. Inheriting her family's Anansi Totem, Mari can access the powers of animals - anything from the super-strength of a gorilla to the speed of a cheetah. As Vixen, she fights valiantly to protect the world from threats like those that claimed her family.","genre_ids":[28,16],"media_type":"movie","popularity":1.0453,"vote_count":130,"poster_path":"/5A52QYVaZFGWZnXeNfvMOrnd49E.jpg","release_date":"2017-05-08","vote_average":6.8,"backdrop_path":"/hUZT1RTSEoXcGcuXdmb4fVk0qgZ.jpg","original_title":"Vixen: The Movie","original_language":"en"},{"id":701,"adult":false,"title":"Our Hospitality","video":false,"overview":"A young man falls for a young woman on his trip home; unbeknownst to him, her family has vowed to kill every member of his family.","genre_ids":[35,10749],"media_type":"movie","popularity":0.6888,"vote_count":310,"poster_path":"/cAEdL6RzfDSbPO51izl01Njzikx.jpg","release_date":"1923-11-19","vote_average":7.484,"backdrop_path":"/265pOIZG5xsX1I2AnLqzQoNFOL5.jpg","original_title":"Our Hospitality","original_language":"en"},{"id":25318,"adult":false,"title":"Escape from Sobibor","video":false,"overview":"The true story of WWII's notorious Sobibor Nazi death camp, where a courageous inmate orchestrates and leads the escape of over 300 prisoners.","genre_ids":[18,53,10752,10770],"media_type":"movie","popularity":1.2212,"vote_count":202,"poster_path":"/sAeljrIHTtKgJ2BaVoa9oCTmD4u.jpg","release_date":"1987-04-12","vote_average":7.2,"backdrop_path":"/sOhrxGvSJOaAJdBXHu1vQImfGuj.jpg","original_title":"Escape from Sobibor","original_language":"en"}],"similar_content":[{"id":106,"adult":false,"title":"Predator","video":false,"overview":"A team of elite commandos on a secret mission in a Central American jungle come to find themselves hunted by an extraterrestrial warrior.","genre_ids":[878,28,12,53],"popularity":14.8271,"vote_count":8869,"poster_path":"/k3mW4qfJo6SKqe6laRyNGnbB9n5.jpg","release_date":"1987-06-12","vote_average":7.5,"backdrop_path":"/otkJlfjB7zJ5h34FEIfemenMbCy.jpg","original_title":"Predator","original_language":"en"},{"id":653569,"adult":false,"title":"Save Yourselves!","video":false,"overview":"A young Brooklyn couple head upstate to disconnect from their phones and reconnect with themselves. Cut off from their devices, they miss the news that the planet is under attack.","genre_ids":[35,878],"popularity":0.5839,"vote_count":214,"poster_path":"/bvNwVJ3Wh6KeE28TMIczJD6OEPm.jpg","release_date":"2020-10-02","vote_average":5.766,"backdrop_path":"/2vJewgdaf0N8BnAgHZ8R7y3w5qQ.jpg","original_title":"Save Yourselves!","original_language":"en"},{"id":74,"adult":false,"title":"War of the Worlds","video":false,"overview":"Ray Ferrier is a divorced dockworker and less-than-perfect father. Soon after his ex-wife and her new husband drop off his teenage son and young daughter for a rare weekend visit, a strange and powerful lightning storm touches down.","genre_ids":[12,53,878],"popularity":8.8816,"vote_count":8977,"poster_path":"/6Biy7R9LfumYshur3YKhpj56MpB.jpg","release_date":"2005-06-28","vote_average":6.531,"backdrop_path":"/bInicBgSHfQiWLbnRT5jxw9Grvm.jpg","original_title":"War of the Worlds","original_language":"en"},{"id":75,"adult":false,"title":"Mars Attacks!","video":false,"overview":"A fleet of Martian spacecraft surrounds the world's major cities and all of humanity waits to see if the extraterrestrial visitors have, as they claim, \"come in peace.\" U.S. President James Dale receives assurance from science professor Donald Kessler that the Martians' mission is a friendly one. But when a peaceful exchange ends in the total annihilation of the U.S. Congress, military men call for a full-scale nuclear retaliation.","genre_ids":[35,14,878],"popularity":4.8484,"vote_count":5779,"poster_path":"/hll4O5vSAfnZDb6JbnP06GPtz7b.jpg","release_date":"1996-12-13","vote_average":6.4,"backdrop_path":"/ELsTifJ2lu4vsMhoHeZ5EnncHw.jpg","original_title":"Mars Attacks!","original_language":"en"},{"id":11,"adult":false,"title":"Star Wars","video":false,"overview":"Princess Leia is captured and held hostage by the evil Imperial forces in their effort to take over the galactic Empire. Venturesome Luke Skywalker and dashing captain Han Solo team together with the loveable robot duo R2-D2 and C-3PO to rescue the beautiful princess and restore peace and justice in the Empire.","genre_ids":[12,28,878],"popularity":19.9596,"vote_count":21965,"poster_path":"/6FfCtAuVAW8XJjZ7eWeLibRLWTw.jpg","release_date":"1977-05-25","vote_average":8.201,"backdrop_path":"/2w4xG178RpB4MDAIfTkqAuSJzec.jpg","original_title":"Star Wars","original_language":"en"},{"id":1058282,"adult":false,"title":"That Which Once Was","video":false,"overview":"In 2032 an eight-year old boy, displaced by global warming, fends for himself as an environmental refugee in a hostile northern metropolis. Haunted by memories of flooding that left him homeless and orphaned, the boy forms an unexpected friendship with an Inuk ice carver who helps him confront his past.","genre_ids":[18,878],"popularity":0.1737,"vote_count":0,"poster_path":"/xPAqc6UV0itYXRSiKwVnkMbpOwb.jpg","release_date":"2011-04-18","vote_average":0,"backdrop_path":"/2ZBz6sY6k8wXmYVnXEApQYC8qYP.jpg","original_title":"That Which Once Was","original_language":"en"},{"id":271078,"adult":false,"title":"Georgia","video":false,"overview":"A young woman investigates the death of her mother, who drowned when her daughter was still a baby. The question is: was it murder, suicide or merely an accident?","genre_ids":[53,9648],"popularity":0.3002,"vote_count":2,"poster_path":"/fr5WE4UXp50G41idexZ32EFZHBp.jpg","release_date":"1989-10-12","vote_average":1,"backdrop_path":"/1UNQvI7iGjcifmieoxXv34S9Swt.jpg","original_title":"Georgia","original_language":"en"},{"id":1576,"adult":false,"title":"Resident Evil","video":false,"overview":"When a virus leaks from a top-secret facility, turning all resident researchers into ravenous zombies and their lab animals into mutated hounds from hell, the government sends in an elite military task force to contain the outbreak.","genre_ids":[27,28,878],"popularity":4.3107,"vote_count":6780,"poster_path":"/1UKNef590A0ZaMnxsscIcWuK1Em.jpg","release_date":"2002-03-15","vote_average":6.649,"backdrop_path":"/xcENFGw9AlsmtiQGWuzIGbg1bdi.jpg","original_title":"Resident Evil","original_language":"en"},{"id":1577,"adult":false,"title":"Resident Evil: Apocalypse","video":false,"overview":"As the city is locked down under quarantine, Alice finds out that the people that died from the previous incident at the Umbrella Corporation have turned into zombies. She then joins a small band of elite soldiers, who are enlisted to rescue the missing daughter of the creator of the mutating T-virus.  Once lack of luck and resources happen, they begin to wage an exhilarating battle to survive and escape before the Umbrella Corporation erases its experiment from the face of the earth.","genre_ids":[27,28,878],"popularity":3.2609,"vote_count":4639,"poster_path":"/way9dOm4dM2sm9UMcu2PEXMTX0q.jpg","release_date":"2004-09-10","vote_average":6.354,"backdrop_