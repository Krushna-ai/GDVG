8,"vote_average":0},{"width":1920,"height":1080,"file_path":"/hRO4TS0IlH9UJW2PGuuFBYdXZgC.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3358,"height":1889,"file_path":"/iwMjinbOYgfCgznHKninwi8Dfw0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T04:59:00.469+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":86,"tagline":"","homepage":"","overview":"Una niña huérfana es rescatada por la policía en medio de un extraño ritual satánico y llevada al instituto Saint Catherine para jóvenes sin hogar. En este lugar poco convencional aprenderá nuevas"},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":86,"tagline":"","homepage":"","overview":"An orphaned girl is rescued from a satanic ritual and taken to Saint Catherine Institute for homeless youth. There she will learn new skills while facing demons that stalk her."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Заклятие монахини","runtime":86,"tagline":"","homepage":"","overview":"Сироту Элли спасают от сатанистов и помещают в особое учреждение, где проходят обучение бездомные подростки, которые уже хоть раз встречались с демонами."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Rytuał Świętej Katarzyny","runtime":0,"tagline":"","homepage":"","overview":"Osierocona dziewczyna zostaje uratowana z satanistycznego rytuału i zabrana do Instytutu św. Katarzyny dla bezdomnej młodzieży. Tam nauczy się nowych umiejętności, stawiając czoła prześladującym ją demonom."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Den forældreløse Ellie bringes til Saint Catherine-instituttet efter at være blevet reddet fra en kidnapning med satanistiske motiver. Denne hemmelige institution, som udgiver sig for at være et kloster, oplærer unge børn til at kunne kæmpe imod ondskab. Men dæmonerne, som hjemsøger Ellie, finder nye steder at dukke op."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Den föräldrarlösa Ellie tas till Saint Catherine-institutet efter att ha räddats från en kidnappning med satanistiska motiv. Den här hemliga institutionen, som utger sig för att vara ett kloster, tränar upp unga barn för att kunna kämpa emot ondska. Men demonerna som hemsöker Ellie hittar nya tillfällen att dyka upp."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":84,"tagline":"","homepage":"","overview":"Una niña huérfana es rescatada de un ritual satánico y llevada al Instituto Saint Catherine para jóvenes sin hogar. Allí aprenderá nuevas habilidades mientras se enfrenta a los demonios que la acechan."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Свята Катерина","runtime":0,"tagline":"","homepage":"","overview":"Дівчинку-сироту дивом рятують від страшного обряду та незабаром відправляють до безпечного священного місця, Інституту Святої Катерини. Саме там дівчинка має повернутися до більш звичного та спокійного життя. Але несподівано її починають переслідувати могутні демони, котрі швидко перетворюють буденність на справжнє пекло."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Een weesmeisje wordt gered van een satanisch ritueel en naar het Sint-Catharina-instituut voor dakloze jongeren gebracht. Daar zal ze nieuwe vaardigheden leren terwijl ze het opneemt tegen demonen die haar achtervolgen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"წმინდა ეკატერინე","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"圣凯瑟琳","runtime":0,"tagline":"","homepage":"","overview":"一名孤女从一次邪教仪式中被解救后，被送往圣凯瑟琳收容所。在那里，她不仅要学习新技能，还必须直面那些一直在暗中追踪她的恶魔。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"سانت كاثرين","runtime":86,"tagline":"","homepage":"","overview":"فتاة يتيمة تم إنقاذها من طقس شيطاني، ونُقلت إلى معهد القديسة كاثرين لرعاية الشباب المشردين. هناك ستتعلم مهارات جديدة بينما تواجه شياطين تلاحقها."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"聖凱瑟琳","runtime":0,"tagline":"","homepage":"","overview":"一名孤女從一次邪教儀式中被解救後，被送往聖凱瑟琳收容所。在那裏，她不僅要學習新技能，還必須直面那些一直在暗中追蹤她的惡魔。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":603673,"adult":false,"title":"Laxmii","video":false,"overview":"Aasif's belief in logic and science shatters when he gets possessed by a transgender's ghost.","genre_ids":[27,35],"media_type":"movie","popularity":0.9969,"vote_count":55,"poster_path":"/6COHwokEERAjjvlmNF44Xg9BK1y.jpg","release_date":"2020-11-09","vote_average":4.345,"backdrop_path":"/hJHfqLvYPz9nMPEZamjifHiXZbr.jpg","original_title":"लक्ष्मी","original_language":"hi"},{"id":1339206,"adult":false,"title":"The Surrender","video":false,"overview":"A fraught mother-daughter relationship is put to a terrifying test when the family patriarch dies, and the grieving mother hires a mysterious stranger to bring her husband back from the dead.","genre_ids":[18,27],"media_type":"movie","popularity":2.8675,"vote_count":11,"poster_path":"/t45V9B1kSvwVpupWie1t9e1YWXe.jpg","release_date":"2025-11-06","vote_average":5.636,"backdrop_path":"/6prlDNn0CY5ZcxkP33GH5tIGOMd.jpg","original_title":"The Surrender","original_language":"en"},{"id":75074,"adult":false,"title":"Touchback","video":false,"overview":"A former hi