aspect_ratio":0.7,"vote_average":0},{"width":2000,"height":3000,"file_path":"/6a0WLwIonbT2lx5Wa2CItvnyAsC.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/hC1QdYR0ytoNb0YbWyj9gSC0Bdw.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1500,"height":2140,"file_path":"/sHNzusORhKftLO7g8bIFyFMJPow.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.701,"vote_average":0}],"backdrops":[{"width":1772,"height":997,"file_path":"/mctcKx0Co9qe821DQuAjhoH33lw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.777,"vote_average":3.334},{"width":1469,"height":827,"file_path":"/mJ4W7kmjdvmA93a3bVKlj7RnBxy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.776,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/9yFWXEzeugCxxiSyd46dZGiD6SX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/e1xlFBnmvwiQGVYavb9neJTVEdl.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/1K8Px1EOBIPYgQfF6jAtVDOHd7j.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/4qk1TGaoYzdY4Ab5FO6PdLS0GSM.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1851,"height":1041,"file_path":"/8wuUOUDGfQkVM8fEW6iVbXBxMZv.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":2048,"height":1152,"file_path":"/gMjjZCFhtxXdBZqVCkiHcrqwzOn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":2048,"height":1153,"file_path":"/tktmRVVTmHUaspFGHirEsdVfrB1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.776,"vote_average":1.75},{"width":2048,"height":1153,"file_path":"/9ZLR7TZPFi6GSZdsRjDks3GoHs3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.776,"vote_average":0.166},{"width":1600,"height":900,"file_path":"/mPxggaRLknZyFfsSMdEqHlby7mT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":2048,"height":1152,"file_path":"/jbGdLw59HTIw9AwoeuyOFzawRuz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/sbapK3MYzETh2PhN2EIvOf8aQvQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2048,"height":1152,"file_path":"/rmJXntsBO99fdo7W4uQk5xZ8pdk.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2048,"height":1152,"file_path":"/aeKYkeIgCRIJNejDmNQCiYx53sw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2048,"height":1152,"file_path":"/vum3mYFEikfYPDTQLoeBoBBrnbz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2000,"height":1123,"file_path":"/hqr9kx0bT8DGnR2WRRBfdCZUHOV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.781,"vote_average":0},{"width":2000,"height":1123,"file_path":"/xYiEDJrjQec1ND14GvttWjgJ9XR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.781,"vote_average":0}]},"enriched_at":"2026-02-26T03:45:51.392+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Assassination","runtime":140,"tagline":"The country falls. The operation begins.","homepage":"","overview":"In Japanese-occupied Korea, three freedom fighters are assigned a mission to assassinate a genocidal military leader and his top collaborator. But the plan goes completely awry amidst double-crossings, counter-assassinations, and a shocking revelation about one of the assassins' past."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":139,"tagline":"1933년 친일파 암살작전, 그들의 선택은 달랐다","homepage":"http://assassination.kr/","overview":"1933년 조국이 사라진 일제 강점기, 대한민국 임시정부는 일본 측에 노출되지 않은 세 명을 암살작전에 지목한다. 대한독립군 저격수 안옥윤, 신흥무관학교 출신 속사포, 폭탄 전문가 황덕삼이 바로 그들. 김구의 두터운 신임을 받는 임시정부 경무국 대장 염석진은 이들을 찾아 나서기 시작한다. 암살단의 타깃은 조선주둔군 사령관 카와구치 마모루와 친일파 강인국. 한편 의문의 누군가에게 거액의 의뢰를 받은 청부 살인업자 하와이 피스톨이 암살단의 뒤를 추격하는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"暗杀","runtime":0,"tagline":"暗杀","homepage":"","overview":"1933年，朝鲜半岛沦陷后，韩国临时政府要挑选三名秘密特工潜伏回朝鲜京城，执行刺杀朝鲜驻军司令官川口真守和卖国贼康寅国的特殊任务。临时政府警察局长廉硕晋（李政宰 饰）因此寻找到了朝鲜独立军狙击手安沃允（全智贤 饰）、新兴武官学校毕业生“速射炮”秋尚沃（赵震雄 饰）和爆破专家黄德三（崔德文 饰）。与此同时，日本驻上海司令部却收到了有关这次暗杀行动的密报。他们雇佣杀手夏威夷·手枪（河正宇 饰）和搭档波马德（吴达洙 饰）追杀刺客。为完成各自任务，独立军战士、临时政府专员和雇佣杀手的命运交织在了一起……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Assassination","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Amsal","runtime":0,"tagline":"","homepage":"","overview":"V roce 1933 je Korea okupována Japonskem. Prozatímní vláda je v exilu a existuje množství hnutí za svobodu, které se snaží svými činy oslabit Japonce a přispět tak k osvobození Koreje. Jedno z těchto hnutí sídlící v Šanghaji vysílá do Soulu tři své členy pod vedením An Ok-jun, aby spáchali atentát na japonského generála. Několik událostí však trojici bojovníků tento úkol značně zkomplikuje."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Assassination","runtime":140,"tagline":"O país cai. A operação começa.","homepage":"","overview":"Jeon Ji Hyun vive um franco-atirador que estava aguardando uma sentença de morte em Xangai, mas foi libertado por um agente secreto do governo, interpretado por Lee Jung Jae, famoso pelo filme The Face Reader. Eles iram unir forças com outros lutadores, incluindo um pistoleiro chamado Hawaii Pistol, interpretado pelo ator Ha Jung Woo, para lutar pela independência da Coréia."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Η Δολοφονία","runtime":140,"tagline":"","homepage":"","overview":"Η ταινία μας μεταφέρει στην Κορέα και τη Σανγκάη της δεκαετίας του 1930, κατά τη διάρκεια της Ιαπωνικής κατοχής. Η αντίσταση αναθέτει σε μια μυστική ομάδα πρακτόρων να δολοφονήσει όσους συνεργάζονται με τους κατακτητές."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Assassination","runtime":140,"tagline":"","homepage":"","overview":"Im Korea der frühen 30er entfalten japanische Besatzer ein Schreckensregiment. Viele passen sich an oder kollaborieren, einige wenige wagen den bewaffneten Widerstand und müssen sich dabei ständig vor Verrätern in den eigenen Reihen in Acht nehmen. Als die Partisanen erfahren, dass der höchste Offizier der japanischen Armee zur Inspektion herbei reist, aktiviert man die Scharfschützin Ahn Ok-yn im chinesischen Exil. Doch die muss erst einmal aus dem Gefängnis von Shanghai befreit werden. Ein Fall für den Agenten Yem Sek-jin..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Amsal","runtime":140,"tagline":"","homepage":"","overview":"In 1933 wordt Korea bezet door het Japanse leger. Veel leden van het verzet zijn gedwongen te vluchten naar China. Ze vernemen dat de hoogste commandant van het Japanse leger Korea zal bezoeken. Het verzet is van plan om hem te doden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"דרמת אקשן תקופתית המבוססת בקוריאה של שנות ה-30 ובעלילות המתנגדים לכיבוש היפני. הבמאי דונג-הון צ'ו זוכה לשבחים רבים על אפוס היסטורי מהסוג שהוליווד כבר חדלה מלעשות. הסרט מתפרש על פני שלוש תקופות זמן שונות, מלהטט בכשרון בין ז'אנרים ומריח כמו מעשה אהבה של ליאונה, שפילברג וג'ון וו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Zabójstwo","runtime":0,"tagline":"","homepage":"","overview":"Okupowana Korea. Ruch oporu planuje zamach na japońskiego dowódce, ale akcja jest zagrożona, ponieważ w powstańczych szeregach ukrył się zdrajca."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Asesinos","runtime":140,"tagline":"El país cae. Comienza la operación.","homepage":"","overview":"1933. Corea está ocupada por los japoneses. Un grupo de exiliados rebeldes planea matar a un comandante nipón, pero la única asesina que puede hacerse cargo de tan delicada tarea está en la cárcel. La resistencia se dispone a sacarla de prisión, cuando un espía alerta a los japoneses, acelerando un entramado de traiciones."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Assassination","runtime":140,"tagline":"Le pays tombe. L'opération commence.","homepage":"","overview":"En 1933, la Corée vit sous l’occupation japonaise. Le gouvernement provisoire coréen demande à Yeom, personnalité de la résistance, de recruter trois mercenaires qui auront pour objectif d’éliminer deux figures importantes de l’Occupation. Mais certains préfèreraient voir cet assassinat échouer, et engagent Hawaï Pistol, tueur à gages redoutable, pour supprimer les trois assassins avant qu’ils n’accomplissent leur mission."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"A bérgyilkosság","runtime":0,"tagline":"","homepage":"","overview":"Mesterlövészekből, zsoldosokból és kettős ügynökből álló csapat lázadó azt tervezi, hogy rajtaüt a hadsereg parancsnokán a japánok által megszállt Koreában, de az egyetlen, aki véghez tudná vinni a merényletet, börtönben ül. A lázadók megszöktetik őt a fogságból, azonban áruló van a soraik között..."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Assassinato","runtime":140,"tagline":"O país cai. A operação começa.","homepage":"","overview":"Nos anos 1930, dominada pelo Japão, a Coréia possui grupos de resistência. Yeom Seok-jin é o capitão de um desses grupos, que planeja assassinar o governador Kang In Guk, apoiador dos japoneses. Para isso, Yeom seleciona o sniper de elite An Ok-yun, que estava aguardando uma sentença de morte em Xangai, mas foi libertado."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Suikast","runtime":140,"tagline":"","homepage":"","overview":"Film 1900'lü yılların başlarında Kore - Japon işgali sırasında bir çok Kore'li aktivistin Japon yetkililerden saklanarak Çin'de yaptıkları suikast planlarına dayanıyor. Yıl 1933 Shanghai, birinci sınıf keskin nişancı Ahn Ok Yun (Jun Ji Hyun) Japon ordusunun komutanına suikast düzenlemek için komut alır. Bu sırada Kore geçici hükümet ajanı olan Yeom Seok Jin (Lee Jung Jae) hapishanede olan yoldaşlarını da kurtarmak için Ahn Ok Yun'la birlikte planlar yapmaktadır. Ama bu büyük plan Japonlar tarafından öğrenilir ve grubun içine Ahn Ok Yun'u öldürmesi için bir casus aynı zamanda bir tetikçi olan Hawaii Pistol (Ha Jung Woo) yerleştirilir. Peşinde ki tetikçiden habersiz Ahn Ok Yun bu görevi başarıyla tamamlayabilecek midir?"},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Assassination","runtime":140,"tagline":"","homepage":"","overview":"Året är 1933 och Japan har Sydkorea i ett järngrepp. Frihetskämpar planerar ett mord på en högt rankad japansk officer, men en förrädare på insidan ihop med konstant tryck från den japanska militären gör att saker blir allt farligare."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"暗殺","runtime":140,"tagline":"一個任務 三種抉擇？ 失去生命也無所畏懼","homepage":"","overview":"1933年朝鮮半島淪陷，落入日軍統治之手，國家動盪紛亂之際，描述一群獨立反抗軍、臨時政府特務和殺手，來自四面八方卻因一暗殺親日派任務集結於上海。全智賢飾演「安沃允」為率領整起暗殺行動的關鍵人物，同時也是獨立軍狙擊手；李政宰飾演大韓民國臨時政府特務「廉碩晉」；河正宇則飾演只要支付佣金即可執行刺殺任務的殺手「夏威夷」。各自為了執行自己的任務，命運就此交纏…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"復國者聯盟","runtime":0,"tagline":"","homepage":"","overview":"二戰期間被日兵佔領的朝鮮，大批抗日特工其中包括廉碩晉（李政宰 飾演）窩藏中國密謀刺殺計劃，更從上海監獄救出判了死刑的頂尖狙擊手安沃允（全智賢 飾演）與她的戰友，並委託她們進行特別任務。可惜計劃被內奸洩露了，日軍更隨即派出殺手（河正宇 飾演）暗地裏反刺殺沃允. . . 最終究竟誰負誰勝？情節緊張刺激，場景奢華宏大，全智賢與《盜賊門》導演崔東勳再度驚世合作，炮製出引人入勝的犯罪動作片。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Убийство","runtime":139,"tagline":"","homepage":"","overview":"В 1933 году борцы за независимость Кореи планируют убийство важных лиц японской администрации — губернатора Кёнсона Мамору Кавагути и прояпонского магната Кан Ин-гука. Агент сопротивления Ём Сок-чин поручает миссию девушке-снайперу Ан Ог-юн, специалисту-подрывнику Хван Док-саму и Чу Сан-оку. Группа прибывает в Кёнсон, не зная, что один из них работает на японцев и нанял киллеров для устранения членов группы."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"暗殺","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Sứ Mệnh Truy Sát","runtime":0,"tagline":"","homepage":"","overview":"Phim với bối cảnh vào năm 1933 khi mà Hàn Quốc bị quân Nhật chiếm đóng, nhiều chiến binh phải sống lưu vong ở Trung quốc đại lục. Nhưng họ vẫn tổ chức khánh chiến từ xa. Một tin tình báo cho biết người chỉ huy tối cao của phát xít Nhật sẽ đến thăm Hàn Quốc, và họ lên kế hoạch ám sát anh chàng này, nhưng trong tổ chức thì thực hiện được bắn tỉa chỉ có  Ahn Ok-yun có thể làm được. Nhưng lúc này cô đang ở trong tù tại Thượng Hải, một kế hoạch đưa cô ra khỏi đó và thực hiện kế hoạch, nhưng trong đó lại có một kẻ phản bội. Giờ đây mục tiêu của họ không chỉ là phát xít."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"ยัยตัวร้าย สไนเปอร์","runtime":0,"tagline":"","homepage":"","overview":"\"เราต้องการใช้งานมือปืนในโซล ไปพาพวกเขามา\" ปี 1933 ในยุคที่มาตุภูมิล่มสลาย นักฆ่าสามคนของรัฐบาลชั่วคราวเกาหลี ที่ทางญี่ปุ่นไม่เคยเห็นหน้า อันอ๊กยูน (จอนจีฮยอน) สไนเปอร์กองทัพอิสระหน่วย 3 เสือปืนกล จบจากโรงเรียนนายร้อย ฮวังด๊อกซัม (ชเวด็อกมุน) มือระเบิดสังหาร ยอมซอกจิน (อี จองแจ) อธิบดีกรมตำรวจ และแล้วปฏิบัติการของพวกเขาได้เริ่มขึ้น"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Vražedný útok","runtime":0,"tagline":"","homepage":"","overview":"Akčný historický thriller, ktorého dej sa odohráva v roku 1933, keď bola Kórea okupovaná Japonskom."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Assassins","runtime":0,"tagline":"","homepage":"","overview":"Corea està ocupada pels japonesos. És l'any 1933 i les nombroses faccions coreanes que lluiten per recuperar la independència del país no es posen d'acord. Un grup de la resistència, però, planifica l'assassinat d'un comandant japonès i d'un empresari coreà considerat un traïdor. Alhora, un agent doble que passa informació als japonesos alertarà de la trama i contractarà dos sicaris perquè matin els membres de la missió. Un joc de traïcions i supervivència en què el passat reapareixerà amb tota la seva cruesa."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"მკვლელობა","runtime":0,"tagline":"","homepage":"","overview":"ფილმში მოქმედება 1930იანი წლების კორეაში და შანხაიში ვითარდება, როცა ისინი იაპონიის მიერ იყო ოკპირებული. მთავრობა ქმნის საიდუმლო დაქირავებული მკვლელების ჯგუფს რათა გადაჭრას პრობლემები ..."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"ترور","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"}],"reviews_tmdb":[{"id":"56b3854e9251415320000cde","url":"https://www.themoviedb.org/review/56b3854e9251415320000cde","author":"Reno","content":"$11","created_at":"2016-02-04T17:07:26.154Z","updated_at":"2024-05-16T15:18:28.250Z","author_details":{"name":"Reno","rating":8,"username":"Rangan","avatar_path":"/6ZpVUJzqXMzH35VprEtnX0sNI3.jpg"}}],"recommendations":[{"id":250650,"adult":false,"title":"Captivated: The Trials of Pamela Smart","video":false,"overview":"In an extraordinary and tragic American story, a small town murder becomes one of the highest profile cases of all time. From its historic role as the first televised trial to the many books and movies made about it, the film looks at the media’s enduring impact on the case.","genre_ids":[99],"media_type":"movie","popularity":0.1465,"vote_count":29,"poster_path":"/qMnJYok56Vz9NeiUV9pcvogTmkz.jpg","release_date":"2014-01-17","vote_average":6.1,"backdrop_path":"/p4GPRqLpwbwwX3EsiEPQNV4DCV6.jpg","original_title":"Captivated: The Trials of Pamela Smart","original_language":"en"},{"id":48192,"adult":false,"title":"Sorum","video":false,"overview":"A young man moves into a run-down apartment building and soon gets into a relationship with a neighbor. Both the characters and the building have traumatic histories, and over time the ghosts of their past come to light.","genre_ids":[27,18,53],"media_type":"movie","popularity":0.5012,"vote_count":40,"poster_path":"/35SRY5NbciKKjqhLZ3edHW0QkVr.jpg","release_date":"2001-08-04","vote_average":5.6,"backdrop_path":"/jRGkZInhVUiPyixTHeyBcKVHEnh.jpg","original_title":"소름","original_language":"ko"},{"id":369443,"adult":false,"title":"Fatal Intuition","video":false,"overview":"Desperate for revenge, a young man enlists the aid of a medium to help him track down his sister's killer.","genre_ids":[53,80],"media_type":"movie","popularity":1.5464,"vote_count":38,"poster_path":"/rHbamrUbEkTv3cB7zNvSnmWzO6V.jpg","release_date":"2015-10-28","vote_average":5.684,"backdrop_path":"/eDC81zgFf5akn2sB2MoWwSlZ07I.jpg","original_title":"그놈이다","original_language":"ko"},{"id":315509,"adult":false,"title":"Helios","video":false,"overview":"Wanted criminal \"Helios\" and his assistant stole a quantity of uranium and plan to produce weapons of mass destruction. They are planning to trade with a terrorist organization in Hong Kong. Chief Inspector Lee Yinming and Inspector Fan Kaming lead the Counter Terrorism Response Unit of the Hong Kong Police Force. Along with a Chinese senior official, a physics professor, and two South Korean weapon experts, they hope to defuse a crisis sufficient to destroy the world.","genre_ids":[28,9648,12,53],"media_type":"movie","popularity":0.7726,"vote_count":62,"poster_path":"/wIL0ggdzO1Y7kOMEZIUV1XzvJ92.jpg","release_date":"2015-04-30","vote_average":5.2,"backdrop_path":"/rxv2tw69MlXqGh4UyH6r5CTZKRi.jpg","original_title":"赤道","original_language":"cn"},{"id":241375,"adult":false,"title":"7 Assassins","video":false,"overview":"When social unrest plagues a Kingdom in ancient China, the Imperial Court collects stockpiles of gold from local governments to expand the royal army. However, the gold is robbed while in transport. In a desperate move to retrieve the stolen treasure, elite royal guards are sent on a mission to go after the gold but soon find out they are not the only ones in pursuit of it.","genre_ids":[18,28,53,36],"media_type":"movie","popularity":0.742,"vote_count":12,"poster_path":"/nSglRjCNh6BIYZ0HPlN5QKRquzf.jpg","release_date":"2013-06-09","vote_average":4.833,"backdrop_path":"/4mC2NBCI9d6HJbdudS0Ix0kU9ej.jpg","original_title":"光辉岁月","original_language":"zh"},{"id":278558,"adult":false,"title":"Danger Dolls","video":false,"overview":"A quartet of cute idol singers moonlight as butt-kicking action heroines. When extraterrestrial invaders threaten the safety of the Earth, after an earthquake unleashes them from an alternate dimension, the Danger Dolls become humanity's only hope for survival. The team infiltrates the evil cult behind the invasion and must use their swords and their fists to smash the invading army.","genre_ids":[878,28],"media_type":"movie","popularity":0.2799,"vote_count":6,"poster_path":"/wPo2ypQl2oPic0tKoFlqq0QbRRx.jpg","release_date":"2014-07-11","vote_average":5.9,"backdrop_path":null,"original_title":"少女は異世界で戦った","original_language":"ja"},{"id":355953,"adult":false,"title":"Nezha","video":false,"overview":"Li Xiaolu, 16, meets the bookish student of the class, Wang Xiaobing. They become best friends. During their short period of friendship, they read Sanmao, and discover the most beautiful places in Baocheng - the orchard and the riverbank. However, over time they become less close. Serious differences lead to their separation. In the summer holidays after the college entrance exams are over, Xiaobing comes to see Xiaolu for the last time. As memorable as their first encounter, the friends who have not met for two years reconcile on this day.","genre_ids":[18],"media_type":"movie","popularity":0.2249,"vote_count":6,"poster_path":"/fnJ7cMrMDnQXOUuxHs1nw0W1f8P.jpg","release_date":"2014-10-05","vote_average":6.1,"backdrop_path":null,"original_title":"少女哪吒","original_language":"zh"},{"id":853315,"adult":false,"title":"Adultery Alumni Association 3","video":false,"overview":"Yeon-woo is reunited with her first love, Yoon-jeong, at a reunion after returning from America. While her husband is on a business trip, Yoon Jeong-eun calls Yeon-woo to her house and has sex. Yoon-jeong's husband, Jun-hyeok, finds another man's hair in the bed and visits Yeon-woo to warn him. Yoon-jung comes to Yeon-woo with a complicated heart. The two have sex once again and confirm their love...","genre_ids":[18,10749],"media_type":"movie","popularity":2.6747,"vote_count":13,"poster_path":"/azNqGqZEKKHJ2z8iOoMszQLPLBT.jpg","release_date":"2020-11-09","vote_average":7.269,"backdrop_path":"/2LqkxEi0YenHbIMmiupcv0q1qBw.jpg","original_title":"불륜 동창회3","original_language":"ko"},{"id":18426,"adult":false,"title":"Daisy","video":false,"overview":"A painter in Amsterdam receives flowers from a mysterious admirer, while a hitman and cop find themselves in conflict.","genre_ids":[18,10749,28],"media_type":"movie","popularity":0.8668,"vote_count":101,"poster_path":"/twmYZWjyrHm0fhJnPxHcC4XtrA3.jpg","release_date":"2006-03-09","vote_average":7.1,"backdrop_path":"/4NTM2UfehhQueBQd06DCzzHMW5i.jpg","original_title":"데이지","original_language":"ko"},{"id":27644,"adult":false,"title":"Ride Lonesome","video":false,"overview":"On the way to pick up the bounty on a wanted murderer, a bounty hunter stops at a staging post where he is forced to continue his journey with two outlaws who want the murderer for their own reasons and a recently-widowed woman, with the murderer's brother and his men in hot pursuit.","genre_ids":[37],"media_type":"movie","popularity":0.5302,"vote_count":155,"poster_path":"/4fQW6hAFW0YrQXrDUaMweNI1SgQ.jpg","release_date":"1959-02-01","vote_average":6.7,"backdrop_path":"/5UiC1NvHMH4YVCc88hSwrfZRSSl.jpg","original_title":"Ride Lonesome","original_language":"en"},{"id":572637,"adult":false,"title":"Asphalt Goddess","video":false,"overview":"Max returns to her slum turned into the vocalist of a rock band. There, the memories await, the latest news and the truths that were silent for years: Sonia is a voice that speaks from the death.","genre_ids":[18],"media_type":"movie","popularity":0.0943,"vote_count":41,"poster_path":"/wDn3JtWeqHYAWmKEKx8oJB5ItnO.jpg","release_date":"2020-10-31","vote_average":6.7,"backdrop_path":"/p4jG57vkjRo7HYT9FpaUNsk4Eos.jpg","original_title":"La diosa del asfalto","original_language":"es"},{"id":544627,"adult":false,"title":"Dark Figure of Crime","video":false,"overview":"A serial killer is caught for his seventh murder. A cop tries to solve the first six cases with the killer's help, but starts to suspect that he has ulterior motives. Based on a true story.","genre_ids":[80,18],"media_type":"movie","popularity":0.7018,"vote_count":90,"poster_path":"/uWislqbyIFvR02uN4n20zjDnAm2.jpg","release_date":"2018-10-03","vote_average":6.589,"backdrop_path":"/9p0vq4f44SioluXmb6JhuS3Gi6t.jpg","original_title":"암수살인","original_language":"ko"},{"id":348689,"adult":false,"title":"Memories of the Sword","video":false,"overview":"While in medieval Korea, a young girl sets out to revenge the betrayal and the death of her mother. But therefore she must face one of the most powerful men and warriors of the Goryeo Dynasty.","genre_ids":[18,36,28],"media_type":"movie","popularity":0.62,"vote_count":105,"poster_path":"/dqf7fnJXoPvKdVD33w4KYl3qB55.jpg","release_date":"2015-08-13","vote_average":6.605,"backdrop_path":"/e50DTFe9hOgCEDfinYkAhZojoU.jpg","original_title":"협녀, 칼의 기억","original_language":"ko"},{"id":79374,"adult":false,"title":"Blind","video":false,"overview":"A blind witness and a runaway help the police find the suspect in a hit and run until the culprit realizes that they are close on his trail. The killer tracks her down and Soo-ah realizes that in order to save Gi-sub she would have to risk her life.","genre_ids":[53],"media_type":"movie","popularity":0.6432,"vote_count":135,"poster_path":"/mAfgDfAXCXcj5lPR5DUeezFrTGA.jpg","release_date":"2011-08-10","vote_average":7.315,"backdrop_path":"/y5VVRsulUlskqElCV6SVQ26fFYR.jpg","original_title":"블라인드","original_language":"ko"},{"id":220176,"adult":false,"title":"The Face Reader","video":false,"overview":"An exceptionally talented face reader becomes entangled in a bloody power struggle between a child king and his uncle who plans to usurp the throne.","genre_ids":[18,36],"media_type":"movie","popularity":1.9625,"vote_count":103,"poster_path":"/hYBj2NWvYp0JoiOb4MMdD6MDCFz.jpg","release_date":"2013-09-11","vote_average":6.971,"backdrop_path":"/srQeYfvA7BEUjV3YC5VNaY90vDH.jpg","original_tit