9:{"metadata":[["$","title","0",{"children":"Mission: Impossible - The Final Reckoning | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Ethan Hunt and team continue their search for the terrifying AI known as the Entity — which has infiltrated intelligence networks all over the globe — with the world's governments and a mysterious ghost from Hunt's past on their trail. Joined by new allies and armed with the means to shut the Entity down for good, Hunt is in a race against time to prevent the world as we know it from changing forever."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/100600/mission-impossible-the-final-reckoning"}],["$","meta","5",{"property":"og:title","content":"Mission: Impossible - The Final Reckoning"}],["$","meta","6",{"property":"og:description","content":"Ethan Hunt and team continue their search for the terrifying AI known as the Entity — which has infiltrated intelligence networks all over the globe — with the world's governments and a mysterious ghost from Hunt's past on their trail. Joined by new allies and armed with the means to shut the Entity down for good, Hunt is in a race against time to prevent the world as we know it from changing forever."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/100600/mission-impossible-the-final-reckoning"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/z53D72EAOxGRqdr7KXXWp9dJiDe.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Mission: Impossible - The Final Reckoning"}],["$","meta","12",{"name":"twitter:description","content":"Ethan Hunt and team 