},{"width":1000,"height":1500,"file_path":"/yDdiRJ6h4zEFYyZikVviSNX2bel.jpg","iso_639_1":"es","iso_3166_1":"MX","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/mHglxM0wjfuc5hmVrz7sVykBLrG.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/yi513H1wMeb8nE0sbriqfnrD8SG.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/eICs7S3L8jXO1BYxwcGebpKV50R.jpg","iso_639_1":"es","iso_3166_1":"MX","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":600,"height":900,"file_path":"/qa6LFAQYINCorK5uu5whUhxsHau.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":810,"height":1080,"file_path":"/wGGsqxugZSQPgAPzQPMcsntEVi4.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.75,"vote_average":0},{"width":2000,"height":3000,"file_path":"/taMMxgN8SEvuAYAAdpG0v3BtKv5.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":700,"height":1000,"file_path":"/brW4VBsV2kZtozO0EIoFGdYkf50.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":900,"height":1283,"file_path":"/AwCEOi2M5HLoT2G5HSwvo9bnUbF.jpg","iso_639_1":"ko","iso_3166_1":"KR","vote_count":0,"aspect_ratio":0.701,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/i1Aa25l2TtKwp528wM5g2MK4ER6.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/yvfde7RZROxOKDf1HkUManEe12s.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1908,"height":1073,"file_path":"/u7Ae9HhaK8yvN4eOTEXuySKek3K.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":2613,"height":1470,"file_path":"/7DpleF0PRfVLEm23AWkpanwpYnO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1908,"height":1073,"file_path":"/wgfPqhU17LKderGvlxgwgluEANq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1908,"height":1073,"file_path":"/l3AVrqufRtm5aonH3GyOU8j2pIi.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1908,"height":1073,"file_path":"/7uxEovxxn7w0peJt2oR64ZecNQf.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1908,"height":1073,"file_path":"/t2orm8W7lrerxJQduzKy1pNffgu.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1908,"height":1073,"file_path":"/1zHwWz92fEhR2DcCj80RWCdc4m1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1908,"height":1073,"file_path":"/urrsQumiLaN3WZ43nf11IZC1dtr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1908,"height":1073,"file_path":"/rrMIWdBStS8bgexjUGsEbTvdLaY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1908,"height":1073,"file_path":"/uojhWfdIUQZLgZWdZ5LLY3vDqBz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1908,"height":1073,"file_path":"/9j0o9h6lDCutWQApzmMXKWd6AlV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1908,"height":1073,"file_path":"/lXEwelGQVrSSFHxdtBs7dnXyQ9Y.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1908,"height":1073,"file_path":"/vcSKSUm9ambhJ3Uj9eDz66mYp2j.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2560,"height":1440,"file_path":"/2Lwv9AIn94VgoTViCW08lpC96Ne.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2560,"height":1440,"file_path":"/9v7bG2npvVWYwwW2tuFuMOtRTi4.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/xvbW04sX3QvgdvTeg8KHl4C42QJ.jpg","iso_639_1":"he","iso_3166_1":"IL","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3200,"height":1800,"file_path":"/9DrKWSlxmUjjm0PJHVbneVQXPTA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/3PvqUMOGqwE0o37JgPBTT2Ja0F0.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/qkga99Wrz9HZGiVQ1KYcQ0Jx2ZX.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/9gnAkY82NvjkewDuUier5rDSH6b.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/9M9GORE4MskS7majdYPgv9D7ODS.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T03:37:58.369+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Dreams","runtime":98,"tagline":"","homepage":"https://dreams.film/","overview":"A powerful socialite and a promising ballet dancer begin a dangerous affair. When he secretly crosses the US-Mexico border, she takes desperate measures to protect their future together."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.imagemfilmeslatam.com/micrositio/dreams","overview":"El romance florece entre una acaudalada dama de la alta sociedad y un joven bailarín de ballet mexicano. Creyendo que su amante le apoyará, él cruza la frontera para perseguir sus sueños en San Francisco. Pero cuando la ambición y el amor chocan con la dura realidad, él debe enfrentarse a la verdadera naturaleza de su relación."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Dreams","runtime":0,"tagline":"Cosa sei disposto a fare per inseguire i tuoi sogni?","homepage":"","overview":"Fernando, giovane e talentuoso ballerino messicano, sogna il riconoscimento internazionale e una nuova vita negli Stati Uniti.  Convinto che Jennifer, una raffinata filantropa dell’alta società americana e sua amante, lo sosterrà nel realizzare le sue ambizioni, decide di lasciarsi tutto alle spalle e mette in pericolo la sua vita pur di inseguire il suo sogno. Ma il suo arrivo finisce per sconvolgere il mondo attentamente costruito da Jennifer. Disposta a tutto pur di proteggere il futuro di entrambi e tutto ciò che ha costruito attorno a sé, Jennifer dovrà affrontare le conseguenze delle proprie scelte."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"드림스","runtime":99,"tagline":"","homepage":"","overview":"멕시코 출신의 젊고 매력적인 무용수 ‘페르난도’는 성공한 자선사업가이자 연인인 미국인 ‘제니퍼’와 함께할 아메리칸 드림을 꿈꾸며 불법 입국을 감행한다. 그러나, 제니퍼는 미국 상류사회에서 자신의 자리를 지키기 위해 페르난도와 연인임을 숨기게 되고, 두 사람 사이에 서서히 균열이 생기기 시작하는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Dreams","runtime":0,"tagline":"","homepage":"","overview":"In de overtuiging dat zijn geliefde hem zal steunen, steekt een jonge Mexicaanse balletdanser de grens over om zijn dromen na te jagen in San Francisco. Maar terwijl ambitie en liefde botsen met de harde realiteit, moet hij de ware aard van hun relatie onder ogen zien."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Nebezpečné sny","runtime":0,"tagline":"Co všechno mohou milenci riskovat pro lásku?","homepage":"","overview":"Jennifer je vlivná žena v bohatém světě sanfranciské společenské smetánky. Její pečlivě vystavěný život se otřese, když do něj nečekaně vstoupí mladý, charismatický tanečník Fernando. Napětí vyplývající z rozdílů v postavení a zkušenostech jen umocňuje vzájemnou přitažlivost. Flirt se rychle mění v posedlost. Co všechno budou oba nepravděpodobní milenci ochotni riskovat?"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"חלומות","runtime":0,"tagline":"","homepage":"","overview":"פרננדו, רקדן בלט צעיר ממקסיקו, חולם על חיים בארצות הברית ותהילה בינלאומית. כשהוא פוגש את ג'ניפר – אשת חברה עשירה ופילנתרופית – הוא מאמין בכל ליבו שהיא זו שתעזור לו להגשים את החלום, ומחליט לברוח ממקסיקו לארה\"ב, למרות כל הסכנות הטמונות בדבר. אבל הגעתו לארה\"ב מערערת את עולמה המתוכנן בקפידה של ג'ניפר, והיא תעשה הכול על מנת להגן על עתידם המשותף – ובו זמנית על החיים שבנתה לעצמה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"İlişki","runtime":0,"tagline":"","homepage":"","overview":"Meksikalı genç bir bale dansçısı olan Fernando, dünya çapında tanınmanın ve ABD’de bir yaşamanın hayalini kurar. Sosyetik ve hayırsever bir kadın olan sevgilisi Jennifer’ın onu destekleyeceğine inanarak her şeyi geride bırakır; bu sırada ölümden kıl payı kurtulur. Ancak Fernando’nun gelişi, Jennifer’ın özenle inşa ettiği dünyayı altüst eder. Jennifer, hem kendi geleceğini hem de Fernando’nunkini korumak için her şeyi yapmaya hazırdır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Мечты","runtime":95,"tagline":"","homepage":"","overview":"Фернандо, молодой танцор из Мексики, стремится к признанию и мечтает о новой жизни в США. Уверенный, что его возлюбленная Дженнифер, состоятельная американка и филантроп, поможет осуществить мечты, он в тайне пересекает границу, рискуя жизнью. Фернандо разыскивает Дженнифер в Сан-Франциско, однако его появление мешает привычной жизни женщины, которая не готова появляться с любовником на публике."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Sonhos","runtime":98,"tagline":"","homepage":"https://imagemfilmes.com.br/filme/sonhos","overview":"Jennifer é uma influente socialite de São Francisco. Sua vida cuidadosamente construída entra em risco quando ela se envolve com Fernando, um jovem bailarino mexicano que sonha em atuar numa grande escola de balé. Impulsionado pelo amor e pela esperança de um recomeço, ele atravessa a fronteira para estar ao lado dela, uma decisão que ameaça desestabilizar o mundo que Jennifer tanto lutou para preservar. Determinada a manter seu império intacto, ela será capaz de tudo, mesmo que isso revele o lado mais obscuro desse romance."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Χαμένα Όνειρα","runtime":0,"tagline":"","homepage":"","overview":"Ο Fernando, ένας νεαρός Μεξικανός χορευτής μπαλέτου, φτάνει στις ΗΠΑ γεμάτος ελπίδες για μια νέα ζωή και μια διεθνή καριέρα. Πιστεύει ότι η Jennifer, μια πλούσια και ισχυρή γυναίκα, με φιλανθρωπικό έργο, θα τον στηρίξει. Όμως η εμφάνισή του ανατρέπει την ισορροπία της προσεκτικά χτισμένης ζωής της Jennifer και του αδερφού της Jake. Ο έρωτας, τα όνειρα και η πραγματικότητα συγκρούονται, αποκαλύπτοντας σκληρές αλήθειες για την κοινωνική τάξη, την εξουσία, τη μετανάστευση και την επιβίωση."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Dreams","runtime":95,"tagline":"","homepage":"","overview":"Fernando, un jeune danseur de ballet au Mexique, rêve de reconnaissance internationale et d'une vie aux États-Unis. Croyant que son amante, Jennifer, mondaine et philanthrope, le soutiendra, il laisse tout derrière - échappant étroitement à la mort dans le processus. Cependant, son arrivée perturbe le monde soigneusement organisé de Jennifer. Elle fera tout pour protéger à la fois leur avenir - et la vie qu'elle a construite."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Uždraustos svajos","runtime":95,"tagline":"","homepage":"","overview":"Kuomet Dženiferė pirmą kartą pamato Fernandą, ji net neįtaria, kaip stipriai susipins jų gyvenimai. Fernandas svajoja apie šokėjo karjerą, pripažinimą ir šlovę Amerikoje ir padarys viską, kad jo svajonė taptų realybe. Užsikrėtusi jo aistra, Dženiferė nutaria padėti jaunuoliui, o netrukus ir pati pajunta jam nevaldomą kūnišką aistrą.\r Patikėjęs savo turtingos meilužės pažadais, Fernandas nutaria rizikuoti ir atvyksta į Jungtines Valstijas nelegaliai. Deja, greitai paaiškėja, kad Dženiferė nepasiruošusi atsisakyti savo skrupulingai sutvarkyto, turtingo ir privilegijuoto gyvenimo vardan kelių malonumo akimirkų su jaunu talentingu meilužiu. Vis tik ji pasiruošusi padaryti viską, kad ir padėtų Fernandui. Tiesa, tik iki tam tikros ribos. Klausimas tik – kur toji riba bus nubrėžta?"},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Sapņi","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Dreams","runtime":0,"tagline":"","homepage":"","overview":"Pomiędzy zamożną kobietą a meksykańskim tancerzem baletu rozkwita romans, który splata ich kontrastujące życie i kultury."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"梦想","runtime":95,"tagline":"","homepage":"","overview":"Fernando是一位来自墨西哥的年轻芭蕾舞演员，他梦想着在美国获得国际声誉和生活。他相信他的恋人Jennifer（一位社交名媛和慈善家）会支持他，于是他抛弃了一切，在穿越边境时险些丧命。然而，他的到来打乱了Jennifer精心打造的世界。她愿意做任何事情来保护他们共同的未来—以及她为自己建立的生活。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"رویاها","runtime":0,"tagline":"","homepage":"","overview":"داستان زنی ثروتمند از کلاس بالا و یک رقصنده باله مکزیکی که عاشق یکدیگر می‌شوند و..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"夢想","runtime":0,"tagline":"","homepage":"","overview":"Fernando是一位來自墨西哥的年輕芭蕾舞演員，他夢想著在美國獲得國際聲譽和生活。他相信他的戀人Jennifer（一位社交名媛和慈善家）會支持他，於是他拋棄了一切，在穿越邊境時險些喪命。然而，他的到來打亂了Jennifer精心打造的世界。她願意做任何事情來保護他們共同的未來—以及她為自己建立的生活。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Sonhos","runtime":98,"tagline":"","homepage":"","overview":"Em Sonhos, Fernando (Isaac Hernández) é um bailarino profissional que opta por sair do México para ir atrás de seus sonhos nos Estados Unidos, acreditando na possibilidade de ser apoiado e auxiliado por Jennifer (Jessica Chastain), a socialite pela qual ele estava se apaixonando. Deportado do país, o dançarino passa dias de muito sofrimento ao aceitar atravessar a fronteira ilegalmente dentro de um caminhão passando fome, sede e calor. A rica mulher vive uma vida tranquila e luxuosa, sempre ajudando Fernando a treinar, dar aulas e até mesmo sobreviver financeiramente. No entanto, o casal enfrenta um grande drama por conta da diferença socioeconômica."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Мечти","runtime":0,"tagline":"","homepage":"","overview":"Фернандо е млад мексикански балетист, който мечтае за международно признание.  Той предприема опасно пътуване към САЩ с надеждата, че покровителката му Дженифър, богата филантропка, ще го подкрепи и ще му помогне да реализира таланта си.  Пристигането му обаче всява смут в добре организирания свят на Дженифър,  поставя на изпитание нейните убеждения и разкрива невидимата бариера между мечтата и реалността."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"}],"reviews_tmdb":[],"recommendations":[{"id":362800,"adult":false,"title":"Hannibal Before the Gates","video":false,"overview":"The scrappy 18-year-old daughter of a small-town prostitute storms the bastion of the rich and powerful in this drama set in the elite world of horse trials and show jumping. Sheer talent and an unbreakable bond with a temperamental thoroughbred may not be enough for Chara, who aspires to rise from stable hand to champion.. I","genre_ids":[18],"media_type":"movie","popularity":0.1563,"vote_count":16,"poster_path":"/4Cn3tP6BuwyEuKaq6zLJpTvGAIU.jpg","release_date":"2011-09-19","vote_average":6.3,"backdrop_path":"/bw4xQIYmhZXXOC2zx2ulhs6BGiJ.jpg","original_title":"Ο Αννίβας προ των Πυλών","original_language":"en"},{"id":248774,"adult":false,"title":"Obvious Child","video":false,"overview":"An immature, newly unemployed comic must navigate the murky waters of adulthood after her fling with a graduate student results in an unplanned pregnancy.","genre_ids":[35,10749],"media_type":"movie","popularity":1.7798,"vote_count":454,"poster_path":"/vAVuQuboHiqc6ClsFeWQXBHJkOX.jpg","release_date":"2014-06-06","vote_average":6.5,"backdrop_path":"/7DsPcLMbybqpl7nNMcwzPCM4VKG.jpg","original_title":"Obvious Child","original_language":"en"},{"id":387893,"adult":false,"title":"Ice Age: The Great Egg-Scapade","video":false,"overview":"A harried prehistoric bird mother entrusts her precious, soon-to-hatch egg to Sid. When she recommends him to her neighbours, business booms at his new egg-sitting service. However, dastardly pirate bunny, Squint, who is seeking revenge on the herd, steals, camouflages and hides all the eggs. Once again, with Squint’s twin brother assisting, Manny, Diego and the rest of the gang come to the rescue and take off on a daring mission that turns into the world’s first Easter egg hunt.","genre_ids":[12,16,35,10751,10770],"media_type":"movie","popularity":2.401,"vote_count":499,"poster_path":"/ysQqYp9G37Q114Nc6uvCHbDmaj6.jpg","release_date":"2016-03-19","vote_average":6.39,"backdrop_path":"/cwQ7IO6ZNBnlQ1b8zA7pXzkdT5S.jpg","original_title":"Ice Age: The Great Egg-Scapade","original_language":"en"},{"id":24160,"adult":false,"title":"My Friends Act II","video":false,"overview":"The four old friends meet on the grave of the fifth of them, Perozzi, who died at the end of the first episode. Time has passed but they are still up for adventures and cruel jokes, and while they recall the one they created together with the late friend, new ones are on their way, starting right there at the cemetery.","genre_ids":[35],"media_type":"movie","popularity":0.699,"vote_count":360,"poster_path":"/dCecKtLk2MOkFti5aYKu0WFe5BG.jpg","release_date":"1982-12-22","vote_average":7.632,"backdrop_path":"/AtaH2jdp845H6oK59bkLlf25XXC.jpg","original_title":"Amici miei - Atto II°","original_language":"it"},{"id":12092,"adult":false,"title":"Alice in Wonderland","video":false,"overview":"On a golden afternoon, wildly curious young Alice tumbles into the burrow and enters the merry, madcap world of Wonderland full of whimsical escapades.","genre_ids":[16,10751,14,12],"media_type":"movie","popularity":5.7913,"vote_count":6188,"poster_path":"/20cvfwfaFqNbe9Fc3VEHJuPRxmn.jpg","release_date":"1951-07-28","vote_average":7.188,"backdrop_path":"/tyj0QztA0PkYo6XauifWjkx7UVi.jpg","original_title":"Alice in Wonderland","original_language":"en"},{"id":4481,"adult":false,"title":"Manon of the Spring","video":false,"overview":"In this, the sequel to Jean de Florette, Manon has grown into a beautiful young shepherdess living in the idyllic Provencal countryside. She plots vengeance on the men who greedily conspired to acquire her father's land years earlier.","genre_ids":[18],"media_type":"movie","popularity":0.9857,"vote_count":554,"poster_path":"/1qpu6Zc1PSDL3UbDNIZJ6YuhJDW.jpg","release_date":"1986-11-19","vote_average":7.581,"backdrop_path":"/3ejcvnHxMFfCbnFi736cXi1ChH1.jpg","original_title":"Manon des sources","original_language":"fr"},{"id":283704,"adult":false,"title":"Leopardi","video":false,"overview":"In 19th-century Italy, Giacomo Leopardi channels his debilitating illness and isolation into poetry.","genre_ids":[18,36],"media_type":"movie","popularity":0.3917,"vote_count":667,"poster_path":"/hycSAhQhHEGGr3FppbdqFdAQd4O.jpg","release_date":"2014-10-16","vote_average":6.8,"backdrop_path":"/ppueqApDDVU6xuDEoCyZ6FEPhp9.jpg","original_title":"Il giovane favoloso","original_language":"it"},{"id":33475,"adult":false,"title":"Bud Abbott and Lou Costello Meet the Invisible Man","video":false,"overview":"As novice detectives, Bud and Lou come face to face with the Invisible Man.","genre_ids":[27,35,878],"media_type":"movie","popularity":1.0259,"vote_count":114,"poster_path":"/sGFnr4dCUm1Ro1bZHR5TXHOolXb.jpg","release_date":"1951-03-14","vote_average":6.313,"backdrop_path":"/5pXhfTMklUEKVtDt6EIUKcEqtSx.jpg","original_title":"Bud Abbott and Lou Costello Meet the Invisible Man","original_language":"en"},{"id":165,"adult":false,"title":"Back to the Future Part II","video":false,"overview":"Marty and Doc are at it again as the time-traveling duo head to 2015 to nip some McFly family woes in the bud. But things go awry thanks to bully Biff Tannen and a pesky sports almanac. In a last-ditch attempt to set things straight, Marty finds himself bound for 1955 and face to face with his teenage parents -- again.","genre_ids":[12,35,878],"media_type":"movie","popularity":7.6311,"vote_count":13690,"poster_path":"/YBawEsTkUZBDajKbd5LiHkmMGf.jpg","release_date":"1989-11-22","vote_average":7.775,"backdrop_path":"/w6tPctxWAsHoQXeKxxNOT6lYKpx.jpg","original_title":"Back to the Future Part II","original_language":"en"},{"id":49132,"adult":false,"title":"Boy","video":false,"overview":"Boy is the unsettling story of a young male prostitute, or Rent Boy, in a small rural town who learns the truth behind a hit and run accident which has killed a local girl. When the news of the girls death spreads through the community, the driver and his family decide that the boy must be silenced. The set out to scare him into silence. The pressure becomes more and more violent, but despite this, the boy battles to expose the truth.","genre_ids":[18],"media_type":"movie","popularity":0.6768,"vote_count":23,"poster_path":"/xqR2g50MJsDfrhfEYDaiV2sxgiI.jpg","release_date":"2004-10-14","vote_average":5.717,"backdrop_path":"/hAt7a1EKKqpikXo3ak4keMbZmoe.jpg","original_title":"Boy","original_language":"en"},{"id":72890,"adult":false,"title":"Girl Most Likely","video":false,"overview":"A failed New York playwright stages a suicide in an attempt to win back her ex, only to wind up in the custody of her gambling-addict mother.","genre_ids":[35],"media_type":"movie","popularity":0.6068,"vote_count":267,"poster_path":"/6chqhaNb2TwyaMeknbThUzziPWq.jpg","release_date":"2012-09-07","vote_average":5.6,"backdrop_path":"/nDPfwJChKbTi6m8mUinl8aV0St4.jpg","original_title":"Girl Most Likely","original_language":"en"},{"id":1058,"adult":false,"title":"Breathless","video":false,"overview":"Jesse, a small-time criminal, high-tails it to Los Angeles to rendezvous with a French exchange student. Stealing a car and accidentally killing a highway patrolman, he becomes the most wanted fugitive in L.A.","genre_ids":[10749,18,28],"media_type":"movie","popularity":1.2177,"vote_count":259,"poster_path":"/ipnsEbOsnQYO0HMrHTyqsO5osUV.jpg","release_date":"1983-05-13","vote_average":5.861,"backdrop_path":"/hlhRw9SldaaeFLHHTlatTu3DuBJ.jpg","original_title":"Breathless","original_language":"en"},{"id":11562,"adult":false,"title":"Crimes and Misdemeanors","video":false,"overview":"A renowned ophthalmologist is desperate to cut off an adulterous relationship…which ends up in murder; and a frustrated documentary filmmaker woos an attractive television producer while making a film about her insufferably self-centered boss.","genre_ids":[35,18,80],"media_type":"movie","popularity":1.5113,"vote_count":936,"poster_path":"/6vC6MLYUICH57MmEVi1UaNaj2Qs.jpg","release_date":"1989-10-13","vote_average":7.417,"backdrop_path":"/xDPaSuwaOizRNPitEvNiuY7i6iE.jpg","original_title":"Crimes and Misdemeanors","original_language":"en"},{"id":75571,"adult":false,"title":"Our War Game","video":false,"overview":"Spring break turns into a summer war when the evil Diaboromon wreaks havoc on the internet, and Tai and Matt must achieve a new Digivolution to defeat him! Will Tai and the Digidestined save the world, and will Sora ever forgive Tai for giving her a hair clip?","genre_ids":[12,16,28,878],"media_type":"movie","popularity":1.2624,"vote_count":67,"poster_path":"/rY7XzmfQgwMYJXAZSIChU5FLP7y.jpg","release_date":"2000-03-04","vote_average":8,"backdrop_path":"/9WS1AUI57GNpqYLqobaWjlio86S.jpg","original_title":"デジモンアドベンチャー ぼくらのウォーゲーム!","original_language":"ja"},{"id":244516,"adult":false,"title":"Indovina chi viene a Natale?","video":false,"overview":"A very extended family gathers for the Christmas holidays, after the death of the breadwinner Leonardo Sereni, famous singer. The eldest son Julius, with his wife Marina, has a panettone factory.","genre_ids":[35],"media_type":"movie","popularity":0.1403,"vote_count":369,"poster_path":"/rjQtWijw5jqJLf49cAjsZpalf4W.jpg","release_date":"2013-12-19","vote_average":5.607,"backdrop_path":"/bq2spDK7r7f7KELPKE2piDtqLHx.jpg","original_title":"Indovina chi viene a Natale?","original_language":"it"},{"id":13358,"adult":false,"title":"A Dennis the Menace Christmas","video":false,"overview":"A Dennis The Menace version of A Christmas Carol where Mr. Wilson plays his own version of Scrooge. While Dennis has problems of his own with the neighborhood bully, he does his best to try and give Mr. Wilson the Christmas Spirit. Dennis causes his usual damage and Mr. Wilson ends up breaking Dennis' spirit. An Angel of Christmas Past Present and Future steps in to help save Christmas for the Mitchells, the Wilsons, and everyone else.","genre_ids":[35,10751,14],"media_type":"movie","popularity":0.9932,"vote_count":107,"poster_path":"/cgjyUL2STLzjOGb3mXePXpNNC1O.jpg","release_date":"2007-11-13","vote_average":5.551,"backdrop_path":"/eCHTvzQVj7D7XQjdFh3NxKl9094.jpg","original_title":"A Dennis the Menace Christmas","original_language":"en"},{"id":13679,"adult":false,"title":"Kirikou and the Wild Beasts","video":false,"overview":"Kirikou's Grandfather says that the story of Kirikou and The Witch was too short, so he proceeds to explain more about Kirikou's accomplishments. We find out how little boy became a gardener, a detective, a maker of pottery, a merchant, a traveler and a doctor.","genre_ids":[12,16,10751,14],"media_type":"movie","popularity":0.7106,"vote_count":316,"poster_path":"/yPWBxCxwMbwdvwcXagHNOPWrCig.jpg","release_date":"2005-12-07","vote_average":6.4,"backdrop_path":"/ggDcngtIQVXMQAsK0ucYbmi59Bv.jpg","original_title":"Kirikou et les bêtes sauvages","original_language":"fr"},{"id":42322,"adult":false,"title":"Tarek's Situation","video":false,"overview":"Tarek is a young man who is working at a telecommunications company,and he fell in love with a girl when he heard her voice in a radio talk show. A customer of the company he works at asks him to spy on a girl which stole a valuable thing from him. When Tarek does his searches, he discovers that she is the girl he have dreamed about.","genre_ids":[10749,35],"media_type":"movie","popularity":0.7488,"vote_count":59,"poster_path":"/twE4XKly7N8KNpTm5nIKsYwPEyX.jpg","release_date":"2006-01-03","vote_average":6.966,"backdrop_path":"/efHg4fTpRwd6Wk0N64ogcsYeHsI.jpg","original_title":"ظرف طارق","original_language":"ar"},{"id":25768,"adult":false,"title":"Steamboat Bill, Jr.","video":false,"overview":"The just-out-of-college, effete son of a no-nonsense steamboat captain comes to visit his father whom he's not seen since he was a child.","genre_ids":[35,10749],"media_type":"movie","popularity":0.692,"vote_count":382,"poster_path":"/zygJMsmXxeyDc1N67OCZc8xtq4I.jpg","release_date":"1928-05-09","vote_average":7.601,"backdrop_path":"/kmZjw9hbo8ErovofQvPB21HRyRf.jpg","original_title":"Steamboat Bill, Jr.","original_language":"en"},{"id":26954,"adult":false,"title":"Pu