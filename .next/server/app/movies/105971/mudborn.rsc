5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Mudborn\",\"description\":\"Xu Chuan, who works at a game company, accidentally brings home a broken clay doll from a haunted house while developing a new horror VR game. Unexpectedly, his pregnant wife, Mu Hua, a cultural relic restorer, develops an obsession with the doll and relentlessly tries to repair it. As strange things begin to happen in the house, Mu Hua's condition deteriorates, and Xu Chuan, at his wits' end, seeks help from a spiritual medium, A Sheng. Meanwhile, the horrifying secret hidden behind the clay doll begins to surface.\",\"image\":\"https://image.tmdb.org/t/p/w500/3epkiHj6FacptxIfRiDZFQXUyL7.jpg\",\"datePublished\":\"2025-10-09\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"TW\",\"inLanguage\":\"zh\",\"genre\":[\"Horror\",\"Thriller\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6,\"bestRating\":10,\"ratingCount\":1}}"}}],["$","$L10",null,{"initialDrama":{"id":"7fc91818-fa0a-433d-8635-672e630fcc2c","tmdb_id":1526650,"imdb_id":"tt38365045","content_type":"movie","title":"Mudborn","original_title":"泥娃娃","overview":"Xu Chuan, who works at a game company, accidentally brings home a broken clay doll from a haunted house while developing a new horror VR game. Unexpectedly, his pregnant wife, Mu Hua, a cultural relic restorer, develops an obsession with the doll and relentlessly tries to repair it. As strange things begin to happen in the house, Mu Hua's condition deteriorates, and Xu Chuan, at his wits' end, seeks help from a spiritual medium, A Sheng. Meanwhile, the horrifying secret hidden behind the clay doll begins to surface.","poster_path":"/3epkiHj6FacptxIfRiDZFQXUyL7.jpg","backdrop_path":"/3okjpK0zn4LGkXXdfPS7WKzcyve.jpg","release_date":"2025-10-09","first_air_date":null,"status":"published","original_language":"zh","origin_country":["TW"],"genres":[{"id":27,"name":"Horror"},{"id":53,"name":"Thriller"}],"popularity":4.4094,"vote_average":6,"vote_count":1,"runtime":111,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:50:11.759913+00:00","updated_at":"2026-02-21T07:46:05.355+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":165242,"name":"Gift Pictures","logo_path":null,"origin_country":"TW"}],"production_countries":[{"name":"Taiwan","iso_3166_1":"TW"}],"spoken_languages":[{"name":"普通话","iso_639_1":"zh","english_name":"Mandarin"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[],"alternative_titles":[],"videos":[{"id":"6971000d0b7142517908da5e","key":"I--CxbFKzPA","name":"泥娃娃 ｜ Mudborn | Official Trailer | 正式预告片","site":"YouTube","size":1080,"type":"Trailer","official":true,"iso_639_1":"en","iso_3166_1":"US","published_at":"2025-11-07T14:06:00.000Z"}],"watch_providers":{"results":{}},"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/3epkiHj6FacptxIfRiDZFQXUyL7.jpg","images":{"logos":[],"posters":[{"width":2000,"height":3000,"file_path":"/3epkiHj6FacptxIfRiDZFQXUyL7.jpg","iso_639_1":"zh","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/iZEeNOrqWOMP8jD413kP5xw1PH9.jpg","iso_639_1":"zh","vote_average":0.166},{"width":1067,"height":1600,"file_path":"/vRDSA6IxveyVyxg5jp2unovq8d.jpg","iso_639_1":"zh","vote_average":0}],"backdrops":[{"width":1760,"height":990,"file_path":"/uM1fPVSxpcOGPbR1dofRLdrF9pL.jpg","iso_639_1":"zh","vote_average":0},{"width":3000,"height":1688,"file_path":"/3okjpK0zn4LGkXXdfPS7WKzcyve.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T07:55:24.219+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"在遊戲公司工作的旭川（楊祐寧 飾），為開發一項新的恐怖VR遊戲，意外將一尊來自凶宅現場的殘破泥娃娃帶回家，沒想到懷有身孕、身為文物修護師的妻子慕華（蔡思韵 飾）對其產生異常執念，不斷進行修復。隨著家中怪事頻傳，慕華狀態也越來越虛弱，旭川無計可施，輾轉求助通靈驅魔人阿生（張軒睿 飾），而泥娃娃背後深埋的駭人祕密，也隨之浮出水面⋯⋯"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Mudborn","runtime":111,"tagline":"","homepage":"","overview":"Xu Chuan, who works at a game company, accidentally brings home a broken clay doll from a haunted house while developing a new horror VR game. Unexpectedly, his pregnant wife, Mu Hua, a cultural relic restorer, develops an obsession with the doll and relentlessly tries to repair it. As strange things begin to happen in the house, Mu Hua's condition deteriorates, and Xu Chuan, at his wits' end, seeks help from a spiritual medium, A Sheng. Meanwhile, the horrifying secret hidden behind the clay doll begins to surface."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"泥娃娃","runtime":0,"tagline":"","homepage":"","overview":"在遊戲公司工作的旭川（楊祐寧 飾），為開發一項新的恐怖 VR 遊戲，意外將一尊來自兇宅現場的殘破泥娃娃帶回家，沒想到懷有身孕、身為文物修護師的妻子慕華（蔡思韻 飾）對其產生異常執念，不斷進行修復。隨著家中怪事頻傳，慕華狀態也越來越虛弱，旭川無計可施，輾轉求助通靈驅魔人阿生（張軒睿 飾），而泥娃娃背後深埋的駭人秘密，也隨之浮出水面⋯⋯"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"หุ่นดินผี","runtime":0,"tagline":"","homepage":"","overview":"ความมุ่งมั่นของนักออกแบบวิดีโอเกมคนหนึ่งต้องถูกทดสอบ เมื่อวิญญาณลึกลับได้แฝงตัวเข้ามาอยู่ในครอบครัวใหม่ของเขา และได้กลายมาเป็นภัยของว่าที่ภรรยาของเขา"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[],"external_ids":{"imdb_id":"tt38365045","twitter_id":null,"facebook_id":"Mudborn2025","wikidata_id":null,"instagram_id":"Mudborn2025"},"social_ids":{"twitter":null,"facebook":"Mudborn2025","instagram":"Mudborn2025"},"gdvg_id":105971,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki