5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Red Cliff\",\"description\":\"In 208 A.D., in the final days of the Han Dynasty, shrewd Prime Minster Cao convinced the fickle Emperor Han the only way to unite all of China was to declare war on the kingdoms of Xu in the west and East Wu in the south. Thus began a military campaign of unprecedented scale. Left with no other hope for survival, the kingdoms of Xu and East Wu formed an unlikely alliance.\",\"image\":\"https://image.tmdb.org/t/p/w500/eEelFTjUYJJDlwqd53VfSA8xMfj.jpg\",\"datePublished\":\"2008-07-10\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"film based on a novel\",\"historical film\",\"action film\",\"Adventure\",\"Drama\",\"History\",\"Action\",\"War\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.113,\"bestRating\":10,\"ratingCount\":871}}"}}],["$","$L10",null,{"initialDrama":{"id":"7e7d7fd2-ff32-4ce4-bd3e-26156b98fd5e","tmdb_id":12289,"imdb_id":"tt0425637","content_type":"movie","title":"Red Cliff","original_title":"赤壁","overview":"In 208 A.D., in the final days of the Han Dynasty, shrewd Prime Minster Cao convinced the fickle Emperor Han the only way to unite all of China was to declare war on the kingdoms of Xu in the west and East Wu in the south. Thus began a military campaign of unprecedented scale. Left with no other hope for survival, the kingdoms of Xu and East Wu formed an unlikely alliance.","poster_path":"/eEelFTjUYJJDlwqd53VfSA8xMfj.jpg","backdrop_path":"/pkcW3uu862e41ol1JXEVP4RSo0N.jpg","release_date":"2008-07-10","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"name":"film based on a novel"},{"name":"historical film"},{"name":"action film"},{"id":12,"name":"Adventure"},{"id":18,"name":"Drama"},{"id":36,"name":"History"},{"id":28,"name":"Action"},{"id":10752,"