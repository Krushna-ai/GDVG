9:{"metadata":[["$","title","0",{"children":"Steam: The Turkish Bath | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Francesco and Marta run a husband-and-wife design company in Rome. When Francesco's aunt dies in Istanbul he travels there to sort out the hamam Turkish steam bath that she left him. He finds a love and warmth in his relatives' Istanbul home that is missing from his life in Italy."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/103126/steam-the-turkish-bath"}],["$","meta","5",{"property":"og:title","content":"Steam: The Turkish Bath"}],["$","meta","6",{"property":"og:description","content":"Francesco and Marta run a husband-and-wife design company in Rome. When Francesco's aunt dies in Istanbul he travels there to sort out the hamam Turkish steam bath that she left him. He finds a love and warmth in his relatives' Istanbul home that is missing from his life in Italy."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/103126/steam-the-turkish-bath"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/a1c3p8qvTXf3Eue9QNzq1kVG5MM.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Steam: The Turkish Bath"}],["$","meta","12",{"name":"twitter:description","content":"Francesco and Marta run a husband-and-wife design company in Rome. When Francesco's aunt dies in Istanbul he travels there to sort out the hamam Turkish steam bath that she left him. He finds a love and warmth in his relatives' Istanbul home that is missing from his life in Italy."}],["$","meta","13",{"name":"twitter:image","content":"https://image.t