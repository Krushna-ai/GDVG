null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/4oJMTW7iFz9btq98JN9KwiNtlgv.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/wAbUXWqBx469UJ1wCqXmCRtPmCg.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/6ZyQEZaDY2e9RKfEQy9HIfPZt9F.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/lkr5eteYzSTOt8pefAPEnwddlN9.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/fOcCagsLSJ4U2u82e6FebXDO8B4.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/fjs1g47Fh6EzxgmT1wAl7HyFU52.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T04:12:20.732+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":76,"tagline":"","homepage":"","overview":"Em busca de uma história de aventura na floresta, um grupo de estudantes de jornalismo desperta um ser sobre-humano de sua câmara criogênica perdida. Segue-se uma longa noite de caça ao homem e desespero."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Nazi Supersoldier","runtime":78,"tagline":"They awakened a monster.","homepage":"","overview":"A group of journalism students ventures into a remote forest and awakens a long-frozen World War II experiment a superhuman Nazi soldier. Hunted through cursed woods where trust crumbles and survival is slim, they soon learn that some sins demand blood."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Erbsünde - Veil of Sin","runtime":0,"tagline":"","homepage":"","overview":"Eine Gruppe von Journalismusstudenten wagt sich in einen abgelegenen Wald und erweckt ein seit langem eingefrorenes Experiment aus dem Zweiten Weltkrieg: einen übermenschlichen Nazi-Soldaten. Gejagt durch verfluchte Wälder, in denen Vertrauen zerbricht und das Überleben gering ist, lernen sie bald, dass manche Sünden Blut fordern."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Nazi Supelsodier","runtime":0,"tagline":"","homepage":"","overview":"Un grupo de estudiantes de periodismo, que buscan una historia de aventuras en el bosque, despiertan a un ser sobrehumano de su cámara criogénica perdida. Una larga noche de caza de hombres y sueños de desesperación."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":78,"tagline":"","homepage":"","overview":"En quête d'un sujet d'aventure dans les bois, un groupe d'étudiants en journalisme réveille un être surhumain de sa chambre cryogénique perdue. S'ensuit une longue nuit de traque et de désespoir."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[{"id":1654,"adult":false,"title":"The Dirty Dozen","video":false,"overview":"12 American military prisoners in World War II are ordered to infiltrate a well-guarded enemy château and kill the Nazi officers vacationing there. The soldiers, most of whom are facing death sentences for a variety of violent crimes, agree to the mission and the possible commuting of their sentences.","genre_ids":[28,12,10752],"popularity":3.8636,"vote_count":1288,"poster_path":"/tFWWsuhp22zJ6OG6QepJIiPUfeF.jpg","release_date":"1967-06-15","vote_average":7.579,"backdrop_path":"/iXS9Y5oMwbN9wKsVu7mNzsI7QSM.jpg","original_title":"The Dirty Dozen","original_language":"en"},{"id":1724,"adult":false,"title":"The Incredible Hulk","video":false,"overview":"Scientist Bruce Banner scours the planet for an antidote to the unbridled force of rage within him: the Hulk. But when the military masterminds who dream of exploiting his powers force him back to civilization, he finds himself coming face to face with a new, deadly foe.","genre_ids":[878,28,12],"popularity":10.6929,"vote_count":12500,"poster_path":"/gKzYx79y0AQTL4UAk1cBQJ3nvrm.jpg","release_date":"2008-06-12","vote_average":6.231,"backdrop_path":"/jPu8yiadqgzwFPGKJmGo637ASVP.jpg","original_title":"The Incredible Hulk","original_language":"en"},{"id":1771,"adult":false,"title":"Captain America: The First Avenger","video":false,"overview":"During World War II, Steve Rogers is a sickly man from Brooklyn who's transformed into super-soldier Captain America to aid in the war effort. Rogers must stop the Red Skull – Adolf Hitler's ruthless head of weaponry, and the leader of an organization that intends to use a mysterious device of untold powers for world domination.","genre_ids":[28,12,878],"popularity":7.3077,"vote_count":22477,"poster_path":"/vSNxAJTlD0r02V9sPYpOjqDZXUK.jpg","release_date":"2011-07-22","vote_average":7.004,"backdrop_path":"/yFuKvT4Vm3sKHdFY4eG6I4ldAnn.jpg","original_title":"Captain America: The First Avenger","original_language":"en"},{"id":1783,"adult":false,"title":"To End All Wars","video":false,"overview":"Based on a real-life story, this drama focuses on a small group of Allied soldiers in Burma who are held captive by the Japanese. Capt. Ernest Gordon, Lt. Jim Reardon and Maj. Ian Campbell are among the military officers kept imprisoned and routinely beaten and deprived of food. While Campbell wants to rebel and attempt an escape, Gordon tries to take a more stoic approach, an attitude that proves to be surprisingly resonant.","genre_ids":[18,10752,28],"popularity":1.3686,"vote_count":177,"poster_path":"/4fXRE02M2EckpGPZNbuZIo05dmL.jpg","release_date":"2001-09-02","vote_average":6.415,"backdrop_path":"/7ew2soLD1RY0PbHwhReqNUv08Wa.jpg","original_title":"To End All Wars","original_language":"en"},{"id":856290,"adult":false,"title":"After She Died","video":false,"overview":"A young woman is horrified to discover that her father's new girlfriend looks identical to her dead mother.","genre_ids":[27,9648,53],"popularity":0.1322,"vote_count":5,"poster_path":"/jwIDNrVV64l86RMapphoz0cz4qL.jpg","release_date":"2022-09-23","vote_average":6,"backdrop_path":"/iUHKLrKYcl8E1OniGUEUe1fSYyf.jpg","original_title":"After She Died","original_language":"en"},{"id":1933,"adult":false,"title":"The Others","video":false,"overview":"Grace is a religious woman who lives in an old house kept dark because her two children, Anne and Nicholas, have a rare sensitivity to light. When the family begins to suspect the house is haunted, Grace fights to protect her children at any cost in the face of strange events and disturbing visions.","genre_ids":[27,9648,53],"popularity":7.0107,"vote_count":7020,"poster_path":"/p8g1vlTvpM6nr2hMMiZ1fUlKF0D.jpg","release_date":"2001-08-02","vote_average":7.618,"backdrop_path":"/rbBe9WQ1OqCxzgwskOTnaY6JdUA.jpg","original_title":"The Others","original_language":"en"},{"id":5707,"adult":false,"title":"Shooting War","video":false,"overview":"A remarkable film that takes a special look at the first war to be truly reported and recorded by one of the more unsung heroes of World War II: the combat photographer. Through the unflinching eye of their camera's lenses, these courageous soldiers continually risked their lives in their brave attempts to capture history.","genre_ids":[99,28,10752,36],"popularity":0.6086,"vote_count":8,"poster_path":"/81XtyZfL5WFPJXVLUUQP9PQP6Hl.jpg","release_date":"2000-12-07","vote_average":5.9,"backdrop_path":null,"original_title":"Shooting War","original_language":"en"},{"id":1257780,"adult":false,"title":"Gentleman Caller","video":false,"overview":"Imogen Sayre is given an ultimatum by her publisher to write a sequel to her one best selling novel or not be signed to a new book deal. Imogen must overcome mental and supernatural forces to write this book and salvage her career.","genre_ids":[27],"popularity":0.2876,"vote_count":2,"poster_path":"/qhcswlNJa7s6pzTtPnyiiiFZE5E.jpg","release_date":"2024-03-11","vote_average":10,"backdrop_path":"/muCARsNYK9tPYxzN2rDk0v6msUp.jpg","original_title":"Gentleman Caller","original_language":"en"},{"id":468696,"adult":false,"title":"Suite 313","video":false,"overview":"Special Agent Alexander Connor is sent to investigate a house, from which a woman named Sandra has made numerous 911 calls. Things become more complicated than expected for Agent Connor, as he finds he must also rescue a police officer who responded to the home 24 hours earlier. Soon, Agent Connor will discover a horrifying secret; that Sandra is one of LUMEN CORPORATION's donors and has devoted her house to the corporation; a house which has been turned into a research lab for atrocious experiments performed on human beings.","genre_ids":[27,28],"popularity":1.1357,"vote_count":8,"poster_path":"/d7ermrJrFI9geR4XyE6IvtYTpqf.jpg","release_date":"2017-07-13","vote_average":4.6,"backdrop_path":"/abztzm2fsTkCRZhs29jCWe8Ng2.jpg","original_title":"Suite 313","original_language":"en"},{"id":5336,"adult":false,"title":"Salò, or the 120 Days of Sodom","video":false,"overview":"Four corrupted fascist libertines round up 9 teenage boys and girls and subject them to 120 days of sadistic physical, mental and sexual torture.","genre_ids":[18,27],"popularity":4.6685,"vote_count":2250,"poster_path":"/xnaDdiRfZlJaTf6JRc4in40eaeI.jpg","release_date":"1976-01-10","vote_average":6.344,"backdrop_path":"/j88mvEqaL9i9VTcmDgNZ1rTn3g0.jpg","original_title":"Salò o le 120 giornate di Sodoma","original_language":"it"},{"id":15873,"adult":false,"title":"The Bridge at Remagen","video":false,"overview":"In March of 1945, as the War in Europe is coming to a close, fighting erupts between German and American troops at the last remaining bridgehead across the Rhine.","genre_ids":[10752,28],"popularity":1.5728,"vote_count":176,"poster_path":"/cWNzClIEf3bb4Cq1NH47QHCHUW.jpg","release_date":"1969-06-25","vote_average":6.756,"backdrop_path":"/dR4QmjDof7w2vqulfsSthYt9ktF.jpg","original_title":"The Bridge at Remagen","original_language":"en"},{"id":15497,"adult":false,"title":"Twelve O'Clock High","video":false,"overview":"In the early days of daylight bombing raids over Germany, General Frank Savage must take command of a 'hard luck' bomber group. Much of the story deals with his struggle to whip his group into a disciplined fighting unit in spite of heavy losses, and withering attacks by German fighters over their targets.","genre_ids":[10752,28,18],"popularity":1.5664,"vote_count":156,"poster_path":"/g9VeQUobhofLwxSIbKM4ia5biAX.jpg","release_date":"1949-12-21","vote_average":7.112,"backdrop_path":"/fVnphXrYJTH8xPKvJCtzSwZycFC.jpg","original_title":"Twelve O'Clock High","original_language":"en"},{"id":15742,"adult":false,"title":"Taxidermia","video":false,"overview":"Set over three generations and beginning with a sexually frustrated orderly during WWII who relieves his tensions in the most outlandish, gross ways. The result of his liaison is a glutton who grows up to be a champion speed eater. He produces a child who becomes obsessed with taxidermy.","genre_ids":[18,27,35],"popularity":1.037,"vote_count":339,"poster_path":"/uRqxKim0Vr1JZPLYcR1rjFtu74p.jpg","release_date":"2006-08-23","vote_average":6.642,"backdrop_path":"/sZuuEKmEdd9Emn6QIW4WiHrRjSk.jpg","original_title":"Taxidermia","original_language":"hu"},{"id":15807,"adult":false,"title":"Air Force","video":false,"overview":"The crew of an Air Force bomber arrives in Pearl Harbor in the aftermath of the Japanese attack and is sent on to Manila to help with the defense of the Philippines.","genre_ids":[28,18,10752,12],"popularity":0.8909,"vote_count":59,"poster_path":"/mqH4V49GvANYsu1q4SW4CFUTFZe.jpg","release_date":"1943-03-20","vote_average":6.5,"backdrop_path":"/7L6SrvZgbTdNdj0lUA9L6C1mjuY.jpg","original_title":"Air Force","original_language":"en"},{"id":15813,"adult":false,"title":"Dark Blue World","video":false,"overview":"Lt. Franta Slama is a top pilot in the Czech Air Force who is assigned to train a promising young flier, Karel Vojtisek, and they soon become friends. When Nazi Germany invades Czechoslovakia in 1939, they both reject the authority of their new leaders and escape to England where they join other Czech exiles in the RAF. While flying a mission over England, Karel crash lands and happens upon the farmhouse of Susan, a young woman whose husband is in the Navy. Karel soon falls head over heels for Susan but, while they enjoy a brief fling, in time Susan decides she prefers the company of the older and more worldly Franta. As Franta and Karel struggle to maintain their friendship despite their romantic rivalry.","genre_ids":[28,18,10752],"popularity":1.0733,"vote_count":90,"poster_path":"/9vu152xTO89l9UWDcqmE9zVD5xK.jpg","release_date":"2001-05-17","vote_average":6.85,"backdrop_path":"/8DvbkZsU1hjnLz6QUMn6dQHCTV1.jpg","original_title":"Tmavomodrý svět","original_language":"cs"},{"id":15613,"adult":false,"title":"Fire in the Sky","video":false,"overview":"After clearing brush for the government, a group of men return to town claiming their friend was abducted. Despite no apparent motive or evidence of foul play, no-one believes their story and his disappearance is treated as murder.","genre_ids":[878,9648,53],"popularity":2.3092,"vote_count":668,"poster_path":"/rTFrjAp1YV49DSTUGCyKSkaEHC8.jpg","release_date":"1993-03-12","vote_average":6.64,"backdrop_path":"/rG8rGUrK3Ur6N2DuTVvjrtpV44l.jpg","original_title":"Fire in the Sky","original_language":"en"},{"id":286371,"adult":false,"title":"Feed the Gods","video":false,"overview":"Two brothers return to a small mountain town in search of their long lost parents only to discover that the place has a monstrous taste for tourists.","genre_ids":[27,53,12],"popularity":0.2791,"vote_count":13,"poster_path":"/xldYyOSYX2syX2Rg7HlqoVFJlp1.jpg","release_date":"2014-10-26","vote_average":3.538,"backdrop_path":"/eY8HN7WgPUSb4YLcvJOf3WDxpDp.jpg","original_title":"Feed the Gods","original_language":"en"},{"id":480465,"adult":false,"title":"Wunderland","video":false,"overview":"Christmas 1944, The Germans make one final push against the attacking allied armies in the West. Lt. Robert Cappa and his platoon of 2nd Infantry Division soldiers have been ordered to hold a vital road junction against the German aggressors. Cappa and his men must find their faith and strength to stand against their enemy in the epic fight know as \"The Battle of The Bulge.\"","genre_ids":[28,10752,18,53],"popularity":3.2093,"vote_count":50,"poster_path":"/WRTtEKVKkCKBJBVGQart22fXap.jpg","release_date":"2018-02-19","vote_average":5.4,"backdrop_path":"/xzMQUomguGq749lJqEUsuIfHlNk.jpg","original_title":"Wunderland","original_language":"en"},{"id":671474,"adult":false,"title":"Bone Breaker","video":false,"overview":"A group of friends looking for a weekend of fun mistakenly cross paths with the Bone Breaker, turning their trip into a fight for survival.","genre_ids":[27,53,18],"popularity":0.1588,"vote_count":12,"poster_path":"/6PlDdRzlpNcL0GHDyu5iqg6Dq4S.jpg","release_date":"2020-02-09","vote_average":3.6,"backdrop_path":"/6biZG7JVNlOnHytx5YNJEAQmMyp.jpg","original_title":"Bone Breaker","original_language":"en"},{"id":16166,"adult":false,"title":"Sauna","video":false,"overview":"It is 1595. Brutal wars have just ended in an uneasy peace between Protestant Sweden and Orthodox Russia. We focus on the spiritual defeats of two conquered Finnish brothers, one a hardened near-psychopathic war hero, the other a gentle scientist in an age with no use for such men. They find themselves in the swampy interior, demarcating the new border with a unit of sadistic Russians.","genre_ids":[27],"popularity":2.645,"vote_count":128,"poster_path":"/9OnBhOx8kAyA3BLi8bx83L2dQbA.jpg","release_date":"2008-10-17","vote_ave