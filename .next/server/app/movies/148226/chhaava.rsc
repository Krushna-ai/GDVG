pg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:45:34.802+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Chhaava","runtime":161,"tagline":"One warrior, one aim and one epic saga.","homepage":"","overview":"Shivaji's death sparks the Maratha-Mughal conflict. His son Sambhaji leads resistance against Aurangzeb's forces. Amid battles and intrigue, both sides face challenges in a struggle for power."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"Chhaava","runtime":155,"tagline":"","homepage":"","overview":"Das historische Drama basiert auf dem Leben von Chhatrapati Sambhaji Maharaj, dem Sohn von Chhatrapati Shivaji Maharaj."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"De dood van Shivaji leidt tot het Maratha-Mughal-conflict. Zijn zoon Sambhaji leidt het verzet tegen de troepen van Aurangzeb. Te midden van gevechten en intriges staan beide partijen voor uitdagingen in een strijd om de macht."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Chhaava","runtime":0,"tagline":"","homepage":"","overview":"Moartea lui Shivaji declanșează conflictul dintre marathas și mughali. Fiul său, Sambhaji, preia conducerea rezistenței împotriva forțelor lui Aurangzeb. În mijlocul bătăliilor și intrigilor, ambele tabere se confruntă cu provocări majore într-o luptă aprigă pentru putere."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"מלחמת האריות","runtime":0,"tagline":"","homepage":"","overview":"בנו של שיוואג'י, סמבהאג'י נלחם נגד הקיסר המוגולי, אורנגזב, כדי להגן על הממלכה המארטהית, רוחו חסרת הפחד והבלתי ניתנת לשליטה של סמבהאג'י יחזק את מורשת ממלכת אביו, וישנה לנצח את ההיסטוריה של הודו. סאגה אפית של גבורה, הקרבה והחתירה הבלתי פוסקת לחופש."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Сын льва","runtime":160,"tagline":"","homepage":"","overview":"XVII век. Чхатрапати Шиваджи Махарадж, основатель государства маратхов, бросает вызов тюркско-мусульманскому господству. Его старший сын Чхатрапати Самбхаджи Махарадж с мужеством и решимостью продолжает дело отца и противостоит правителю Аурангзебу."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"بچه شیر","runtime":0,"tagline":"","homepage":"","overview":"فیلم داستان شجاعت \"ساتامپارتی ماهاراج\" در دوران استارت هند و تلاش جانانه او برای ایجاد الگویی استقلال منش برای ازادی کشورش است و ..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"O Filho do Rei","runtime":0,"tagline":"","homepage":"","overview":"Depois da morte do pai, o marajá Sambhaji combate as forças do Império Mugal lideradas por Aurangzeb para manter vivo o Império Marata."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"มหาราชาหัวใจสิงห์","runtime":0,"tagline":"","homepage":"","overview":"หลังจากผู้เป็นบิดาสิ้นพระชนม์ สัมภาจีมหาราช กษัตริย์ยอดนักรบก็ต่อสู้ฟาดฟันกับกองทัพโมกุลที่นำโดยออรังเซบ เพื่อที่จะปกป้องจักรวรรดิมราฐาให้ปลอดภัย"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"幼狮","runtime":157,"tagline":"","homepage":"","overview":"一部根据贾特拉帕蒂·希瓦吉·马哈拉吉之子贾特拉帕蒂·桑巴吉·马哈拉吉一生改编的历史剧。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"شبل الأسد","runtime":161,"tagline":"","homepage":"https://www.netflix.com/eg/title/81902061","overview":"بعد أن غيّب الموت والده، يخوض الملك المحارب \"سامهاجي ماهاراج\" حربًا ضد قوات المغول التي يقودها \"أورنغزيب\" لحماية إمبراطورية \"ماراثا\" من السقوط."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Тінь","runtime":0,"tagline":"","homepage":"","overview":"XVII ст. Чхатрапаті Шиваджі Махарадж, засновник держави маратхів, кидає виклик тюрксько-мусульманському пануванню. Його старший син Чхатрапаті Самбхаджі Махарадж із мужністю та рішучістю продовжує справу батька та протистоїть правителю Аурангзебу."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"幼獅王朝","runtime":161,"tagline":"","homepage":"","overview":"父親去世之後，驍勇善戰的桑巴吉馬哈拉傑國王力抗奧朗則布率領的蒙兀兒大軍，為馬拉塔帝國的存亡奮戰。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Chhaava","runtime":0,"tagline":"","homepage":"","overview":"La mort de Shivaji déclenche le conflit entre les Maratha et les Moghols. Son fils Sambhaji mène la résistance contre les forces d'Aurangzeb. Au milieu des batailles et des intrigues, les deux camps sont confrontés à des défis dans une lutte pour le pouvoir."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Chiến Binh Maratha","runtime":0,"tagline":"","homepage":"","overview":"Chhaava (2025) là một bộ phim lịch sử - hành động của Ấn Độ, kể về cuộc đời của Chhatrapati Sambhaji Maharaj, vị vua thứ hai của Đế quốc Maratha. Bộ phim tái hiện cuộc chiến chống lại Đế chế Mughal của Sambhaji, khi Hoàng đế Aurangzeb cố gắng thôn tính Maratha. Ông đã sử dụng chiến thuật du kích để bảo vệ vương quốc, nhưng cũng phải đối mặt với những cuộc phản bội và âm mưu chính trị. Dù bị bắt và tra tấn, ông vẫn kiên cường, trở thành biểu tượng của lòng quả cảm và sự bất khuất."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"차바","runtime":0,"tagline":"","homepage":"","overview":"마라타 제국의 두 번째 통치자인 삼바지 마하라지의 삶을 바탕으로 한 역사 액션 영화"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"幼獅王朝","runtime":0,"tagline":"","homepage":"","overview":"父親去世之後，驍勇善戰的桑巴吉馬哈拉傑國王力抗奧朗則布率領的蒙兀兒大軍，為馬拉塔帝國的存亡奮戰。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"شبل الأسد","runtime":161,"tagline":"","homepage":"https://www.netflix.com/eg/title/81902061","overview":"بعد أن غيّب الموت والده، يخوض الملك المحارب \"سامهاجي ماهاراج\" حربًا ضد قوات المغول التي يقودها \"أورنغزيب\" لحماية إمبراطورية \"ماراثا\" من السقوط."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"}],"reviews_tmdb":[],"recommendations":[{"id":1472668,"adult":false,"title":"Wick Is Pain","video":false,"overview":"Witness the never-before-seen footage and true story behind the John Wick phenomenon – from independent film to billion-dollar franchise.","genre_ids":[99],"media_type":"movie","popularity":1.3695,"vote_count":90,"poster_path":"/ctZ9bjmCYyfFt3cUepc9axr0zHs.jpg","release_date":"2025-05-08","vote_average":7.433,"backdrop_path":"/fog8Vbeg1KOZAucucPxgYpXJ0a0.jpg","original_title":"Wick Is Pain","original_language":"en"},{"id":1201012,"adult":false,"title":"Dhoom Dhaam","video":false,"overview":"On their wedding night, an oddball couple is thrust into a chaotic chase, dodging goons and cops in a frenzied hunt for the mysterious \"Charlie.\"","genre_ids":[35],"media_type":"movie","popularity":1.5518,"vote_count":71,"poster_path":"/2E7me3rPi8HqaeheuD86YlpNX6k.jpg","release_date":"2025-02-13","vote_average":6.845,"backdrop_path":"/l2QSVFR5aLcW1Vl4cGKrQkEp6fY.jpg","original_title":"धूम धाम","original_language":"hi"},{"id":949716,"adult":false,"title":"Vidaamuyarchi","video":false,"overview":"While struggling with his broken marriage, Arjun is pulled into a desperate search for his wife, Kayal, when she goes missing during a road trip.","genre_ids":[28,18,9648,53,80],"media_type":"movie","popularity":1.2814,"vote_count":31,"poster_path":"/yx7AYFLoupzBfdfEAlDFuOiei2A.jpg","release_date":"2025-02-06","vote_average":6,"backdrop_path":"/k4cFld0vF83N