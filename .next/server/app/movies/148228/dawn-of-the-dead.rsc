iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.781,"vote_average":0},{"width":1920,"height":1078,"file_path":"/p1f1ptrf7wgYovo7Evk0ECfQoIY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.781,"vote_average":0},{"width":1920,"height":1078,"file_path":"/8Y40XjJsZCvLptvXmlGuc5a0vtJ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.781,"vote_average":0},{"width":1920,"height":1078,"file_path":"/o5n7WBeaHjnafy5XbrOInApCmmy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.781,"vote_average":0},{"width":1920,"height":1080,"file_path":"/cgUvKLRkws4p1on1PBrR68tnYQf.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3072,"height":1725,"file_path":"/eCWM3RiJtGfOeKMUswZakZ2YZtZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.781,"vote_average":0},{"width":3072,"height":1728,"file_path":"/hOHKnL5wUiTwwK4ElygrjDcTZE8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1078,"file_path":"/gikYGSkgcdfAdcEMpGfcLWZlyj7.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.781,"vote_average":0},{"width":1920,"height":1078,"file_path":"/pyBbcOJbSh5LATADPFW3Q5Kyw3W.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.781,"vote_average":0},{"width":1920,"height":1080,"file_path":"/hmDDRPAr6X5eITKUTaVCQMPoUhF.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/zZDKcYObp7FtJs8PJJh3MbKVvBW.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3072,"height":1728,"file_path":"/ccoAzkHDqNpx7NK9Ae0lGZkhcne.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/fEt7UXrQJPUKzIQvlHB7GYLF1vT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/gQWAgo6HE8dZu0asTVO4Jh12MFQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/u3pR4gYHhK9dEAyX0zseIwoHpqi.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/9bmAeQX7MUThJ5PkMLqGf9kgrkE.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/vbGBCA9PV9WP9kKlehxpACawTjK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/ttFnEMzLMBtaxsdre8L8htBdAQR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/jsjG7f51ds1BUZ8L9F73vhno9pT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3072,"height":1728,"file_path":"/9dpVy6s9PB68t8UUDwWQNznY1X9.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3072,"height":1728,"file_path":"/5tsQ6MUvFYcK8ocoo7tskOKNj2I.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2560,"height":1440,"file_path":"/e5RBKUOv8OC28NJAziHCOy1auKb.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2560,"height":1440,"file_path":"/ny3OuRR9AKIT9PEdb5FRqZy7KDr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2560,"height":1440,"file_path":"/nGqvND3MFgBS31Lnb53VhpGhm2y.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2560,"height":1440,"file_path":"/onKpT4iPk7hBXf7yNU81OytTQuL.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3684,"height":2072,"file_path":"/nhQfV3bb4DxVmvqFZSkAi96IsMN.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3684,"height":2072,"file_path":"/8oiKBnizTGad5qbd6dCZQOJ338P.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/1tbPY7fcyxk5qRsAQ7E2TLvPEQX.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:45:43.276+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":127,"tagline":"When there’s no more room in HELL, the dead will walk the EARTH!","homepage":"","overview":"During an ever-growing epidemic of zombies that have risen from the dead, two Philadelphia SWAT team members, a traffic reporter, and his television-executive girlfriend seek refuge in a secluded shopping mall."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Zombie","runtime":126,"tagline":"Wenn in der Hölle kein Platz mehr ist, kommen die Toten auf die Erde","homepage":"","overview":"Es herrschen Panik und Chaos auf der Welt. Der nationale Notstand wird ausgerufen. Aus unbekannten Gründen verwandeln sich die Körper kürzlich Verstorbener in fleischhungrige Untote. Auf den Straßen wandeln die Zombies umher. Vier Menschen können sich mit einem Hubschrauber aus Fängen des Grauens retten. Sie verstecken sich in einem gigantischen Shopping-Center und verschanzen sich dort. Anfangs scheint dies ein sicherer Ort zu sein, doch schon bald müssen sie feststellen, dass die lebenden Toten viel gefährlicher sein können, als zuerst angenommen. Gemeinsam beginnen sie einen Kampf gegen die Zombie-Übermacht und müssen sich bald noch brutaleren Gegnern stellen.  George A. Romeo setzte mit „Zombies: Dawn of the Dead“ seinen Kultklassiker „Night of the Living Dead“ fort und schuf gleichzeitig einen neuen Meilenstein des Horrorkinos."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Zombi","runtime":118,"tagline":"Quando non ci sarà più spazio all'inferno, i morti cammineranno sulla terra.","homepage":"","overview":"Negli Stati Uniti dilaga un'invasione di zombi, cadaverici redivivi dall'al di là, essere regrediti a uno stato di torpore animalesco, tesi alla ricerca di cibo (carne fresca dei viventi), deboli di forza e robusti di zanne, facili da abbattere, ma invulnerabili se non sono colpiti al cervello. Iniziata in medias res l'azione si svolge in gran parte all'interno di un supermercato Penney dove si barricano tre uomini e una donna."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Zombie","runtime":115,"tagline":"Quand il n’y a plus de place en enfer, les morts reviennent sur terre.","homepage":"","overview":"Des morts-vivants assoiffés de sang ont envahi la Terre et se nourrissent de ses habitants. Un groupe de survivants se réfugie dans un centre-commercial abandonné. Alors que la vie s'organise à l'intérieur, la situation empire à l'extérieur."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"O Despertar dos Mortos","runtime":126,"tagline":"Quando não houver mais espaço no inferno, os mortos caminharão sobre a terra.","homepage":"","overview":"Os Estados Unidos está sendo devastado por uma epidemia que transforma pessoas em zumbis assassinos. As causas são desconhecidas, mas todos os cadáveres que são afetados pelo vírus se tornam mortos-vivos, famintos por carne humana. Diante deste cenário de caos e desolação, o governo recruta uma equipe de acabar com a ameaça. Dois membros dessa equipe, Peter (Ken Foree) e Roger (Scott Reiniger) foram incumbidos de exterminar os zumbis de um conjunto habitacional em Pittsburgh. Porém, a missão fica complicada e os agentes pedem ajuda a Stephen (David Emge), um piloto de helicóptero e sua namorada Frances (Gaylen Ross). Os quatro se refugiam em um shopping local, mas eles não vão conseguir se esconder por muito tempo."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Zombi","runtime":115,"tagline":"Cuando no hay sitio en el infierno, los muertos caminarán sobre la Tierra.","homepage":"","overview":"La epidemia que hace resucitar a los muertos convertidos en seres ávidos de carne humana se ha extendido, llegando al punto en el que varias ciudades han quedado prácticamente desiertas. Los supervivientes deben refugiarse en zonas militares ya que los zombies no dudan en acabar con sus propios familiares…"},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"活死人黎明","runtime":0,"tagline":"当地狱里没有更多的空间时，死者将在地球上行走！","homepage":"","overview":"死而复生的嗜血僵尸如瘟疫般迅速占领全城，整个城市在一夜之间成为僵尸之城。为了躲避僵尸的攻击，两个特种部队警察和一个交通记者以及他的女友，逃到了一个荒废的大型购物中心里。这四个人斯蒂芬（大卫·艾梅治 David Emge 饰）、彼得（肯·弗里 Ken Foree 饰）、罗杰（斯科特·H·雷宁格 Scott H. Reiniger 饰）以及法兰妮（盖伦·罗丝 Gaylen Ross 饰）使尽浑身解数武装自己，尽一切可能抵抗凶残僵尸的袭击。然而他们的抵抗却不敌越来越多的僵尸，好景不长，僵尸蜂拥而至。雪上加霜的是，一大群车手也发现了这个避难所。四人不但要躲避疯狂的僵尸，还要同凶残的劫匪对抗。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Зора живих мртваца","runtime":127,"tagline":"Зора живих мртваца","homepage":"","overview":"У овом наставку филма \"Ноћ живих мртваца\", радња се одвија неколико недеља после догађаја у првом делу. Ситуација се погоршала, па два репортера, удружена са два члана SWAT тима, одлучују да украду хеликоптер и пронађу место где се могу сакрити од крволочних зомбија. Они проналазе забачени тржни центар и одлучују да се ту зауставе и преноће. Они одлучују и да остану у тржном центру па се забарикадирају у малој соби док периодично одлазе у тржни центар преплављен зомбијима како би узели шта им треба. Све време боре се са зомбијима а касније и са бандом бајкера која жели тржни центар за себе."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Úsvit mrtvých","runtime":126,"tagline":"","homepage":"","overview":"Na zemi se začne šířit smrtelný virus. Mrtví ožívají a živí se lidským masem. Peter, Steven, Roger a Francin se ukrývají v opuštěném obchodním domě. Zatarasí dveře náklaďáky, aby se další zombie do obchodu nedostali. Bohužel, všimne si jich jedna banda, která rabuje obchody a užívají si věcí, kterých by se jim v normálním světě asi nedostalo."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Zombi","runtime":101,"tagline":"Cehennemde boş yer kalmadığında, ölüler dünyada yürüyecek!","homepage":"","overview":"Ülkemizde Zombi adı ile vizyona giren korku klasiği 1978 yapımı Dawn of the Dead, zombi filmlerinin babası ünlü yönetmen George A. Romero’nun ‘Yaşayan Ölüler’ serisinin ikinci filmi. Zombi istilasından kaçarken bir alışveriş merkezine sığınan dört kişinin başına gelenleri konu edinen filmde Romero, ilk film Yaşayan Ölülerin Gecesi’nin (Night of the Living Dead, 1968) sahip olduğu politik alt metnin dozunu bir miktar daha arttırıyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Рассвет мертвецов","runtime":139,"tagline":"«В 1968 году Джордж Ромеро представил нам \"Ночь живых мертвецов\". Этот фильм стал классикой ужасов своего времени. Теперь Джордж Ромеро предлагает нам самый шокирующий фильм всех времён»","homepage":"","overview":"Кошмар продолжается. Убежав от ужаса мертвых на вертолете, четверо путешественников вынуждены приземлиться на крышу торгового центра. Там они находят пищу, приют и неприятности - многоэтажный магазин сверху донизу забит глупыми ходячими трупами.\r Развлекаясь отстрелом мертвецов, люди и не подозревают, что всего через несколько часов один из них станет тем, кого они так легко убивают — плотоядным зомби, а чуть позже в магазин нагрянет банда отморозков, не делающая различия между живым и мертвым, единственным желанием которых является жажда наживы и насилия."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"ゾンビ","runtime":115,"tagline":"地獄の底から這い出して、ゾンビが食う！人間を食う！","homepage":"","overview":"世界各地で原因が判らぬまま死体が蘇り、生きている人間を襲って食べる現象が蔓延し次第に社会は大混乱していく。アメリカ地方テレビ局のスティーブンとフランはこの状況から都市部を脱出する事にした。友人のSWAT隊員ロジャーと同僚ピーターと共にヘリコプターで人の少ない田舎を目指すが、途中孤立したショッピングモールに立ち寄る。何でもそろっているショッピングモールは隔離して中のゾンビを駆除してしまえば安全と思われ、出入り口を閉鎖し快適な空間へ作り変えていく。そんな中、暴徒と化した暴走集団がショッピングモールに目をつけ襲撃してくる。暴動集団の無計画な襲撃をやり過ごす中、ゆっくりとだが群がるゾンビが彼ら人間を確実に取り囲んでいく。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"De döda har börjat invadera världen och de kommer inte i fredligt syfte. Mänsklighetens överlevnad är hotad och en grupp människor hittar sin tillflyktsort i ett övergivet shoppingcentrum."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Ζόμπι: Το Ξύπνημα των Νεκρών","runtime":0,"tagline":"Όταν δεν υπάρχει άλλος χώρος στην κόλαση, οι νεκροί θα περπατήσουν στη Γη.","homepage":"","overview":"Μετά το ξέσπασμα της εξαπλωνόμενης επιδημίας των ζόμπι, δύο αστυνομικοί των ειδικών δυνάμεων, ένας δημοσιογράφος και η κοπέλα του, η οποία είναι τηλεοπτική παραγωγός, βρίσκουν καταφύγιο σε ένα εγκαταλελειμμένο εμπορικό κέντρο. Τα ζόμπι δεν αργούν να εμφανιστούν πολιορκώντας το εμπορικό κέντρο και η μάχη για την επιβίωση ξεκινά."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"","runtime":127,"tagline":"","homepage":"","overview":"Over de hele wereld komen de doden tot leven. Reporter Francine vindt met haar vriend Roger en de twee soldaten Peter en Stephen onderdak in een enorm winkelcentrum. In eerste instantie lijken ze veilig, maar de vleesetende doden blijven maar oprukken."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Holtak hajnala","runtime":0,"tagline":"Amikor már nincs hely a POKOLBAN, a holtak FÖLD felszínét járják majd.","homepage":"","overview":"Miért és hol kezdődött, senki sem tudta... Az emberiséget egy ismeretlen és legyőzhetetlen kór fertőzte meg: a holtak többé nem voltak holtak... Testek tántorogtak egy cafat véres hús után sóvárogva, az élő emberek iránti kielégíthetetlen, mohó vágyukat követve. Egy tévécsatorna két munkatársa, Stephen és France a tudosítás helyett a menekülést választja. Két kommandós rendőr csapódik hozzájuk, akik a rendefenntartás helyett választották a menekülést. A szedett-vetett kis csapat néhány előhalott megsemmisítése után egy elhagyatott, üres bevásárló központba fészkeli be magát. A külvilág egyre pokolibbá válik, a foszladozó zombik egyre növekvő serege fáradhatatlanul ostromolja a bevásárló központot a friss húsért. De az élőket nem csak vérszomjas, éhségtől hörgő, és a központba egyre többször behatoló élőhalottak fenyegetik. Vészesen fogy az élelem, kialszik a villany és az ivóvíznek is híján vannak. Az élők megütköznek az élőhalottakkal, egymással, és saját félelmeikkel..."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Zombie: Rædslernes morgen","runtime":127,"tagline":"Når der ikke mere er plads i helvede. Vil de døde vende tilbage til jorden.","homepage":"","overview":"Horder af zombier truer med at overtage USAs storbyer. Derfor bliver nationalgarden sat ind i kampen mod de levende døde. Peter og Roger er soldater i en enhed, der skal rydde op i Pittsburgh. Men de deserterer og forskanser sig sammen med to andre i et kæmpe indkøbscenter, hvor de vil leve lykkeligt til deres dages ende. Men kampen mod zombierne er langt fra slut."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"שחר המתים","runtime":0,"tagline":"","homepage":"","overview":"סרט הקאלט של במאי האימה המוביל של שנות ה-70, ג'ורג' רומרו, שמהווה המשך לסרטו המוקדם והמכונן, \"ליל המתים החיים\". מתקפת זומבים פרועה מובילה קבוצה של אנשים להתבצר בקניון גדול בפרברי העיר. כשהמוות מידפק על הדלתות בהמוניו, עושים הגיבורים הכול כדי לצאת מזה שלמים ואנושיים. כל נשיכה עשויה להוביל לחיי נצח של פלצות. מהדורה אולטימטיבית שכוללת כמה גרסאות לסרט, כולל ורסיה מורחבת. כמו כן, כולל הדיסק דוקומנטרי חדש ומחודש על הסרט, בין מרואייניו גם במאי האימה האיטלקי דריו ארג'נטו (Susperia, פנטום האופרה), שהפיק את הסרט ואף כתב חלק מהמוזיקה, וגם סרט על ההפקה שצולם במהלך הצילומים עצמם."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"시체들의 새벽","runtime":116,"tagline":"공포영화의 마스터피스","homepage":"","overview":"어떤 병원체로 인해 수 많은 사람들이 좀비가 되어 뇌만 죽은 채 의식없이 거리를 방황한다. 이들은 오직 살아있는 사람들을 먹기 위해 달려들고, 좀비에게 물리게 되면 그 사람도 같은 상태가 된다. 이로 인해 좀비들은 점차 늘어나고 세상은 온통 무질서의 마비 상태가 된다. 이때 네 사람이 헬기로 어떤 한적한 곳의 백화점에 피신하게 되고 좀비들로부터 포위되는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Despertar dos Mortos","runtime":139,"tagline":"Quando não houver mais espaço no inferno, os mortos caminharão pela terra.","homepage":"","overview":"Os mortos estão retornando a vida e atacando os vivos. Quatro sobreviventes do ataque escondem-se em um shopping abandonado e planejam contra-atacar. No entanto, milhares de mortos-vivos descobrem o esconderijo e iniciam um novo massacre, contaminando alguns sobreviventes que retornam como zumbis e somam-se ao exército de abomináveis criaturas."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Świt żywych trupów","runtime":0,"tagline":"","homepage":"","overview":"Tajemnicza epidemia zamienia ludzi w krwiożerczych zombie, a USA pogrążają się w anarchii. Nieliczni ocaleni - dwaj policjanci z elitarnej brygady SWAT, dziennikarz i jego dziewczyna - ukrywają się w opuszczonym, gigantycznym centrum handlowym. Początkowo wydaje im się, że znaleźli bezpieczny azyl, w którym spokojnie przeczekają do końca morderczej zarazy. Sytuacja zmienia się w chwili, gdy do centrum handlowego przedostaje się grupa uzbrojonych bandytów, a za nimi przerażające zombie. Rozpoczyna się dramatyczna walka o przetrwanie..."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"生人勿近","runtime":0,"tagline":"","homepage":"","overview":"一場可怕的瘟疫席捲了整個世界,滿世界被瘟疫襲倒之後,成百上千萬的屍體被感染變成了吸血的殭屍。不管是死人還是活人,只要被殭屍吸去鮮血,就會也立刻殭屍.殭屍電影的真正集大成之作是A·羅梅羅的《殭屍三部曲》之二，拍攝於1979年的《殭屍的黎明》（Dawn of the dead）。這部投資依然不足500k的小電影帶來了全美超過20M,全球超過55M的驚人票房，也徹底奠定了羅梅羅殭屍電影大師的地位。《殭屍的黎明》在完善了殭屍基本設定的同時，成功的引進了之後始終佔據核心地位的城市元素。破敗無人的大型城市，四處遊走的喪屍，絕望的尋求生存的人類，DOTD幾乎可以被稱為現代殭屍電影字典。更可貴的是，在恐怖，逃亡以外，羅梅羅不吝筆墨的大量描寫了人處於極端環境中的各種心理活動: 恐懼，迷茫，瘋狂，種群概念模糊的失落等等，這些元素綜合在一切，終於使殭屍電影超越了初級的恐怖電影，進化為了一類非常獨特的類型。而《殭屍的黎明》本身也被供為了殭屍影迷心中的神作，成為了clut經典。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"El amanecer de los muertos vivientes","runtime":0,"tagline":"","homepage":"","overview":"La epidemia que hace resucitar a los muertos convertidos en seres ávidos de carne humana se ha extendido, llegando al punto en el que varias ciudades han quedado prácticamente desiertas. Los supervivientes deben refugiarse en zonas militares ya que los zombies no dudan en acabar con sus propios familiares... Continuación del clásico de horror de George A. Romero \"La noche de los muertos vivientes\" (Night of the Living Dead, 1968)."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"ต้นฉบับรุ่งอรุณแห่งความตาย","runtime":0,"tagline":"Dawn Of The Dead 1978 : รุ่งอรุณแห่งความตาย","homepage":"","overview":"การต่อสู้ระหว่างซอมบี้และมนุษย์ เมื่อฝ่ายหนึ่งล่าเพราะต้องการอาหาร อีกฝ่ายก็ต้องปกป้องตัวเอง เรื่องราวเกิดขึ้นเมื่อประชากรโลกประสบกับโรคระบาดร้ายแรงที่หาคำตอบไม่ได้ และซากศพกลับฟื้นคืนชีพและพวกมันต้องการอาหาร พวกมันจึงไล่ล่าผู้ที่รอดชีวิตเพื่อฉีกกินเนื้อของพวกมนุษย์ซึ่งได้หลบซ่อนอยู่และทำทุกอย่างเพื่อที่จะป้องกันตัวเอง แม้สิ่งสำคัญที่สุดที่จะต้องรับมือก็คือมนุษย์ด้วยกันเอง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Outo epidemia on levinnyt ympäri maailman. Elävien kuolleiden armeijaa ei voi enää pysäyttää. Pakeneminen on ihmiskunnan ainoa toivo. Hylätty ostoskeskus suo lyhytaikaisen turvan pienelle turvapaikkaa etsivälle joukolle. Mutta jälleen kerran suurimman uhkan aiheuttaa toinen ihminen, tällä kertaa ryöstelevä moottoripyöräjengi. Dawn of the Dead on jatkoa vuonna 1968 valmistuneelle legendaariselle kauhuelokuvalle Night of the Living Dead."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"生人勿近","runtime":0,"tagline":"","homepage":"","overview":"一場可怕的瘟疫席捲了整個世界,滿世界被瘟疫襲倒之後,成百上千萬的屍體被感染變成了吸血的殭屍。不管是死人還是活人,只要被殭屍吸去鮮血,就會也立刻殭屍.殭屍電影的真正集大成之作是A·羅梅羅的《殭屍三部曲》之二，拍攝於1979年的《殭屍的黎明》（Dawn of the dead）。這部投資依然不足500k的小電影帶來了全美超過20M,全球超過55M的驚人票房，也徹底奠定了羅梅羅殭屍電影大師的地位。《殭屍的黎明》在完善了殭屍基本設定的同時，成功的引進了之後始終佔據核心地位的城市元素。破敗無人的大型城市，四處遊走的喪屍，絕望的尋求生存的人類，DOTD幾乎可以被稱為現代殭屍電影字典。更可貴的是，在恐怖，逃亡以外，羅梅羅不吝筆墨的大量描寫了人處於極端環境中的各種心理活動: 恐懼，迷茫，瘋狂，種群概念模糊的失落等等，這些元素綜合在一切，終於使殭屍電影超越了初級的恐怖電影，進化為了一類非常獨特的類型。而《殭屍的黎明》本身也被供為了殭屍影迷心中的神作，成為了clut經典。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"მკვდრების აისი","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Bình Minh Chết","runtime":0,"tagline":"","homepage":"","overview":"Đây là phiên bản cũ khác với bản Dawn of the Dead do Universal làm lại và phát hành năm 2004. Một dịch bệnh kì lạ khiến cho cả thành phố trở thành những xác chết muốn ăn thịt người sống và một nhóm người chưa bị biến thành xác chết đã lên trực thăng chạy trốn vào một siêu thị và mọi chuyện vẫn tiếp diễn khi mà bọn xác chết xông vào… Tuy nhiên zombie ở đây khá yếu ớt và chỉ biết lê lết chứ không chạy được, nhưng vẫn cực kỳ nguy hiểm vì có số lượng rất đông..."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"El despertar dels zombis","runtime":0,"tagline":"Quan no hi hagi lloc a l'infern, els morts caminaran sobre la Terra.","homepage":"","overview":"L'epidèmia que fa ressuscitar els morts convertits en éssers àvids de carn humana s'ha estès, arribant al punt en què diverses ciutats han quedat pràcticament desertes. Els supervivents han de refugiar-se en zones militars ja que els zombies no dubten a acabar amb els seus familiars... Continuació del clàssic d'horror de George A. Romero \"La nit dels morts vivents\" (Night of the Living Dead, 1968)."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Світанок мерців","runtime":0,"tagline":"","homepage":"","overview":"Кошмар зомбі, що почався у фільмі «Ніч живих мерців», продовжується. Четверо мандрівників, що врятувалися від жаху мертвих на вертольоті, вимушено приземлитися на дах супермаркету. Там вони знаходять їжу, притулок і неприємності. Багатоповерховий магазин від низу до верху забитий дурними ходячими трупами. Розважаючи себе відстрілом мертвяків, люди і не підозрюють, що всього через декілька годин один із них стане тим, кого вони так легко вбивають — м'ясоїдним зомбі, а трохи пізніше в магазин нагряне банда відморозків, для якої немає різниці між живим і мертвим, єдиним бажанням яких є жадання наживи і насильства."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"L'aube des morts","runtime":127,"tagline":"Quand il n’y a plus de place en enfer, les morts reviennent sur terre.","homepage":"","overview":"Des morts-vivants assoiffés de sang ont envahi la Terre et se nourrissent de ses habitants. Un groupe de survivants se réfugie dans un centre commercial abandonné. Alors que la vie s'organise à l'intérieur, la situation empire à l'extérieur."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Numirėlių aušra","runtime":0,"tagline":"","homepage":"","overview":"Dėl nuolat augančios zombių epidemijos du Filadelfijos specialiųjų pajėgų pareigūnai, eismo reporteris ir jo televizijoje dirbanti mergina ieško prieglobsčio nuošaliame prekybos centre."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"}],"reviews_tmdb":[{"id":"577961db9251415ede000591","url":"https://www.themoviedb.org/review/577961db9251415ede000591","author":"talisencrw","content":"This is one of the finest sequels ever, in that it's both of comparable quality with the original, yet is fundamentally different from it at the same time. Marvelous stuff, with aspects copied thousands of times over the past two generations, with no end in sight.\r\n\r\nThis and 'Salo, or the 120 Days of Sodom', from about the same time frame, would make one of the best double-bills ever on the evils of consumerism gone rampant...","created_at":"2016-07-03T19:04:59.238Z","updated_at":"2021-06-23T15:57:48.505Z","author_details":{"name":"","rating":9,"username":"talisencrw","avatar_path":null}},{"id":"5b7ce3640e0a263bc7005d10","url":"https://www.themoviedb.org/review/5b7ce3640e0a263bc7005d10","author":"Wuchak","content":"$11","created_at":"2018-08-22T04:15:32.169Z","updated_at":"2021-06-23T15:58:11.370Z","author_details":{"name":"","rating":8,"username":"Wuchak","avatar_path":"/4KVM1VkqmXLOuwj1jjaSdxbvBDk.jpg"}},{"id":"5fda9dc67776f0003f2f3288","url":"https://www.themoviedb.org/review/5fda9dc67776f0003f2f3288","author":"JPV852","content":"Been a while since I last watched this one, but with the new 4K UHD out, decided to give it another watch going with the Extended Cut. Still very well made with some great zombie effects and really liked the characters, Peter (Ken Foree), especially. I'm not a big fan of the zombie horror genre but this is one of the exceptions. **4.0/5**","created_at":"2020-12-16T23:52:38.017Z","updated_at":"2021-06-23T15:58:48.871Z","author_details":{"name":"","rating":8,"username":"JPV852","avatar_path":"/xNLOqXXVJf9m7WngUMLIMFsjKgh.jpg"}},{"id":"65f2944f6dea3a017c7c034b","url":"https://www.themoviedb.org/review/65f2944f6dea3a017c7c034b","author":"Filipe Manuel Neto","content":"$12","created_at":"2024-03-14T06:08:15.441Z","updated_at":"2024-03-14T06:08:15.627Z","author_details":{"name":"Filipe Manuel Neto","rating":1,"username":"FilipeManuelNeto","avatar_path":"/nidqITf735x9xxHfncXkT9BmOQ7.png"}}],"recommendations":[{"id":8408,"adult":false,"title":"Day of the Dead","video":false,"overview":"As the world is overrun by zombies, scientists and military personnel in an underground Florida bunker must decide on how they should deal with the undead.","genre_ids":[27,18,9648],"media_type":"movie","popularity":2.0266,"vote_count":1353,"poster_path":"/bi7SO5F4VyyGQTlxQirbH1dwKzW.jpg","release_date":"1985-07-03","vote_average":7.036,"backdrop_path":"/sZUnqJCjEUtdZ0vhPO3oe1PFYV9.jpg","original_title":"Day of the Dead","original_language":"en"},{"id":10331,"adult":false,"title":"Night of the Living Dead","video":false,"overview":"A ragtag group barricade themselves in an old Pennsylvania farmhouse to remain safe from a horde of flesh-eating ghouls ravaging the Northeast.","genre_ids":[27,53],"media_type":"movie","popularity":2.6136,"vote_count":2670,"poster_path":"/rb2NWyb008u1EcKCOyXs2Nmj0ra.jpg","release_date":"1968-10-04","vote_average":7.614,"backdrop_path":"/5KtmBSqFtHY3I9t8lgH27Mc0bqY.jpg","original_title":"Night of the Living Dead","original_language":"en"},{"id":924,"adult":false,"title":"Dawn of the Dead","video":false,"overview":"A group of survivors take refuge in a shopping mall after the world is taken over by aggressive, flesh-eating zombies.","genre_ids":[27,28],"media_type":"movie","popularity":5.9619,"vote_count":4364,"poster_path":"/ttquyxStEEctzghtA2f4PUGprDr.jpg","release_date":"2004-03-19","vote_average":7.052,"backdrop_path":"/rspbS1E9wJtslrb8amfJgtMBUVh.jpg","original_title":"Dawn of the Dead","original_language":"en"},{"id":11683,"adult":false,"title":"Land of the Dead","video":false,"overview":"The living dead have taken over the world, and the remaining humans live in a walled city to protect themselves as they cope with the situation.","genre_ids":[27,878,53],"media_type":"movie","popularity":2.7007,"vote_count":1711,"poster_path":"/xxp0qcZ3n2YA53SIzWilDSfIaA4.jpg","release_date":"2005-06-18","vote_average":6.2,"backdrop_path":"/teAcCOSN9wWDgePt4bRbzDK9oZF.jpg","original_title":"Land of the Dead","original_language":"en"},{"id":59223,"adult":false,"title":"Deadlands 2: Trapped","video":false,"overview":"The United States Government has developed a highly effective nerve gas that is unleashed upon the residents of a small Maryland City. During the top secret exercise the infected citizens begin to convert each resident into a sort of living zombie, until the remaining town residents, 6 total strangers, are trapped inside a movie theater cineplex.","genre_ids":[27,878,53],"media_type":"movie","popularity":0.1835,"vote_count":11,"poster_path":"/1ucfyMAM10aUQCTBIs0O88SgWH9.jpg","release_date":"2008-10-27","vote_average":5.818,"backdrop_path":null,"original_title":"Deadlands 2: Trapped","original_language":"en"},{"id":29425,"adult":false,"title":"The Crazies","video":false,"overview":"The military attempts to contain a manmade virus causing death and permanent insanity in those infected, as it overtakes a small Pennsylvania town.","genre_ids":[878,27,28],"media_type":"movie","popularity":2.3223,"vote_count":399,"poster_path":"/xSNgBJL9WKMHwl42gZXeRsQXFa1.jpg","release_date":"1973-03-16","vote_average":6.1,"backdrop_path":"/iCdtK81PavU2Tcm5nuuPipG0gHt.jpg","original_title":"The Crazies","original_language":"en"},{"id":42196,"adult":false,"title":"The Bad Seed","video":false,"overview":"Air Force Colonel Kenneth Penmark and his wife, Christine, adore their daughter Rhoda, despite her secret tendency for selfishness. Christine keeps her knowledge of her daughter's darker side to herself, but when a schoolmate of Rhoda's dies mysteriously, her self-deception unravels.","genre_ids":[53,18,27],"media_type":"movie","popularity":1.9103,"vote_count":255,"poster_path":"/iAgSkpZslQ2s3onL9TaHbyWygtC.jpg","release_date":"1956-09-12","vote_average":7.1,"backdrop_path":"/tqiAcUqaXPyL2oo18CIPWUGxkJk.jpg","original_title":"The Bad Seed","original_language":"en"},{"id":77365,"adult":false,"title":"Into the Abyss","video":false,"overview":"We do not know when and how we will die. Death Row inmates do. Werner Herzog embarks on a dialogue with Death Row inmates, asks questions about life and death and looks deep into these individuals, their stories, their crimes.","genre_ids":[99,80],"media_type":"movie","popularity":0.3858,"vote_count":277,"poster_path":"/omYLK5w7N5YeWi4gFcNTylgvL8j.jpg","release_date":"2011-11-11","vote_average":6.879,"backdrop_path":"/fFt23F1shcYqwD7QgvdapZNrTvy.jpg","original_title":"Into the Abyss","original_language":"en"},{"id":12171,"adult":false,"title":"The Deaths of Ian Stone","video":false,"overview":"Deaths tells the story of an all-American guy who is murdered each day by horrifying pursuers, only to wake up in slightly different lives to experience the terror of being murdered again.","genre_ids":[27,53],"media_type":"movie","popularity":0.8418,"vote_count":289,"poster_path":"/guhprfoix4DCKnbPeVQXuF08rHt.jpg","release_date":"2008-07-18","vote_average":5.618,"backdrop_path":"/g4YR7t02w3JPMXDQkigeJZ2u2MZ.jpg","original_title":"The Deaths of Ian Stone","original_language":"en"},{"id":12237,"adult":false,"title":"Faces of Death","video":false,"overview":"A collection of death scenes, ranging from TV-material to home-made super-8 movies. The common factor is death by some means.","genre_ids":[27,99],"media_type":"movie","popularity":1.3953,"vote_count":197,"poster_path":"/fhHzqDrdHLqjawXLXoV3w4FDOUd.jpg","release_date":"1978-11-10","vote_average":4.5,"backdrop_path":"/f81NvyLKg23gv5Rw3o7uHmupyte.jpg","original_title":"Faces of Death","original_language":"en"},{"id":27814,"adult":false,"title":"Brain Damage","video":false,"overview":"Brian co