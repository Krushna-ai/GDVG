10:T423,{"@context":"https://schema.org","@type":"Movie","name":"King of Painting","description":"Ke Huan is a talented and dreamy painter, but in this \"era of hype by all\", he became a joke in Tangzhuang, a painter village, because he was busy painting. Just when he couldn't pay the rent, was bullied by his peers, and his girlfriend was stolen by his rival, an alien changed his fate! With the help of \"it\"'s superpowers, the protagonist Ke Huan drove a luxury car, lived in a luxury house, held his dream exhibition, became a hot painter, and reached the peak of his life! The arrival of \"it\" also caused trouble everywhere, shocked the world, and caused panic among the people. The police, opponents, and even aliens came to the door one after another.","image":"https://image.tmdb.org/t/p/w500/eanTANOpYFy2Ir692wqUwdeZS6T.jpg","datePublished":"2025-03-21","numberOfEpisodes":null,"countryOfOrigin":"CN","inLanguage":"zh","genre":["Adventure","Science Fiction"],"aggregateRating":{"@type":"AggregateRating","ratingValue":6,"bestRating":10,"ratingCount":7}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"817b68e6-761c-4207-929a-2022ed38bd31","tmdb_id":1450379,"imdb_id":null,"content_type":"movie","title":"King of Painting","original_title":"大画王","overview":"Ke Huan is a talented and dreamy painter, but in this \"era of hype by all\", he became a joke in Tangzhuang, a painter village, because he was busy painting. Just when he couldn't pay the rent, was bullied by his peers, and his girlfriend was stolen by his rival, an alien changed his fate! With the help of \"it\"'s superpowers, the protagonist Ke Huan drove a luxury car, lived in a luxury house, held his dream exhibition, became a hot painter, and reached the peak of his life! The arrival of \"it\" also caused trouble everywhere, shocked the world, and caused panic among the people. The police, opponents, and even aliens came to the door one after another.","poster_path":"/eanTANOpYFy2Ir692wqUwdeZS6T.jpg","backdrop_path":"/vHKXplu3X6JNkY1WLbnloT3VDvW.jpg","release_date":"2025-03-21","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":12,"name":"Adventure"},{"id":878,"name":"Science Fiction"}],"popularity":4.1426,"vote_average":6,"vote_count":7,"runtime":0,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-27T21:42:05.58907+00:00","updated_at":"2026-02-23T13:34:26.617+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":210812,"name":"Shangxianyue Films","logo_path":null,"origin_country":"CN"}],"production_countries":[{"name":"China","iso_3166_1":"CN"}],"spoken_languages":[{"name":"普通话","iso_639_1":"zh","english_name":"Mandarin"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[],"alternative_titles":[{"type":"","title":"Da Hua Wang","iso_3166_1":"CN"}],"videos":[],"watch_providers":{"results":{"AU":{"buy":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":13}],"link":"https://www.themoviedb.org/movie/1450379/watch?locale=AU","rent":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":13}]},"CA":{"ads":[{"logo_path":"/zLYr7OPvpskMA4S79E3vlCi71iC.jpg","provider_id":73,"provider_name":"Tubi TV","display_priority":19}],"link":"https://www.themoviedb.org/movie/1450379/watch?locale=CA"},"GB":{"ads":[{"logo_path":"/gZlCYHPx9a0TRUCEeTvHXBf9ibX.jpg","provider_id":613,"provider_name":"Amazon Prime Video Free with Ads","display_priority":17}],"buy":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":7}],"link":"https://www.themoviedb.org/movie/1450379/watch?locale=GB","rent":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id