h":801,"height":360,"file_path":"/1pAP0pTMeAlkOPekZUMC4QlPAZN.png","iso_639_1":"zh","vote_average":0},{"width":640,"height":300,"file_path":"/4MWJGZIXDGgpIa3IpSEfgB7HDWH.png","iso_639_1":"zh","vote_average":0}],"posters":[{"width":720,"height":1080,"file_path":"/ewLQiTqnrhFlo3OFlHhltPgoClS.jpg","iso_639_1":"zh","vote_average":0},{"width":1707,"height":2560,"file_path":"/eanTANOpYFy2Ir692wqUwdeZS6T.jpg","iso_639_1":"en","vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/vHKXplu3X6JNkY1WLbnloT3VDvW.jpg","iso_639_1":null,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/ywBIZBL0zBPkZdTuJVt4d39wcXb.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T03:44:42.112+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":126,"tagline":"","homepage":"","overview":"柯奂是一个有才华、有梦想的画家，但在这个“全民炒作时代”，埋头苦画的他成了画家村唐庄的一个笑话。就在他交不起房租、被同行欺辱、女朋友被对手撬走的人生最低谷，一个天外来客改变了他的命运！主人公柯奂在“它”的超能力帮助下开上了豪车，住上了豪宅，举办了梦寐以求的画展，成了炙手可热的画家，走上人生巅峰！“它”的到来也处处闯祸，惊呆世人，引起了全民恐慌，警察、对手，甚至外星人都纷纷找上门来……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"King of Painting","runtime":0,"tagline":"","homepage":"","overview":"Ke Huan is a talented and dreamy painter, but in this \"era of hype by all\", he became a joke in Tangzhuang, a painter village, because he was busy painting. Just when he couldn't pay the rent, was bullied by his peers, and his girlfriend was stolen by his rival, an alien changed his fate! With the help of \"it\"'s superpowers, the protagonist Ke Huan drove a luxury car, lived in a luxury house, held his dream exhibition, became a hot painter, and reached the peak of his life! The arrival of \"it\" also caused trouble everywhere, shocked the world, and caused panic among the people. The police, opponents, and even aliens came to the door one after another."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Vua Vẽ Tranh","runtime":0,"tagline":"","homepage":"","overview":"Nhân vật chính Kha Hoán (do Lý Khắc Long thủ vai) là một họa sĩ tài năng, đầy đam mê, nhưng trong thời đại mà mọi thứ đều bị thương mại hóa và chiêu trò, một người chỉ biết cắm cúi vẽ tranh như anh lại trở thành trò cười tại làng họa sĩ Đường Trang. Khi rơi xuống đáy vực của cuộc đời, không đủ tiền thuê nhà, bị đồng nghiệp khinh thường, bạn gái bị đối thủ cướp mất, Kha Hoán ngỡ như không còn lối thoát. Nhưng đúng lúc tuyệt vọng nhất, một vị khách đến từ ngoài hành tinh đã thay đổi số phận của anh…!"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"ราชานักวาด","runtime":0,"tagline":"","homepage":"","overview":"ตัวเอก เคอห้วน (รับบทโดย หลี่เค่อหลง) เป็นจิตรกรผู้มีความสามารถและมีความทะเยอทะยานสูง แต่ใน \"ยุคสมัยที่ชาตินิยม\" นี้ เขาได้กลายเป็นตัวตลกในหมู่บ้านถังซึ่งเป็นหมู่บ้านของจิตรกร เนื่องจากเขาหมกมุ่นอยู่กับการวาดภาพ ในจุดต่ำสุดในชีวิต เขาจ่ายค่าเช่าบ้านไม่ได้ ถูกเพื่อนร่วมงานรังแก และแฟนสาวถูกคู่แข่งแย่งไป ผู้มาเยือนจากนอกโลกได้เปลี่ยนแปลงโชคชะตาของเขา..."},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Великий художник","runtime":0,"tagline":"","homepage":"","overview":"Кэ Хуань - талантливый и амбициозный художник. Но в районе художников Танчжуан он был целью для насмешек, жил на самом дне бедности, не мог оплачивать аренду жилья, подвергался издевательствам соперников и владельца местного выставочного зала. Его девушку увёл соперник, который, к тому же, использовал Кэ Хуаня. В минуты его отчаяния внезапно появившиеся инопланетные гости изменили как его судьбу, так и судьбы его друзей. С помощью «волшебного подарка» Кэ Хуань становится безумно богатым, переезжает в особняк, проводит художественную выставку, о которой всегда мечтал и как востребованный художник достигает вершины славы. Однако почему-то его удача вызвала панику среди людей. Полиция, враги, и даже инопланетяне, один за другим пришли к его порогу за разъяснениями."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"大畫王","runtime":0,"tagline":"","homepage":"","overview":"柯奐是一個有才華、有夢想的畫家，但在這個“全民炒作時代”，埋頭苦畫的他成了畫家村唐莊的一個笑話。就在他交不起房租、被同行欺辱、女朋友被對手撬走的人生最低谷，一個天外來客改變了他的命運！主人公柯奐在“它”的超能力幫助下開上了豪車，住上了豪宅，舉辦了夢寐以求的畫展，成了炙手可熱的畫家，走上人生巔峰！“它”的到來也處處闖禍，驚呆世人，引起了全民恐慌，警察、對手，甚至外星人都紛紛找上門來……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Ke Huan je talentovaný a zasněný malíř, ale v této „době všeobecného humbuku“ se stal terčem posměchu v malířské vesnici Tangzhuang, protože se věnoval malování. Právě když nemohl zaplatit nájem, byl šikanován svými vrstevníky a jeho přítelkyně mu byla odlouděna rivalem, změnil jeho osud mimozemšťan! S pomocí „toho“ superhrdiny řídil protagonista Ke Huan luxusní auto, bydlel v luxusním domě, uspořádal svou vysněnou výstavu, stal se populárním malířem a dosáhl vrcholu svého života! Příchod „toho“ také způsobil potíže všude, šokoval svět a vyvolal paniku mezi lidmi. Policie, protivníci a dokonce i mimozemšťané přišli jeden po druhém."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"}],"reviews_tmdb":[],"recommendations":[{"id":1431009,"adult":false,"title":"Throne of Seal The Movie: The Crownless God","video":false,"overview":"The legendary epic of Elekes, re - presenting the glorious path of the great Necromancer of the Undead Scourge, Elekes.","genre_ids":[16,14,12,28],"media_type":"movie","popularity":1.0292,"vote_count":2,"poster_path":"/phhFyKAnl8OH3Cf3TOxCoDwplF0.jpg","release_date":"2025-04-30","vote_average":9,"backdrop_path":"/vgfoc68kjAk5Nkkgp41BNV1GNKb.jpg","original_title":"神印王座剧场版：伊莱克斯传奇","original_language":"zh"},{"id":583984,"adult":false,"title":"Re-Elected","video":false,"overview":"Friends battle former U.S. presidents when they come back from the dead as zombies on the Fourth of July.","genre_ids":[27,35],"media_type":"movie","popularity":2.2612,"vote_count":84,"poster_path":"/iZqYQwRve5DSPopmZWdyvY9DVMx.jpg","release_date":"2020-07-04","vote_average":6.875,"backdrop_path":"/n5zliNGIDyG1k0IkUo3o4XUJFgI.jpg","original_title":"Re-Elected","original_language":"en"},{"id":173731,"adult":false,"title":"The Cave of the Golden Rose 3","video":false,"overview":"The powerful evil wizard Tarabas gets knowledge about a prophecy that a king's child will defeat him. So he sends out his army of dead soldiers to kidnap all royal children. When the soldiers attack Fantaghiro's castle to steal the babies of her sisters, the battle seems to be lost until she discovers the secret to defeat the solders but by doing that she loses Romualdo. Now Fantaghiro must find the evil wizard Tarabas and convince him to break the spell and bring back Romualdo.","genre_ids":[12,10751,14,10749],"media_type":"movie","popularity":0.9828,"vote_count":103,"poster_path":"/3xRkLoMRxCbL3AN17KUdjZ5heLD.jpg","release_date":"1993-12-20","vote_average":6.3,"backdrop_path":"/r6Ddjy5H1LFWbW0BgQ83dFX5Cqr.jpg","original_title":"Fantaghirò 3","original_language":"it"},{"id":11708,"adult":false,"title":"Chitty Chitty Bang Bang","video":false,"overview":"A hapless inventor finally finds success with a flying car, which a dictator from a foreign government sets out to take for himself.","genre_ids":[10751,12,14,35],"media_type":"movie","popularity":2.2381,"vote_count":719,"poster_path":"/wJ62FzGeCAs6PjCIK1as6xzdIY5.jpg","release_date":"1968-12-17","vote_average":6.818,"backdrop_path":"/vOl8p3u3MKjACtpTn6CV3BB7HY.jpg","original_title":"Chitty Chitty Bang Bang","original_language":"en"},{"id":10197,"adult":false,"title":"Nine","video":false,"overview":"Arrogant, self-centered movie director Guido Contini finds himself struggling to find meaning, purpose, and a script for his latest film endeavor. With only a week left before shooting begins, he desperately searches for answers and inspiration from his wife, his mistress, his muse, and his mother.","genre_ids":[18,10402,10749],"media_type":"movie","popularity":1.5662,"vote_count":624,"poster_path":"/bSxdTXktgPQPNwlkQ0DZtuAJXlb.jpg","release_date":"2009-12-03","vote_average":5.522,"backdrop_path":"/3ixn2R4tPEUQuq5AWw5EngopyWZ.jpg","original_title":"Nine","original_language":"en"},{"id":52408,"adult":false,"title":"Tomie: Rebirth","video":false,"overview":"Young art student Hideo paints an unnerving portrait of Tomie, who whispers that she loves him. Inexplicably, he reacts by stabbing her to death with a painting trowel. Two friends, Takumi and Shunichi, arrive on the scene and help him dispose of the body. To cheer him up, the boys take the unwitting murderer to the nearest bar for a party... but a mysterious girl named Tomie shows up, bearing a few odd physical resemblances to the dead girl in the ground.","genre_ids":[27],"media_type":"movie","popularity":2.8656,"vote_count":98,"poster_path":"/zJ16L8nW2ouQmV0DQ2yebICIPy6.jpg","release_date":"2001-03-24","vote_average":7.168,"backdrop_path":"/uzmtRCDGsZAGFiY8BJcSspNS7RP.jpg","original_title":"富江 re-birth","original_language":"ja"},{"id":414119,"adult":false,"title":"What's New Scooby-Doo? Vol. 3: Halloween Boos and Clues","video":true,"overview":"4 TV Episodes Spectacle!","genre_ids":[16,35,10751,9648],"media_type":"movie","popularity":0.3833,"vote_count":52,"poster_path":"/82rIIU5ahaJJu7Ul5FsTjBfvI6l.jpg","release_date":"2004-08-10","vote_average":9.9,"backdrop_path":null,"original_title":"What's New Scooby-Doo? Vol. 3: Halloween Boos and Clues","original_language":"en"},{"id":16340,"adult":false,"title":"Rugrats in Paris: The Movie","video":false,"overview":"A group of rambunctious toddlers travel a trip to Paris. As they journey from the Eiffel Tower to Notre Dame, they learn new lessons about trust, loyalty and love.","genre_ids":[10751,35,12,16],"media_type":"movie","popularity":1.9456,"vote_count":481,"poster_path":"/grIL8mvfLznaWsv7EEEPhCpkH81.jpg","release_date":"2000-11-17","vote_average":6.67,"backdrop_path":"/4JbPQv5