5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The King of Snipers\",\"description\":\"The genius sniper Anna is forced to accept an assassination assignment. In the process, she gradually finds her true calling to fight for kindness and to defend a greater love. Tai, a special agent for the UN army, stands up for justice when drug lords try to harm innocent citizens. The two join forces to block the bill to legalize drug cultivation and distribution in Libiwala. They fight to the death with the drug lord Luo Jie and eventually foil his plans, protecting the people from the drugs. This is the exciting story of them working together to save a nation.\",\"image\":\"https://image.tmdb.org/t/p/w500/r5C85R0Bc6RL51PnPv2HIvpSMJ7.jpg\",\"datePublished\":\"2023-01-24\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Action\",\"Crime\",\"Comedy\",\"War\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.6,\"bestRating\":10,\"ratingCount\":10}}"}}],["$","$L10",null,{"initialDrama":{"id":"a066e8d6-a79d-40aa-908f-90c1fca5e3aa","tmdb_id":1078023,"imdb_id":"tt26748976","content_type":"movie","title":"The King of Snipers","original_title":"狙击之王：暗杀","overview":"The genius sniper Anna is forced to accept an assassination assignment. In the process, she gradually finds her true calling to fight for kindness and to defend a greater love. Tai, a special agent for the UN army, stands up for justice when drug lords try to harm innocent citizens. The two join forces to block the bill to legalize drug cultivation and distribution in Libiwala. They fight to the death with the drug lord Luo Jie and eventually foil his plans, protecting the people from the drugs. This is the exciting story of them working together to save a nation.","poster_path":"/r5C85R0Bc6RL51PnPv2HIvpSMJ7.jpg","backdrop_path":"/lkOrEPIbNTt6s7I2qcYNtABjcaU.jpg","release_date":"2023-01-24","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":28,"name":"Action"},{"id":80,"name":"Crime"},{"id":35,"name":"Comedy"},{"id":10752,"name":"War"}],"popularity":6.2246,"vote_average":5.6,"vote_count":10,"runtime":98,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:52:05.665158+00:00","updated_at":"2026-02-21T07:12:53.792+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[],"production_countries":[{"name":"China","iso_3166_1":"CN"}],"spoken_languages":[{"name":"普通话","iso_639_1":"zh","english_name":"Mandarin"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[{"id":1589,"name":"sniper"},{"id":782,"name":"assassin"},{"id":13065,"name":"soldier"},{"id":14964,"name":"drugs"},{"id":18026,"name":"drug lord"},{"id":162365,"name":"military"},{"id":235245,"name":"assassination team"},{"id":246238,"name":"guns"},{"id":307161,"name":"snipers"},{"id":323114,"name":"crime"}],"alternative_titles":[{"type":"","title":"狙击之王2","iso_3166_1":"CN"},{"type":"","title":"King of Snipers","iso_3166_1":"US"},{"type":"","title":"ลอบสังหารราชาสไนเปอร์","iso_3166_1":"TH"}],"videos":[{"id":"640edb962a09bc00e8455ed3","key":"2Q1DvnDlxMY","name":"TRAILER：超强女狙击手就位，三千米爆头绝命美艳！1月24日，杨杏麦亨利合体搏命暗杀！  |【狙击之王：暗杀 The King of Snipers】| YOUKU MOVIE | 优酷电影","site":"YouTube","size":1080,"type":"Trailer","official":false,"iso_639_1":"en","iso_3166_1":"US","published_at":"2023-01-16T10:30:01.000Z"}],"watch_providers":{"results":{}},"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/r5C85R0Bc6RL51PnPv2HIvpSMJ7.jpg","images":{"logos":[],"posters":[{"width":800,"height":1200,"file_path":"/r5C85R0Bc6RL51PnPv2HIvpSMJ7.jpg","iso_639_1":null,"vote_average":3.334},{"width":1080,"height":1620,"file_path":"/tPz8qWfMHQUHvt5nWE3EFmlEfac.jpg","iso_639_1":null,"vote_average":0},{"width":770,"height":1080,"file_path":"/82xapKvFtkKsRMWpByEgDBEb3Gv.jpg","iso_639_1":null,"vote_average":0},{"width":1999,"height":2851,"file_path":"/giGoDW0MDqk9MphJnt0lp76298p.jpg","iso_639_1":null,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/lkOrEPIbNTt6s7I2qcYNtABjcaU.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/8EKfsdXIn1kw7HmcKh1SPhibofV.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/n12eLe4tU5UQNHTPwUBwacWqOjZ.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T07:15:56.405+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":97,"tagline":"","homepage":"","overview":"　　讲述天才女狙击手安娜被迫接受刺杀任务，在执行过程中逐渐觉醒为善良、大爱的正义战士，联合军方特工阿泰在面对毒枭迫害百姓时挺身而出、声张正义。二人联手阻止利比瓦拉国毒品种植和贩卖合法化法案通过，与毒枭大反派罗杰展开生死对战，最终粉碎反派阴谋，保护百姓不受毒品侵害，挽救国家的热血故事。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"The King of Snipers","runtime":98,"tagline":"","homepage":"","overview":"The genius sniper Anna is forced to accept an assassination assignment. In the process, she gradually finds her true calling to fight for kindness and to defend a greater love. Tai, a special agent for the UN army, stands up for justice when drug lords try to harm innocent citizens. The two join forces to block the bill to legalize drug cultivation and distribution in Libiwala. They fight to the death with the drug lord Luo Jie and eventually foil his plans, protecting the people from the drugs. This is the exciting story of them working together to save a nation."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"저격지왕: 암살","runtime":0,"tagline":"","homepage":"","overview":""},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"ملك القناصين","runtime":0,"tagline":"","homepage":"","overview":"تدور احداث الفيلم حول ( آن نا )القناصة العبقرية على أجبارها على قبول مهمة اغتيال. وفي هذه العملية، تجد تدريجيا دعوتها الحقيقية للقتال من أجل اللطف والدفاع عن حب أكبر. تاي، العميل الخاص لجيش الأمم المتحدة، يدافع عن العدالة عندما يحاول أباطرة المخدرات إيذاء المواطنين الأبرياء، يتحد الاثنان لإعاقة مشروع القانون لإضفاء الشرعية على زراعة المخدرات وتوزيعها في ليبيوالا. يقاتلون حتى الموت مع زعيم المخدرات لوه جي وفي النهاية يحبطون خططه، وحماية الناس من المخدرات. هذه قصة مثيرة عن عملهم معا لإنقاذ أمة."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Król snajperów","runtime":0,"tagline":"","homepage":"","overview":"Oddział chińskich żołnierzy wpada w japońską zasadzkę. Ren zostaje poważnie ranny i uratowany przez bandytów."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"狙擊之王：暗殺","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"ราชาสไนเปอร์","runtime":0,"tagline":"","homepage":"","overview":"แอนนานักแม่นปืนหญิงผู้มีพรสวรรค์ถูกบังคับให้รับภารกิจลอบสังหารและค่อยๆตื่นขึ้นมาเป็นนักสู้เพื่อความยุติธรรมที่ใจดีและรักในระหว่างกระบวนการประหารชีวิตตัวแทนทหารร่วม Artai ยืนหยัดและเรียกร้องความยุติธรรมเมื่อเผชิญกับการกดขี่ข่มเหงจากเจ้าพ่อยาเสพติดทั้งสองร่วมมือกันขัดขวางการผ่านกฎหมายว่าด้วยการทำให้การเพาะปลูกและการค้ายาเสพติดถูกกฎหมายในลิบิวาลาและเริ่มการต่อสู้แบบเอาเป็นเอาตายกับเจ้าวายร้ายเจ้าพ่อโรเจอร์ในที่สุดก็ทำลายแผนสมรู้ร่วมคิดของคนร้ายปกป้องผู้คนจากยาเสพติดและกอบกู้ชาติ"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"狙擊之王：暗殺","runtime":0,"tagline":"","homepage":"","overview":"講述天才女狙擊手安娜被迫接受刺殺任務，在執行過程中逐漸覺醒為善良、大愛的正義戰士，聯合軍方特工阿泰在面對毒梟迫害百姓時挺身而出、聲張正義。二人聯手阻止利比瓦拉國毒品種植和販賣合法化法案通過，與毒梟大反派羅傑展開生死對戰，最終粉碎反派陰謀，保護百姓不受毒品侵害，挽救國家的熱血故事。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":934632,"adult":false,"title":"Rebel Moon - Part Two: The Scargiver","video":false,"overview":"The rebels gear up for battle against the ruthless forces of the Motherworld as unbreakable bonds are forged, heroes emerge — and legends are made.","genre_ids":[878,28,12],"media_type":"movie","popularity":4.09,"vote_count":1415,"poster_path":"/95gnJZIk2rEkMO0Ch46x5CVjnms.jpg","release_date":"2024-04-19","vote_average":6.055,"backdrop_path":"/tpiqEVTLRz2Mq7eLq5DT8jSrp71.jpg","original_title":"Rebel Moon - Part Two: The Scargiver","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":21.4528,"vote_count":11363,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.036,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":693134,"adult":false,"title":"Dune: Part Two","video":false,"overview":"Follow the mythic journey of Paul Atreides as he unites with Chani and the Fremen while on a path of revenge against the conspirators who destroyed his family. Facing a choice between the love of his life and the fate of the known universe, Paul endeavors to prevent a terrible future only he can foresee.","genre_ids":[878,12],"media_type":"movie","popularity":23.1578,"vote_count":7533,"poster_path":"/1pdfLvkbY9ohJlCjQH2CZjjYVvJ.jpg","release_date":"2024-02-27","vote_average":8.132,"backdrop_path":"/ylkdrn23p3gQcHx7ukIfuy2CkTE.jpg","original_title":"Dune: Part Two","original_language":"en"},{"id":475557,"adult":false,"title":"Joker","video":false,"overview":"During the 1980s, a failed stand-up comedian is driven insane and turns to a life of crime and chaos in Gotham City while becoming an infamous psychopathic crime figure.","genre_ids":[80,53,18],"media_type":"movie","popularity":20.7457,"vote_count":27317,"poster_path":"/udDclJoHjfjb8Ekgsd4FDteOkCU.jpg","release_date":"2019-10-01","vote_average":8.128,"backdrop_path":"/hO7KbdvGOtDdeg0W4Y5nKEHeDDh.jpg","original_title":"Joker","original_language":"en"},{"id":264660,"adult":false,"title":"Ex Machina","video":false,"overview":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl.","genre_ids":[18,878],"media_type":"movie","popularity":7.7763,"vote_count":14029,"poster_path":"/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg","release_date":"2015-01-21","vote_average":7.573,"backdrop_path":"/uqOuJ50EtTj7kkDIXP8LCg7G45D.jpg","original_title":"Ex Machina","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":29.5562,"vote_count":26800,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.9,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":11324,"adult":false,"title":"Shutter Island","video":false,"overview":"World War II soldier-turned-U.S. Marshal Teddy Daniels investigates the disappearance of a patient from a hospital for the criminally insane, but his efforts are compromised by troubling visions and a mysterious doctor.","genre_ids":[18,53,9648],"media_type":"movie","popularity":15.0553,"vote_count":25436,"poster_path":"/nrmXQ0zcZUL8jFLrakWc90IR8z9.jpg","release_date":"2010-02-14","vote_average":8.2,"backdrop_path":"/8xt8AMb1OKC63AdhNSaYBWxB4Iq.jpg","original_title":"Shutter Island","original_language":"en"},{"id":577922,"adult":false,"title":"Tenet","video":false,"overview":"Armed with only one word - Tenet - and fighting for the survival of the entire world, the Protagonist journeys through a twilight world of international espionage on a mission that will unfold in something beyond real time.","genre_ids":[28,53,878],"media_type":"movie","popularity":9.3849,"vote_count":10855,"poster_path":"/aCIFMriQh8rvhxpN1IWGgvH0Tlg.jpg","release_date":"2020-08-22","vote_average":7.2,"backdrop_path":"/yY76zq9XSuJ4nWyPDuwkdV7Wt0c.jpg","original_title":"Tenet","original_language":"en"},{"id":297222,"adult":false,"title":"PK","video":false,"overview":"A stranger in the city asks questions no one has asked before. Known only by his initials, the man's innocent questions and childlike curiosity take him on a journey of love, laughter and letting go.","genre_ids":[35,18,878],"media_type":"movie","popularity":5.6684,"vote_count":1118,"poster_path":"/z2x2Y4tncefsIU7h82gmUM5vnBJ.jpg","release_date":"2014-12-18","vote_average":7.707,"backdrop_path":"/gxfvtq5eYiClS2X7hxAAPBNrbWA.jpg","original_title":"पीके","original_language":"hi"},{"id":361743,"adult":false,"title":"Top Gun: Maverick","video":false,"overview":"After more than thirty years of service as one of the Navy’s top aviators, and dodging the advancement in rank that would ground him, Pete “Maverick” Mitchell finds himself training a detachment of TOP GUN graduates for a specialized mission the likes of which no living pilot has ever seen.","genre_ids":[28,18],"media_type":"movie","popularity":20.6156,"vote_count":10594,"poster_path":"/62HCnUTziyWcpDaBO2i1DX17ljH.jpg","release_date":"2022-05-21","vote_average":8.156,"backdrop_path":"/AaV1YIdWKnjAIAOe8UUKBFm327v.jpg","original_title":"Top Gun: Maverick","original_language":"en"},{"id":575264,"adult":false,"title":"Mission: Impossible - Dead Reckoning Part One","video":false,"overview":"Ethan Hunt and his IMF team embark on their most dangerous mission yet: To track down a terrifying new weapon that threatens all of humanity before it falls into the wrong hands. With control of the future and the world's fate at stake and dark forces from Ethan's past closing in, a deadly race around the globe begins. Confronted by a mysterious, all-powerful enemy, Ethan must consider that nothing can matter more than his mission—not even the lives of those he cares about most.","genre_ids":[28,53,12],"media_type":"movie","popularity":12.5395,"vote_count":4925,"poster_path":"/NNxYkU70HPurnNCSiCjYAmacwm.jpg","release_date":"2023-07-08","vote_average":7.508,"backdrop_path":"/628Dep6AxEtDxjZoGP78TsOxYbK.jpg","original_title":"Mission: Impossible - Dead Reckoning Part One","original_language":"en"},{"id":49046,"adult":false,"title":"All Quiet on the Western Front","video":false,"overview":"Paul Baumer and his friends Albert and Muller, egged on by romantic dreams of heroism, voluntarily enlist in the German army. Full of excitement and patriotic fervour, the boys enthusiastically march into a war they believe in. But once on the Western Front, they discover the soul-destroying horror of World War I.","genre_ids":[10752,36,18],"media_type":"movie","popularity":7.3883,"vote_count":4519,"poster_path":"/2IRjbi9cADuDMKmHdLK7LaqQDKA.jpg","release_date":"2022-10-07","vote_average":7.721,"backdrop_path":"/zbOlpFM306PHE7EP1OELCH5qSmS.jpg","original_title":"Im Westen nichts Neues","original_language":"de"},{"id":945961,"adult":false,"title":"Alien: Romulus","video":false,"overview":"While scavenging the deep ends of a derelict space station, a group of young space colonizers come face to face with the most terrifying life form in the universe.","genre_ids":[27,878],"media_type":"movie","popularity":13.8151,"vote_count":4292,"poster_path":"/2uSWRTtCG336nuBiG8jOTEUKSy8.jpg","release_date":"2024-08-13","vote_average":7.171,"backdrop_path":"/iYqSQaWDttQIQzsxg9xHyg0bttG.jpg","original_title":"Alien: Romulus","original_language":"en"},{"id":530915,"adult":false,"title":"1917","video":false,"overview":"At the height of the First World War, two young British soldiers must cross enemy territory and deliver a message that will stop a deadly attack on hundreds of soldiers.","genre_ids":[10752,36,18,28,12],"media_type":"movie","popularity":7.6928,"vote_count":13294,"poster_path":"/iZf0KyrE25z1sage4SYFLCCrMi9.jpg","release_date":"2019-12-25","vote_average":8,"backdrop_path":"/2lBOQK06tltt8SQaswgb8d657Mv.jpg","original_title":"1917","original_language":"en"},{"id":495764,"adult":false,"title":"Birds of Prey (and the Fantabulous Emancipation of One Harley Quinn)","video":false,"overview":"Harley Quinn joins forces with a singer, an assassin and a police detective to help a young girl who had a hit placed on her after she stole a rare diamond from a crime lord.","genre_ids":[28,80],"media_type":"movie","popularity":8.0422,"vote_count":10689,"poster_path":"/h4VB6m0RwcicVEZvzftYZyKXs6K.jpg","release_date":"2020-02-05","vote_average":6.885,"backdrop_path":"/uozb2VeD87YmhoUP1RrGWfzuCrr.jpg","original_title":"Birds of Prey (and the Fantabulous Emancipation of One Harley Quinn)","original_language":"en"},{"id":940721,"adult":false,"title":"Godzilla Minus One","video":false,"overview":"In postwar Japan, Godzilla brings new devastation to an already scorched landscape. With no military intervention or government help in sight, the survivors must join together in the face of despair and fight back against an unrelenting horror.","genre_ids":[878,27,28],"media_type":"movie","popularity":8.4921,"vote_count":2999,"poster_path":"/2E2WTX0TJEflAged6kzErwqX1kt.jpg","release_date":"2023-11-03","vote_average":7.583,"backdrop_path":