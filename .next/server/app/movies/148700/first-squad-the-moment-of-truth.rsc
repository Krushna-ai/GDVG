BuUMbVkUefP.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":1,"aspect_ratio":0.694,"vote_average":3.334},{"width":2000,"height":3000,"file_path":"/m4zltJFwn5Xye7KjQOzNytVW6S0.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":2000,"height":3000,"file_path":"/mh2DUD5iHNs9VR8kxxJ8yVgZD0N.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":683,"height":1024,"file_path":"/qAMfEwS4WbTMaGuH9GDC2zNx1jZ.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1102,"height":1653,"file_path":"/axwP67tbsJwGrQTZfEotyNQsArc.jpg","iso_639_1":"af","iso_3166_1":"ZA","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":600,"height":800,"file_path":"/lgylqeZP6pFQQmH7M9AwyoLhfoJ.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.75,"vote_average":0},{"width":960,"height":1440,"file_path":"/hBj1aTnGf4564Klv9yIbSuB7Y8w.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/3k1PKmzNEosWFaOR1yC9ZKIYqmm.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T02:55:55.746+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"First Squad: The Moment of Truth","runtime":73,"tagline":"","homepage":"http://www.first-squad.com","overview":"Set during the opening days of World War II on the Eastern Front. Its main cast are a group of Soviet teenagers with extraordinary abilities; the teenagers have been drafted to form a special unit to fight the invading German army. They are opposed by a Schutzstaffel officer who is attempting to raise from the dead a supernatural army of crusaders from the 12th-century Order of the Sacred Cross."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"1942 год. Россия – единственная страна, которой удается противостоять нашествию нацистских захватчиков. Параллельно с боевыми действиями между регулярными армиями разворачивается скрытая война двух секретных оккультных служб, двух специальных военных ведомств – немецкого «Аненербе» и русского 6-го отдела военной разведки. На вооружении этих подразделений не танки и самолеты, а законы магии и волшебства. Древнее заклинание позволяет магам «Аненербе» вызвать из царства мертвых дух великого магистра ордена Меча крестоносца барона фон Вольфа, павшего 700 лет назад в ходе Ледового побоища. Начальник советской разведки, генерал Белов, решает подключить к операции по противодействию барона фон Вольфа одного из своих самых одаренных агентов – четырнадцатилетнюю девочку Надю, которая вызывает из потустороннего мира своих погибших друзей – пионеров-героев, казненных фашистами в самом начале войны..."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"First Squad - Il momento della verità","runtime":58,"tagline":"","homepage":"","overview":"First Squad è un'opera particolare nata da un'idea di due autori russi e animata dallo studio giapponese 4°C. La storia è ambientata nella Russia del 1942, nel momento più duro della guerra contro i nazisti. Nadya è una ragazza con poteri di chiaroveggenza, membro di un'unità speciale dell'Armata Rossa che fa uso di poteri paranormali per cercare di contrastare le strategie occulte messe in piedi dagli stregoni delle SS."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"First Squad: The Moment of Truth","runtime":73,"tagline":"","homepage":"","overview":"Set i løbet af de indledende dage af Anden Verdenskrig på østfronten. Dets vigtigste cast er en gruppe af sovjetiske teenagere med ekstraordinære evner, teenagere er blevet udarbejdet for at danne en særlig enhed til at bekæmpe den invaderende tyske hær. De er modstandere af et Schutzstaffel officer, der forsøger at rejse fra de døde en overnaturlig hær af korsfarere fra bekendtgørelse af den Hellige Kors 12. århundrede."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"First Squad - Le Moment de Vérité","runtime":72,"tagline":"","homepage":"","overview":"Sur le front de l'Est, le conflit perdure entre les armées allemandes et soviétiques, contraintes à une guerre de position pendant l'hiver. Parallèlement à ce combat, une autre bataille se joue à coup de pouvoirs occultes: Du côté des SS, l'Ahnenerbe se lance dans la résurrection du baron von Wolff, un chevalier tué en Russie, il y a 700 ans avec ses hommes. Le renfort d'une armée de morts vivants devrait faire basculer la balance du côté allemand.Pour contrer ce plan, la section 6 des services secrets soviétiques compte sur sa pièce maîtresse, Nadia, une jeune fille dotée de pouvoirs paranormaux. Envoyée sur le front, sous couverture, Nadia est cependant victime d'une attaque aérienne, qui la laisse amnésique et coupée de sa base. Elle est en plus pourchassée par des tueuses de l'Ahnenerbe , qui cherche à éliminer tous les membres de la section 6."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"First Squad - Moment der Wahrheit","runtime":73,"tagline":"","homepage":"","overview":"Nadya ist ein ganz besonderes 14-jähriges Mädchen: aufgrund ihrer außergewöhnlichen übersinnlichen Fähigkeiten und ihrer Ausbildung als Profikillerin, rekrutiert die russische Armee sie während des Zweiten Weltkriegs und teilt sie dem First Squad zu, einer auf die Bekämpfung paranormaler Kräfte spezialisierten Einheit. Als einzige Überlebende eines brutalen Angriffs wird ihr eine Sondermission übertragen: Sie soll ihre Kameraden aus dem Jenseits zurückholen, um Von Wolff zu vernichten, einen 700 Jahre alten Geist, der zum Leben erweckt wurde, um den Nazis zu helfen, die Welt zu erobern."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":73,"tagline":"","homepage":"","overview":"De film speelt zich af tijdens het begin van de Tweede Wereldoorlog op het oostelijke front. Een groep tieners, met speciale krachten, uit de Sovjet-Unie, vormen een speciaal team die zich inzetten tegen de Duitsers. Hun grootste probleem is een SS-officier, die probeert een leger met bovennatuurlijke krachten te creëren door kruisvaarders uit de twaalfde eeuw uit de dood terug te brengen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Primer Escuadrón","runtime":60,"tagline":"","homepage":"","overview":"En 1942 el combate que mantiene Alemania con Rusia parece no tener fin y ambos países comenzarán a desarrollar unidades especializadas en la magia y el ocultismo. Nadya, una joven medium, se convertirá en la mejor arma del ejército ruso para solventar a su favor ‘el momento de la verdad’, el segundo decisivo en que una batalla se gana o se pierde."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"First Squad: A Hora da Verdade","runtime":0,"tagline":"","homepage":"","overview":"Nadya é uma menina especial com apenas 14 anos de idade. Com seus incríveis poderes psíquicos e treinamento para ser assassina, ela é recrutada pelo exército russo durante a Segunda Guerra para integrar a First Squad, uma unidade especial de combate especializada em combater forças paranormais. Quando só ela sobrevive á um ataque brutal, ela volta para a unidade para um projeto especial – ressuscitar os outros integrantes para combater Von Wolf, um espírito velho de 700 anos que voltou à vida para ajudar os nazistas a dominar o mundo."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"제1부대, 진실의 순간","runtime":0,"tagline":"","homepage":"","overview":"1942년 구소련의 적군(赤軍)이 독일인에 맞서 저항하고 있다. 나디아는 공습으로 인한 탄환 충격에 시달리지만 곧 그녀의 새로운 재능을 발견한다. 그것은 바로 ‘진실의 순간들’을 예견할 수 있는 능력으로, 그녀는 미래의 전투에서 가장 결정적인 순간들과 조우하게 된다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"ファーストスクワッド","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Први одред: Тренутак истине","runtime":0,"tagline":"","homepage":"","overview":"Радња филма се одвија током 1942. године, негде на Источном фронту. Немачки окултисти из групе Аненербе призивају из загробног света злог грофа фон Вулфа, уз чију помоћ се надају да ће коначно пробити одбрану совјетске војске. Али ни руска страна не седи скрштених руку, па у бој шаље своје најбоље агенте: пионире 6. одреда војно-обавештајне службе који су специјално обучени за парапсихолошки рат."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Първи отряд","runtime":55,"tagline":"","homepage":"","overview":"Действието на анимацията се развива през 1942 г. в Русия, която е успяла да се противопостави на немското нашествие. По време на разгара на бойните действия, се разразява паралелна схватка между две тайни служби - призованите от задгробния свят рицари от Ливонския орден и печално известната организация Аненербе. Те воюват с парапсихологически и окултни средства и са готови да защитават родината си на невидимия фронт."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"First Squad: A Hora da Verdade","runtime":73,"tagline":"","homepage":"","overview":"No ano de 1942, o Exército Vermelho cria uma resistência violenta e eficaz contra os invasores alemães. Nadya, uma garota  de 14 anos de idade, é uma médium. Em um ataque aéreo mortal a garota entra em estado de choque. Recuperando-se de sua  contusão, Nadya descobre seu novo dom, a capacidade de prever o “Momento da Verdade”, os momentos mais críticos de combate no futuro, em que as ações de uma pessoa decidirão o desfecho do presente de uma maneira certa ou errada.  A habilidade de Nadya é indispensável para a 6ª Divisão, uma divisão militar russa de inteligência, que estão travando  uma guerra secreta contra a “Ahnenerbe”, uma ordem oculta dentro das SS. Ahnenerbe invoca do reino dos mortos, o poderoso príncipe das trevas, o Barão Von Wolff. Com ele à seu lado eles esperam mudar o curso da história e conseguir dominar o mundo."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Перший загін","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"第一小队","runtime":73,"tagline":"","homepage":"","overview":"由日本、加拿大、俄罗斯三国携手合作。故事发生在第二次世界大战爆发几天后的东部战线，纳粹德军的党卫队司令官Martin Linz意图唤醒出十二世纪东征十字军的超能力部队，并组成幽灵军团来攻占苏联。片中的五位年轻主角Nadya、Leo、Zena、Marat、Valya是在苏联军队中接受了手术改造的异能士兵，而他们的任务即是尽全力消灭这批幽灵兵团，以击败纳粹司令官的野心。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"El primer escuadrón","runtime":0,"tagline":"","homepage":"","overview":"Nadya tiene poderes psíquicos y entrenamiento de asesina, y el ejército ruso la recluta durante la Segunda Guerra Mundial. Así se inicia el camino de una misión pavorosa."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"หน่วยพิฆาตปีศาจนาซี","runtime":0,"tagline":"","homepage":"","overview":"นัดญ่า เด็กสาววัย 14 ผู้มีพลังพิเศษ เธอมีพลังจิตที่ได้รับการฝึนฝนมาเพื่อเป็นนักฆ่า ถูกจ้างวานโดยกลุ่มทหารรัสเซียช่วงสงครามโลกครั้งที่ 2 ให้มาร่วมหน่วยรบ เฟิร์ส สควอด กองกำลังพิเศษที่เชี่ยวชาญการสู้รบกับพลังเหนือธรรมชาติ เมื่อเธอเป็นสมาชิกคนสุดท้ายที่เหลืออยู่หลังการจู่โจมครั้งใหญ่ เธอถูกนำตัวกลับมาเพื่อภารกิจใหม่ นั่นคือฟื้นชีพให้เพื่อนร่วมหน่วยมาสู้กับวอน วูล์ฟ วิญญาณอายุ 700 ปีที่นาซีปลุกให้ขึ้นมาช่วยยึดครองโลก พบกับภาพยนตร์อะนิเมชั่นแอ็คชั่นสุดมันพร้อมความเข้มข้นระทึกใจและผลงานกราฟฟิคอันน่าทึ่งจาก Studio 4°C สตูดิโอสุดเจ๋งเบื้องหลังความสำเร็จของดิ อะนิเมทริกซ์และเฮโล: เลเจนส์"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"First Squad - Le Moment de Vérité","runtime":72,"tagline":"","homepage":"","overview":"Sur le front de l'Est, le conflit perdure entre les armées allemandes et soviétiques, contraintes à une guerre de position pendant l'hiver. Parallèlement à ce combat, une autre bataille se joue à coup de pouvoirs occultes: Du côté des SS, l'Ahnenerbe se lance dans la résurrection du baron von Wolff, un chevalier tué en Russie, il y a 700 ans avec ses hommes. Le renfort d'une armée de morts vivants devrait faire basculer la balance du côté allemand.Pour contrer ce plan, la section 6 des services secrets soviétiques compte sur sa pièce maîtresse, Nadia, une jeune fille dotée de pouvoirs paranormaux. Envoyée sur le front, sous couverture, Nadia est cependant victime d'une attaque aérienne, qui la laisse amnésique et coupée de sa base. Elle est en plus pourchassée par des tueuses de l'Ahnenerbe , qui cherche à éliminer tous les membres de la section 6."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"第一小隊","runtime":0,"tagline":"","homepage":"","overview":"由日本、加拿大、俄羅斯三國攜手合作。故事發生在第二次世界大戰爆發幾天后的東部戰線，納粹德軍的黨衞隊司令官 Martin Linz 意圖喚醒出十二世紀東征十字軍的超能力部隊，並組成幽靈軍團來攻佔蘇聯。片中的五位年輕主角 Nadya、Leo、Zena、Marat、Valya 是在蘇聯軍隊中接受了手術改造的異能士兵，而他們的任務即是盡全力消滅這批幽靈兵團，以擊敗納粹司令官的野心。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Az előőrs","runtime":0,"tagline":"","homepage":"","overview":"1942 van. A Vörös Hadsereg erőszakos és hatékony ellenállást vesz fel a német támadók ellen. A 14 éves Nadja egy médium. Idegsokkot kap a halálos légi támadásban. A megrázkódtatásból felépülve Nadja új képességet fedez fel magában, képes előre látni az \"Igazság Pillanatai\"-t. A jövőbeli harc legválságosabb pillanatai csapnak össze, ahol egyetlen ember cselekedetei dönthetik el egyik vagy másik út kimenetelét. Nadja képessége nélkülözhetetlenné válik az Orosz Katonai Hírszerzés bizalmas 6. Különítménye számára, ami titkos hadviselést indít az \"Ahnenerbe\" - az SS-en belüli okkult rend ellen. Az Ahnenerbe felhívja a halottak birodalmából a sötétség hatalmas hercegét, von Wolff bárót. Vele az oldalukon azt remélik, megváltoztatják a történelem menetét és világuralomra tesznek szert. Hogy ellenálljon a bárónak, Nadja úgy dönt, segítségül hívja túlvilági barátait, az Első Szakasz Előharcosait. R3"},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"}],"reviews_tmdb":[],"recommendations":[{"id":381873,"adult":false,"title":"Accel World: Infinite Burst","video":false,"overview":"In 2046, many aspects of life are carried out on a virtual network. No matter how advanced the time becomes, however, bullying never disappears. Haruyuki is one of the bullied students. However, one day he is contacted by Kuroyukihime, the most famous person in the school. \"Wouldn't you like to 'accelerate' and go further ahead, boy?\" Haruyuki is introduced to the \"Accel World\" and decides to fight as Kuroyukihime's knight.","genre_ids":[16,28,878],"media_type":"movie","popularity":1.4869,"vote_count":50,"poster_path":"/xyya6A2M4gxFdw0bhhlOdU5kw3N.jpg","release_date":"2016-07-23","vote_average":6.62,"backdrop_path":"/vRY3TEU3aspFVVicyh8Y5zVAJkN.jpg","original_title":"アクセル・ワールド INFINITE∞BURST","original_language":"ja"},{"id":43258,"adult":false,"title":"Friendly Persuasion","video":false,"overview":"The story of a family of Quakers in Indiana in 1862. Their religious sect is strongly opposed to violence and war. It's not easy for them to meet the rules of their religion in everyday life but when Southern troops pass the area they are in real trouble. Should they fight, despite their peaceful attitude?","genre_ids":[18,10752],"media_type":"movie","popularity":1.6926,"vote_count":137,"poster_path":"/mhsdObvFHoOfgaKAVJUOeK3LiOP.jpg","release_date":"1956-10-30","vote_average":6.7,"backdrop_path":"/vRkB3lYI26YjXvMEc8IvxM45h8X.jpg","original_title":"Friendly Persuasion","original_language":"en"},{"id":589764,"adult":false,"title":"Once In The Desert","video":false,"overview":"The films follows a Syrian War Explosive Ordnance Disposal team who are targeted by ISIS militants while they prepare the recently liberated historic site of Palmyra to hold a symbolic concert of the Mariinsky Symphony Orchestra. The peacekeeping event can only be held in Palmyra that has been severely damaged by the terrorists only if the ancient city and the roads leading to it are defused. The EOD team clears the way one kilometer at a time. But the closer they get to the center of Palmyra, the more destructive the explosives. Tension grows between the young team Captain and the most experienced of the EOD experts. And yet, despite their differences, when the team falls into an ambush and the Captain goes missing, it’s the experienced sapper that sets out to search for him.","genre_ids":[10752,18],"media_type":"movie","popularity":1.0753,"vote_count":27,"poster_path":"/hnjGrFdh2FZPQGOFq9myiQuABoK.jpg","release_date":"2022-02-17","vote_average":7.037,"backdrop_path":"/b1CNQfwlyMZVQNcvFjcl0CaRoKO.jpg","original_title":"Однажды в пустыне","original_language":"ru"},{"id":343144,"adult":false,"title":"Barcelona Christmas Night","video":false,"overview":"Multiple love stories unfold in Barcelona during Christmas's Eve.","genre_ids":[10749,35,18],"media_type":"movie","popularity":0.5817,"vote_count":74,"poster_path":"/a21FeB4RLiGEXSSNqPgf6H3TzNG.jpg","release_date":"2015-12-04","vote_average":6.351,"backdrop_path":"/f0u7oOAmGC5sHyKMxAY3ARb9WFx.jpg","original_title":"Barcelona, nit d'hivern","original_language":"ca"},{"id":321211,"adult":false,"title":"Santa Company","video":false,"overview":"Noel is an 11-year-old girl who despises Christmas. She has lived with her father ever since her parents divorced three years ago, but her father ends up busy at work every Christmas and she cannot play with her friends from school.  On a lonely Christmas Eve, Noel takes her usual apartment complex elevator ride to her home, but when the doors open, she finds herself lost in a humongous factory—owned by Santa Claus. Santa Claus has gone corporate as Santa Company with the motto \"Swiftly, surely, secretly.\" The outfit takes orders and delivers top-notch presents to children in the utmost secrecy. Noel meets some new friends, and together, they take off in a sled to deliver presents.","genre_ids":[14,16],"media_type":"movie","popularity":0.5865,"vote_count":5,"poster_path":"/gEHBJSnIywHeAHyoMjOmTrNj9Fp.jpg","release_date":"2014-10-25","vote_average":5.8,"backdrop_path":"/n4toH7IFI3m7kq8wqo6F1feeEj1.jpg","original_title":"サンタ・カンパニー ～クリスマスの秘密～","original_language":"ja"},{"id":52010,"adult":false,"title":"Ultramarines: A Warhammer 40,000 Movie","video":false,"overview":"A squad of Ultramarines answer a distress call from an Imperial Shrine World. A full Company of Imperial Fists was stationed there, but there is no answer from them. The squad investigates to find out what has happened there.","genre_ids":[16,878],"media_type":"movie","popularity":0.9549,"vote_count":152,"poster_path":"/eFfkF9uVqOhAxIKEyNCHfRRdGgj.jpg","release_date":"2010-12-10","vote_average":5.832,"backdrop_path":"/oOBtTgunRkq4xKMoe7DrffHpKIf.jpg","original_title":"Ultramarines: A Warhammer 40,000 Movie","original_language":"en"},{"id":28396,"adult":false,"title":"The Valdemar Legacy","video":false,"overview":"Luisa Llorente, an expert on taxation of old buildings, had recently gone to the Victorian mansion Valdemar to conduct an inventory of property ownership. After she mysteriously disappeared, Maximilian, president of her company, engaged the services of a private detective to help find her. But soon they will discover that it is not the first disappearance at Valdemar mansion!","genre_ids":[27,9648],"media_type":"movie","popularity":0.3966,"vote_count":114,"poster_path":"/tYTe2HRLBWgHpgNfEoRASxee60C.jpg","release_date":"2010-01-22","vote_average":5.9,"backdrop_path":"/vOtyASZTONSu9TibRRTNGHPfgFA.jpg","original_title":"La herencia Valdemar","original_language":"es"},{"id":14711,"adult":false,"title":"Afro Samurai: Resurrection","video":false,"overview":"Afro Samurai avenged his father and found a life of peace. But the legendary master is forced back into the game by a beautiful and deadly woman from his past. The sparks of violence dropped along Afro’s bloody path now burn out of control – and nowhere are the flames of hatred more intense than in the eyes of Sio.","genre_ids":[16,28,12,18,14,878,10770],"media_type":"movie","popularity":1.194,"vote_count":212,"poster_path":"/6snrLj3Ydmbu5L9giAYtiSNwE0U.jpg","release_date":"2009-10-16","vote_average":6.858,"backdrop_path":"/4rNjTccVltQHKKJd6INzqHtfV5x.jpg","original_title":"Afro Samurai: Resurrection","original_language":"en"},{"id":631939,"adult":false,"title":"The Legion","video":false,"overview":"Noreno, a half-Roman, is entrusted with the mission of crossing the snowy mountains of Armenia, swarming with Parthian patrols, to seek help for his slowly dying men.","genre_ids":[12,36,28],"media_type":"movie","popularity":0.9512,"vote_count":135,"poster_path":"/6ssoBXQOxNhrsGJoM6Tcvm57V79.jpg","release_date":"2020-05-08","vote_average":6.022,"backdrop_path":"/9NlswPRK5Kap6KVr59Feah9EBLP.jpg","original_title":"The Legion","original_language":"en"},{"id":409421,"adult":false,"title":"BLAME!","video":false,"overview":"In the distant technological future, civilization has reached its ultimate Net-based form. An \"infection\" in the past caused the automated systems to spiral out of order, resulting in a multi-leveled city structure that replicates itself infinitely in all directions. Now humanity has lost access to the city's controls, and is hunted down and purged by the defense system known as the Safeguard. In a tiny corner of the city, a little enclave known as the Electro-Fishers is facing eventual extinction, trapped between the threat of the Safeguard and dwindling food supplies. A girl named Zuru goes on a journey to find food for her village, only to inadvertently cause doom when an observation tower senses her and summons a Safeguard pack to eliminate the threat. With her companions dead and all escape routes blocked, the only thing that can save her now is the sudden arrival of Killy the Wanderer, on his quest for the Net Terminal Genes, the key to restoring order to the world.","genre_ids":[28,18,878,16],"media_type":"movie","popularity":1.1272,"vote_count":346,"poster_path":"/7eoRQY7VUMawwBnuD6uwN4szc8k.jpg","release_date":"2017-05-20","vote_average":6.519,"backdrop_path":"/9orgGrjh0Jivz0zZLn1Ufj4NRZP.jpg","original_title":"ブラム","original_language":"ja"},{"id":13184,"adult":false,"title":"Bangkok Dangerous","video":false,"overview":"When carrying out a hit, assassin Joe always makes use of the knowledge of the local population. On arriving in Bangkok, Joe meets street kid Kong and he becomes his primary aide. But when Kong is nearly killed, he asks Joe to train him up in the deadly arts and unwittingly becomes a target of a band of killers.","genre_ids":[28,80,53],"media_type":"movie","popularity":0.8889,"vote_count":1079,"poster_path":"/iTRftxHW8i4H7ONaOiCIwEXjNDJ.jpg","release_date":"2008-08-21","vote_average":5.205,"backdrop_path":"/ueXbXSehnVK62UqfLrdJdWZ7gla.jpg","original_title":"Bangkok Dangerous","original_language":"en"},{"id":4464,"adult":false,"title":"Seabiscuit","video":false,"overview":"True story of the undersized Depression-era racehorse whose victories lifted not only the spirits of the team behind it but also those of their nation.","genre_ids":[18,36],"media_type":"movie","popularity":2.1434,"vote_count":911,"poster_path":"/5m7NfZvxYsSm2YBCJ2VPQf8ziKr.jpg","release_date":"2003-07-22","vote_average":7.056,"backdrop_path":"/9mxDXwoNLLX1SOeq2uiqEfGg4sN.jpg","original_title":"Seabiscuit","original_language":"en"},{"id":844417,"adult":false,"title":"Marlowe","video":false,"overview":"Private detective Philip Marlowe becomes embroiled in an investigation involving a wealthy Californian family after a beautiful blonde hires him to track down her former lover.","genre_ids":[80],"media_type":"movie","popularity":2.0839,"vote_count":424,"poster_path":"/vjAMj81oYBryzGBhJk4gcK0M636.jpg","release_date":"2023-02-15","vote_average":5.725,"backdrop_path":"/1KpCjh3hedCEX8mvxtldU0Z2IiE.jpg","original_title":"Marlowe","original_language":"en"},{"id":10122,"adult":false,"title":"Flight of the Navigator","video":false,"overview":"12-year-old David is accidentally knocked out in the forest near his home, but when he awakens eight years have passed. His family is overjoyed to have him back, but is just as perplexed as he is that he hasn't aged. When a NASA scientist discovers a UFO nearby, David gets the chance to unravel the mystery and recover the life he lost.","genre_ids":[10751,878,12],"media_type":"movie","popularity":2.6676,"vote_count":921,"poster_path":"/tdRgQWMximj0tL6OWu9kRTtePmI.jpg","release_date":"1986-07-30","vote_average":6.947,"backdrop_path":"/tg5Y6tS6gA4cLsYWMEgD8TMlEuE.jpg","original_title":"Flight of the Navigator","original_language":"en"},{"id":378108,"adult":false,"title":"In This Corner of the World","video":false,"overview":"Japan, 1943, during World War II. Young Suzu leaves her village near Hiroshima to marry and live with her in-laws in Kure, a military harbor. Her creativity to overcome deprivation quickly makes her indispensable at home. Inhabited by an ancestral wisdom, Suzu impregnates the simple gestures of everyday life with poetry and beauty. The many hardships, the loss of loved ones, the frequent air raids of the enemy, nothing alters her enthusiasm…","genre_ids":[18,16,10749,10752,36],"media_type":"movie","popularity":2.9284,"vote_count":612,"poster_path":"/9Z4H4M2F8OQTB04YC1Opds8MFBb.jpg","release_date":"2016-11-12","vote_average":7.911,"backdrop_path":"/bh5jn