9:{"metadata":[["$","title","0",{"children":"Harry Potter and the Prisoner of Azkaban | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Year three at Hogwarts means new fun and challenges as Harry learns the delicate art of approaching a Hippogriff, transforming shape-shifting Boggarts into hilarity and even turning back time. But the term also brings danger: soul-sucking Dementors hover over the school, an ally of the accursed He-Who-Cannot-Be-Named lurks within the castle walls, and fearsome wizard Sirius Black escapes Azkaban. And Harry will confront them all."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/109345/harry-potter-and-the-prisoner-of-azkaban"}],["$","meta","5",{"property":"og:title","content":"Harry Potter and the Prisoner of Azkaban"}],["$","meta","6",{"property":"og:description","content":"Year three at Hogwarts means new fun and challenges as Harry learns the delicate art of approaching a Hippogriff, transforming shape-shifting Boggarts into hilarity and even turning back time. But the term also brings danger: soul-sucking Dementors hover over the school, an ally of the accursed He-Who-Cannot-Be-Named lurks within the castle walls, and fearsome wizard Sirius Black escapes Azkaban. And Harry will confront them all."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/109345/harry-potter-and-the-prisoner-of-azkaban"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/aWxwnYoe8p2d2fcxOqtvAtJ72Rw.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Harry Potter and the Prisoner of Azkaban"}],["$","meta","12",{"