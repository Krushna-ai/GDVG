3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/mhWX9mIdAUxHrC4HlomUeQkl8dc.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/uWBG6Y7FGM0ckNlhs11EvKgJ3nB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/wPIIdbBpy6fq96QUhp1JepsaNcV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/9C257bODzyWwjTPTYkue1pG1qMd.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/49J0RL1ookPqfjbVjr2P2Zxzmsf.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/7DAoCqwkMYD1ydSl09jbxCUIcYo.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/9PIV1gelH6WJiR0VC65XopBGFro.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":2048,"height":1152,"file_path":"/e42JjxITFISaZ0na0uU1iVoCuJZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":0.166},{"width":1300,"height":731,"file_path":"/kJkzG0jE7z4GnkDG7RPF1VmCaTU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/sasZQs6B1eerbxJ4OlbPgW4aMeD.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/rEqA9FWbXHwL4Aj4HmTNSvVtccO.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1300,"height":730,"file_path":"/r3DraWvfRp5IkPcIqhBJDpestk2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.781,"vote_average":0},{"width":1628,"height":916,"file_path":"/mBaPz3Zlhlm1TYG7z5mLesruBMD.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2048,"height":1152,"file_path":"/6hFT32qSmv0PtxlA1sGmz6Y0dl3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2047,"height":1151,"file_path":"/xqpa9xSFoyj9wKN0QeA3rrDCpSr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2023,"height":1138,"file_path":"/hcTUlCgPE8LHQuq7paOBM8INSv3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/vZQGIKdJTlIVfAQBdU9wFLo8GtO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/bcXc726Crr6MP3PDX8Fv0oWBvJ1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T06:40:27.679+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.ufo-distribution.com/movie/refletdansundiamantmort/","overview":"Suite à la disparition soudaine de sa voisine de chambre, un ancien agent secret, reclus dans un palace de la Côte d’Azur, s’imagine que ses ennemis jurés refont surface. Surtout la redoutable Serpentik, qu’il n’a jamais réussi à démasquer. Oscillant entre présent et passé, il remonte le film de sa vie, au risque de découvrir qu’il n’y tenait pas forcément le meilleur rôle. Et que les diamants sont loin d’être éternels…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Reflection in a Dead Diamond","runtime":87,"tagline":"","homepage":"","overview":"When the mysterious woman in the room next door disappears, a debonair 70-year-old ex-spy living in a luxury hotel on the Côte d'Azur is confronted by the demons and darlings of a lurid past in which moviemaking, memories and madness collide."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"리플렉션","runtime":87,"tagline":"","homepage":"","overview":"남프랑스 코트 다쥐르의 고급 호텔에서 우아한 일상을 이어가는 70대 노인 존 D. 그는 음모와 약속, 갈등과 글래머로 가득한 1960년대 전 세계를 누비며 활동하던 전직 스파이다. 한가롭게 해변의 산책과 햇살을 즐기던 그의 옆방 투숙객으로 등장한 한 여성이 그의 눈길을 사로잡고, 어느 날 그녀가 갑자기 흔적도 없이 사라지면서 존은 익숙한 두려움을 느끼며 과거 속으로 돌아가게 되는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"死钻倒影","runtime":0,"tagline":"","homepage":"","overview":"约翰·D 是一位居住在蔚蓝海岸豪华酒店的古稀退休间谍，他被新搬来的邻居深深吸引，她让他想起了 20 世纪 60 年代蔚蓝海岸那段充满活力的时光。当这位邻居神秘失踪后，约翰不得不直面自己过去的恶魔。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Błysk diamentu śmierci","runtime":87,"tagline":"Bardziej bondowski niż jakikolwiek film o Bondzie.","homepage":"https://velvetspoon.pl/film/blysk-diamentu-smierci/","overview":"John ma 70 lat i mieszka w odosobnieniu w luksusowym hotelu na Lazurowym Wybrzeżu. Zaintrygowany jest kobietą w pokoju obok, która przypomina mu o jego szalonych latach na Riwierze w latach 60., kiedy był eleganckim międzynarodowym szpiegiem w świecie pełnym niebezpieczeństw i obietnic. Ale kiedy kobieta tajemniczo znika, Johna dręczą retrospekcje – lub może fantazje – jego pełnej przepychu i groteskowej przeszłości oraz kuszących kobiet i nikczemnych złoczyńców, którzy tam żyli i umarli. Dzięki obrazom, które oddają pełen czułości hołd gatunkowi Eurospy z lat 60. i są zabarwione zabawną krwią, rzeczywistość Johna staje się rozbita, gdy stara się rozwikłać zagadkę swojej przeszłości. Pamięć, szaleństwo i kręcenie filmów stają się coraz trudniejsze do oddzielenia. Czy jego starzy wrogowie powrócą, by siać spustoszenie w jego idyllicznym życiu? Czy czekają na ujawnienie kolejne spiski i zdrady? A może po prostu został oczarowany piękną i niebezpieczną przynętą samego kina ucieczki?"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Reflection in a Dead Diamond","runtime":0,"tagline":"","homepage":"","overview":"In un grand hotel sulla Costa azzurra, l'anziano agente speciale John rimane affascinato da una giovane donna e ricorda i suoi giorni da spia negli anni '60. Quando la donna scompare misteriosamente, l'uomo è preda delle sue fantasie e rivive le avventure del passato, tra furti di gioielli, rapimenti e torture, arrivando a temere che forse i suoi nemici del passato sono tornati. John vive la sua vita, o forse ha sempre fatto parte di un mondo di fantasia, segnato dall'immaginario del cinema d'avventura d'un tempo?"},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"O Brilho do Diamante Secreto","runtime":87,"tagline":"","homepage":"","overview":"Ambientado na glamourosa Côte d’Azur, o filme acompanha John D., um espião aposentado de 70 anos que vive em um hotel de luxo, imerso em lembranças, fantasias e alucinações. Quando sua vizinha desaparece misteriosamente, ele é levado a revisitar o passado, enfrentando seus traumas e mergulhando em um universo de paranoia, erotismo e referências visuais ao cinema de espionagem B dos anos 60."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Reflection In A Dead Diamond","runtime":87,"tagline":"","homepage":"","overview":"Als die mysteriöse Frau aus dem Nachbarzimmer verschwindet, wird ein charmanter 70-jähriger Ex-Spion, der in einem Luxushotel an der Côte d'Azur lebt, mit den Dämonen und Lieblingen einer schillernden Vergangenheit konfrontiert, in der Filmemachen, Erinnerungen und Wahnsinn aufeinanderprallen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Відображення у мертвому діаманті","runtime":0,"tagline":"","homepage":"","overview":"Іронічний шпигунський трилер. Головний герой, шпигун у відставці підозрює, що його колишні вороги повернулися, коли зникає його інтригуючий сусід. Іронічне переосмислення шпигунських трилерів, зокрема, лінійки фільмів про агента 007."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Atspindys mirusiame deimante","runtime":87,"tagline":"","homepage":"","overview":"Džonas D. mėgaujasi pensija prabangiame viešbutyje, Prancūzijos Rivjeroje. Tačiau dingus jo kaimynei, Džoną pradeda persekioti jo, kaip 7-ojo dešimtmečio šnipo, praeitis. Tai buvo žavesio ir spindesio era, kurioje šėlo ekstravagantiški piktadariai ir žibėjo deimantai. Praeitis ir dabartis pradeda persipinti, o fone ima kilti ir paties Džono demonai."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Reflection in a Dead Diamond","runtime":0,"tagline":"","homepage":"","overview":"John tiene 70 años y vive en un lujoso y solitario hotel de la Costa Azul. Se siente intrigado por la mujer de la habitación de al lado, que le recuerda sus años salvajes en la Riviera en la década de 1960, cuando era un elegante espía internacional en un mundo lleno de peligros y promesas. Pero cuando la mujer desaparece misteriosamente, John se ve acosado por recuerdos -o tal vez fantasías- de su glamuroso y grotesco pasado, y de las seductoras mujeres y ruines villanos que vivieron y murieron allí."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Reflection in a Dead Diamond","runtime":87,"tagline":"","homepage":"","overview":"John tiene 70 años y vive en un lujoso y solitario hotel de la Costa Azul. Se siente intrigado por la mujer de la habitación de al lado, que le recuerda sus años salvajes en la Riviera en la década de 1960, cuando era un elegante espía internacional en un mundo lleno de peligros y promesas. Pero cuando la mujer desaparece misteriosamente, John se ve acosado por recuerdos -o tal vez fantasías- de su glamuroso y grotesco pasado, y de las seductoras mujeres y ruines villanos que vivieron y murieron allí."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"بازتابی در الماس مرده","runtime":0,"tagline":"","homepage":"","overview":"داستان یک جاسوس بازنشسته که پس از ناپدید شدن همسایه‌اش، به بازگشت رقبای قدیمی‌اش شک می‌کند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"","runtime":87,"tagline":"","homepage":"","overview":"John D, een zeventiger die in een luxehotel aan de Côte d'Azur woont, is gefascineerd door zijn buurvrouw. Ze doet hem denken aan zijn wilde jaren aan de Rivièra in de jaren 60. Hij was toen spion in een beloftevolle maar snel veranderende wereld. Op een dag verdwijnt zijn buurvrouw op mysterieuze wijze... en komt John oog in oog te staan met zijn demonen. Wordt zijn idyllische wereld verstoord door zijn toenmalige tegenstanders die terug zijn om chaos te creëren?"},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Отражение в мёртвом бриллианте","runtime":87,"tagline":"","homepage":"","overview":"1960-е. Джон, 70-летний бывший тайный агент, ведёт тихую жизнь в отеле на Лазурном берегу, предаваясь воспоминаниям о своих шпионских приключениях молодости. Однажды в соседний номер заселяется милая женщина, которая привлекает внимание Джона. Когда женщина бесследно пропадает, он пытается разгадать тайну её исчезновения, а воспоминания и прошлые страхи накатываются с новой силой."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"死鑽倒影","runtime":0,"tagline":"","homepage":"","overview":"約翰年屆七十，獨居於蔚藍海岸的豪華酒店。他被隔壁神秘女子吸引，喚起對1960年代作為國際間諜的回憶。女子突然失蹤後，約翰陷入一連串光怪陸離的回憶或幻想——魅惑的女人、邪惡的反派、血腥又迷人的往昔。他試圖解開記憶的謎團，卻逐漸分不清現實與幻覺。影片以致敬歐洲諜戰片的風格，描繪一個被電影幻象吞噬的靈魂：舊敵是否重現？陰謀是否仍在？還是他只是沉溺於銀幕的誘惑？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Odlesk v mrtvém diamantu","runtime":0,"tagline":"","homepage":"","overview":"John D. (Fabio Testi/Yannick Renier) si užívá důchodu v luxusním hotelu na Francouzské riviéře, ale když zmizí jeho sousedka, Johna začne pronásledovat minulost špiona během 60. let. Byla to éra glamouru, kdy se Riviérou proháněli extravagantní zločinci a třpyt diamantů byl všudypřítomný. Prostřednictvím fragmentárního vyprávění, v němž se minulost a současnost začínají stírat, se Johnovi začínají znovu zjevovat jeho vlastní démoni. Film manželského týmu Hélène Cattet a Bruno Forzani, Odlesk v mrtvém diamantu, je sexy – stejně jako brutálním – návratem k surrealismu 60. let. Je to přímá pocta klasickým špionážním filmům, která podrobuje současnému pohledu genderovou politiku dané doby. Lokality jsou stejně nádherné jako akční scény drastické – plné rozbitého skla a rezavých rybářských háků."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Reflection in a Dead Diamond","runtime":87,"tagline":"","homepage":"","overview":"Yan odadaki gizemli kadın aniden ortadan kaybolduğunda, Côte d'Azur'da inzivaya çekilmiş 70 yaşındaki karizmatik eski bir casus; sinemanın, anıların ve deliliğin iç içe geçtiği sarsıcı bir geçmişin hayaletleri ve tutkularıyla yüzleşmek zorunda kalır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"}],"reviews_tmdb":[],"recommendations":[{"id":1320276,"adult":false,"title":"The New Year That Never Came","video":false,"overview":"The New Year That Never Came is a tragicomedy whose action takes place in a single day, before the counter-revolution of 1989, in which the characters search for normality, safety, love, freedom and meaning in an absurd world.","genre_ids":[18],"media_type":"movie","popularity":0.2562,"vote_count":72,"poster_path":"/AxoszYlyv6qkFzRxLmlsc3pcs7.jpg","release_date":"2024-09-27","vote_average":7.354,"backdrop_path":"/mPjBP9cvdSnSrRLXs2sLBWeq8u5.jpg","original_title":"Anul Nou care n-a fost","original_language":"ro"},{"id":1214140,"adult":false,"title":"Monster Island","video":false,"overview":"In the Pacific, 1944, a Japanese soldier and a British prisoner of war are stranded on a deserted island, hunted by a deadly creature. Two mortal enemies must come together to survive the unknown.","genre_ids":[27,14,28,53],"media_type":"movie","popularity":6.0679,"vote_count":96,"poster_path":"/x1JOs4xWNr1QYjDAXHxWw1NJ7Sq.jpg","release_date":"2025-05-08","vote_average":5.995,"backdrop_path":"/fxKC10HQliVA3Tn5smOclqzL96N.jpg","original_title":"Orang Ikan","original_language":"en"},{"id":1104937,"adult":false,"title":"Kill the Jockey","video":false,"overview":"Remo's self-destructive behavior overshadows his talent. Abril, an upcoming jockey, is pregnant with Remo's baby and has to decide between the child or continuing to race. They both race for Sirena, a businessman who saved Remo's life in the past but now is determined to find him, dead or alive.","genre_ids":[35,80,18],"media_type":"movie","popularity":0.6717,"vote_count":59,"poster_path":"/2CGm69ebTBnbqFZIT8cWSuRIb8S.jpg","release_date":"2024-09-26","vote_average":6.822,"backdrop_path":"/fXt669559jwHXZkx3ZEhDbF90Wz.jpg","original_title":"El jockey","original_language":"es"},{"id":1313226,"adult":false,"title":"Kika","video":false,"overview":"While pregnant with her second child, Kika faces the sudden death of her partner. Totally heartbroken, and broke, she sets her priorities straight : 1.⁠ ⁠make money fast 2.⁠ ⁠stay strong. Dirty underwear, dildos and neurotic parents will unexpectedly help.","genre_ids":[18,35],"media_type":"movie","popularity":3.2163,"vote_count":11,"poster_path":"/c6HGOGRYXVFl8dq88Eb5Jnsj7PL.jpg","release_date":"2025-11-05","vote_average":6.045,"backdrop_path":"/6q3gGVYj36im8OswF80CdsFH6BC.jpg","original_title":"Kika","original_language":"fr"},{"id":475660,"adult":false,"title":"Under the Rose","video":false,"overview":"Sara, the daughter of Oliver and Julia suddenly disappears. Days pass by without any news about the girl. But one morning, the family receives a letter from someone who claims to have retained Sara and wants to talk with them that night.","genre_ids":[53,80,18,9648],"media_type":"movie","popularity":0.1102,"vote_count":39,"poster_path":"/d4ELqJSvUTXFyEkZrzQL7WpO41c.jpg","release_date":"2017-06-22","vote_average":6.1,"backdrop_path":"/rocYBb3I7Cevib09JwV9huFtVlK.jpg","original_title":"Bajo la rosa","original_language":"es"},{"id":9535,"adult":false,"title":"Analyze This","video":false,"overview":"Countless wiseguy films are spoofed in this film that centers on the neuroses and angst of a powerful Mafia racketeer who suffers from panic attacks. When Paul Vitti needs help dealing with his role in the \"family,\" unlucky shrink Dr. Ben Sobel is given just days to resolve Vitti's emotional crisis and turn him into a happy, well-adjusted gangster.","genre_ids":[35,80],"media_type":"movie","popularity":3.6508,"vote_count":2076,"poster_path":"/eqa4TEgkx63WRhqyD8eTwmL7bUi.jpg","release_date":"1999-03-05","vote_average":6.505,"backdrop_path":"/oas0DvvhhaMncvn805LjepxeoZh.jpg","original_title":"Analyze This","original_language":"en"},{"id":7345,"adult":false,"title":"There Will Be Blood","video":false,"overview":"Ruthless silver miner, turned oil prospector, Daniel Plainview, moves to oil-rich California. Using his son to project a trustworthy, family-man image, Plainview cons local landowners into selling him their valuable properties for a pittance. However, local preacher Eli Sunday suspects Plainview's motives and intentions, starting a slow-burning feud that threatens both their lives.","genre_ids":[18],"media_type":"movie","popularity":8.879,"vote_count":7245,"poster_path":"/fa0RDkAlCec0STeMNAhPaF89q6U.jpg","release_date":"2007-12-26","vote_average":8.077,"backdrop_path":"/9UAKA6ceZi6TgQwTAAMt7DWwYPI.jpg","original_title":"There Will Be Blood","original_language":"en"},{"id":911430,"adult":false,"title":"F1","video":false,"overview":"Racing legend Sonny Hayes is coaxed out of retirement to lead a struggling Formula 1 team—and mentor a young hotshot driver—while chasing one more chance at glory.","genre_ids":[28,18],"media_type":"movie","popularity":33.1588,"vote_count":3411,"poster_path":"/vqBmyAj0Xm9LnS1xe1MSlMAJyHq.jpg","release_date":"2025-06-25","vote_average":7.768,"backdrop_path":"/1KFv63mmcBGVbFl3jxxozoSFlhA.jpg","original_title":"F1","original_language":"en"},{"id":1061474,"adult":false,"title":"Superman","video":false,"overview":"Superman, a journalist in Metropolis, embarks on a journey to reconcile his Kryptonian heritage with his human upbringing as Clark Kent.","genre_ids":[878,12,28],"media_type":"movie","popularity":28.4139,"vote_count":4376,"poster_path":"/ldyfo0BKmz5rWtJJKCvwaNS4cJT.jpg","release_date":"2025-07-09","vote_average":7.359,"backdrop_path":"/aJDLz1748CIMZkCkyISYe5Hl6I7.jpg","original_title":"Superman","original_language":"en"},{"id":507086,"adult":false,"title":"Jurassic World Dominion","video":false,"overview":"Four years after Isla Nublar was destroyed, dinosaurs now live—and hunt—alongside humans all over the world. This fragile balance will reshape the future and determine, once and for all, whether human beings are to remain the apex predators on a planet they now share with history's most fearsome creatures.","genre_ids":[12,28,878],"media_type":"movie","popularity":14.0982,"vote_count":6896,"poster_path":"/jbAvCACjLf1ZG0unB2tdmx5HAf1.jpg","release_date":"2022-06-01","vote_average":6.61,"backdrop_path":"/698FjyzLdpgXmUSr63LaRwblTmx.jpg","original_title":"Jurassic World Dominion","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":19.7563,"vote_count":11389,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0c