age":0},{"width":2000,"height":3000,"file_path":"/55BuN1j4ZtrFXEKJ34n8B1EMKuk.jpg","iso_639_1":"fa","iso_3166_1":"IR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":655,"height":982,"file_path":"/9qx6OGfVTuN9iWVY9djIDO9qWBO.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1500,"height":2250,"file_path":"/aUrfdiVcCpEiq3gPMyM8Uou56qX.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/2AMwEooBu33V2vQVKMphjC1WdUR.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/207ZYv4LZDoZMmiTIwna74LlP59.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/klXhJ8IpWhzfjupJ1xZmyC2Uk1A.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/zmfaCjc4MNUWgEztT3pOOyMSMBw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/9YqyNdvYkumiNaC67HuO2FrGuCy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1384,"height":778,"file_path":"/ytfDm680Ytym0GtrNtZ1G85ALro.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":1920,"height":1080,"file_path":"/5hHfI6XlbGkbQpSvUnirdp6y3Zm.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/9cmoFkhofcFZoJn5FZGy10PVLjM.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T02:54:53.72+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Gentleman","runtime":89,"tagline":"","homepage":"","overview":"Aging ex-soldier Theo meets weekly with prostitute Olga to reminisce. After Olga's murder, Theo seeks bloody revenge, attracting attention of alcoholic cop Iborra and hitman Herodes."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":89,"tagline":"","homepage":"","overview":"Theo, conocido como \"el Gentleman\", es un ex soldado estadounidense cuya existencia solitaria y miserable transcurre entre sus recuerdos de un pasado mejor con su difunta esposa y su habitual cita de los jueves con Olga, una prostituta a la que paga por conversar, recordando quién fue una vez y soñando con lo que podría haber sido. Cuando Olga es asesinada, busca una venganza brutal. El rastro de sangre que deja es seguido por Iborra, una inspectora de policía alcohólica, y Herodes, un despiadado asesino a sueldo. El cruce de estos personajes al límite tendrá un abrupto desenlace cuando el presente venga a cobrarse las deudas del pasado."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"The Gentleman","runtime":90,"tagline":"","homepage":"","overview":"Der ehemalige US-Soldat Theo (Ron Perlman) verbringt seine Tage damit, von besseren Zeiten zu träumen, die nun Jahre hinter ihm liegen. Jede Woche trifft sich Theo mit Olga (Natti Natasha), einer Prostituierten, die er dafür bezahlt, mit ihm darüber zu sprechen, wer er einmal war und was er unter anderen Umständen hätte werden können. Als Olga ermordet wird, begibt sich Theo auf eine blutige Rachetour, die schnell die Aufmerksamkeit des alkoholkranken Polizeiinspektors Iborra und des kaltblütigen Auftragskillers Herodes erregt."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Ostareli nekdanji vojak Theo se tedensko redno sestaja s prostitutko Olgo. Po Olginem umoru se želi Theo krvavo maščevati, kar pritegne pozornost alkoholizirane policistke Iborre in plačanega morilca Herodesa."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Stárnoucí bývalý voják Theo se každý týden schází s prostitutkou Olgou, aby zavzpomínali na staré časy. Po Olgině vraždě se Theo vydává na krvavou pomstu, čímž upoutá pozornost alkoholického policisty Iborry a nájemného vraha Herodese."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"绅士之风","runtime":0,"tagline":"","homepage":"","overview":"《绅士》由朗·普尔曼主演，饰演西奥，一位年事已高的前美国士兵。年迈的退伍军人西奥每周与妓女奥尔加会面，一同回忆往事。奥尔加被杀害后，西奥展开血腥复仇，引起了酗酒警探伊博拉和杀手赫罗德斯的注意。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"En Theo és un exsoldat nord-americà amb una existència solitària i miserable. El seu únic moment de felicitat és la seva habitual cita dels dijous amb Olga, una prostituta a qui paga per conversar. Quan Olga és assassinada, busca venjança per la seva mort. El rastre de sang que deixa és seguit per Iborra, una inspectora de policia alcohòlica, i Herodes, un assassí despietat a sou."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Джентльмен","runtime":0,"tagline":"","homepage":"","overview":"Офицер в отставке Тео, живущий в одиночестве и погружённый в воспоминания о прошлом, каждую неделю встречается с проституткой Ольгой. Их беседы — не просто оплаченная услуга, а редкие моменты искренности и утешения. Однако жизнь Тео рушится, когда Ольгу жестоко убивают. Охваченный яростью и жаждой мести, он начинает собственное расследование, выходя на опасный путь, где сталкивается с коррумпированной полицией и безжалостными киллерами."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"}],"reviews_tmdb":[],"recommendations":[{"id":760329,"adult":false,"title":"The Smashing Machine","video":false,"overview":"In the late 1990s, up-and-coming mixed martial artist Mark Kerr aspires to become the greatest fighter in the world. However, he must also battle his opioid dependence and a volatile relationship with his girlfriend Dawn.","genre_ids":[18,36],"media_type":"movie","popularity":9.6453,"vote_count":445,"poster_path":"/mPuBDGrVIBGOymBxR6rO3iIvBSe.jpg","release_date":"2025-10-01","vote_average":6.461,"backdrop_path":"/hTCr9dDf0EcBGZSUaY0YCeBjBr5.jpg","original_title":"The Smashing Machine","original_language":"en"},{"id":803796,"adult":false,"title":"KPop Demon Hunters","video":false,"overview":"When K-pop superstars Rumi, Mira and Zoey aren't selling out stadiums, they're using their secret powers to protect their fans from supernatural threats.","genre_ids":[14,10402,35,16],"media_type":"movie","popularity":47.0685,"vote_count":2422,"poster_path":"/zT7Lhw3BhJbMkRqm9Zlx2YGMsY0.jpg","release_date":"2025-06-20","vote_average":8.1,"backdrop_path":"/w3Bi0wygeFQctn6AqFTwhGNXRwL.jpg","original_title":"KPop Demon Hunters","original_language":"en"},{"id":693134,"adult":false,"title":"Dune: Part Two","video":false,"overview":"Follow the mythic journey of Paul Atreides as he unites with Chani and the Fremen while on a path of revenge against the conspirators who destroyed his family. Facing a choice between the love of his life and the fate of the known universe, Paul endeavors to prevent a terrible future only he can foresee.","genre_ids":[878,12],"media_type":"movie","popularity":24.0699,"vote_count":7549,"poster_path":"/1pdfLvkbY9ohJlCjQH2CZjjYVvJ.jpg","release_date":"2024-02-27","vote_average":8.13,"backdrop_path":"/ylkdrn23p3gQcHx7ukIfuy2CkTE.jpg","original_title":"Dune: Part Two","original_language":"en"},{"id":490132,"adult":false,"title":"Green Book","video":false,"overview":"Tony Lip, a bouncer in 1962, is hired to drive pianist Don Shirley on a tour through the Deep South in the days when African Americans, forced to find alternate accommodations and services due to segregation laws below the Mason-Dixon Line, relied on a guide called The Negro Motorist Green Book.","genre_ids":[18,35,36],"media_type":"movie","popularity":10.0209,"vote_count":12612,"poster_path":"/7BsvSuDQuoqhWmU2fL7W2GOcZHU.jpg","release_date":"2018-11-16","vote_average":8.222,"backdrop_path":"/5En0fmDagt3Pk8d7P3uTwfeQceg.jpg","original_title":"Green Book","original_language":"en"},{"id":680,"adult":false,"title":"Pulp Fiction","video":false,"overview":"A burger-loving hit man, his philosophical partner, a drug-addled gangster's moll and a washed-up boxer converge in this sprawling, comedic crime caper. Their adventures unfurl in three stories that ingeniously trip back and forth in time.","genre_ids":[53,80,35],"media_type":"movie","popularity":25.4546,"vote_count":29734,"poster_path":"/vQWk5YBFWF4bZaofAbv0tShwBvQ.jpg","release_date":"1994-09-10","vote_average":8.486,"backdrop_path":"/96hiUXEuYsu4tcnvlaY8tEMFM0m.jpg","original_title":"Pulp Fiction","original_language":"en"},{"id":533535,"adult":false,"title":"Deadpool & Wolverine","video":false,"overview":"A listless Wade Wilson toils away in civilian life with his days as the morally flexible mercenary, Deadpool, behind him. But when his homeworld faces an existential threat, Wade must reluctantly suit-up again with an even more reluctant Wolverine.","genre_ids":[28,35,878],"media_type":"movie","popularity":24.3599,"vote_count":8293,"poster_path":"/8cdWjvZQUExUUTzyp4t6EDMubfO.jpg","release_date":"2024-07-24","vote_average":7.557,"backdrop_path":"/ufpeVEM64uZHPpzzeiDNIAdaeOD.jpg","original_title":"Deadpool & Wolverine","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":23.0611,"vote_count":11386,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":361743,"adult":false,"title":"Top Gun: Maverick","video":false,"overview":"After more than thirty years of service as one of the Navy’s top aviators, and dodging the advancement in rank that would ground him, Pete “Maverick” Mitchell finds himself training a detachment of TOP GUN graduates for a specialized mission the likes of which no living pilot has ever seen.","genre_ids":[28,18],"media_type":"movie","popularity":20.7841,"vote_count":10612,"poster_path":"/62HCnUTziyWcpDaBO2i1DX17ljH.jpg","release_date":"2022-05-21","vote_average":8.156,"backdrop_path":"/AaV1YIdWKnjAIAOe8UUKBFm327v.jpg","original_title":"Top Gun: Maverick","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":30.0131,"vote_count":26824,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.9,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":945961,"adult":false,"title":"Alien: Romulus","video":false,"overview":"While scavenging the deep ends of a derelict space station, a group of young space colonizers come face to face with the most terrifying life form in the universe.","genre_ids":[27,878],"media_type":"movie","popularity":14.05,"vote_count":4307,"poster_path":"/2uSWRTtCG336nuBiG8jOTEUKSy8.jpg","release_date":"2024-08-13","vote_average":7.169,"backdrop_path":"/iYqSQaWDttQIQzsxg9xHyg0bttG.jpg","original_title":"Alien: Romulus","original_language":"en"},{"id":823464,"adult":false,"title":"Godzilla x Kong: The New Empire","video":false,"overview":"Following their explosive showdown, Godzilla and Kong must reunite against a colossal undiscovered threat hidden within our world, challenging their very existence – and our own.","genre_ids":[28,12,878],"media_type":"movie","popularity":13.49,"vote_count":4515,"poster_path":"/z1p34vh7dEOnLDmyCrlUVLuoDzd.jpg","release_date":"2024-03-27","vote_average":7.052,"backdrop_path":"/gvLG3Fnznkxl4SmYfcK8gUuqxM8.jpg","original_title":"Godzilla x Kong: The New Empire","original_language":"en"},{"id":414906,"adult":false,"title":"The Batman","video":false,"overview":"In his second year of fighting crime, Batman uncovers corruption in Gotham City that connects to his own family while facing a serial killer known as the Riddler.","genre_ids":[80,9648,53],"media_type":"movie","popularity":16.376,"vote_count":11641,"poster_path":"/74xTEgt7R36Fpooo50r9T25onhq.jpg","release_date":"2022-03-01","vote_average":7.656,"backdrop_path":"/rvtdN5XkWAfGX6xDuPL6yYS2seK.jpg","original_title":"The Batman","original_language":"en"},{"id":37165,"adult":false,"title":"The Truman Show","video":false,"overview":"An insurance salesman begins to suspect that his whole life is actually some sort of reality TV show.","genre_ids":[35,18],"media_type":"movie","popularity":14.3409,"vote_count":19829,"poster_path":"/vuza0WqY239yBXOadKlGwJsZJFE.jpg","release_date":"1998-06-04","vote_average":8.151,"backdrop_path":"/aCHn2TXYJfzPXQKA6r9mKPbMlUB.jpg","original_title":"The Truman Show","original_language":"en"},{"id":495764,"adult":false,"title":"Birds of Prey (and the Fantabulous Emancipation of One Harley Quinn)","video":false,"overview":"Harley Quinn joins forces with a singer, an assassin and a police detective to help a young girl who had a hit placed on her after she stole a rare diamond from a crime lord.","genre_ids":[28,80],"media_type":"movie","popularity":6.253,"vote_count":10692,"poster_path":"/h4VB6m0RwcicVEZvzftYZyKXs6K.jpg","release_date":"2020-02-05","vote_average":6.884,"backdrop_path":"/uozb2VeD87YmhoUP1RrGWfzuCrr.jpg","original_title":"Birds of Prey (and the Fantabulous Emancipation of One Harley Quinn)","original_language":"en"},{"id":272,"adult":false,"title":"Batman Begins","video":false,"overview":"Driven by tragedy, billionaire Bruce Wayne dedicates his life to uncovering and defeating the corruption that plagues his home, Gotham City.  Unable to work within the system, he instead creates a new identity, a symbol of fear for the criminal underworld - The Batman.","genre_ids":[18,80,28],"media_type":"movie","popularity":13.2944,"vote_count":22280,"poster_path":"/sPX89Td70IDDjVr85jdSBb4rWGr.jpg","release_date":"2005-06-10","vote_average":7.721,"backdrop_path":"/9IIBboV7MCT0bTxzXHmWK1Hq558.jpg","original_title":"Batman Begins","original_language":"en"},{"id":238,"adult":false,"title":"The Godfather","video":false,"overview":"Spanning the years 1945 to 1955, a chronicle of the fictional Italian-American Corleone crime family. When organized crime family patriarch, Vito Corleone barely survives an attempt on his life, his youngest son, Michael steps in to take care of the would-be killers, launching a campaign of bloody revenge.","genre_ids":[18,80],"media_type":"movie","popularity":40.3175,"vote_count":22502,"poster_path":"/3bhkrj58Vtu7enYsRolD1fZdja1.jpg","release_date":"1972-03-14","vote_average":8.687,"backdrop_path":"/tSPT36ZKlP2WVHJLM4cQPLSzv3b.jpg","original_title":"The Godfather","original_language":"en"},{"id":98,"adult":false,"title":"Gladiator","video":false,"overview":"After the death of Emperor Marcus Aurelius, his devious son takes power and demotes Maximus, one of Rome's most capable generals who Marcus preferred. Eventually, Maximus is forced to become a gladiator and battle to the death against other men for the amusement of paying audiences.","genre_ids":[28,18,12],"media_type":"movie","popularity":15.3337,"vote_count":20539,"poster_path":"/ty8TGRuvJLPUmAR1H1nRIsgwvim.jpg","release_date":"2000-05-04","vote_average":8.222,"backdrop_path":"/jhk6D8pim3yaByu1801kMoxXFaX.jpg","original_title":"Gladiator","original_language":"en"},{"id":475557,"adult":false,"title":"Joker","video":false,"overview":"During the 1980s, a failed stand-up comedian is driven insane and turns to a life of crime and chaos in Gotham City while becoming an infamous psychopathic crime figure.","genre_ids":[80,53,18],"media_type":"movie","popularity":19.3785,"vote_count":27337,"poster_path":"/udDclJoHjfjb8Ekgsd4FDteOkCU.jpg","release_date":"2019-10-01","vote_average":8.128,"backdrop_path":"/hO7KbdvGOtDdeg0W4Y5nKEHeDDh.jpg","original_title":"Joker","original_language":"en"},{"id":545611,"adult":false,"title":"Everything Everywhere All at Once","video":false,"overview":"An aging Chinese immigrant is swept up in an insane adventure, where she alone can save what's important to her by connecting with the lives she could have led in other universes.","genre_ids":[28,12,878],"media_type":"movie","popularity":11.7985,"vote_count":7694,"poster_path":"/u68AjlvlutfEIcpmbYpKcdi09ut.jpg","release_date":"2022-03-24","vote_average":7.721,"backdrop_path":"/ss0Os3uWJfQAENILHZUdX8Tt1OC.jpg","original_title":"Everything Everywhere All at Once","original_language":"en"},{"id":438631,"adult":false,"title":"Dune","video":false,"overview":"Paul Atreides, a brilliant and gifted young man born into a great destiny beyond his understanding, must travel to the most dangerous planet in the universe to ensure the future of his family and his people. As malevolent forces explode into conflict over the planet's exclusive supply of the most precious resource in existence-a commodity capable of unlocking humanity's greatest potential-only those who can conquer their fear will survive.","genre_ids":[878,12],"media_type":"movie","popularity":20.4722,"vote_count":14480,"poster_path":"/d5NXSklXo0qyIYkgV94XAgMIckC.jpg","release_date":"2021-09-15","vote_average":7.778,"backdrop_path":"/wYMbnrdRCREjNLwFlG5SLWzBjui.jpg","original_title":"Dune","original_language":"en"}],"similar_content":[],"external_ids":{"imdb_id":"tt32140922","twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148283,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"DE","release_dates":[{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":"2025-11-20T00:00:00.000Z","certification":"16"},{"note":"","type":5,"iso_639_1":"","descriptors":[],"release_date":"2025-11-20T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"ES","release_dates":[{"note":"San Sebastián International Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-09-23T00:00:00.000Z","certification":""},{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-09-26T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"GB","release_dates":[{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":"2025-11-24T00:00:00.000Z","certification":"15"}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikidata_metadata":{},"mood_tags":null,"trope_tags":null,"vibe_description":null,"ai_enriched_at":null,"ai_enrichment_version":0}}]]
