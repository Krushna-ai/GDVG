5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Gentleman\",\"description\":\"Aging ex-soldier Theo meets weekly with prostitute Olga to reminisce. After Olga's murder, Theo seeks bloody revenge, attracting attention of alcoholic cop Iborra and hitman Herodes.\",\"image\":\"https://image.tmdb.org/t/p/w500/iIIZ3qIh7A3B8Y1VVo5laFyusVV.jpg\",\"datePublished\":\"2025-09-26\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"ES\",\"inLanguage\":\"es\",\"genre\":[\"Action\",\"Crime\",\"Thriller\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.229,\"bestRating\":10,\"ratingCount\":48}}"}}],["$","$L10",null,{"initialDrama":{"id":"ea24782a-5e1d-4673-b216-90758ad12225","tmdb_id":1426968,"imdb_id":"tt32140922","content_type":"movie","title":"The Gentleman","original_title":"Ya no quedan junglas","overview":"Aging ex-soldier Theo meets weekly with prostitute Olga to reminisce. After Olga's murder, Theo seeks bloody revenge, attracting attention of alcoholic cop Iborra and hitman Herodes.","poster_path":"/iIIZ3qIh7A3B8Y1VVo5laFyusVV.jpg","backdrop_path":"/klXhJ8IpWhzfjupJ1xZmyC2Uk1A.jpg","release_date":"2025-09-26","first_air_date":null,"status":"published","original_language":"es","origin_country":["ES"],"genres":[{"id":28,"name":"Action"},{"id":80,"name":"Crime"},{"id":53,"name":"Thriller"}],"popularity":11.2508,"vote_average":6.229,"vote_count":48,"runtime":89,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-25T00:19:50.026249+00:00","updated_at":"2026-02-25T00:19:49.877+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":125381,"name":"SDB Films","logo_path":"/fqyj3ATL45iYVHSIprJP1cUy4sG.png","origin_country":"MX"},{"id":85066,"name":"Film Factory","logo_path":"/5FhRorfPgloqzv7zlEAMi0dsiCa.png","origin_country":"ES"},{"id":149886,"name":"Esto También Pasará","logo_path":"/oDG7mNqzG