9:{"metadata":[["$","title","0",{"children":"Your Fault | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"The love between Noah and Nick seems unwavering despite their parents' attempts to separate them. But his job and her entry into college open up their lives to new relationships that will shake the foundations of both their relationship and the Leister family itself."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148277/your-fault"}],["$","meta","5",{"property":"og:title","content":"Your Fault"}],["$","meta","6",{"property":"og:description","content":"The love between Noah and Nick seems unwavering despite their parents' attempts to separate them. But his job and her entry into college open up their lives to new relationships that will shake the foundations of both their relationship and the Leister family itself."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148277/your-fault"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/1sQA7lfcF9yUyoLYC0e6Zo3jmxE.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Your Fault"}],["$","meta","12",{"name":"twitter:description","content":"The love between Noah and Nick seems unwavering despite their parents' attempts to separate them. But his job and her entry into college open up their lives to new relationships that will shake the foundations of both their relationship and the Leister family itself."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/1sQA7lfcF9yUyoLYC0e6Zo3jmxE.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}