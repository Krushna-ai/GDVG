 Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/vLZKlXUNDcZR7ilvfY9Wr9k80FZ.jpg","provider_id":538,"provider_name":"Plex","display_priority":126}]}}},"wikidata_id":"Q124737605","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"WESTERN","main_poster":null,"images":null,"enriched_at":"2026-02-21T10:15:56.125+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":98,"tagline":"Hope is uncharted territory.","homepage":"https://www.greenland2.movie","overview":"Having found the safety of the Greenland bunker after the comet Clarke decimated the Earth, the Garrity family must now risk everything to embark on a perilous journey across the wasteland of Europe to find a new home."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Greenland : Migration","runtime":0,"tagline":"L'espoir est un territoire inexploré.","homepage":"","overview":"Après l'impact dévastateur d'une comète qui a réduit la Terre en ruines, la famille Garrity doit quitter la sécurité de son bunker au Groenland. Commence alors un périple pour leur survie et l'avenir de l'Humanité à travers un monde dévasté à la recherche d'un nouveau foyer."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"그린랜드 2","runtime":0,"tagline":"","homepage":"","overview":"생존한 개리티 가족은 안전한 그린란드 벙커를 떠나 폐허가 된 얼어붙은 유럽의 황무지를 가로질러 새로운 보금자리를 찾기 위한 위험한 여정을 시작한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Thảm Họa Thiên Thạch 2: Di Tản","runtime":0,"tagline":"","homepage":"","overview":"Sau ngày tận thế, gia đình Garrity rời boong-ke an toàn ở Greenland, mạo hiểm tất cả để bước vào một hành trình đầy hiểm nguy, băng qua vùng đất hoang tàn của châu Âu nhằm tìm kiếm một mái nhà mới."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":99,"tagline":"Hoop is onbekend terrein.","homepage":"","overview":"Vijf jaar nadat een komeet het grootste deel van de aarde heeft verwoest, moeten John Garrity en zijn gezin noodgedwongen de veiligheid van de bunker in Groenland verlaten. Ze moeten opnieuw de meest extreme weersomstandigheden trotseren en beginnen aan een genadeloze tocht door een verwoest Europa, op zoek naar een nieuwe plek om een veilig bestaan op te bouwen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Greenland 2","runtime":0,"tagline":"La esperanza es un territorio inexplorado.","homepage":"","overview":"La familia Garrity superviviente debe abandonar la seguridad del búnker de Groenlandia y embarcarse en un peligroso viaje a través del diezmado páramo helado de Europa para encontrar un nuevo hogar."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Greenland: Kıyamet","runtime":0,"tagline":"5 yıl önce dünya yok oldu. Bu yalnızca başlangıçtı.","homepage":"","overview":"Dünyayı vuran büyük bir felaketler zincirinden Grönland sığınağına gitmeyi başararak kurtulan John Garrity ve ailesinin, güvenlik gerekçesiyle sığınaktan ayrılarak kendilerine yeni bir yaşam yeri bulmak için zorlu bir yolculuğa çıkarlar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Destruição Final 2","runtime":99,"tagline":"A esperança é um território desconhecido","homepage":"https://www.diamondfilms.com.br/filmes/destruicao-final-2","overview":"Tendo encontrado a segurança do bunker da Groenlândia depois que o cometa Clarke dizimou a Terra, a família Garrity deve agora arriscar tudo para embarcar em uma jornada angustiante através do deserto da Europa para encontrar um novo lar."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Гренландія 2: Міграція","runtime":0,"tagline":"5 років тому настав кінець світу. Це був лише початок.","homepage":"","overview":"Родина Ґарріті мусить залишити безпечний бункер у Ґренландії та вирушити в небезпечну подорож спустошеними крижаними просторами Європи, щоб знайти новий дім."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Greenland 2: Útěk","runtime":98,"tagline":"","homepage":"","overview":"Snímek přináší příběh přeživších členů rodiny Garrityových, kteří musí opustit bezpečí svého bunkru a vydat se na nebezpečnou cestu napříč zpustošenou, zamrzlou Evropou, aby našli nový domov. (Vertical Entertainment)"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"El Día del Fin del Mundo: Migración","runtime":0,"tagline":"La esperanza es un territorio inexplorado.","homepage":"","overview":"La familia Garrity debe abandonar la seguridad del búnker de Groenlandia y embarcarse en un peligroso viaje a través del diezmado páramo helado de Europa para encontrar un nuevo hogar."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Greenland 2","runtime":99,"tagline":"","homepage":"","overview":"Fünf Jahre nach dem verheerenden Einschlag des Kometen Clarke leben John (Gerard Butler), Allison (Morena Baccarin) und ihr Sohn Nathan (Roman Griffin Davis) noch immer in dem Bunker in Grönland, der ihr Überleben sicherte. Doch Frieden finden sie hier nicht: Luft und Wasser sind verseucht, Strahlungsstürme wüten über die Oberfläche und Fragmente des Kometen schweben noch immer in der Umlaufbahn und drohen auf die Erde zu stürzen. Als ein verheerendes Beben den Bunker zerstört, muss die Familie erneut aufbrechen und sich durch ein verwüstetes Europa bis zum einzig sicher scheinenden Ort auf dem Planeten durchschlagen – dem gigantischen Krater des Clarke-Kometen in Südfrankreich.  Ein absolutes Highlight für alle Action-Fans: Mit atemberaubenden Bildern, packender Spannung und einer emotionalen Familiengeschichte bietet GREENLAND 2 alles, was einen großen Endzeit-Blockbuster ausmacht."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"天劫倒數2：大遷徙","runtime":0,"tagline":"五年前的末日，只是個開始","homepage":"","overview":"倖存的蓋瑞提一家必須離開安全的格陵蘭島避難所，踏上危險的旅程，穿越歐洲滿目瘡痍的冰凍荒原，尋找新的家園。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Гренландия 2: Миграция","runtime":98,"tagline":"«Надежда – неизведанная территория»","homepage":"","overview":"Найдя безопасный бункер в Гренландии после того, как комета уничтожила Землю, семья Гаррити теперь должна рискнуть всем и отправиться в опасное путешествие по пустошам Европы, чтобы найти новый дом."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Greenland 2: Migracija","runtime":0,"tagline":"Prije 5 godina dogodio se smak svijeta. To je bio tek početak.","homepage":"","overview":"Kad su pronašli sigurnost grenlandskog bunkera nakon što je komet Clarke desetkovao Zemlju, obitelj Garrity sada mora riskirati sve kako bi krenula na opasno putovanje kroz pustoš Europe u potrazi za novim domom."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"","runtime":0,"tagline":"5 vuotta sitten tuli maailmanloppu. Se oli vasta alkua.","homepage":"","overview":"Maailmanlopusta selvinnyt Garrityn perhe joutuu jättämään Grönlannin bunkkerin ja sen antaman turvan ja lähteä vaaralliselle matkalle halki tuhotun, jäätiköityneen Euroopan erämaan etsiäkseen uuden kodin."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"末日逃生2：迁移","runtime":95,"tagline":"","homepage":"","overview":"　　由于宇宙中的两颗彗星正面撞击了地球，致使地表生态遭遇毁灭性打击，造成恶劣后果。全人类不得不躲藏在地堡中求得生存。身为科学家的加里蒂带着一家人劫后余生，幸存了下来。虽然他们躲过了第一波的冲击，但是他们所在的地堡中剩余的生活物资逐渐减少，其他幸存的人类也开始蠢蠢欲动。迫于压力这一家人必须离开格陵兰岛的安全掩体，开始踏上危险的旅程。在这一路上他们无奈的发现，整个欧洲已经被毁灭，变成了冰冻荒地。于是一家人只能再次被迫上路……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Гренландия 2: Миграция","runtime":0,"tagline":"","homepage":"","overview":"След като открива безопасността на бункера в Гренландия след разрушителния удар на кометата Кларк върху Земята, семейство Гарити е принудено да рискува всичко и да се впусне в опасно пътешествие през пустошта на Европа, за да намери нов дом."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Greenland: Az új menedék","runtime":0,"tagline":"","homepage":"","overview":"Nem sokkal azután, hogy egy üstökös megtizedelte a Föld élővilágát, a Garrity család kénytelen hátrahagyni a grönlandi bunker nyújtotta biztonságot, és nekivágni a darabjaira hullott világnak, hogy új otthont találjanak.  A 2020-as a 'Greenland - Az utolsó menedék' folytatására visszatért a rendezői székbe Ric Roman Waugh, míg a főbb szerepeket ezúttal is Gerard Butler és Morena Baccarin alakítják."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"末世綠洲2: 絕地遷徙","runtime":0,"tagline":"","homepage":"","overview":"五年前，彗星「奇勒」忽然撞擊地球，全球遭受毀滅性破壞，77億人僅餘少數人僥倖生還。尊、愛麗和兒子尼敦（謝拉畢拿、莫蓮娜芭卡琳、盧文格芬 飾）一家三口及時逃至格陵蘭，卻沒想到這才是災難開端…五年後，在地下避難所苟延殘喘的他們，不但要面對末日後的輻射風暴來襲及缺糧等問題，更因基地遭受極端天災摧毀，而被迫再一次逃難！尊一家從格陵蘭橫越大海到歐洲，穿越滿目瘡痍的末日世界，克服重重危機，只為尋找安身的「希望之地」…在絕望籠罩之下，人類還能如何頑抗？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Greenland – Um Novo Começo","runtime":86,"tagline":"","homepage":"https://www.cinemundo.pt/filmes/greenland-um-novo-comeco/","overview":"Na continuação dos acontecimentos de “Greenland”, a ameaça imediata do impacto do cometa Clarke foi ultrapassada mas o mundo encontra-se totalmente alterado. Depois de cinco anos a viver em modo de sobrevivência num “bunker” subterrâneo, os que resistiram à catástrofe deparam-se com uma nova realidade: praticamente todas as zonas do planeta se tornaram inabitáveis. Em busca de um lugar com condições mínimas de subsistência, John e Allison Garrity deixam a Gronelândia e seguem em direcção a uma cratera situada no sul de França que, segundo os especialistas, parece reunir condições para sustentar a vida. Pelo caminho, enfrentam não apenas um ambiente instável e imprevisível, mas também comunidades fragilizadas que, perante a escassez e o medo, se revelam capazes das maiores atrocidades."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"גרינלנד: בתנועה","runtime":0,"tagline":"הסוף של העולם שלנו היה רק ההתחלה.","homepage":"","overview":"לאחר פגיעת אסטרואיד שהחריבה את רוב כדור הארץ, הסרט עוקב אחר משפחת גאריטי, הנאלצת לעזוב את הבונקר הבטוח שלה בגרינלנד ולחצות עולם הרוס על מנת למצוא בית חדש."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"گرینلند 2 : مهاجرت","runtime":0,"tagline":"","homepage":"","overview":"بعد از این‌که یک شهاب‌سنگ بزرگ زمین را ویران می‌کند، خانواده گاری‌تی در پناهگاهی زیرزمینی در گرینلند زنده می‌مانند. حالا تقریباً پنج سال بعد، شرایط درون پناهگاه به‌قدری بحرانی می‌شود که آن‌ها مجبور می‌شوند آنجا را ترک کنند و در دنیایی یخ‌زده و ویران، سفری خطرناک را آغاز کنند تا مکانی امن‌تر برای زندگی پیدا کنند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Efter att en meteorit har utplånat större delen av jorden tvingas familjen Garrity lämna tryggheten i sin bunker på Grönland och ta sig genom en ödelagd värld på jakt efter ett nytt hem."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"ฝ่าชะตา โลกาวินาศ","runtime":0,"tagline":"","homepage":"","overview":"ครอบครัว การ์ริตี้ ที่รอดชีวิตมาได้ จะต้องเดินทางออกจากหลุมหลบภัยที่แสนจะปลอดภัยในกรีนแลนด์ และผจญการเดินทางอันแสนอันตราย ข้ามผ่านดินแดนเยือกแข็งที่แหลกสลายของยุโรป เพื่อค้นหาบ้านหลังใหม่"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":0,"tagline":"La fine del mondo sarà solo l'inizio","homepage":"","overview":"Avendo trovato la sicurezza del bunker della Groenlandia dopo che la cometa Clarke ha decimato la Terra, la famiglia Garrity deve ora rischiare tutto per intraprendere un pericoloso viaggio attraverso la terra desolata d'Europa per trovare una nuova casa."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":0,"tagline":"Πριν από 5 χρόνια, ο κόσμος τελείωσε. Αυτή ήταν μόνο η αρχή.","homepage":"","overview":"Μετά από πέντε χρόνια, οι επιζώντες του καταφυγίου στη Γροιλανδία, ο Τζον Γκάριτι, η σύζυγος και ο γιος του, παλεύουν με τη ζοφερή πραγματικότητα της ζωής υπογείως. Οι πόροι και το ηθικό εξαντλούνται, αλλά η εξερεύνηση της επιφάνειας μπορεί να θέσει σε κίνδυνο όλα για όσα πάλεψαν τόσο σκληρά. Ξαφνικά, ολόκληρος ο κόσμος των Γκάριτι καταρρέει ξανά όταν το καταφύγιο στη Γροιλανδία καταστρέφεται. Αντιμετωπίζουν τώρα τη σκληρή πραγματικότητα ότι κανένα μέρος δεν είναι ασφαλές για πάντα. Φήμες λένε ότι υπάρχει μια νέα όαση που δημιουργήθηκε στη Γαλλία στο σημείο πρόσκρουσης του μετεωρίτη Κλαρκ. Αποφασισμένη να συνεχίσει, η οικογένεια Γκάριτι ξεκινά το επικίνδυνο ταξίδι της προς τη Γαλλία."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Grenlande 2: Jauns patvērums","runtime":0,"tagline":"","homepage":"","overview":"Pēc komētas trieciena, kas iznīcināja lielāko daļu Zemes, Garitī ģimene ir spiesta pamest savu drošo bunkuru Grenlandē, lai šķērsotu izpostīto pasauli un meklētu jaunu mājvietu."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Grenlandija 2: Migracija","runtime":0,"tagline":"Upanje je neraziskano ozemlje.","homepage":"","overview":"Pet let po tem, ko je komet Clarke skoraj uničil Zemljo, družina Garrity še vedno živi v bunkerju na Grenlandiji. Svet zunaj je porušen, življenje pod zemljo pa postaja neznosno - še posebej za Nathana, zdaj že najstnika, ki si želi videti sončno svetlobo in svobodo. Ko se napetost v družini stopnjuje, John in Allison sprejmeta težko odločitev: zapustiti varnost bunkerja in se podati skozi razdejano, nevarno Evropo v iskanju novega doma."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Greenland 2","runtime":98,"tagline":"","homepage":"","overview":"Po katastrofie, która niemal zniszczyła naszą planetę i doprowadziła do zagłady większości jej mieszkańców, John Garrity wraz z żoną i synem próbuje zacząć nowe życie w spustoszonym świecie. Zmuszeni do opuszczenia bezpiecznego bunkra na Grenlandii, wyruszają przez zrujnowaną Europę w poszukiwaniu terenów nadających się do zamieszkania. Mówi się, że na południu dawnej Francji powietrze i woda są na tyle czyste, że jest szansa na przeżycie. Najpierw trzeba tam jednak dotrzeć. Droga wiedzie przez zrujnowane, wyludnione miasta i skażone pustynie, które były kiedyś ludzkimi siedliskami. Najbardziej niebezpieczne są jednak tereny opanowane przez ocalałych, którzy dla przetrwania są gotowi na wszystko. Każdy dzień tej wędrówki może okazać się ostatnim, a każdy nowy przyjaciel może stać się śmiertelnym wrogiem."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Groenlanda 2: Migrația","runtime":0,"tagline":"","homepage":"","overview":"Membrii supraviețuitori ai familiei Garrity trebuie să părăsească siguranța buncărului din Groenlanda și să pornească într-o călătorie periculoasă prin pustiul înghețat și devastat al Europei pentru a-și găsi o nouă casă."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"გრენლანდია 2: მიგრაცია","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":98,"tagline":"","homepage":"","overview":"Katastrofefilmen 'Greenland 2: Migration' fortsætter historien om familien Garrity, der overlevede kometnedslaget og nu tvinges ud af sikkerhed i bunkeren i Grønland for at krydse et nediset og ødelagt Europa i jagten på et nyt hjem."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Posledný úkryt 2","runtime":0,"tagline":"Nádej je neprebádané územie.","homepage":"","overview":"V pokračovaní katastrofického filmu sa rodina Garrityovcov (Gerard Butler, Morena Baccarin) ocitá v ďalšom nebezpečenstve. Päť rokov po dopade kométy, ktorá zničila veľkú časť Zeme, sú nútení opustiť svoj bezpečný bunker v Grónsku a vydať sa na dlhú cestu naprieč spustošenou a zamrznutou Európou, aby si našli nový obývateľný domov. V snahe prežiť a začať nový život na zatiaľ neznámom mieste budú musieť  čeliť  mnohým výzvam, ktoré si dovtedy nevedeli ani predstaviť."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Grenlandija 2: Migracija","runtime":0,"tagline":"","homepage":"","overview":"Radusi prieglobstį Grenlandijos bunkeryje po to, kai kometa sunaikino didžiąją dalį Žemės, šeima dabar privalo rizikuoti viskuo, leisdama į pavojingą kelionę per nuniokotą Europos dykynę. Jų tikslas – rasti naujus namus, kur galėtų pradėti gyvenimą iš naujo.  Šiame kelyje jų laukia ne tik gamtos stichijų išbandymai, bet ir žmogiškosios ištvermės bei vilties ribų patikrinimas. Kiekvienas žingsnis yra kova už išlikimą pasaulyje, kuris nebeprimena to, ką jie kadaise pažinojo."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"}],"reviews_tmdb":[{"id":"69641f439db2570eeb90d22e","url":"https://www.themoviedb.org/review/69641f439db2570eeb90d22e","author":"Manuel São Bento","content":"Full review: https://movieswetextedabout.com/greenland-2-migration-movie-review-gerard-butler-shines-in-a-superior-sequel/\r\n\r\nRating: B-\r\n\r\n\"Greenland 2: Migration is the first surprise of the year, standing out as a remarkable evolution of the original by swapping repetitive melodrama for a more tactical and emotionally engaging survival narrative. While not free of visual hiccups or script conveniences, the sequel compensates with robust performances and direction that knows how to value the scale of desolation. It’s an immersive experience that proves that even when the world ends, there’s still room to find new paths amidst the rubble, as long as we’re willing to walk forward instead of constantly checking the rearview mirror.\"","created_at":"2026-01-11T22:08:03.193Z","updated_at":"2026-01-11T22:08:03.222Z","author_details":{"name":"Manuel São Bento","rating":6,"username":"msbreviews","avatar_path":null}},{"id":"69648a0d8d99f86732dc4945","url":"https://www.themoviedb.org/review/69648a0d8d99f86732dc4945","author":"MovieGuys","content":"There's no keeping a good disaster movie down, with \"Greenland 2\" rounding out a family tale of survival, against the odds. \r\n\r\nWhilst the second outing wont win any awards, there's enough on offer here by way of over the top action, thrills and a compellingly heartfelt, back story, to make this film an entertaining watch.\r\n\r\nIn summary, formulaic, action packed and entertaining. Worth a look.","created_at":"2026-01-12T05:43:41.473Z","updated_at":"2026-01-12T05:44:05.153Z","author_details":{"name":"","rating":6,"username":"MovieGuys","avatar_path":null}}],"recommendations":[],"similar_content":[{"id":170,"adult":false,"title":"28 Days Later","video":false,"overview":"Twenty-eight days after a killer virus was accidentally unleashed from a British research facility, a small group of London survivors are caught in a desperate struggle to protect themselves from the infected. Carried by animals and humans, the virus turns those it infects into homicidal maniacs -- and it's absolutely impossible to contain.","genre_ids":[27,53,878],"popularity":16.2528,"vote_count":8234,"poster_path":"/sQckQRt17VaWbo39GIu0TMOiszq.jpg","release_date":"2002-10-31","vote_average":7.237,"backdrop_path":"/aJFwk1clMal1prxAvKAgHxKPAf.jpg","original_title":"28 Days Later","original_language":"en"},{"id":419261,"adult":false,"title":"Earthtastrophe","video":false,"overview":"In a white hot flash of light, and with no warning, one minute our moon is there, the next it's gone. Then, a second flash. And that's the last thing anyone on Earth can remember. 11 months later, it's not post- apocalyptic; it's apocalyptic as Earth has been sucked through a wormhole, literally ripping our planet from the inside out. With bizarre disasters and civilization collapsing, our heroes must find a way to survive and get to \"safe ground\" before it's too late.","genre_ids":[878,10770],"popularity":2.667,"vote_count":44,"poster_path":"/PdO6DOQktCGtPeZRrtOZhtvjWf.jpg","release_date":"2016-03-05","vote_average":4.6,"backdrop_path":"/q9VrDrEO55HppFzEchAmHfGH1Qw.jpg","original_title":"Earthtastrophe","original_language":"en"},{"id":664,"adult":false,"title":"Twister","video":false,"overview":"An unprecedented series of violent tornadoes is sweeping across Oklahoma. Tornado chasers, headed by Dr. Jo Harding, attempt to release a groundbreaking device that will allow them to track them and create a more advanced warning system. They are joined by Jo's soon to be ex-husband Bill, a former tornado chaser himself, and his girlfriend Melissa.","genre_ids":[28,12,18],"popularity":5.7984,"vote_count":3747,"poster_path":"/d4ie3f6QTvNw40V770Uzo87SDZn.jpg","release_date":"1996-05-10","vote_average":6.548,"backdrop_path":"/5oCAo7LFj2x0yByfi5JYirGnK8I.jpg","original_title":"Twister","original_language":"en"},{"id":1991,"adult":false,"title":"Death Proof","video":false,"overview":"Austin's hottest DJ, Jungle Julia, sets out into the night to unwind with her two friends Shanna and Arlene. Covertly tracking their moves is Stuntman Mike, a scarred rebel leering from behind the wheel of his muscle car, revving just feet away.","genre_ids":[28,53],"popularity":3.8446,"vote_count":5504,"poster_path":"/vtu6H4NWnQVqEp3aanUq3hNeeot.jpg","release_date":"2007-05-22","vote_average":6.841,"backdrop_path":"/qbVCChwbGWDAgsCXKZxyjBrRiWx.jpg","original_title":"Death Proof","original_language":"en"},{"id":2133,"adult":false,"title":"The Perfect Storm","video":false,"overview":"In October 1991, a confluence of weather conditions combined to form a killer storm in the North Atlantic. Caught in the storm was the sword-fishing boat Andrea Gail.","genre_ids":[18,12,28],"popularity":3.6238,"vote_count":2497,"poster_path":"/vJPoxqgpfFNbGi0HyoNsjFeLCio.jpg","release_date":"2000-06-29","vote_average":6.478,"backdrop_path":"/tO1wEUOSmZLyttwkhOMzUxTiR7k.jpg","original_title":"The Perfect Storm","original_language":"en"},{"id":435,"adult":false,"title":"The Day After Tomorrow","video":false,"overview":"After paleoclimatologist Jack Hall is largely ignored by UN officials when presenting his environmental concerns about the beginning of a new Ice Age, his research proves true when a superstorm develops, setting off catastrophic natural disasters throughout the world. Trying to get to his son, Sam, who is trapped in New York City with his friend Laura and others, Jack and his crew must travel to get to Sam before it's too late.","genre_ids":[878,53,12],"popularity":6.0896,"vote_count":8677,"poster_path":"/Wr4HeYQRvwVCxzOV5TmGE7UkXq.jpg","release_date":"2004-05-26","vote_average":6.549,"backdrop_path":"/smqQ71MIn1DSdSiQzCzCOV6rgRq.jpg","original_title":"The Day After Tomorrow","original_language":"en"},{"id":503,"adult":false,"title":"Poseidon","video":false,"overview":"A packed cruise ship traveling the Atlantic is hit and overturned by a massive wave, compelling the passengers to begin a dramatic fight for their lives.","genre_ids":[12,28,18,53],"popularity":3.4635,"vote_count":2254,"poster_path":"/fDPdjGc8SUEDWfTwMaZlCE6NSi3.jpg","release_date":"2006-05-03","vote_average":5.9,"backdrop_path":"/cmif4raVnSublaj6wEswHHPPL65.jpg","original_title":"Poseidon","original_language":"en"},{"id":16309,"adult":false,"title":"Monster","video":false,"overview":"Two women, aspiring documentary filmmakers, find themselves trapped in a monster-plagued Tokyo in 2003.","genre_ids":[28,27,878],"popularity":2.5564,"vote_count":31,"poster_path":"/dhZMd89Fa0DWIWOnXLsgkh3fN5W.jpg","release_date":"2008-01-18","vote_average":3.2,"backdrop_path":"/o7NQzQbDMZk7izm07ToJuXMHrpl.jpg","original_title":"Monster","original_language":"en"},{"id":15749,"adult":false,"title":"While She Was Out","video":false,"overview":"Della Myers, a suburban housewife, lives with her twin children and her abusive husband, Kenneth. On Christmas Eve, she drives to the local mall to buy gift-wrap. In the jam-packed parking lot, she notices an old car taking up two spaces and decides to leave a note on the windshield calling them out. After the mall closes, her car is blocked by the old car and she's threatened by four thugs. She escapes in her vehicle, but they drive after her. She crashes at a dead end construction site at the edge of a forest. What unfolds in the desolate woods is Della's lone fight for survival against a gang of angry young men with murderous intent.","genre_ids":[18,53],"popularity":0.8213,"vote_count":191,"poster_path":"/ehhJzxVV566RxPKmotY4E6xU477.jpg","release_date":"2008-10-27","vote_average":5.6,"backdrop_path":"/d8twGjhgFmsapoUpY4K6WoieobH.jpg","original_title":"While She Was Out","original_language":"en"},{"id":16380,"adult":false,"title":"When Worlds Collide","video":false,"overview":"When a group of astronomers calculate a star is on a course to slam into Earth, a few days before, it's accompanying planet will first pass close enough to the Earth to cause havoc on land and sea. They set about building a rocket so a few selected individuals can escape to the planet.","genre_ids":[878,18],"popularity":0.8212,"vote_count":196,"poster_path":"/zVBEXGxtnD83t0PfKm9uZbnpDbA.jpg","release_date":"1951-09-14","vote_average":6.334,"backdrop_path":"/3yq46OSqqCqh6nP36guN1WAwwVy.jpg","original_title":"When Worlds Collide","original_language":"en"},{"id":18230,"adult":false,"title":"Supervolcano","video":false,"overview":"Yellowstone is a park, but it's also the deadliest volcano on Earth. Beneath it, a sleeping 'dragon' is stirring. When an earthquake opens a crack for magma to seep through, other warning signs of an eruption start popping up, but they are ignored or dismissed as 'minor'. But when they learn an eruption will happen, panic breaks out through people of the USA and the world.","genre_ids":[28,18,53,10770],"popularity":0.5862,"vote_count":39,"poster_path":"/mVmVm2gZduw857yU4LR6C1nb2lO.jpg","release_date":"2005-03-13","vote_average":6.2,"backdrop_path":"/gxaaYsRmBSuTaiTlw2BJfqPILVw.jpg","original_title":"Supervolcano","original_language":"en"},{"id":266433,"adult":false,"title":"Ejecta","video":false,"overview":"Two men witness an unexplainable event in the sky as a historic solar storm approaches, and they try to survive as a terrifying life form hunts them.","genre_ids":[878],"popularity":0.3,"vote_count":42,"poster_path":"/wMF7hBnoUhVjjDZcTZqaO1iZ378.jpg","release_date":"2014-09-24","vote_average":3.762,"backdrop_path":"/Ao1qigOI0ekNYaxDwndivAhzLei.jpg","original_title":"Ejecta","original_language":"en"},{"id":19166,"adult":false,"title":"House of 9","video":false,"overview":"Nine strangers wake up in a house with no recollection how they got there and no way out. The voice on the PA introduces them to a grisly game they must play. The prize is $5 million and their life.","genre_ids":[53,18,27],"popularity":0.7167,"vote_count":237,"poster_path":"/3WHQlgb9aKMu35K5UC0DTlUd37n.jpg","release_date":"2005-06-19","vote_average":5.015,"backdrop_path":"/yNEIo4uwh1vP2yZ8Y23UmNlitpK.jpg","original_title":"House of 9","original_language":"en"},{"id":19209,"adult":false,"title":"White Water Summer","video":false,"overview":"When the experienced guide Vic accompanies the city boy Alan and his three friends on their first wilderness experience, he not only hopes to teach the four boys lessons about the wilderness, but about themselves. Vic pushes them to the limit. Soon after alienating the boys, Vic finds himself in desperate need of help and must rely on his students in order to survive.","genre_ids":[12,18],"popularity":0.7055,"vote_count":103,"poster_path":"/jvoxMkXms4O490OlCNuJk4y7ZB4.jpg","release_date":"1987-07-10","vote_average":6.2,"backdrop_path":"/kz8lB8SXZHdxQmS89yINcvP9L4m.jpg","original_title":"White Water Summer","original_language":"en"},{"id":252932,"adult":false,"title":"Locusts","video":false,"overview":"A swarm of locusts appears on the horizon near a Midwestern town and the inhabitants must find a way to destroy or divert them before the insects devour the area's valuable crops","genre_ids":[18,10770,27,53],"popularity":0.2448,"vote_count":6,"poster_path":"/x7uNWRlMFBwsP0luldvcWqMUkEs.jpg","release_date":"1974-10-09","vote_average":4.8,"backdrop_path":"/mKWEuhxQQ92cbtczmUoFpS3lJC.jpg","original_title":"Locusts","original_language":"en"},{"id":2787,"adult":false,"title":"Pitch Black","video":false,"overview":"When their ship crash-lands on a remote planet, the marooned passengers soon learn that escaped convict Riddick isn't the only thing they have to fear. Deadly creatures lurk in the shadows, waiting to attack in the dark, and the planet is rapidly plunging into the utter blackness of a total eclipse. With the body count rising, the doomed survivors are forced to turn to Riddick with his eerie eyes to guide them through the darkness to safety. With time running out, there's only one rule: Stay in the light.","genre_ids":[53,878,28],"popularity":2.0449,"vote_count":4697,"poster_path":"/3AnlxZ5CZnhKKzjgFyY6EHxmOyl.jpg","release_date":"2000-02-18","vote_average":6.9,"backdrop_path":"/mZGwhwIwYuF0G9XLS8j23dhNfUC.jpg","original_title":"Pitch Black","original_language":"en"},{"id":254128,"adult":false,"title":"San Andreas","video":false,"overview":"In the aftermath of a massive earthquake in California, a rescue-chopper pilot makes a dangerous journey across the state in order to rescue his estranged daughter.","genre_ids":[28,18,53],"popularity":6.5278,"vote_count":8908,"poster_path":"/2Gfjn962aaFSD6eST6QU3oLDZTo.jpg","release_date":"2015-05-27","vote_average":6.244,"backdrop_path":"/zcySy6dnSmyqiichtDgO7AEeZoq.jpg","original_title":"San Andreas","original_language":"en"},{"id":9341,"adult":false,"title":"The Core","video":false,"overview":"Geophysicist Dr. Josh Keyes discovers that an unknown force has caused the earth's inner core to stop rotating. With the planet's magnetic field rapidly deteriorating, our atmosphere literally starts to come apart at the seams with catastrophic consequences. To resolve the crisis, Keyes, along with a team of the world's most gifted scientists, travel into the earth's core. Their mission: detonate a device that will reactivate the core.","genre_ids":[878,12,53],"popularity":4.2353,"vote_count":2084,"poster_path":"/iMPR3OFhKNVvJw4eZoRhf9RzfHJ.jpg","release_date":"2003-03-28","vote_average":5.809,"backdrop_path":"/v2YxWPX2yKdo6arIAknJzKLxhZY.jpg","original_title":"The Core","original_language":"en"},{"id":9355,"adult":false,"title":"Mad Max Beyond Thunderdome","video":false,"overview":"Mad Max becomes a pawn in a decadent oasis of a technological society, and when exiled, becomes the deliverer of a colony of children.","genre_ids":[28,12,878],"popularity":4.1882,"vote_count":3181,"poster_path":"/jJlxcEVVUHnrUeEkQ0077VeHQpb.jpg","release_date":"1985-06-29","vote_average":6.217,"backdrop_path":"/br1zDvgmBPa1EbBrUmEDaXXgykq.jpg","original_t