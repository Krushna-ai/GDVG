,"display_priority":13}]},"TW":{"link":"https://www.themoviedb.org/movie/278927-the-jungle-book/watch?locale=TW","flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":2}]},"UA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3},{"logo_path":"/bZvc9dXrXNly7cA0V4D9pR8yJwm.jpg","provider_id":35,"provider_name":"Rakuten TV","display_priority":4}],"link":"https://www.themoviedb.org/movie/278927-the-jungle-book/watch?locale=UA","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3},{"logo_path":"/bZvc9dXrXNly7cA0V4D9pR8yJwm.jpg","provider_id":35,"provider_name":"Rakuten TV","display_priority":4}]},"US":{"buy":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":6},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"link":"https://www.themoviedb.org/movie/278927-the-jungle-book/watch?locale=US","rent":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":6},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":3}]},"UY":{"link":"https://www.themoviedb.org/movie/278927-the-jungle-book/watch?locale=UY","flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":25}]},"VE":{"buy":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3}],"link":"https://www.themoviedb.org/movie/278927-the-jungle-book/watch?locale=VE","flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":1}]},"ZA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3}],"link":"https://www.themoviedb.org/movie/278927-the-jungle-book/watch?locale=ZA","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3}]}}},"wikidata_id":"Q16857406","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-11T22:26:17.914471+00:00","region":null,"main_poster":null,"images":null,"enriched_at":"2026-02-22T20:39:17.861+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":106,"tagline":"The legend comes to life.","homepage":"http://movies.disney.com/the-jungle-book-2016","overview":"A man-cub named Mowgli fostered by wolves. After a threat from the tiger Shere Khan, Mowgli is forced to flee the jungle, by which he embarks on a journey of self discovery with the help of the panther, Bagheera and the free-spirited bear, Baloo."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"奇幻森林","runtime":106,"tagline":"","homepage":"","overview":"毛克利（尼尔·塞西 Neel Sethi 饰）是一个由狼群养大的人类男孩，影片围绕他的森林冒险徐徐展开。谢利·可汗，一只受过人类伤害的老虎（伊德里斯·艾尔巴 Idris Elba 配音），发誓要将毛克利铲除。为了逃脱追捕，毛克利跟随严厉的导师黑豹巴希拉（本·金斯利 Ben Kingsley 配音）和自由自在的好友棕熊巴鲁（比尔·默瑞 Bill Murray 配音），踏上了一场精彩纷呈的自我探索旅程。在这趟旅途中，毛克利遇到了一些对他居心叵测的丛林生物，包括巨蟒卡奥（斯嘉丽·约翰逊 Scarlett Johansson 配音），她用迷人的声音和眼神迷惑毛克利；还有花言巧语的猩猩路易王（克里斯托弗·沃肯 Christopher Walken 配音），他试图通过威逼利诱让毛克利交出迷幻而致命的“红花”——火焰的秘密。当森林不再是安全的家园，毛克利该何去何从？而毕生难忘的伟大冒险，才刚刚拉开序幕……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"El libro de la selva","runtime":105,"tagline":"La leyenda nunca será lo mismo.","homepage":"","overview":"Después de ser abandonado en la selva, una familia de lobos cría al pequeño cachorro humano Mowgli. Gracias a la manada de lobos, sale adelante hasta ser capaz de enfrentarse por sí mismo a los peligros de la selva. Pero con la llegada del peligroso Shere Khan, Mowgli deja de ser bien recibido. Este temible tigre, resentido por las heridas que le ha ocasionado el hombre, ha prometido eliminar toda amenaza humana en la selva. Así que a Mowgli no le queda más remedio que abandonar el único hogar que ha conocido en toda su vida.  El pequeño niño humano emprenderá entonces un arriesgado y fascinante viaje de autodescubrimiento, para regresar junto a su especie, acompañado de la siempre fiel Bagheera, la pantera mentora del niño, y el despreocupado y divertido oso Baloo.  Esta nueva adaptación de El Libro de la selva de Rudyard Kipling, que combina acción real con escenarios fotorrealistas y animales generados por ordenador, corre a cargo de Disney."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Le Livre de la jungle","runtime":106,"tagline":"Tu n'es plus en sécurité dans la jungle.","homepage":"","overview":"Les aventures de Mowgli, un petit homme élevé dans la jungle par une famille de loups. Mais Mowgli n'est plus le bienvenu dans la jungle depuis que le redoutable tigre Shere Khan, qui porte les cicatrices des hommes, promet d'éliminer celui qu'il considère comme une menace. Poussé à abandonner le seul foyer qu'il ait jamais connu, Mowgli se lance dans un voyage captivant, à la découverte de soi, guidé par son mentor la panthère Bagheera et l'ours Baloo. Sur le chemin, Mowgli rencontre des créatures comme Kaa, un pyton à la voix séduisante et au regard hypnotique et le Roi Louie, qui tente de contraindre Mowgli à lui révéler le secret de la fleur rouge et insaisissable : le feu."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"O Livro da Selva","runtime":106,"tagline":"","homepage":"","overview":"Com base nas histórias intemporais de Rudyard Kipling e inspirado no clássico filme de animação da Disney, O Livro da Selva é uma aventura épica em imagem real sobre Mogli, um menino criado por uma família de lobos. Mogli descobre que já não é bem-vindo na selva quando o temido tigre Shere Khan, que carrega as cicatrizes do Homem, promete eliminar o que considera uma ameaça. Incitado a abandonar a única casa que alguma vez conheceu, Mogli embarca numa jornada de autodescoberta, conduzido pela pantera transformada em severo mentor Baguera e pelo urso de espírito livre Balu. Ao longo do caminho, Mogli encontra criaturas da selva que não têm as melhores intenções, incluindo Kaa, uma cobra cuja voz e olhar sedutor hipnotizam o menino, e o Rei Louie, que tenta coagir Mogli a revelar o segredo da flor vermelha elusiva e mortal: o fogo."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":105,"tagline":"Die Legende wird niemals dieselbe sein.","homepage":"","overview":"Der junge Mogli ist nach einem Zwischenfall von seiner Familie getrennt und von nun an alleine im indischen Dschungel unterwegs. Er findet jedoch schon bald Zuflucht bei der Wolfsmutter Rakcha, die ihn als einer seiner Kinder aufzieht. Allerdings hat es der Tiger Schir Khan auf ihn abgesehen und Mogli bringt das Wolfsrudel unfreiwilig in Gefahr. Als er letztendlich von den Wölfen verstoßen wird, nehmen sich der Bär Balu und der Panther Baghira seiner an. Gemeinsam machen sie sich auf, Mogli zurück zu den Menschen zu bringen. Auf dem Weg durch den Dschungel bekommen sie es aber mit allerhand Gefahren zu tun, so auch der hinterhältigen Schlange Kaa und allen voran der Tiger Schir Khan, der immer noch hinter dem Menschenjungen her ist..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":107,"tagline":"","homepage":"http://www.thejunglebook.nl/","overview":"The Jungle Book gaat over Mowgli, een mensenjong dat opgroeit bij een wolvenroedel. Mowgli voelt zich niet langer thuis in de jungle wanneer de angstaanjagende Shere Khan, de tijger die zichtbaar getekend is door de mens, bezweert alles te elimineren wat hij als een bedreiging ziet. Als Mowgli de enige plek die hij kent moet verlaten, begint hij aan een fascinerende reis op zoek naar zichzelf. In gezelschap van zijn strenge mentor, panter Bagheera, en de zorgeloze beer Baloo komt hij onderweg junglebewoners tegen die nu niet bepaald het beste met hem voorhebben. Kaa, probeert het mensenjong te hypnotiseren met haar verleidelijke blik en stem, en koning Louie, probeert Mowgli het geheim te laten prijsgeven. Het geheim van de ongrijpbare en dodelijke rode bloem: vuur."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"A dzsungel könyve","runtime":0,"tagline":"","homepage":"","overview":"Egy árva fiú a dzsungelben cseperedik fel, de nem marad segítők nélkül. Társai között egy medve, egy fekete párduc és farkasok is akadnak. Sir Kán azonban már hosszú ideje feni a fogát az embercsemetére.Rudyard Kipling klasszikus meséjét, A dzsungel könyvét aligha kell bemutatni bárkinek is. Ki ne ismerné Mauglit, a fiúét, aki a dzsungel mélyén a farkasok nevelnek fel és akit gyerekkorában a mindig bölcs medve, Balu próbál meg terelgetni az élet tengerében, a fekete párduccal, Bagirával közösen.  A fákkal és indákkal övezet erdőségekben azonban a veszélynek sem vagyunk híján, hiszen Ká és Sírkán is állandó fenyegetést jelent, de talán a majomkirály Lajcsi sem éppen az ember legjobb barátja."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Το Βιβλίο της Ζούγκλας","runtime":106,"tagline":"Ο θρύλος δεν θα είναι ποτέ ξανά ο ίδιος.","homepage":"https://www.facebook.com/DisneyJungleBook","overview":"Όταν ένας τρομακτικός τίγρης απειλεί την ζωή τού Μόγλη, του μεγαλωμένου από λύκους παιδιού, εκείνος αφήνει το σπίτι του στην ζούγκλα και με οδηγούς τον αυστηρό πάνθηρα Μπαγκίρα και τον αρκούδο με το ελεύθερο πνεύμα, τον Μπαλού, για να καταλήξει σε μία περιπέτεια αυτοανακάλυψης."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"ספר הג'ונגל","runtime":0,"tagline":"הקלאסיקה מתעוררת לחיים","homepage":"","overview":"מוגלי, ילד שגודל על ידי משפחה של זאבים, מגלה שהוא אינו רצוי עוד בג'ונגל לאחר שהנמר האימתני שירחאן, אשר נותר מצולק על ידי בני האדם, מחליט שמוגלי הוא סכנה שצריך לסלק מהג'ונגל. כשהוא נאלץ לעזוב את הבית היחיד שאי פעם הכיר, מוגלי יוצא למסע מרתק של גילוי עצמי, מובל על ידי מורו הרוחני- הפנתר בגירה ועל ידי באלו- הדוב החופשי בנשמתו. לאורך הדרך מוגלי פוגש ביצורים שונים בג'ונגל כמו קאה, נחשית פיתון שמפתה ומהפנטת את גור-האדם, והמלך לואי החלקלק, שמנסה לשכנע את מוגלי לוותר על הסוד לפרח האדום החמקמק והקטלני: אש."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Cartea Junglei","runtime":105,"tagline":"Legenda nu va mai fi niciodată la fel.","homepage":"","overview":"Celebra colecție de povestiri a lui Rudyard Kipling are parte de o nouă ecranizare în regia lui Jon Favreau. Vom vedea cum micul Mowgli este crescut de lupoaica Raksha în junglă, devenind prieten la cataramă cu voiosul urs Baloo și precauta panteră neagră Bagheera. Pornit în căutarea familiei sale, Mowgli va trebui să-l înfrunte pe regele maimuțelor, pe înfometatul piton Kaa, dar și pe fiorosul tigru Shere Khan, spaima întregii jungle! Va reuși micul Mowgli să-și regăsească părinții?"},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Il libro della giungla","runtime":105,"tagline":"La leggenda non sarà più la stessa.","homepage":"","overview":"La storia, nata originariamente dalla fantasia dello scrittore inglese Rudyard Kipling, narra le vicende di Mowgli, un giovane cucciolo di uomo cresciuto da una famiglia di lupi e costretto a lasciare la giungla quando la temibile tigre Shere Khan, segnata dalle cicatrici dell’uomo, giura di eliminarlo per evitare che diventi una minaccia. Mentre abbandona la sua unica casa, Mowgli s’imbarca in un avvincente viaggio alla scoperta di se stesso, guidato dal suo severo mentore, la pantera Bagheera, e dallo spensierato orso Baloo."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Kniha džunglí","runtime":105,"tagline":"Legenda nebude nikdy stejná.","homepage":"","overview":"Hrdinou filmu je chlapec Mauglí, člověčí mládě vychované v džungli vlčí smečkou. Do džungle však přichází hrozivý tygr Šér Chán, jenž si nese jizvy způsobené člověkem. Šér Chán chce zničit vše, co vnímá jako ohrožení a Mauglí cítí, že již v džungli není vítán. A tak opouští svůj domov a vydává se na dobrodružnou cestu plnou poznání. Provází ho přísný mentor, pardál Baghíra, a veselý medvěd Balú. Cestou džunglí se Mauglí setká se zvířaty, které to s ním nemyslí vždy dobře. Patří mezi ně krajta Ká, jejíž svůdný hlas a pronikavý pohled hypnotizují člověčí mládě, a marnivý král Ludvík, který se snaží Mauglího přemluvit, aby mu prozradil tajemství překrásného, leč smrtonosného Rudého květu: ohně."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Seorang anak manusia bernama Mowgli yang diasuh oleh serigala. Setelah mendapat ancaman dari harimau Shere Khan, Mowgli terpaksa melarikan diri dari hutan, dan memulai perjalanan mencari jati diri dengan bantuan macan kumbang, Bagheera, dan beruang berjiwa bebas, Baloo."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"Книга джунглей","runtime":101,"tagline":"Легенда никогда не будет прежней","homepage":"","overview":"Непримиримая борьба с опасным и внушающим страх тигром Шерханом вынуждает Маугли покинуть волчью стаю и отправиться в захватывающее путешествие. На пути мальчика ждут удивительные открытия и запоминающиеся встречи с пантерой Багирой, медведем Балу, питоном Каа и другими обитателями дремучих джунглей."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Mogli: O Menino Lobo","runtime":106,"tagline":"Homem é proibido!","homepage":"","overview":"Mogli é um menino criado por uma família de lobos. Mas Mogli sente que não é mais bem-vindo na floresta quando o temido tigre Shere Khan, que carrega cicatrizes causadas por caçadores, promete eliminar o que ele considera uma ameaça. Forçado a abandonar o único lar que conhece, Mogli embarca em uma cativante jornada de autoconhecimento, guiado pela pantera e mentora Bagheera e pelo alegre urso Baloo. Pelo caminho, Mogli encontra criaturas da selva que não são exatamente bondosas, incluindo Kaa, uma cobra cuja voz sedutora e olhar penetrante hipnotizam o menino-lobo, e Rei Loiue, o nobre de fala mansa que tenta convencer Mogli a contar o segredo da ilusória flor vermelha mortal: o fogo."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Junglebogen","runtime":106,"tagline":"Jon Favreau instruerer denne episke eventyrfilm fra Disney, der handler om Mowgli, en menneskeunge, der er opfostret af ulve, som begiver sig ud på en selvopdagelsesrejse, da han må forlade sit hjem.","homepage":"","overview":"Drengebarnet Mowgli vokser op hos en ulvefamilie i junglen. Da den menneskehadende tiger Shere Khan vender tilbage til området, kommer Mowglis liv i fare. Drengens ven, panteren Bagheera, finder det klogt at flytte Mowgli tilbage til menneskenes landsby. Der bliver til en lang og begivenhedsrig tur gennem junglen, hvor Mowgli bl.a. møder den dovne bjørn Baloo og kæmpeaben kong Louie."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Orman Çocuğu","runtime":103,"tagline":"","homepage":"","overview":"Ailesini kaybeden bir erkek çocuk vahşi ormanın derinliklerinde bir ayı, bir siyah panter ve bir kurt sürüsü tarafından büyütülür. Bagheera, Mowgli’ye bu macerada akıl hocalığı yapacaktır. Canlı-aksiyon ve epik türündeki bu hikayede, kurtlar tarafından yetiştirilen Mowgli evi bildiği tek yeri terketmek zorunda kalınca, hem kendisini hem dış dünyayı keşfetmek için yeni bir arayışa çıkacaktır. Rudyard Kipling‘in klasik çocuk romanından uyarlanan filmin yönetmenliğini Jon Favreau sırtlarken uyarlama senaryo ise Justin Marks’a ait. Disney tarafından hayata geçirilen filmin orijinal seslendirme kadrosunda ise Ben Kingsley ve Neel Sethi isimleri başı çekerken kadroda onlara Scarlett Johansson, Idris Elba, Bill Murray, Christopher Walken, Lupita Nyong'o ve Giancarlo Esposito  isimleri yer alıyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Djungelboken","runtime":106,"tagline":"","homepage":"","overview":"En föräldralös pojke växer upp i djungeln och uppfostras av vargar, björnar och en svart panter. Efter den klassiska sagan skriven av Rudyard Kipling."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Księga dżungli","runtime":106,"tagline":"","homepage":"","overview":"Przerażający tygrys Shere Khan, noszący na swym ciele szramy po walce z człowiekiem, postanawia wyeliminować z dżungli wszystko, co uważa za zagrożenie. Wychowany przez rodzinę wilków chłopiec o imieniu Mowgli przestaje być tam mile widziany. Zmuszony do porzucenia jedynego domu, jaki kiedykolwiek miał, Mowgli wyrusza w fascynującą podróż, podczas której odkryje swoje pochodzenie. Jego przewodnikami są pantera Bagheera, która przyjmuje rolę srogiego mentora, oraz niedźwiedź-filozof Baloo. Trójka bohaterów napotyka na swojej drodze stworzenia, które nie zawsze życzą Mowgliemu jak najlepiej. Są to między innymi pyton Kaa oraz podstępny King Louie, starający się wydobyć od Mowgliego tajemnicę nieuchwytnego i śmiertelnie niebezpiecznego „czerwonego kwiatu” – czyli ognia."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"เมาคลีลูกหมาป่า","runtime":105,"tagline":"เมาคลีลูกหมาป่า","homepage":"","overview":"เรื่องราวการผจญภัยของ เมาคลี เด็กน้อยที่ถูกเลี้ยงโดยครอบครัวของหมาป่า แต่เมาคลีพบว่าเขาไม่เป็นที่ต้อนรับในป่าแห่งนี้อีกต่อไปเมื่อแชร์คาน เสือร้ายผู้น่าเกรงขามที่มีแผลเป็นจากฝีมือมนุษย์ ให้คำมั่นว่าจะกำจัดทุกสิ่งที่เขาเห็นว่าเป็นภัยคุกคาม หลังจากถูกขับไล่จากบ้านเพียงหลังเดียวที่เขามี เมาคลีจึงออกเดินทางเพื่อค้นหาตัวเองในการผจญภัยครั้งยิ่งใหญ่ โดยได้รับการชี้แนะจากคู่หูที่กลายมาเป็นอาจารย์ บากีร่า และหมีผู้มีจิตวิญญาณอิสระ บาลู ระหว่างทาง เมาคลีได้เผชิญหน้ากับเหล่าสัตว์ป่าที่ไม่ได้ให้ความสนใจในจิตใจของเขา รวมถึง คา เหลือมที่เสียงอันเย้ายวนและจ้องสะกดจิตเด็กน้อยคนนี้ และคิง ลูอี้ผู้ปากหวาน ที่พยายามจะบังคับเมาคลีให้เปิดเผยความลับของพลังอันอัตรายและอธิบายไม่ได้ของดอกไม้แดงหรือที่เราเรียกกันว่า \"ไฟ\""},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bosanski","iso_639_1":"bs","iso_3166_1":"BS","english_name":"Bosnian"},{"data":{"title":"Viidakkokirja","runtime":106,"tagline":"Legenda ei tule koskaan olemaan samanlainen.","homepage":"","overview":"Susilauman kasvattama orpo poika, Mowgli, joutuu pahan tiikerin, Shere Khanin, silmätikuksi. Suojellakseen laumaansa Mowgli päättää pantteri Bagheeran opastuksella lähteä ihmisten kylään. Matkalla Mowgli törmää jättiläiskäärme Kaahan sekä apinakuningas Louiehen ja ystävystyy huulikarhu Baloon kanssa. Lopulta välit on selvitettävä Shere Khanin kanssa. Intian viidakoihin sijoittuva Viidakkokirja on Rudyard Kiplingin (1865–1936) tunnetuimpia teoksia. Viidakkokirjasta on tehty useita elokuvasovituksia, joista tunnetuin on viidakkopoika Mowglin tarinoista ideoitu Walt Disneyn klassikkoanimaatio Viidakkokirja (1967). Teknisesti taiturimainen elokuva on suurelta osin tehty tietokoneella, mitä ei yllättävää kyllä kovin helpolla huomaa lopputuloksesta. Miljööt on luotu kokonaan tietokoneilla ja eläimet ovat perinteisten tehosteiden ja digitehosteiden saumatonta yhteispeliä."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"與森林共舞","runtime":105,"tagline":"","homepage":"","overview":"意外中失去父母的男嬰，由狼群收養照料，隨著他漸漸長大，叢林裡的霸者老虎對他起了戒心，一心想將男孩驅逐，狼群無法與殘暴的老虎抗衡，唯一的希望就是將男孩送回人類村莊。就這樣，孤獨的孩子踏上一個人的旅程，在路上，他遇到了棕熊、黑豹、蟒蛇、還有猩猩王，各方人馬對於人類的出現各有盤算。不甘於離開從小長大的家園，男孩該如何起身對抗森林之王，爭回屬於自己的家？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"정글북","runtime":121,"tagline":"인간에게 허락되지 않은 모험이 시작된다","homepage":"","overview":"늑대 무리에서 길러진 인간 소년 모글리는 정글이 자신의 보금자리이고, 어미 늑대 락샤와 늑대들의 리더 아킬라가 자신의 부모라 여기며 살고 있다. 하지만 인간이 휘두른 횃불에 큰 상처를 입고 인간을 증오하게 된 정글의 무법자 쉬어칸은 모글리를 정글에서 쫓아내려 한다. 모글리는 쉬어칸의 위협을 피해 인간 세상으로 향하고, 그 여정에 든든한 멘토 바기라와 유쾌한 곰 발루가 동행한다. 정글을 떠나는 여정은 끝없는 위협으로 가득 차 있고, 쉬어칸 역시 그를 바짝 쫓는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"كتاب الأدغال","runtime":0,"tagline":"","homepage":"","overview":"الأسطورة لن تكون هي نفسها أبدا.\r رجل شبل يدعى ماوكلي ترعاه الذئاب. بعد تهديد من النمر شيري خان ، يضطر ماوكلي إلى الفرار من الغابة ، حيث يشرع في رحلة لاكتشاف الذات بمساعدة النمر ، باغيرا والدب الحر ، بالو."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Книга за джунглата","runtime":0,"tagline":"Легендата никога няма да бъде същата.","homepage":"","overview":"Историята проследява израстването на малко момченце, отгледано в джунглата от глутница вълци. Скоро Маугли разбира, че вече не е добре дошъл в единствения дом, когото познава, когато страховитият тигър Шир Хан, имащ горчив опит с Човека, се заканва да унищожи всичко, което сметне за заплаха. Детето предприема завладяващо пътешествие на самоопознаване под вещия взор на превърналата се в негов водач пантера Багира и свободолюбивия мечок Балу. Маугли среща и много създания, които не му мислят точно доброто, включително Ка, питон с хипнотизиращ поглед и глас, и убедителния Крал Луи, който се опитва да измъкне от Маугли тайната на огъня."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Книга джунглів","runtime":0,"tagline":"Легенда ніколи не буде такою ж","homepage":"","overview":"Історія неймовірних пригод індійського хлопчика Мауглі, вихованого зграєю диких вовків. Хто ж він – один з мисливців Вільного Народу джунглів, чи все ж таки людина? На шляху до самопізнання Мауглі зустрічає різних істот: одні стануть його вірними друзями, інші постійно становитимуть загрозу, але гострий розум і сміливе серце допоможуть хлопчині пройти всі випробування."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"El Libro de la Selva","runtime":106,"tagline":"La leyenda nunca será la misma","homepage":"","overview":"Mowgli, un niño criado en la selva por una manada de lobos, emprende un fascinante viaje de autodescubrimiento cuando se ve obligado a abandonar el único hogar que ha conocido en toda su vida."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Le livre de la jungle","runtime":106,"tagline":"La légende ne sera plus jamais la même.","homepage":"","overview":"Mowgli est un orphelin qui a été sauvé d'une mort certaine par une panthère noire appelée Bagheera. Confié au clan des loups, le garçon grandira pour devenir un être très spécial que tous adorent dans la jungle. Tous sauf un, Shere Kan, un tigre assoiffé de vengeance qui souhaite la mort du petit d'homme à tout prix. Mowgli sera forcé de fuir et ainsi quitter la seule famille qu'il ait jamais connue, pour se trouver un nouveau repère. Sur son chemin, il fera la rencontre de bons et moins bons personnages et découvrira au passage qui il est vraiment."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Књига о џунгли","runtime":106,"tagline":"","homepage":"","overview":"Заснован на чувеним причама Ридлија Киплинга и инспирисан Дизнијевим анимираним класиком, „Књига о џунгли“ је потпуно нова играна епска авантура о Моглију, људском младунчету које је подигла породица вукова."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Jungelboken","runtime":105,"tagline":"","homepage":"","overview":"Jungelboken er et legendarisk eventyr om Mowgli, en gutt som har vokst opp hos en ulvefamilie. Mowgli må dra fra jungelen for å slippe unna den farlige tigeren Shere Khan. Han drar ut på en begivenhetsrik reise sammen med den strenge panteren Bagheera og den livlige bjørnen Baloo. Underveis møter Mowgli andre dyr i jungelen, som Kaa - en pytonslange som hypnotiserer gutten - og King Louie, som prøver å tvinge ham til å røpe hemmeligheten med den flyktige og dødelige \"røde blomsten\": ild."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Kniha džungle","runtime":0,"tagline":"","homepage":"","overview":"Ľudské mláďa Mauglí sa kedysi zatúlal do džungle, kde sa ho ujala a vychovala vlčia svorka. Do džungle sa však vracia tiger Šer Chán, obávaný vládca pralesa. Šer Chán, ktorý si nesie jazvy, spôsobené človekom, prisahá, že odstráni všetko, čo vníma ako hrozbu. Mauglí cíti, že musí opustiť džungľu, jediný domov, ktorý kedy poznal. Spoločnosť mu robia len dvaja priatelia – čierny panter Baghíra a ľahkomyseľný medveď Balú. Počas svojej cesty stretáva v džungli veľa tvorov, ktoré však nemajú najčistejšie úmysly. Obrovský pytón so zvodným hlasom Kaa zláka ľudské mláďa do trosiek dávneho chrámu, kde sídli opičí kráľ Louie. Na prvý pohľad priateľský kráľ chce presvedčiť Mauglího, aby mu prezradil tajomstvo krásneho, prchavého a smrtiaceho červeného kvetu – ohňa."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Knjiga o džungli","runtime":0,"tagline":"Ponovno otkrijte priču o dječačiću Mowgliju i njegovim prijateljima panteri Bagheeri i medvjedu Baloou u spektakularnoj realnoj animaciji.","homepage":"","overview":"Mowgli je maleni dječak iz džungle kojeg je odgojila obitelj vukova. No, kada opaki tigar Shere Khan obećaje riješiti ga se, jer ga smatnja prijetnjom, Mowgli shvati da više nije dobrodošao u džunglu. On napušta svoj dom i kreće u avanturu samootkrivenja sa svojim mentorom –  panterom Bagheerom, te luckastim medvjedom zvanim Baloo.  Na svom putu Mowgli će upoznati životinje koje mu ne žele sve najbolje, poput zlokobne zmije Kaa i kralja majmuna Louieja, koji želi da mu Mowgli otkrije tajnu smrtonosnog crvenog cvijeta – vatre."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"El llibre de la selva","runtime":0,"tagline":"","homepage":"","overview":"Mowgli, un nen criat a la selva per una manada de llops, comença un fascinant viatge d'autoconeixement a l'haver d'abandonar l'única llar que ha conegut. Nova adaptació de la novel·la de Rudyard Kipling."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Cậu Bé Rừng Xanh","runtime":0,"tagline":"","homepage":"","overview":"Phim nói về chuyến phiêu lưu của Mowgli – một cậu bé mồ côi được đàn chó sói nuôi dưỡng trong rừng già Ấn Độ. Ngày qua ngày, Mowgli cảm thấy mình không còn được chào đón ở mái nhà tự nhiên này nữa, bởi một con hổ hung dữ tên Shere Khan tuyên bố sẽ tiêu diệt những sinh vật có khả năng gây nên hiểm họa, sau khi hắn bị loài người tấn công. Buộc phải rời khỏi chốn dung thân duy nhất, Mogwli dấn bước vào một hành trình khám phá, với sự dẫn dắt của báo đen Bagheera và gấu Baloo. Trên đường đi, Mowgli đã gặp những sinh vật xấu xa: một con trăn tên Kaa có ánh mắt thôimiên, con khỉ đột King Louie với khả năng nói tiếng người lưu loát. Chúng cố ép buộc Mowgli hé lộ công thức tạo ra “bông hoa đỏ” lập lòe, được gọi là Lửa."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"ジャングル・ブック","runtime":0,"tagline":"今、あふれ出すー生きる力。","homepage":"","overview":"モーグリは、生まれて間もなくジャングルに取り残されてしまう。黒ヒョウのバギーラから母オオカミのラクシャに託された彼は、愛情に包まれながら自然の厳しさと生き抜くための知恵と術を学んでいく。やがて少年となって動物たちと幸せな日々を過ごしていたモーグリは、人間に恨みを抱くトラのシア・カーンと出会う。シア・カーンから人間である自分の存在が、ジャングルやそこに住む動物たちの脅威になると言われる。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Džungļu grāmata","runtime":0,"tagline":"","homepage":"","overview":"Filmas pamatā ir Redjarda Kiplinga slavenā grāmatu sērija par Maugli. Uzaudzis džungļos vilku barā, viņš sastopas ar savu ienaidnieku - tīģeri Širhanu, kurš ir gatavs iznīcināt visu, kas Mauglim ir kļuvis tuvs. Lai tiktu skaidrībā pats ar sevi un gūtu rūdījumu pārbaudījumos, Mauglis dodas episkā ceļojumā kopā ar saviem pavadoņiem - lāci Balū un panteru Bagiru."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"魔幻森林","runtime":0,"tagline":"挑戰森林定律，生死一線！","homepage":"","overview":"故事講述由狼群養大的人類小男孩毛克利（尼爾塞西），不能再容於森林，因為曾受人類傷害的森林霸主老虎謝爾汗（艾德里斯艾巴 ）決意鏟除任何潛在威脅，被迫離開他唯一熟悉的家園，毛克利展開一段發現自我之旅。途中由黑豹導師巴希拉（賓京士利）和無拘無束的熊人巴魯（標梅利 ）為他指引；卻也遇上心懷鬼胎的蟒蛇卡亞（史嘉莉祖安遜），以誘人聲音和眼神作出迷惑，還有花言巧語的猩猩路易王試圖套取致命紅花之火的秘密⋯"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Džiunglių knyga","runtime":0,"tagline":"","homepage":"","overview":"Mauglis – berniukas, kurį vilkai užaugino džiunglėse. Jo draugai – laukinėje gamtoje gyvenantys paukščiai ir žvėrys. Tačiau ne visiems patinka, kad tarp jų gyvena žmonių vaikas. Todėl lydimas geriausių draugų – panteros Bagiros ir lokio Balu – mažasis drąsuolis išsiruošia į nuotykių ir pavojų kupiną kelionę, ieškoti savo tikrųjų namų."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"کتاب جنگل","runtime":0,"tagline":"","homepage":"","overview":"پسر کوچکی به نام موگلی که تا ۱۰ سالگی در جنگل و در کنار حیوانات و توسط خانواده‌ای از گرگ‌ها بزرگ شده است، اما اکنون او باید برای اینکه توسط شیر خان کشته نشود، جنگل را ترک کند و…"},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Knjiga o džungli","runtime":0,"tagline":"","homepage":"","overview":"Priljubljena pravljična zgodba o izgubljenem džungelskem dečku nas v osupljivi igrani različici popelje na nove pustolovščine neustrašnega Mavglija in njegovih živalskih prijateljev. Čeprav ga je kot dojenčka posvojil trop volkov in je odraščal po zakonih džungle, se zlobni tiger Šir Kan nikakor ne more sprijazniti s človeškim prišlekom. Da bi ušel njegovim maščevalnim krempljem, mora Mavgli zapustiti svoj dom, na nepozabni dogodivščini pa ga spremljata zvesta prijatelja - premeteni panter Bagira in dobrodušni medved Balu."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"ჯუნგლების წიგნი","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Džungliraamat","runtime":0,"tagline":"","homepage":"","overview":"Rudyard Kiplingu ajatul ja samanimelisel kirjandusklassikal ning samuti 1967. aasta Disney filmistuudio animafilmil põhinev linateos, mis sobilik ja põnev vaatamine igas vanuses kinosõbrale ja mille peategelaseks on keset džunglit hundikarjas kasvanud inimlaps nimega Mowgli."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"द जंगल बुक","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"}],"reviews_tmdb":[{"id":"57acf1c89251415882000311","url":"https://www.themoviedb.org/review/57acf1c89251415882000311","author":"Austin Singleton","content":"A great movie for the whole family. Watch my full review here.\r\n\r\nhttp://www.hweird1reviews.com/allreviews//the-jungle-book","created_at":"2016-08-11T21:44:40.460Z","updated_at":"2021-06-23T15:57:50.199Z","author_details":{"name":"Austin Singleton","rating":null,"username":"hweird1","avatar_path":null}},{"id":"57c8b6e1c3a3685be9000cf5","url":"https://www.themoviedb.org/review/57c8b6e1c3a3685be9000cf5","author":"Reno","content":"$11","created_at":"2016-09-01T23:16:49.501Z","updated_at":"2024-05-16T15:18:31.043Z","author_details":{"name":"Reno","rating":8,"username":"Rangan","avatar_path":"/6ZpVUJzqXMzH35VprEtnX0sNI3.jpg"}},{"id":"57c9773d9251415e9f0005e1","url":"https://www.themoviedb.org/review/57c9773d9251415e9f0005e1","author":"Gimly","content":"$12","created_at":"2016-09-02T12:57:33.765Z","updated_at":"2021-06-23T15:57:50.798Z","author_details":{"name":"Gimly","rating":5,"username":"Ruuz","avatar_path":"/xUObnJSvHrFPsIpoDmb1jiQZLq7.jpg"}},{"id":"58b03fcf9251411a6000e8e2","url":"https://www.themoviedb.org/review/58b03fcf9251411a6000e8e2","author":"Per Gunnar Jonsson","content":"$13","created_at":"2017-02-24T14:14:39.085Z","updated_at":"2024-05-16T15:21:15.198Z","author_details":{"name":"Per Gunnar Jonsson","rating":8,"username":"Dark Jedi","avatar_path":null}},{"id":"5f1100b943494f0033336f47","url":"https://www.themoviedb.org/review/5f1100b943494f0033336f47","author":"Kamurai","content":"$14","created_at":"2020-07-17T01:36:57.312Z","updated_at":"2021-06-23T15:58:40.750Z","author_details":{"name":"Kamurai","rating":6,"username":"Kamurai","avatar_path":"/sKeC7qZLAKreuwxH4x6U3mN7Aa8.jpg"}},{"id":"65748625cadb6b080f8ff573","url":"https://www.themoviedb.org/review/65748625cadb6b080f8ff573","author":"CinemaSerf","content":"$15","created_at":"2023-12-09T15:22:13.642Z","updated_at":"2023-12-09T15:22:13.756Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":9325,"adult":false,"title":"The Jungle Book","video":false,"overview":"The boy Mowgli makes his way to the man-village with Bagheera, the wise panther. Along the way he meets jazzy King Louie, the hypnotic snake Kaa and the lovable, happy-go-lucky bear Baloo, who teaches Mowgli \"The Bare Necessities\" of life and the true meaning of friendship.","genre_ids":[10751,16,12],"media_type":"movie","popularity":6.5718,"vote_count":6576,"poster_path":"/yN1kuupnPTLUprgfvC5WapgrxG4.jpg","release_date":"1967-10-18","vote_average":7.277,"backdrop_path":"/zj8XS0l1cWStpKnuD1LFMB3VoV1.jpg","original_title":"The Jungle Book","original_language":"en"},{"id":290595,"adult":false,"title":"The Huntsman: Winter's War","video":false,"overview":"As two evil sisters prepare to conquer the land, two renegades—Eric the Huntsman, who aided Snow White in defeating Ravenna in Snowwhite and the Huntsman, and his forbidden lover, Sara—set out to stop them.","genre_ids":[28,12,18],"media_type":"movie","popularity":3.7651,"vote_count":4980,"poster_path":"/ekHPrneEoa1EoDclWdillOKznqM.jpg","release_date":"2016-04-06","vote_average":6.3,"backdrop_path":"/4kCDWJhceLHwPbRWd9uTR8bJpLz.jpg","original_title":"The Huntsman: Winter's War","original_language":"en"},{"id":271110,"adult":false,"title":"Captain America: Civil War","video":false,"overview":"Following the events of Age of Ultron, the collective governments of the world pass an act designed to regulate all superhuman activity. This polarizes opinion amongst the Avengers, causing two factions to side with Iron Man or Captain America, which causes an epic battle between former allies.","genre_ids":[12,28,878],"media_type":"movie","popularity":15.2077,"vote_count":23757,"poster_path":"/rAGiXaUfPzY7CDEyNKUofk3Kw2e.jpg","release_date":"2016-04-27","vote_average":7.446,"backdrop_path":"/wdwcOBMkt3zmPQuEMxB3FUtMio2.jpg","original_title":"Captain America: Civil War","original_language":"en"},{"id":14873,"adult":false,"title":"The Jungle Book 2","video":false,"overview":"Mowgli has been living in the man-village with his little stepbrother Ranjan and his best friend Shanti. But the man-cub still has that jungle rhythm in his heart, and he misses his old buddies Baloo and Bagheera. When Mowgli wanders back to the wild for some swingin' fun, he soon finds the man-eating tiger Shere Khan is lurking in the shadows and planning his revenge.","genre_ids":[10751,16,12],"media_type":"movie","popularity":2.543,"vote_count":1181,"poster_path":"/21GanxizOIL1CN0HLx7j3je8k87.jpg","release_date":"2003-02-07","vote_average":5.893,"backdrop_path":"/bMcXBBkLHgh60Z8OnpIX4GdMN6m.jpg","original_title":"The Jungle Book 2","original_language":"en"},{"id":258489,"adult":false,"title":"The Legend of Tarzan","video":false,"overview":"Tarzan, having acclimated to life in London, is called back to his former home in the jungle to investigate the activities at a mining encampment.","genre_ids":[14,28,12],"media_type":"movie","popularity":4.8732,"vote_count":6435,"poster_path":"/eJrfz178xBGlxjDGxnBXTzWWa4w.jpg","release_date":"2016-06-29","vote_average":5.914,"backdrop_path":"/btCaMm9aVW1PG485Ef8RMBBALzI.jpg","original_title":"The Legend of Tarzan","original_language":"en"},{"id":209112,"adult":false,"title":"Batman v Superman: Dawn of Justice","video":false,"overview":"Fearing the actions of a god-like Super Hero left unchecked, Gotham City’s own formidable, forceful vigilante takes on Metropolis’s most revered, modern-day savior, while the world wrestles with what sort of hero it really needs. And with Batman and Superman at war with one another, a new threat quickly arises, putting mankind in greater danger than it’s ever known before.","genre_ids":[28,12,14],"media_type":"movie","popularity":15.8327,"vote_count":18760,"poster_path":"/5UsK3grJvtQrtzEgqNlDljJW96w.jpg","release_date":"2016-03-23","vote_average":6,"backdrop_path":"/mwuP3Ah8b7SKnmSCk8EaQw7jrEq.jpg","original_title":"Batman v Superman: Dawn of Justice","original_language":"en"},{"id":269149,"adult":false,"title":"Zootopia","video":false,"overview":"Determined to prove herself, Officer Judy Hopps, the first bunny on Zootopia's police force, jumps at the chance to crack her first case - even if it means partnering with scam-artist fox Nick Wilde to solve the mystery.","genre_ids":[16,12,10751,35],"media_type":"movie","popularity":30.0113,"vote_count":17707,"poster_path":"/hlK0e0wAQ3VLuJcsfIYPvb4JVud.jpg","release_date":"2016-02-11","vote_average":7.759,"backdrop_path":"/9tOkjBEiiGcaClgJFtwocStZvIT.jpg","original_title":"Zootopia","original_language":"en"},{"id":407436,"adult":false,"title":"Mowgli: Legend of the Jungle","video":false,"overview":"A human child raised by wolves, must face off against a menacing tiger named Shere Khan, as well as his own origins.","genre_ids":[12,18],"media_type":"movie","popularity":3.2381,"vote_count":2573,"poster_path":"/clRnzMsFoMIdC7I5JsG6dnnHH8l.jpg","release_date":"2018-11-25","vote_average":6.5,"backdrop_path":"/pApaVlxJCp2o4mrzCAD3AaLjq77.jpg","original_title":"Mowgli: Legend of the Jungle","original_language":"en"},{"id":333352,"adult":false,"title":"Eye in the Sky","video":false,"overview":"A UK-ba