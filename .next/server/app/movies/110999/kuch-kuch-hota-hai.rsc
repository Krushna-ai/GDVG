provider_id":1796,"provider_name":"Netflix Standard with Ads","display_priority":154},{"logo_path":"/8aBqoNeGGr0oSA85iopgNZUOTOc.jpg","provider_id":2100,"provider_name":"Amazon Prime Video with Ads","display_priority":204}]},"UY":{"link":"https://www.themoviedb.org/movie/11854/watch?locale=UY","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0},{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1}]},"VE":{"link":"https://www.themoviedb.org/movie/11854/watch?locale=VE","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0},{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":2}]},"YE":{"link":"https://www.themoviedb.org/movie/11854/watch?locale=YE","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0},{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1}]},"ZA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}],"link":"https://www.themoviedb.org/movie/11854/watch?locale=ZA","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}],"flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0},{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1}]},"ZM":{"link":"https://www.themoviedb.org/movie/11854/watch?locale=ZM","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0},{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1}]},"ZW":{"link":"https://www.themoviedb.org/movie/11854/watch?locale=ZW","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":2},{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":4}]}}},"wikidata_id":"Q623336","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-20T22:04:20.660019+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":[{"data":{"title":"Kuch Kuch Hota Hai","runtime":185,"tagline":"Love is Friendship.","homepage":"","overview":"Per her mother's last wish, an 8 year old girl sets out to reunite her father with his college best friend who was in love with him."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Kuch Kuch Hota Hai - Und ganz plötzlich ist es Liebe","runtime":177,"tagline":"","homepage":"","overview":"Indisches Liebesdrama von Karan Johar. Der beliebte Rahul und die burschikose Anjali sind beste Freunde. Als Tina neu auf die Schule kommt, sind sie bald ein Trio. Als Anjali Rahul ihre Liebe gesteht, erzählt er ihr, dass er sich in Tina verliebt hat. Rahul verlässt die Schule und die beiden anderen heiraten, doch das Glück währt nicht lange."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Laisse parler ton cœur","runtime":177,"tagline":"L'amour c'est l'amitié","homepage":"","overview":"Rahul, Anjali et Tina terminent leurs études à l'université. Anjali, la meilleure amie de Rahul, se rend compte qu'elle est amoureuse de lui quand il tombe amoureux de Tina. Rahul épouse Tina, mais celle-ci meurt après avoir donné naissance à leur fille, qu'elle tient à appeller Anjali. Huit ans plus tard, Rahul, inconsolable, ne s'est pas remarié. Mais sa fille découvre que sa mère lui a laissé pour mission de retrouver Anjali qui est partie sans laisser d'adresse..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"怦然心动","runtime":0,"tagline":"","homepage":"","overview":"Tina因为难产而选择自己离开人世而保住女儿，并给女儿留下了八封信。女儿Anjali八岁时，收到了母亲的最后一封信，信中讲述了她的父母以及另一个叫Anjali的女孩之间的故事，而那也是她为何给她的女儿取名为Anjali的原因。在大学时代，Tina和Anjali同时爱着Rahul，但Rahul却只把Anjali当成最好的朋友，而同时深爱着Tina。当看到Rahul和Anjali互相奔跑着来到各自面前，然后说出“I LOVE YOU”，Rahul只是为了在跟Tina表白之前练习一下，而Anjali却表达的自己的真实想法，当Rahul问她可不可以现在就去向Tina表白的时候，她抱着他，头偎在他肩膀上，眼里噙满了泪水；当他放开她在雨里，然后奔向Tina的时候，anjali的世界坍塌了。最好anjali收拾了行囊，想要默默地离开，当他追到车站想把她留下来，但是她却忍着痛苦祝福他和Tina；多年以后，他们再次相遇是因为Rahul和Tina的女儿小Anjali的刻意安排，他们互相不知所措，而Anjali已经不再像大学里那么风风火火，穿着纱丽变得非常美丽动人，可是那时候Anjali已经和Aman订婚了，Aman是个深爱她的男人，但是她嫁给他却只是妥协，当他们的婚礼举行的时候，Aman才从Anjali的眼神里看到的爱意，但却不是为了他，而是因为Anjali的初恋Rahul来到了现场，Aman拖着新娘来到大厅中间，对她说“我从你眼里看到爱意是第一次，但却不是因为我”……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Kuch Kuch Hota Hai","runtime":177,"tagline":"","homepage":"","overview":"Rahul y Anjali son los mejores amigos hasta que se encuentran en un triángulo romántico, una vez llega Tina. Rahul y Tina se casan y tienen una hija, que Tina nombra Anjalí, pero Tina muere en el parto. Anjalí, la hija de Rahul, recibe una serie de cartas escritas por su madre antes de su muerte y la última letra describe su nombre. La pequeña Anjalí intentará volver a unir a su padre de vuelta con su antigua mejor amiga de la universidad, Anjalí."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"משהו זז בלב","runtime":0,"tagline":"","homepage":"","overview":"רהול ואנג'לי חברים טובים, בסתר אנג'לי מאוהבת ברהול אך הוא רואה בה רק חברה טובה יותרנכון חבר טוב, רהול מתאהב בבחורה החדשה שמגיעה לקולג' ואנג'לי עוזבת כדי לא לעמוד בדרכם.רהול מתחתן בינתיים ושנים אחרי הם נפגשים שוב."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Усе в житті буває","runtime":0,"tagline":"","homepage":"","overview":"Маленька дівчинка Анджалі читає листи своєї матері, яка померла після важких пологів, і з них дізнається про історію кохання свого батька Рахула і його подруги по коледжу Анджалі ... Анджалі і Рахул - \"солодка парочка\". Весь коледж спостерігає за їх сварками і сутичками, але всі знають, що вони нерозлучні друзі і будь-яка їх сварка обов'язково закінчується перемир'ям. Але будь-яка ідилія може бути порушена випадковою подією - саме це й відбувається: з Америки приїжджає дочка директора коледжу Тіна - красива, освічена, модна дівчина. Рахул закохується в неї. Тіна теж симпатизує хлопцеві, а Анджалі, раптом розуміє, що Рахул, її найближчий друг, став ще й коханням всього її життя. Вона поспішає поділитися з ним своїми почуттями, але Рахул випереджає її та розповідає про свою любов до Тіни. Не наважившись зруйнувати щастя друга, Анджалі залишає коледж, так і не розповівши про свою любов ..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Bir Şeyler Oluyor","runtime":0,"tagline":"","homepage":"","overview":"Annesinin son dileğini yerine getirmek isteyen kız, babasını üniversitede ona âşık olan en iyi arkadaşıyla bir araya getirmeye çalışır, ancak kadın başkasıyla nişanlıdır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Kuch Kuch Hota Hai","runtime":177,"tagline":"","homepage":"","overview":"Anjali Sharma en de lokale casanova Rahul Khanna zijn dikke maatjes op het St. Xavier's College. Anjali denkt dat het ooit wel wat zal worden tussen haar en Rahul totdat Tina Malhotra bij hun op school komt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"무슨 일인가 일어나고 있어","runtime":0,"tagline":"","homepage":"","overview":"안젤리는 그녀의 가장 친한 친구이자 짝사랑 상대인 라훌이 티나와 사랑에 빠지자 슬픔에 잠긴다.  몇 년 후, 티나의 어린 딸은 라훌과 안젤리를 연결시키고자 하는 어머니의 마지막 소원을 이루려고 노력한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Algo sucede en mi corazón","runtime":0,"tagline":"","homepage":"","overview":"Una mujer deja cartas antes de morir, pidiendo a su hija hacer de casamentera de su padre y su amigo de la universidad."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Kuch Kuch Hota Hai","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Quando Surge o Amor","runtime":185,"tagline":"","homepage":"","overview":"Uma garota vai atrás da melhor amiga de faculdade do pai viúvo, acreditando que eles devam ficar juntos. Mas a mulher já está noiva de outro homem."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Всё в жизни бывает","runtime":177,"tagline":"Любовь-это Дружба","homepage":"","overview":"Красавица Тина умирает при родах, но перед смертью успевает написать своей новорожденной дочери Анджали восемь писем. В последнем, которое девочка читает, когда ей исполняется восемь лет, мама завещает ей помочь папе воссоединиться с другой Анджали, некогда пожертвовавшей своей любовью ради его счастья с Тиной. Сегодня Анджали как раз выходит замуж, и девочке потребуется преодолеть немало препятствий, чтобы все было хорошо и все запели жизнеутверждающую финальную песню."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Ceva se întâmplă","runtime":187,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Coś się dzieje","runtime":0,"tagline":"","homepage":"","overview":"Pomiędzy przyjaźniących się Anjali i Rahula wkracza Tina. Po latach, gdy mężczyzna zostaje wdowcem, jego córka postanawia ponownie połączyć losy dawnych przyjaciół."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Κάτι που να Αξίζει","runtime":177,"tagline":"","homepage":"","overview":""},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"ცხოვრებაში ყველაფერი ხდება","runtime":0,"tagline":"","homepage":"","overview":"მშვენიერი თინა მშობიარობისას იღუპება, მაგრამ გარდაცვალებამდე ახერხებს რვა წერილის დაწერას ახალშობილი ქალიშვილისთვის ანჯალისთვის. ბოლოში, რომელსაც გოგონა რვა წლის ასაკში კითხულობს, დედა უანდერძებს მას, რომ დაეხმაროს მამას სხვა ანჯალთან გაერთიანებაში, რომელიც ერთხელ თინასთან ბედნიერებისთვის სიყვარულს შესწირა. ანჯალი დღეს ახლახან ქორწინდება და გოგონას ბევრი წინაღობის გადალახვა დასჭირდება, რათა ყველაფერი კარგად იყოს და ყველამ იმღეროს სიცოცხლის დამადასტურებელი ბოლო სიმღერა."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"อัญชลี","runtime":0,"tagline":"","homepage":"","overview":"หนังบอลลิวูดชื่อดังตลอดกาล เรื่องรักโรแมนติก coming of age ที่เล่าผ่านรักสามเส้าสองหนที่เกิดขึ้นในคนละช่วงของชีวิต เพื่อนรักสองคน อัญชลีและราหุล ต้องแยกจากกัน เมื่อมีสาวคนใหม่อย่าง ทีน่า เข้ามาแทรกกลาง หลายปีผ่านไป ลูกสาวของทีน่าที่เสียไป ตัดสินใจจะจับคู่สองเพื่อนรักที่แยกจาก แต่อัญชลีดันหมั้นอยู่กับอามาน แล้วทีนี้อัญชลีจะเลือกใคร?"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"何かが起きてる","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"كوتش كوتش هوتا هي","runtime":0,"tagline":"","homepage":"","overview":"تدور احداث الفيلم حول (راهول) شاب يدرس في الجامعة ، لديه صديقة مفضلة في الجامعة تدعي (أنجلي) ، وهي تحبه كثيرا ، ولكنة لم يلاحظ ذلك ، حتى جاءت (تينا) ابنة مدير الجامعة ، والتي كانت تدرس في (لندن) ، وقد خطفت قلب (راهول) من النظرة الأولى ، وقد تعذبت (أنجلي) كثيرا عندما اخبرها (راهول) بحبه (لتينا) ، فقررت (أنجلي) أن تترك البلدة وتذهب لتعيش فى بيت أهلها ، حتى تزوج (راهول) من (تينا) ، وأنجب (أنجلي) الصغيرة ، وماتت (تينا) ، واتفقت (أنجلي) ابنته مع جدتها أن يجمعا بين أبيها ، وصديقته (أنجلي) بأية طريقة حتى يتزوجا ، وتنفذ وصية والدتها ، ولكن عندما يقرر (راهول) أن يذهب ليطلب يد (أنجلي) يتفاجأ بأنها سوف تتزوج ، فيحاول منع الزواج بأية طريقة ."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"遺下的愛","runtime":185,"tagline":"","homepage":"","overview":"為了完成母親臨終時的交代，一個女孩打算讓父親與愛過他的大學摯友重逢，卻發現那名女子已經訂婚了。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Něco se děje","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"}],"reviews_tmdb":[{"id":"647a6a61caef2d00df88070d","url":"https://www.themoviedb.org/review/647a6a61caef2d00df88070d","author":"badelf","content":"This film is the epitome of BOLLYWOOD. The script is a cheesy and predictable love triangle. But OH, the production design! the colors! the dancing! the costumes! the singing! the sets! and the cinematography! This film screams visual. If you have 3 hours for a heart-warming, don't-have-to-think, purely passive experience, see Kuch Kuch Hota Hai on as big a screen as you can find.","created_at":"2023-06-02T22:17:05.220Z","updated_at":"2023-06-02T22:18:36.677Z","author_details":{"name":"","rating":8,"username":"badelf","avatar_path":null}}],"recommendations":[{"id":4254,"adult":false,"title":"Kal Ho Naa Ho","video":false,"overview":"An uptight MBA student falls for the charismatic new neighbor who charms her troubled family – but he has a secret that forces him to push her away.","genre_ids":[35,18,10749],"media_type":"movie","popularity":1.7165,"vote_count":436,"poster_path":"/zhMI6I0kSLnewTMwE0A8Tz3Cj2f.jpg","release_date":"2003-11-27","vote_average":7.452,"backdrop_path":"/rTELwIG56mizXNT9Q27fVA2e7uh.jpg","original_title":"कल हो ना हो","original_language":"hi"},{"id":21210,"adult":false,"title":"Dil Se..","video":false,"overview":"Journalist Amar falls for a mysterious woman on an assignment, but she does not reciprocate his feelings. However, when Amar is about to get married, the woman shows up at his doorstep asking for help.","genre_ids":[18,10749],"media_type":"movie","popularity":0.8257,"vote_count":189,"poster_path":"/rCoGw9cp0EY2Rd504iqqjSDtepF.jpg","release_date":"1998-08-22","vote_average":6.862,"backdrop_path":"/8v8Uc4PfiZk6g87qdq2L87sCDvE.jpg","original_title":"दिल से..","original_language":"hi"},{"id":159090,"adult":false,"title":"Duplicate","video":false,"overview":"Seeking vengeance on those who double-crossed him, an escaped prisoner impersonates an unsuspecting chef.","genre_ids":[28,35],"media_type":"movie","popularity":0.9183,"vote_count":78,"poster_path":"/ylBsNn4xkMlZPk1beZuuwFqrWUK.jpg","release_date":"1998-05-08","vote_average":6.141,"backdrop_path":"/t07vHnStf1HvcOvlszlcjmCa8F1.jpg","original_title":"डुप्लीकेट","original_language":"hi"},{"id":14395,"adult":false,"title":"Kabhi Alvida Naa Kehna","video":false,"overview":"Dev and Maya are both married to different people. Settled into a life of domestic ritual, and convinced that they are happy in their respective relationships, they still yearn for something deeper and more meaningful, which is precisely what they find in each other.","genre_ids":[18,10749],"media_type":"movie","popularity":1.0326,"vote_count":224,"poster_path":"/lwgH4S0km8lD7rk5qy78EKW8YEn.jpg","release_date":"2006-08-11","vote_average":6.379,"backdrop_path":"/qRbAsojp77pkKYatbFGG7oIOa0P.jpg","original_title":"कभी अलविदा ना कहना","original_language":"hi"},{"id":45001,"adult":false,"title":"Deewana","video":false,"overview":"A singer marries his biggest fan, but his uncle plans to kill him in order to gain his money.","genre_ids":[28,35,80,18,10749],"media_type":"movie","popularity":1.1143,"vote_count":42,"poster_path":"/8liOcHgcghI3aQFxq8QCGKKqQKX.jpg","release_date":"1992-06-25","vote_average":6.8,"backdrop_path":"/8OFoHybzT7DbXkP1RmcuCjIHDZa.jpg","original_title":"दीवाना","original_language":"hi"},{"id":82698,"adult":false,"title":"Ladies VS. Ricky Bahl","video":false,"overview":"A smooth and charming conman, Ricky Bahl, cons girls for a living but finally meets his match is this fun-filled \"ROM-CON.\"","genre_ids":[35,18,10749],"media_type":"movie","popularity":0.524,"vote_count":81,"poster_path":"/3PxKzBv4hr7rKjofcCiMRnwx4AT.jpg","release_date":"2011-12-08","vote_average":5.988,"backdrop_path":"/4QRHPLwgVFG4psPn8OBMKNjvgo7.jpg","original_title":"Ladies VS. Ricky Bahl","original_language":"hi"},{"id":383281,"adult":false,"title":"Raju Chacha","video":false,"overview":"Siddhant Rai is a single father, looking after three young children. All four of them live a wealthy and comfortable lifestyle, which changes suddenly when Siddhant passes away after a car accident. Siddhant's shady relatives hire a former jailbird and con-man by the name of Shekar to pose as their paternal uncle, Raju, which he does for a hefty sum of money. When Raju is introduced to the children, he is an instant hit with them, as well as their Catholic governess, Anna. Then the Rai family are stunned when another young man enters their lives - claiming to be the real Raju Chacha.","genre_ids":[28,35,10751],"media_type":"movie","popularity":0.6144,"vote_count":21,"poster_path":"/eWT27sD5lp8y5CaMoknhFO3OwRi.jpg","release_date":"2000-12-21","vote_average":5.9,"backdrop_path":"/2gAkClLzdp2vPqbrujw3ibLppNr.jpg","original_title":"राजू चाचा","original_language":"hi"},{"id":974052,"adult":false,"title":"Pretty Young Thing","video":false,"overview":"It’s a new school year and at Rosenholm High School there are many initiation rituals that the new first-year students must go through, which are of great importance for their future life in high school, not least for their personal life.  Best friends and freshmen Frida and Selma quickly become friends with another first-year student Nadja. When Frida catches feelings for Nadja’s older boyfriend Emil and is invited to the ritual party for first-year students but Selma is not, their friendship starts to fall apart.","genre_ids":[18,35],"media_type":"movie","popularity":0.2893,"vote_count":16,"poster_path":"/9TzrxbBx5SZCnfCsZsM4qQgEQwr.jpg","release_date":"2022-10-13","vote_average":6.9,"backdrop_path":"/diqxKwyfnxrzdqLj6DJXNAAXDAG.jpg","original_title":"Smuk","original_language":"da"},{"id":64499,"adult":false,"title":"Quinceañera","video":false,"overview":"As Magdalena's 15th birthday approaches, her simple, blissful life is complicated by the discovery that she's pregnant. Kicked out of her house, she finds a new family with her great-granduncle and gay cousin.","genre_ids":[18],"media_type":"movie","popularity":0.3603,"vote_count":36,"poster_path":"/kJv276uU9K0Z9MRhz6F3BEEetEO.jpg","release_date":"2006-06-05","vote_average":6.2,"backdrop_path":"/iuZN4EzpPl9D21cteLyKRPQRoCT.jpg","original_title":"Quinceañera","original_language":"es"},{"id":165065,"adult":false,"title":"Kuch Khatti Kuch Meethi","video":false,"overview":"This story revolves around the lives of two look-alike sisters, who are brought up separately by their estranged parents, who had separated due to a misunderstandings when the girls were little. The twins meet, find out about their backgrounds, and decide to switch places","genre_ids":[10751,18],"media_type":"movie","popularity":0.3479,"vote_count":9,"poster_path":"/w8zIRrBdLBe5Jz9xAtfyTgxnJVw.jpg","release_date":"2001-01-19","vote_average":6,"backdrop_path":"/uBazz9l4I6tWYvZ8qyUQLaiMBW5.jpg","original_title":"कुछ खट्टी कुछ मीठी","original_language":"hi"},{"id":181462,"adult":false,"title":"Akaash Vani","video":false,"overview":"Akaash and Vani leaving their house to go to college. Vani catches her train on the other hand Akaash travels by a truck as he misses his train. As they reach their the next day Vaani says \"I love you\" to Akaash. He replies to this in a filmy way and both of them become friends. Akaash and Vani fall in love with each other and continue a 4 year rela