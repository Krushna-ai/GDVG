_639_1":"zh","vote_average":3.334},{"width":3840,"height":2160,"file_path":"/gOfgYtWFl7Awt8oKwNroyEUMG3M.jpg","iso_639_1":"zh","vote_average":3.334},{"width":1920,"height":1080,"file_path":"/uJEZaEM2hY3MG50CgZ3z9jeTwmp.jpg","iso_639_1":null,"vote_average":2.542},{"width":1920,"height":1080,"file_path":"/qxcM8r2CoKz7HliFGMbUoGYVx7F.jpg","iso_639_1":null,"vote_average":2.542},{"width":1525,"height":858,"file_path":"/rrUsh0jODStzpJcDbDvLB1Tl901.jpg","iso_639_1":null,"vote_average":2.278},{"width":1525,"height":858,"file_path":"/dHjAdJcst9DKZZG1vXe6Y8HlCI5.jpg","iso_639_1":"zh","vote_average":0},{"width":1525,"height":858,"file_path":"/pYNsS3hNu2EWM5VVyAllY6Fw7g7.jpg","iso_639_1":null,"vote_average":0},{"width":1525,"height":858,"file_path":"/86IFp84vAfnxKgH5xsxWhtypbsL.jpg","iso_639_1":null,"vote_average":0},{"width":1525,"height":858,"file_path":"/qtsSqfK7j5HzGYgMcDdwUAdmdDR.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/s8onQ7I3S6QzZnlbqoo7giEYE0O.jpg","iso_639_1":"zh","vote_average":0},{"width":3840,"height":2160,"file_path":"/25yrqHKnaCzNcfPfB11OPG1X1jw.jpg","iso_639_1":"zh","vote_average":0},{"width":3840,"height":2160,"file_path":"/1gImhYzlKNPaX0JWogD2tYe0Zo5.jpg","iso_639_1":"zh","vote_average":0}]},"enriched_at":"2026-04-21T07:19:57.868+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Legend of Hei 2","runtime":119,"tagline":"","homepage":"https://gkids.com/films/the-legend-of-hei-2","overview":"When an attack shatters the fragile peace between the spirit world and humanity, Hei teams up with Luye, the last disciple of his Shifu Wuxian, to expose a conspiracy that threatens both realms - and the bond they've sworn to protect."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"羅小黒戦記２ ぼくらが望む未来","runtime":0,"tagline":"","homepage":"","overview":"中国の人気WEBアニメシリーズを原作に、黒猫の妖精シャオヘイの冒険を描くアクションファンタジーアニメ第2弾。ある襲撃事件により妖精の世界の平和が脅かされ、シャオヘイと師匠ムゲンの運命が大きく揺らいでいく。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":120,"tagline":"","homepage":"","overview":"　　小黑跟师父无限在村里过着安宁日子，他也渐渐适应了人类世界的生活。两年后，妖灵会馆突然被袭击，无限和小黑接到任务前往会馆。小黑能否经受住这突如其来的考验？面对意想不到的敌人，小黑又会做出怎样的选择……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"羅小黑戰記 2","runtime":119,"tagline":"","homepage":"","overview":"小黑跟隨師父在小鎮上過著安甯日子，分會館遇襲，打破了妖精世界維系多年的和平，來自妖靈會館的“全新任務”也讓兩人陷入分離危機，更讓師父無限的處境發生翻天覆地的變化。面對環環相扣的謎團，小黑與師姐鹿野共同開啓了尋找真相的新冒險。這一次小黑能否經受住考驗，順利保護師父化險為夷？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"La Leyenda de Hei 2","runtime":120,"tagline":"","homepage":"","overview":"La película cuenta la historia de una \"nueva misión\" del Monster Hall. Enfrentados a una serie de misterios, Xiaohei y su hermana mayor Luye se embarcan en una nueva aventura para encontrar la verdad."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"羅小黑戰記 2","runtime":0,"tagline":"","homepage":"","overview":"小黑跟隨師父在小鎮上過著安甯日子，分會館遇襲，打破了妖精世界維系多年的和平，來自妖靈會館的“全新任務”也讓兩人陷入分離危機，更讓師父無限的處境發生翻天覆地的變化。面對環環相扣的謎團，小黑與師姐鹿野共同開啟了尋找真相的新冒險。這一次小黑能否經受住考驗，順利保護師父化險為夷？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"나소흑전기 2: 우리가 원하는 미래","runtime":0,"tagline":"","homepage":"","overview":"공격이 영계와 인간계 사이의 위태로운 평화를 깨뜨리자, 헤이는 스승 무현의 마지막 제자 루예와 힘을 합쳐 양계를 위협하는 음모를 밝혀낸다. 그들이 지키기로 맹세한 유대마저 위태롭게 하는 음모를."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"เฮย ภูตแมวมหัศจรรย์ 2","runtime":0,"tagline":"","homepage":"","overview":"เมื่อการโจมตีครั้งหนึ่งได้ทำลายความสงบที่เปราะบางระหว่างโลกวิญญาณกับมนุษย์ เฮยจำต้องร่วมมือกับลู่เย่ ศิษย์คนสุดท้ายของอาจารย์อู๋เซียน เพื่อเปิดโปงแผนสมคบคิดที่คุกคามทั้งสองโลก — รวมถึงสายสัมพันธ์ที่พวกเขาสาบานว่าจะปกป้อง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"La Tiểu Hắc chiến ký 2","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"La leggenda di Hei 2","runtime":0,"tagline":"","homepage":"","overview":"Quando un attacco infrange la fragile pace tra il mondo degli spiriti e l’umanità, Hei si unisce a Luye, l’ultimo discepolo del suo Shifu Wuxian, per smascherare una cospirazione che minaccia entrambi i regni—e il legame che hanno giurato di proteggere."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"افسانه هی 2","runtime":0,"tagline":"","homepage":"","overview":"ژائوهی و شاگرد سابق استادش باید با کمک یکدیگر بی‌گناهی استادشان را ثابت کنند و جلوی یک جنگ تمام عیار میان انسان‌ها و ارواح را بگیرند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Po brutalnym ataku na Świat Duchów, kruche porozumienie między ludźmi a duchami zostaje zerwane. Xiaohei i Luye wyruszają w podróż, by odkryć prawdę o zamachu, oczyścić imię swojego mistrza i zapobiec wojnie, która może pochłonąć oba światy."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"A Lenda de Hei 2","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"}],"reviews_tmdb":[],"recommendations":[{"id":1406607,"adult":false,"title":"The Stage","video":false,"overview":"During the Republican era, wars and conflicts were frequent. On stage, the \"Overlord\" sings with resounding passion, while below, the absurd spectacle of life unfolds. They must both secure the opera troupe's livelihood and appease the audience in their seats. Once the curtain rises, how should this play be performed?","genre_ids":[18,35],"media_type":"movie","popularity":1.0846,"vote_count":39,"poster_path":"/wSFGtkoz8SW6yIgu1Xvxs584QQt.jpg","release_date":"2025-07-12","vote_average":7.256,"backdrop_path":"/6ggN6nRgJskoRIEVYmvY1hyRvBv.jpg","original_title":"戏台","original_language":"zh"},{"id":1356587,"adult":false,"title":"The Lychee Road","video":false,"overview":"During the Tianbao period of the Tang Dynasty, Li Shande, a petty official in Chang'an, was suddenly given a task to bring fresh lychees from Lingnan. The lychee is perishable, and becomes tasteless three days after it leaves the branch, and Lingnan is more than 5,000 miles away from Chang'an, so this is an impossible task. But for the sake of his wife and daughter at home, Li Shande was determined to give it a try.","genre_ids":[18,36,35],"media_type":"movie","popularity":2.4015,"vote_count":35,"poster_path":"/zbTrwhUxxJ0BgDai1FflfeOELrO.jpg","release_date":"2025-07-12","vote_average":7.3,"backdrop_path":"/8OPxY4gmVLoURJcz1BbR2a4Hi5q.jpg","original_title":"长安的荔枝","original_language":"zh"},{"id":1500536,"adult":false,"title":"Dead to Rights","video":false,"overview":"During the 1937 Nanjing Massacre, a postman poses as a photo developer, helping Japanese forces while secretly sheltering Chinese refugees. He later risks his life evacuating them and revealing evidence of the atrocities.","genre_ids":[18,10752,36],"media_type":"movie","popularity":3.4834,"vote_count":68,"poster_path":"/rx9xTly73NssFHPg9gKrX9tJdDI.jpg","release_date":"2025-07-19","vote_average":8.015,"backdrop_path":"/ngLgoY3MTfLANqv9cpXr96saaFV.jpg","original_title":"南京照相馆","original_language":"zh"},{"id":1304434,"adult":false,"title":"Nobody","video":false,"overview":"The Little Pig Yao decides to leave Langlang Mountain to join the pilgrimage. On the journey west, what trials will the little monsters face? In the end, will they achieve their dreams and live as they truly desire?","genre_ids":[16,12,14,35],"media_type":"movie","popularity":5.4579,"vote_count":59,"poster_path":"/oqS3wJX3wNj4DciCyTznnMZ3Fuu.jpg","release_date":"2025-08-02","vote_average":7.805,"backdrop_path":"/xawDFjfjBmtKYC29bZOYnYPGa8e.jpg","original_title":"浪浪山小妖怪","original_language":"zh"},{"id":1154478,"adult":false,"title":"I Am What I Am 2","video":false,"overview":"Gyun, an unknown person who came to Shanghai to work, agreed to represent the declining Chuanwu Boxing Gym to participate in the \"Shanghai Fight Night\" martial arts competition in order to earn money to treat his father's illness. To do so, he must overcome all the experts, prejudices, and himself.","genre_ids":[16,28,35],"media_type":"movie","popularity":0.9051,"vote_count":29,"poster_path":"/bdNtCxSon555n2QdNob7ZJHG0XW.jpg","release_date":"2024-12-07","vote_average":7.6,"backdrop_path":"/rC7bSysZ51WIZXFUHLJWFMUfvlS.jpg","original_title":"雄狮少年2","original_language":"zh"},{"id":1241924,"adult":false,"title":"The Dumpling Queen","video":false,"overview":"Based on the true story of Ms. Zang Jianhe, the founder of Wan Chai Ferry Terminal and known as the \"Queen of Dumplings\"; in the late 1970s, Ms. Zang Jianhe from Qingdao, Shandong Province was forced to flee to her husband with her two young daughters, but was forced to stay in Hong Kong, and in order to survive, she had to sell dumplings at the Wan Chai Ferry Terminal. How will she carry down the heavy difficulties of fate, step by step to reverse her life...","genre_ids":[18],"media_type":"movie","popularity":1.4471,"vote_count":16,"poster_path":"/3xfohHcBHB1tkgG8wqUmvo7Qklp.j