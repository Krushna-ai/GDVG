5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The 33D Invader\",\"description\":\"A young woman named Future is sent from the year 2046 to the year 2011 in Hong Kong. Future was sent by the United Nations in order to get pregnant, where she can then extract her genes and repopulate the earth as 99% of males have become infertile in the future due to attacks from Planet Xucker. Two assassins from Xuckler are sent after her to stop her. Future meets three University students: Felix, Dan-san and Sing. The men are obsessed with female students next door: Chin-chin, Chen-chen and Sai-sai. The students agree to help Future find a mate at the university.\",\"image\":\"https://image.tmdb.org/t/p/w500/bBC1fBHyFBmc6fn4UDedtkOVSaD.jpg\",\"datePublished\":\"2011-10-06\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"cn\",\"genre\":[\"science fiction film\",\"Comedy\",\"Science Fiction\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.6,\"bestRating\":10,\"ratingCount\":31}}"}}],["$","$L10",null,{"initialDrama":{"id":"12465d0a-b01d-4aa3-935a-682faadfb560","tmdb_id":85877,"imdb_id":"tt2084885","content_type":"movie","title":"The 33D Invader","original_title":"蜜桃成熟時33D","overview":"A young woman named Future is sent from the year 2046 to the year 2011 in Hong Kong. Future was sent by the United Nations in order to get pregnant, where she can then extract her genes and repopulate the earth as 99% of males have become infertile in the future due to attacks from Planet Xucker. Two assassins from Xuckler are sent after her to stop her. Future meets three University students: Felix, Dan-san and Sing. The men are obsessed with female students next door: Chin-chin, Chen-chen and Sai-sai. The students agree to help Future find a mate at the university.","poster_path":"/bBC1fBHyFBmc6fn4UDedtkOVSaD.jpg","backdrop_path":"/jl7RhBszdR4chHuL9DLoIYjjNcJ.jpg","release_date":"2011-10-06","first_air_date":null,"status":"published","original_language":"cn","origin_country":["HK"],"genres":[{"name":"science fiction film"},{"id":35,"name":"Comedy"},{"id":878,"name":"Science Fiction"},"science fiction film"],"popularity":10.8653,"vote_average":5.6,"vote_count":31,"runtime":82,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-05T00:09:16.069495+00:00","updated_at":"2026-02-22T20:45:58.661+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":13958,"name":"My Way Film Company","logo_path":"/yblRwoxf2sGIzzWVy8scyidp7j2.png","origin_country":"HK"}],"production_countries":[{"name":"Hong Kong","iso_3166_1":"HK"}],"spoken_languages":[{"name":"广州话 / 廣州話","iso_639_1":"cn","english_name":"Cantonese"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[],"alternative_titles":[{"type":"","title":"蜜桃成熟时33D","iso_3166_1":"HK"},{"type":"working title","title":"Crazy Love 33D","iso_3166_1":"HK"},{"type":"transliteration","title":"Mat to sing suk si 33D","iso_3166_1":"HK"},{"type":"","title":"The 33D Invader","iso_3166_1":"US"}],"videos":[{"id":"5c1f3c659251414c16bf11b3","key":"xXsLIBLFSsA","name":"The 33D Invader 2011 trailer ~ 蜜桃成熟時33D","site":"YouTube","size":480,"type":"Trailer","official":false,"iso_639_1":"en","iso_3166_1":"US","published_at":"2017-09-01T13:00:06.000Z"}],"watch_providers":{"results":{"TW":{"link":"https://www.themoviedb.org/movie/85877-33d/watch?locale=TW","flatrate":[{"logo_path":"/r9rEesXJjzY8sH3NLqNdkPdZ714.jpg","provider_id":624,"provider_name":"KKTV","display_priority":29}]}}},"wikidata_id":"Q7711871","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/bBC1fBHyFBmc6fn4UDedtkOVSaD.jpg","images":{"logos":[{"width":1320,"height":357,"file_path":"/dQLlNXecIyq47FGatgjSfjsK0tL.png","iso_639_1":"zh","vote_average":0}],"posters":[{"width":1000,"height":1500,"file_path":"/bBC1fBHyFBmc6fn4UDedtkOVSaD.jpg","iso_639_1":"zh","vote_average":3.334},{"width":1454,"height":2181,"file_path":"/bTL5psHkHfIwUO5Piu0K6Jn2dGo.jpg","iso_639_1":"zh","vote_average":3.334},{"width":1878,"height":2548,"file_path":"/mONnW8eISOaJU6AM0mlA3cl3oyF.jpg","iso_639_1":"zh","vote_average":2.278},{"width":800,"height":1201,"file_path":"/jfYbvQmWt28MTJGB6IX6PC00qHq.jpg","iso_639_1":"zh","vote_average":1.75},{"width":720,"height":1080,"file_path":"/fL7TsiFVP7Rqmg0p56YIFk1RSXa.jpg","iso_639_1":"zh","vote_average":1.75},{"width":572,"height":858,"file_path":"/xMi2qg1c1buWtxHvMHmaWWsdq7.jpg","iso_639_1":"th","vote_average":0}],"backdrops":[{"width":1454,"height":818,"file_path":"/jl7RhBszdR4chHuL9DLoIYjjNcJ.jpg","iso_639_1":null,"vote_average":1.75},{"width":1454,"height":818,"file_path":"/AlW7KZl1HMD1nulwNcp9grQJoRN.jpg","iso_639_1":null,"vote_average":1.75},{"width":1454,"height":818,"file_path":"/aBQwlJktbhpzsikMGaEFogcM7ci.jpg","iso_639_1":null,"vote_average":0.166},{"width":1454,"height":818,"file_path":"/hyYmdVCSQob7R3NIhA3dRyIxVV2.jpg","iso_639_1":null,"vote_average":0.166}]},"enriched_at":"2026-04-21T06:46:25.401+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The 33D Invader","runtime":82,"tagline":"","homepage":"","overview":"A young woman named Future is sent from the year 2046 to the year 2011 in Hong Kong. Future was sent by the United Nations in order to get pregnant, where she can then extract her genes and repopulate the earth as 99% of males have become infertile in the future due to attacks from Planet Xucker. Two assassins from Xuckler are sent after her to stop her. Future meets three University students: Felix, Dan-san and Sing. The men are obsessed with female students next door: Chin-chin, Chen-chen and Sai-sai. The students agree to help Future find a mate at the university."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"蜜桃成熟时33D","runtime":0,"tagline":"","homepage":"","overview":"　　朗仔与他的3名好友在海边租了一间渡假屋温习应付毕业考试，发现四名美女同学千、西、珍与米亚搬到了隔壁。其中最美的校花千，其实暗恋朗仔但却无胆入情关。  朗仔回家睡觉，半夜忽然狂风大作。在强压电流中出现一位全裸美少女，自称叫“未来”，是从2046年经时光机回到2011年，找寻完美基因的，因为在2046年，外星人已用辐射令地球男女失去生殖能力。所以她被派来带完美精子回去延续人类后代..."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Нашественик 33D","runtime":82,"tagline":"","homepage":"","overview":""},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"İşgalci 33D","runtime":0,"tagline":"","homepage":"","overview":"Bir kadın en sağlıklı insan genlerini aramak için geleceğe ulaşır. Bu arada, kötü niyetli bir çift de görevini durdurmak için kadını takip ediyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"蜜桃成熟時 33D","runtime":83,"tagline":"","homepage":"","overview":"影片改編自情色片《蜜桃成熟時 3 之蜜桃仙子》。來自未來的美少女未來到地球尋找好男人的完美基因帶回未來世界。朗仔（陳俊言 飾）與他的 3 名好友在海邊租了一間渡假屋温習應付畢業考試，發現四名美女同學千（吉澤明步 飾）、西西、珍（林宜芝 飾）與米亞（米亞 飾）搬到了隔壁。其中最美的校花千，其實暗戀朗仔但卻無膽入情關。朗仔回家睡覺，半夜忽然狂風大作。在強壓電流中出現一位全裸美少女，自稱叫「未來」（吳晴晴 飾），是從 2046 年經時光機回到 2011 年，找尋完美基因的，因為在 2046 年，外星人已用輻射令地球男女失去生殖能力。所以她被派來地球尋找好男人的完美基因帶回去延續人類後代. . . . . . 而尾隨未來前來的外星人（加籐鷹 飾）卻要對這一切加以阻止。最終，未來是否能夠成功帶著現代優秀男人的基因返回未來呢？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"The 3DD Invader","runtime":73,"tagline":"","homepage":"","overview":"The 3DD Invader é um filme de comédia sexual de ficção científica de Hong Kong de 2011, dirigido por Cash Chin. O filme é estrelado por Macy Wu como uma garota chamada Future que tem que repovoar a raça humana após os ataques de radiação da raça Xucker terem feito 99% dos homens na Terra inférteis no ano de 2046."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"밀도성숙시33D","runtime":0,"tagline":"","homepage":"","overview":""},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Khi Trái Đào Chín","runtime":0,"tagline":"","homepage":"","overview":"Năm 2046, hành tinh Sucker đã làm trái đất thay đổi khi biến 99% đàn ông mất khả năng duy trì giống nòi. Liên hợp quốc đã chọn ra một phụ nữ khỏe mạnh, đặt tên là “Tương lai” để gửi đến trái đất vào thời điểm năm 2011 vơi mục đích gặp một nam nhi khỏe mạnh để tạo ra những giống nòi cường tráng cho trái đất. Tuy niên hành tinh Sucker đã cử 2 tinh binh của chúng là Sucker số 1 và Sucker số 2 xuống ngăn chặn kế hoạch này"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"影片改編自情色片《蜜桃成熟時3之蜜桃仙子》。\r 來自未來的美少女未來到地球尋找好男人的完美基因帶回未來世界。朗仔（陳俊言飾）與他的3名好友在海邊租了一間渡假屋溫習應付畢業考試，發現四名美女同學千（吉沢明步飾）、西西、珍（林宜芝飾）與米亞（米亞飾）搬到了隔壁。其中最美的校花千，其實暗戀朗仔但卻無膽入情關。朗仔回家睡覺，半夜忽然狂風大作。在強壓電流中出現一比特全裸美少女，自稱叫“未來”（吳晴晴飾），是從2046年經時光機回到2011年，找尋完美基因的，因為在2046年，外星人已用輻射令地球男女失去生殖能力。所以她被派來地球尋找好男人的完美基因帶回去延續人類後代……\r 而尾隨未來前來的外星人（加藤鷹飾）卻要對這一切加以封锁。最終，未來是否能够成功帶著現代優秀男人的基因返回未來呢？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"Захватчик 33D","runtime":0,"tagline":"","homepage":"","overview":"В скором будущем Земля подвергнется атаке инопланетных монстров, которые заразят человечество, почти полностью лишив его способности к оплодотворению. В 2046 году единственная здоровая девушка Земли отправляется в прошлое, в Гонконг 2011 года, чтобы найти здорового мужчину, который сможет оплодотворить ее. Таковой находится сразу же, но вот беда – у него уже есть девушка Джина, которую он любит. А по следам гостьи из будущего уже идут инопланетные монстры."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Een jonge vrouw genaamd Future wordt van het jaar 2046 naar het jaar 2011 in Hong Kong gestuurd. Future werd door de Verenigde Naties gestuurd om zwanger te worden, waar ze vervolgens haar genen kan extraheren en de aarde opnieuw kan bevolken, aangezien 99% van de mannen in de toekomst onvruchtbaar is geworden als gevolg van aanvallen van Planet Xucker. Twee huurmoordenaars uit Xuckler worden achter haar aan gestuurd om haar te stoppen. Future ontmoet drie universiteitsstudenten: Felix, Dan-san en Sing. De mannen zijn geobsedeerd door de buurvrouwen: Chin-chin, Chen-chen en Sai-sai. De studenten stemmen ermee in om Future te helpen een partner te vinden op de universiteit."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"}],"reviews_tmdb":[],"recommendations":[{"id":15067,"adult":false,"title":"The Good, the Bad, the Weird","video":false,"overview":"The story of three Korean outlaws in 1930s Manchuria and their dealings with the Japanese army and Chinese and Russian bandits. The Good (a bounty hunter), the Bad (a hitman), and the Weird (a thief) battle the army and the bandits in a race to use a treasure map to uncover the riches of legend.","genre_ids":[28,12,35,37],"media_type":"movie","popularity":1.8873,"vote_count":789,"poster_path":"/lbPZ0aNoF0cHisg6DubFO2eS8so.jpg","release_date":"2008-07-16","vote_average":7.168,"backdrop_path":"/gec3e76TRGUBx1Ut0c6yuSahVDp.jpg","original_title":"좋은 놈, 나쁜 놈, 이상한 놈","original_language":"ko"},{"id":53130,"adult":false,"title":"A Lonely Cow Weeps at Dawn","video":false,"overview":"A young widow, Noriko, lives with her senile father-in-law on a farm. Noriko pretends to be his long-gone favorite cow and lets him milk her—a satisfying arrangement for them both.","genre_ids":[18,10749],"media_type":"movie","popularity":0.8656,"vote_count":30,"poster_path":"/k0X238unufnNxvDwgoJM9xvR1Cr.jpg","release_date":"2003-04-08","vote_average":4.9,"backdrop_path":"/jxt3KEIWNTDQ2qtLgy5KnZwNDkg.jpg","original_title":"痴漢ぎふ：息子の嫁と","original_language":"ja"},{"id":63455,"adult":false,"title":"Flower & Snake 3","video":false,"overview":"A businessman is ruthless with his competitors, and in response his competitors after being driven out of business kidnap aforementioned business man's wife and start training her to be a porn star, particularly of the S&amp;M/bondage variety","genre_ids":[18,10749,53,27],"media_type":"movie","popularity":1.1947,"vote_count":36,"poster_path":"/cgfkYW5Gd1ebDjCRc2PDPDwLftk.jpg","release_date":"2010-08-28","vote_average":6,"backdrop_path":"/zk2GE29fQHOC0mQemTwfM73hzH7.jpg","original_title":"花と蛇 3","original_language":"ja"},{"id":119589,"adult":false,"title":"The Vampires' Night Orgy","video":false,"overview":"A busload of tourists stops in to visit a small European town. What they don't know is that the town is completely inhabited by vampires.","genre_ids":[27],"media_type":"movie","popularity":0.3851,"vote_count":22,"poster_path":"/umJ8qcWcN2iQeD9KG7jqBmT3WE0.jpg","release_date":"1973-07-01","vote_average":4.522,"backdrop_path":"/wJOEhpOmWLltmGecEr1dNM1fYGH.jpg","original_title":"La orgía nocturna de los vampiros","original_language":"es"},{"id":481990,"adult":false,"title":"Next Door Woman","video":false,"overview":"Min Woo's dream is to offer his sympathy and a good deed to help his loved ones around him. So your goal is to raise money, it does not exist in your heart to find a love. Until the day a woman moves into the next apartment...","genre_ids":[18],"media_type":"movie","popularity":0.4243,"vote_count":1,"poster_path":"/qquaoitqSzkfz4wlpbGoXXOJH4f.jpg","release_date":"2017-06-20","vote_average":6,"backdrop_path":"/vfj6HF9RtJNo0wKL3LhUhvrjis9.jpg",