5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Obscene House: Slave Wife\",\"description\":\"Hyun-jung, who moved to a local mansion, was delighted with unexpected luck. She hated the noise between the floors so she wanted a quiet place with soundproofing. Since the tenants were mostly working couples, the mansion is quiet like a haunted city.\",\"image\":\"https://image.tmdb.org/t/p/w500/1VfuzK2Qx1tIGE1nhn2G2ilF7RN.jpg\",\"datePublished\":\"2020-02-06\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"Romance\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7,\"bestRating\":10,\"ratingCount\":3}}"}}],["$","$L10",null,{"initialDrama":{"id":"8a789005-94ff-44e1-930a-157d7628d7e2","tmdb_id":698818,"imdb_id":null,"content_type":"movie","title":"Obscene House: Slave Wife","original_title":"음란 주택: 노예가 된 아내","overview":"Hyun-jung, who moved to a local mansion, was delighted with unexpected luck. She hated the noise between the floors so she wanted a quiet place with soundproofing. Since the tenants were mostly working couples, the mansion is quiet like a haunted city.","poster_path":"/1VfuzK2Qx1tIGE1nhn2G2ilF7RN.jpg","backdrop_path":"/77xFxLtD2jGpOrcjJbCez2wZWX1.jpg","release_date":"2020-02-06","first_air_date":null,"status":"published","original_language":"ko","origin_country":["KR"],"genres":[{"id":10749,"name":"Romance"}],"popularity":3.6944,"vote_average":7,"vote_count":3,"runtime":72,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:51:16.435526+00:00","updated_at":"2026-02-21T13:24:51.087+00:00","tagline":"Do people even live here?","homepage":null,"budget":0,"revenue":0,"production_companies":[],"production_countries":[{"name":"South Korea","iso_3166_1":"KR"}],"spoken_languages":[{"name":"한국어/조선말","iso_639_1":"ko","english_name":"Korean"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[{"id":155477,"name":"softcore"}],"alternative_titles":[{"type":"","title":"음란주택:노예가 된 아내","iso_3166_1":"KR"}],"videos":[],"watch_providers":{"results":{}},"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"KR","main_poster":"/1VfuzK2Qx1tIGE1nhn2G2ilF7RN.jpg","images":{"logos":[],"posters":[{"width":740,"height":1061,"file_path":"/1VfuzK2Qx1tIGE1nhn2G2ilF7RN.jpg","iso_639_1":null,"vote_average":3.334}],"backdrops":[{"width":1280,"height":720,"file_path":"/77xFxLtD2jGpOrcjJbCez2wZWX1.jpg","iso_639_1":null,"vote_average":3.334}]},"enriched_at":"2026-02-21T13:24:55.494+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Obscene House: Slave Wife","runtime":72,"tagline":"Do people even live here?","homepage":"","overview":"Hyun-jung, who moved to a local mansion, was delighted with unexpected luck. She hated the noise between the floors so she wanted a quiet place with soundproofing. Since the tenants were mostly working couples, the mansion is quiet like a haunted city."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"淫室奴妻","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"음란 주택: 노예가 된 아내","runtime":0,"tagline":"내 아내의 비밀스런 사생활이 시작된다.","homepage":"","overview":"지방의 한 맨션으로 이사를 오게 된 현정은 뜻밖의 행운에 쾌재를 부르고 있었다. 층간 소음문제로 한바탕 홍역을 치렀던 탓에, 방음시설이 재대로 되어있는 조용한 집을 소망했던 그녀. 입주자 대부분이 맞벌이 부부인 때문인지, 한 낱의 맨션은 유령의 도시처럼 조용하다.  \"사람이 살기는 하는 건가?\"\r 의아한 생각에 이웃들을 살펴보니, 방음이 잘 되는 게 아니라 숨을 죽이고 살았던 것. 잠시 집을 비우고 돌아와 보니 누군가 집에 들어와 뒤진 흔적이 생생하게 남겨져 있다. 득달같이 관리실로 달려가 따져보니 외부인의 침입은 없었다는 대답과 함께 현관엔 주민들의 경고장이 붙어있다.\r ※ 경고 - 신혼인건 알겠는데 조용히 좀 삽시다!\r 누군가 자신의 일거수일투족을 감시하고 있다는 생각에 숨이 막혀오는 현정. 아파트 여자들의 비밀과 약점을 움켜쥐고 제왕처럼 군림하는 '관리인'의 존재가 서서히 그 실체를 드러내는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"နယ်ဘက်က အိမ်ယာတစ်ခုစီ ပြောင်းရွှေ့လာသော ဇနီးမောင်နှံတစ်တွဲဟာအိမ်အသစ်က တိတ်ဆိတ်ပြီး အသံလုံတာကြောင့် သဘောကျနေပါတယ်…ဒါပေမယ့် အရမ်းတိတ်ဆိတ်လွန်းတာကြောင့် လူနေတာရော ဟုတ်ရဲ့လားဆိုပြီး သံသယဝင်လာပါတော့တယ်…ဒါ့အပြင် အိမ်ထဲမှာ ထူးဆန်းတဲ့ပစ္စည်းတွေ ရောက်နေတာမျိုးတစ်ယောက်ယောက်က အိမ်ထဲကို ဝင်နေတဲ့ သဲလွန်စတွေတွေ့နေတာကြောင့် ထိန်းသိမ်းရေးရုံးကို သွားပြီးအကြောင်းကြားလိုက်ပါတယ်…ထိန်းသိမ်းရေးမှုးပြောတဲ့အတိုင်း လုပ်ပေမယ့် ဘာမှမထူးခြားတာကြောင့် ကိုယ်တိုင်စုံစမ်းတဲ့အခါ ဘာတွေဆက်ဖြစ်လာမလဲဆိုတာ ဆက်လက်ကြည့်ရှုလိုက်ပါဦး…ဇာတ်လမ်းဘာညာနဲ့ လှပညက်ညောတဲ့အခန်းတွေပါတာမို့လို့မိသားစုနဲ့အတူမကြည့်သင့်ပါဘူ"},"name":"","iso_639_1":"my","iso_3166_1":"MY","english_name":"Burmese"},{"data":{"title":"淫室奴妻","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":83088,"adult":false,"title":"Saint Seiya: Warriors of the Final Holy Battle","video":false,"overview":"The plot involves the coming of Lucifer to the Sanctuary, where his underlings systematically dispose of the surviving Gold Saints. Athena goes to Lucifer to ask for peace, placing herself in peril. The Bronze Saints must then come to her rescue, destroying Lucifer's Fallen Angels (Seima Tenshi in Japanese) in the process.","genre_ids":[28,16,14],"media_type":"movie","popularity":1.9449,"vote_count":249,"poster_path":"/a1ftT2mM219UvZ86jgF19mBoUT1.jpg","release_date":"1989-03-18","vote_average":7.357,"backdrop_path":"/1FdYcvnpyk8vxBbw583ZzwVQ5Ev.jpg","original_title":"聖闘士星矢 最終聖戦の戦士たち","original_language":"ja"},{"id":671,"adult":false,"title":"Harry Potter and the Philosopher's Stone","video":false,"overview":"Harry Potter has lived under the stairs at his aunt and uncle's house his whole life. But on his 11th birthday, he learns he's a powerful wizard—with a place waiting for him at the Hogwarts School of Witchcraft and Wizardry. As he learns to harness his newfound powers with the help of the school's kindly headmaster, Harry uncovers the truth about his parents' deaths—and about the villain who's to blame.","genre_ids":[12,14],"media_type":"movie","popularity":22.7137,"vote_count":29167,"poster_path":"/wuMc08IPKEatf9rnMNXvIDxqP4W.jpg","release_date":"2001-11-16","vote_average":7.899,"backdrop_path":"/1XAC6RPT01UX9EQGy2JVn5c8pgy.jpg","original_title":"Harry Potter and the Philosopher's Stone","original_language":"en"},{"id":429617,"adult":false,"title":"Spider-Man: Far From Home","video":false,"overview":"Peter Parker and his friends go on a summer trip to Europe. However, they will hardly be able to rest - Peter will have to agree to help Nick Fury uncover the mystery of creatures that cause natural disasters and destruction throughout the continent.","genre_ids":[28,12,878],"media_type":"movie","popularity":15.1643,"vote_count":16686,"poster_path":"/4q2NNj4S5dG2RLF9CpXsej7yXl.jpg","release_date":"2019-06-28","vote_average":7.396,"backdrop_path":"/34jW8LvjRplM8Pv06cBFDpLlenR.jpg","original_title":"Spider-Man: Far From Home","original_language":"en"},{"id":673,"adult":false,"title":"Harry Potter and the Prisoner of Azkaban","video":false,"overview":"Year three at Hogwarts means new fun and challenges as Harry learns the delicate art of approaching a Hippogriff, transforming shape-shifting Boggarts into hilarity and even turning back time. But the term also brings danger: soul-sucking Dementors hover over the school, an ally of the accursed He-Who-Cannot-Be-Named lurks within the castle walls, and fearsome wizard Sirius Black escapes Azkaban. And Harry will confront them all.","genre_ids":[12,14],"media_type":"movie","popularity":15.6854,"vote_count":22846,"poster_path":"/aWxwnYoe8p2d2fcxOqtvAtJ72Rw.jpg","release_date":"2004-05-31","vote_average":8,"backdrop_path":"/vbk5CfaAHOjQPSAcYm6AoRRz2Af.jpg","original_title":"Harry Potter and the Prisoner of Azkaban","original_language":"en"},{"id":767,"adult":false,"title":"Harry Potter and the Half-Blood Prince","video":false,"overview":"As Lord Voldemort tightens his grip on both the Muggle and wizarding worlds, Hogwarts is no longer a safe haven. Harry suspects perils may even lie within the castle, but Dumbledore is more intent upon preparing him for the final battle fast approaching. Together they work to find the key to unlock Voldemorts defenses and to this end, Dumbledore recruits his old friend and colleague Horace Slughorn, whom he believes holds crucial information. Even as the decisive showdown looms, romance blossoms for Harry, Ron, Hermione and their classmates. Love is in the air, but danger lies ahead and Hogwarts may never be the same again.","genre_ids":[12,14],"media_type":"movie","popularity":13.7456,"vote_count":20502,"poster_path":"/z7uo9zmQdQwU5ZJHFpv2Upl30i1.jpg","release_date":"2009-07-15","vote_average":7.7,"backdrop_path":"/ze6Mx4QE5mQVXRYmG2flncqqle4.jpg","original_title":"Harry Potter and the Half-Blood Prince","original_language":"en"},{"id":284052,"adult":false,"title":"Doctor Strange","video":false,"overview":"After his career is destroyed, a brilliant but arrogant surgeon gets a new lease on life when a sorcerer takes him under her wing and trains him to defend the world against evil.","genre_ids":[14,12,28],"media_type":"movie","popularity":11.8742,"vote_count":23169,"poster_path":"/xf8PbyQcR5ucXErmZNzdKR0s8ya.jpg","release_date":"2016-10-25","vote_average":7.417,"backdrop_path":"/3zvZ699gMW2RhWc0GisIukzq0Ls.jpg","original_title":"Doctor Strange","original_language":"en"},{"id":530915,"adult":false,"title":"1917","video":false,"overview":"At the height of the First World War, two young British soldiers must cross enemy territory and deliver a message that will stop a deadly attack on hundreds of soldiers.","genre_ids":[10752,36,18,28,12],"media_type":"movie","popularity":7.6928,"vote_count":13294,"poster_path":"/iZf0KyrE25z1sage4SYFLCCrMi9.jpg","release_date":"2019-12-25","vote_average":8,"backdrop_path":"/2lBOQK06tltt8SQaswgb8d657Mv.jpg","original_title":"1917","original_language":"en"},{"id":299536,"adult":false,"title":"Avengers: Infinity War","video":false,"overview":"As the Avengers and their allies have continued to protect the world from threats too large for any one hero to handle, a new danger has emerged from the cosmic shadows: Thanos. A despot of intergalactic infamy, his goal is to collect all six Infinity Stones, artifacts of unimaginable power, and use them to inflict his twisted will on all of reality. Everything the Avengers have fought for has led up to this moment - the fate of Earth and existence itself has never been more uncertain.","genre_ids":[12,28,878],"media_type":"movie","popularity":31.7841,"vote_count":31495,"poster_path":"/7WsyChQLEftFiDOVTGkv3hFpyyt.jpg","release_date":"2018-04-25","vote_average":8.234,"backdrop_path":"/mDfJG3LC3Dqb67AZ52x3Z0jU0uB.jpg","original_title":"Avengers: Infinity War","original_language":"en"},{"id":495764,"adult":false,"title":"Birds of Prey (and the Fantabulous Emancipation of One Harley Quinn)","video":false,"overview":"Harley Quinn joins forces with a singer, an assassin and a police detective to help a young girl who had a hit placed on her after she stole a rare diamond from a crime lord.","genre_ids":[28,80],"media_type":"movie","popularity":8.0422,"vote_count":10689,"poster_path":"/h4VB6m0RwcicVEZvzftYZyKXs6K.jpg","release_date":"2020-02-05","vote_average":6.885,"backdrop_path":"/uozb2VeD87YmhoUP1RrGWfzuCrr.jpg","original_title":"Birds of Prey (and the Fantabulous Emancipation of One Harley Quinn)","original_language":"en"},{"id":436969,"adult":false,"title":"The Suicide Squad","video":false,"overview":"Supervillains Harley Quinn, Bloodsport, Peacemaker and a collection of nutty cons at Belle Reve prison join the super-secret, super-shady Task Force X as they are dropped off at the remote, enemy-infused island of Corto Maltese.","genre_ids":[28,35,12],"media_type":"movie","popularity":12.5847,"vote_count":9394,"poster_path":"/q61qEyssk2ku3okWICKArlAdhBn.jpg","release_date":"2021-07-28","vote_average":7.469,"backdrop_path":"/jlGmlFOcfo8n5tURmhC7YVd4Iyy.jpg","original_title":"The Suicide Squad","original_language":"en"},{"id":181812,"adult":false,"title":"Star Wars: The Rise of Skywalker","video":false,"overview":"The surviving Resistance faces the First Order once again as the journey of Rey, Finn and Poe Dameron continues. With the power and knowledge of generations behind them, the final battle begins.","genre_ids":[12,28,878],"media_type":"movie","popularity":12.0822,"vote_count":10629,"poster_path":"/db32LaOibwEliAmSL2jjDF6oDdj.jpg","release_date":"2019-12-18","vote_average":6.273,"backdrop_path":"/jOzrELAzFxtMx2I4uDGHOotdfsS.jpg","original_title":"Star Wars: The Rise of Skywalker","original_language":"en"},{"id":354912,"adult":false,"title":"Coco","video":false,"overview":"Despite his family’s baffling generations-old ban on music, Miguel dreams of becoming an accomplished musician like his idol, Ernesto de la Cruz. Desperate to prove his talent, Miguel finds himself in the stunning and colorful Land of the Dead following a mysterious chain of events. Along the way, he meets charming trickster Hector, and together, they set off on an extraordinary journey to unlock the real story behind Miguel's family history.","genre_ids":[10751,16,10402,12],"media_type":"movie","popularity":18.2681,"vote_count":20674,"poster_path":"/6Ryitt95xrO8KXuqRGm1fUuNwqF.jpg","release_date":"2017-10-27","vote_average":8.199,"backdrop_path":"/g7CHF8gTLGooTbP4GznIGwaqAGL.jpg","original_title":"Coco","original_language":"en"},{"id":642885,"adult":false,"title":"Hocus Pocus 2","video":false,"overview":"29 years since the Black Flame Candle was last lit, the 17th-century Sanderson sisters are resurrected, and they are looking for revenge. Now it's up to three high school students to stop the ravenous witches from wreaking a new kind of havoc on Salem before dawn on All Hallow's Eve.","genre_ids":[14,35,10751],"media_type":"movie","popularity":2.6983,"vote_count":1800,"poster_path":"/7ze7YNmUaX81ufctGqt0AgHxRtL.jpg","release_date":"2022-09-27","vote_average":7.161,"backdrop_path":"/ml8YBTJq7UkALfI022FWscCQuQW.jpg","original_title":"Hocus Pocus 2","original_language":"en"},{"id":260513,"adult":false,"title":"Incredibles 2","video":false,"overview":"Elastigirl springs into action to save the day, while Mr. Incredible faces his greatest challenge yet – taking care of the problems of his three children.","genre_ids":[28,12,16,10751],"media_type":"movie","popularity":8.2342,"vote_count":13501,"poster_path":"/9lFKBtaVIhP7E2Pk0IY1CwTKTMZ.jpg","release_date":"2018-06-14","vote_average":7.453,"backdrop_path":"/mabuNsGJgRuCTuGqjFkWe1xdu19.jpg","original_title":"Incredibles 2","original_language":"en"},{"id":337401,"adult":false,"title":"Mulan","video":false,"overview":"When the Emperor of China issues a decree that one man per family must serve in the Imperial Chinese Army to defend the country from Huns, Hua Mulan, the eldest daughter of an honored warrior, steps in to take the place of her ailing father. She is spirited, determined and quick on her feet. Disguised as a man by the name of Hua Jun, she is tested every step of the way and must harness her innermost strength and embrace her true potential.","genre_ids":[12,14,28],"media_type":"movie","popularity":6.3592,"vote_count":6966,"poster_path":"/aKx1ARwG55zZ0GpRvU2WrGrCG9o.jpg","release_date":"2020-09-04","vote_average":6.837,"backdrop_path":"/zMrk2G3XsnfYKiIp1NEfdtvDyBH.jpg","original_title":"Mulan","original_language":"en"},{"id":497582,"adult":false,"title":"Enola Holmes","video":false,"overview":"While searching for her missing mother, intrepid teen Enola Holme