5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Gigolo\",\"description\":\"Fung looks like a super-heartthrob and was born with a special endowment, making him the high school idol. He was expelled from school when he was caught fighting on campus. When his mom, the sole provider of his family with her poultry business, had to stop working due to her back problems, Fung decides to support his family financially. And from that moment, his life takes on a tumultuous change…\",\"image\":\"https://image.tmdb.org/t/p/w500/v0YIyJc5EtAGciCZsvqsW2QPRAr.jpg\",\"datePublished\":\"2015-01-29\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"cn\",\"genre\":[\"drama film\",\"erotic film\",\"Romance\",\"Drama\",\"Comedy\",null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.4,\"bestRating\":10,\"ratingCount\":44}}"}}],["$","$L10",null,{"initialDrama":{"id":"dc1cb726-d6c2-4e57-9e2c-20b3d85f7061","tmdb_id":323260,"imdb_id":"tt4539508","content_type":"movie","title":"The Gigolo","original_title":"鴨王","overview":"Fung looks like a super-heartthrob and was born with a special endowment, making him the high school idol. He was expelled from school when he was caught fighting on campus. When his mom, the sole provider of his family with her poultry business, had to stop working due to her back problems, Fung decides to support his family financially. And from that moment, his life takes on a tumultuous change…","poster_path":"/v0YIyJc5EtAGciCZsvqsW2QPRAr.jpg","backdrop_path":"/3W6ifzDqxINcxsZQypwupTPue8m.jpg","release_date":"2015-01-29","first_air_date":null,"status":"published","original_language":"cn","origin_country":["HK"],"genres":[{"name":"drama film"},{"name":"erotic film"},{"id":10749,"name":"Romance"},{"id":18,"name":"Drama"},{"id":35,"name":"Comedy"},"drama film","erotic film"],"popularity":4.7106,"vote_average":5.4,"