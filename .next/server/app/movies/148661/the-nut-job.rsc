9:{"metadata":[["$","title","0",{"children":"The Nut Job | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Surly, a curmudgeon, independent squirrel is banished from his park and forced to survive in the city. Lucky for him, he stumbles on the one thing that may be able to save his life, and the rest of park community, as they gear up for winter - Maury's Nut Store."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148661/the-nut-job"}],["$","meta","5",{"property":"og:title","content":"The Nut Job"}],["$","meta","6",{"property":"og:description","content":"Surly, a curmudgeon, independent squirrel is banished from his park and forced to survive in the city. Lucky for him, he stumbles on the one thing that may be able to save his life, and the rest of park community, as they gear up for winter - Maury's Nut Store."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148661/the-nut-job"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/4iHnGlmOjAj2k5zUftYDIzSITCf.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"The Nut Job"}],["$","meta","12",{"name":"twitter:description","content":"Surly, a curmudgeon, independent squirrel is banished from his park and forced to survive in the city. Lucky for him, he stumbles on the one thing that may be able to save his life, and the rest of park community, as they gear up for winter - Maury's Nut Store."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/4iHnGlmOjAj2k5zUftYDIzSITCf.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11"