kYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":13}],"link":"https://www.themoviedb.org/movie/13398/watch?locale=UG","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":13}]},"US":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"free":[{"logo_path":"/j7D006Uy3UWwZ6G0xH6BMgIWTzH.jpg","provider_id":212,"provider_name":"Hoopla","display_priority":34}],"link":"https://www.themoviedb.org/movie/13398/watch?locale=US","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"flatrate":[{"logo_path":"/yhrtzYd43pFIhRq0ruO8umJPuyn.jpg","provider_id":258,"provider_name":"Criterion Channel","display_priority":39}]},"VE":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":4}],"link":"https://www.themoviedb.org/movie/13398/watch?locale=VE"},"ZA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}],"link":"https://www.themoviedb.org/movie/13398/watch?locale=ZA","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}]}}},"wikidata_id":"Q917278","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-22T21:57:49.115655+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":[{"data":{"title":"Tokyo Godfathers","runtime":92,"tagline":"Meet the ultimate dysfunctional family.","homepage":"https://www.sonypictures.com/movies/tokyogodfathers","overview":"On Christmas Eve, three homeless people living on the streets of Tokyo discover a newborn baby among the trash and set out to find its parents."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Tokyo Godfathers","runtime":92,"tagline":"","homepage":"","overview":"Der Alkoholiker Gin, die ehemalige Drag Queen Hana und die Ausreißerin Miyuki leben auf den Straßen Tokyos und davon, was der Müll des Nobelbezirks Shinjuku hergibt. An Heiligabend finden sie auf einer dieser Streiftouren hinter Müllsäcken ein ausgesetztes Mädchen im Säuglingsalter. Sie machen sich auf die Suche nach den Eltern, in deren Verlauf sie immer wieder mit ihrer eigenen Vergangenheit konfrontiert werden."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Tokyo Godfathers","runtime":91,"tagline":"Incontra l'ultima famiglia disfunzionale.","homepage":"","overview":"Tre senzatetto trovano una neonata abbandonata la vigilia di Natale e partono alla ricerca dei genitori, incontrando lungo la via una sfilza di strani personaggi."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Padrinhos de Tóquio","runtime":92,"tagline":"Que família tão original","homepage":"","overview":"Na véspera de Natal, Hana, Gin e Miyuki estão à procura de presentes entre montes de lixo quando encontram um bebé abandonado numa fria noite de inverno. Chocada com a visão lastimável, o instinto maternal de Hana aflora e ela insiste em encontrar a mãe biológica do bebé para exigir uma explicação. Nomeando o bebé de Kiyoko, que significa criança pura, começam a sua busca usando as possíveis pistas deixadas ao lado dela: uma chave misteriosa e uma única nota. No entanto, os seus planos são rapidamente postos em desordem quando se veem apanhados numa série de eventos sem precedentes. Tokyo Godfathers acompanha a jornada do trio enquanto permanecem juntos em todas as situações, na esperança de entregar Kiyoko à sua verdadeira casa e encontrar o seu próprio milagre de Natal."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Tokyo Godfathers","runtime":92,"tagline":"Rencontrez la famille dysfonctionnelle ultime.","homepage":"","overview":"À Tokyo, dans le quartier populaire de Shinjuku, pendant les fêtes de Noël. Alors que le froid a envahi la ville, Gin, un homme bourru, Miyuki, un adolescent fugueur et Hana, un travesti, vivent ensemble dans les rues de la ville. Un soir, à la recherche de nourriture, ils trouvent un bébé abandonné dans une poubelle. Dans ses langes, une clef dont les comparses ignorent à quoi elle peut bien servir. Bien décidés à protéger le nourrisson des rigueurs du froid, les trois clochards cherchent également à retrouver les parents du bambin le plus rapidement possible. La clef s'avère être leur seul indice. Commence pour eux un parcours semé d'embûches…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"东京教父","runtime":92,"tagline":"","homepage":"","overview":"圣诞夜，退役自行车选手Gin，跨性别者花，离家出走的少女美由纪三人在东京的雪夜中无所事事。这是，他们发现垃圾堆中有一位哭泣的弃婴。孩子的襁褓中仅有一个酒吧的名片与照片。婴儿的父母身份成了谜团。花想收留孩子，并将孩子取名清子。但另外2人表示反对。于是三人开始了寻找清子的父母的旅程。圣诞夜幸福的气氛，伴随的却是怀中清子的哭泣。无家可归的三个人，开始为同样无家可归的清子找寻属于她的家。这一队流浪者，在一夜经历了诸多奇妙的事件。他们能找到清子的父母吗？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Tokyo Godfathers","runtime":91,"tagline":"","homepage":"","overview":"Es Navidad y la nieve cubre la ciudad de Tokio con su blanco manto. En algún lugar de Shinjuku encontramos a tres vagabundos: Gin, Hana y Miyuki. Una noche oyen unos lloros que salen de entre un montón basura y encuentran a un angelical bebé. Gin insiste en llevarlo a la policía y que ellos se encarguen de él. Sin embargo, Hana, que siempre ha tenido la ilusión de tener un bebé, no quiere dejárselo a nadie y que sean ellos mismos los que busquen a los padres. Así será como estos tres amigos se embarcan en la aventura de encontrar a la familia del bebé..."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Однажды в Токио","runtime":92,"tagline":"«Познакомьтесь с самой настоящей неблагополучной семьей»","homepage":"","overview":"Трое бездомных — алкоголик-бродяга Джин, трансвестит Хана и беглая беспризорница Миюки — живут на улицах Токио. Они уже давно позабыли, что значит иметь крышу над головой и есть три раза в день. Им уже ничего не нужно от жизни, и она проходит мимо них. Но однажды в Сочельник наша троица находит на улице потерянную новорожденную девочку, и в опустившихся бродяжках просыпаются забытые было человеческие чувства — приятели решают во что бы то ни стало найти родителей малютки."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Tokyo Godfathers","runtime":92,"tagline":"En annorlunda stödfamilj","homepage":"","overview":"Tillvaron för tre hemlösa Tokyobor förändras drastiskt när de på julafton hittar en baby, ensam på en soptipp. Nyåret närmar sig med stormsteg, och de tre utstötta medborgarna går samman för att lösa mysteriet med det övergivna barnet och hennes föräldrars öde. Under resans gång ställs de inför oväntade konfrontationer och händelser, som tvingar dem att ta itu med sina egna problem och möta framtiden tillsammans."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Tokyo Godfathers","runtime":92,"tagline":"","homepage":"","overview":"Efter tre hjemløse personer finder et forladt spædbarn juleaften, leder de efter barnets forældre og møder en lang række originaler undervejs."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Tokyo Godfathers","runtime":92,"tagline":"","homepage":"","overview":"Kolmen tokiolaisen kodittoman elämä muuttuu ikiajoiksi, kun he löytävät jouluaattona kaatopaikalta hylätyn tyttövauvan. Uuden vuoden lähestyessä kolme yhteiskunnan hylkäämää jäsentä yhdistävät voimansa ratkaistakseen hylätyn lapsen arvoituksen ja saadakseen selville, mitä hänen vanhemmilleen on tapahtunut. Matkan aikana sattumanvaraiselta vaikuttavat tapahtumat ja tapaamiset pakottavat heidät kohtaamaan oman menneisyytensä samalla kun he opettelevat kohtaamaan tulevaisuuden yhdessä."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Tokyo Godfathers","runtime":92,"tagline":"","homepage":"","overview":"Verhaal over drie daklozen, met ieder hun verschillende, eigenzinnige karakter, die samen de dagen voor kerst in het besneeuwde Tokio proberen door te komen. Ze vinden een baby en doen hun best om de ouders van het kind te vinden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":92,"tagline":"私の「名づけ親(ゴッドファーザー)」は3人のホームレスでしたー。","homepage":"http://www.madhouse.co.jp/tokyogodfathers/","overview":"新宿の裏通り界隈を根城にするホームレスの中年男性ギン、オカマのハナ、家出娘のミユキはクリスマス・イヴの夜、ゴミ置き場に捨てられた赤ん坊を発見。ギンは赤ん坊を警察に届けようとするが、子どもを育てることが夢だったハナは赤ん坊を勝手に《清子》と命名し、自分たちで親探しをしようと決める。だが、手がかりになりそうなものは赤ん坊と一緒にあったわずかな写真と名刺だけ。翌日、3人は写真の場所を探して歩き回る。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Tokiói keresztapák","runtime":0,"tagline":"","homepage":"","overview":"Tokióban, karácsony este három hajléktalan élete örökre megváltozik. A szemétben guberálva egy lánycsecsemőt találnak. Elhatározzák, hogy megtartják a csöppséget, és a lehetetlen körülményeik ellenére megpróbálják felnevelni. Azonban hamar be kell látniuk, nem képesek arra, amit vállaltak. Az újév közeledtével úgy döntenek, hogy a kicsinél talált fényképet segítségével megkeresik Kyoko szüleit. A fordulatos nyomozás során számtalan kalandba keveredve feltárul Gin, Hana és Miyuki elátkozott múltja, és a különleges hangulatú Tokió modern labirintusában a reményteli jövőre is rátalálnak."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"크리스마스에 기적을 만날 확률","runtime":90,"tagline":"당신의 모든 순간이 마법이 됩니다","homepage":"","overview":"까칠한 아저씨 긴과 여자를 꿈꾸는 남자 하나, 십대 가출 소녀 미유키는 하루하루 대충~살아가는 홈리스들. 흰 눈이 내리는 화이트 크리스마스에도 언제나처럼 쓰레기를 뒤지던 그들은 버려진 아기 ‘키요코’를 발견하게 된다. 키요코가 하늘이 보내준 천사라 생각한 홈리스 트리오는 아기천사에게 따뜻한 집을 찾아주겠다는 불타는 사명감으로 길을 나서는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"‏סנדקי טוקיו","runtime":0,"tagline":"הכירו את המשפחה הלא מתפקדת האולטימטיבית.","homepage":"","overview":"‏שלושה חסרי בית מוצאים תינוק נטוש בערב חג המולד, יוצאים לחפש את הוריו ונתקלים בשלל טיפוסים מוזרים."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Padrinhos de Tóquio","runtime":93,"tagline":"","homepage":"","overview":"Ao encontrar um bebê abandonado na noite de Natal, três sem-teto saem em busca dos pais da criança, enfrentando vários obstáculos no caminho."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Tokyo Tanrıları","runtime":0,"tagline":"","homepage":"","overview":"Tokyo sokaklarında yaşamakta olan üç evsiz bir Noel Arifesi’nde çöplerin içinde bir bebek bulurlar. Hep anne olma hayali kurmuş olan Hana, bebeği o gecelik yanlarında tutmak için diğer ikisini ikna eder. Sonraki gün bebeğin annesini bulmak için Tokyo’nun köhne sokaklarından ışıklı caddelerle dolu zengin semtlerine doğru yola çıkarlar. Bu yolculuksa hayatlarının macerası olur; çünkü üçlü kendi geçmişleriyle de yüzleşmek zorunda kalacaklardır. Perfect Blue’nun yaratıcısı Satoshi Kon’un diğer filmlerine göre daha kolay izlenebilir bir hikaye sunduğu Tokyo Godfathers, hem komik hem hüzünlü hikayesiyle yönetmenin en başarılı çalışmalarından biri."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Велика пустоловина у Токију","runtime":0,"tagline":"","homepage":"","overview":"Троје бескућника, за време божића проналазе бебу и одлучују да преврну цео Токио док не пронађу њене родитеље..."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Кръстниците от Токио","runtime":0,"tagline":"","homepage":"","overview":"В Токио животът на трима бездомници се променя завинаги, след като намират бебе-момиченце в боклука, в навечерието на Коледа. С настъпването на Новата година тримата забравени от обществото скитници се събират, за да разрешат загадката на изоставеното дете и съдбата на неговите родители. По пътя им се случват привидно несвързани събития, които ги принуждават да се изправят срещу призраците от собственото им минало, докато се научат да вървят към бъдещето заедно."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Héroes al rescate","runtime":0,"tagline":"","homepage":"","overview":"Es Navidad y la nieve cubre la ciudad de Tokio con su blanco manto. En algún lugar de Shinjuku encontramos a tres vagabundos: Gin, Hana y Miyuki. Una noche oyen unos lloros que salen de entre un montón basura y encuentran a un angelical bebé. Gin insiste en llevarlo a la policía y que ellos se encarguen de él. Sin embargo, Hana, que siempre ha tenido la ilusión de tener un bebé, no quiere dejárselo a nadie y que sean ellos mismos los que busquen a los padres. Así será como estos tres amigos se embarcan en la aventura de encontrar a la familia del bebé."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"東京教父","runtime":0,"tagline":"","homepage":"","overview":"宮崎駿接班人今敏的最新動畫作品，2004年台灣國際動畫影展閉幕片，劇情幽默諷刺，這次今敏用大家熟悉的東京街頭和景點描繪了一段笑中帶淚的奇幻追尋。今敏透過片中的三位流浪漢影射了日本現代社會整體的現實、經濟變遷下的殘忍及底層民政的辛酸生活。  大雪紛飛的東京，在一個原本應該是全家團圓的聖誕夜裡，流浪漢阿仁、小花和美雪卻在新宿街頭意外撿到一個被遺棄的女嬰。阿仁堅持要將女嬰送交警察局，但前紅頂藝人小花卻一直渴望有個小孩，執意留下女嬰直到找到她的親生父母為止，並將女嬰取名為木代子，而他們就是木代子的教父和教母。  但女嬰親生父母的資料只有一張酒吧名片和幾張照片而已，於是三個看似放棄人生，沒有未來的流浪漢在叢林都市中展開了一段尋人冒險。在這個旅程中，遇到了許多不可思議的人事物，經歷了無數的巧合和意外，也漸漸地彼此發現了成為流浪漢之前的過去…。究竟他們最後到底找到的是木代子的幸福亦或是他們自己的幸福？  今敏這次將眾人熟悉的東京轉化成魔幻寫實的最佳場景。藉由一段段如此奇妙但合理的巧合和偶遇，每一個小意外都像一股不可抗拒的力量帶著所有人面對他們不可知但又必然的未來。在這一段段的巧合中，觀眾也自然而然的認識三位主角流浪街頭的原因。這種帶著觀眾如偵探般從一無所知到漸漸拼湊所有事件的巧妙手法，就是今敏最吸引人的魔術。  本片劇本是由曾寫過日本國民偶像劇《白線流》的信本敬子撰寫，音樂出自曾擔任北野武電影《座頭市》(台區片名: 盲劍客) 配樂的鈴木慶一，人物設計則由今敏和《千年女優》的動畫總監小西賢一共同完成，除此之外《神隱少女》的動畫監督安藤雅司也加入製作行列，日本演技派男星江守徹擔任阿仁的配音，可說是日本菁英的大結合。片中結尾使用了貝多芬第9號交響曲，令人悸動。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Токійські Хрещені","runtime":93,"tagline":"","homepage":"","overview":"На Різдво трапляються дива. Це давно відомий факт. От і ця історія про диво. Троє безпритульних знаходять покинуте дитя і вирушають на пошуки його батьків. Дорогою їх веде Божа рука, адже це Святвечір і знайдуть вони не лишень дім для маляти."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Tokyo Godfathers","runtime":0,"tagline":"","homepage":"","overview":"Κατά τη διάρκεια της παραμονής των Χριστουγέννων στο Τόκιο, τρεις άστεγοι, ο μεσήλικας αλκοολικός Τζιν, η πρώην ναρκομανής Χάνα και η φυγάς Miyuki, ανακαλύπτουν ένα εγκαταλελειμμένο νεογέννητο, ψάχνοντας τα σκουπίδια. Με ελάχιστα στοιχεία για την ταυτότητα του μωρού, οι τρεις φίλοι ψάχνουν στην πόλη για να βρουν τους γονείς του."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Tokijští kmotři","runtime":92,"tagline":"","homepage":"","overview":"Život na ulici není ani v Tokiu jednoduchý. Pouliční bitky, strach a nejistota. Gin, Hana a Miyuko by o tom mohli vyprávět. Každý z nich má svůj nezáviděníhodný životní příběh. Avšak právě na Štědrý den tito tři lidé najdou na jednom smetišti malou holčičku a všechno se pro ně změní. Odhalí tajemství opuštěného dítěte a jeho rodičů?"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Một Đêm Tuyết Phủ","runtime":0,"tagline":"","homepage":"","overview":"Gin nghiện rượu trung niên (Darren Pleavin), thiếu niên bỏ trốn Miyuki (Candice Moore) và cựu nữ hoàng kéo Hana (Myrta Dangelo) là một bộ ba người vô gia cư sống sót trong một gia đình tạm bợ trên đường phố Tokyo. Khi đang lục trong thùng rác để tìm thức ăn trong đêm Giáng sinh, họ tình cờ phát hiện một đứa trẻ sơ sinh bị bỏ rơi trong thùng rác. Chỉ với một số manh mối về danh tính của đứa bé, ba kẻ xấu tìm kiếm trên đường phố Tokyo để được giúp đỡ trong việc trả lại đứa bé cho cha mẹ của nó."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"東京教父","runtime":0,"tagline":"","homepage":"","overview":"一份意想不到的聖誕禮物，出現在三個無家可歸、於新宿街頭流浪的人面前。某個平安夜，中年流浪漢阿仁、變性人小花和離家出走的女高中生美由紀，在垃圾堆中發現一個被遺棄的女嬰，並為她取名為清子。為了尋回清子的父母，三人帶著女嬰在下雪的東京夜晚，展開充滿奇跡的尋親之旅。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Tokyo Godfathers","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ca-fr/title/60034521","overview":"La veille de Noël, trois sans-abri partent à la recherche des parents d'un bébé abandonné qu'ils ont trouvé, croisant plusieurs curieux personnages en chemin."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Rodzice chrzestni z Tokio","runtime":0,"tagline":"Poznajcie najbardziej niedpoasowaną rodzinę","homepage":"","overview":"Troje bezdomnych znajduje w Wigilię porzucone niemowlę i wyrusza na poszukiwania jego rodziców, spotykając po drodze całe mnóstwo niezwykłych oryginałów."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"โตเกียว ก็อตฟาเธอร์ เมตตาไม่มีวันตาย","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"ტოკიოელი ნათლიები","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"}],"reviews_tmdb":[{"id":"63a8267b0f21c600b0cbc249","url":"https://www.themoviedb.org/review/63a8267b0f21c600b0cbc249","author":"CinemaSerf","content":"$11","created_at":"2022-12-25T10:31:23.931Z","updated_at":"2022-12-25T10:31:24.093Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":33320,"adult":false,"title":"Millennium Actress","video":false,"overview":"Documentary filmmaker Genya Tachibana has tracked down the legendary actress Chiyoko Fujiwara, who mysteriously vanished at the height of her career. When he presents her with a key she had lost and thought was gone forever, the filmmaker could not have imagined that it would not only unlock the long-held secrets of Chiyoko’s life... but also his own.","genre_ids":[18,16,10749,14],"media_type":"movie","popularity":1.8237,"vote_count":981,"poster_path":"/p44UXOFBCY5xbpCKEsWpi4filCD.jpg","release_date":"2002-09-14","vote_average":7.8,"backdrop_path":"/jZW391Kknf4YiIaZ1XHyVjnJaKe.jpg","original_title":"千年女優","original_language":"ja"},{"id":4977,"adult":false,"title":"Paprika","video":false,"overview":"When a machine that allows therapists to enter their patient's dreams is stolen, all hell breaks loose. Only a young female therapist can stop it and recover it before damage is done: Paprika.","genre_ids":[16,878,53],"media_type":"movie","popularity":7.1929,"vote_count":2770,"poster_path":"/bLUUr474Go1DfeN1HLjE3rnZXBq.jpg","release_date":"2006-10-01","vote_average":7.8,"backdrop_path":"/zfbuY4A9X5sTJ2bzTt84rtiDK9t.jpg","original_title":"パプリカ","original_language":"ja"},{"id":10494,"adult":false,"title":"Perfect Blue","video":false,"overview":"Rising pop star Mima quits singing to pursue a career as an actress. After she takes up a role on a popular detective show, her handlers and collaborators begin turning up murdered. Harboring feelings of guilt and haunted by visions of her former self, Mima's reality and fantasy meld into a frenzied paranoia.","genre_ids":[16,53],"media_type":"movie","popularity":7.03,"vote_count":3069,"poster_path":"/6WTiOCfDPP8XV4jqfloiVWf7KHq.jpg","release_date":"1998-02-28","vote_average":8.3,"backdrop_path":"/mHG7dpLb0ZScSY3LpP443IHRmjy.jpg","original_title":"PERFECT BLUE","original_language":"ja"},{"id":41201,"adult":false,"title":"The Illusionist","video":false,"overview":"A French illusionist travels to Scotland to work. He meets a young woman in a small village. Their ensuing adventure in Edinburgh changes both their lives forever.","genre_ids":[16,18],"media_type":"movie","popularity":1.3964,"vote_count":664,"poster_path":"/Ac2tNYW9sRaOhmtMJQuhf2mvo00.jpg","release_date":"2010-06-16","vote_average":7.259,"backdrop_path":"/9Ocq5X0MNHsTpSONcaRvNDWPiz6.jpg","original_title":"L'Illusionniste","original_language":"fr"},{"id":15877,"adult":false,"title":"The Sky Crawlers","video":false,"overview":"Youngsters called Kildren, who are destined to live eternally in their adolescence. The Kildren are conscious that every day could be the last, because they fight a war as entertainment, organized and operated by adults. But as they embrace the reality they are faced with, they live their day-to-day lives to the full.","genre_ids":[16,28,12,10752,878],"media_type":"movie","popularity":1.4282,"vote_count":169,"poster_path":"/bCObr03CsKOOwKysoUL5teG8wmU.jpg","release_date":"2008-08-02","vote_average":6.7,"backdrop_path":"/obDHA3z3M6IbacldHvdsrcQjn4o.jpg","original_title":"スカイ・クロラ","original_language":"ja"},{"id":330770,"adult":false,"title":"Evolution","video":false,"overview":"11-year-old Nicolas lives with his mother in a seaside housing estate. The only place that ever sees any activity is the hospital. It is there that all the boys from the village are forced to undergo strange medical trials that attempt to disrupt the phases of evolution.","genre_ids":[9648,18,27],"media_type":"movie","popularity":0.8514,"vote_count":226,"poster_path":"/sLluKqBaGl0NLOFTtoXLXN9u9G6.jpg","release_date":"2016-03-16","vote_average":5.896,"backdrop_path":"/qnqXk1yjSxamhBel8tOgynMbnkv.jpg","original_title":"Évolution","original_language":"fr"},{"id":41077,"adult":false,"title":"Son of the White Mare","video":false,"overview":"A horse goddess gives birth to three powerful brothers who set out into the Underworld to save three princesses from three evil dragons and reclaim their ancestors' lost kingdom.","genre_ids":[12,16,14],"media_type":"movie","popularity":0.8955,"vote_count":91,"poster_path":"/cYYYIfBFG5nszjDk5xea4MQHyDS.jpg","release_date":"1981-10-22","vote_average":7.588,"backdrop_path":"/nV5bIMguQKNVmuO9NGvZcInjcul.jpg","original_title":"Fehérlófia","original_language":"hu"},{"id":1942,"adult":false,"title":"Bunny Lake Is Missing","video":false,"overview":"A woman reports that her young daughter is missing, but there seems to be no evidence that she ever existed.","genre_ids":[9648,53],"media_type":"movie","popularity":0.7025,"vote_count":202,"poster_path":"/zsZ2PAMMyBhkn5OSC8Qnror2KCA.jpg","release_date":"1965-10-03","vote_average":7.228,"backdrop_path":"/u6cyzNiF95GaZFRmNYRDQJoU0Av.jpg","original_title":"Bunny Lake Is Missing","original_language":"en"},{"id":13180,"adult":false,"title":"Zeitgeist: Addendum","video":false,"overview":"Zeitgeist: Addendum premiered at the 5th Annual Artivist Film Festival. Director Peter Joseph stated: \"The failure of our world to resolve the issues of war, poverty, and corruption, rests within a gross ignorance about what guides human behavior to begin with. It address the true source of the instability in our society, while offering the only fundamental, long-term solution.\"","genre_ids":[99,36,10752],"media_type":"movie","popularity":0.5782,"vote_count":255,"poster_path":"/5zlBxoyWRyzPOHO7QmmAC1WG9bK.jpg","release_date":"2008-10-02","vote_average":7.231,"backdrop_path":"/4o1fHunY6UawAjfBsILGyJ1hKvU.jpg","original_title":"Zeitgeist: Addendum","original_language":"en"},{"id":34283,"adult":false,"title":"The Pervert's Guide to Cinema","video":false,"overview":"A hilarious introduction, using as examples some of the best films ever made, to some of Slovenian philosopher and psychoanalyst Slavoj Žižek's most exciting ideas on personal subjectivity, fantasy and reality, desire and sexuality.","genre_ids":[99],"media_type":"movie","popularity":0.5777,"vote_count":171,"poster_path":"/9AAxgfwAnpBmQCspuwlMITekcsW.jpg","release_date":"2006-10-06","vote_average":7.351,"backdrop_path":"/gsUS2ngyoOmbPDioUsHNXWPhD7Q.jpg","original_title":"The Pervert's Guide to Cinema","original_language":"en"},{"id":212063,"adult":false,"title":"Tim's Vermeer","video":false,"overview":"Tim Jenison, a Texas based inventor, attempts to solve one of the greatest mysteries in all art: How did Dutch Master Johannes Vermeer manage to paint so photo-realistically 150 years before the invention of photography? Spanning a decade, Jenison's adventure takes him to Holland, on a pilgrimage to the North coast of Yorkshire to meet artista David Hockney, and eventually even to Buckingham Palace. The epic research project Jenison embarques on is as extraordinary as what he discovers.","genre_ids":[99],"media_type":"movie","popularity":0.5185,"vote_count":164,"poster_path":"/vEF0f8dktdp4NbUbpi0xSzwUAY8.jpg","release_date":"2013-12-06","vote_average":7.213,"backdrop_path":"/pY6gDWUjRmh785MRVHLgnqM9fV2.jpg","original_title":"Tim's Vermeer","original_language":"en"},{"id":342917,"adult":false,"title":"Batman Unlimited: Monster Mayhem","video":false,"overview":"The Joker is aided in his Halloween quest to render modern technology useless and take over Gotham City by Solomon Grundy, Silver Banshee, Clayface and Scarecrow.","genre_ids":[28,16,10751],"media_type":"movie","popularity":0.9587,"vote_count":158,"poster_path":"/jceXBNFMPLAKlo2MPJGJlXJBQJL.jpg","release_date":"2015-08-18","vote_average":6.285,"backdrop_path":"/b2PukjpOQOv11Ymd7smZLIMYZwg.jpg","original_title":"Batman Unlimited: Monster Mayhem","original_language":"en"},{"id":18384,"adult":false,"title":"Scandal Makers","video":false,"overview":"Former teen idol Nam Hyeon-soo is now in his thirties and working as a radio DJ. One day a young woman named Jeong-nam shows up and claims to be his own daughter. She also has a son whom she claims to be Hyeon-soo's grandson. Their relation is proven via DNA tests by Hyeon-soo's brother. This leads to Hyeon-soo attempting to avoid a scandal concerning him having children \"unknown\" to the media.","genre_ids":[35,18],"media_type":"movie","popularity":0.5427,"vote_count":102,"poster_path":"/1DHrv3dQpLX3x2GBbBRd05VX3dG.jpg","release_date":"2008-12-03","vote_average":7.235,"backdrop_path":"/usQsY5Db8SxKDALitFgMj1iJU9V.jpg","original_title":"과속스캔들","original_language":"ko"},{"id":781816,"adult":false,"title":"Fortune Favors Lady Nikuko","video":false,"overview":"Brash single mother Nikuko is well-known for her bold spirit, much to the embarrassment of Kikuko, her pensive yet imaginative daughter. In contrast to her mother, Kikuko wants nothing more than to fit in as she navigates the everyday social dramas of middle school. Life in the harbor is peaceful until a shocking revelation from the past threatens to uproot the pair's tender relationship.","genre_ids":[16,18,10751,35],"media_type":"movie","popularity":1.1531,"vote_count":63,"poster_path":"/ceine994qh3wc5KpQoEp3LAGHOS.jpg","release_date":"2021-06-11","vote_average":7.175,"backdrop_path":"/yfUTW2pYUGU3vK682TZmV95Q6vn.jpg","original_title":"漁港の肉子ちゃん","original_language":"ja"},{"id":15318,"adult":false,"title":"The Taste of Tea","video":false,"overview":"A spell of time in the life of a family in rural Tochigi prefecture. Yoshiko is not an ordinary housewife, instead working on an animated film project. Uncle Ayano, a successful music producer, is looking to get his head together after living in Tokyo. Meanwhile, Sachiko is concerned with why she seems to be followed by a giant version of herself. As the lazy days pass by, each member of the family is followed in a series of episodic vignettes.","genre_ids":[35,18,14],"media_type":"movie","popularity":1.3346,"vote_count":158,"poster_path":"/yapwfNElQYFY9TaVS03jv6Gk2Rs.jpg","release_date":"2004-07-17","vote_average":7.487,"backdrop_path":"/kmPpgz9TNhQO8IQcZMtmznRtgKg.jpg","original_title":"茶の味","original_language":"ja"},{"id":49291,"adult":false,"title":"Time and Tide","video":false,"overview":"A streetwise young man becomes a bodyguard to score quick cash. He befriends a disillusioned mercenary determined to begin life anew. They find themselves working together to foil an assassination attempt, but their partnership ultimately can't last.","genre_ids":[28,53,80],"media_type":"movie","popularity":0.6959,"vote_count":184,"poster_path":"/ywm95TI4eZUNrQwXOEamn2diVD6.jpg","release_date":"2000-10-19","vote_average":6.4,"backdrop_path":"/k6RUUIiJDVn6Rs1jmenk0uNUwaY.jpg","original_title":"順流逆流","original_language":"cn"},{"id":506492,"adult":false,"title":"L Storm","video":false,"overview":"ICAC Investigator William Luk and JFIU Chief Inspector Lau Po-keung both hit a dead end in their investigation of a bribery case and a money laundering case. In the meantime, William Luk was suspended when model Eva Ng went to Inspector Kenny Ching of ICAC’s Internal Investigation Group L, to file a report against him for accepting a $12M bribe.  Lau discovered Luk was set up and whoever framed Luk was connected to his case. He began to suspect the bank manager Thomson Yau was assisting a gangster, Wong Hoi-wo in money laundering activities. When Director Hong Liang of China’s Anti-Corruption & Bribery Bureau (ACBB) provided Lau with important intelligence, it became clear the money laundering activities were connected to a corrupted Vice-Ministerial Level cadre. To clear his name, William Luk put everything on the line…","genre_ids":[28,80,53],"media_type":"movie","popularity":1.1796,"vote_count":42,"poster_path":"/aaOgrGklljbs2nCdICtkvGPtvRR.jpg","release_date":"2018-08-23","vote_average":6.952,"backdrop_path":"/t24KuHPBo0SBcSiuFNptHIEvPT5.jpg","original_title":"L風暴","original_language":"cn"},{"id":71579,"adult":false,"title":"Rare Exports Inc.","video":false,"overview":"An elite trio of expert hunters venture into the woods to track and capture an especially rare and dangerous prey for the Christmas season.","genre_ids":[35,28],"media_type":"movie","popularity":2.257,"vote_count":80,"poster_path":"/kgjUiikRZ8g1p5vxvk2BMez3PdO.jpg","release_date":"2003-06-19","vote_average":6.988,"backdrop_path":"/c8eOezxfAwEJtRS9UudGJpTNZsK.jpg","original_title":"Rare Exports Inc.","original_language":"fi"},{"id":689643,"adult":false,"title":"Sincerely Louis C.K.","video":true,"overview":"Louis C.K. muses on religion, terrorism, small towns, Florida, disabilities, dogs, Auschwitz, marriage, sex, vegans, and his personal sexual controversy, in a live performance from Washington, D.C.","genre_ids":[35],"media_type":"movie","popularity":0.1761,"vote_count":112,"poster_path":"/vk2c6UzgnLinjzGvoQ2QZsauPEV.jpg","release_date":"2020-04-04","vote_average":7.406,"backdrop_path":"/lHctVQ60nBYzJ51n9xpZGYJiWiV.jpg","original_title":"Sincerely Louis C.K.","original_language":"en"}],"similar_content":[{"id":10228,"adult":false,"title":"Pokémon: The First Movie","video":false,"overview":"Determined to prove its superiority, a bio-engineered Pokémon called Mewtwo lures Ash, Pikachu and others into a Pokemon match like none before.","genre_ids":[16,10751,12,14,28],"popularity":5.3554,"vote_count":1549,"poster_path":"/xPW3AeK3iQi1Zd9dCbdNLijE48o.jpg