78,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/qQPDAvGL6dVFo1a0WmRIvxmbVNY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/SgvZLZBR9Jm6aAgXZU5A6O9cj5.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/zsp0BqMCYSHB85lFev8E1XuqOzS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/7xOgjJSIrKUu0ru3y96wc9GmXm3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":7,"aspect_ratio":1.778,"vote_average":1.714},{"width":1280,"height":720,"file_path":"/nGZqSqujjZ5i7ZrHP0Yl5xcjAYY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":1.066},{"width":1280,"height":720,"file_path":"/OVhvvMNalKG0xbzWsyptpFbyct.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":1920,"height":1080,"file_path":"/aikVeGvbZxj2CsPRy3PsAmRrhNo.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/8mC8u646wfKynWoJeksJiILAYfT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2048,"height":1152,"file_path":"/mYwZNz7Z3K83KnGBlRd7v1mbIWS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/iJICFUnjvcx97ov0imXPJEpEsHX.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/eO3K367hZ7zyic450M6VsP9dq6r.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/zg6sSbkUeE8ZSEz5DQWEjS8uO4a.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/qg5J1XZ1E68xg8HWPIjfZrMKnlw.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/yQXLRywt1tFU5m4bC5JzroREapA.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/otZg5gu5kDmQXYGixnrJElEMyTf.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:58:38.703+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":91,"tagline":"No sesame. All street.","homepage":"http://www.thehappytimemurders.movie/","overview":"In a world where humans coexist with puppets—who are seen as lesser citizens—cast members of a beloved 1990s children's television series begin getting murdered one by one. Puppet Phil Philips, an ex-LAPD detective-turned-private eye, takes on the case at the request of his old boss in order to assist his former partner, Detective Connie Edwards."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Carnage chez les Puppets","runtime":0,"tagline":"","homepage":"","overview":"Dans les bas-fonds de Los Angeles, humains et marionnettes vivent ensemble. Deux détectives, un humain et une marionnette, sont obligés de faire équipe bien malgré eux pour découvrir qui assassine les anciens acteurs du «Happytime Gang», une émission de marionnettes très populaire."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"I Los Angeles lever dukker og mennesker side om side og er lige levende. En kvindelig betjent og en privatdetektiv, som er dukke, bliver tvunget til at arbejde sammen for at finde ud af, hvem der systematisk dræber de tidligere medlemmer af det engang så populære dukkeshow 'The Happytime Gang'."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Игрушки для взрослых","runtime":91,"tagline":"","homepage":"","overview":"Лос-Анджелес – обитель денег, знаменитостей и взрослых развлечений, здесь куклы живут бок о бок с людьми. Внезапно по городу прокатывается волна загадочных преступлений, связанных со звездами популярного телешоу. И тогда на охоту выходят бывшие напарники – брутальный частный детектив и коп в юбке…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Іграшки для дорослих","runtime":0,"tagline":"","homepage":"","overview":"Лос-Анджелес — оселя грошей, знаменитостей і дорослих розваг, тут ляльки живуть пліч-о-пліч з людьми. Раптово по місту прокочується хвиля загадкових злочинів, пов'язаних з зірками популярного телешоу. І тоді на полювання виходять колишні напарники — брутальний приватний детектив і коп в спідниці."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Убийства в Хепитайм","runtime":0,"tagline":"","homepage":"","overview":"Действието се развива в свят, в който хора и живи кукли живеят заедно. Но въпреки мирното съжителство, много от куклите изпитват страх от хората. Страх породен от определени човешки организации, които постоянно протестират срещу многото права, с които куклите, на пръв поглед, разполагат."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"¿Quién está matando a los moñecos?","runtime":0,"tagline":"Nada de sesamo, solo puro barrio","homepage":"","overview":"En el barrio más vulnerable de Los Ángeles, donde cohabitan muñecos y humanos, dos detectives enfrentados, un humano y un moñeco, se ven obligados a trabajar juntos para tratar de averiguar quién está asesinando brutalmente al antiguo elenco de “The Happytime Gang”, un exitoso programa de marionetas de los años 80."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Haláli bábjáték","runtime":91,"tagline":"Semmi Szezám. Csak az utca.","homepage":"","overview":"Egy olyan világban, ahol bábok és emberek egymás mellett élnek -nem túl nagy harmóniában-, a levitézlett hekusból lett báb-magánnyomozó, Phil Phillips egy sorozatgyilkos nyomába ered egykori rendőrtársával, a kissé vonalas, ám nem túl áramvonalas Edwards detektívvel az oldalán."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"賤偵 MADAM 摷公仔","runtime":0,"tagline":"","homepage":"","overview":"一群主演兒童節目多年的布公仔，逐一被人謀殺。瑪莉莎麥卡菲飾演的女幹探，在查案過程中，竟發現布公仔並非如想像般純情；他們亦如人類一樣，有齊各式人性弱點！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"欢乐时光谋杀案","runtime":0,"tagline":"","homepage":"","overview":"故事发生在布偶与人类共居的洛杉矶腹地，布偶剧组发生了神秘谋杀案，两个意见不合的警探一个人类、一个布偶不得不携手破案。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"בובה של רצח","runtime":0,"tagline":"רק רחוב. בלי סומסום.","homepage":"","overview":"ברובע עזוב אך מלא חיים שבו מסתובבים בני אנוש וחבובות זה לצד זה בהרמוניה כמעט מושלמת. שני בלשים יריבים עם סוד כמוס, אחת בת אנוש וחבובה אחת, נאלצים לדאבונם לעבוד שוב יחדיו כדי לפתור את תעלומת הרציחות של צוות משתתפי תוכנית החבובות הקלאסית."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":91,"tagline":"","homepage":"","overview":"I en värld där \"puppets\" lever bland människor, men inte riktigt har uppnått samma status, jobbar detektiv Phil. Han återförenas med sin forna partner, detektiv Connie Edwards för att hitta den som mördade detektiv Phils bror och som nu är ute efter flera ur casten till 80-talets succé-TV-serie The Happytime Gang. Phils gamla tjej har utsatts för hot och är nästa tilltänkta offer. Snart pekar misstankarna mot Phil själv. Han sticker och måste nu ensam försöka lösa The Happytime Murders."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Плишани Гадови","runtime":0,"tagline":"","homepage":"","overview":"Радња је смештена у криминално подземље Лос Анђелеса у којем лутке и људи живе заједно, али лутке се сматрају грађанима другог реда. Посрнули бивши полицајац и порочни приватни детектив, Фил Филипс (лутка), одлучан је у откривању серијског убице који је убио његовог брата а сада убија чланове популарне серије из ‘80-их година. Како би решио случај, удружује се с детективом Едвардс, својом бившом партнерком коју не подноси."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Edepsiz Kuklalar","runtime":0,"tagline":"","homepage":"","overview":"Film, insanlar ve kuklaların birlikte yaşadığı bir dünyada geçiyor. Ancak bu dünyada kuklalar ikinci sınıf vatandaş muamelesi görüyor. 1980'li yılların çocuk programı The Happytime Gang'in oyuncu kuklaları bir bir ölü bulunmaya başladığı zaman alkolik ve gözden düşmüş bir LAPD dedektifi dedektifliğe soyunuyor ve bu ölümlerin peşine düşüyor..."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Žaisliukai suaugusiems","runtime":0,"tagline":"","homepage":"","overview":"Neprestižinėje Los Andželo dalyje, į kurią turistai niekuomet neužsuka, nuo seno kartu sugyvena žmonės ir lėlės. Rajone verda savas smulkių nusikaltėlių, chuliganų, šulerių, apgavikų ir sukčių gyvenimas. Vieną dieną rajoną sukrečia žiauri lėliažudystė: nužudomas privataus detektyvo, buvusio policijos pareigūno Filo brolis. Netrukus nužudoma dar viena lėlė. Ir dar viena. Ir dar. Paaiškėja, kad serijinis lėliažudys metodiškai šalina kažkada itin populiaraus televizijos serialo „The Happytime Gang“ aktorius. Suvokęs, kad kita auka žudiko sąraše bet kuriuo metu gali tapti jo buvusi meilė Dženė (akt. Elizabeth Banks), Filas prisiekia sugauti nusikaltėlį. Kartu su buvusia savo partnere policijoje Kone Edvards (aktorė Melissa McCarthy), su kuria jį sieja bendra paslaptis, Filas leidžiasi medžioti paslaptingojo žudiko. Tačiau tyrimui įsibėgėjant, vis daugiau įkalčių rodo būtent į Filo pusę."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Pupazzi senza gloria","runtime":91,"tagline":"Niente sesamo. Tutta strada.","homepage":"","overview":"Nella tranquilla città di Los Angeles pupazzi e umani vivono insieme quotidaniamente,ma un giorno trovano i cadaveri di alcuni pupazzi in un bar,un poliziotto di nome Philips e la sua collega Connie Edwards scoprono che in città gira un assasino che assieme ai suoi compagni e cani ammazza tutti i pupazzi che incontra nella sua strada facendogli esplodere la testa,ora Philips e la sua collega devono cercare a tutti i costi questo assassino prima che uccida altri pupazzi."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"해피타임 스파이","runtime":0,"tagline":"하얀 솜이 낭자한 연쇄 살해 사건! 낫닝겟급 수사가 시작된다!","homepage":"","overview":"인간과 인형들이 함께 사는 평화로운 도시, 인형들만 노리는 살인형범이 나타났다. 과거의 악연으로 원수지간이 되어버린 병맛 인형 탐정 ‘필립스’와 열혈 형사 ‘에드워즈’는 환상적인 궁합(?)을 보이며 범인을 추격하기 시작하는데…  지금까지 이런 솜뭉치는 없었다! X나게 신선하고, X나게 웃긴 약빤 코믹 수사극 탄생!"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Rozpruci na śmierć","runtime":0,"tagline":"","homepage":"","overview":"Kiedy byłe gwiazdy telewizyjnego show stają się ofiarami seryjnego mordercy, detektyw/kukiełka Jim będzie samotnie próbował wyjaśnić te zbrodnie. Samotnie, ponieważ żaden człowiek nie zamierza zawracać sobie głowy niedolą pluszowych kukiełek. Gdy jednak sprawa staje się coraz bardziej głośna, Jimowi zostaje przydzielona ludzka partnerka. Detektyw Edwards, bo tak ma na imię, to mało sympatyczna i upierdliwa osoba. Na tyle irytująca, że ta pomoc okaże się dla Jima prawdziwym utrapieniem, a rozpruwacz wcale nie zwalnia tempa…"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Pela Hora da Morte","runtime":91,"tagline":"","homepage":"","overview":"Dois detetives em confronto, um humano (Melissa McCarthy) e um boneco, são forçados a trabalhar juntos para solucionar os violentos assassinatos do elenco de bonecos de uma famosa série de televisão."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":91,"tagline":"","homepage":"","overview":"Σε έναν κόσμο όπου οι άνθρωποι συνυπάρχουν με τα muppets, ο ιδιωτικός ντετέκτιβ Φιλ ψάχνει να βρει τον κατά συρροή δολοφόνο που σκότωσε τον αδερφό του και τώρα έχει βάλει στο μάτι τους πρωταγωνιστές μιας διάσημης τηλεοπτικής σειράς για παιδιά."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"歡樂時光謀殺案","runtime":0,"tagline":"","homepage":"","overview":"警探康妮艾德華（瑪莉莎麥卡錫 飾）和布偶菲爾菲利浦原是洛城警局最風光的一對搭檔，直到菲爾因為涉入一樁槍擊案被免職，導致兩人被迫拆夥。離開警局後的菲爾淪為私家偵探，四處接案維生，但某次調查過程中，他發現自己身陷一樁布偶連續殺人案，受害者全是90年代家喻戶曉兒童節目「歡樂時光幫」的演員。為了找出凶手，菲爾只好找上老搭檔康妮，再度發揮辦案本事，攜手破案。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Elokuva sijoittuu Los Angelesin laitamille, jossa nuket ja ihmiset elävät rinta rinnan. Kaksi erimielistä etsivää, toinen ihminen, toinen nukke, joutuvat työskentelemään yhdessä selvittääkseen kuka murhaa julmasti suositun ”The Happytime Gang” -nukkeshow’n entisiä tähtiä."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"","runtime":91,"tagline":"Kein Sesam. Nur Straße. Das Leben ist nicht immer warm und flauschig.","homepage":"","overview":"In einer Welt in der Puppen als ‚Menschen‘ zweiter Klasse mit eben diesen koexistieren, ist der Privatdetektiv und Ex-Cop Phil Phillips auf der Jagd nach einem Mörder, der bereits seinen Bruder auf dem Gewissen hat. Aktuell hat der Verbrecher es auf die Darsteller der berühmten 80er-Jahre-Fernsehshow „The Happytime Gang“ abgesehen und killt ein Ensemblemitglied nach dem anderen. – Phil sorgte zwar mit einem Fehler einst dafür, dass sämtliche Puppen vom Polizeidienst ausgeschlossen wurden, doch nun sind die Cops auf sein Insiderwissen angewiesen. – Bei den Ermittlungen im düster-versauten Milieu der Puppen stellen Connie und Phil bald fest, dass es der Killer auch auf Phils Ex-Freundin Jenny abgesehen hat …"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Crimes em Happytime","runtime":0,"tagline":"","homepage":"","overview":"Phil Phillips é um ex-policial que agora trabalha como detetive particular. Após seu irmão ser assassinado, ele descobre que o responsável é um serial killer que pretende eliminar todos os integrantes do \"The Happytime Gang\", série de TV de grande sucesso nos anos 1980. Para investigar o caso, Phil é obrigado a trabalhar com sua ex-parceira Connie Edwards (Melissa McCarthy), responsável por sua expulsão da polícia, anos atrás."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Carnage chez les joyeux touffus","runtime":0,"tagline":"Des choses se passent. Partout.","homepage":"https://vvs.ca/fr/film/vvs2798-carnage-chez-les-joyeux-touffus/","overview":"La marionnette Phil Philips a déjà été un enquêteur au service de police de Los Angeles, mais à la suite d'une erreur impardonnable, il a été renvoyé et travaille maintenant comme détective privé. Quand les vedettes de l'émission pour enfants The Happytime Show sont éliminées les unes après les autres par un tueur en série, Phil reprend du service avec son ancienne partenaire humaine Connie Edwards. Ils devront mettre leurs différends de côté afin d'arrêter le massacre. Quand Phil Philips devient le principal suspect de l'enquête, les choses se compliquent. Les deux amis devront redoubler d'ardeur pour découvrir l'identité du véritable assassin."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"¿Quién mató a los Puppets?","runtime":91,"tagline":"","homepage":"https://www.thehappytimemurders.movie/","overview":"En el barrio más vulnerable de Los Ángeles, donde cohabitan muñecos y humanos, dos detectives enfrentados, un humano y un moñeco, se ven obligados a trabajar juntos para tratar de averiguar quién está asesinando brutalmente al antiguo elenco de “The Happytime Gang”, un exitoso programa de marionetas de los años 80"},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Nemilosrdni plišanci","runtime":0,"tagline":"Nema sezama. Samo ulica.","homepage":"","overview":"Radnja je smještena u kriminalno podzemlje Los Angelesa u kojem lutke i ljudi žive zajedno, ali lutke se smatraju građanima drugog reda. Posrnuli bivši policajac i poročni privatni detektiv, Phil Phillips (lutka), odlučan je u otkrivanju serijskog ubojice koji je ubio njegovog brata a sada ubija zvijezde nekad popularna serije. Kako bi riješio slučaj, udružuje se s detektivom Edwards, svojom bivšom partnericom koju ne podnosi."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Cine trage sforile?","runtime":91,"tagline":"","homepage":"","overview":"În L.A., unde păpușile și oamenii coexistă, un detectiv fără noroc face echipă cu fostul partener pentru a-l prinde pe cel care omoară actorii dintr-un vechi serial."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":91,"tagline":"","homepage":"","overview":"Sinds Phil Phillips na een incident ontslagen is werkt deze pop als privé-detective die kort achter elkaar getuige is van twee moorden, waaronder die van zijn broer."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Rotaļlietas pieaugušajiem","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Hele Muppete, kdo tady vraždí?","runtime":0,"tagline":"Dva detektivové - člověk a loutka - musí spolupracovat, aby dopadli vraha.","homepage":"","overview":"Ve světě, kde loutky koexistují s lidmi, ale jsou považovány za druhořadé občany, byl Phil Phillips prvním loutkovým policajtem na policejním oddělení v Los Angeles (LAPD). Nyní je soukromým detektivem, který má lidskou sekretářku Bubbles a je najat loutkovou klientkou Sandrou, aby zjistil, kdo ji vydírá. Phil vede vyšetřování v porno prodejně, která je vlastněna loutkami, a když jde dozadu, aby zkontroloval jejich záznamy, neznámý útočník zabije každého přítomného, ​​včetně pana Bumblypantsa, který hrál v „The Happytime Gang“, oblíbeném a milovaném sitcomu loutkové televize z 90-tých let. Přijde policie a Phil se po létech setkává s bývalou parťačkou, detektivem Connie Edwardsovou (Melissa McCarthy). Bylo to jen loupežné přepadení, které nevyšlo nebo vražda? Jsou nuceni začít spolupracovat, aby se dopátrali pravdy."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Pozri Mupet, kto tu vraždí!","runtime":91,"tagline":"","homepage":"","overview":"Sme vo svete, kde ľudia spolunažívajú s bábkami, ktoré spoločnosť považuje za druhoradých občanov. Phil Phillips bol prvým bábkovým policajtom na oddelení v Los Angeles. Teraz je súkromným detektívom a spolu so Sandrou – bábkovou klientkou – musia zistiť, kto ju vydiera. Phil vedie vyšetrovanie v porno predajni, ktorú vlastní skupina bábik. Keď ide dozadu skontrolovať záznamy, niekto vyvraždí celý obchod, vrátane pána Bumblypantsa, obľúbeného herca z úspešného sitcomu 90-tych rokov. Po príchode polície sa Phil stretne s bývalou parťáčkou, detektívkou Connie Edwardsovou, a spoločne pokračujú vo vyšetrovaní, aby vypátrali pravdu.  Bolo to iba obyčajné lúpežné prepadnutie obchodu so zlým koncom, alebo plánovaná vražda?"},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"パペット大騒査線 追憶の紫影","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"ตายหละหว่า ใครฆ่ามัพเพทส์!","runtime":0,"tagline":"","homepage":"","overview":"ในเรื่องจะเล่าเกี่ยวกับโลกที่หุ่นผ้าและมนุษย์อาศัยอยู่ร่วมกัน หุ่นเชิดนักสืบเอกชนและอดีตตำรวจ ฟิล ฟิลลิปส์ (บิล แบร์เร็ตต้า) กำลังตามล่าฆาตกรต่อเนื่องที่ลงมือสังหารทีมนักแสดงจาก The Happytime Gang รายการทีวียอดฮิตยุค 80 และ อดีตคนรักของฟิล เจนนี่ (อลิซาเบธ แบงค์ส) กำลังเป็นรายต่อไป ทำให้ฟิลจำต้องกลับมาร่วมมือกับศัตรูตลอดกาลอย่าง นักสืบเอ็ดเวิร์ดส (เมลิซซ่า แม็กคาร์ธี) ฉายาอาเจ๊สายโหด แสบกว่าเจ๊ก็มีแต่ทิงเจอร์เท่านั้น! ท่ามกลางการขัดขากันเอง พวกเขาจะลุยฝ่าไปถึงฆาตกรได้หรือไม่?"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":91,"tagline":"","homepage":"","overview":"Sa LA kung saan magkasama ang mga puppet at tao, nagtulungan ang malas na detective at ex-partner niya para mahuli ang killer na pumupuntirya sa cast ng dating TV show."},"name":"","iso_639_1":"tl","iso_3166_1":"PH","english_name":"Tagalog"},{"data":{"title":"","runtime":91,"tagline":"Kein Sesam. Nur Straße. Das Leben ist nicht immer warm und flauschig.","homepage":"","overview":"In einem L. A., in dem Puppen und Menschen koexistieren, jagt ein Privatdetektiv mit seiner Ex-Partnerin einen Killer, der es auf die Besetzung einer Serie abgesehen hat."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"","runtime":91,"tagline":"Kein Sesam. Nur Straße. Das Leben ist nicht immer warm und flauschig.","homepage":"","overview":"In einem L. A., in dem Puppen und Menschen koexistieren, jagt ein Privatdetektiv mit seiner Ex-Partnerin einen Killer, der es auf die Besetzung einer Serie abgesehen hat."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"CH","english_name":"German"}],"reviews_tmdb":[{"id":"5f3386ac29c62600365db96e","url":"https://www.themoviedb.org/review/5f3386ac29c62600365db96e","author":"Gimly","content":"I honestly don't think I've ever loved a Melissa McCarthy led comedy, but I did dare to dream when it came to an R-rated Muppets movie. But when _The Happytime Murders_ came to tread on my dreams, it did not tread softly. \r\n\r\n_Final rating:★½: - Boring/disappointing. Avoid where possible._","created_at":"2020-08-12T06:05:32.221Z","updated_at":"2021-06-23T15:58:42.470Z","author_details":{"name":"Gimly","rating":3,"username":"Ruuz","avatar_path":"/xUObnJSvHrFPsIpoDmb1jiQZLq7.jpg"}},{"id":"63532a6da0f1a20090b0eaa6","url":"https://www.themoviedb.org/review/63532a6da0f1a20090b0eaa6","author":"jw","content":"Puppet stories. Why do they have to be over the top? But I get it, it's not the puppets, it's the humans. \r\n\r\nPretty much standard plots, standard characters combined; but that's kind of the point. The same thing, but more gross - and more honest. \r\nAbout \"more funny\", it wasn't my taste. But hey, different tastes. Some will have laugh themselves silly.\r\n\r\nI haven't heard of Melissa McCarthy before;\r\nbut it appears this kind of humour is right up her, err, alley; and if you share it, then up yours, too.\r\n\r\n\r\n(yes, that type of humour.)","created_at":"2022-10-21T23:25:33.203Z","updated_at":"2022-10-21T23:25:48.969Z","author_details":{"name":"","rating":5,"username":"jw","avatar_path":null}}],"recommendations":[{"id":279144,"adult":false,"title":"The Death of \"Superman Lives\": What Happened?","video":false,"overview":"The Death of 'Superman Lives': What Happened? feature film documents the process of development of the ill fated \"Superman Lives\" movie, that was to be directed by Tim Burton and star Nicolas Cage as the man of steel himself, Superman. The project went through years of development before the plug was pulled, and this documentary interviews the major filmmakers: Kevin Smith, Tim Burton, Jon Peters, Dan Gilroy, Colleen Atwood, Lorenzo di Bonaventura and many many more.","genre_ids":[99],"media_type":"movie","popularity":0.4575,"vote_count":137,"poster_path":"/oned45Htl78YYkf1ByyodDmLzZ0.jpg","release_date":"2015-05-01","vote_average":6.697,"backdrop_path":"/5rPKfawUTGbZL23uQlBPJWsMgun.jpg","original_title":"The Death of \"Superman Lives\": What Happened?","original_language":"en"},{"id":491766,"adult":false,"title":"Perfect Bid: The Contestant Who Knew Too Much","video":false,"overview":"Maths teacher Ted Slauson became adept at recording and memorizing prices of products featured on the iconic game show The Price is Right, an obsession dating back to the show's inception in 1972. This passion and dedication for the show culminated in him helping a contestant place a perfect bid during a 2008 showcase, an innocent act that would create one of the biggest controversies in television industry history.","genre_ids":[99],"media_type":"movie","popularity":0.2497,"vote_count":71,"poster_path":"/k0ZpJq0QyNyPqJz57DqyORqqrPt.jpg","release_date":"2017-10-13","vote_average":6.507,"backdrop_path":"/ev9v0MrfRRLVO2GUSwN5ZL8ifuu.jpg","original_title":"Perfect Bid: The Contestant Who Knew Too Much","original_language":"en"},{"id":314285,"adult":false,"title":"Antboy: Revenge of the Red Fury","video":false,"overview":"The film ' Antboy: Revenge of the Red Fury ' is a sequel to the Danish superhero film Antboy, based on the books by Kenneth Bøgh Andersen. The story is again on the ordinary Danish boy Pelle, who secretly fights crime as a superhero Antboy. In the first film, he made ​​short work of the super villain flea , now tucked away on the local insane clinic.","genre_ids":[12,35,10751,14],"media_type":"movie","popularity":0.4729,"vote_count":72,"poster_path":"/ye4KIGuRZmq2qRk85fZg7ubeV37.jpg","release_date":"2014-12-25","vote_average":6.4,"backdrop_path":"/wEcPUE6qre4D2w8YYJ1o0aLTJhx.jpg","original_title":"Antboy II: Den røde furies hævn","original_language":"da"},{"id":550248,"adult":false,"title":"Joe Rogan: Strange Times","video":false,"overview":"Outspoken as ever, comedian Joe Rogan takes on politics, pro wrestling, pot laws, cats, vegans and much more in a stand-up special shot in Boston.","genre_ids":[35],"media_type":"movie","popularity":0.1041,"vote_count":71,"poster_path":"/nxV9XiWQsp0J9bOpReKiAnKrzNj.jpg","release_date":"2018-10-02","vote_average":7.014,"backdrop_path":"/sgiL650geWsP90TIamFK25jTGOH.jpg","original_title":"Joe Rogan: Strange Times","original_language":"en"},{"id":470901,"adult":false,"title":"Face 2 Face","video":false,"overview":"Over a series of video chats, a teenage outcast reaches out to his childhood friend, but finds that behind the veneer of popularity and a seemingly perfect life, she hides a disturbing secret.","genre_ids":[18],"media_type":"movie","popularity":0.3045,"vote_count":43,"poster_path":"/lciZWx3qVPUxGnw9rzNBqNgQPuN.jpg","release_date":"2017-04-23","vote_average":6,"backdrop_path":"/9VoU9AV6POqPSVXVR832BZDBAr.jpg","original_title":"Face 2 Face","original_language":"en"},{"id":608611,"adult":false,"title":"Relativity","video":false,"overview":"The fate of Nora, a supermarket cashier who lives happily with her boyfriend Aron, and that of Natan, a loving father who works as a night watchman, cross paths when misfortune turns their lives upside down.","genre_ids":[18,10749],"media_type":"movie","popularity":0.1857,"vote_count":39,"poster_path":"/9F5YRwCHzl47bNZsJxAHvFlYNFq.jpg","release_date":"2019-11-28","vote_average":5.9,"backdrop_path":"/vyaeQl1ioWbzWyGQGOtFqYRu1ab.jpg","original_title":"Mein Ende. Dein Anfang.","original_language":"de"},{"id":851238,"adult":false,"title":"Guglhupfgeschwader","video":false,"overview":"Bavaria's most relaxed village policeman has to face an organized crime syndicate coming after his grandmother's cakes.","genre_ids":[35,80],"media_type":"movie","popularity":0.5544,"vote_count":64,"poster_path":"/oVgqx7A0x6fK79oF9Qrkdp62fiQ.jpg","release_date":"2022-08-04","vote_average":6.438,"backdrop_path":"/AiR95OFlkY00Z18uLl2eL2pZNeL.jpg","original_title":"Guglhupfgeschwader","original_language":"de"},{"id":390867,"adult":false,"title":"D.P.A. Detetives do Prédio Azul - O Filme","video":false,"overview":"The Detetives do Prédio Azul are faced with the biggest case of their lives: saving the building itself from destruction. Pippo, Sol and Bento infiltrate Dona Leocádia's party, the terrible manager who is literally a witch. There they witness a \"magical\" crime, which condemns the Blue Building to an emergency demolition.","genre_ids":[10751,12,9648],"media_type":"movie","popularity":0.2759,"vote_count":33,"poster_path":"/4ezEwZp2gUCfiT5STguLWNV4BYR.jpg","release_date":"2017-07-13","vote_average":7.3,"backdrop_path":"/g3TWOEadu0Rr4yhedx3lEIpYX21.jpg","original_title":"D.P.A. Detetives do Prédio Azul - O Filme","original_language":"pt"},{"id":225854,"adult":false,"title":"A Liar in Paradise","video":false,"overview":"Two poor friends are trying to run a con on a wealthy family.","genre_ids":[35],"media_type":"movie","popularity":0.2125,"vote_count":8,"poster_path":"/hvtX0wBB8ejn1mUjJuk44fJrktz.jpg","release_date":"1998-12-04","vote_average":5.5,"backdrop_path":"/b5UASahwBPMRhX42di5xx70tac1.jpg","original_title":"Un bugiardo in paradiso","original_language":"it"},{"id":477449,"adult":false,"title":"Overlord: The Dark Hero","video":false,"overview":"The second recap film of season 1 of the anime TV series Overlord, covering episodes 8 to 13.","genre_ids":[16,28,12,14],"media_type":"movie","popularity":1.2546,"vote_count":27,"poster_path":"/joAUUvoVxRkk0AHny7lhoN9yk5r.jpg","release_date":"2017-03-11","vote_average":7.4,"backdrop_path":"/7ppe5S9RJKBaIjliCFWOqwTiUaP.jpg","original_title":"劇場版総集編 オーバーロード 漆黒の英雄【後編】","original_language":"ja"},{"id":41090,"adult":false,"title":"Wisdom","video":false,"overview":"Unable to find work after a past felony, graduate John Wisdom and his girlfriend embark on a cross-country bank-robbing spree in order to aid American farmers.","genre_ids":[80,18,28],"media_type":"movie","popularity":0.5445,"vote_count":48,"poster_path":"/jJiKZG7vauFCeax5Aj5fahrcKUO.jpg","release_date":"1986-12-31","vote_average":5.917,"backdrop_path":"/k27eOAX1DLy2ZjAfb88Z5OJBq6v.jpg","original_title":"Wisdom","original_language":"en"},{"id":84572,"adult":false,"title":"The Mars Underground","video":false,"overview":"The Mars Underground is a landmark documentary that brings to life, through the use of state-of-the-art 3D animation, the daring first human mission to the red planet and explores the challenges of surviving on Mars.","genre_ids":[99],"media_type":"movie","popularity":0.0947,"vote_count":14,"poster_path":"/oPuJz3Z7z6WbBln3hIlClvf321T.jpg","release_date":"2007-05-09","vote_average":7.2,"backdrop_path":"/43GR1dH2AaU6LKeHvxG3Wakh2u7.jpg","original_title":"The Mars Underground","original_language":"en"},{"id":485880,"adult":false,"title":"Safari: Match Me If You Can","video":false,"overview":"Munich, the city of singles and unfulfilled desire. Whoever feels like having a one-night stand can just use Safari, a new dating app. But is it also possible to find love via the app? Harry at least meets Lara through Safari, even though he’s married to Aurelie.","genre_ids":[35],"media_type":"movie","popularity":0.1769,"vote_count":18,"poster_path":"/ijA8Pemp9NMFpIFyaRPa0m4J3bu.jpg","release_date":"2018-08-30","vote_average":4.5,"backdrop_path":"/w58GL4CNgIPPFqhTGJo9Qmhq2jV.jpg","original_title":"Safari: Match Me If You Can","original_language":"de"},{"id":513540,"adult":false,"title":"Missing","video":false,"overview":"A couple checks into a beach resort in Mauritius late night with their three-year-old daughter Titli who in the next morning goes missing.","genre_ids":[53,9648],"media_type":"movie","popularity":1.1205,"vote_count":16,"poster_path":"/6FRPUYld8D0dT0AMrGMJ4cjb94R.jpg","release_date":"2018-04-06","vote_average":6.094,"backdrop_path":"/qRaADZ6wg11LN2z1aZ1EkDeYnLs.jpg","original_title":"Missing","original_language":"hi"},{"id":23127,"adult":false,"title":"The Haunted World of El Superbeasto","video":false,"overview":"The Haunted World of El Superbeasto is an animated comedy that also combines elements of a horror and thriller film. It is based upon the comic book series created by Rob Zombie that follows the character of El Superbeasto and his sexy sidekick sister, Suzi-X, voiced by Sheri Moon, as they confront an evil villain by the name of Dr. Satan.","genre_ids":[16,28,35,14,27,10402],"media_type":"movie","popularity":1.108,"vote_count":204,"poster_path":"/obOr6ir0UlLGqln6HVMa2My9ENs.jpg","release_date":"2009-09-12","vote_average":5.902,"backdrop_path":"/8GesS58jfNn1Ytp2GnGj9ElW9fl.jpg","original_title":"The Haunted World of El Superbeasto","original_language":"en"},{"id":463022,"adult":false,"title":"The Super","video":false,"overview":"A man becomes the superintendent of a large New York City apartment building where people mysteriously go missing.","genre_ids":[53,27],"media_type":"movie","popularity":1.0473,"vote_count":166,"poster_path":"/1No4DWiCA7QiVwz3CghUQ6X8PMJ.jpg","release_date":"2018-11-08","vote_average":5.181,"backdrop_path":"/1wSYWBqSmy0xCNFD2UWe0PsBu8.jpg","original_title":"The Super","original_language":"en"},{"id":463821,"adult":false,"title":"The House with a Clock in Its Walls","video":false,"overview":"When ten-year-old Lewis is suddenly orphaned, he is sent to live with his Uncle Jonathan in a creaky (and creepy) old mansion with a mysterious ticking noise that emanates from the walls. Upon discovering that his uncle is a warlock, Lewis begins learning magic, but when he rebelliously resurrects an evil warlock he must find the secret of the house and save the world from destruction.","genre_ids":[35,14,10751,27,9648],"media_type":"movie","popularity":3.6739,"vote_count":2268,"poster_path":"/qM66Hv4ByAxnilr0jaqCA9uOD4Y.jpg","release_date":"2018-09-15","vote_average":6.248,"backdrop_path":"/tQvvRReWhrXnj28s4AIp2PblByg.jpg","original_title":"The House with a Clock in Its Walls","original_language":"en"},{"id":497984,"adult":false,"title":"Monster Hunt 2","video":false,"overview":"The sequel to Monster Hunt. Set in a world where monsters and humans co-exist, the franchise tells the story of Wuba, a baby monster born to be king. Wuba becomes the central figure in stopping an all-out monster civil war.","genre_ids":[12,35,14],"media_type":"movie","popularity":2.1437,"vote_count":142,"poster_path":"/3IxcMNvnDKDKFpLzMH73LwnbXAm.jpg","release_date":"2018-02-16","vote_average":6.6,"backdrop_path":"/gKDuRB6Uj3gzF8Dd85DOtkxi7KC.jpg","original_title":"捉妖记2","original_language":"zh"},{"id":294,"adult":false,"title":"Desert Hearts","video":false,"overview":"While waiting for her divorce papers, a repressed literature professor finds herself unexpectedly attracted by a carefree, spirited young woman named Cay.","genre_ids":[18,10749],"media_type":"movie","popularity":0.7666,"vote_count":167,"poster_path":"/klAHoWOZgL8sR74Tnl7K7z4Lziq.jpg","release_date":"1985-10-01","vote_average":7,"backdrop_path":"/naXcvWfRZ4pDHPP9xJfZ4K1MgvG.jpg","original_title":"Desert Hearts","original_language":"en"},{"id":354979,"adult":false,"title":"Dog Eat Dog","video":false,"overview":"Carved from a lifetime of experience that runs the gamut from incarceration to liberation, Dog Eat Dog is the story of three men who are all out of prison and now have the task of adapting themselves to civilian life.","genre_ids":[18,80,53],"media_type":"movie","popularity":0.8937,"vote_count":376,"poster_path":"/ve6qJRjs2OUsXLIHLson3j4eVTB.jpg","release_date":"2016-11-04","vote_average":5.13,"backdrop_path":"/eRpVvbvvO7UCA2vTGant3kq1zSc.jpg","original_title":"Dog Eat Dog","original_language":"en"}],"similar_content":[{"id":48709,"adult":false,"title":"My Man","video":false,"overview":"In Lyon, where many are unemployed, Marie is a prostitute who loves her work: she's thoughtful and exuberant toward clients old and young, slim or flabby. One night, a homeless man sleeps in the foyer of her apartment house; she gives him a hot meal, then a place on the floor to sleep by her radiator, then she offers herself. She falls in love, giving him new life, clothes, a place to live. When he grouses that he must bar hop while she uses the flat for her work, she finds them a larger flat. He grows restless, seducing a manicurist and pressing her to prostitution. He's arrested for procuring, so Marie must decide what to do; he, too, must face the consequences of his choices.","genre_ids":[10749,35,18],"popularity":0.4968,"vote_count":42,"poster_path":"/A2vNKPMD1JnsgOV0Adimhd9vIPA.jpg","release_date":"1996-01-31","vote_average":5.655,"backdrop_path":"/8mk1w1friPH3yEWrIPivk1XMIf9.jpg","original_title":"Mon homme","original_language":"fr"},{"id":48579,"adult":false,"title":"My Sister in Law","video":false,"overview":"Intransigent magistrate Viola Orlando is targeted by her rivals who set her twin sister Rosa — a high-class prostitute and pornographic photo-novel star — up to impersonate Viola and demolish her reputation. To complicate things even further, Viola is torn between enforcing the law or giving up her seat on the bench to marry her childhood friend.","genre_ids":[35],"popularity":1.6166,"vote_count":35,"poster_path":"/1C73JoBvAryD2mwA3wqdajfJb22.jpg","release_date":"1976-11-05","vote_average":5.286,"backdrop_path":"/ntsZ4FwUbbt8tXS0fJpTiV6lFnU.jpg","original_title":"La pretora","original_language":"en"},{"id":901060,"adult":false,"title":"Seven Cemeteries","video":false,"overview":"A recent parolee gets a Mexican witch to resurrect his old posse so that they can help him save a woman's ranch from a ruthless drug lord.","genre_ids":[27,28,14,53],"popularity":0.5978,"vote_count":18,"poster_path":"/jHdmMiS35fN0zLJBXNg3VHLJk9y.jpg","release_date":"2024-10-11","vote_average":4.806,"backdrop_path":"/tDOVQe5RFwd9l8Es7A0EOqzo011.jpg","original_title":"Seven Cemeteries","original_language":"en"},{"id":49010,"adult":false,"title":"Hobo with a Shotgun","video":false,"overview":"A vigilante homeless man pulls into a new city and finds himself trapped in urban chaos, a city where crime rules and where the city's crime boss reigns. Seeing an urban landscape filled with armed robbers, corrupt cops, abused prostitutes and even a pedophile Santa, the Hobo goes about bringing justice to the city the best way he knows how - with a 20-gauge shotgun. Mayhem ensues when he tries to make things better for the future generation. Street justice will indeed prevail.","genre_ids":[80,28,53],"popularity":1.1646,"vote_count":673,"poster_path":"/xxMaO7VoN2BnZit79PedVHnTjcO.jpg","release_date":"2011-05-06","vote_average":5.889,"backdrop_path":"/7ugJdVksDA4oYCxZY6tHhsG2NyV.jpg","original_title":"Hobo with a Shotgun","original_language":"en"},{"id":49049,"adult":false,"title":"Dredd","video":false,"overview":"In the future, America is a dystopian wasteland. The latest scourge is Ma-Ma, a prostitute-turned-drug pusher with a dangerous new drug and aims to take over the city. The only possibility of stopping her is an elite group of urban police called Judges, who combine the duties of judge, jury and executioner to deliver a brutal brand of swift justice. But even the top-ranking Judge, Dredd, discovers that taking down Ma-Ma isn’t as easy as it seems in this explosive adaptation of the hugely popular comic series.","genre_ids":[28,878],"popularity":6.491,"vote_count":5418,"poster_path":"/wLx65gtGVnUFCxceHWGszcruCZj.jpg","release_date":"2012-09-07","vote_average":6.857,"backdrop_path":"/jUqDBi02CDjqrroC3Zl8hroBbSr.jpg","original_title":"Dredd","original_language":"en"},{"id":313321,"adult":false,"title":"Quick, Let's Get Married","video":false,"overview":"Madame Rinaldi, owner of a bordello, helps thief Mario Forni locate an ancient buried treasure.","genre_ids":[18,35],"popularity":0.219,"vote_count":3,"poster_path":"/9ExaGGLpagSNlwhM3EiZgnZjv4v.jpg","release_date":"1964-01-01","vote_average":2.3,"backdrop_path":"/89MnTZx6O18eDfiDsIopfWvRMzB.jpg","original_title":"Quick, Let's Get Married","original_language":"en"},{"id":49114,"adult":false,"title":"$$30","video":false,"overview":"A father buys his closeted son a night with a prostitute.","genre_ids":[35,18],"popularity":0.2444,"vote_count":12,"poster_path":"/a6KNqcbdnylw7GPIKhKWu7PPIET.jpg","release_date":"1999-01-01","vote_average":6,"backdrop_path":"/eNmWipQZKx37wEVNp8jXIpd58gD.jpg","original_title":"$$30","original_language":"en"},{"id":49840,"adult":false,"title":"Takedown","video":false,"overview":"Five years ago David's life came undone when his young daughter fell victim to a brutal attack. The subsequent emotional fallout cost him his marriage and his job. Handicapped by guilt and anguish David abandoned his past and alienated himself. He took a second rate job as a security guard and plodded on - his wounds concealed but unhealed. All it would take is a scratch for them to open wide and consume him.... During a routine security inspection, David discovers a young Serbian girl stowed in the cab of a truck. Her sister and other girls have been murdered - all victims of a perfidious human trafficking racket. She pleads for his help. This is his chance at retribution. This time he will champion the young girl that places her trust in him. But David is taking on Goliath and he has his back against the wall and a gun at his head. Enlisting the help of a woman's refuge counselor, David embarks on a do or die mission to save the girl.","genre_ids":[28,53,18],"popularity":0.3487,"vote_count":17,"poster_path":"/pkGELajs0oETASbVH6aBJi1V9Bd.jpg","release_date":"2010-04-16","vote_average":4.5,"backdrop_path":"/iZcFDSfmTn9tIocg7UoI6RVuFhE.jpg","original_title":"Takedown","original_language":"en"},{"id":33076,"adult":false,"title":"Wholly Moses","video":false,"overview":"Harvey and Zoey, two tourists in Israel, discover an ancient scroll about Herschel, the man who was almost Moses. Herschel receives the command from God to free his people from slavery, but Moses keeps getting all the credit.","genre_ids":[35],"popularity":0.6988,"vote_count":37,"poster_path":"/2k9h9F9gf3YJAJojl2TzevTZaaa.jpg","release_date":"1980-06-13","vote_average":4.724,"backdrop_path":"/3sQ7jcYfzElYbw2Db1eQbeBX8sf.jpg","original_title":"Wholly Moses","original_language":"en"},{"id":36220,"adult":false,"title":"Spaceship","video":false,"overview":"A farce satirizing extraterrestrial horror movies such as Alien.  Alternate titles include \"The Creature Wasn't Nice\" and \"Naked Space\" (1999 re-release trying to capitalize on Nielsen's \"Naked Gun\" success).","genre_ids":[35,27],"popularity":0.4867,"vote_count":33,"poster_path":"/pihIOXhwXpvYPBeF8vnJqP8ROmX.jpg","release_date":"1983-07-01","vote_average":3.682,"backdrop_path":"/gFvXNjwDGgwwIViGAZiTY9p3cxv.jpg","original_title":"Spaceship","original_language":"en"},{"id":36349,"adult":false,"title":"Black Moon Rising","video":false,"overview":"An FBI free-lancer stashes a stolen Las Vegas-crime tape in a high-tech car stolen by someone else.","genre_ids":[28,878,53],"popularity":1.1945,"vote_count":160,"poster_path":"/2KNhZ3D0YkBDaO82aqWN6WxVvJS.jpg","release_date":"1986-01-10","vote_average":5.516,"backdrop_path":"/6Kx7bxFJuEeK5tZLcSoUj5b8jhU.jpg","original_title":"Black Moon Rising","original_language":"en"},{"id":36536,"adult":false,"title":"Follow That Bird","video":false,"overview":"Big Bird is sent to live far from Sesame Street by a pesky social worker, who thinks it would be better for him to live with other birds. Unhappy, Big Bird runs away from his foster home, prompting the rest of the Sesame Street gang to go on a cross-country journey to find him.","genre_ids":[10751,35,12,10402],"popularity":0.9046,"vote_count":89,"poster_path":"/kkhgC0IDWtmPYX6FxMrVGx7jJnn.jpg","release_date":"1985-08-02","vote_average":6.4,"backdrop_path":"/kO1PMdDcuZ6HEDpgH9vu8HLMl7z.jpg","original_title":"Follow That Bird","original_language":"en"},{"id":43915,"adult":false,"title":"Fathom","video":false,"overview":"While touring abroad in Europe, beautiful American skydiver Fathom Harvill gets wrapped up in international intrigue when Scottish spy Douglas Campbell recruits her to help him on a secret mission. Before long, Fathom realizes that no one around her, including the mysterious Peter Merriweather, can easily be trusted, leading to various adventures that involve bull fighting, beaches and, of course, romance.","genre_ids":[28,35,18],"popularity":0.9365,"vote_count":36,"poster_path":"/w8ere2qGBpoJ92lL6fsJ3hrYT6z.jpg","release_date":"1967-08-25","vote_average":5.9,"backdrop_path":"/bnnZQkX1KLM20dF4WO7XOJ54HHw.jpg","original_title":"Fathom","original_language":"en"},{"id":44123,"adult":false,"title":"Sam Kinison: Breaking the Rules","video":false,"overview":"This is a great performance. Through yelling and energetic story-telling, he talks about marriage, drugs, being arrested (thanks to his ex-wife), pleasing women, religion, and much, much more.","genre_ids":[35],"popularity":0.265,"vote_count":20,"poster_path":"/l4pligKABQknfKMTdpAxz3PjTJW.jpg","release_date":"1987-04-21","vote_average":7,"backdrop_path":"/hZ9dZF9OdR6hHItUAKKmNrnsDc3.jpg","original_title":"Sam Kinison: Breaking the Rules","original_language":"en"},{"id":44149,"adult":false,"title":"I Murder Seriously","video":false,"overview":"A cop sets out to find a man who has been delivering too much of a good thing in this offbeat comedy. Police detective Martinez (Jesus Ochoa) has been handed a most unusual case -- a number of local prostitutes have been murdered, and it's up to Martinez to bring in the killer. What makes the case truly unusual, though, is the manner of death; it seems the hookers all died as a result of having orgasms so powerful they were literally fatal. Teaming up with cultural anthropologist Onofre (Daniel Giménez Cacho), Martinez hits the streets looking for clues, and eventually gets some unexpected help from Father Gorkisolo (Santiago Segura), a priest with a unusually deep knowledge of sexual matters. Asesino en Serio was the first feature film from director Antonio Urrutia; noted Mexican filmmaker Guillermo del Toro served as executive producer.","genre_ids":[35,80,18],"popularity":0.659,"vote_count":30,"poster_path":"/tDFtXrxnFCxo2A0QOtaCvb2KJmZ.jpg","release_date":"2002-10-11","vote_average":5.5,"backdrop_path":"/93S2ivPgeVotuc3K6jYcg8R9Svl.jpg","original_title":"Asesino en serio","original_language":"es"},{"id":46018,"adult":false,"title":"Willie Dynamite","video":false,"overview":"Willie Dynamite is a pimp who operates in New York City. Willie was a big success as a pimp, but now, just as fast as he rose to the top, he has hit bottom. A former prostitute who has become a social worker tries to get Willie to clean up his life while it is still possible.","genre_ids":[80,18],"popularity":0.5369,"vote_count":26,"poster_path":"/lmjJ176Ff9R7cpT6TWB6T9dtRBl.jpg","release_date":"1974-01-23","vote_average":6.2,"backdrop_path":"/saTlrUSCWyrL8mMo2n4J4PqcfD6.jpg","original_title":"Willie Dynamite","original_language":"en"},{"id":46435,"adult":false,"title":"Topsy-Turvy","video":false,"overview":"For nearly a decade, Gilbert and Sullivan’s collaborations have delighted the English people. But in 1884, as a London heat wave cuts into the theater trade, their latest work, \"Princess Ida\", receives lukewarm press. In an effort to reconcile their creative differences and drawing inspiration from Japanese culture, they went on to create the hit opera \"The Mikado\", one of the duo's greatest successes.","genre_ids":[18,10402,35,36],"popularity":0.6948,"vote_count":163,"poster_path":"/oFYbpqqj5C6MXshBI1umd9qrrdY.jpg","release_date":"1999-12-15","vote_average":6.6,"backdrop_path":"/vuB822fEemGIv5CXhd05OVFiroI.jpg","original_title":"Topsy-Turvy","original_language":"en"},{"id":46743,"adult":false,"title":"Out of Bounds","video":false,"overview":"Farm boy Daryl Cage's parents ship him off to the big city to live with his brother, hoping he will have a better life there. After a baggage mixup at the airport, Daryl finds himself in possession of a drug cache, which a ruthless drug dealer wants back. The dealer murders Daryl's brother and the small town boy ends up all alone in the big city, being pursued by both the drug dealer and the police, who suspect him of the murder.","genre_ids":[18,28,80,53],"popularity":0.7654,"vote_count":29,"poster_path":"/aOp7kLTkp1UAT6LjTX5V7rlnGqs.jpg","release_date":"1986-07-25","vote_average":5.328,"backdrop_path":"/yWchXAZ6eCBSSfgh8jrky7sjvkn.jpg","original_title":"Out of Bounds","original_language":"en"},{"id":1295781,"adult":false,"title":"Triumph Presents: Let's Make a Poop Live","video":false,"overview":"Triumph the Insult Comic Dog hosts his game show \"Let's Make a Poop\" live from the Castro Theatre at SF Sketchfest.  With announcer Michael Winslow, guest panelists Weird Al Yankovic, Adam Savage, and Rob Schneider, and special appearances by Thomas Lennon, Amber Ruffin, and Dave Hill. Plus a very special tribute to Blackwolf the Dragonmaster. Recorded live on January 21, 2024.","genre_ids":[35,99],"popularity":0.1674,"vote_count":1,"poster_path":null,"release_date":"2024-05-20","vote_average":10,"backdrop_path":null,"original_title":"Triumph Presents: Let's Make a Poop Live","original_language":"en"},{"id":311368,"adult":false,"title":"On the Game","video":false,"overview":"Comic look at the history of prostitution.","genre_ids":[35],"popularity":1.8157,"vote_count":6,"poster_path":"/ppm5hV0ZeIFKPqVTc6bFxsxxTkh.jpg","release_date":"1974-02-01","vote_average":3.167,"backdrop_path":"/5yDfnk9dHzENtOWI6J3bviwy2bD.jpg","original_title":"On the Game","original_language":"en"}],"external_ids":{"imdb_id":"tt1308728","twitter_id":"happytimemovie","facebook_id":"happytimemovie","wikidata_id":"Q9086870","instagram_id":"happytimemovie","metacritic_id":"movie/the-happytime-murders","rotten_tomatoes_id":"m/the_happytime_murders_2017"},"social_ids":{"twitter":"happytimemovie","facebook":"happytimemovie","instagram":"happytimemovie"},"gdvg_id":148418,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wik