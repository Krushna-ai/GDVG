5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Ip Man\",\"description\":\"A semi-biographical account of Yip Man, the first martial arts master to teach the Chinese martial art of Wing Chun. The film focuses on events surrounding Ip that took place in the city of Foshan between the 1930s to 1940s during the Second Sino-Japanese War. Directed by Wilson Yip, the film stars Donnie Yen in the lead role, and features fight choreography by Sammo Hung.\",\"image\":\"https://image.tmdb.org/t/p/w500/zyQQ7wFuCvH6MzJcUKy6N6ouMYs.jpg\",\"datePublished\":\"2008-12-12\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"cn\",\"genre\":[\"biographical film\",\"martial arts film\",\"drama film\",\"action film\",\"historical film\",\"Drama\",\"Action\",\"History\",null,null,null,null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.8,\"bestRating\":10,\"ratingCount\":4010}}"}}],["$","$L10",null,{"initialDrama":{"id":"eb4e3c3d-e228-43d1-882f-999e6ae5658a","tmdb_id":14756,"imdb_id":"tt1220719","content_type":"movie","title":"Ip Man","original_title":"葉問","overview":"A semi-biographical account of Yip Man, the first martial arts master to teach the Chinese martial art of Wing Chun. The film focuses on events surrounding Ip that took place in the city of Foshan between the 1930s to 1940s during the Second Sino-Japanese War. Directed by Wilson Yip, the film stars Donnie Yen in the lead role, and features fight choreography by Sammo Hung.","poster_path":"/zyQQ7wFuCvH6MzJcUKy6N6ouMYs.jpg","backdrop_path":"/69QJSMkm5Hh0x9fLElZ8hjv5N4P.jpg","release_date":"2008-12-12","first_air_date":null,"status":"published","original_language":"cn","origin_country":["CN","HK"],"genres":[{"name":"biographical film"},{"name":"martial arts film"},{"name":"drama film"},{"name":"action film"},{"name":"historical film"},{"id":18,"name":"Drama"},{"id":28,"name