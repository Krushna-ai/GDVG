9:{"metadata":[["$","title","0",{"children":"Ip Man | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"A semi-biographical account of Yip Man, the first martial arts master to teach the Chinese martial art of Wing Chun. The film focuses on events surrounding Ip that took place in the city of Foshan between the 1930s to 1940s during the Second Sino-Japanese War. Directed by Wilson Yip, the film stars Donnie Yen in the lead role, and features fight choreography by Sammo Hung."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/100910/ip-man"}],["$","meta","5",{"property":"og:title","content":"Ip Man"}],["$","meta","6",{"property":"og:description","content":"A semi-biographical account of Yip Man, the first martial arts master to teach the Chinese martial art of Wing Chun. The film focuses on events surrounding Ip that took place in the city of Foshan between the 1930s to 1940s during the Second Sino-Japanese War. Directed by Wilson Yip, the film stars Donnie Yen in the lead role, and features fight choreography by Sammo Hung."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/100910/ip-man"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/zyQQ7wFuCvH6MzJcUKy6N6ouMYs.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Ip Man"}],["$","meta","12",{"name":"twitter:description","content":"A semi-biographical account of Yip Man, the first martial arts master to teach the Chinese martial art of Wing Chun. The film focuses on events surrounding Ip that took place in the city of Foshan between the 1930s to 1940s during the Second Sino-