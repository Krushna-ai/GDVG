Tx30P.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":2,"aspect_ratio":0.667,"vote_average":1.75},{"width":1000,"height":1500,"file_path":"/djHPD5qPIKT7m06xPuq4rZ3Slr4.jpg","iso_639_1":"id","iso_3166_1":"ID","vote_count":5,"aspect_ratio":0.667,"vote_average":1.434},{"width":550,"height":786,"file_path":"/mJ9ckYjN8qoM24dWA6HpWYvJ0B5.jpg","iso_639_1":"id","iso_3166_1":"ID","vote_count":3,"aspect_ratio":0.7,"vote_average":1.222},{"width":1453,"height":2048,"file_path":"/27bhzM7KzCsvc1QbJRzTKZunSUt.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":0.709,"vote_average":0.166},{"width":500,"height":750,"file_path":"/i9NITiPogXbNb6nazAqYVWd9abm.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":720,"height":1009,"file_path":"/AvJogpNRAkGJk6UDbQsLGLuHgnj.jpg","iso_639_1":"id","iso_3166_1":"ID","vote_count":0,"aspect_ratio":0.714,"vote_average":0},{"width":720,"height":1009,"file_path":"/rc9Hgx6Weooo0VFTA2LUevs4A5c.jpg","iso_639_1":"id","iso_3166_1":"ID","vote_count":0,"aspect_ratio":0.714,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/rXA03j9HBzhcmgjJetcVSjkmwQg.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":2048,"height":1152,"file_path":"/tuIywwBkbsRpjaqaikVHrKEyRGY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/rblHR0ZSZ6Jy5lPSjquc6cEP48L.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3838,"height":2160,"file_path":"/aoI4kb5Mp57xpXohY3atpYYuSwS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0}]},"enriched_at":"2026-04-21T08:37:43.471+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":98,"tagline":"","homepage":"","overview":"A toy manufacturer and his wife are terrorized by a demon after their orphaned niece tries to call her late mother's spirit."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Maira vive feliz com Aiden um fabricante de bonecas e dono de uma empresa de brinquedos, mas Vanya, sua filha adotiva e sobrinha de Aiden, ainda está lidando com a perda de sua mãe biológica. Depois que Vanya toca o Lápis de Charlie para invocar sua falecida mãe, coisas estranhas começam a acontecer. Maira é aterrorizada pela boneca Sabrina. O que está acontecendo com a boneca e o que ela quer?"},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"鬼娃萨布丽娜","runtime":0,"tagline":"","homepage":"","overview":"故事讲述一个玩具制造商和太太对侄女视如己出，这名孤儿却欲试着用诡异的仪式召唤死去的妈妈的灵魂，这对夫妻被恶魔吓得魂飞魄散。这邪恶的鬼魂铁了心要复仇，急需一个寄宿的身体，没有人能躲过被附身的危险，就连小孩玩的玩具都不例外。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Une poupée diabolique se met à terroriser un fabricant de jouets et sa femme quand leur nièce tente d'invoquer sa mère défunte dans un rituel à glacer le sang."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":113,"tagline":"","homepage":"","overview":"Maira vive feliz con Aiden, un fabricante de muñecas y dueño de una compañía de juguetes. Pero Vanya, su hija adoptiva y sobrina de Aiden, todavía está lidiando con la pérdida de su madre biológica. Después de que Vanya realiza un juego para llamar a su difunta madre, comienzan a suceder cosas extrañas. Maira está aterrorizada por la muñeca Sabrina. ¿Qué está pasando con la muñeca y qué es lo que quiere?"},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"MAIRA hidup bahagia di pernikahan barunya bersama AIDEN, pembuat boneka Sabrina. Tapi kebahagiaan mereka belum sempurna karena VANYA, anak angkat sekaligus keponakan Aiden yang yang piatu belum bisa menerima kehadiran Maira sebagai ibunya karena Vanya masih belum bisa merelakan kepergian ANDINI, bundanya yang sudah meninggal. Suatu hari, Vanya melakukan permainan ‘Pensil Charlie’ untuk memanggil bundanya dan kejanggalan-kejanggalan pun mulai terjadi. Maira dan Aiden Adak percaya, hingga akhirnya Maira mengalami serentetan kejadian menakutkan dan mereka melihat sendiri sosok Andini. Maira pun memanggil BU LARAS, seorang paranormal yang dulu pernah membantunya. Tapi Andini ternyata bukanlah Andini, melainkan iblis keji bernama BAGHIAH yang menetap di boneka Sabrina dan menginginkan tubuh manusia"},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"鬼娃娃不聽話","runtime":113,"tagline":"","homepage":"","overview":"成了孤兒的姪女想喚出亡母的靈魂，害得玩具製造商夫妻被惡魔嚇得魂飛魄散。本片為「魔娃」系列第三部作品。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":113,"tagline":"","homepage":"","overview":"Maira is gelukkig en woont samen met Aiden, een poppenmaker en eigenaar van een speelgoedwinkel. Vanya, hun geadopteerde dochter, probeert nog steeds om te gaan met het verlies van haar biologische moeder. Wanneer Vanya het spel Charlie's Pencil speelt in de hoop haar overleden moeder te kunnen oproepen, beginnen er vreemde dingen te gebeuren. Zo wordt Maira geterroriseerd door Sabrina de pop. Het is echter niet duidelijk wat er precies met Sabrina aan de hand is of wat zij nu eigenlijk wil."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":113,"tagline":"","homepage":"","overview":"Spielzeugmacher Aiden (Christian Sugiono) und seine Ehefrau Maira (Luna Maya) werden von einer teuflischen Puppe terrorisiert. Vanya (Richelle Georgette Skornicki), Aidens Nichte und das Adoptivkind der beiden wollte seine leibliche Mutter mit einem primitiven Ritual von den Toten auferstehen lassen, erweckte jedoch einen bösen Geist."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Η Maira ζει ευτυχισμένη με τον Aiden, έναν κατασκευαστή κουκλών και ιδιοκτήτη μιας εταιρίας παιχνιδιών. Όμως η Vanya, η υιοθετημένη τους κόρη και ανιψιά του Aiden, εξακολουθεί να προσπαθεί να διαχειριστεί την απώλεια της βιολογικής της μητέρας. (tainiesonline.top)Όταν η Vanya αρχίζει να παίζει με ένα παιχνίδι για να \"καλέσει\" τη μητέρα της, παράξενα πράγματα αρχίζουν να συμβαίνουν."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"인형의 저주","runtime":0,"tagline":"","homepage":"","overview":"Maira는 인형 제작자이자 장난감 회사 주인 인 Aiden과 행복하게 살고 있습니다. 그러나 입양 된 딸이자 에이든의 조카딸 인 반야 (Vanya)는 여전히 그녀의 출생 어머니의 상실을 다루고있다. Vanya가 그녀의 늦은 엄마를 소환하기 위해 Charlie 's Pencil을 연기 한 후에, 이상한 일들이 일어나기 시작합니다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":113,"tagline":"","homepage":"","overview":"Maira žije šťastně s Aidenem, výrobcem panenek a majitelem hračkářské společnosti. Vanya, jejich adoptivní dcera a Aidenova neteř, se však stále potýká se ztrátou své matky. Poté, co jejich osamocená neteř  Vanya začne hrát hru Charlieho tužka, aby vyvolala svou zesnulou matku, se začnou dít divné věci. Aiden a Maira začnou být terorizováni panenkou Sabrina. Co se děje s panenkou a co chce?"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Sabrina","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Búp Bê Ma Sabrina","runtime":0,"tagline":"","homepage":"","overview":"Một nhà sản xuất đồ chơi và vợ đã bị một con quỷ tấn công sau khi bé gái mồ côi họ nhận nuôi gọi hồn người mẹ đã mất. Đây là bộ phim thứ ba trong loạt \"Búp bê ma\"."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"}],"reviews_tmdb":[],"recommendations":[{"id":416497,"adult":false,"title":"The Doll","video":false,"overview":"Anya and Daniel just moved to their new house in Bandung. Daniel brings home a doll from his workplace. Anya, who is a dollmaker, welcomes the doll happily to their house. They later learned that the doll belonged to a little girl named Uci, who died when she and her family were brutally murdered in a robbery. Strange things begin to happen.....","genre_ids":[53,27],"media_type":"movie","popularity":0.5382,"vote_count":56,"poster_path":"/AvbE67kjH7aeXKMTCdULIfw6U28.jpg","release_date":"2016-10-27","vote_average":5.2,"backdrop_path":"/hZfGXpg59vCpaUlFe3psQAmXsvw.jpg","original_title":"The Doll","original_language":"id"},{"id":460578,"adult":false,"title":"The Doll 2","video":false,"overview":"A mother uses her deceased daughter's doll as a medium to communicate with her, but the consequences are chilling.","genre_ids":[27,53],"media_type":"movie","popularity":0.3306,"vote_count":46,"poster_path":"/y10Ll8lFOIZNIVxvraVirT1GMT5.jpg","release_date":"2017-07-20","vote_average":5.3,"backdrop_path":"/cRlJaee0mUyaDwGOXrLvTOWPkDH.jpg","original_title":"The Doll 2","original_language":"id"},{"id":618225,"adult":false,"title":"White on White","video":false,"overview":"In the prelude of the twentieth century, Pedro arrives in Tierra del Fuego, an hostile and violent territory, to immortalise the marriage of a powerful landowner. Fascinated by the beauty of the bride-to-be, he betrays the rules and is left to face the land, crawling with violence and marked by the genocide of the land indigenous.","genre_ids":[18],"media_type":"movie","popularity":0.1537,"vote_count":25,"poster_path":"/rDm84pyplHIa9p9sEwg2zKK3TQP.jpg","release_date":"2020-07-31","vote_average":6.02,"backdrop_path":"/4BArwnYeYaut6Y6jgri02A9jFcm.jpg","original_title":"Blanco en blanco","original_language":"es"},{"id":811134,"adult":false,"title":"Calls","video":false,"overview":"Lucie is in NYC. Her boyfriend Tom is in Paris. We found their phone calls a couple of hours before the disaster.","genre_ids":[27],"media_type":"movie","popularity":0.3416,"vote_count":3,"poster_path":"/2LumZ2airqqQ26bcifqQ2BKgrlj.jpg","release_date":"2016-12-12","vote_average":9.3,"backdrop_path":null,"original_title":"Calls","original_language":"fr"},{"id":612390,"adult":false,"title":"The Naked Truth","video":false,"overview":"Amal, a tour guide in Cairo, doesn’t want to get married after witnessing her mother’s divorce, and has decided that all men are no good. With high hopes, she goes to visit the Aswan High Dam where a tourism delegation is. In a chance encounter, she meets civil engineer Ahmed, who intervenes in time to save her life after a near freak accident. After this, Amal must decide what she will do with her life: whether she will return to Cairo and whether to continue graduate studies in America.","genre_ids":[18,10749],"media_type":"movie","popularity":0.1409,"vote_count":1,"poster_path":"/pcdcZUOm8lruw5YeWz2cTzQ6SDh.jpg","release_date":"1963-12-16","vote_average":8,"backdrop_path":null,"original_title":"الحقيقة العارية","original_language":"ar"},{"id":429742,"adult":false,"title":"Still/Born","video":false,"overview":"Still/Born follows Mary, a new mother who lost one of her twins in childbirth. As she struggles with the loss of one of her children, she starts to suspect something sinister is after her surviving child – a supernatural entity that has chosen her child and will stop at nothing to take it from her.","genre_ids":[27],"media_type":"movie","popularity":0.8053,"vote_count":158,"poster_path":"/kZ1BbnMArbnSISel8dK9mpRwWIB.jpg","release_date":"2018-02-09","vote_average":5.8,"backdrop_path":"/nvxj7TwfyY9j2AnQDaNkLawaHAn.jpg","original_title":"Still/Born","original_language":"en"},{"id":40127,"adult":false,"title":"Art of the Devil","video":false,"overview":"When Boom suffers abandonment and abuse by Prathan, she decides to use black magic to take revenge on him and his family.","genre_ids":[27],"media_type":"movie","popularity":1.0146,"vote_count":108,"poster_path":"/rxLlAzwihpsUQQXAbNVmKg2peBZ.jpg","release_date":"2004-06-17","vote_average":6.5,"backdrop_path":"/tlVhygnHZIUcvMJnjRT7JZq0NqH.jpg","original_title":"คนเล่นของ","original_language":"th"},{"id":391626,"adult":false,"title":"The Offering","video":false,"overview":"When young and successful reporter Jamie finds out that her sister has died in mysterious circumstances, she travels to Singapore to uncover the truth. There, she discovers multiple deaths linked to her sister's and must join forces with her sister's husband in order to defeat a demonic entity that is using new technology to complete an ancient mission.","genre_ids":[9648,53,27],"media_type":"movie","popularity":0.2443,"vote_count":128,"poster_path":"/h4uMM1wOhzGpP5GNphloNEHT0jz.jpg","release_date":"2016-05-06","vote_average":5.2,"backdrop_path":"/oSyudhN5SYCLnNMfwEDKlbXZmsF.jpg","original_title":"The Offering","original_language":"en"},{"id":834742,"adult":false,"title":"First Love","video":false,"overview":"A young man’s difficult entry into adulthood, who experiences the highs and lows of his first love, while dealing with the familial fallout spurred by the financial crisis of 2008.","genre_ids":[10749,18],"media_type":"movie","popularity":1.2823,"vote_count":145,"poster_path":"/hqwSUWQcnd1cxpc6Gdx1X3t5v2O.jpg","release_date":"2022-06-17","vote_average":5.693,"backdrop_path":"/3PIF0u6ulHX9Se0DED4TCGXG4U2.jpg","original_title":"First Love","original_language":"en"},{"id":42968,"adult":false,"title":"The Nun","video":false,"overview":"Years ago, a cruel and merciless nun turned a boarding school into a living hell for her students until they could no longer bear the abuse, and she mysteriously disappeared. Now the alumnae are being brutally murdered one by one.","genre_ids":[27,9648],"media_type":"movie","popularity":2.2295,"vote_count":265,"poster_path":"/2bDojliSLzGFwxlqQZodJAXHy7H.jpg","release_date":"2005-11-03","vote_average":5.6,"backdrop_path":"/xh1Xjiu7Q0ORz3DbJjlwfC2KwVM.jpg","original_title":"La monja","original_language":"es"},{"id":1019836,"adult":false,"title":"Christmas Bloody Christmas","video":false,"overview":"It's Christmas Eve and Tori just wants to get drunk and party, but when a robotic Santa Claus at a nearby toy store goes haywire and begins a rampant killing spree through her small town, she's forced into a battle for survival.","genre_ids":[27],"media_type":"movie","popularity":0.5218,"vote_count":235,"poster_path":"/60Dy8eA5QyUHKHBmojXUtZxWdo8.jpg","release_date":"2022-12-09","vote_average":5.4,"backdrop_path":"/evxXVJtomJJbAXcDxF6wsCJzVDe.jpg","original_title":"Christmas Bloody Christmas","original_language":"en"},{"id":508138,"adult":false,"title":"Burn","video":false,"overview":"Lonely, unstable gas station attendant Melinda is tired of being overshadowed by her more confident, outgoing co-worker Sheila. When the gas station is held up at gunpoint by Billy, a desperate man in need of quick cash, Melinda finds an opportunity to make a connection with the robber, regardless of who gets hurt.","genre_ids":[53,80,28],"media_type":"movie","popularity":2.9117,"vote_count":332,"poster_path":"/ifSMo5x7SDXpettRt8TWY9EOquM.jpg","release_date":"2019-08-23","vote_average":6.029,"backdrop_path":"/3C14xx4RteMksSUwgYfI52B8Iu6.jpg","original_title":"Burn","original_language":"en"},{"id":481375,"adult":false,"title":"Malevolent","video":false,"overview":"A brother-sister team who fake paranormal encounters for cash get more than they bargained for when a job at a haunted estate turns very, very real.","genre_ids":[27],"media_type":"movie","popularity":0.9068,"vote_count":540,"poster_path":"/gbq5yQTQ1AfcBQb0y4ozUPTzd8Y.jpg","release_date":"2018-12-13","vote_average":5.006,"backdrop_path":"/i2PQLKOun5HzRMuGEG6tzeBIcbF.jpg","original_title":"Malevolent","original_language":"en"},{"id":576004,"adult":false,"t