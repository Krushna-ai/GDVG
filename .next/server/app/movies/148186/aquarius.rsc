_1":"US","vote_count":3,"aspect_ratio":0.667,"vote_average":0.166},{"width":1600,"height":2199,"file_path":"/1nS9PWcguLWD2GIFn1MR49CqKwt.jpg","iso_639_1":"da","iso_3166_1":"DK","vote_count":1,"aspect_ratio":0.728,"vote_average":0.166},{"width":2000,"height":3000,"file_path":"/zvP4zq8kURF2lJ3rzUXBT8tndXU.jpg","iso_639_1":"sv","iso_3166_1":"SE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":795,"height":1080,"file_path":"/wTkwe0eEC7ksPQIOUdH0GisllSn.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.736,"vote_average":0},{"width":600,"height":893,"file_path":"/GfkQl3qtuSaZMW2VMXcNsIKmBz.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":0.672,"vote_average":0},{"width":583,"height":834,"file_path":"/g5zwFeUceuq2tHtelfyoFYUk5B5.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.699,"vote_average":0},{"width":1000,"height":1500,"file_path":"/jD5J127tAHUbeq4wMHtEzhJ9lnE.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/veZzmysk4x3clDOsXiAADWVjL40.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/bIINh478rsL4UfURkITUwCIaEcj.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3000,"height":1688,"file_path":"/nB43fedXBzwx7Xv8OWKjfaMzpQF.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.777,"vote_average":2.278},{"width":3840,"height":2160,"file_path":"/wCDvBzr4rcrhTWlb0ytOKIpycUN.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":2.278},{"width":3840,"height":2160,"file_path":"/bnh8lN4Z5I0tfVFnsWZLX0Tpvz5.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/k4pTGNgkoyFIvc69AQf2NnzYzcy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/2vNh3qltTVwD86Bqm5eYiszbHGh.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1422,"height":800,"file_path":"/dd1EBZnDGF0JaGtQKTPAhRyJfLN.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1602,"height":901,"file_path":"/r2QP9oNrSwBYaVHVxrcShNvPzvt.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/hPKMxi1XkPFZWv6w2oyPhdoNqBh.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/9AvbxYlK5Xatkdj6zB0GUFNgky8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/fKEnk8udcZhTPbiKMC4BTnLUyQY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/gzdFEViDmNG0K6iVOgb6z1m23qb.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/sB5bG3KstHjBAV4RFxbta15yXLD.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/2YyC0Rl65pLquGQQ7gZyNd5b9y.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/x7SnSIj4nqOAUwfh75cO1IPzL3E.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:45:48.623+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":147,"tagline":"","homepage":"","overview":"Clara, a vibrant former music critic and widow with flowing tresses is the only remaining apartment owner in a beautiful older building targeted for demolition by ruthless luxury high-rise developers. Clara proves to be a force to be reckoned with as she thwarts the builders plans to kick her out of the apartment."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":145,"tagline":"Hoje carrego no meu corpo as marcas do tempo, do meu desespero.","homepage":"","overview":"Clara mora de frente para o mar no Aquarius, último prédio de estilo antigo da Av. Boa Viagem, no Recife. Jornalista aposentada e escritora, viúva com três filhos adultos e dona de um aconchegante apartamento repleto de discos e livros, ela irá enfrentar as investidas de uma construtora que tem outros planos para aquele terreno: demolir o Aquarius e dar lugar a um novo empreendimento."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":145,"tagline":"","homepage":"","overview":"Šedesátiletá, stále krásná Clara se odmítá odstěhovat z domu Aquarius, přestože už v něm zůstala sama. Marně jí investor, chystající se dům zbourat, nabízí odstupné, marně jí ztrpčuje život. Clara se umí bránit každému nátlaku. Někdejší hvězda Latinské Ameriky Sonia Bragaová našla v postavě Clary velkou dramatickou roli. Novinka tvůrce snímku Zvuky od sousedů soutěžila letos v Cannes o Zlatou palmu. (51st KVIFF)"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":144,"tagline":"","homepage":"","overview":"Clara, la soixantaine, ancienne critique musicale, est née dans un milieu bourgeois de Recife, au Brésil. Elle vit dans un immeuble singulier, l'Aquarius construit dans les années 1940, sur la très huppée Avenida Boa Viagem qui longe l’océan. Un important promoteur a racheté tous les autres appartements mais elle, se refuse à vendre le sien. Elle va rentrer en guerre froide avec la société immobilière qui la harcèle. Très perturbée par cette tension, elle repense à sa vie, son passé, ceux qu’elle aime."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Aquarius","runtime":0,"tagline":"Uma metáfora do Brasil","homepage":"","overview":"Clara, uma viúva de 65 anos e crítica musical aposentada, nasceu numa família rica e tradicional de Recife. Ela é a última moradora do Aquarius, um prédio de dois andares construído nos anos 1940 que fica na orla da Avenida Boa Viagem, numa região de classe alta do Recife. Os apartamentos vizinhos foram todos comprados por uma empresa que tem outros planos para aquele lugar. Clara jurou sair de seu apartamento só depois que morrer, e vai travar uma espécie de guerra fria com a empresa. Essa tensão perturba Clara, ao mesmo tempo que a motiva na rotina diária. Isso também a faz pensar nas pessoas que ela ama, no passado e no seu futuro."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":142,"tagline":"","homepage":"","overview":"La sessantacinquenne Clara è una scrittrice e critica di musica oramai in pensione. Vedova, è madre di tre figli adulti e vive in un appartamento pieno di libri e dischi nel quartiere di Boa Viagem, in un originale edificio chiamato Aquarius e costruito negli anni Quaranta. Tutti gli appartamenti limitrofi sono stati acquistati da una società ma Clara si è impegnata a lasciare la sua residenza solo nel momento della morte. La tensione che si crea finisce con il disturbare Clara e la sua esistenza quotidiana, fatta di ricordi dei suoi cari e di pensieri sul passato e sul futuro."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"水瓶座","runtime":0,"tagline":"","homepage":"","overview":"克拉拉，一位65岁的寡妇、退休音乐评论家，出生于巴西累西腓一个富裕的传统家庭。她是“水瓶座”公寓楼的最后一位住户——这栋建于上世纪40年代的两层老建筑，坐落于累西腓博阿维斯塔大道的高档海滨区。周围所有公寓已被一家公司收购，该公司对该地块另有规划。克拉拉立誓至死才愿搬离此处，由此与公司展开了一场无声的冷战。这场对峙既困扰着她，也为她的日常生活注入了抗争的锋芒，同时也促使她不断追忆所爱之人、回首过往，并思索自己的未来。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Doña Clara","runtime":140,"tagline":"","homepage":"","overview":"Clara, una ex-crítica musical de Recife de 65 años, vive retirada en un edificio particular, el Aquarius, construido en la década de 1940 sobre la chic Avenida Boa Viagem, que bordea el océano. Un importante promotor ha comprado todos los apartamentos, pero ella se niega a vender el suyo y emprende una guerra fría contra la empresa que la acosa. La estresante situación le perturba y le lleva a pensar en su vida, en su pasado, en sus seres queridos."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"65 yaşındaki Clara, Brezilya’nın Recife şehrinde zengin ve köklü bir ailenin üyesi olarak dünyaya gelmiş olan emekli bir müzik eleştirmenidir. Üst sınıf insanların yaşadığı deniz kenarındaki Boa Viagem Avenue’da 1940’larda ilk olarak iki katlı bir bina olarak inşa edilen Aquarius’ın son sakinidir. O bölgeyi başka planları için kullanmak isteyen bir şirket, etraftaki tüm apartmanları satın almış durumdadır. Clara ise, ancak ölümüyle terkedeceğini söylediği evinden çıkmayı reddeder ve şirket ile arasında soğuk bir savaş başlar. Bu gerilim Clara’yı rahatsız etmekle birlikte günlük hayatını da etkiler. Bütün bunlar ona sevdiklerini, geçmişini ve geleceğini düşündürtecektir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":137,"tagline":"","homepage":"","overview":"Clara ist eine 65-jährige Frau, die voller Wissen steckt, als Literatur- und Musikkritikerin arbeitet und die Mutter dreier inzwischen erwachsener Kinder ist. Sie hängt an ihrer etwas baufälligen Wohnung, in der sie seit Jahrzehnten lebt. Als eine Baufirma die Wohnungen des Blocks aufkauft, ist sie die letzte Eigentümerin, die sich weigert zu verkaufen, trotz durchaus lukrativen Angeboten. Daraufhin greift die Baufirma zu dubiosen Methoden. Doch sie haben die resolute Clara unterschätzt."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":146,"tagline":"","homepage":"http://www.sevenfilms.gr/movies/aquarius","overview":"Η Κλάρα, μια 65χρονη χήρα και συνταξιούχος κριτικός μουσικής, κατάγεται από μια πλούσια οικογένεια της Βραζιλίας. Είναι η τελευταία κάτοικος του Aquarius, ενός ιστορικού κτιρίου που χτίστηκε τη δεκαετία του ’40 στο παραθαλάσσιο Ρεσίφε. Όλα τα γειτονικά κτίσματα έχουν ήδη πουληθεί σε μια πολυεθνική που έχει άλλα σχέδια για την περιοχή. Η Κλάρα έχει ορκιστεί ότι θα αφήσει το σπίτι της μόνο αν πεθάνει. Η Κλάρα έχει επίσης το δώρο του ταξιδιού στον χρόνο, μια υπερδύναμη που λίγοι άνθρωποι στον κόσμο είναι σε θέση να αναπτύξουν."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Clara er en 65-årig pensioneret musikkritiker og enke. Hun er også den sidste lejlighedsindehaver i Aquarius, et lejlighedskompleks fra 1940-tallet i overklassens smukke strandresidenser i Recife.  Resten af naboerne er lokket til at flytte af nye bygherrer, der har store planer om byfornyelse. Men Clara lader sig ikke snøre. Hun har boet der i en menneskealder, opfostret sine børn dér og nægter at flytte, så hun lægger sig ud med både de nye entreprenører og sine voksne børn, der ikke kan forstå hendes beslutning.  Clara er stædig og tager kampen op imod det korrupte byggeselskab. Det giver hende ekstra kulør på hverdagen og får hende til at tænke tilbage på sit liv, sin kærlighed og musikken."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Акуариус","runtime":142,"tagline":"","homepage":"","overview":"Клара е пенсиониран журналист и писател, вдовица и майка на три деца. Тя е последният жител на \"Акуариус\" (Водолей), оригинален комплекс в крайбрежния квартал на Ресифе, където Клара е отгледала децата си; там е минал почти целият й живот. Компанията Бонфим, представлявана от младия Диего, иска да построи на мястото голяма модерна сграда. Клара категорично отказва да продаде апартамента и влиза в студена война с предприемача, който опитва да я принуди с всички средства. Сблъсъкът е плашещ, напрегнат и дава нова енергия за ежедневието й."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Emerytowana Clara jest ostatnią rezydentką willi Aquarius. Rozpoczyna walkę ze spółką, która ma inne plany zagospodarowania tego terenu."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Водолей","runtime":142,"tagline":"","homepage":"","overview":"Портрет несгибаемой и гордой женщины — стареющей вдовы Клары, чья судьба прочно связана с домом, откуда теперь ее пытаются выдворить. Любезность и щедрость меркантильного скупщика сменяется угрозами и откровенными кознями, но на счету у Клары есть победы и в более безнадежных войнах."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":146,"tagline":"","homepage":"","overview":"Clara, een bejaarde weduwe en gepensioneerde muziekcriticus, woont in Aquarius, een origineel twee verdiepingen tellend appartementengebouw uit de jaren 1940 in Recife in Brazilië."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Водолій","runtime":0,"tagline":"","homepage":"","overview":"Портрет незламної і гордої жінки - старіючої вдови Клари, чия доля міцно пов'язана з будинком, звідки тепер її намагаються видворити. Люб'язність і щедрість меркантильного скупника змінюється погрозами і відвертими підступами, але на рахунку у Клари є перемоги і в більш безнадійних війнах."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"","runtime":142,"tagline":"","homepage":"","overview":"Clara är en 65-årig pensionerad musikkritiker och änka, men också den sista lägenhetsinnehavaren i Aquarius, ett tvåvåningskomplex från 1940-talet i överklassens vackra strandresidenser i Recife. Alla hennes grannar har tvingats sälja sina boenden till ett företag som har byggplaner för området. Men Clara har bestämt sig för att hon hellre dör än ger upp sin lägenhet, vilket leder henne till ett stilla krig med företaget. Deras kamp ger henne dock lite färg i vardagen och får henne att tänka tillbaka på sitt liv, sin kärlek och musiken."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"아쿠아리우스","runtime":0,"tagline":"","homepage":"","overview":"노년의 클라라에게 평생을 살아온 오래된 건물 아쿠아리우스는 집 이상의 의미가 있다. 재개발을 앞두고 건설사의 회유와 이웃들의 불만이 쏟아지지만 그녀는 퇴거를 거부하고, 곧 그녀의 일상에는 의문의 위협이 찾아드는데… 집단이기주의에 맞서 싸우는 쏘냐 브래거의 열연이 돋보인다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"水瓶女人心","runtime":0,"tagline":"巴西導演克雷伯曼東沙費侯執導的新劇情片，入選2016年坎城影展競賽片。以家鄉為創作環境，描述巴西古城累西腓的美麗海灘旁，一幢名為水瓶座老公寓面臨都更的故事。","homepage":"","overview":"《鄰居的狗吠聲》克雷伯曼東沙費侯執導新片，巴西知名女演員索尼婭布拉加主演。  費侯以家鄉為創作環境，描述巴西古城累西腓的美麗海灘旁，一幢名為水瓶座的老公寓即將都更，住戶們幾乎都已搬離，只剩下一位六十幾歲的婦人，守著她充滿記憶的房子，獨自對抗不義的建商。  以《蜘蛛女之吻》中謎樣女子而聞名影壇的索妮亞布拉加，氣場強大的表演魅力成為整部電影的靈魂，也在坎城獲得壓倒性的讚譽，是繼《中央車站》後又一成功的巴西女性角色。  劇組也成為紅地毯上最出風頭的焦點，因為費侯率領演員舉牌抗議巴西的社會不公，從民主倒退、分配不義等問題，讓電影寓意走出銀幕，向國際社會發聲。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"}],"reviews_tmdb":[{"id":"59fe1d56c3a3686853025031","url":"https://www.themoviedb.org/review/59fe1d56c3a3686853025031","author":"Reno","content":"$11","created_at":"2017-11-04T20:04:38.522Z","updated_at":"2024-05-16T15:18:37.078Z","author_details":{"name":"Reno","rating":7,"username":"Rangan","avatar_path":"/6ZpVUJzqXMzH35VprEtnX0sNI3.jpg"}}],"recommendations":[{"id":97989,"adult":false,"title":"Neighboring Sounds","video":false,"overview":"An independent private security firm arrives at a middle-class neighborhood in Recife, Brazil.","genre_ids":[53,18,80],"media_type":"movie","popularity":0.408,"vote_count":237,"poster_path":"/gX5bvUtJZaBjWwq8lSwGOIJN5jM.jpg","release_date":"2012-11-19","vote_average":7.1,"backdrop_path":"/xJQsDKD6ZfQ9nJGtuKB4N878REq.jpg","original_title":"O Som ao Redor","original_language":"pt"},{"id":407201,"adult":false,"title":"Ceasefire","video":false,"overview":"In the early 1920s, Georges Laffont, traumatized by the horrific trench warfare, decides to leave his life behind and travel to West Africa. In the vast territories of Upper Volta he - with the help of Diofo, artist and also survivor of the Great War - try to recruit the villagers as labor for plantations in Ghana. But his adventure leads him to a dead-end, and he comes back to Paris desperate to find his place in the world.","genre_ids":[18],"media_type":"movie","popularity":0.2085,"vote_count":51,"poster_path":"/fZW5XxyoWS03gEguz3dENEJWijk.jpg","release_date":"2017-04-19","vote_average":6.186,"backdrop_path":"/9W6QGlWLUUaJldhFdg0GRCO8e3c.jpg","original_title":"Cessez-le-feu","original_language":"fr"},{"id":42167,"adult":false,"title":"Bye Bye Brazil","video":false,"overview":"The Caravana Rolidei rolls into town with the Gypsy Lord at the mike: he does magic tricks, the erotic Salomé dances, and the mute Swallow performs feats of strength. A young accordion player is completely enamored of Salomé, and he begs to come along. The Gypsy Lord shrugs, and the accordionist and his pregnant wife, Dasdô, join the troupe.","genre_ids":[18],"media_type":"movie","popularity":0.2956,"vote_count":56,"poster_path":"/sRzzduxIr4FKKZGTg3dtjwNi2YT.jpg","release_date":"1980-02-08","vote_average":6.875,"backdrop_path":"/1LvhLEd6lHg7wQth03qIn731nE6.jpg","original_title":"Bye Bye Brasil","original_language":"pt"},{"id":393520,"adult":false,"title":"Mimosas","video":false,"overview":"A dying Sheikh travels across the Moroccan Atlas in a caravan escorted by two rogues.","genre_ids":[18,12,37],"media_type":"movie","popularity":0.3636,"vote_count":33,"poster_path":"/8u8ahh3VzpBVlNsPqlkHHkH9oZ5.jpg","release_date":"2016-08-24","vote_average":6.1,"backdrop_path":"/upO4ci3ajeGnBfeKwJOifLjC1qE.jpg","original_title":"ميموزا","original_language":"ar"},{"id":34084,"adult":false,"title":"I Bury the Living","video":false,"overview":"The new manager of a small-town cemetery becomes convinced that he triggered the untimely deaths of several plot owners by tampering with a certain map. When nobody believes him, he risks his sanity to play God once again and prove his point.","genre_ids":[9648,27],"media_type":"movie","popularity":0.6746,"vote_count":71,"poster_path":"/3qBNVDbdXNRsexZ5mLvMcvItayH.jpg","release_date":"1958-07-01","vote_average":6.113,"backdrop_path":"/nlkH0ogQMrc6U1hSihmkcGcWTDt.jpg","original_title":"I Bury the Living","original_language":"en"},{"id":132041,"adult":false,"title":"Alyonka","video":false,"overview":"Set in 1955 when many migrated from Russia to the Steppes of Kazakhstan, this is the trip back to the Canal from the frontier and farms by a number of people who tell their settler stories. Alenka Muratova (Ovodova) is a winsome 13 year old who talks Dmitry Prokovich, the chief mechanic for the Soviet, into giving up his seat in the truck to a young mother with her infant daughter. Then Alenka and Dmitry share the back of the open truck with a young woman, newly graduated dentist who has not been able to find a position, Stefan, a hitchhiker with a dog who hopes his upper-class wife will return to him and the countryside, and Vasselina Petrovolka, a woman who lost one of her twin daughters in a riding accident by the river shortly after they arrived, and now is returning to tell the other twin of her sister's fate. A warm hearted look at common folks traveling in the frontier.","genre_ids":[35,18,10751],"media_type":"movie","popularity":0.3129,"vote_count":12,"poster_path":"/6r7lg6ROo7eIxaAr3WE70tL2fFF.jpg","release_date":"1962-03-22","vote_average":5.2,"backdrop_path":"/6Er0lX0jxHMwxPF67LbsG4FQTq.jpg","original_title":"Алёнка","original_language":"ru"},{"id":253282,"adult":false,"title":"She's Lost Control","video":false,"overview":"Ronah's life unravels when she starts working with a new client, Johnny.","genre_ids":[18],"media_type":"movie","popularity":0.3313,"vote_count":36,"poster_path":"/tzikHOQrR4mefWaKsDiG0vP1WsQ.jpg","release_date":"2014-02-09","vote_average":4.958,"backdrop_path":"/e6hwgvyXTBu6TcQgGrPyr1yrJDp.jpg","original_title":"She's Lost Control","original_language":"en"},{"id":977925,"adult":false,"title":"Zurück aufs Eis","video":false,"overview":"Divorced policewoman Maren and her daughter Amelie live together in Bad Tölz and are a close-knit team. Not just mother and daughter, but best friends. But then Amelie starts to study, falls head over heels in love with her fellow student Erik and moves in with him in a shared student flat in Munich. Without Amelie, Maren not only feels very alone in the apartment, but also in life. She has to realize that she has been hiding behind Amelie for the last eight years after the divorce and hasn't had a life of her own. So she slowly goes \"back on the ice\". On the uncertain, slippery and sometimes painful ice that is called \"life\".","genre_ids":[35],"media_type":"movie","popularity":0.1075,"vote_count":2,"poster_path":"/yCQgVaKc1so6ZP09Y64Iu4i1UdV.jpg","release_date":"2022-11-18","vote_average":6,"backdrop_path":"/caWew10glZ78SsFsqmkzdw6WwhR.jpg","original_title":"Zurück aufs Eis","original_language":"de"},{"id":544482,"adult":false,"title":"Yesterday There Were Strange Things in the Sky","video":false,"overview":"The daily life of a family in which countless factors are disturbing: the father is unemployed, the members need to move house, the mother is abducted, and life continues as if nothing had happened.","genre_ids":[878,18],"media_type":"movie","popularity":0.0759,"vote_count":8,"poster_path":"/uERXr9rIusxSvEPUWQXQg0HqO73.jpg","release_date":"2020-01-28","vote_average":7.5,"backdrop_path":"/keuGid6sTWg7PymsEgGP9cxMHdv.jpg","original_title":"Ontem Havia Coisas Estranhas no Céu","original_language":"pt"},{"id":767631,"adult":false,"title":"Presente de Deus","video":false,"overview":"","genre_ids":[99],"media_type":"movie","popularity":0.0071,"vote_count":1,"poster_path":"/4vbLI69jjgiT0onqKTtOEhgfJjk.jpg","release_date":"2019-10-04","vote_average":10,"backdrop_path":null,"original_title":"Presente de Deus","original_language":"pt"},{"id":686582,"adult":false,"title":"Leviatã","video":false,"overview":"","genre_ids":[],"media_type":"movie","popularity":0.053,"vote_count":1,"poster_path":"/9BiU9jLpBqRVEB7PaDTWHh9MFM8.jpg","release_date":"1999-12-02","vote_average":10,"backdrop_path":null,"original_title":"Leviatã","original_language":"pt"},{"id":295973,"adult":false,"title":"Still the Enemy Within","video":false,"overview":"A documentary about the 1984 Miner's Strike which changed Britain forever.","genre_ids":[99],"media_type":"movie","popularity":0.0256,"vote_count":5,"poster_path":"/doFOYLTxiSoTALJbuXm4PTWu3Jr.jpg","release_date":"2014-10-04","vote_average":6.9,"backdrop_path":null,"original_title":"Still the Enemy Within","original_language":"en"},{"id":263017,"adult":false,"title":"Tie and Red Nail","video":false,"overview":"Several characters realize their personal way to build their own identity from the choice of genre. Transsexual, transgender, crossdressing – the defining of terminologies different ways of looking at yourself are constantly rising, portraying a universe of possibilities, expanding the boundaries of the possible and permitted.","genre_ids":[99],"media_type":"movie","popularity":0.0853,"vote_count":5,"poster_path":"/roRAFWkoAQ7usFyhHwFpO3m0Qhv.jpg","release_date":"2014-03-01","vote_average":7.4,"backdrop_path":"/blIbBXeGcrXk9vTx7AwKHternrh.jpg","original_title":"De Gravata e Unha Vermelha","original_language":"pt"},{"id":79956,"adult":false,"title":"Nonfilm","video":false,"overview":"A young actor suddenly wakes up in the middle of the shooting of a movie he doesn't understand.","genre_ids":[35],"media_type":"movie","popularity":0.5217,"vote_count":65,"poster_path":"/aKuGXFAbMQh69cBqAEaJITKVZ4T.jpg","release_date":"2002-05-06","vote_average":5.8,"backdrop_path":"/mN3f3KQBvDbP6POapqYingPuhC9.jpg","original_title":"Nonfilm","original_language":"fr"},{"id":647495,"adult":false,"title":"Death Doesn't Exist, and Love Doesn't Either","video":false,"overview":"Emilia is a young psychiatrist living in Buenos Aires with her boyfriend. She has a steady life but is not fully satisfied. She receives an invitation to go back to her hometown in Patagonia to spread Andrea's ashes, Emilia's best friend who died five years earlier.","genre_ids":[18],"media_type":"movie","popularity":0.1398,"vote_count":32,"poster_path":"/nuSxuQl5akLr94TzqAb8Uw28F5E.jpg","release_date":"2020-01-09","vote_average":6.9,"backdrop_path":"/wnujnlmJGXMdintpVOzDPoHqPCR.jpg","original_title":"La muerte no existe y el amor tampoco","original_language":"es"},{"id":310569,"adult":false,"title":"The Second Mother","video":false,"overview":"After leaving her daughter Jessica in a small town in Pernambuco to be raised by relatives, Val spends the next 13 years working as a nanny to Fabinho in São Paulo. She has financial stability but has to live with the guilt of having not raised Jessica herself. As Fabinho’s university entrance exams approach, Jessica reappears in her life and seems to want to give her mother a second chance. However, Jessica has not been raised to be a servant and her very existence will turn Val’s routine on its head. With precision and humour, the subtle and powerful forces that keep rigid class structures in place and how the youth may just be the ones to shake it all up.","genre_ids":[18],"media_type":"movie","popularity":0.9203,"vote_count":769,"poster_path":"/u1tDQun2iJAzersd94S8P47WEOL.jpg","release_date":"2015-06-04","vote_average":8,"backdrop_path":"/9h5BsxRmxLAvASADo2VcTlTUdb0.jpg","original_title":"Que Horas Ela Volta?","original_language":"pt"},{"id":314029,"adult":false,"title":"Neon Bull","video":false,"overview":"Iremar works at the rodeo in North East of Brazil. From his home, the truck he uses to transport the animals, he dreams of a future in the region's booming clothing industry.","genre_ids":[18],"media_type":"movie","popularity":0.4265,"vote_count":101,"poster_path":"/5UZOBQBxofQguD2jGgHxvZjqiLI.jpg","release_date":"2016-01-14","vote_average":6.718,"backdrop_path":"/ldVlc16CVgreuzuv236HRMbmI2.jpg","original_title":"Boi Neon","original_language":"pt"},{"id":17614,"adult":false,"title":"Yossi & Jagger","video":false,"overview":"A sociological study of two men in the Israeli army who are lovers. The others in the unit react to their situation, suspecting, but not always understanding. One will leave the military soon, a few months away, as a snowy and desolate outpost is guarded from attack.","genre_ids":[10752,18,10749],"media_type":"movie","popularity":0.4342,"vote_count":99,"poster_path":"/iAaoY66dkJiZftsj3bmbWLeNgRt.jpg","release_date":"2002-08-28","vote_average":6.636,"backdrop_path":"/ql8eEivmqg2vfas07ucDNAAtAAb.jpg","original_title":"יוסי וג'אגר","original_language":"he"},{"id":393443,"adult":false,"title":"Extremis","video":false,"overview":"A purely observational non-fiction film that takes viewers into the ethically murky world of end-of-life decision making in a public hospital.","genre_ids":[99],"media_type":"movie","popularity":1.1917,"vote_count":86,"poster_path":"/1vDbsnL2601o6fyrNlXHu0wWP1.jpg","release_date":"2016-04-17","vote_average":7,"backdrop_path":"/hl7b32TWdR5rIfhN9rACdwyscIk.jpg","original_title":"Extremis","original_language":"en"},{"id":581475,"adult":false,"title":"Juanita","video":false,"overview":"Fed up with her deadbeat grown kids and marginal urban existence, Juanita takes a Greyhound bus to Paper Moon, Montana - where she reinvents herself and finds her mojo.","genre_ids":[18],"media_type":"movie","popularity":0.6424,"vote_count":90,"poster_path":"/yKq6LErlgWizCtl3DcdYv86xn2e.jpg","release_date":"2019-03-08","vote_average":5.4,"backdrop_path":"/84G2n5VRBiFE534BbH4rTUpMI4Y.jpg","original_title":"Juanita","original_language":"en"}],"similar_content":[{"id":8440,"adult":false,"title":"Carandiru","video":false,"overview":"When a doctor decides to carry out an AIDS prevention program inside Latin America’s largest prison: the Casa de Detenção de São Paulo - Carandiru, he meets the future victims of one of the darkest days in Brazilian History when the State of São Paulo’s Military Police, with the excuse for law enforcement, shot to death 111 people. Based on real facts and on the book written by Dráuzio Varella.","genre_ids":[18],"popularity":3.3175,"vote_count":594,"poster_path":"/kKAgIMwQWQ6u4s0c56XKSDX3vAs.jpg","release_date":"2003-03-21","vote_average":7.577,"backdrop_path":"/rhrBU761a5B4w7hhpA9og3fNBCH.jpg","original_title":"Carandiru","original_language":"pt"},{"id":10503,"adult":false,"title":"Happy-Go-Lucky","video":false,"overview":"A look at a few chapters in the life of Poppy, a cheery, colorful, North London schoolteacher whose optimism tends to exasperate those around her.","genre_ids":[35,18],"popularity":0.8697,"vote_count":495,"poster_path":"/9FdD4YClMPZponkvHuQOgEOaWcF.jpg","release_date":"2008-04-18","vote_average":6.605,"backdrop_path":"/nrKkpJ4qOWWXl2v4a9UAw5nXYex.jpg","original_title":"Happy-Go-Lucky","original_language":"en"},{"id":10434,"adult":false,"title":"Faraway, So Close!","video":false,"overview":"A group of angels look longingly upon the life of humans. Berlin now is a very different place: unified in name but overrun with crime, corruption,