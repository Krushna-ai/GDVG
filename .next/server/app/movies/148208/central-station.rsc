":1.777,"vote_average":0},{"width":1920,"height":1080,"file_path":"/ilLlO2h2xBYvmFPSr4n5XzqTTZY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/xxiuaCz6pyiySgwIWQIfOoUouUH.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/r6lMxz1RDA1cwLj7zeeWM3VVGjU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/bV3PV9weiBQtgqanWTy50TeE6pT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/plA8ePUeKHke2uyXsfSj8KG5ht3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/odvsFrdl2LL6K9JATKax3K8Wjqw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/tv0JbDTOmxWTPCEBHeB7U9TopRy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/k0huXsU0XQp938qtOX1RMLNSs4m.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/sqLZ06aau0nvGkZObeaoamGSt4k.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/49FBhBgsAj2myOxo30v0CJxCDWp.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/gJ3jZvl0Nvvfp3N3fe7dzz38Jga.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/h1s1Qv63ZodYZQuJs0wtN9L8y6P.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/i7LMGteMS9yHmJL480kiNorOrLQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/1HuEqDeMwLFum4pUYLLNvtEj9TF.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/mOMggvPl0yvjY6v2K6hkXjXyB6i.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/yeuBf41uKkZkmAwSlfcYfRcdbKj.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/wAhbuXhFHMsNgI4mPvwe16SKiT5.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/ojF6dgvfjhrd5I5mruVZu2PZznm.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/vnmWVJE1I3UcHnesHQp1qCHXeKA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/9Qciw5wG6pXiyE93Metn0y3MSHM.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/sWUbB72feTUMvlY8Ue2VDhkCLwK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2820,"height":1586,"file_path":"/6QOwGm8VnGbn8sUKFMnaELdDPiR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2048,"height":1152,"file_path":"/zqzq5lCrrTbTT0ufEG7zDT3ezIi.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2111,"height":1187,"file_path":"/g7KAmd6xr1d28v387TZn8wm8EG.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2217,"height":1247,"file_path":"/gjD09meJnoo87hj280F78jQI0kw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2175,"height":1223,"file_path":"/bgXS2BbEEys7nGHM3P4Wqb44imv.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2201,"height":1238,"file_path":"/zSifwFMWGJ4tApbROBlY0hXn2qO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2195,"height":1235,"file_path":"/eeyl5W7V1ZHDCCcHcTdI6rArDVj.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2232,"height":1255,"file_path":"/qZTP5Bj8l808Lknf54W4sH6g9KY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2201,"height":1238,"file_path":"/39qvqaraPnxm7zy6cQfbOUNGQKl.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:44:18.46+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Central Station","runtime":110,"tagline":"Between hope and solitude, two lives cross and reinvent themselves","homepage":"","overview":"An emotional journey of a former school teacher, who writes letters for illiterate people, and a young boy, whose mother has just died, as they search for the father he never knew."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Central Station","runtime":113,"tagline":"","homepage":"","overview":"Central do Brasil ist ein brasilianischer Klassiker von Regisseur Walter Salles über die Beziehung einer älteren verbitterten Frau zu einem verwaisten Jungen, der in Rio de Janeiro spielt. Central do Station meint den Hauptbahnhof der Metropole."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":113,"tagline":"","homepage":"","overview":"Dora trabalha escrevendo cartas para analfabetos na estação Central do Brasil, Rio de Janeiro. A escrivã ajuda um menino, após a sua mãe ser atropelada, a tentar encontrar o pai que nunca conheceu, no interior do Nordeste."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":113,"tagline":"","homepage":"","overview":"In de buurt van het centraal station van Rio de Janeiro, verdient Dora, een voormalige lerares van bijna zestig, haar boterham met het schrijven van brieven voor analfabete migranten. Tot haar arme klanten behoren Ana en haar jonge zoon."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Dworzec nadziei","runtime":110,"tagline":"","homepage":"","overview":"Film psychologiczno-obyczajowy. Rio de Janeiro, czasy współczesne: 50-letnia kobieta przed dworcem kolejowym pisuje odpłatnie listy dla analfabetów. Pewnego dnia jej klientka, matka 9-latka, która prosi o napisanie listu do dawno niewidzianego męża, ginie w wypadku drogowym. Wzruszającą opowieść o przyjaźni emerytowanej nauczycielki z małym osieroconym chłopcem, która na zawsze odmieniła ich życie."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"中央车站","runtime":110,"tagline":"","homepage":"","overview":"里约热内卢的中央车站，朵拉在这里帮人写信。但她会把看不顺眼的信统统撕掉不寄，甚至公开读信里的内容取乐。朵拉生活拮据，年纪不小却还未嫁，或许在她内心，人与人之间的真情根本就不值得信赖。 小男孩约书亚的出现令她开始了一段重新认识人生的旅程——约书亚很想见到远方素未谋面的父亲，不断写信给他。男孩母亲意外的车祸让朵拉决定陪伴约书亚前往东北部寻找父亲。在约书亚眼中，即使父亲很陌生，却总是骄傲地谈起父亲。而朵拉，也同样有着一段和父亲的痛苦往事。在约书亚寻父的过程中，朵拉因为往事而冰冻的内心慢慢回暖。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Central do Brasil","runtime":0,"tagline":"","homepage":"","overview":"Dora è un'insegnante in pensione di Rio, che per arrotondare scrive lettere per gli analfabeti. È una donna senza fascino e delusa, certamente cinica. Quando un bambino rimane solo per la morte della mamma, Dora lo raccoglie soltanto per venderlo a chi fa commercio di organi. Si pente, recupera il bambino ma deve fuggire. Così, attraversa il Brasile per accompagnare il piccolo da un fantomatico padre, che non viene mai trovato. In compenso il bambino si ricongiunge con due fratelli sconosciuti, mentre Dora ha tratto qualcosa dall'esperienza. Saprà star sola, meno disperata."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Dora, ex-institutrice, gagne sa vie en écrivant des lettres pour les migrants illettrés à la gare centrale de Rio. Ana et son jeune fils Josue font appel à ses services pour retrouver le père de Josue. Lorsque Dora rentre dans son petit appartement de banlieue, elle fait le tri des lettres de la journée, en envoie certaines, jette les autres et en garde une partie dans un tiroir. C'est ce qui arrive à la lettre de Josue. Quand sa mère meurt, renversée par un bus, Josue demande à Dora de l'aider à retrouver son père. D'abord insensible, Dora finit par accepter de l'aider."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Estación central de Brasil","runtime":115,"tagline":"","homepage":"","overview":"En los asfixiantes pasillos de la Estación Central, en Río de Janeiro, una antigua maestra se gana la vida escribiendo las cartas que le dictan los analfabetos. Endurecida por la soledad y por la adversidad, Dora ha ido cayendo en una estoica indiferencia. Sin embargo, cuando una de sus clientes muere atropellada a la salida de la estación, decide hacerse cargo de su hijo y llevarlo a casa de su padre en una remota zona del nordeste de Brasil."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Központi pályaudvar","runtime":0,"tagline":"","homepage":"","overview":"Dora, az egykori tanárnő a forgalmas pályaudvaron üldögél asztala mögött. Analfabéták helyett ír levelet, ezzel tartja el magát. Egy nap egyik ügyfelét halálos baleset éri, akinek fia, Josué magára marad. Dora úgy érzi, hogy segítenie kell a gyermeken, de nem vállalkozik rá, hogy magához vegye. Inkább útnak indul a kisfiúval, hogy megkeressék az apját."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Merkez İstasyonu","runtime":0,"tagline":"","homepage":"","overview":"Rio de Janeiro'da çalışan, müşterilere mektup yazıp postalamakla görevli soğuk ve yaşlı bir kadın olan Dora (Fernanda Montenegro), müşterilerden ve insanlardan nefret ediyor. Dokuz yaşında bir çocuk olan Josue (Vinicius de Oliveira), babasını hiç görmemiş. Josue'nun annesi, kocasına mektuplar yazıyor ve bu mektuplar Dora aracılığıyla gönderiliyor. Kadın bir araba kazasında ölünce, Josue'nin sorumluluğunu insanları pislik olarak gören Dora üstlenmek zorunda kalıyor. Dora, Josue'yı babasını görebilmesi için yolculuğa çıkmaya ikna ediyor ve bu iki farklı insan arasında sıradışı bir dostluk kuruluyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":110,"tagline":"Entre a esperança e a solidão, duas vidas se cruzam e se reinventam.","homepage":"","overview":"Dora escreve cartas para analfabetos na estação Central do Brasil. Uma das clientes de Dora é Ana, que vem escrever uma carta com o seu filho, Josué, um garoto de nove anos, que sonha encontrar o pai que nunca conheceu. Na saída da estação, Ana é atropelada e Josué fica abandonado. Mesmo a contragosto, Dora acaba acolhendo o menino e envolvendo-se com ele. Termina por levar Josué para o interior do Nordeste, à procura do pai. À medida em que vão entrando país adentro, esses dois personagens, tão diferentes, vão se aproximando... Começa então uma viagem fascinate ao coração do Brasil, à procura do pai desaparecido, e uma viagem profundamente emotiva ao coração de cada um dos personagens do filme."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Центральный вокзал","runtime":0,"tagline":"","homepage":"","overview":"Бывшая учительница — Дора зарабатывает тем, что пишет письма для неграмотных людей, приезжающих на Центральный вокзал Рио-де-Жанейро. Безразличная к своим клиентам, она берет по доллару за письмо, и еще доллар, если просят его отправить. А отправляет она не все письма.\r 9-летний Жозуэ и его мать тоже пользуются услугами Доры. Они пишут отцу. Отца Жозуэ никогда не видел, но мечтает встретиться с ним.\r А однажды, когда погибает его мать, мальчик остается совсем один в огромном городе. У наблюдающей за бедным мальчиком Доры появляется мысль о возможной выгоде. И она решает найти его отца…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"중앙역","runtime":0,"tagline":"","homepage":"","overview":"글을 모르는 사람들을 대신해 편지를 써주는 것으로 생계를 이어가는 초로의 전직 여교사 도라는 어느 날 안나와 그 아들의 부탁을 받는다. 아버지에게 보낼 편지를 써달라는 부탁을 받고 도라가 잠시 역을 나선 순간 안나가 그만 차에 치여 사망한다. 도라는 갑자기 엄마를 잃은 아이를 어쩌지 못해 아이의 아버지를 찾기 위한 여행을 떠난다.\r 베를린영화제에서 최우수 작품상과 여우주연상을 받은 작품으로, 월터 살레스는 도라와 아이의 여정을 통해 브라질의 현실을 보여준다. 원주민들의 모습, 순례와 축제, 황량하고 마른 땅과 한없이 뻗은 신작로 등 브라질의 풍광을 배경으로 영화는 도라와 아이 사이에 싹트는 인간에 대한 사랑을 전달한다. 살레스는 반문맹인 여성 장기수와 저명한 조각가 사이에 오랜 세월 주고받은 편지를 기초로 만든 자신의 다큐멘터리 <또다른 어떤 곳의 삶>에서 <중앙역>의 아이디어를 떠올렸고 아이 역을 맡은 배우는 리우 공항에서 구두닦이를 하던 소년이었다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Централна гара Бразилия","runtime":113,"tagline":"","homepage":"","overview":"Централна гара Бразилия е разказ за една жена, която си изкарва хляба на Централната гара с писане на писма на неграмотни хора до техните роднини. Един ден нейна клиентка я моли да съчини писмо до мъжа й, който никога не е виждал сина си Жозуе, момче на 9 години. На излизане от гарата майката е блъсната от автомобил и Жозуе остава сам. Дора - така се казва писарката - прибира момчето у дома си без особен ентусиазъм и заедно тръгват да търсят изчезналия баща. Започва едно увлекателно пътуване към сърцето на Бразилия, пътуване изключително емоционално и разтърсващо, което променя душевността и на двамата герои - старата дама и детето. По време на пътуването те истински се сприятеляват..."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Κεντρικός σταθµός","runtime":0,"tagline":"","homepage":"","overview":"Η Dora είναι πρώην δασκάλα που ζει γράφοντας γράµµατα για αγράµµατους περαστικούς από τον κεντρικό σιδηροδροµικό σταθµό του Ρίο ντε Ζανέιρο. Ανάµεσα στους πελάτες της συγκαταλέγονται η Ana και ο εννιάχρονος γιος της. Όταν η Ana σκοτώνεται, η Dora δεσµεύεται να οδηγήσει τον εννιάχρονο ορφανό στον πατέρα του στην απόµακρη βορειανατολική Βραζιλία. Καθώς λεωφορεία και φορτηγά τους µεταφέρουν µέσα από το αφιλόξενο τοπίο, η Ana και το αγόρι κάνουν ένα νοερό ταξίδι φιλίας αλλά και αυτογνωσίας. Το ταξίδι µετατρέπεται σε µια αναζήτηση της ταυτότητάς τους."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"セントラル・ステーション","runtime":0,"tagline":"","homepage":"","overview":"かつて教師をしていたドーラは、今はリオデジャネイロの中央駅で代筆業を営んでいる。字の書けない人のために手紙を書くのが彼女の仕事だが、次第に何の感情も持たないようになり、その手紙を実際に出すことはほとんどなくなっていた。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"中央車站","runtime":0,"tagline":"","homepage":"","overview":"在巴西里約熱內盧中央車站替人寫信的朵拉，替一名少婦與她十歲的兒子約書亞寫信給父親，然而少婦卻在離開車站後意外身亡，朵拉決定帶著孤苦無依的約書亞，踏上找尋父親的旅程。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"中央車站","runtime":0,"tagline":"","homepage":"","overview":"朵拉在里約熱內盧最主要的火車站－中央車站為不識字的人寫信。這一天，安娜帶著她一直很想見他素未謀面的爸爸九歲的兒子約書亞來。第二天，安娜與約書亞又來到中央車站，口述了第二封信給約書亞的父親，但一出車站，安娜就發生車禍身亡，母性的驅使下，朵拉答應帶約書亞到東北部去找爸爸，沿途的風景越來越陌生，兩人卻變得越來越親近…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"ცენტრალური სადგური","runtime":0,"tagline":"","homepage":"","overview":"ყოფილი მასწავლებელი - დორა შოულობს იმით, რომ წერილებს წერს წერა-კითხვის უცოდინარი ადამიანებისთვის, რომლებიც რიო-დე-ჟანეიროს ცენტრალურ სადგურზე მოდიან. კლიენტების მიმართ გულგრილი, წერილში დოლარს იხდის, ხოლო თუ სთხოვენ მის გაგზავნას. და ის არ აგზავნის ყველა წერილს. დორას მომსახურებით სარგებლობენ 9 წლის ხოსუე და მისი დედაც. ისინი წერენ მამას. ხოსუეს არასოდეს უნახავს მამა, მაგრამ ოცნებობს მასთან შეხვედრაზე."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Estación central","runtime":0,"tagline":"","homepage":"","overview":"En los asfixiantes pasillos de la Estación Central, en Río de Janeiro, una antigua maestra se gana la vida escribiendo las cartas que le dictan los analfabetos. Endurecida por la soledad y por la adversidad, Dora ha ido cayendo en una estoica indiferencia. Sin embargo, cuando una de sus clientes muere atropellada a la salida de la estación, decide hacerse cargo de su hijo y llevarlo a casa de su padre en una remota zona del nordeste de Brasil."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Den pensionerade, cyniska lärarinnan Dora försörjer sig genom att skriva brev åt analfabeter på Rio de Janeiros järnvägsstation Central do Brasil. Hon får genom en slump och till en början högst motvilligt ta hand om den 9-årige Josué efter det att hans mor dött i en olycka. De två beger sig iväg för att söka efter Josués far."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Hlavní nádraží","runtime":0,"tagline":"","homepage":"","overview":"Bývalá učitelka Dora si přivydělává jako příležitostná písařka na hlavním nádraží v Rio de Janeiru. Jejíma rukama projdou denně desítky dopisů, o jejichž napsání ji žádají lidé, kteří neumějí psát. Jednoho dne ji jedna zákaznice požádá, aby napsala dopis jejímu manželovi a otci chlapce, jehož má s sebou. Chvíli poté se stane Dora svědkem nehody: tuto ženu srazí auto a její synek zůstane na ulici sám. Chlapec se několik dní potuluje po nádraží, až se ho Dora nakonec ujme. Hodlá si přivydělat tím, že ho postoupí pokoutní agentuře obstarávající děti k adopci. Později však pocítí výčitky svědomí, unese chlapce z bytu překupníků a podstoupí s ním cestu za jeho pravým otcem. Ani Dora, ani chlapec nejsou zpočátku nadšeni jeden druhým, ale dlouhé a náročné putování postupně odbourává jejich předsudky a mezi oběma se začíná vytvářet pevné citové pouto..."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Бразилія. Центральний вокзал","runtime":0,"tagline":"","homepage":"","overview":"Дора пише листи за неписьменних на Центральному вокзалі Ріо-де-Жанейро. У почутих і записаних нею оповідях постає Бразилія — незнана і чарівна. Вимальовується справжня панорама життя мандрівного населення, яке намагається втримати зв´язки зі своєю ріднею і зі своїм минулим. Однією з клієнток Дори стає Ана, яка просить її написати листа своєму чоловіку. Ана прийшла зі своїм синочком — Жошуе, дев´ятирічним хлопчиком, який мріє познайомитись з татом, якого він ніколи не бачив. Виходячи з вокзалу, Ана потрапляє під машину і Жошуе лишається сиротою. Дора забирає хлопчика до себе і прив´язується до нього. Вони їдуть вглиб Бразилії у пошуках його тата. Подорожуючи, незважаючи на величезну різницю у віці і поглядах на оточуючий світ, вони все більше зближуються. Захоплююча подорож до серця Бразилії у пошуках зниклого тата, подорож, яка пробуджує емоції у серцях кожного героя фільму."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Stația centrală","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"תחנה מרכזית ברזיל","runtime":0,"tagline":"","homepage":"","overview":"דורה, מורה בגמלאות, מתפרנסת מכתיבת מכתבים עבור אנאלפבתיים בתחנה המרכזית של ריו דה זענרו. בוקר אחד, נהרגת אחת מלקוחותיה לנגד עיניה. היתה זו אשה צעירה שביקשה לאתר את בעלה. עתה נותר בנה הקטן בגפו והוא פונה אל דורה שתסייע לו. יחדיו יוצא הזוג המוזר למסע ברחבי ברזיל כדי למצוא את אביו האבוד של הנער. על הבסיס הדרמטי הזה יצר וולטר סאלס סרט קטן ונוגע ללב אשר זכה לאהדה ולפרסים ברחבי העולם."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"สถานีแห่งศรัทธา","runtime":0,"tagline":"","homepage":"","overview":"เล่าเรื่องราวของโดร่า อดีตครูที่เขียนจดหมายให้คนอ่านไม่ออกที่สถานีรถไฟกลางในริโอเดจาเนโร และโจชัว เด็กชายกำพร้าที่แม่เสียชีวิตจากอุบัติเหตุรถชน โดร่าตัดสินใจพาโจชัวเดินทางข้ามประเทศเพื่อตามหาพ่อของเขา การเดินทางครั้งนี้กลายเป็นเส้นทางของการเยียวยาและค้นหาตัวเองของทั้งคู่"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Nhà Ga Trung Tâm","runtime":0,"tagline":"","homepage":"","overview":"Một hành trình đầy cảm xúc của một cựu giáo viên, người viết thư cho những người mù chữ, và một cậu bé, người mẹ vừa mất, khi họ tìm kiếm người cha mà cậu chưa từng biết mặt."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"ایستگاه مرکزی","runtime":0,"tagline":"","homepage":"","overview":"داستان سفری احساسی و معنوی معلمی سابق که برای مردم بیسواد و پسری که مادر خود را به تازگی از دست داده و به دنبال پدر خود است که هیچگاه او را ندیده نامه می نویسد..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"}],"reviews_tmdb":[{"id":"68cbdedc69c15c2506c3f81c","url":"https://www.themoviedb.org/review/68cbdedc69c15c2506c3f81c","author":"CinemaSerf","content":"$11","created_at":"2025-09-18T10:28:44.468Z","updated_at":"2025-09-18T10:36:54.587Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":37817,"adult":false,"title":"Ó Paí, Ó: Look at This","video":false,"overview":"During the Carnival in the historical site of Pelourinho, Salvador da Bahia, we follow the lives of the tenants of a falling-to-pieces tenement house who try to get by using creativity, irony, humor, and music.","genre_ids":[10402,35],"media_type":"movie","popularity":0.5029,"vote_count":198,"poster_path":"/BFVGUEQxhORXLRsclpzvGsIIFY.jpg","release_date":"2007-03-30","vote_average":6.97,"backdrop_path":"/aQtgaQ4nOIKaPtbyqLLQs94DRvZ.jpg","original_title":"Ó Paí, Ó","original_language":"pt"},{"id":913816,"adult":false,"title":"Mars One","video":false,"overview":"A middle-class Black family in Brazil copes with the election of a far-right extremist president. The mother believes that she's cursed after an unexpected encounter, while her husband puts all of his hopes into their son's soccer career.","genre_ids":[18],"media_type":"movie","popularity":1.4475,"vote_count":93,"poster_path":"/mrEHCuGyXpkBpQW5Xqt5kaHOyap.jpg","release_date":"2022-08-25","vote_average":7.3,"backdrop_path":"/mYA6m2kruLxmqAApVcX8uMc0jNJ.jpg","original_title":"Marte Um","original_language":"pt"},{"id":34671,"adult":false,"title":"Olga","video":false,"overview":"Based upon the true story of Olga Benário, the German-born wife of Brazilian communist leader Luís Carlos Prestes. During the dictatorship of Getúlio Vargas (1930-1945) she was arrested and sent to Nazi Germany, where she was put to death in a concentration camp. After World War II began, Vargas decided to uphold the Allies.","genre_ids":[18,36,10752],"media_type":"movie","popularity":0.5171,"vote_count":201,"poster_path":"/zym9l0b5eu6fDeBXJzbDuVYMOVJ.jpg","release_date":"2004-08-20","vote_average":7.147,"backdrop_path":"/cvi87c0MElnvslK5asTyLCmx4jL.jpg","original_title":"Olga","original_language":"pt"},{"id":52345,"adult":false,"title":"Lisbela and the Prisoner","video":false,"overview":"Lisbela is a young woman who loves going to the movies. Leléu is a con man, going from town to town selling all sort of things and performing as master of ceremonies for some cheesy numbers, such as the woman who gets transformed into a gorilla. He gets involved with Linaura, a sexy and beautiful woman who happens to be the wife of the most frightening hitman of the place. The hitman finds out his wife's affair and goes after Leléu, who has to leave in a hurry. In another town, he meets and falls instantly in love with Lisbela, who is engaged to Douglas, a hillbilly who tries hard to pass for a cosmopolitan Rio de Janeiro dweller.","genre_ids":[35,10749],"media_type":"movie","popularity":0.7134,"vote_count":401,"poster_path":"/raCdo5Hjpd3uXbpSd1JZ7tEyE31.jpg","release_date":"2003-08-22","vote_average":7.825,"backdrop_path":"/eAOOeqa14oCxgdKxLvpDYxCJhqQ.jpg","original_title":"Lisbela e o Prisioneiro","original_language":"pt"},{"id":1653,"adult":false,"title":"The Motorcycle Diaries","video":false,"overview":"Based on the journals of Che Guevara, leader of the Cuban Revolution. In his memoirs, Guevara recounts adventures he and best friend Alberto Granado had while crossing South America by motorcycle in the early 1950s.","genre_ids":[18],"media_type":"movie","popularity":2.2876,"vote_count":1400,"poster_path":"/qz2aBYT8CAiJYvX4fRZpJ5G0Oz1.jpg","release_date":"2004-02-06","vote_average":7.411,"backdrop_path":"/o6Ln9kTC4ZrHZNUhWLOwBfUvqXU.jpg","original_title":"Diarios de motocicleta","original_language":"es"},{"id":40823,"adult":false,"title":"The Man Who Copied","video":false,"overview":"A young photocopier operator becomes infatuated with his neighbor and, unable to afford anything from her shop, turns to shady schemes to make money.","genre_ids":[35,18,10749,80],"media_type":"movie","popularity":0.4663,"vote_count":371,"poster_path":"/3RsEkEdLEFd0Q5HThqMd4X8tYZk.jpg","release_date":"2003-06-13","vote_average":7.503,"backdrop_path":"/fN4OThflKQ8ZT1w2qRRIJmLejKk.jpg","original_title":"O Homem Que Copiava","original_language":"pt"},{"id":69938,"adult":false,"title":"Trap.com","video":false,"overview":"Exposed by his girlfriend through a video on the Internet, Bruno tries to revive his reputation, but all he can do is get into a series of traps (Cilada, in Portuguese). Cilada.com is a comedy about love and betrayal that shows the power of the Internet to transform small intimacies and slips in fame and constraints globalized.","genre_ids":[35,10749],"media_type":"movie","popularity":0.2584,"vote_count":145,"poster_path":"/jCTh6jL9fd39Zu65Af5lnlHg0uw.jpg","release_date":"2011-07-08","vote_average":5.048,"backdrop_path":"/tYuPkSBWpiLopOvH3KPXt1SvoM.jpg","original_title":"Cilada.com","original_language":"pt"},{"id":191185,"adult":false,"title":"My Sweet Orange Tree","video":false,"overview":"Zezé is an 8 year old boy who, although a naughty boy, has a good heart. He leads a very modest life, due to the fact that his father has been unemployed for a long time, and has the habit of having long conversations with a sweet orange tree which is in his backyard. Until one day he meets Portuga, a man who begins to help him and soon becomes his best friend.","genre_ids":[18,10751],"media_type":"movie","popularity":0.1995,"vote_count":49,"poster_path":"/7Q6FpTfJYiZZHSe8C9jcopFLptt.jpg","release_date":"2012-09-29","vote_average":7.4,"backdrop_path":"/fKOdobrFOaixErZDNVF4mS5S6oI.jpg","original_title":"Meu Pé de Laranja Lima","original_language":"pt"},{"id":478187,"adult":false,"title":"The Swindlers","video":false,"overview":"A group of swindlers unite to hunt down an infamous con man who was known dead, amid their hidden motives and deception.","genre_ids":[80,28,53],"media_type":"movie","popularity":0.5776,"vote_count":102,"poster_path":"/wzxsCW4chkwXzfJPLXImpEpjtV.jpg","release_date":"2017-11-22","vote_average":6.7,"backdrop_path":"/qTiLXkTKBPXpVE7aYQwZpd99DOA.jpg","original_title":"꾼","original_language":"ko"},{"id":43615,"adult":false,"title":"Lula, the Son of Brazil","video":false,"overview":"The true story of a working class boy who moves to the nation's financial capital at a young age and becomes one the most influential politicians in Brazilian history.","genre_ids":[18,36],"media_type":"movie","popularity":0.2626,"vote_count":85,"poster_path":"/eBMfXW9J9iH81Ni34fplljW03eX.jpg","release_date":"2010-01-01","vote_average":5.5,"backdrop_path":"/1HosReoyDPOEbBdQVlnboFdcbQj.jpg","original_title":"Lula, o Filho do Brasil","original_language":"pt"},{"id":211166,"adult":false,"title":"Rio, I Love You","video":false,"overview":"The third episode of the Cities of Love franchise, Rio, I Love You is an anthology, created by 10 visionary directors from across the globe. The story line of each segment focuses on an encounter of love in a different neighborhood of the city, demonstrating the distinctive qualities and character of that location. The film serves to bridge gaps between cultures, educating and entertaining the audience, while celebrating unique and universal expressions of love.","genre_ids":[10749,18],"media_type":"movie","popularity":0.6967,"vote_count":47,"poster_path":"/e4MEGQlEE7VojlBpwaJvjMcXJPg.jpg","release_date":"2014-09-12","vote_average":4.809,"backdrop_path":"/fee4Wfz9zWhRO7ybfUMIYSCZg8q.jpg","original_title":"Rio, Eu Te Amo","original_language":"pt"},{"id":78214,"adult":false,"title":"Paradise Kiss","video":false,"overview":"Hyasaka Yukari only wants one thing: to enter the college that her mom wants. One day, she meets an extravagant group that loves fashion. They were searching for a model and Yukari fits their ideal model. From now Yukari will know the world of fashion and modeling, and what she really wants.","genre_ids":[18,10749],"media_type":"movie","popularity":0.8074,"vote_count":65,"poster_path":"/eyNH5XUHTStR7IhpBeOJoK7jqpl.jpg","release_date":"2011-06-04","vote_average":7.085,"backdrop_path":"/qRyuVUaENDPGGJBbPHOycnT0JdB.jpg","original_title":"パラダイス・キス","original_language":"ja"},{"id":10608,"adult":false,"title":"Bob Roberts","video":false,"overview":"Millionaire conservative Bob Roberts launches an insurgent campaign against incumbent senator Brickley Paiste, firing up crowds at his rallies by singing '60s-style acoustic folk songs with lyrics espousing far-right conservative social and economic views.","genre_ids":[35,18],"media_type":"movie","popularity":0.8204,"vote_count":173,"poster_path":"/j4PokuSIrmbN5oCR54D8kiI0U6a.jpg","release_date":"1992-09-04","vote_average":6.5,"backdrop_path":"/lyTh10IP4bNVYp3G7cWBac76OYb.jpg","original_title":"Bob Roberts","original_language":"en"},{"id":59990,"adult":false,"title":"The Given Word","video":false,"overview":"Zé is a very poor man whose most prized possession is his donkey. When his donkey falls terminally ill, Zé makes a promise to Saint Bárbara: If his donkey recovers, he will carry a cross - like Jesus - all the way from his city to Saint Bárbara's church, in the state capital. Upon the recovery of his donkey, Zé leaves on his journey. He makes it to the church, but the priest refuses to accept the cross once he discovers the context of Zé's promise.","genre_ids":[18],"media_type":"movie","popularity":0.5711,"vote_count":122,"poster_path":"/wjNydK6CnoJFEp69OzAcSsAaIME.jpg","release_date":"1962-04-17","vote_average":8.1,"backdrop_path":"/k13mFZr51lcOxvLrHHCk9Llevcf.jpg","original_title":"O Pagador de Promessas","original_language":"pt"},{"id":9440,"adult":false,"title":"Primary Colors","video":false,"overview":"In this adaptation of the best-selling roman à clef about Bill Clinton's 1992 run for the White House, the young and gifted Henry Burton is tapped to oversee the presidential campaign of Governor Jack Stanton. Burton is pulled into the politician's colorful world and looks on as Stanton -- who has a wandering eye that could be his downfall -- contends with his ambitious wife, Susan, and an outspoken adviser, Richard Jemmons.","genre_ids":[18,35],"media_type":"movie","popularity":1.1218,"vote_count":342,"poster_path":"/1FDR837wg7bi02F1R7JESCoPWBD.jpg","release_date":"1998-03-20","vote_average":6.3,"backdrop_path":"/8S0fdn8FumgyqEN2yQDeVfBFOk1.jpg","original_title":"Primary Colors","original_language":"en"},{"id":57811,"adult":false,"title":"Foreign Land","video":false,"overview":"During a time of political upheaval in Brazil, two strangers meet by coincidence in a foreign land and end up caught in the middle of a gem smuggling ring.","genre_ids":[18,53,10749],"media_type":"movie","popularity":0.3693,"vote_count":58,"poster_path":"/6whwSYpWuixvof2fDKJVvVD0QiA.jpg","release_date":"1996-09-04","vote_average":7.1,"backdrop_path":"/i9dJI44Zy9rB5I1NjntfRN5932d.jpg","original_title":"Terra Estrangeira","original_language":"pt"},{"id":373579,"adult":false,"title":"Malasartes e o Duelo com a Morte","video":false,"overview":"Small-town trickster Pedro Malasartes has to face two great enemies: Próspero, who will do anything to impede such a lazy, cowardly person like Malasartes from dating his sister, Áurea; and Death incarnated, who wants to take a vacation after two thousand years collecting lives and intends on tricking Malasartes into assuming his tedious job.","genre_ids":[35,14],"media_type":"movie","popularity":0.1549,"vote_count":49,"poster_path":"/A7wR2bxwQfiFJJqw8G4YMBtjpSv.jpg","release_date":"2017-08-10","vote_average":6.48,"backdrop_path":"/fGtJ7bxDo45bkU7KU6QN0mje6po.jpg","original_title":"Malasartes e o Duelo com a Morte","original_language":"pt"},{"id":37993,"adult":false,"title":"Angels of the Sun","video":false,"overview":"In Northeastern Brazil, twelve-year-old Maria is sold to have a better life as a housemaid. However, Maria is resold and sent to a brothel in the Amazon gold fields and put to work by the despicable Saraiva.","genre_ids":[18],"media_type":"movie","popularity":0.4251,"vote_count":39,"poster_path":"/8BEucdM9eJ27omJACKfwfhTGSa6.jpg","release_date":"2006-03-04","vote_average":7,"backdrop_path":"/yrLH3f5ZUDQVGv5RJT2BUX1BEwP.jpg","original_title":"Anjos do Sol","original_language":"pt"},{"id":716978,"adult":false,"title":"Thiago Ventura: POKAS","video":false,"overview":"In a rollicking special, Thiago Ventura jokes about life in the hood, politics and more, explaining how actions speak louder then words.","genre_ids":[35],"media_type":"movie","popularity":0.0545,"vote_count":38,"poster_path":"/nAc2hBnkqpssxzTDVP4P3Hcmucj.jpg","release_date":"2020-07-02","vote_average":6.9,"backdrop_path":"/jMB4TAb0mAY5KzpBKLmgzW3VuiA.jpg","original_title":"Thiago Ventura: POKAS","original_language":"pt"},{"id":928118,"adult":false,"title":"The Movie Teller","video":false,"overview":"María Margarita is the youngest of four siblings in a family living in a mining town in the Atacama Desert (Chile). The most special time of the week for this family is Sunday, when they all go to the movies to enjoy stories that let them escape their everyday lives by transporting them to other worlds. The girl’s parents soon realise that the little girl has a very special gift: an almost uncanny ability to recount movies. The girl’s extraordinary talent will spread throughout the village, changing the fortunes of her family as the country is transformed forever.","genre_ids":[18,36],"media_type":"movie","popularity":0.8249,"vote_count":49,"poster_path":"/w1TGEhGbcvIp0MnUGdzDdTji9E9.jpg","release_date":"2023-10-27","vote_average":6.4,"backdrop_path":"/wxTm7Fppm0XnpzuAmCtT0XvLpuE.jpg","original_title":"La contadora de películas","original_language":"es"}],"similar_content":[{"id":8347,"adult":false,"title":"Running on Empty","video":false,"overview":"The dull daily routine of an insurance agent, who listlessly drives down the highway every day and conducts customer meetings while longing for his family, becomes a metaphor for a life that has come to a standstill and is threatened with being crushed by loneliness.","genre_ids":[18],"popularity":0.1676,"vote_count":0,"poster_path":"/f594pC0Iyn1x8oS4ZkuXCKhcPw5.jpg","release_date":"2006-02-14","vote_average":0,"backdrop_path":null,"original_title":"Der Lebensversicherer","original_language":"de"},{"id":8343,"adult":false,"title":"Badland","video":false,"overview":"Jerry (Jamie Draven) was an idealist when he served in the first Gulf War. But when he was later deployed to Iraq, Jerry was an older man, a father of three and embittered by broken promises and unfulfilled desires. When Jerry returns from Iraq he has been transformed by horrors that cannot be forgiven. He lives a life of poverty, his children afraid of him and his wife, Nora (Vinessa Shaw), unsympathetic and unhappy. When Jerry discovers that Nora has betrayed him, his anger and despair drive him to commit an act so heinous and irreversible that nothing he had experienced in combat could have prepared him for.","genre_ids":[18],"popularity":0.345,"vote_count":12,"poster_path":"/yndr9Ze8TtEGkb2n5QA0egMN04a.jpg","release_date":"2007-11-30","vote_average":6,"backdrop_path":"/yMgiZ7gKHCLxWHmr8LMn3i64ehO.jpg","original_title":"Badland","original_language":"en"},{"id":8440,"adult":false,"title":"Carandiru","video":false,"overview":"When a doctor decides to carry out an AIDS prevention program inside Latin America’s largest prison: the Casa de Detenção de São Paulo - Carandiru, he meets the future victims of one of the darkest days in Brazilian History when the State of São Paulo’s Military Police, with the excuse for law enforcement, shot to death 111 people. Based on real facts and on the book written by Dráuzio Varella.","genre_ids":[18],"popularity":3.3175,"vote_count":594,"poster_path":"/kKAgIMwQWQ6u4s0c56XKSDX3vAs.jpg","release_date":"2003-03-21","vote_average":7.577,"backdrop_path":"/rhrBU761a5B4w7hhpA9og3fNBCH.jpg","original_title":"Carandiru","original_language":"pt"},{"id":8618,"adult":false,"title":"The History Boys","video":false,"overview":"The story of an unruly class of bright, funny history students at a Yorkshire grammar school in pursuit of an undergraduate place at Oxford or Cambridge. Bounced between their maverick English master, a young and shrewd teacher hired to up their test scores, a grossly out-numbered history teacher, and a headmaster obsessed with results, the boys attempt to pass.","genre_ids":[18],"popularity":0.5679,"vote_count":211,"poster_path":"/klybhTU75GUcQbzdVXUhsZgq1EV.jpg","release_date":"2006-10-02","vote_average":6.626,"backdrop_path":"/A159OAi9EAU9v4l3sfMhpMqSK5v.jpg","original_title":"The History Boys","original_language":"en"},{"id":8649,"adult":false,"title":"Bringing Out the Dead","video":false,"overview":"Once called \"Father Frank\" for his efforts to rescue lives, Frank Pierce sees the ghosts of those he failed to save around every turn. He has tried everything he can to get fired, calling in sick, delaying taking calls where he might have to face one more victim he couldn't help, yet cannot quit the job on his own.","genre_ids":[18],"popularity":3.3849,"vote_count":1191,"poster_path":"/gE2Q8mL0m0EA6HakRyc92uzSPJn.jpg","release_date":"1999-10-22","vote_average":6.607,"backdrop_path":"/A1V1suhllQJ1CTrKpCulcM7mjyj.jpg","original_title":"Bringing Out the Dead","original_language":"en"},{"id":8651,"adult":false,"title":"En Route","video":false,"overview":"A slightly sinister but charming young man falls in with a young mother and daughter and her boyfriend on a camping holiday and leads them astray.","genre_ids":[10749,18],"popularity":0.1876,"vote_count":8,"poster_path":"/tew3nZObTsXB7AHelNQSca8MTR9.jpg","release_date":"2004-02-10","vote_average":7.4,"backdrop_path":null,"original_title":"Unterwegs","original_language":"de"},{"id":8903,"adult":false,"title":"My Magic","video":false,"overview":"A single dad looks to give up drinking and his bartender job in order to impress his son and find work as a magician.","genre_ids":[18],"popularity":0.2823,"vote_count":9,"poster_path":"/9mu3YmNDsp4BX1qvm7wuB5SSw0n.jpg","release_date":"2008-05-23","vote_average":5,"backdrop_path":"/x1syvjhOug0XEYEJ2nzhmphRBHl.jpg","original_title":"My Magic","original_language":"ta"},{"id":8841,"adult":false,"title":"The Class","video":false,"overview":"Teacher and novelist François Bégaudeau plays a version of himself as he negotiates a year with his racially mixed students from a tough Parisian neighborhood.","genre_ids":[18],"popularity":0.8222,"vote_count":708,"poster_path":"/8yFgK1YgfrnbsRXTg4Hko98nIUt.jpg","release_date":"2008-09-24","vote_average":7,"backdrop_path":"/vGtICaExlrMmQwMPlzt6HLiRKV1.jpg","original_title":"Entre les murs","original_language":"fr"},{"id":8441,"adult":false,"title":"The Man of the Year","video":false,"overview":"Maiquél has lost a bet and dyed his hair blond. This  seemingly innocuous event triggers a head-on collision with destiny in which he goes from nobody to hero to outlaw — all in 24 hours.","genre_ids":[18,80,53],"popularity":0.4247,"vote_count":84,"poster_path":"/7Qai7kYNbx5k8Dy4mGTPHdVxXjK.jpg","release_date":"2003-08-01","vote_average":6.708,"backdrop_path":"/7wZY5QVLv9GWg7KSUzbDdFe6JTA.jpg","original_title":"O Homem do Ano","original_language":"pt"},{"id":8443,"adult":false,"title":"Lower City","video":false,"overview":"Best friends Deco and Naldinho co-own a cargo boat in Brazil's Salvador da Bahia. They give a ride to a sultry prostitute named Karinna, and soon both men fall prey to her considerable sexual charms, pushing the bounds of their friendship to the limit.","genre_ids":[18],"popularity":0.5876,"vote_count":92,"poster_path":"/qFWvDBCN2LpVczu6ZKQq8B0AIYG.jpg","release_date":"2005-11-04","vote_average":6.4,"backdrop_path":"/3he9tOMisKv5tEpZMl2sIyaVtVy.jpg","original_title":"Cidade Baixa","original_language":"pt"},{"id":8462,"adult":false,"title":"Joyless Street","video":false,"overview":"In 1921, we follow two women - Marie and Grete - from the same poor Viennese neighborhood, as they try to better the lives of themselves and their families during the period of Austrian postwar hyperinflation.","genre_ids":[18],"popularity":0.3133,"vote_count":49,"poster_path":"/qmOQssz4GfbdtOmxwMP0jBj4P4F.jpg","release_date":"1925-03-01","vote_average":6.724,"backdrop_path":"/h4lY3dgzmtAZ5dl9mPO81S12S7W.jpg","original_title":"Die freudlose Gasse","original_language":"de"},{"id":9909,"adult":false,"title":"Dangerous Minds","video":false,"overview":"Former Marine Louanne Johnson lands a gig teaching in a pilot program for bright but underachieving teens at a notorious inner-city high school. After having a terrible first day, she decides she must throw decorum to the wind. When Johnson returns to the classroom, she does so armed with a no-nonsense attitude informed by her military training and a fearless determination to better the lives of her students -- no matter what the cost.","genre_ids":[18],"popularity":2.8401,"vote_count":1232,"poster_path":"/yWHWC8fJRp2kLgiFrEa8o3krOH9.jpg","release_date":"1995-08-11","vote_average":6.962,"backdrop_path":"/k28lTv01nuncbs9Y2WZh6FQunqv.jpg","original_title":"Dangerous Minds","original_language":"en"},{"id":9956,"adult":false,"title":"The Brave","video":false,"overview":"A down-on-his-luck American Indian recently released from jail is offered the chance to \"star\" as the victim of a snuff film, the resulting pay of which could greatly help his poverty stricken family.","genre_ids":[18],"popularity":1.0309,"vote_count":198,"poster_path":"/pVEVtkbvKfZyXm9aZ6fxAvPFg6i.jpg","release_date":"1997-07-30","vote_average":6.018,"backdrop_path":"/eDqf1F85rU7cxUeBBArL6k2QVtv.jpg","original_title":"The Brave","original_language":"en"},{"id":862495,"adult":false,"title":"Tuition","video":false,"overview":"Where is the line between discipline and abuse? 13-year-old Alan attends class under physically aggressive tuition teacher Beatrice. As the class progresses, so does her abusive treatment of the children. As Alan tries to secretly record audio evidence with his phone, his attempts fail to go as planned.","genre_ids":[18,10751],"popularity":0.1388,"vote_count":0,"poster_path":"/2ar8m5W0kRt7J0el9LBHTfT3zNM.jpg","release_date":"2021-08-15","vote_average":0,"backdrop_path":null,"original_title":"Tuition","original_language":"en"},{"id":9769,"adult":false,"title":"Lolita","video":false,"overview":"Humbert Humbert is a middle-aged British novelist who is both appalled by and attracted to the vulgarity of American culture. When he comes to stay at the boarding house run by Charlotte Haze, he soon becomes obsessed with Lolita, the woman's teenaged daughter.","genre_ids":[18,10749],"popularity":9.0211,"vote_count":1930,"poster_path":"/9INcC14WZjCMKGE360VXmklCLdZ.jpg","release_date":"1997-09-27","vote_average":7.103,"backdrop_path":"/b9diKSmofRcgjbUxDrSPms82yAN.jpg","original_title":"Lolita","original_language":"en"},{"id":278939,"adult":false,"title":"Girl in the Cadillac","video":false,"overview":"A runaway teenage girl and a drifter rob a bank, hit the road to elude the Texas Rangers and find love on the run.","genre_ids":[10749,12,80,18],"popularity":0.3154,"vote_count":9,"poster_path":"/k9bCfnN4tfDJoGCmT8KVuvIjZWM.jpg","release_date":"1995-10-24","vote_average":4.222,"backdrop_path":null,"original_title":"Girl in the Cadillac","original_language":"en"},{"id":9844,"adult":false,"title":"The Opposite of Sex","video":false,"overview":"A 16-year-old girl visits her gay half-brother and ends up seducing his boyfriend, thus wreaking havoc on all of their lives.","genre_ids":[35,18],"popularity":2.4044,"vote_count":215,"poster_path":"/e0rNtvIlcd8c0WChSsVC0W8Bvlf.jpg","release_date":"1998-05-22","vote_average":6.2,"backdrop_path":"/fw4mgfiq01d0SQduEqKjnh3xzbs.jpg","original_title":"The Opposite of Sex","original_language":"en"},{"id":9727,"adult":false,"title":"End Game","video":false,"overview":"Alex Thomas was the man in charge of protecting the president but, when the time came to fulfill his duties, everything just went wrong. His conscience haunted by a bullet, and his devotion to his country stronger than ever, Alex teams with a seasoned reporter to navigate a treacherous web of lies, unlocking a dangerous conspiracy, and enter a deadly world in which skilled assassins and highly-trained ex-special ops lurk in every shadow.","genre_ids":[28,53,80,18],"popularity":0.7529,"vote_count":99,"poster_path":"/1fqDXE7nxsqWCng3rwlWZwzBBBn.jpg","release_date":"2006-07-27","vote_average":5.394,"backdrop_path":"/xm1eHJ6MV33LzneyxLkxFjYWV0m.jpg","original_title":"End Game","original_language":"en"},{"id":279091,"adult":false,"title":"Perverted Adolescence","video":false,"overview":"Professor Mirella Buzzati, recovering from a failed relationship that ended with a divorce from her husband, travels to Perugia where she has obtained a mathematics teaching position at a high school. Her hatred of men, evident during the train ride and in her interactions with male colleagues who quickly flock to her, quickly yields to the attractiveness of Alain, a student nicknamed \"the dark and handsome\" by the high school girls. He already has a relationship with Giorgina, a fellow student of the same age and a fanatical militant of \"Lotta Continua.\" In an effort to win over her idol, Mirella becomes unscrupulous in her teaching, preaches political and sexual revolution; she earns the headmaster's rebukes, and heaps scathing criticism on her rival Giorgina. After a stint in Paris with a lesbian colleague, the professor resumes her attack and obtains Alain's physical performance, but not her love: the boy understands her well and deeply despises her.","genre_ids":[18,10749],"popularity":0.6462,"vote_count":12,"poster_path":"/zcHjoWTJzd3ax7TjZkJmOQ1xf20.jpg","release_date":"1974-03-15","vote_average":4.5,"backdrop_path":"/mf6XEJvCupChRbaOKpVKWLfeUsw.jpg","original_title":"Adolescence pervertie","original_language":"fr"}],"external_ids":{"imdb_id":"tt0140888","twitter_id":null,"facebook_id":null,"wikidata_id":"Q1054036","instagram_id":null,"metacritic_id":"movie/central-station","mydramalist_id":"9732","rotten_tomatoes_id":"m/central_station"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148208,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"BR","release_dates":[{"note":"Rio