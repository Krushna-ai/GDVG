9:{"metadata":[["$","title","0",{"children":"Black Dog | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"On the edge of the Gobi desert in Northwest China, Lang returns to his hometown after being released from jail. While working for the local dog patrol team to clear the town of stray dogs before the Olympic Games, he strikes up an unlikely connection with a black dog. These two lonely souls embark on a journey together."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/108540/black-dog"}],["$","meta","5",{"property":"og:title","content":"Black Dog"}],["$","meta","6",{"property":"og:description","content":"On the edge of the Gobi desert in Northwest China, Lang returns to his hometown after being released from jail. While working for the local dog patrol team to clear the town of stray dogs before the Olympic Games, he strikes up an unlikely connection with a black dog. These two lonely souls embark on a journey together."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/108540/black-dog"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/dWssO0oGC6b3PtN5uarGuVp66Uv.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Black Dog"}],["$","meta","12",{"name":"twitter:description","content":"On the edge of the Gobi desert in Northwest China, Lang returns to his hometown after being released from jail. While working for the local dog patrol team to clear the town of stray dogs before the Olympic Games, he strikes up an unlikely connection with a black dog. These two lonely souls embark on a journey together."}],["$","meta","13