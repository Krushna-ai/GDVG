h":"/rjSzUkXe4UpSZsuXywRaZj5yejO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3543,"height":1993,"file_path":"/crHccMI0s89fn40os9Qpq4OCzox.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/mhWQg7HWqVHKsIOfbLHynhbjrMn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/vvvTZi6BdrhIksHMIBYZOZ775Ru.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T04:58:05.091+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":95,"tagline":"","homepage":"","overview":"A group of high school friends decide to livestream themselves inside a haunted apartment building, but end up opening a portal to Hell."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":95,"tagline":"","homepage":"","overview":""},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"드레드아웃","runtime":97,"tagline":"버려진 아파트, 그곳엔 가지 말아야 했다.","homepage":"","overview":"린다와 제시카, 에릭을 비롯한 친구들은 SNS 실시간 방송으로 유명해지기 위해 살인사건으로 버려진 흉가에 들어간다. 흉가에 들어가 실시간 방송을 진행하던 그들은 들어가서는 안 될 통제구역을 넘어가고 그 안에서 다른 세계와 연결된 지옥의 문을 열게 된다. 공포 체험을 떠난 6명의 친구들에게 실시간으로 벌어지는 소름 끼치는 순간들… 괴담의 실체가 밝혀지는 순간, 그 누구도 그곳에서 빠져나올 수 없게 되는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"小镇惊魂","runtime":97,"tagline":"","homepage":"","overview":"高中生洁西卡、班尼、迪安、艾瑞克和琳达，打算用手机拍摄他们的冒险经历影片，只为了能在社群网站上获得人气。他们决定潜入一间有名的废弃公寓，琳达说服管理员让他们进去后，五人发现了一间被警用封锁线围起来的公寓，在好奇心驱使下他们闯入了公寓。他们四处搜索，并在房间裡发现了一张老旧的牛皮纸，身为唯一看得懂牛皮纸上文字的人，琳达朗读纸上咒语，一个神秘的入口突然出现…五人发现自己无意间打开了通往神秘世界的入口，不仅如此，还触怒了守护入口的超自然生物⋯。一场变调的试胆大会，唤醒了惊悚的灵异杀机，现在他们心中只剩下对死亡的恐惧、与回家的渴望……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"鬼入鏡：靈之鬼跡","runtime":97,"tagline":"","homepage":"","overview":"為了在社群的直播影片上獲得關注，一群高中生踏進荒廢已久的公寓，卻喚醒了惡靈，將把他們拖下地獄… 高中生潔西卡、班尼、迪安、艾瑞克和琳達，打算用手機拍攝他們的冒險經歷影片，只為了能在社群網站上獲得人氣。他們決定潛入一間有名的廢棄公寓，琳達說服管理員讓他們進去後，五人發現了一間被警用封鎖線圍起來的公寓，在好奇心驅使下他們闖入了公寓。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":97,"tagline":"","homepage":"","overview":"Un grupo de estudiantes se dirige a una zona en la que se produjo un asesinato ritual bajo extrañas circunstancias con el fin de obtener popularidad en las redes sociales."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":97,"tagline":"","homepage":"","overview":"Μια ομάδα μαθητών κατευθύνεται σε μια περιοχή όπου μια τελετουργική δολοφονία έλαβε χώρα υπό περίεργες συνθήκες για να κερδίσουν δημοτικότητα στα μέσα κοινωνικής δικτύωσης. Μέχρι που ανοίγουν μια πύλη στον μυστικιστικό κόσμο και εξοργίζουν τον φύλακα της πύλης."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Dom grozy","runtime":97,"tagline":"","homepage":"","overview":"Grupa znajomych, będąc w nawiedzonym apartamencie, przypadkiem otwiera tajemniczy portal, czym narażają się jego strażnikowi. Rozpoczyna się walka o przetrwanie."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"เกมท้าวิญญาณ","runtime":97,"tagline":"","homepage":"","overview":"กลุ่มเด็กมัธยมปลายตัดสินใจไลฟ์สดขณะเข้าไปเยือนอาคารหลอน แต่การกระทำครั้งนี้กลับกลายเป็นการเปิดทางสู่ขุมนรก"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":97,"tagline":"","homepage":"","overview":"Un groupe d'amis du lycée décide de se diffuser en direct dans un immeuble hanté, mais finit par ouvrir un portail vers l'enfer."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Toà Tháp Địa Ngục","runtime":97,"tagline":"","homepage":"","overview":"Một nhóm bạn trung học quyết định phát trực tiếp cảnh mình bên trong một tòa nhà chung cư bị ma ám nhưng cuối cùng lại mở ra cánh cổng dẫn đến Địa ngục."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":97,"tagline":"","homepage":"","overview":"Sekelompok siswa SMA memutuskan untuk membuat siaran langsung aktivitas mereka di dalam gedung apartemen berhantu, tetapi akhirnya mereka malah membuka portal ke neraka."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"","runtime":97,"tagline":"","homepage":"","overview":"Sekumpulan rakan sekolah memutuskan untuk membuat strim langsung di dalam sebuah bangunan pangsapuri berhantu, namun akhirnya membuka pintu neraka secara tidak sengaja."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"","runtime":97,"tagline":"","homepage":"","overview":"Sekumpulan rakan sekolah memutuskan untuk membuat strim langsung di dalam sebuah bangunan pangsapuri berhantu, namun akhirnya membuka pintu neraka secara tidak sengaja."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"SG","english_name":"Malay"},{"data":{"title":"小镇惊魂","runtime":97,"tagline":"","homepage":"","overview":"一群高中朋友决定进入一座闹鬼的公寓进行直播，结果却开启了通向地狱的大门。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"鬼入鏡：靈之鬼跡","runtime":0,"tagline":"","homepage":"","overview":"為了在社羣的直播影片上獲得關注，一羣高中生踏進荒廢已久的公寓，卻喚醒了惡靈，將把他們拖下地獄… 高中生潔西卡、班尼、迪安、艾瑞克和琳達，打算用手機拍攝他們的冒險經歷影片，只為了能在社羣網站上獲得人氣。他們決定潛入一間有名的廢棄公寓，琳達説服管理員讓他們進去後，五人發現了一間被警用封鎖線圍起來的公寓，在好奇心驅使下他們闖入了公寓。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":18252,"adult":false,"title":"My Science Project","video":false,"overview":"His high school teacher issues an ultimatum: turn in a science project or flunk. So Mike Harlan scavenges a military base's junk pile for a suitable gizmo. He finds one... and unwittingly unleashes the awesome power and energy of the unknown. Twisted dimensions. Time warps. A fantastic realm where the past, present, and future collide in a whirling vortex of startling adventure and superlative special effects.","genre_ids":[35,10751,14,878],"media_type":"movie","popularity":1.0539,"vote_count":152,"poster_path":"/pKPdD20G8fvlY6tFVjmJYdbgqQf.jpg","release_date":"1985-08-09","vote_average":6.204,"backdrop_path":"/2KDfY3QCRz23Xdi21Ey6ATa7Oe8.jpg","original_title":"My Science Project","original_language":"en"},{"id":47869,"adult":false,"title":"Hidden Agenda","video":false,"overview":"In Ireland, American lawyer Ingrid Jessner and her activist partner, Paul Sullivan, struggle to uncover atrocities committed by the British government against the Northern Irish during the \"Troubles.\" But when Sullivan is assassinated in the streets, Jessner teams up with Peter Kerrigan, a British investigator acting against the will of his own government, and struggles to uncover a conspiracy that may even implicate one of Kerrigan's colleagues.","genre_ids":[18,53],"media_type":"movie","popularity":0.5434,"vote_count":103,"poster_path":"/ceaYwvuTMfgRu7XCrLHmeK1LDzN.jpg","release_date":"1990-11-21","vote_average":7,"backdrop_path":"/7K6al25y1WBolpXO1RYjvhwYNBz.jpg","original_title":"Hidden Agenda","original_language":"en"},{"id":1136100,"adult":false,"title":"Unnatural Causes","video":false,"overview":"Whether it's bots in the bloodstream, a silent stranger by the road or even a single, all-consuming thought, death comes in peculiar forms in this wildly creative collection of shorts, offering five gruesome tales of the strange and the unnatural.","genre_ids":[27],"media_type":"movie","popularity":0.1625,"vote_count":1,"poster_path":"/w6VUCjkMHRmD5Vprh2xUcz1qeUp.jpg","release_date":"2023-05-05","vote_average":7,"backdrop_path":"/comK91kU07C97d15VqBCIotTtt9.jpg","original_title":"Unnatural Causes","original_language":"en"},{"id":412656,"adult":false,"title":"Chaos Walking","video":false,"overview":"Two unlikely companions embark on a perilous adventure through the badlands of an unexplored planet as they try to escape a dangerous and disorienting reality, where all inner thoughts are seen and heard by everyone.","genre_ids":[14,878,12],"media_type":"movie","popularity":5.053,"vote_count":2510,"poster_path":"/xAYGdGBGptNkisXRpmhZSry6SPF.jpg","release_date":"2021-02-24","vote_average":6.548,"backdrop_path":"/ovggmAOu1IbPGTQE8lg4lBasNC7.jpg","original_title":"Chaos Walking","original_language":"en"},{"id":431,"adult":false,"title":"Cube","video":false,"overview":"A group of strangers find themselves trapped in a maze-like prison. It soon becomes clear that each of them possesses the peculiar skills necessary to escape, if they don't wind up dead first.","genre_ids":[53,878,9648],"media_type":"movie","popularity":3.8821,"vote_count":5105,"poster_path":"/x4BTjxdrOKC27FcSkBh8KPEgnum.jpg","release_date":"1998-07-11","vote_average":6.812,"backdrop_path":"/3TimUBrXMVblpnTsyg4HssGVbBv.jpg","original_title":"Cube","original_language":"en"},{"id":503736,"adult":false,"title":"Army of the Dead","video":false,"overview":"Following a zombie outbreak in Las Vegas, a group of mercenaries take the ultimate gamble: venturing into the quarantine zone to pull off the greatest heist ever attempted.","genre_ids":[80,28,27],"media_type":"movie","popularity":4.4871,"vote_count":4320,"poster_path":"/gCIsRxzcxvmuLYeAvWgoOuSxszF.jpg","release_date":"2021-05-14","vote_average":6.218,"backdrop_path":"/c0izdYdnTe4uMRifHgvTA85wPz0.jpg","original_title":"Army of the Dead","original_language":"en"},{"id":305470,"adult":false,"title":"Power Rangers","video":false,"overview":"Five ordinary teens must become something extraordinary when they learn that their small town of Angel Grove — and the world — is on the verge of being obliterated by an alien threat. Chosen by destiny, our heroes quickly discover they are the only ones who can save the planet. But to do so, they will have to overcome their real-life issues and before it’s too late, band together as the Power Rangers.","genre_ids":[28,12,878],"media_type":"movie","popularity":4.4318,"vote_count":4577,"poster_path":"/bKYKyyIv5YnisxjZtDreWtYA386.jpg","release_date":"2017-03-23","vote_average":6.252,"backdrop_path":"/2vcdZBbf7sPPzIHfN5ial24UbxK.jpg","original_title":"Power Rangers","original_language":"en"},{"id":76600,"adult":false,"title":"Avatar: The Way of Water","video":false,"overview":"Set more than a decade after the events of the first film, learn the story of the Sully family (Jake, Neytiri, and their kids), the trouble that follows them, the lengths they go to keep each other safe, the battles they fight to stay alive, and the tragedies they endure.","genre_ids":[28,12,878],"media_type":"movie","popularity":36.0964,"vote_count":13745,"poster_path":"/t6HIqrRAclMCA60NsSmeqe9RmNV.jpg","release_date":"2022-12-14","vote_average":7.598,"backdrop_path":"/cd8YDn7M0lfaHhZdU6MvCDxPalP.jpg","original_title":"Avatar: The Way of Water","original_language":"en"},{"id":11357,"adult":false,"title":"Halloween 4: The Return of Michael Myers","video":false,"overview":"Ten years after his original massacre, the invalid Michael Myers awakens on Halloween Eve and returns to Haddonfield to kill his seven-year-old niece.","genre_ids":[27,53],"media_type":"movie","popularity":2.1336,"vote_count":2027,"poster_path":"/eFSOkXF9n9hsfGv45MDsPixiOyx.jpg","release_date":"1988-10-21","vote_average":6.174,"backdrop_path":"/zE4I9YvrrMUfwDZ3zLiN10eRZxG.jpg","original_title":"Halloween 4: The Return of Michael Myers","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":28.4976,"vote_count":26824,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.9,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":264660,"adult":false,"title":"Ex Machina","video":false,"overview":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl.","genre_ids":[18,878],"media_type":"movie","popularity":7.9469,"vote_count":14040,"poster_path":"/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg","release_date":"2015-01-21","vote_average":7.573,"backdrop_path":"/uqOuJ50EtTj7kkDIXP8LCg7G45D.jpg","original_title":"Ex Machina","original_language":"en"},{"id":297222,"adult":false,"title":"PK","video":false,"overview":"A stranger in the city asks questions no one has asked before. Known only by his initials, the man's innocent questions and childlike curiosity take him on a journey of love, laughter and letting go.","genre_ids":[35,18,878],"media_type":"movie","popularity":6.4022,"vote_count":1122,"poster_path":"/z2x2Y4tncefsIU7h82gmUM5vnBJ.jpg","release_date":"2014-12-18","vote_average":7.698,"backdrop_path":"/gxfvtq5eYiClS2X7hxAAPBNrbWA.jpg","original_title":"पीके","original_language":"hi"},{"id":17654,"adult":false,"title":"District 9","video":false,"overview":"Thirty years ago, aliens arrive on Earth. Not to conquer or give aid, but to find refuge from their dying planet. Separated from humans in a South African area called District 9, the aliens are managed by Multi-National United, which is unconcerned with the aliens' welfare but will do anything to master their advanced technology. When a company field agent contracts a mysterious virus that begins to alter his DNA, there is only one place he can hide: District 9.","genre_ids":[878],"media_type":"movie","popularity":6.9108,"vote_count":10149,"poster_path":"/tuGlQkqLxnodDSk6mp5c2wvxUEd.jpg","release_date":"2009-08-05","vote_average":7.461,"backdrop_path":"/jhM3wgWUrrOkz9r4xwV5cV5RhI4.jpg","original_title":"District 9","original_language":"en"},{"id":2108,"adult":false,"title":"The Breakfast Club","video":false,"overview":"Five high school students from different walks of life endure a Saturday detention under a power-hungry principal. The disparate group includes rebel John, princess Claire, outcast Allison, brainy Brian and Andrew, the jock. Each has a chance to tell his or her story, making the others see them a little differently -- and when the day ends, they question whether school will ever be the same.","genre_ids":[35,18],"media_type":"movie","popularity":5.7903,"vote_count":8414,"poster_path":"/gp4zlj7wgbiofLMNsTPndMuO3PN.jpg","release_date":"1985-02-15","vote_average":7.725,"backdrop_path":"/kjVgUMsG0PKBXzlP8HGNQpWDxAX.jpg","original_title":"The Breakfast Club","original_language":"en"},{"id":14,"adult":false,"title":"American Beauty","video":false,"overview":"Lester Burnham, a depressed suburban father in a mid-life crisis, decides to turn his hectic life around after developing an infatuation with his daughter's attractive friend.","genre_ids":[18],"media_type":"movie","popularity":10.4774,"vote_count":12825,"poster_path":"/wby9315QzVKdW9BonAefg8jGTTb.jpg","release_date":"1999-09-15","vote_average":8.002,"backdrop_path":"/2ndw55F40IkALzWyjCCza3M6nqM.jpg","original_title":"American Beauty","original_language":"en"},{"id":8874,"adult":false,"title":"My Best Friend's Wedding","video":false,"overview":"When she receives word that her longtime platonic pal Michael O'Neal is getting married to debutante Kimberly Wallace, food critic Julianne Potter realizes her true feelings for Michael -- and sets out to sabotage the wedding.","genre_ids":[35,10749],"media_type":"movie","popularity":3.731,"vote_count":2834,"poster_path":"/b5g4bp8gS5ovMyR5439AII6zQ3n.jpg","release_date":"1997-06-19","vote_average":6.565,"backdrop_path":"/naA6aqGYh8D8x2pODBAvFiqwuJh.jpg","original_title":"My Best Friend's Wedding","original_language":"en"},{"id":16780,"adult":false,"title":"The Return of the Texas Chainsaw Massacre","video":false,"overview":"A group of teenagers get into a car crash in the Texas woods on prom night, and then wander into an old farmhouse that is home to Leatherface and his insane family of cannibalistic psychopaths.","genre_ids":[27,35],"media_type":"movie","popularity":4.8424,"vote_count":737,"poster_path":"/e1ikqofvLBddrZJ73IjmJWhUYus.jpg","release_date":"1995-09-22","vote_average":4.575,"backdrop_path":"/eZvVoJc3XrAE81bmNhtyTUDti8b.jpg","original_title":"The Return of the Texas Chainsaw Massacre","original_language":"en"},{"id":138843,"adult":false,"title":"The Conjuring","video":false,"overview":"Paranormal investigators Ed and Lorraine Warren work to help a family terrorized by a dark presence in their farmhouse. Forced to confront a powerful entity, the Warrens find themselves caught in the most terrifying case of their lives.","genre_ids":[27,53],"media_type":"movie","popularity":10.489,"vote_count":12515,"poster_path":"/wVYREutTvI2tmxr6ujrHT704wGF.jpg","release_date":"2013-07-18","vote_average":7.539,"backdrop_path":"/aQCCpAIdWAp6wyFgjMry4okwrZo.jpg","original_title":"The Conjuring","original_language":"en"},{"id":424694,"adult":false,"title":"Bohemian Rhapsody","video":false,"overview":"Singer Freddie Mercury, guitarist Brian May, drummer Roger Taylor and bass guitarist John Deacon take the music world by storm when they form the rock 'n' roll band Queen in 1970. Hit songs become instant classics. When Mercury's increasingly wild lifestyle starts to spiral out of control, Queen soon faces its greatest challenge yet – finding a way to keep the band together amid the success and excess.","genre_ids":[10402,18],"media_type":"movie","popularity":8.5334,"vote_count":17564,"poster_path":"/lHu1wtNaczFPGFDTrjCSzeLPTKN.jpg","release_date":"2018-10-24","vote_average":7.961,"backdrop_path":"/dcvbs8z0GEXslC1kCT77x19XDeR.jpg","original_title":"Bohemian Rhapsody","original_language":"en"},{"id":603,"adult":false,"title":"The Matrix","video":false,"overview":"Set in the 22nd century, The Matrix tells the story of a computer hacker who joins a group of underground insurgents fighting the vast and powerful computers who now rule the earth.","genre_ids":[28,878],"media_type":"movie","popularity":22.54,"vote_count":27417,"poster_path":"/p96dm7sCMn4VYAStA6siNz30G1r.jpg","release_date":"1999-03-31","vote_average":8.238,"backdrop_path":"/tlm8UkiQsitc8rSuIAscQDCnP8d.jpg","original_title":"The Matrix","original_language":"en"}],"similar_content":[{"id":1297599,"adult":false,"title":"Sweet Brother","video":false,"overview":"Ensnared in a fairytale of his own making, a pious and mysterious wanderer who calls himself ‘Jude’, is forced to confront the depths of his own darkness as he dances upon the precipice of dreams and reality. In 'Hell', Jude will come to learn that it is only through his own painful metamorphosis, that he can ever hope to find the path to salvation.","genre_ids":[14,18,27],"popularity":2.123,"vote_count":0,"poster_path":null,"release_date":"","vote_average":0,"backdrop_path":null,"original_title":"Sweet Brother","original_language":"en"},{"id":705683,"adult":false,"title":"Altun Paltun","video":false,"overview":"Altun Paltun is a Marathi horror comedy film starring Ashok Saraf and Bhalchandra Kadam. Dhananjay and Yashwant are thrilled after purchasing a new house at a very reasonable cost. However, the brothers’ excitement soon turns into horror when they discover that the house is haunted.","genre_ids":[27,35],"popularity":0.2345,"vote_count":0,"poster_path":"/ktzh0rgoVuvINorZwzloWhrvy1F.jpg","release_date":"2020-04-28","vote_average":0,"backdrop_path":null,"original_title":"Altun Paltun","original_language":"mr"},{"id":48660,"adult":false,"title":"The Kindred","video":false,"overview":"Amanda's deathbed request to her son, John, was for him to destroy all the lab notes etc. from her last experiment. She also blurts out he had a brother. At the funeral John meets Melissa, who claims to be his mother's biggest fan. Together with some of John's friends they go to Amanda's house, but none are prepared for what they find there.","genre_ids":[27,878],"popularity":0.9298,"vote_count":77,"poster_path":"/bDMUr5IQWAwUpFZFFxltLuAIb7N.jpg","release_date":"1987-01-09","vote_average":6,"backdrop_path":"/kYZNaF79kwGb8RceJV7Q2EifKJG.jpg","original_title":"The Kindred","original_language":"en"},{"id":48668,"adult":false,"title":"Fragment","video":false,"overview":"When Lloyd, a photographer slowly dying of a brain tumor, realises the growth killing him is breathing life into the recently dead, he uses his camera lens as the conduit to reanimation. After discovering a disturbing snuff film of a beautiful naked woman being tortured and murdered, he is compelled to bring her back to life. Enchanted by her grace and charm he resurrects her night after night and gradually falls in love. However, each night Lloyd also unwittingly resurrects her killer... SHAPE.","genre_ids":[18,53],"popularity":0.1296,"vote_count":8,"poster_path":"/kKPyJkCTbfaKtgtSnkGALjFcVTN.jpg","release_date":"2009-08-09","vote_average":3.7,"backdrop_path":null,"original_title":"Fragment","original_language":"en"},{"id":48669,"adult":false,"title":"Terror Trap","video":false,"overview":"While driving, an estranged couple's car is hit twice. A sheriff takes them to a motel where they hear disturbing noises from a room, realizing they're part of a deadly game.","genre_ids":[27,53],"popularity":2.0569,"vote_count":63,"poster_path":"/gab9aBrD8fxP2NveitSzOEP4rfV.jpg","release_date":"2010-09-22","vote_average":4.8,"backdrop_path":"/lIitoSriIAUanELQlMJaJQtJfxL.jpg","original_title":"Terror Trap","original_language":"en"},{"id":313219,"adult":false,"title":"Grasshopper","video":false,"overview":"Movie contains the stories of three people: Suzuki (Toma Ikuta), Kujira (Tadanobu Asano) and Semi (Ryosuke Yamada).  Suzuki is a former middle school teacher. His girlfriend was killed, which led him to quit his job and attempt to take revenge on her murderer. To do so, Suzuki has to infiltrate the underground world of criminals. Kujira is a contract killer for hire. He makes his targets fall into confusion and eventually commit suicide. Semi is a contract killer who uses the knife to take out his targets.","genre_ids":[80,53,28,18],"popularity":0.6213,"vote_count":15,"poster_path":"/h9YkeTwcSnep0ZvEA6U5KtqCzb5.jpg","release_date":"2015-11-07","vote_average":5.933,"backdrop_path":"/44L1vTmftGyK0aRtKFJMAMHsEc4.jpg","original_title":"グラスホッパー","original_language":"ja"},{"id":48675,"adult":false,"title":"Small Town Folk","video":false,"overview":"High above the tiny hamlet of Grockleton stands Beesley Manor, home to the ominous Landlord and his...shall we say, genetically ambiguent...minions, including Pooch, a cross-eyed marksman, and Dobbin, who likes to drink gasoline. The Landlord keeps a watchful eye over his domain, brutally dispatching any strangers who enter - except for females he needs to (involuntarily) sire a Beesley heir...When three unsuspecting travelers arrive, the Landlord plans to make two of them his trophies and the other his bride...unless they can beat him at his own game.","genre_ids":[27],"popularity":0.2187,"vote_count":22,"poster_path":"/qkWuQnWlopK9FdEiVAK4vJBAuMJ.jpg","release_date":"2007-01-01","vote_average":3.2,"backdrop_path":null,"original_title":"Small Town Folk","original_language":"en"},{"id":48682,"adult":false,"title":"Infection","video":false,"overview":"A mutant hero, a virtual bank heist. A digital action thriller. A three fingered virus is let loose on a computer system with the express purpose of erasing a student loan.","genre_ids":[53,14,878,16],"popularity":0.0916,"vote_count":3,"poster_path":"/yVrsoMEHHT1U6HigCiOOEum7izG.jpg","release_date":"2000-01-01","vote_average":5.7,"backdrop_path":"/uh3UFimz6CYbxBsQznc1Qpx9kHd.jpg","original_title":"Infection","original_language":"en"},{"id":48686,"adult":false,"title":"Assassination","video":false,"overview":"Jay Killon is the bodyguard of the recently elected US president, but he is assigned to the first lady (Lara Royce). Lara hates Killon so she does all she can to escape. The story complicates when someone tries to kill Lara.","genre_ids":[28,53],"popularity":0.5663,"vote_count":91,"poster_path":"/5wGAfVATbWAL6g91XMnMZeMKz5F.jpg","release_date":"1987-01-09","vote_average":5.61,"backdrop_path":"/ivpVT0V3gt8FZQ5Dafx2BQ7tLaT.jpg","original_title":"Assassination","original_language":"en"},{"id":48691,"adult":false,"title":"Goodbye Uncle Tom","video":false,"overview":"Two documentary filmmakers go back in time to the pre-Civil War American South, to film the slave trade.","genre_ids":[18,80,27],"popularity":1.127,"vote_count":70,"poster_path":"/nLw410E9rnJw13kufNgOtjiGvGk.jpg","release_date":"1971-09-23","vote_average":6.6,"backdrop_path":"/qMYvxKZ4ocJbU32bZvFVft7ZjJz.jpg","original_title":"Addio zio Tom","original_language":"it"},{"id":901140,"adult":false,"title":"Impulse","video":false,"overview":"Set in 2020 in the Shibuya neighborhood of Tokyo, the story revolves around Hachi, a boy who fled to the Japanese capital from his hometown of Fukushima and now lives away from society as an illegal drug dealer.","genre_ids":[18,53],"popularity":0.1767,"vote_count":2,"poster_path":"/f0upvJYkKhJusm8uukIez