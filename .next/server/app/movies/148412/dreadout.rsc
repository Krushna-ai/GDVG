ate":"2021-04-28","vote_average":5.8,"backdrop_path":"/jq09EVjtlyQgp9kjF5O6SBtdfbH.jpg","original_title":"Dietro la notte","original_language":"it"},{"id":1297344,"adult":false,"title":"Nocturnos","video":false,"overview":"Three stories about vampires intertwined during a night in the city of Buenos Aires.","genre_ids":[27],"popularity":0.694,"vote_count":0,"poster_path":"/nOUyvjt7YNw0tVkBLQPqkU7xdI9.jpg","release_date":"2008-11-01","vote_average":0,"backdrop_path":null,"original_title":"Nocturnos","original_language":"en"},{"id":513297,"adult":false,"title":"Fear Level","video":false,"overview":"Increased level of fear, six colliding stories, one roller coaster ride of emotions and terror. What would you do if you caught your significant other in the act or was face to face with your abductors? With twists and turns at every corner you will have the ride of your life on this journey. A journey where you will be dying to find out the unknown. Where curiosity kills the cat and a seductive mistake can be your last. What level are you?","genre_ids":[27],"popularity":0.1224,"vote_count":7,"poster_path":"/oj7gQO0Aw6G8F3JeEidT0Ina86i.jpg","release_date":"2018-05-25","vote_average":3.571,"backdrop_path":"/AuFHevt9J4eSIeQu87wCUfE2ES.jpg","original_title":"Fear Level","original_language":"en"},{"id":48381,"adult":false,"title":"Savage Messiah","video":false,"overview":"As a small-town social worker investigates a commune headed by a spiritual leader calling himself Moses, she discovers a dead child, sadistic rituals, and ruthless mental and physical abuse.","genre_ids":[18,53],"popularity":0.5964,"vote_count":25,"poster_path":"/wfFaCct1TWjnIHSu79qnp8IcnYB.jpg","release_date":"2002-04-26","vote_average":5.3,"backdrop_path":"/edeSUOYacNFzwT3anFI3HL8xZoo.jpg","original_title":"Savage Messiah","original_language":"en"},{"id":48385,"adult":false,"title":"Indestructible Man","video":false,"overview":"A scientific experiment involving subjecting a corpse to an extreme charge of electricity accidentally revives an executed criminal and makes him impervious to harm, allowing him to seek revenge on his former partners, and deal similarly with anyone else who gets in his way.","genre_ids":[80,27,878],"popularity":0.5038,"vote_count":54,"poster_path":"/kcD0kG86GK2mUHjNf6QoDfwtnxd.jpg","release_date":"1956-03-24","vote_average":4.25,"backdrop_path":"/3bAoBfuCIVbIRLOBL8Nqerdycuz.jpg","original_title":"Indestructible Man","original_language":"en"},{"id":1109006,"adult":false,"title":"Bitter Night","video":false,"overview":"Bitter Night follows an unfortunate man throughout his wild night of events.","genre_ids":[12,53,18,28],"popularity":0.3098,"vote_count":1,"poster_path":"/5mS4K8aBRczjjl7tJpeA9eTPE6D.jpg","release_date":"2023-04-04","vote_average":10,"backdrop_path":"/3C9azOOblaZJfEJ0Ko0ZgGl75Lt.jpg","original_title":"Bitter Night","original_language":"en"}],"external_ids":{"imdb_id":"tt9435162","twitter_id":null,"facebook_id":null,"wikidata_id":"Q61366042","instagram_id":null,"mydramalist_id":"319067"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148412,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"ID","release_dates":[{"note":"","type":3,"iso_639_1":"id","descriptors":[],"release_date":"2019-01-03T00:00:00.000Z","certification":"17+"}]},{"iso_3166_1":"KR","release_dates":[{"note":"Bucheon International Fantastic Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2019-06-30T00:00:00.000Z","certification":""},{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2019-11-12T00:00:00.000Z","certification":""}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":"DreadOut","filming_location":"Indonesia","narrative_location":"Indonesia","review_score_rt":null,"review_score_mc":nul