_path":"/eLmgUhf5rUP92pwGbOBpZV9UUKr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1422,"height":800,"file_path":"/nBOXHar4P720uvdlxxV6NEtiV3L.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1422,"height":800,"file_path":"/iU9hEjstPMfep1BqfwrNiqdkN8u.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1422,"height":800,"file_path":"/iARLjZfgRvEIPCGtgxyUzSZgZ8t.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:16:54.334+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"18x2 Beyond Youthful Days","runtime":124,"tagline":"","homepage":"https://happinet-phantom.com/seishun18x2/","overview":"Having lost his job and the company he built, a 36-year-old man at rock bottom goes on a wistful solo trip to Japan in search of the love he left behind."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"青春18×2 通往有你的旅程","runtime":124,"tagline":"我能擁有夢想，都是因為遇見你。","homepage":"","overview":"18年前的台灣――高中生 Jimmy 打工的地方出現了一位大他四歲、從日本來的背包客女孩Ami。兩人整個夏天都在同一家店打工，漸漸地 Jimmy 對 Ami 萌生純純的愛意。他們共乘機車夜遊、看電影，就在距離越來越近的時候，Ami突然要回日本。看著難以接受的 Jimmy，Ami 提出了「某個約定」。  ​  時光飛逝，Jimmy 因故回到久未進門的老家，他在房間內找到18年前Ami從日本寄來的明信片。初戀的記憶湧上心頭， Jimmy 決定要好好面對過去、審視現在的自己，因此展開第一次在日本的單人旅行。Jimmy 聽著和 Ami 有共通回憶的歌曲，坐火車前往她的故鄉。究竟 Jimmy 和 Ami 能夠再次相遇嗎？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"青春18x2 君へと続く道","runtime":0,"tagline":"","homepage":"https://happinet-phantom.com/seishun18x2/","overview":"始まりは18年前の台湾――  高校生・ジミーのバイト先に現れた日本から来た4つ年上のバックパッカー・アミ。ひと夏を同じ店で働き過ごすことになった2人だったが、次第にジミーはアミに淡い恋心を抱いていく。夜道をバイクで2人乗りしたり、映画を観に行ったり、2人の距離は縮まっていったが、突然、アミが日本に帰ることに。気持ちの整理がつかないジミーに、アミは“ひとつの約束”を提案する。  時が経ち、あるきっかけで久々に実家を訪れたジミーは、日本に戻ったアミから18年前に届いたハガキを見つける。  初恋の記憶がよみがえったジミーは、過去と向き合い、今を見つめるため、初めての日本での一人旅へ。アミとの思い出の曲を聞きながら列車に乗り、ジミーが向かうのは彼女の故郷。  ジミーはアミとの再会を果たせるのか―。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"错过你的那些年","runtime":120,"tagline":"","homepage":"","overview":"36 岁的他失去工作和自己一手成立的公司，在人生跌到谷底后，决定到日本惆怅独旅，寻找早已被他抛在脑后的爱情。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"청춘 18X2 너에게로 이어지는 길","runtime":125,"tagline":"너를 처음 만났던 그 여름을 나는 사랑했어","homepage":"","overview":"18년 전의 대만 타이난. 노래방에서 아르바이트를 하는 고등학생 ‘지미’는, 배낭여행 중 잠시 일자리를 찾아 온 일본인 ‘아미’를 만난다. 천진난만한 그녀와 지내는 동안 풋풋한 첫사랑의 감정이 자라는 ‘지미’. 그러나, 돌연 ‘아미’가 귀국을 하게 되고 갑작스런 이별에 충격을 받은 ‘지미’에게 ‘아미’는 서로의 꿈을 이룬 뒤 다시 만나자는 약속을 하고 떠난다. 시간이 지나 현재. 타이페이에서의 성공한 삶에 지쳐 고향에 돌아온 ‘지미’는, 예전에 ‘아미’로부터 받은 그림엽서를 발견한다. 첫사랑의 기억이 되살아나고 그날의 약속을 지키기 위해 그녀가 나고 자란 일본으로의 여행을 결심하는 ‘지미’. 도쿄부터 가마쿠라, 나가노, 니가타 그리고 ‘아미’의 고향 타다미로 향하는 도중 예기치 않았던 소중한 만남을 되풀이하며 ‘지미’는 ‘아미’와 보냈던 그 여름의 나날들을 떠올린다. 이윽고 다다른 ‘아미’의 고향에서 ‘지미’가 알게 된 18년 전 ‘아미’의 진짜 마음이란..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"青春 18x2 君へと續く道","runtime":124,"tagline":"","homepage":"","overview":"18 年前高中生家銘 Jimmy（許光漢 飾）打工的地方出現了一位大他四歲、從日本來的揹包客女孩 Ami（清原果耶 飾）。兩人夏天一起打工，漸漸地 Jimmy 對 Ami 萌生純純的愛意。就在距離越來越近的時候，Ami 突然要回日本。看著難以接受的 Jimmy，Ami 提出了「某個約定」。時光飛逝，Jimmy 回到久未進門的老家，在房間內找到 18 年前 Ami 從日本寄來的明信片。初戀的記憶湧上心頭，決定展開第一次在日本的單人旅行。Jimmy 聽著和 Ami 有共通回憶的歌曲，坐火車前往她的故鄉。究竟 Jimmy 和 Ami 能夠再次相遇嗎？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"18×2 Beyond Youthful Days","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"18×2 BEYOND YOUTHFUL DAYS - 2024","runtime":0,"tagline":"","homepage":"","overview":""},"name":"","iso_639_1":"my","iso_3166_1":"MY","english_name":"Burmese"},{"data":{"title":"รักเรายังคิดถึง","runtime":123,"tagline":"","homepage":"","overview":"เล่าย้อนกลับไป 18 ปีก่อนที่ไต้หวัน จิมมี่นักเรียนม.ปลาย ได้พบเจอกับ อามิ แบคแพคเกอร์สาวจากญี่ปุ่น ที่ทำงานพาร์ทไทม์  พวกเขาทั้งสองได้ทำงานด้วยกันตลอดช่วงฤดูร้อน และจิมมี่ก็ได้ตกหลุมรัก แต่จู่ๆ อามิก็ตัดสินใจว่าจะเดินทางกลับญี่ปุ่น เวลาผ่านไปหลายปี จิมมี่ก็ได้เจอโปสการ์ดที่เขาได้รับจากอามิเมื่อ 18 ปีก่อน ความทรงจำของรักครั้งแรกก็ย้อนกลับมา และทำให้เขาตัดสินใจเดินทางมาญี่ปุ่นเพื่อตามหารักแรกที่เขาไม่เคยได้พูดคำว่ารักบอกเธอ"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"18 Anos Depois","runtime":124,"tagline":"","homepage":"","overview":"No fundo do poço depois de perder o emprego e a empresa que ele próprio criou, um homem de 36 anos viaja sozinho ao Japão para tentar reencontrar um amor do passado."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Ami, seorang backpacker Jepang, dan Jimmy bekerja bersama di sebuah KTV. Mereka terikat melalui pekerjaan dan petualangan, tetapi Ami tiba-tiba pergi. Delapan belas tahun kemudian, Jimmy menemukan kartu pos dari Ami, memicu perjalanan ke Jepang untuk menemukan penutupan dan terhubung kembali."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"Thanh xuân 18×2: Lữ trình hướng về em","runtime":124,"tagline":"","homepage":"","overview":"Thanh xuân 18×2: Lữ trình hướng về em là bộ phim điện ảnh thuộc thể loại lãng mạn hợp tác giữa hai nước Nhật Bản và Đài Loan. Bộ phim được đạo diễn bởi Michihito Fujii cùng với sự tham gia diễn xuất của hai diễn viên chính là Hứa Quang Hán và Kiyohara Kaya."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"}],"reviews_tmdb":[],"recommendations":[{"id":597165,"adult":false,"title":"1","video":false,"overview":"Three stories, two people, and one outcome. A couple's third date is seen in three different situations where, despite their best efforts, nothing seems to go right. She hasn't gotten over a past relationship; he simply seems unlucky in love. Both will try to break free from their circumstances, only to encounter failure and discontent, which seems to seal their fate.","genre_ids":[18],"media_type":"movie","popularity":0.1463,"vote_count":34,"poster_path":"/3STr1Eo7219SSx3qeIvOuQxhKgx.jpg","release_date":"2008-06-01","vote_average":5.9,"backdrop_path":"/rkzmqqN9ZffdXJcuHfXgk4ge2I0.jpg","original_title":"1","original_language":"es"},{"id":20220,"adult":false,"title":"1001 Nights","video":false,"overview":"Sheherazade has been married to a ruler who wants many wives, but only one at a time. Consequently, as soon as he has bedded them, he has them put to death. In most retellings, the girl staves off this unfortunate conclusion by putting off the connubial event for a thousand and one nights, telling irresistible stories instead. In this one, she gets hold of a magic lamp.","genre_ids":[14,35,12],"media_type":"movie","popularity":1.4629,"vote_count":61,"poster_path":"/wFubQZcMS5ZEPX3kf1XatDQPAmy.jpg","release_date":"1990-04-11","vote_average":5.041,"backdrop_path":"/vzF3VTGRMd4Iz7VDCvZyTqfy6Pe.jpg","original_title":"Les 1001 nuits","original_language":"fr"},{"id":20342,"adult":false,"title":"Secret","video":false,"overview":"Ye Xiang Lun, a talented piano player is a new student at the prestigious Tamkang School. On his first day, he meets Lu Xiao Yu, a pretty girl playing a mysterious piece of music.","genre_ids":[14,18,53],"media_type":"movie","popularity":1.6215,"vote_count":203,"poster_path":"/pOqdX6e4y2F9JTyoe4qorBtXVaR.jpg","release_date":"2007-07-27","vote_average":7.6,"backdrop_path":"/gm9REvuEjb3p2gylDsAzoT1G0r7.jpg","original_title":"不能說的秘密","original_language":"zh"},{"id":757770,"adult":false,"title":"The First People's City Found By The Chinese Communist Party","video":false,"overview":"With the continuous advancement of artillery fire in 1947, Yangquan was liberated, and the Chinese Communist Party established its own city in ruins, becoming the first people's city created by the leadership of the Chinese Communist Party. The whole film takes the construction of the city as the main line, with the elimination of enemy agents and personal emotions as the secondary line, and narrates the liberation and construction of Yangquan as a reference for other cities across the country. It has shaped the revolutionary heroism of the Communists represented by Ren Gong and Liu Shuihe in the process of building the people's city, and the responsibility of not forgetting the original intention and keeping the mission in mind","genre_ids":[18,10752],"media_type":"movie","popularity":0.1394,"vote_count":1,"poster_path":"/dysS7Z13MDOFO02AJEpxWh0j8gM.jpg","release_date":"2019-12-19","vote_average":5,"backdrop_path":"/yVCQn9RlfrGY0ruFvzL4Bvvcr9w.jpg","original_title":"铁血阳泉","original_language":"zh"},{"id":727010,"adult":false,"title":"Mama","video":false,"overview":"The story follows twelve-year-old Xiaoxian's memories of her family and her village. During seven days, the girl witnesses three deaths and two births, including the death of her own mother, who dies giving birth to her fourth sister.","genre_ids":[18],"media_type":"movie","popularity":0.3128,"vote_count":3,"poster_path":"/ql2FGYSwOnZOPh4D4vqFSeRMmXt.jpg","release_date":"2024-05-08","vote_average":8,"backdrop_path":"/8Kioosz3faHgQVzEB54DrOXoD2G.jpg","original_title":"妈妈和七天的时间","original_language":"zh"},{"id":1212742,"adult":false,"title":"The Rule of Jenny Pen","video":false,"overview":"Confined to a secluded rest home and trapped within his stroke-ridden body, a former Judge must stop an elderly psychopath who employs a child's puppet to abuse the home's residents with deadly consequences.","genre_ids":[27,53],"media_type":"movie","popularity":15.0112,"vote_count":132,"poster_path":"/5vqK1wbrgmUvqHn6yPt9b6qT9iL.jpg","release_date":"2025-03-07","vote_average":6.11,"backdrop_path":"/eftVUg9R1lys3wT8kHJqMaK64m7.jpg","original_title":"The Rule of Jenny Pen","original_language":"en"},{"id":1279294,"adult":false,"title":"Dear Family","video":false,"overview":"Nobumasa Tsuboi (Yo Oizumi) runs a small factory in a small town. He has a daughter Yoshimi Tsuboi (Riko Fukumoto) who suffers from a congenital heart disease. A doctor tells Nobumasa Tsuboi that his daughter will only live for about 10 more years. Nobumasa Tsuboi is devastated that his daughter won't live past the ago of 20. Nobumasa Tsuboi and his wife Yoko Tsuboi (Miho Kanno) cannot accept the diagnosis. Even though he has no medical knowledge or experience, Nobumasa Tsuboi begins to study about artificial hearts.","genre_ids":[18,10751],"media_type":"movie","popularity":0.758,"vote_count":7,"poster_path":"/6TiD1JCaAuISwadMsRhnvLQYmJl.jpg","release_date":"2024-06-14","vote_average":8,"backdrop_path":"/pockhPln4FIa4Y2QtBPra4guWQT.jpg","original_title":"ディア・ファミリー","original_language":"ja"},{"id":1124193,"adult":false,"title":"To My Star","video":true,"overview":"Actor Kang Seo Joon was once one of South Korea’s biggest and most popular stars, but his career is now in decline. But despite his fall in popularity, he believes he has had a change of fortune when he meets and falls for a dashing young chef named Han Ji Woo.","genre_ids":[18,35,10749],"media_type":"movie","popularity":0.3307,"vote_count":3,"poster_path":"/9JUz8jhZyBgl5jS42vcqQiRMJdI.jpg","release_date":"2021-03-05","vote_average":7.7,"backdrop_path":"/p5dQVQetjMJNZFiNDvQgzm8rb4b.jpg","original_title":"나의 별에게","original_language":"ko"},{"id":925293,"adult":false,"title":"Dwelling by the West Lake","video":false,"overview":"A mother and her son living amid economic turbulence in the beautiful Chinese green tea-farming landscape.","genre_ids":[18],"media_type":"movie","popularity":0.5487,"vote_count":8,"poster_path":"/a8X7hMZIqwn8nRl1wKyBTakE0Yh.jpg","release_date":"2024-04-03","vote_average":5.1,"backdrop_path":"/sFeFWK3SI662yC2sx4clmWttWVj.jpg","original_title":"草木人间","original_language":"zh"},{"id":991190,"adult":false,"title":"Gold Kingdom and Water Kingdom","video":false,"overview":"Once upon a time, there were two neighboring countries that did not get along.  They bickered over trivial things day in and day out. Finally, they went to war over the issue of cleaning up dog feces. God intervened in a hurry and said to the chiefs of the two countries. Country A gives its most beautiful girl to Country B as a bride and Country B gives its wisest young man to Country A as a bridegroom. Then, the princess of country A, Saara, happens to meet a young man from country B...!","genre_ids":[16,10749,14],"media_type":"movie","popularity":1.1134,"vote_count":7,"poster_path":"/xZo0wYhHvniCqVHMcCV7z1qB1XY.jpg","release_date":"2023-01-27","vote_average":6.714,"backdrop_path":"/6tW0O03jlSSHy6K5tYig1Qmo00o.jpg","original_title":"金の国 水の国","original_language":"ja"},{"id":1294203,"adult":false,"title":"My Fault: London","video":false,"overview":"18-year-old Noah moves from America to London, with her mother who's recently fallen in love with William, a wealthy British businessman. Noah meets William’s son, bad-boy Nick, and soon discovers there is an attraction between them neither can avoid. As Noah spends the summer adjusting to her new life, her devastating past will catch up with her while falling in love for the first time.","genre_ids":[18,10749],"media_type":"movie","popularity":9.196,"vote_count":529,"poster_path":"/ttN5D6GKOwKWHmCzDGctAvaNMAi.jpg","release_date":"2025-02-12","vote_average":7.407,"backdrop_path":"/uJK0jjJ8QDOQw5lcNBwu059ht4D.jpg","original_title":"My Fault: London","original_language":"en"},{"id":618588,"adult":false,"title":"Arthur the King","video":false,"overview":"Over the course of ten days and 435 miles, an unbreakable bond is forged between pro adventure racer Michael Light and a scrappy street dog companion dubbed Arthur. As the team is pushed to their outer limits of endurance in the race, Arthur redefines what victory, loyalty and friendship truly mean.","genre_ids":[12,18],"media_type":"movie","popularity":2.9954,"vote_count":892,"poster_path":"/zkKB3kOun5DKAkm61pHvLbrjxfa.jpg","release_date":"2024-02-22","vote_average":7.555,"backdrop_path":"/jw4SNkaSgbrO7VJPsZUZqbBg1Ph.jpg","original_title":"Arthur the King","original_language":"en"},{"id":423,"adult":false,"title":"The Pianist","video":false,"overview":"The true story of pianist Władysław Szpilman's experiences in Warsaw during the Nazi occupation. When the Jews of the city find themselves forced into a ghetto, Szpilman finds work playing in a café; and when his family is deported in 1942, he stays behind, works for a while as a laborer, and eventually goes into hiding in the ruins of the war-torn city.","genre_ids":[18,10752],"media_type":"movie","popularity":9.4783,"vote_count":9933,"poster_path":"/2hFvxCCWrTmCYwfy7yum0GKRi3Y.jpg","release_date":"2002-09-17","vote_average":8.375,"backdrop_path":"/c0fB9xk7D1aVb3Bg2rk2SVJcGn.jpg","original_title":"The Pianist","original_language":"en"},{"id":49568,"adult":false,"title":"1","video":false,"overview":"A bookshop renowned for its rare works is mysteriously and filled with copies of a book entitled 1, which doesn't appear to have a publisher or author. The strange almanac describes what happens to humanity in a minute. A police investigation begins and the bookshop staff are placed in solitary confinement by the Bureau for Paranormal Research. As the investigation progresses, the situation becomes more complex and the book becomes increasingly well-known, raising numerous controversies. Plagued by doubts, the protagonist has to face facts: reality only exists in the imagination of individuals.","genre_ids":[878,53],"media_type":"movie","popularity":0.219,"vote_count":120,"poster_path":"/eDgwvkkiK8DKBjPeEup4Wz87vBp.jpg","release_date":"2009-11-05","vote_average":6.171,"backdrop_path":"/c2pFJYckuMW0F5LcWD1IDQYPY6C.jpg","original_title":"1","original_language":"hu"},{"id":217316,"adult":false,"title":"1","video":false,"overview":"Set in the golden era of Grand Prix Racing '1' tells the story of a generation of charismatic drivers who raced on the edge, risking their lives during Formula 1's deadliest period, and the men who stood up and changed the sport forever.","genre_ids":[99],"media_type":"movie","popularity":0.7647,"vote_count":363,"poster_path":"/nIHvkb3M1B9TnaiaABsfTzmFMYP.jpg","release_date":"2013-09-30","vote_average":6.613,"backdrop_path":"/nPqDbXYaMhR2XKQ9IU8bkX7YgO7.jpg","original_title":"1","original_language":"en"},{"id":530915,"adult":false,"title":"1917","video":false,"overview":"At the height of the First World War, two young British soldiers must cross enemy territory and deliver a message that will stop a deadly attack on hundreds of soldiers.","genre_ids":[10752,36,18,28,12],"media_type":"movie","popularity":8.3821,"vote_count":13303,"poster_path":"/iZf0KyrE25z1sage4SYFLCCrMi9.jpg","release_date":"2019-12-25","vote_average":7.985,"backdrop_path":"/2lBOQK06tltt8SQaswgb8d657Mv.jpg","original_title":"1917","original_language":"en"},{"id":407890,"adult":false,"title":"Lean on Pete","video":false,"overview":"Charley Thompson, a teenager living with his single father, gets a summer job working for horse trainer Del Montgomery. Bonding with an aging racehorse named Lean on Pete, Charley is horrified to learn he is bound for slaughter, and so he steals the horse, and the duo embark on an odyssey across the new American frontier.","genre_ids":[18,12],"media_type":"movie","popularity":0.8888,"vote_count":354,"poster_path":"/7SuPHSo9Uw8GACkP2oPst512Qhl.jpg","release_date":"2018-04-06","vote_average":6.9,"backdrop_path":"/a26Gj4TqFKEdku1XLIWLFpzUgv4.jpg","original_title":"Lean on Pete","original_language":"en"},{"id":579245,"adult":false,"title":"The Specials","video":false,"overview":"For twenty years, Bruno and Malik have lived in a different world—the world of autistic children and teens. In charge of two separate nonprofit organizations (The Hatch & The Shelter), they train young people from underprivileged areas to be caregivers for extreme cases that have been refused by all other institutions. It’s an exceptional partnership, outside of traditional settings, for some quite extraordinary characters.","genre_ids":[35,18],"media_type":"movie","popularity":1.5622,"vote_count":971,"poster_path":"/zJziqrnSOzKiV0TrNVZ3AS0NMKI.jpg","release_date":"2019-10-23","vote_average":7.782,"backdrop_path":"/580aO5umsOX5FAFmD6ObYvVuk6p.jpg","original_title":"Hors Normes","original_language":"fr"},{"id":453350,"adult":false,"title":"Bloody Milk","video":false,"overview":"Pierre, in his thirties, is a breeder of dairy cattle. His life revolves around his farm, his veterinarian sister and his parents whose livestock he took over. As the first cases of a zoonotic outbreak are reported in France, Pierre discovers that one of his animals is infected. He cannot cope with the perspective of losing the whole herd. They are everything he has and he will do whatever it takes to save them.","genre_ids":[18],"media_type":"movie","popularity":2.2447,"vote_count":208,"poster_path":"/dG5nkpW9F4r0zlTlzKlhgJ0lIjM.jpg","release_date":"2017-08-30","vote_average":6.9,"backdrop_path":"/t8CJeAEcg4Ke5DR4ypYTokKUpXM.jpg","original_title":"Petit Paysan","original_language":"fr"},{"id":977331,"adult":false,"title":"Cat and Dog","video":false,"overview":"While about to take off, Monica, the owner of a famous influencer cat named Diva, and Jack, an international thief whose dog Chichi swallowed a stolen ruby, dis- cover that their pets have gotten lost on the tarmac. The owners – and their pets – must team up to find their loved ones. But they don’t know that Brandt, a cop hot on their heels, will do anything to get his hands on the ruby!","genre_ids":[12,35],"media_type":"movie","popularity":0.8875,"vote_count":131,"poster_path":"/3SYqAvxQIddxY5Bd6sWV9Q9kMTw.jpg","release_date":"2024-02-14","vote_average":5.744,"backdrop_path":"/rUONctvx2KhEKSPz1ybzkwu0rP.jpg","original_title":"Chien et Chat","original_language":"fr"}],"similar_content":[{"id":8856,"adult":false,"title":"The Karate Kid Part II","video":false,"overview":"Summoned by his dying father, Miyagi returns to his homeland of Okinawa, with Daniel, after a 40-year exile. There he must confront Yukie, the love of his youth, and Sato, his former best friend turned vengeful rival. Sato is bent on a fight to the death, even if it means the destruction of their village. Daniel finds his own love in Yukia's niece, Kumiko, and his own enemy in Sato's nephew, the vicious Chozen. Now, far away from the tournaments, cheering crowds and safety of home, Daniel will face his greatest challenge ever when the cost of honor is life itself.","genre_ids":[12,18,28,10749,10751],"popularity":3.4369,"vote_count":2415,"poster_path":"/k0OwgRR6PNu7h3SiqpCbRdZWNaG.jpg","release_date":"1986-06-18","vote_average":6.335,"backdrop_path":"/7rfcRXbFD0xr8NteNq1hwXUd4Af.jpg","original_title":"The Karate Kid Part II","original_language":"en"},{"id":277806,"adult":false,"title":"Say 'I Love You'","video":false,"overview":"Mei Tachibana is a high school student. Due to a traumatic incident when she was a kid, Mei has been unable to make friends or have boyfriends. By mistake, Mei then injures the most popular male student named Yamato Kurosawa. Somehow, Yamato Kurosawa likes Mei Tachibana and tells everyone unilaterally that Mei is his friend. One day, Yamato Kurosawa saves Mei Tachibana from a stalker by kissing her. From that kiss, their love story begins.","genre_ids":[18,10749],"popularity":0.6522,"vote_count":108,"poster_path":"/i1GbBp5YrwPrKN1I2rIMkRQUWHe.jpg","release_date":"2014-07-12","vote_average":6.8,"backdrop_path":"/cAHdFJtRqSieohiiqghnUrS7T6K.jpg","original_title":"好きっていいなよ。","original_language":"ja"},{"id":9908,"adult":false,"title":"Tattoo","video":false,"overview":"Marc Schrader, a rookie cop caught red-handed with drugs in a police raid of an illegal rave, joins a homicide investigation conducted by Chief Inspector Minks. The victim is a naked young woman with the skin stripped off her back, killed as she staggered into traffic. As Schrader and Minks investigate the murder, the case is complicated by a finger found in the stomach of the victim. Forensic examination proves the finger belongs to Nobert Günzel, who was previously convicted of rape and assault. The police raid Günzel’s residence, and discover a blood-stained table with restraints and bits of human flesh in his basement. They also find video equipment and preserved, tattooed skin from the victim’s back. Soon, they found dead bodies buried in the garden. Günzel then goes missing.","genre_ids":[53,18,80],"popularity":0.3886,"vote_count":63,"poster_path":"/zM8eBp85uueFX02SEH5TySPevxu.jpg","release_date":"2002-04-04","vote_average":6,"backdrop_path":"/8o1JywNXwJb6tLKe0N7mhjXQSPO.jpg","original_title":"Tattoo","original_language":"de"},{"id":663509,"adult":false,"title":"Kaiji: Final Game","video":false,"overview":"Kaiji (played by Tatsuya Fujiwara) is about to have his life changed. The thrill is beyond anything he, or most people, have experienced. The adventure is not without risk and danger however. He is given four games, which are challenges, and include life and death situations. The film follows its prequels and things will get both mental and physical.","genre_ids":[28,18,53,9648],"popularity":1.3782,"vote_count":33,"poster_path":"/cgkLaYfPzumdBKxC33EttpURnKn.jpg","release_date":"2020-01-10","vote_average":6.879,"backdrop_path":"/1GCp86Xht8yf1fFPvWPZxZOgqUV.jpg","original_title":"カイジ ファイナルゲーム","original_language":"ja"},{"id":10451,"adult":false,"title":"Eat Drink Man Woman","video":false,"overview":"Retired and widowed Chinese master chef Chu lives in modern day Taipei, with his three attractive daughters, all of whom are unattached. Soon, each daughter encounters a new man in their lives. When these new relationships blossom, stereotypes are broken and the living situation within the family changes.","genre_ids":[35,18,10749],"popularity":2.0096,"vote_count":390,"poster_path":"/olhIWtIBFg6VWK59DEd4lAvgVgz.jpg","release_date":"1994-08-03","vote_average":7.624,"backdrop_path":"/tllmUjmEQKF0OaH7FgqZYnLBsYB.jpg","original_title":"飲食男女","original_language":"zh"},{"id":1069409,"adult":false,"title":"Wakanohana: The Story of the Devil of the Dohyō","video":false,"overview":"A film about sumo wrestler Wakanohana Kanji I. He was nicknamed \"Devil of the dohyo\" due to his excellent fighting spirit and endurance.","genre_ids":[18],"popularity":0.2349,"vote_count":0,"poster_path":"/dX5ag4y7pAQH6Pw5jENpFAMRDxB.jpg","release_date":"1956-12-27","vote_average":0,"backdrop_path":null,"original_title":"Wakanohana monogatari dohyou no oni","original_language":"ja"},{"id":10842,"adult":false,"title":"Strange Circus","video":false,"overview":"The erotic novelist Taeko is writing a morbid story of a family destroyed by incest, murder and abuse. Her assistant, Yuji, sets on a mission to uncover the reality of this story, but the reality might be too much to bear.","genre_ids":[9648,27,18],"popularity":1.2643,"vote_count":205,"poster_path":"/8uEvy8cVVomN82atiLp5i7JIuI4.jpg","release_date":"2005-12-24","vote_average":7.2,"backdrop_path":"/VhuwqCNPHLhWMGAlfez5AXQUQ1.jpg","original_title":"奇妙なサーカス","original_language":"ja"},{"id":474538,"adult":false,"title":"The Blood of Wolves","video":false,"overview":"Set in 1988 in Hiroshima, Japan, prior to the enactment of the anti-organized crime law. A rumor exists that Detective Shogo Ogami has ties with the yakuza. He is partnered with Detective Shuichi Hioka and they investigate a missing person case involving a financial company employee. Conflicts between opposing yakuza groups become more serious.","genre_ids":[80,53,18,27],"popularity":1.0492,"vote_count":35,"poster_path":"/gpMqk6o8mT3bQSRez1Y04bd6dua.jpg","release_date":"2018-05-12","vote_average":7.2,"backdrop_path":"/AoN9T3kgKJgyDBn8Yj4tIXuVRKl.jpg","original_title":"孤狼の血","original_language":"ja"},{"id":474451,"adult":false,"title":"Farewell Rabaul","video":false,"overview":"A squadron of Japanese fighter pilots realise that they are never going to win the war when they understand that Japanese military tactics have little regard for life. Seeking the companionship of any woman who will have them, they spend their days indulging in every fantasy in order to escape the overwhelming fear of death looming just over the horizon.","genre_ids":[10749,10752,18],"popularity":0.4041,"vote_count":5,"poster_path":"/80jwlB8V85GXddtBIBTP1TrCdoW.jpg","release_date":"1954-02-10","vote_average":8.4,"backdrop_path":"/fi7KRdvPPkkIYizkWLtwzaXbx41.jpg","original_title":"さらばラバウル","original_language":"ja"},{"id":472396,"adult":false,"title":"The Seal Of The Sun","video":false,"overview":"At 2:46 PM on March 11, 2011, the Fukushima Daiichi Nuclear Power Plant experiences a black out due to the aftermath of the Tōhoku earthquake and tsunami. The cooling system fails at the nuclear power plant and the temperature of the nuclear reactor rises. The worst case is coming.  Scientists face an unexpected situation and government officials are confused by lack of information. Residents says goodbye to their hometown before evacuating.","genre_ids":[18],"popularity":0.3162,"vote_count":6,"poster_path":"/69L8VPUErTluqwYaNl3p2vfUetV.jpg","release_date":"2019-03-06","vote_average":6.583,"backdrop_path":"/foMh2vMvcAOSzx31MSXZIgEyXTp.jpg","original_title":"太陽の蓋","original_language":"ja"},{"id":279185,"adult":false,"title":"Love's Whirlpool","video":false,"overview":"A room in a fancy downtown apartment. The evening orgy kicks off with eight men and women meeting for the first time, including an unemployed guy who pays the 20,000 yen party fee with money from his parents, and a female college student whose run-of-the-mill appearance hides a voracious sexual appetite.","genre_ids":[18],"popularity":0.8368,"vote_count":27,"poster_path":"/tW5fNVdn5dCr5KC0tmZ05AVkuTM.jpg","release_date":"2014-03-01","vote_average":6.3,"backdrop_path":"/5b65z7Cq9sQZThOrQiRYofwijaB.jpg","original_title":"愛の渦","original_language":"ja"},{"id":11165,"adult":false,"title":"Tora! Tora! Tora!","video":false,"overview":"In the summer of 1941, the United States and Japan seem on the brink of war after constant embargos and failed diplomacy come to no end. \"Tora! Tora! Tora!\", named after the code words used by the lead Japanese pilot to indicate they had surprised the Americans, covers the days leading up to the attack on Pearl Harbor, which plunged America into the Second World War.","genre_ids":[10752,36,18],"popularity":2.2914,"vote_count":581,"poster_path":"/c311sN931DixuZRer0JGYCwpx9N.jpg","release_date":"1970-01-26","vote_average":7.1,"backdrop_path":"/bhEJZ6XH1B9ld97OWppdAnvWzl5.jpg","original_title":"Tora! Tora! Tora!","original_language":"en"},{"id":11553,"adult":false,"title":"Millennium Mambo","video":false,"overview":"Vicky recalls her romances with her exes Hao Hao and Jack in the neon-lit clubs of Taipei.","genre_ids":[18],"popularity":1.5611,"vote_count":242,"poster_path":"/wSc6tOp1yoAFbZqxG5XVGHcFvRN.jpg","release_date":"2001-10-31","vote_average":7,"backdrop_path":"/k603HQRxzlSnYAtyz9wNZndaAzg.jpg","original_title":"千禧曼波","original_language":"zh"},{"id":346,"adult":false,"title":"Seven Samurai","video":false,"overview":"A samurai answers a village's request for protection after he falls on hard times. The town needs protection from bandits, so the samurai gathers six others to help him teach the people how to defend themselves, and the villagers provide the soldiers with food.","genre_ids":[28,18],"popularity":7.8931,"vote_count":4120,"poster_path":"/lOMGc8bnSwQhS4XyE1S99uH8NXf.jpg","release_date":"1954-04-26","vote_average":8.451,"backdrop_path":"/qvZ91FwMq6O47VViAr8vZNQz3WI.jpg","original_title":"七人の侍","original_language":"ja"},{"id":246,"adult":false,"title":"Zatoichi","video":false,"overview":"Blind traveler Zatoichi is a master swordsman and a masseur with a fondness for gambling on dice games. When he arrives in a village torn apart by warring gangs, he sets out to protect the townspeople.","genre_ids":[12,18,28],"popularity":1.9251,"vote_count":932,"poster_path":"/iCIycswWbX1EDS6PYYBcR9ohrC.jpg","release_date":"2003-09-06","vote_average":7.2,"backdrop_path":"/kP6WiYHQUUXo6ZaXI06enkMsxkF.jpg","original_title":"座頭市","original_language":"ja"},{"id":271902,"adult":false,"title":"The Woman of Wrath","video":false,"overview":"A woman, married off to an abusive butcher, is overpowered by the twin forces of patriarchy and tradition in Taiwan during circa 1920 to 1945.","genre_ids":[18],"popularity":0.385,"vote_count":3,"poster_path":"/pXiBO99XZDgqBRbbSAo6wmCFT1R.jpg","release_date":"1984-09-08","vote_average":5.3,"backdrop_path":"/o6hMgPIp1bPVjCFVNuHr8yNwIhU.jpg","original_title":"殺夫","original_language":"zh"},{"id":1059050,"adult":false,"title":"The Broken Commandment","video":false,"overview":"At the strong insistence of his father, Ushimatsu Segawa conceals his origins from a “buraku” area of low-class “untouchables,” leaving his hometown to serve as an elementary school teacher where he excels and is loved by his students. But he constantly struggles with the secret of his low-birth status and is disturbed by all of the discrimination levelled upon his class. It prevents him from pursuing a romance with Shiho, whom he meets at the temple where he resides, but who descends from a samurai family.","genre_ids":[18,36],"popularity":0.4264,"vote_count":8,"poster_path":"/41J7msJ6sukkCut2Uj4JxpR6HCY.jpg","release_date":"2022-07-08","vote_average":7.2,"backdrop_path":"/8ieuOtt7VvlwzosrzRVunuxAb3e.jpg","original_title":"破戒","original_language":"ja"},{"id":1904,"adult":false,"title":"Memoirs of a Geisha","video":false,"overview":"In the years before World War II, a penniless Japanese child is torn from her family to work as a maid in a geisha house.","genre_ids":[18,10749,36],"popularity":3.1767,"vote_count":3323,"poster_path":"/pBwYsQaSTgnPphIy02DJjCF2cqs.jpg","release_date":"2005-12-06","vote_average":7.644,"backdrop_path":"/zJDnqXtGNHUmexiaWNa52Vslve5.jpg","original_title":"Memoirs of a Geisha","original_language":"en"},{"id":870,"adult":false,"title":"Dolls","video":false,"overview":"Dolls takes puppeteering as its overriding motif, which relates thematically to the action provided by the live characters. Chief among those tales is the story of Matsumoto and Sawako, a young couple whose relationship is about to be broken apart by the former's parents, who have insisted their son take part in an arranged marriage to his boss' daughter.","genre_ids":[18,10749],"popularity":0.9199,"vote_count":348,"poster_path":"/vQ9XBpH88jvO3hpHt9Zm5IHe5NP.jpg","release_date":"2002-10-12","vote_average":7.573,"backdrop_path":"/cxULojvpOWYX8AUG5eJpTYS8IbX.jpg","original_title":"ドールズ","original_language":"ja"},{"id":655559,"adult":false,"title":"Kandak Sema","video":false,"overview":"Based on a novel written by Sumithra Rahubadda.","genre_ids":[18,10751],"popularity":0.2149,"vote_count":0,"poster_path":"/pUueZdwj4klRPQnASzaQi0J07Fw.jpg","release_date":"2023-11-02","vote_average":0,"backdrop_path":null,"original_title":"Kandak Sema","original_language":"si"}],"external_ids":{"imdb_id":"tt31039829","twitter_id":"seishun18x2","facebook_id":"seishun18x2TW","wikidata_id":"Q123354231","instagram_id":"seishun18x2","rotten_tomatoes_id":"m/18x2_beyond_youthful_days"},"social_ids":{"twitter":"seishun18x2","facebook":"seishun18x2TW","instagram":"seishun18x2"},"gdvg_id":148180,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"BN","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2024-04-10T00:00:00.0