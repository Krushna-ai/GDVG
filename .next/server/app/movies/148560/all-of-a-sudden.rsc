ight":1800,"file_path":"/mOACrkf0xrwPLeb7l8pv3wbY5xS.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1200,"height":1800,"file_path":"/5gpAq9hBsFW3MvzXYSMxOTxOWYR.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1506,"file_path":"/xOAJrFv0FQLvw1AyYvZGQvQFwAB.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.664,"vote_average":0},{"width":1200,"height":1800,"file_path":"/2lPRms7lDo4EoALtdaCbz77y2Fq.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1200,"height":1800,"file_path":"/rvzR9DPZHL0GD4ClBz2As7k6jxG.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1906,"height":1072,"file_path":"/snQDUyU7Hw4Kea4ZRtxMws4xG8j.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/1O3FgFoUgmYJRbXkQjbJX1RdTi0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/s5AwPGfQdUVFghnQVRe8ZLL8gkt.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":0.166}]},"enriched_at":"2026-04-21T07:17:38.249+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"All of a Sudden","runtime":97,"tagline":"Kidnapping can be a dangerous affair","homepage":"","overview":"An erotic mystery in which two couples engage in multiple layers of passion, betrayal and murder."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"惊变","runtime":0,"tagline":"绑架可能是一件危险的事情","homepage":"","overview":"繁华喧闹的香港街头突然从高空坠下一裸体女子，探长麦sir（黄子华 饰）负责调查此案，发现该女子名叫stella，是一位叫林国财（张坚庭 饰）的大老板的私人女秘书。 林国财与太太苗可怡（温碧霞 饰）还有新出生的儿子一家三口感情很好，一日外出之际却被一神秘歹徒袭击。争斗之际可怡不慎抓下歹徒的面罩，歹徒于是将她与幼子同时绑走。失魂落魄的林国财积极与警方合作，而在麦sir的盘问下，林国财不得不说出Stella长年对自己性骚扰的事实。另一边，愤怒的歹徒徐展东（任达华 饰）对可怡说出自己老婆被林国财勾引导致二人离婚，最后林国财狠心将她抛弃，Stella不得不自杀的事实，可怡不相信，二人大吵。到底谁的话是真的呢？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Biến Động Kinh Hồn","runtime":0,"tagline":"","homepage":"","overview":"Phim Biến Động Kinh Hồn Ôn Bích Hà không thể gợi cảm hơn với 1 khuôn mặt thiên thần và những đường cong hấp dẫn, Nhậm Đạt Hoa thì hơi khờ khạo nhưng chân chất, có lẽ giới thiệu từng đó là đủ. Còn hung thủ thì đến cuối cùng mới xuất đầu lộ diện......."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"驚變","runtime":0,"tagline":"","homepage":"","overview":"繁華喧鬧的香港街頭突然從高空墜下一裸體女子，探長麥 sir（黃子華 飾）負責調查此案，發現該女子名叫 stella（曾燕 飾），是一位叫林國財（張堅庭 飾）的大老闆的私人女秘書。\r 林國財與太太苗可怡（温碧霞 飾）還有新出生的兒子一家三口感情很好，一日外出之際卻被一神秘歹徒襲擊。爭鬥之際，可怡不慎抓下歹徒的面罩，歹徒於是將她與幼子同時綁走。失魂落魄的林國財積極與警方合作，而在麥 sir 的盤問下，林國財不得不説出 Stella 長年對自己性騷擾的事實。\r 另一邊，憤怒的歹徒徐展東（任達華 飾）對可怡説出自己老婆被林國財勾引導致二人離婚，最後林國財狠心將她拋棄，Stella 不得不自殺的事實，可怡不相信，二人大吵。\r 到底，誰的話是真的呢？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":1146972,"adult":false,"title":"Mobile Suit Gundam SEED FREEDOM","video":false,"overview":"In C.E.75, the fighting still continues. There are independence movements, and aggression by Blue Cosmos... In order to calm the situation, a global peace monitoring agency called COMPASS is established, with Lacus as its first president. As members of COMPASS, Kira and his comrades intervene into various regional battles. Then a newly established nation called Foundation proposes a joint operation against a Blue Cosmos stronghold.","genre_ids":[16,878,28,18],"media_type":"movie","popularity":2.2206,"vote_count":73,"poster_path":"/1EBnttleJaKnWWyyEqfiSn76ZjT.jpg","release_date":"2024-01-26","vote_average":6.9,"backdrop_path":"/fU3oaBud5SZadw6k1ycftYedmXJ.jpg","original_title":"機動戦士ガンダムSEED FREEDOM","original_language":"ja"},{"id":266163,"adult":false,"title":"Beauty Evil Rose","video":false,"overview":"A beautiful stranger, Yan-Hong (who is one of the Roses), wanders into Inspector Liang's office, takes her gear off, then turns him into a zombie-servant of the Evil God. Policeman Cheng tries to get his wife, who is also an Inspector and his boss, in the mood for sex, but she handcuffs him and walks off. Ah-Kong and his sister, Sao Mui, are out for a stroll. Ah-Kong is also trying to stop his lovely wife Mannie from posing for nude modelling. Yan-Hong is arrested by Cheng and is interrogated, then she reports to her superior, the leather-clad Dai-Jeh (\"Big Sister\"), who practices her evil laugh and hands out a whipping as punishment. Later, a dozy Taoist priest is called in to exorcise the Beauty and her Evil Roses. The priest fails, but lays the groundwork for the final showdown between good and evil.","genre_ids":[27],"media_type":"movie","popularity":0.2812,"vote_count":4,"poster_path":"/y2duej3pSW1TwPFLRZwtJm62zni.jpg","release_date":"1992-09-11","vote_average":3.5,"backdrop_path":"/3dvbkwYM2GVZvmCHn0cbuOLgwJT.jpg","original_title":"色降II之血玫瑰","original_language":"cn"},{"id":193706,"adult":false,"title":"Cuore matto... matto da legare","video":false,"overview":"Tony is in love with Carla, a young student of architecture, but his parents want him to marry Erminia, a rich but ugly girl.","genre_ids":[35,10402],"media_type":"movie","popularity":0.184,"vote_count":1,"poster_path":"/6qtCvOIodYin61uxyfZWkr1E7XU.jpg","release_date":"1967-07-29","vote_average":4,"backdrop_path":"/hqSIbNdRLjC9EDSJWSiVFANJwW3.jpg","original_title":"Cuore matto... matto da legare","original_language":"it"},{"id":104693,"adult":false,"title":"Dances with the Snakes","video":false,"overview":"In medieval China, three sexy serpentesses need the essence of virgin males to defeat the evil Yinsan Monster, so they go on a quest which leads them to an inn occupied by an impotent landlord and a western Christian missionary with revitalising properties.","genre_ids":[14],"media_type":"movie","popularity":0.499,"vote_count":4,"poster_path":"/8yI2RzOuwan50spbC89OZAtiBZK.jpg","release_date":"1992-01-01","vote_average":3,"backdrop_path":null,"original_title":"與蛇共舞","original_language":"cn"},{"id":545611,"adult":false,"title":"Everything Everywhere All at Once","video":false,"overview":"An aging Chinese immigrant is swept up in an insane adventure, where she alone can save what's important to her by connecting with the lives she could have led in other universes.","genre_ids":[28,12,878],"media_type":"movie","popularity":12.4243,"vote_count":7695,"poster_path":"/u68AjlvlutfEIcpmbYpKcdi09ut.jpg","release_date":"2022-03-24","vote_average":7.72,"backdrop_path":"/ss0Os3uWJfQAENILHZUdX8Tt1OC.jpg","original_title":"Everything Everywhere All at Once","original_language":"en"},{"id":828508,"adult":false,"title":"Return","video":false,"overview":"This is a documentary linking ecological and political problems. The planet has come to be less important than the multinational earnings, and with it politicians earnings as well. With this project we bring foreward this problem, witch not only affects the third world, but is a worldwide situation witch needs to be adressed.","genre_ids":[99],"media_type":"movie","popularity":0.347,"vote_count":571,"poster_path":"/xWjw5JBMuce6Wv33dDUfmzVVaAL.jpg","release_date":"2018-05-11","vote_average":6.5,"backdrop_path":null,"original_title":"Return","original_language":"es"},{"id":1276338,"adult":false,"title":"Star","video":false,"overview":"Follows a youngster Kalai and his aspirations of becoming a 'Star' in the Tamil Film Industry. Born in a lower-middle-class family, will Kalai overcome all his struggles to emerge as a Star?","genre_ids":[18,10749],"media_type":"movie","popularity":0.534,"vote_count":83,"poster_path":"/c74qjGjs6XEKYDTYc1bxRzRkigT.jpg","release_date":"2024-05-10","vote_average":7.3,"backdrop_path":"/nCRLG0OzsP4U5IddWCIZzDoAWLA.jpg","original_title":"ஸ்டார்","original_language":"ta"},{"id":52959,"adult":false,"title":"Star!","video":false,"overview":"Gertrude Lawrence rises to stage stardom at the cost of happiness.","genre_ids":[18,10402,10749],"media_type":"movie","popularity":3.0935,"vote_count":234,"poster_path":"/xMyOm5hLWeuoWBea1DJrcJy8bU6.jpg","release_date":"1968-07-18","vote_average":6.9,"backdrop_path":"/l1wcKPBvB4FKXpvG6rD8FbpjvPT.jpg","original_title":"Star!","original_language":"en"},{"id":329505,"adult":false,"title":"Lola's Secret","video":false,"overview":"Young man has his dreams come true when the sexy new maid seduces him. But she also has a secret that leads to trouble.","genre_ids":[18,35,27],"media_type":"movie","popularity":2.449,"vote_count":68,"poster_path":"/qaJ4iQngrLbyz9OgaQkJLppDN6m.jpg","release_date":"1984-05-04","vote_average":6.9,"backdrop_path":"/tId87yE7JnQsQsqOpnGXjz9PoEe.jpg","original_title":"Il peccato di Lola","original_language":"it"},{"id":1188150,"adult":false,"title":"Return","video":false,"overview":"\"Behind every strong man is a strong woman!\", Mumine shouts as her husband is arrested. She has 4 children, she's in her mid-30s, and she's the wife of a Crimean Tatar political prisoner. Muslim Crimean Tatars have been oppressed for a long time. They were deported under Stalin, allowed to return under Gorbachev, and since the occupation of Crimea in 2014 under Putin, they are being persecuted again. \"Return\" is a portrait of Mumine and Maye, two strong women struggling with the consequences of oppression. Their traditional understanding of their role as women does not stand in the way of their dedication. They possess strength, beauty and dignity. Only in their most intimate moments, they are overwhelmed by desperate helplessness.","genre_ids":[99],"media_type":"movie","popularity":0.4363,"vote_count":567,"poster_path":"/eFUAxw9l8Kz8PJhBQzCkAGMkoHB.jpg","release_date":"2023-09-26","vote_average":6.525,"backdrop_path":"/q2NR7tkons5k1kRXly4rHVdoXUs.jpg","original_title":"Return","original_language":"tt"},{"id":67035