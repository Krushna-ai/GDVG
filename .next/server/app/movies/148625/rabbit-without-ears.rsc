pularity":4.0529,"vote_count":2689,"poster_path":"/wrY629UTCUAKLJ4CxQXz6DCE7pr.jpg","release_date":"2015-07-17","vote_average":5.8,"backdrop_path":"/srQ457TWXxxFFYN2QGctbocFNG6.jpg","original_title":"Trainwreck","original_language":"en"},{"id":271835,"adult":false,"title":"Langit Mo Kaligayahan Ko","video":false,"overview":"This sensual drama depicts the story of an inseparable couple trying to cope with the obstacle in life.","genre_ids":[18],"popularity":0.128,"vote_count":4,"poster_path":"/8iM7RJu9lCNMuZoxJfnoHCIkH1D.jpg","release_date":"2004-01-01","vote_average":2,"backdrop_path":null,"original_title":"Langit Mo Kaligayahan Ko","original_language":"en"},{"id":453,"adult":false,"title":"A Beautiful Mind","video":false,"overview":"From the heights of notoriety to the depths of depravity, John Forbes Nash Jr. experiences it all. As a brilliant but socially awkward mathematician, he made a groundbreaking discovery early in his career and stands on the brink of international acclaim. But as the handsome and arrogant Nash accepts secret work in cryptography, he becomes entangled in a mysterious conspiracy. His life takes a nightmarish turn and he soon finds himself on a painful and harrowing journey of self-discovery.","genre_ids":[18,10749],"popularity":6.8101,"vote_count":10885,"poster_path":"/zwzWCmH72OSC9NA0ipoqw5Zjya8.jpg","release_date":"2001-12-14","vote_average":7.854,"backdrop_path":"/vVBcIN68kFq681b4lObiNJhEVro.jpg","original_title":"A Beautiful Mind","original_language":"en"},{"id":3681,"adult":false,"title":"What's New Pussycat?","video":false,"overview":"A playboy who refuses to give up his hedonistic lifestyle to settle down and marry his true love seeks help from a demented psychoanalyst who is having romantic problems of his own.","genre_ids":[35,10749],"popularity":1.0247,"vote_count":163,"poster_path":"/seKbiGx8mjF04Bx4LVBQk741Eqv.jpg","release_date":"1965-06-22","vote_average":6,"backdrop_path":"/rMciW54meA4ijDLv3wX5FmDzluh.jpg","original_title":"What's New Pussycat?","original_language":"en"},{"id":3865,"adult":false,"title":"Dark Blue Almost Black","video":false,"overview":"Jorge is a young man whose plans for the future are put on hold when his father has a stroke. For seven years, he diligently nurses his father and works as a janitor while studying part time to get a business degree. When Natalia, his childhood crush, returns from a stint studying abroad, Jorge begins to yearn for something better. He is desperate to find a new and better job, but finds that no one will hire him because he has experience only as a janitor. Antonio, Jorge’s older brother, soon to be released from jail, is an opportunist who has never gotten along with their father. In prison, at a theater workshop, Antonio meets Paula, a beautiful young woman in jail on drug charges. Paula has a problem because she flirted with another inmate's boyfriend.","genre_ids":[18,10749],"popularity":0.3976,"vote_count":113,"poster_path":"/oL4Pg64w1IfOTcwzmiRXeGa6iRM.jpg","release_date":"2006-03-24","vote_average":6.748,"backdrop_path":"/dhO1k9S56b1AlKOftYyLojIXWHk.jpg","original_title":"AzulOscuroCasiNegro","original_language":"es"},{"id":4208,"adult":false,"title":"Martin and Lea","video":false,"overview":"A loving couple Martin and Lea have some problems with each other too.","genre_ids":[18],"popularity":0.1293,"vote_count":8,"poster_path":"/9l90MTAKCLNK9t7Oaq2BUKp2rdA.jpg","release_date":"1979-01-31","vote_average":5.6,"backdrop_path":"/uWptQcnIIxfIFKmuGR6DJ1K0w1.jpg","original_title":"Martin et Léa","original_language":"fr"},{"id":4251,"adult":false,"title":"Veer-Zaara","video":false,"overview":"Squadron Leader Veer Pratap Singh, a pilot in the Indian Air Force, rescues the stranded Zaara, a woman from Pakistan, following a bus accident, and their lives are forever bound.","genre_ids":[18,10749],"popularity":1.8294,"vote_count":297,"poster_path":"/j267YqLvKAHeyykTflxzpgVgviQ.jpg","release_date":"2004-11-12","vote_average":7.4,"backdrop_path"