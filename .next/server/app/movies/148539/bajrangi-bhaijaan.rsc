o_639_1":"hi","iso_3166_1":"IN","vote_count":1,"aspect_ratio":0.692,"vote_average":0.166},{"width":900,"height":1300,"file_path":"/4SpkXr0eHhWUSQ3ElSGdKcZanol.jpg","iso_639_1":"hi","iso_3166_1":"IN","vote_count":1,"aspect_ratio":0.692,"vote_average":0.166},{"width":1023,"height":1482,"file_path":"/zZeV4FNwPTknXONkGkqg8sAryQT.jpg","iso_639_1":"hi","iso_3166_1":"IN","vote_count":1,"aspect_ratio":0.69,"vote_average":0.166},{"width":1000,"height":1497,"file_path":"/diiFDZLuWeBEHeIcllWbOhOpu35.jpg","iso_639_1":"hi","iso_3166_1":"IN","vote_count":1,"aspect_ratio":0.668,"vote_average":0.166},{"width":500,"height":750,"file_path":"/bG9IzxMi8IFsfRd40ReiEAL3Zxo.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":837,"height":1200,"file_path":"/jVfQ4JEA5k5miu9WwqOkUDcbEPQ.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":0.698,"vote_average":0},{"width":686,"height":1016,"file_path":"/o44kR6ytmGi6DdkEkFyB8KIb1S7.jpg","iso_639_1":"hi","iso_3166_1":"IN","vote_count":0,"aspect_ratio":0.675,"vote_average":0},{"width":1000,"height":1500,"file_path":"/wn3WQkRwjhINjSgclLZ00QgDScz.jpg","iso_639_1":"ar","iso_3166_1":"SA","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/AtRulWjLKKAbi3nC6LNLtqRXfvC.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":736,"height":1104,"file_path":"/1dhsqwLfkRLC3xdvkUdyeYWnxFp.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1440,"height":2160,"file_path":"/idbQ7iPXrNDLsFHPv5S6PHzzBmW.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1045,"height":1567,"file_path":"/nj8anxgCTOUTgTJbXjcuZtShTKr.jpg","iso_639_1":"zh","iso_3166_1":"TW","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/6XqQ6fOkY5jWgRRMkGdKHwhTn98.jpg","iso_639_1":"hi","iso_3166_1":"IN","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/n9QCm8uagvmXH476u5qFQsW8HkU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/mjZei9Cylhnin05OoiKaBTfljHn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/7jqvojMAC6i6Wb5v7KwMiyL9wNm.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/vZ76B43ZMO4gTq4XhpkexjJEwoo.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1280,"height":720,"file_path":"/uMpuFrYnwJgs6u34skcwmWkc3Jh.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/mOh7GotTPFpnDRV80OFIqXSr8RN.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-27T05:37:54.318+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Bajrangi Bhaijaan","runtime":159,"tagline":"","homepage":"","overview":"A young mute girl from Pakistan loses herself in India with no way to head back. A devoted man with a magnanimous spirit undertakes the task to get her back to her motherland and unite her with her family."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Брат Баджранги","runtime":0,"tagline":"","homepage":"","overview":"Фильм рассказывает о любви между мусульманским мальчиком и индусской девушкой, и о том, как общество относится к ним."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Puterea credinței","runtime":163,"tagline":"","homepage":"","overview":"O tânără mută din Pakistan se pierde în India, fără nicio cale de întoarcere. Un bărbat devotat, cu un spirit generos, își asumă sarcina de a o aduce înapoi în patria ei și de a o uni cu familia ei."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Sevginin Gücü","runtime":0,"tagline":"","homepage":"","overview":"5 yaşında bir kız olan Shahida doğuştan konuşamıyordur. Kızının konuşması için elinden geleni yapan annesi, Shahida’yı tedavi ettirebilmek için onu Pakistan’dan Hindistan’a götürmeye karar verir. Fakat çıktıkları bu yolculuk küçük kızın hayatını tamamen değiştirir. Trenle çıktıkları yolculukta küçük kız, tren durakta beklediği sırada camdan gördüğü kuzuların yanına gitmek için trenden iner. Fakat tren hareket etmek için düdüğü çaldığında Shahida duyamadığı için treni kaçırır. Küçük kız bilmediği topraklar yapayalnız kalmıştır. Tek başına sokaklarda dolaşan küçük kızın yolu Bajrangi adındaki bir adamla kesişir. Bajrangi, Shahida’ya yardım etmeye çalışsa da ondan hiçbir öğrenemediği için ne yapacağını şaşırır. Şans eseri kızın Pakistanlı olduğunu öğrenen genç adam genç kızı ailesine kavuşturmaya kararlıdır. Shahida’nın ailesini bulmak için yola koyulan ikili kendilerini macera dolu bir yolculuğun içerisinde bulur."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Bajrangi Bhaijaan","runtime":0,"tagline":"","homepage":"","overview":"Munni es una chica que se ha perdido en la India. Su mayor deseo es regresar a Pakistán y encontrar a su familia. Su encuentro con un hombre muy generoso le dará la esperanza que necesita."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"小萝莉的猴神大叔","runtime":0,"tagline":"","homepage":"","overview":"印度教教徒 Bajrangi，与 Rasika 在新德里的月光集市相遇，彼此有所误解而成为一对冤家，但他们却联手帮助一位有语言障碍的穆斯林小女孩沙希达，让她回到自己的家乡与家人团聚。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Bajrangi Bhaijaan","runtime":0,"tagline":"","homepage":"","overview":"Ein junges stummes Mädchen aus Pakistan verliert sich in Indien, ohne die Möglichkeit, zurückzukehren. Ein hingebungsvoller Mann mit einem großherzigen Geist übernimmt die Aufgabe, sie zurück in ihr Mutterland zu bringen und sie mit ihrer Familie zu vereinen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"카쉬미르의 소녀","runtime":0,"tagline":"","homepage":"","overview":"독실한 힌두교 신자인 파반은 어머니를 잃어버린 다섯 살짜리 벙어리 파키스탄 소녀를 돌보고 있다. 어머니를 찾기 위한 파반과 소녀의 여정은 펀자브와 라자스탄, 올드 델리와 카쉬미르 지역까지 이어진다. 그리고 종교와 국경을 초월한 사랑의 무한한 힘을 보여준다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Bajrangi Bhaijaan","runtime":163,"tagline":"","homepage":"","overview":"Ένα μικρό, βουβό κορίτσι από ένα χωριό του Πακιστάν χάνεται κατά την επιστροφή της, από ένα ταξίδι στην Ινδία Στην περιοχή Kurukshetra, συναντά τον Pawan - έναν Βραχμάνο αφοσιωμένο στον Θεό Χάνουμαν - που είναι στη μέση μιας πρόκλησης από τον πατέρα της ερωμένης του Στην προσπάθειά του να ανακαλύψει τους γονείς της, αναπτύσσει έναν πολύ ισχυρό δεσμό με το παιδί Προσπαθεί να μπει στο Πακιστάν μέσω ενός μονοπατιού καθοδηγούμενος από τη συνείδησή του και αργότερα, με έναν έξυπνο Πακιστανό δημοσιογράφο για παρέα, αναζητά την οικογένεια της μικρής, ώστε να εκπληρώσει την υπόσχεση που της έδωσε και να την επανενώσει με την οικογένειά της"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Irmão Bajrangi","runtime":163,"tagline":"","homepage":"","overview":"Uma menina de 5 anos do Paquistão se perde de seus pais em uma estação indiana de trem. Perdida e faminta ela encontra abrigo na casa de Pavan, um devoto ardoroso de Hanuman, um Hindu e que vem de uma famosa família de lutadores. O filme mostra a tocante história da jornada de Pavan para unir a criança com os pais, onde, contra todas as probabilidades, move o céu e a terra para cumprir a promessa que fez para a menina do outro lado da fronteira."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Bajrangi Bhaijaan","runtime":0,"tagline":"","homepage":"","overview":"Główny bohater spotyka w Indiach małą dziewczynkę. Nie wie kim ona jest ani skąd pochodzi, a w dodatku dziecko nie mówi. Po wielu perypetiach dowiaduje się że mała pochodzi z Pakistanu. Postanawia na własną rękę odprowadzić ją do domu, ryzykując tym samym szczęście swoje i swojej ukochanej Rasiki.  Opinie widzów"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Bajrangi Bhaijaan","runtime":0,"tagline":"","homepage":"","overview":"Munni, une petite fille de 6 ans, pakistanaise, muette, est désespérément à la recherche de sa mère perdue lors d'un voyage en Inde.  Sa rencontre avec Pawan Kumarum (Salman Khan), un homme généreux, va lui redonner espoir.  Leur incroyable voyage plein de dangers et de belles rencontres sera porteur d'humanité."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"寶萊塢之鋼鐵奶爸","runtime":0,"tagline":"把她帶回家","homepage":"","overview":"印度教教徒帕萬在一次機緣巧合下結識了與母親走失並有語言障礙的穆斯林小女孩沙希達。在得知沙希達是巴基斯坦人後，帕萬決定幫助她回家，可是在回巴基斯坦途中卻四處碰壁……帕萬立志不惜一切代價，盡其所能帶沙希達回到自己的家鄉與家人團聚。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"把她帶回家","runtime":0,"tagline":"","homepage":"","overview":"在大草原生活的小萌，雖然自小不懂説話，卻是一個人見人愛的快樂小女孩。一次意外，媽媽下定決心帶她到印度朝聖祈願，誰知她們在回家途中意外失散. ."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Bajrangi Bhaijaan","runtime":154,"tagline":"","homepage":"","overview":"Een 5 jaar oud meisje uit Pakistan wordt gescheiden van haar moeder op een Indiaas station. Verloren en hongerig vindt ze onderdak in het huis van Pavan. Hij is een vurige aanhanger van Hanuman en een vrome hindoe afkomstig uit een degelijke familie."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Brolis Badžrangas","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"バジュランギおじさんと、小さな迷子","runtime":0,"tagline":"ふたりなら、どんな壁でも超えられる","homepage":"","overview":"パキスタンの小さな村に住む女の子シャヒーダー。幼い頃から声が出せない障害を持った彼女を心配したお母さんと一緒に、インドのイスラム寺院に願掛けに行くが、帰り道で一人インドに取り残されてしまう。そんなシャヒーダーが出会ったのは、ヒンドゥー教のハヌマーン神の熱烈な信者のパワンだった。バカがつくぐらいの正直者で、お人好しなパワンは、これも、ハヌマーンの思し召しと、母親とはぐれたシャヒーダーを預かることにしたが、ある日、彼女がパキスタンのイスラム教徒と分かって驚愕する。歴史、宗教、経済など様々な部分で激しく対立するインドとパキスタン。 それでもパスポートもビザもなしに、国境を越えてシャヒーダーを家に送り届けることを決意したパワンの旅が始まった。果たしてパワンは無事にシャヒーダーを母親の元へ送り届けることができるのか!?"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Bajrangi Bhaijaan","runtime":0,"tagline":"","homepage":"","overview":"E' la storia di Bajrangi, un fervente devoto della divinità Hindu, Hanuman. Proprio durante lo svolgimento di una festività religiosa, l'uomo, incontrerà la piccola Shahida di soli sei anni e sfortunatamente muta. La bimba in viaggio dal Pakistan in India, si è persa separandosi dalla madre che tornata in patria non smetterà di cercarla. L'unico a tendere una mano alla piccola Shahida sarà Bajrangi che proverà ad aiutarla a tornare a casa. Non sarà un'impresa facile e tante saranno le difficoltà da affrontare."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"האחים באג'ראנגי","runtime":0,"tagline":"האחים באג'ראנגי","homepage":"","overview":"אדם הודי עם לב נדיב לוקח בחורה פקיסטנית אילמת צעירה חזרה למולדת שלה כדי לאחד אותה עם משפחתה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Bratr Bajrangi","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Người Hùng Bajrangi Bhaijaan","runtime":0,"tagline":"","homepage":"","overview":"Phim kể về cuộc hành trình của Bajrangi( Salma Khan) và Munni - một bé gái 6 tuổi bị câm từ Ấn Độ sang Pakistan để tìm cha mẹ cho em.Trên đường sang Pakistan họ gặp vô vàng khó khăn từ việc vượt biên đến việc tìm nơi Munni được sinh ra."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"ძმა ბაჯარანგი","runtime":163,"tagline":"","homepage":"","overview":"ფილმი მოგვითხროს პაკისტანელ გოგონაზე, რომელიც ინდოეთშია და ცდილობს დაბრუნდეს სამშობლოში. მას ინდოელი ახალგარდა ბიჭი ეხმარება"},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"باجرانجي بهايجان","runtime":0,"tagline":"","homepage":"","overview":"تتركز الأحداث حول فتاة صغيرة بكماء من (باكستان) تفقد طريقها خلال تواجدها في (الهند) ، باﻹضافة إلى عدم وجود طريق للعودة أمامها عبر الحدود ، ويتولى رجل من (الهند) يدعى بافان كومار شوتارفيدي (سلمان خان) مهمة إعادتها مجددًا إلى منزلها سالمة غانمة ، ويجمعها مع عائلتها من جديد ."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"حياة اخي باجرانجي","runtime":0,"tagline":"","homepage":"","overview":""},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"برادر باجرانگی","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"Bajrangi Bhaijaan","runtime":0,"tagline":"","homepage":"","overview":"Uma jovem muda do Paquistão perde-se na Índia sem ter como regressar. Um homem devotado e de espírito magnânimo assume a tarefa de a levar de volta à sua terra natal e de a reunir à sua família."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"}],"reviews_tmdb":[{"id":"5b1e279bc3a36808a6006c5a","url":"https://www.themoviedb.org/review/5b1e279bc3a36808a6006c5a","author":"gauravmanral","content":"This is one of the best film of Salman Khan. This is the first time when i was very emotional during watching this film. Now i am waiting for your Race 3 movie sir. \r\n","created_at":"2018-06-11T07:41:15.913Z","updated_at":"2021-06-23T15:58:09.459Z","author_details":{"name":"gauravmanral","rating":null,"username":"gauravmanral","avatar_path":null}}],"recommendations":[{"id":280690,"adult":false,"title":"Kick","video":false,"overview":"An adrenaline junkie walks away from a whirlwind romance and embraces a new life as a thief, though he soon finds himself pursued by veteran police officer and engaged in a turf war with a local gangster.","genre_ids":[28,10749,35,80],"media_type":"movie","popularity":1.336,"vote_count":166,"poster_path":"/muRGQIGFcHTyHimE2ru6RSjD8D6.jpg","release_date":"2014-07-25","vote_average":5.7,"backdrop_path":"/sJALzyUz6r2GA1WPY9XcG6tWkiG.jpg","original_title":"Kick","original_language":"hi"},{"id":14073,"adult":false,"title":"Jodhaa Akbar","video":false,"overview":"A sixteenth century love story about a marriage of alliance that gave birth to true love between a Mughal emperor and a Rajput princess.","genre_ids":[10749,36,18],"media_type":"movie","popularity":1.2154,"vote_count":269,"poster_path":"/gPjgeywFNTlh9IUuXWy85nn4h8J.jpg","release_date":"2008-02-13","vote_average":7.322,"backdrop_path":"/dwdH8HykILUADCIupGsqjcq1ygv.jpg","original_title":"जोधा अकबर","original_language":"hi"},{"id":283201,"adult":false,"title":"Finding Fanny","video":false,"overview":"Five friends from Goa get lost during a journey to discover the lot of the childhood sweetheart of an old postman.","genre_ids":[35],"media_type":"movie","popularity":0.2916,"vote_count":46,"poster_path":"/9AeKSeHxI716kJF71Cy6uioOI73.jpg","release_date":"2014-09-11","vote_average":5.37,"backdrop_path":null,"original_title":"Finding Fanny","original_language":"en"},{"id":719949,"adult":false,"title":"Khuda Haafiz","video":false,"overview":"When the 2008 recession leaves Sameer Chaudhary and his wife Nargis jobless, they struggle to make a living and after three months, succeed when they find jobs in a Middle East country named Noman. Due to delay in arrival of documents, Sameer stays in India while Nargis heads to Noman, upon arriving where she is abducted as she pleads for help over a phone call to Sameer. Enraged and helpless, Sameer heads to Noman and teams up with a local taxi driver to find Nargis before it is too late.","genre_ids":[28,53],"media_type":"movie","popularity":0.4479,"vote_count":46,"poster_path":"/4Glh9LgdsmlQxhUUKnCROHWdrsU.jpg","release_date":"2020-08-14","vote_average":7.011,"backdrop_path":"/o46Pcs82jOLqqTCKig8OSGV9C4r.jpg","original_title":"खुदा हाफिज","original_language":"hi"},{"id":610482,"adult":false,"title":"Agent Sai Srinivasa Athreya","video":false,"overview":"Agent Sai Srinivasa Athreya is a brilliant, underrated detective from Nellore who runs an agency called FBI which sees no business. He gets more than what he asked for when a case happens to fall right into his lap out of nowhere.","genre_ids":[80,35,9648],"media_type":"movie","popularity":0.386,"vote_count":57,"poster_path":"/jMVfhhWfHLawVp3kd55KBy3VBsW.jpg","release_date":"2019-06-21","vote_average":7.4,"backdrop_path":"/s7QvyLoxJ1PWMGasGpqluQqhUT9.jpg","original_title":"ఏజెంట్ సాయి శ్రీనివాస అత్రేయ","original_language":"te"},{"id":35687,"adult":false,"title":"LSD: Love, Sex aur Dhokha","video":false,"overview":"A video camcorder, a store security camera, and concealed cameras candidly expose lives in three loosely linked tales.","genre_ids":[18,80,35],"media_type":"movie","popularity":2.5461,"vote_count":46,"poster_path":"/cGB0TZ27GXUTaBIxhf7IBPiHXzr.jpg","release_date":"2010-03-19","vote_average":6.109,"backdrop_path":"/ibNLyuef3pdV3T8n3FKB3FQ9Qs7.jpg","original_title":"लव सेक्स और धोखा","original_language":"hi"},{"id":465656,"adult":false,"title":"Kedarnath","video":false,"overview":"Mansoor, a reserved and reticent Pithoo (porter), helps pilgrims make an arduous journey upwards to the temple town. His world turns around when he meets the beautiful and rebellious Mukku who draws him into a whirlwind of intense love.","genre_ids":[10749],"media_type":"movie","popularity":0.8258,"vote_count":47,"poster_path":"/viq6ltqew6ZU6dur1FUVKpf9tiZ.jpg","release_date":"2018-12-07","vote_average":6.6,"backdrop_path":"/rxAOiBCivJNzL0rXcrlyreofZb0.jpg","original_title":"केदारनाथ","original_language":"hi"},{"id":496320,"adult":false,"title":"Race 3","video":false,"overview":"The Singh family comprises of Shamsher his step-son Sikandar, twins Suraj and Sanjana. They run a business of illegal arms and trade with the help of their friend Yash. Things get dramatic when Jessica meets Sikandar and the family ties are strained under each character’s ulterior motives.","genre_ids":[53,28,80,12],"media_type":"movie","popularity":0.7156,"vote_count":82,"poster_path":"/wtnA5mmNumYkeevokar6IskyrZP.jpg","release_date":"2018-06-15","vote_average":3.543,"backdrop_path":"/4XHjwauS5MC5tvkrNYWBxtw3Twn.jpg","original_title":"Race 3","original_language":"hi"},{"id":330421,"adult":false,"title":"Papanasam","video":false,"overview":"A cinephile tries to protect his family by hiding a heat-of-the-moment murder committed by his daughter by taking cues from the films he has watched. With the victim the son of a cop, can he get away with it?","genre_ids":[80,53,18,10751],"media_type":"movie","popularity":0.3788,"vote_count":47,"poster_path":"/qH0ayDXNdTvzGrBFwzK79JMyKp1.jpg","release_date":"2015-07-03","vote_average":7.9,"backdrop_path":"/e6WQoHeD1lomknxc0a65Ae1sfVw.jpg","original_title":"பாபநாசம்","original_language":"ta"},{"id":422603,"adult":false,"title":"Aanandam","video":false,"overview":"A group of students visit Goa and Hampi while on their college trip. Their experiences during their journey help them understand the intricacies of love and friendship.","genre_ids":[12,35,10749],"media_type":"movie","popularity":0.6555,"vote_count":36,"poster_path":"/lf6uk5ukEhULKS4M386ah9Tv1Fz.jpg","release_date":"2016-10-21","vote_average":7.278,"backdrop_path":"/nm01vAcpeduK6K1HtRaHyTzpvFY.jpg","original_title":"ആനന്ദം","original_language":"ml"},{"id":65946,"adult":false,"title":"Ready","video":false,"overview":"Prem believes Sanjana is the girl chosen by his dad and falls in love with her. However, she is a runaway bride escaping from a marriage set up by her mafia uncles against her wishes. On learning the truth, he devises a plan to win her over from her uncles who intend to usurp her huge inheritance.","genre_ids":[28,35],"media_type":"movie","popularity":0.9355,"vote_count":99,"poster_path":"/umfKMUkXXPfMUoOq60nXjDbQOCL.jpg","release_date":"2011-06-03","vote_average":5.025,"backdrop_path":"/gh9mRGlL41HPnyoakF6WZtCAhe0.jpg","original_title":"Ready","original_language":"hi"},{"id":611356,"adult":false,"title":"Gulabo Sitabo","video":false,"overview":"Set in present-day Lucknow, Gulabo Sitabo is a social satire about two impossibly peculiar human beings, Mirza Chunnan Nawab, who stays in a dilapidated mansion and one of the tenants, Bankey Rastogi.","genre_ids":[18,35],"media_type":"movie","popularity":0.4349,"vote_count":51,"poster_path":"/6ABuPqPqRv2iSDyLf9KJrLoNV2A.jpg","release_date":"2020-06-12","vote_average":5.912,"backdrop_path":"/ae1vyvzNIjhkSuwswAaHvwfvwpp.jpg","original_title":"गुलाबो सिताबो","original_language":"hi"},{"id":445239,"adult":false,"title":"Abu Shanab","video":false,"overview":"Esmat Abu Shanab (Yasmin Abdul Aziz) is a female police officer who works in an administrative position and tries in various ways to work on field assignments.","genre_ids":[35],"media_type":"movie","popularity":0.8291,"vote_count":15,"poster_path":"/beeV6Y9elppF3nrKYnx55bZfHio.jpg","release_date":"2016-07-06","vote_average":6.2,"backdrop_path":"/lZf0vc5dwnTdRx7MvCENQwo1erF.jpg","original_title":"أبو شنب","original_language":"ar"},{"id":304274,"adult":false,"title":"Lai Bhaari","video":false,"overview":"Sumitra travels to Pandharpur to find a ray of hope, after Sangram killed her husband and son and took over their business.","genre_ids":[28,18,10751],"media_type":"movie","popularity":0.1962,"vote_count":7,"poster_path":"/knRrQBBsDiFPPzENpHXU9eQgxGq.jpg","release_date":"2014-07-11","vote_average":6.6,"backdrop_path":"/9tmP58zz7dfiBwVe5seTLCykQGv.jpg","original_title":"लय भारी","original_language":"mr"},{"id":51485,"adult":false,"title":"Delhi Safari","video":false,"overview":"A group of animals in a Bombay national park plan to stop humans from building an apartment complex on their land.","genre_ids":[16,35,10751],"media_type":"movie","popularity":0.3847,"vote_count":19,"poster_path":"/lOHkT0UMej8KXKqm0VxQMysSvDw.jpg","release_date":"2012-10-19","vote_average":5.1,"backdrop_path":"/1xRES1c8zBLy4iotyMlBCk8WjI2.jpg","original_title":"Delhi Safari","original_language":"en"},{"id":53505,"adult":false,"title":"The Last Lions","video":false,"overview":"In Botswana's Okavango Delta, an ostracized lioness and her two cubs must fight alone to survive - overcoming all manner of hazards. Their only defense is to escape to Duba Island -- and with that, an unknown future. The setting for this epic tale is one of the last regions where lions can live in the wild. Faced with dwindling land and increasing pressure from hunting, lions - like our lone lioness and her cubs - are approaching the brink of extinction.","genre_ids":[99],"media_type":"movie","popularity":0.3476,"vote_count":71,"poster_path":"/xNxqoeTfHReYbHbhigir85J21Nh.jpg","release_date":"2011-02-11","vote_average":7.232,"backdrop_path":"/wfTHcv3ZDTzy5pplUup1JWAwa1u.jpg","original_title":"The Last Lions","original_language":"en"},{"id":21188,"adult":false,"title":"Goat Story","video":false,"overview":"A funny animated movie based on the classic Czech tales and legend of a young clockmaker, and his jealous friend, a wisecracking Goat.","genre_ids":[16,35],"media_type":"movie","pop