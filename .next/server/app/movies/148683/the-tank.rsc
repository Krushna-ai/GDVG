ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/9zVFMPG6aKKrljahwqpqCdwpv1J.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/5BaIMAxXFpWkjH2N7KrI6aY1gI8.jpg","iso_639_1":"he","iso_3166_1":"IL","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/wprn92csG4tRHnDjaBhZWUeKFLy.jpg","iso_639_1":"ro","iso_3166_1":"RO","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/pOW3moeOTEMaaakkOQSqyHZkak7.jpg","iso_639_1":"pl","iso_3166_1":"PL","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/emEwb50pD69E9DjaFGNLymRj5RQ.jpg","iso_639_1":"zh","iso_3166_1":"SG","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/6ZuW3zoNcBBCPU3osoHRcJLEH8e.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":2.542},{"width":1920,"height":1080,"file_path":"/hvqPoklQvYQD6Zc8LdwqvYXuckW.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.5},{"width":1280,"height":720,"file_path":"/ym13MZd2zPQYRztXFliDLxnyCb0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":0.166},{"width":1600,"height":900,"file_path":"/hjwWLbwRihXV9sHhCFkOp8wleIO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/q0A6ojU43T2fY9OKvY0JdXe3MxN.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":0.166},{"width":1600,"height":900,"file_path":"/lf4xyAfo46HGjgpxaM7RpgQvRJB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":0.166},{"width":1400,"height":788,"file_path":"/mIU6d03vKPwYKsFl4gXbKV76iau.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.777,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/sX6SxSMYT7be8MRmDym54df3k9w.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/cyPJHjA6lnin4483wjCiEqXgucM.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/rKzPNoJQxDKAIDzFkpWSMXa4Ioa.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/yyLljoR6gwSh3UJFsXBDM8poNjJ.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/v2sU7kEiXldDSz2eaFQIIU4onWG.jpg","iso_639_1":"zh","iso_3166_1":"HK","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T06:04:11.32+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Tank","runtime":117,"tagline":"","homepage":"https://www.amazon.com/dp/B0G4XCZW3X","overview":"A German Tiger tank crew is sent on a dangerous mission to rescue the missing officer Paul von Hardenburg from a top-secret bunker behind enemy lines. As they make their way through the lethal no-man's land, they must confront not only the enemy, but also their own fears and inner demons. Fueled by the Wehrmacht's methamphetamine, their mission increasingly becomes a journey into the heart of darkness."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":122,"tagline":"Wir ernten was wir säen.","homepage":"https://www.pal-next.com/de/projects/the-tiger/","overview":"Ostfront, 1943: Die Besatzung eines deutschen Tiger-Panzers wird auf eine gefährliche Mission weit hinter die hart umkämpfte Frontlinie geschickt. Auf ihrem Weg durch das Niemandsland müssen sie sich nicht nur dem Feind stellen, sondern auch ihren eigenen Ängsten und Abgründen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Tank","runtime":0,"tagline":"","homepage":"","overview":"Doğu Cephesi, 1943: Bir Alman Tiger tank mürettebatı, şiddetli çatışmanın yaşandığı cephenin derinliklerindeki tehlikeli bir göreve gönderilir. Ayak basılmamış ölümcül topraklarda ilerlerken hem düşmanla hem de içlerindeki şeytanlarla yüzleşmek zorunda kalırlar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Czołg","runtime":118,"tagline":"","homepage":"","overview":"Front wschodni, rok 1943: niemiecka załoga czołgu Tygrys zostaje wysłana na niebezpieczną misję głęboko za linią frontu, gdzie toczą się zacięte walki. Podczas podróży przez śmiertelną ziemię niczyją muszą stawić czoła zarówno wrogowi, jak i własnym wewnętrznym demonom."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"O Tanque de Guerra","runtime":0,"tagline":"","homepage":"https://www.primevideo.com/detail/0LTDBRJ28D38II3AEZZK5MWYIH","overview":"Frente oriental, 1943. A equipe de um tanque alemão Tiger é enviada numa missão perigosa além das linhas de frente ferozmente disputadas. Ao cruzarem essa letal terra de ninguém, eles precisam encarar o inimigo e seus próprios demônios internos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Der Tiger (El tanque)","runtime":116,"tagline":"","homepage":"","overview":"Frente oriental, 1943: la dotación alemana de un tanque Tiger se embarca en una peligrosa misión tras las líneas enemigas. A medida que atraviesan la mortífera tierra de nadie, deberán enfrentarse al enemigo y a sus propios fantasmas del pasado."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"The Tank","runtime":0,"tagline":"","homepage":"","overview":"Front de l'Est, 1943 : l'équipage d'un char Tigre allemand se voit confier une dangereuse mission loin derrière les lignes de front âprement disputées. Durant leur traversée de ce no man's land, ils doivent affronter l'ennemi ainsi que leurs propres démons."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"รถถังเจ้าพยัคฆ์","runtime":0,"tagline":"","homepage":"","overview":"แนวรบตะวันออก ปี 1943 ทีมรถถังเยอรมันถูกส่งไปทำภารกิจอันตรายลึกเข้าไปหลังแนวข้าศึกที่รบกันดุเดือด ขณะพวกเขาเดินทางผ่านเขตกันชน พวกเขาต้องเผชิญทั้งศัตรูและปีศาจในใจ"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"虎式坦克","runtime":0,"tagline":"","homepage":"","overview":"1943年的東線戰場，一支德軍虎式坦克小隊被派往敵我激烈拉鋸的前線後方，執行一項危險任務。在穿越致命的無人地帶時，他們不僅必須面對敵軍威脅，也得直視各自的心魔。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"A Tigris","runtime":0,"tagline":"","homepage":"","overview":"Keleti front, 1943: egy német Tigris tank legénysége veszedelmes küldetésre indul, messze a hevesen támadott frontvonalak mögé. Míg áthaladnak a halálos senkiföldjén, nemcsak az ellenséggel kell szembenézniük, hanem saját belső démonjaikkal is."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":122,"tagline":"","homepage":"","overview":"Východní fronta, 1943. Posádka německého tanku Tiger má splnit nebezpečný úkol daleko za přísně střeženou frontovou linií. Cestou přes smrtící zemi nikoho musí čelit nejen nepříteli, ale také svým vnitřním démonům."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Itärintama vuonna 1943. Saksalainen Tiger-panssarivaunumiehistö lähtee vaaralliselle tehtävälle eturintaman kiivaiden taistelujen taakse. Edetessään vaarallisella ei-kenenkään-maalla heidän on kohdattava niin vihollisia kuin sisäisiä demonejaan."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Tank","runtime":0,"tagline":"","homepage":"","overview":"Na vzhodni fronti II. svetovne vojne leta 1943 je petčlanska posadka nemškega tanka Tiger poslana na tajno misijo daleč za močno sporno frontno črto. Pod vplivom metamfetamina Wehrmachta se njihova naloga vse bolj spreminja v potovanje v osrčje teme."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"猛虎末路","runtime":117,"tagline":"","homepage":"","overview":"　　一辆德国虎式坦克的五名车组成员被派往战火纷飞的前线后方执行一项秘密任务。在德军亢奋药物的刺激下，他们的任务逐渐变成了一场深入黑暗之心的旅程。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Frente Oriental, 1943: A tripulação de um tanque Tiger alemão é enviada numa missão perigosa, profundamente para lá das linhas da frente ferozmente disputadas. À medida que atravessam a mortal terra de ninguém, terão de enfrentar o inimigo e os próprios demónios interiores."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Tiger: Tanque de guerra","runtime":0,"tagline":"","homepage":"","overview":"Frente oriental, 1943: la tripulación de un tanque Tiger alemán es enviada a una misión peligrosa muy lejos de las reñidas líneas del frente. Conforme viajan a través de la mortífera tierra de nadie, deben enfrentar tanto al enemigo como a sus propios demonios internos."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"タンク","runtime":116,"tagline":"","homepage":"","overview":"東部戦線、1943年。ドイツ軍ティーガー戦車の１両が、激戦の続く前線に深く進攻する危険な任務に派遣される。死の緩衝地帯を進みながら、隊員たちは敵軍だけでなく自身の内なる悪魔にも立ち向かわねばならない。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"द टैंक","runtime":117,"tagline":"","homepage":"","overview":"ईस्टर्न फ्रंट, 1943: एक जर्मन टाइगर टैंक क्रू को, मोर्चे पर हो रहे भयानक युद्ध के पीछे, एक खतरनाक मिशन पर भेजा जाता है। जब वे खतरनाक नो-मैन्स लैंड से गुज़रते हैं, तो उन्हें दुश्मन और अपने अंदर के शैतानों, दोनों का सामना करना पड़ता है।"},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"الدبابة","runtime":117,"tagline":"","homepage":"","overview":"الجبهة الشرقية عام 1943: يُرسل طاقم دبابة ألمانية طراز تايغر في مهمة خطرة وراء خطوط النزاع التي تشهد حرباً شرسة. مع تقدمهم عبر الأراضي المحفوفة بالمخاطر المميتة، عليهم مواجهة العدو وهواجسهم الداخلية أيضاً."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"","runtime":117,"tagline":"","homepage":"","overview":"Østfronten, 1943: Mannskapet på en tysk Tiger-stridsvogn sendes på et farlig oppdrag dypt bak de omstridte frontlinjene. Mens de reiser gjennom et dødens ingenmannsland, må de møte både fienden og egne indre demoner."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Tancul","runtime":0,"tagline":"","homepage":"","overview":"Frontul de Est, 1943. Echipajul unui tanc Tiger este trimis într-o misiune periculoasă în spatele extrem de disputatei linii a frontului. În timp ce traversează letala zonă tampon, membrii echipajului trebuie să-și înfrunte atât inamicul, cât și demonii proprii."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Тигр","runtime":0,"tagline":"","homepage":"","overview":"В 1943 году на Восточном фронте Второй мировой войны экипаж из пяти человек немецкого танка «Тигр» отправляется на секретную миссию далеко за линию фронта, где разворачивается ожесточенная борьба. Подпитываемые метамфетамином вермахта, их задание все больше превращается в путешествие в самое сердце тьмы."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"הטנק","runtime":116,"tagline":"","homepage":"","overview":"החזית המזרחית, 1943. צוות של טנק טיגר גרמני נשלח למשימה מסוכנת עמוק מאחורי קו החזית שעליו מתנהל קרב קשה. כשהם עוברים בשטח ההפקר הקטלני, הם צריכים להתמודד עם האויב וגם עם השדים הפנימיים שלהם."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Der Tiger - Viaggio all'inferno","runtime":116,"tagline":"","homepage":"","overview":"Fronte Orientale, 1943: l'equipaggio di un carro armato Tiger viene mandato in una pericolosa missione, oltre le linee nemiche. Attraversando la letale terra di nessuno, dovranno affrontare non solo il nemico, ma anche i propri demoni interiori."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"الدبابة","runtime":0,"tagline":"","homepage":"","overview":"الجبهة الشرقية عام 1943: يُرسل طاقم دبابة ألمانية طراز تايغر في مهمة خطرة وراء خطوط النزاع التي تشهد حرباً شرسة. مع تقدمهم عبر الأراضي المحفوفة بالمخاطر المميتة، عليهم مواجهة العدو وهواجسهم الداخلية أيضاً."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Østfronten 1943: Et tysk Tiger-kampvognsmandskab sendes på en farlig mission ind bag frontlinjen. På deres farefulde færd gennem det dødbringende ingenmandsland skal de kæmpe både mod fjenden og deres egne indre dæmoner."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"虎式坦克","runtime":0,"tagline":"","homepage":"","overview":"1943年的東線戰場，一支德軍虎式坦克小隊被派往敵我激烈拉鋸的前線後方，執行一項危險任務。在穿越致命的無人地帶時，他們不僅必須面對敵軍威脅，也得直視各自的心魔。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Άρμα Μάχης Τίγρης","runtime":0,"tagline":"","homepage":"","overview":"Ανατολικό Μέτωπο, 1943: Στο πλήρωμα ενός γερμανικού άρματος Τίγρης ανατίθεται μια επικίνδυνη αποστολή βαθιά πίσω από την ασαφή πρώτη γραμμή του μετώπου. Καθώς διασχίζουν τη θανάσιμα επικίνδυνη νεκρή ζώνη, αντιμετωπίζουν τόσο τον εχθρό όσο και τους πιο σκοτεινούς προσωπικούς τους δαίμονες."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"猛虎战车","runtime":0,"tagline":"","homepage":"","overview":"东线战场，1943年：一支德国虎式坦克乘员组被派往敌后，执行一项极其危险的任务。在穿越致命的无人地带时，他们不仅要面对敌军的威胁，也不得不直面内心的恶魔。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"","runtime":117,"tagline":"","homepage":"","overview":"Oostfront, 1943: De bemanning van een Duitse Tiger-tank wordt op een gevaarlijke missie gestuurd, diep achter de zwaar bevochten frontlinie. Terwijl ze door het dodelijke niemandsland trekken, worden ze geconfronteerd met zowel de vijand als hun innerlijke demonen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"The Tank","runtime":0,"tagline":"","homepage":"","overview":"Front Timur, 1943: Kru tank Tiger Jerman dikirim ke tengah misi berbahaya jauh di balik garis depan yang diperebutkan dengan sengit. Selagi mereka melakukan perjalanan melalui tanah tak bertuan yang berbahaya, mereka harus menghadapi musuh dan konflik dalam diri mereka sendiri."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"The Tank","runtime":0,"tagline":"","homepage":"","overview":"Barisan Timur, 1943: Sekumpulan kru kereta kebal Tiger Jerman dihantar menjalankan misi berbahaya jauh di belakang garisan hadapan yang sengit dipertahankan. Ketika mereka merentas kawasan berbahaya itu, mereka perlu berdepan musuh dan juga bayang hitam dalam diri sendiri."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Östfronten, 1943: En stridsvagnsbesättning i en tysk Tiger, skickas ut på ett farligt uppdrag djupt bakom hårt omstridda frontlinjer. Under färden genom ett ingenmansland, möter de inte bara fiender, utan även sina egna inre demoner."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"전차 티거","runtime":0,"tagline":"","homepage":"","overview":"1943년 동부 전선. 독일군 티거 전차 분대는 치열한 최전선 너머로 침투해야 하는 위험한 임무를 맡는다. 그들은 생사를 장담할 수 없는 무인 지대를 헤쳐 나가며 적과 내면의 악마를 동시에 마주해야 한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Chiếc Xe Tank","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Tenk","runtime":0,"tagline":"","homepage":"","overview":"Petoročlana posada njemačkog tenka Tiger poslana je na tajnu misiju daleko iza linije fronta. Pokretana metamfetaminom Wehrmachta, njihova misija sve više postaje putovanje u srce tame ..."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Танкът","runtime":0,"tagline":"","homepage":"","overview":"Източен фронт, 1943 г.: Екипаж на немски танк „Тигър“ е изпратен на опасна мисия дълбоко зад ожесточените фронтови линии. Докато пътуват през смъртоносната ничия земя, те трябва да се изправят както срещу врага, така и срещу собствените си вътрешни демони."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Tigras","runtime":0,"tagline":"","homepage":"","overview":"1943 metais, Antrojo pasaulinio karo Rytų fronte, penkių žmonių vokiečių tanko įgula siunčiama į slaptą misiją giliai už aršiai ginamos fronto linijos. Skatinami vermachto metamfetamino, jie leidžiasi į kelionę, kuri vis labiau virsta tamsos širdies tyrinėjimu."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"}],"reviews_tmdb":[{"id":"6959b707bbf78189c8cbf053","url":"https://www.themoviedb.org/review/6959b707bbf78189c8cbf053","author":"MovieGuys","content":"\"The Tank\" starts out well but leads to a rather uninspiring outcome. Viewed as an anti war film, with realistic scenes of combat and war crimes, this film is compellingly, horribly, honest. The spirtual component, that the script try's to inject towards the films end, however, falls flat. Its not especially well done, lacking a narrational consistency, that would tie it back, convincingly, into the majority of the story. \r\n\r\nIn summary, excellent acting, realistic scenes of combat and the mistreatment of civilian populations, that sit's somewhat ackwardly, alongside a tale of death and damnation. A reasonable, if not exceptional watch.","created_at":"2026-01-04T00:40:39.236Z","updated_at":"2026-01-04T00:42:37.731Z","author_details":{"name":"","rating":7,"username":"MovieGuys","avatar_path":null}}],"recommendations":[{"id":170,"adult":false,"title":"28 Days Later","video":false,"overview":"Twenty-eight days after a killer virus was accidentally unleashed from a British research facility, a small group of London survivors are caught in a desperate struggle to protect themselves from the infected. Carried by animals and humans, the virus turns those it infects into homicidal maniacs -- and it's absolutely impossible to contain.","genre_ids":[27,53,878],"media_type":"movie","popularity":17.7462,"vote_count":8256,"poster_path":"/sQckQRt17VaWbo39GIu0TMOiszq.jpg","release_date":"2002-10-31","vote_average":7.236,"backdrop_path":"/aJFwk1clMal1prxAvKAgHxKPAf.jpg","original_title":"28 Days Later","original_language":"en"},{"id":297222,"adult":false,"title":"PK","video":false,"overview":"A stranger in the city asks questions no one has asked before. Known only by his initials, the man's innocent questions and childlike curiosity take him on a journey of love, laughter and letting go.","genre_ids":[35,18,878],"media_type":"movie","popularity":6.4022,"vote_count":1122,"poster_path":"/z2x2Y4tncefsIU7h82gmUM5vnBJ.jpg","release_date":"2014-12-18","vote_average":7.698,"backdrop_path":"/gxfvtq5eYiClS2X7hxAAPBNrbWA.jpg","original_title":"पीके","original_language":"hi"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":19.7563,"vote_count":11389,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":264660,"adult":false,"title":"Ex Machina","video":false,"overview":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl.","genre_ids":[18,878],"media_type":"movie","popularity":7.7588,"vote_count":14042,"poster_path":"/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg","release_date":"2015-01-21","vote_average":7.573,"backdrop_path":"/uqOuJ50EtTj7kkDIXP8LCg7G45D.jpg","original_title":"Ex Machina","original_language":"en"},{"id":150540,"adult":false,"title":"Inside Out","video":false,"overview":"When 11-year-old Riley moves to a new city, her Emotions team up to help her through the transition. Joy, Fear, Anger, Disgust and Sadness work together, but when Joy and Sadness get lost, they must journey through unfamiliar places to get back home.","genre_ids":[16,10751,12,18,35],"media_type":"movie","popularity":16.5969,"vote_count":23190,"poster_path":"/2H1TmgdfNtsKlU9jKdeNyYL5y8T.jpg","release_date":"2015-06-17","vote_average":7.909,"backdrop_path":"/o3i6AfTcWAuNvzAUV3q5lOmi6Gx.jpg","original_title":"Inside Out","original_language":"en"},{"id":11324,"adult":false,"title":"Shutter Island","video":false,"overview":"World War II soldier-turned-U.S. Marshal Teddy Daniels investigates the disappearance of a patient from a hospital for the criminally insane, but his efforts are compromised by troubling visions and a mysterious doctor.","genre_ids":[18,53,9648],"media_type":"movie","popularity":14.6244,"vote_count":25460,"poster_path":"/nrmXQ0zcZUL8jFLrakWc90IR8z9.jpg","release_date":"2010-02-14","vote_average":8.2,"backdrop_path":"/8xt8AMb1OKC63AdhNSaYBWxB4Iq.jpg","original_title":"Shutter Island","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":28.4976,"vote_count":26827,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.903,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":680,"adult":false,"title":"Pulp Fiction","video":false,"overview":"A burger-loving hit man, his philosophical partner, a drug-addled gangster's moll and a washed-up boxer converge in this sprawling, comedic crime caper. Their adventures unfurl in three stories that ingeniously trip back and forth in time.","genre_ids":[53,80,35],"media_type":"movie","popularity":22.3091,"vote_count":29738,"poster_path":"/vQWk5YBFWF4bZaofAbv0tShwBvQ.jpg","release_date":"1994-09-10","vote_average":8.486,"backdrop_path":"/96hiUXEuYsu4tcnvlaY8tEMFM0m.jpg","original_title":"Pulp Fiction","original_language":"en"},{"id":389,"adult":false,"title":"12 Angry Men","video":false,"overview":"The defense and the prosecution have rested and the jury is filing into the jury room to decide if a young Spanish-American is guilty or innocent of murdering his father. What begins as an open and shut case soon becomes a mini-drama of each of the jurors' preju