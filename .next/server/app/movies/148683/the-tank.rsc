e_count":5854,"poster_path":"/9Ts7Vc4wLlpI9oox9mkVUE1tBHy.jpg","release_date":"2017-04-07","vote_average":7.999,"backdrop_path":"/aH63TQfTFgAT8tYZs0CjDsqfMo2.jpg","original_title":"Gifted","original_language":"en"},{"id":13510,"adult":false,"title":"Eden Lake","video":false,"overview":"When a young couple goes to a remote wooded lake for a romantic getaway, their quiet weekend is shattered by an aggressive group of local kids. Rowdiness quickly turns to rage as the teens terrorize the couple in unimaginable ways, and a weekend outing becomes a bloody battle for survival.","genre_ids":[27,53],"media_type":"movie","popularity":4.608,"vote_count":2024,"poster_path":"/tOg6ElTe1mJwaCFN0172U4oso22.jpg","release_date":"2008-09-12","vote_average":6.832,"backdrop_path":"/s9v1QZMVhwShQ7415jPhtfqzyjG.jpg","original_title":"Eden Lake","original_language":"en"},{"id":286217,"adult":false,"title":"The Martian","video":false,"overview":"During a manned mission to Mars, Astronaut Mark Watney is presumed dead after a fierce storm and left behind by his crew. But Watney has survived and finds himself stranded and alone on the hostile planet. With only meager supplies, he must draw upon his ingenuity, wit and spirit to subsist and find a way to signal to Earth that he is alive.","genre_ids":[18,12,878],"media_type":"movie","popularity":15.4976,"vote_count":20861,"poster_path":"/3ndAx3weG6KDkJIRMCi5vXX6Dyb.jpg","release_date":"2015-09-30","vote_average":7.691,"backdrop_path":"/sq8oUjbBvKkqv9h0Ns5rQbbquhZ.jpg","original_title":"The Martian","original_language":"en"},{"id":27205,"adult":false,"title":"Inception","video":false,"overview":"Cobb, a skilled thief who commits corporate espionage by infiltrating the subconscious of his targets is offered a chance to regain his old life as payment for a task considered to be impossible: \"inception\", the implantation of another person's idea into a target's subconscious.","genre_ids":[28,878,12],"media_type":"movie","popularity":27.2486,"vote_count":38743,"poster_path":"/xlaY2zyzMfkhk0HSC5VUwzoZPU1.jpg","release_date":"2010-07-15","vote_average":8.371,"backdrop_path":"/8ZTVqvKDQ8emSGUEMjsS4yHAwrp.jpg","original_title":"Inception","original_language":"en"},{"id":37165,"adult":false,"title":"The Truman Show","video":false,"overview":"An insurance salesman begins to suspect that his whole life is actually some sort of reality TV show.","genre_ids":[35,18],"media_type":"movie","popularity":16.282,"vote_count":19832,"poster_path":"/vuza0WqY239yBXOadKlGwJsZJFE.jpg","release_date":"1998-06-04","vote_average":8.151,"backdrop_path":"/aCHn2TXYJfzPXQKA6r9mKPbMlUB.jpg","original_title":"The Truman Show","original_language":"en"}],"similar_content":[{"id":89,"adult":false,"title":"Indiana Jones and the Last Crusade","video":false,"overview":"In 1938, an art collector appeals to eminent archaeologist Dr. Indiana Jones to embark on a search for the Holy Grail. Indy learns that a medieval historian has vanished while searching for it, and the missing man is his own father, Dr. Henry Jones Sr.. He sets out to rescue his father by following clues in the old man's notebook, which his father had mailed to him before he went missing. Indy arrives in Venice, where he enlists the help of a beautiful academic, Dr. Elsa Schneider, along with Marcus Brody and Sallah. Together they must stop the Nazis from recovering the power of eternal life and taking over the world!","genre_ids":[12,28],"popularity":6.4059,"vote_count":10879,"poster_path":"/sizg1AU8f8JDZX4QIgE4pjUMBvx.jpg","release_date":"1989-05-24","vote_average":7.849,"backdrop_path":"/12fvZHskx57kQfNEUXJ3v0flWYQ.jpg","original_title":"Indiana Jones and the Last Crusade","original_language":"en"},{"id":143,"adult":false,"title":"All Quiet on the Western Front","video":false,"overview":"When a group of idealistic young men join the German Army during the Great War, they are assigned to the Western Front, where their patriotism is destroyed by the harsh realities of combat.","