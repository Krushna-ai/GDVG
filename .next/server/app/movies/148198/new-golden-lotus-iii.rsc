5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"New Golden Lotus III\",\"description\":\"3rd episode of a serie of 5. Chinny is stuck in a marriage with a disgusting midget, but is seduced and tricked into becoming the fifth concubine of sexy official Simon Hsin. While Chinny is mistreated by the other concubines, Simon has affairs with anything that movies, poisons Chinny's husband, and imprisons her brother-in-law. It soon becomes apparent that this is Simon's M.O. when he steals another man's wife and kills him as well\",\"image\":\"https://image.tmdb.org/t/p/w500/lPgjena9aMaGtKzji4wkY0FDn2J.jpg\",\"datePublished\":\"1996-03-22\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"TW\",\"inLanguage\":\"cn\",\"genre\":[\"Drama\",\"Romance\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6,\"bestRating\":10,\"ratingCount\":14}}"}}],["$","$L10",null,{"initialDrama":{"id":"5742c2d9-5845-4ecf-bc34-a4c3770bb087","tmdb_id":492105,"imdb_id":"tt12952242","content_type":"movie","title":"New Golden Lotus III","original_title":"新金瓶梅 第三集","overview":"3rd episode of a serie of 5. Chinny is stuck in a marriage with a disgusting midget, but is seduced and tricked into becoming the fifth concubine of sexy official Simon Hsin. While Chinny is mistreated by the other concubines, Simon has affairs with anything that movies, poisons Chinny's husband, and imprisons her brother-in-law. It soon becomes apparent that this is Simon's M.O. when he steals another man's wife and kills him as well","poster_path":"/lPgjena9aMaGtKzji4wkY0FDn2J.jpg","backdrop_path":"/stJlG2HefS8XUXAVqVSB9X6K0W0.jpg","release_date":"1996-03-22","first_air_date":null,"status":"published","original_language":"cn","origin_country":["TW","HK"],"genres":[{"id":18,"name":"Drama"},{"id":10749,"name":"Romance"}],"popularity":3.9972,"vote_average":6,"vote_count":14,"runtime":0,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-24T22:56:18.768199+00:00","updated_at":"2026-02-24T22:56:18.615+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[],"production_countries":[{"name":"Taiwan","iso_3166_1":"TW"},{"name":"Hong Kong","iso_3166_1":"HK"}],"spoken_languages":[{"name":"广州话 / 廣州話","iso_639_1":"cn","english_name":"Cantonese"},{"name":"普通话","iso_639_1":"zh","english_name":"Mandarin"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[],"alternative_titles":[{"type":"","title":"The Golden Lotus Yang III","iso_3166_1":"HK"},{"type":"","title":"The Golden Lotus Yang 3","iso_3166_1":"HK"}],"videos":[],"watch_providers":{"results":{}},"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-24T22:56:18.768199+00:00","region":null,"main_poster":null,"images":{"logos":[],"posters":[{"width":1200,"height":1800,"file_path":"/lPgjena9aMaGtKzji4wkY0FDn2J.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":549,"height":800,"file_path":"/2jkgMD8z1PdajX3zmYmKz4Xy3Fm.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":0.686,"vote_average":0.166}],"backdrops":[{"width":1920,"height":1080,"file_path":"/stJlG2HefS8XUXAVqVSB9X6K0W0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/6xXag6dsg1XB5nhEAb8EHuM8VZm.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T01:47:00.266+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"新金瓶梅3","runtime":87,"tagline":"","homepage":"","overview":"春梅性虐待陈经济后，回房告诉潘金莲，陈经济之所以性能力强，是因为喝一种壮阳的酒，但是那种酒喝多了损伤身体，春梅从他那要了好几瓶，打算给西门庆喝，和潘金莲说这招是[软刀杀硬汉]。李瓶儿因为丈夫花子虚去世独守空房病倒了，医生蒋竹山来医治他，指出她得是心病，两人心有灵犀，迅速结婚了，西门庆知道消息之后，派舞狮子的小厮去捣鬼，把蒋竹山绊倒困在鞭炮里，毁了容、爆瞎了眼，当晚，西门庆溜进蒋竹山家，花言巧语取得李瓶儿欢心，第二天又娶了李瓶儿，但是当晚西门庆并没有和李瓶儿同房，而是在丽春院风流快活，他叫来蒋竹山，叫蒋竹山去李瓶儿房间后院唱歌，李瓶儿听到之后出来查看，蒋竹山劝说李瓶儿离开是非之地，李瓶儿不听劝并且殴打了蒋竹山一顿，蒋竹山被春梅救起。李瓶儿回房之后投井自杀，被小厮救起。蒋竹山为了报复西门庆，送给春梅一瓶壮阳酒和退火汤，喝完前者再喝后者，使人从火堆里掉入冰窟里，叫她伺机下给西门庆喝，害死西门庆。潘金莲叫情夫陈经济打听和帮忙解决武松的事情，在西门庆出外办事的晚上，陈经济下药麻醉妻子，和潘金莲、春梅通奸，但是他们的行为被小厮琴儿偷看到了，琴儿借机敲诈陈经济，提出条件要和潘金莲上床否则告诉西门庆。西门庆出差到了汴梁，一天晚上在妓院风月楼和朋友喝酒，喝醉之后去上厕所，和太尉高俅的儿子高衙内打斗了起来。高衙内回去之后带人来捉西门庆，西门庆早就溜走了。一日，二娘李娇儿在院子里看到琴儿自慰喊五娘潘金莲的名字，李娇儿把这事告诉了西门庆其他妻妾，众妻妾把琴儿叫过来严刑逼问，他们为了整死潘金莲，把琴儿带到西门庆面前告状。西门庆召集众妻妾、琴儿、春梅一起当面查此事，琴儿一口咬定是二娘李娇儿叫他嫁祸五娘潘金莲，这时候陈经济走进来，也站在潘金莲这边说话，西门庆打了李娇儿一顿，把琴儿关了起来。事情完了之后，春梅把蒋竹山给她的壮阳酒倒给西门庆喝，西门庆喝了之后，性欲旺盛，和春梅、潘金莲性交起来。晚上，春梅偷偷给琴儿去送饭，被李娇儿秘密地跟踪，在门外叫“来人”，潘金莲在她身后一棍打晕了她，三人合伙把李娇儿打死，丢入了井里。春梅、潘金莲放走了琴儿，把二娘李娇儿的一支钗子丢在柴房，使得西门庆误以为是李娇儿和琴儿一起逃走了。潘金莲凑齐银两交给陈经济，叫陈经济去沧州救武松。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"New Golden Lotus III","runtime":0,"tagline":"","homepage":"","overview":"3rd episode of a serie of 5. Chinny is stuck in a marriage with a disgusting midget, but is seduced and tricked into becoming the fifth concubine of sexy official Simon Hsin. While Chinny is mistreated by the other concubines, Simon has affairs with anything that movies, poisons Chinny's husband, and imprisons her brother-in-law. It soon becomes apparent that this is Simon's M.O. when he steals another man's wife and kills him as well"},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Tân kim bình mai 3","runtime":97,"tagline":"","homepage":"","overview":"Sau khi Chunmei lạm dụng tình dục Chen Jingji, cô ấy trở về phòng và nói với Pan Jinlian rằng lý do khiến Chen Jingji mạnh mẽ là do cô ấy uống một loại rượu kích thích tình dục, nhưng loại rượu đó đã làm hỏng cơ thể cô ấy khi anh ấy uống quá nhiều, và Chunmei xin vài chai từ anh ta., Tôi định đưa cho Tây Môn Khánh một ly, và nói với Pan Jinlian rằng thủ đoạn này là [dao mềm để giết kẻ cứng rắn]. Li Ping'er đổ bệnh trong căn phòng trống vì cái chết của chồng cô là Hua Zixu, bác sĩ Jiang Zhushan đã đến chữa bệnh và chỉ ra rằng cô đang bị bệnh tim, hai người họ tâm đầu ý hợp rồi nên duyên vợ chồng. Sau khi Tây Môn Khánh biết tin, ông ta đã sai một người múa sư tử đến gây rối. Trượt và bẫy Giang Trạch Sơn trong pháo, bị biến dạng và mù mắt."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"ตำนานพิศวาสดอกเหมย 3","runtime":0,"tagline":"","homepage":"","overview":"ชินนี่ติดอยู่ในชีวิตแต่งงานกับคนแคระที่น่ารังเกียจ แต่กลับถูกล่อลวงและหลอกล่อให้กลายเป็นนางสนมคนที่ 5 ของไซมอน ซิน ข้าราชการสุดเซ็กซี่ ในขณะที่ชินนี่ถูกนางสนมคนอื่นๆ ปฏิบัติอย่างไม่ดี ไซมอนกลับมีสัมพันธ์กับทุกสิ่งทุกอย่างที่ถ่ายภาพยนตร์ วางยาสามีของชินนี่ และจองจำพี่เขยของเธอ ในไม่ช้าก็เห็นได้ชัดว่านี่คือวิธีปฏิบัติของไซมอน เมื่อเขาขโมยภรรยาของชายอื่นและฆ่าเขาด้วย"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"新金瓶梅 第三集","runtime":0,"tagline":"","homepage":"","overview":"春梅性虐待陳經濟后，回房告訴潘金蓮，陳經濟之所以性能力強，是因為喝一種壯陽的酒，但是那種酒喝多了損傷身體，春梅從他那要了好幾瓶，打算給西門慶喝，和潘金蓮説這招是[軟刀殺硬漢]。李瓶兒因為丈夫花子虛去世獨守空房病倒了，醫生蔣竹山來醫治他，指出她得是心病，兩人心有靈犀，迅速結婚了，西門慶知道消息之後，派舞獅子的小廝去搗鬼，把蔣竹山絆倒困在鞭炮裏，毀了容、爆瞎了眼，當晚，西門慶溜進蔣竹山家，花言巧語取得李瓶兒歡心，第二天又娶了李瓶兒，但是當晚西門慶並沒有和李瓶兒同房，而是在麗春院風流快活，他叫來蔣竹山，叫蔣竹山去李瓶兒房間後院唱歌，李瓶兒聽到之後出來查看，蔣竹山勸説李瓶兒離開是非之地，李瓶兒不聽勸並且毆打了蔣竹山一頓，蔣竹山被春梅救起。李瓶兒回房之後投井自殺，被小廝救起。蔣竹山為了報復西門慶，送給春梅一瓶壯陽酒和退火湯，喝完前者再喝後者，使人從火堆裏掉入冰窟裏，叫她伺機下給西門慶喝，害死西門慶。潘金蓮叫情夫陳經濟打聽和幫忙解決武松的事情，在西門慶出外辦事的晚上，陳經濟下藥麻醉妻子，和潘金蓮、春梅通姦，但是他們的行為被小廝琴兒偷看到了，琴兒借機敲詐陳經濟，提出條件要和潘金蓮上床否則告訴西門慶。西門慶出差到了汴梁，一天晚上在妓院風月樓和朋友喝酒，喝醉之後去上廁所，和太尉高俅的兒子高衙內打鬥了起來。高衙內回去之後帶人來捉西門慶，西門慶早就溜走了。一日，二孃李嬌兒在院子裏看到琴兒自慰喊五娘潘金蓮的名字，李嬌兒把這事告訴了西門慶其他妻妾，眾妻妾把琴兒叫過來嚴刑逼問，他們為了整死潘金蓮，把琴兒帶到西門慶面前告狀。西門慶召集眾妻妾、琴兒、春梅一起當面查此事，琴兒一口咬定是二孃李嬌兒叫他嫁禍五娘潘金蓮，這時候陳經濟走進來，也站在潘金蓮這邊説話，西門慶打了李嬌兒一頓，把琴兒關了起來。事情完了之後，春梅把蔣竹山給她的壯陽酒倒給西門慶喝，西門慶喝了之後，性慾旺盛，和春梅、潘金蓮性交起來。晚上，春梅偷偷給琴兒去送飯，被李嬌兒秘密地跟蹤，在門外叫“來人”，潘金蓮在她身後一棍打暈了她，三人合夥把李嬌兒打死，丟入了井裏。春梅、潘金蓮放走了琴兒，把二孃李嬌兒的一支釵子丟在柴房，使得西門慶誤以為是李嬌兒和琴兒一起逃走了。潘金蓮湊齊銀兩交給陳經濟，叫陳經濟去滄州救武松。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":676701,"adult":false,"title":"Tad, the Lost Explorer and the Emerald Tablet","video":false,"overview":"Tad accidentally unleashes an ancient spell, endangering the lives of his friends Mummy, Jeff, and Belzoni. With everyone against him and only helped by Sara, he sets off on an adventure to end the Curse of the Mummy.","genre_ids":[16,12,10751,35,14],"media_type":"movie","popularity":1.2629,"vote_count":332,"poster_path":"/jvIVl8zdNSOAJImw1elQEzxStMN.jpg","release_date":"2022-08-24","vote_average":7.5,"backdrop_path":"/tUBN1paMQ1tmVA5Sjy1ZjPWVsiF.jpg","original_title":"Tadeo Jones 3: La Tabla Esmeralda","original_language":"es"},{"id":999278,"adult":false,"title":"The Goldsmith","video":false,"overview":"Determined to rob a goldsmith, three young robbers break into his country house. The man and his wife turn out to be less defenseless than they seem.","genre_ids":[27,53],"media_type":"movie","popularity":1.0238,"vote_count":101,"poster_path":"/6eUxBpQSfFvQx1tJLRe74lyMw13.jpg","release_date":"2022-10-08","vote_average":5.9,"backdrop_path":"/sBk6nzxhtTkrn9JZj32vaRki0QG.jpg","original_title":"L'Orafo","original_language":"it"},{"id":716263,"adult":false,"title":"Sister-in-law's Taste","video":false,"overview":"Ha-ni who was on a honeymoon with her husband, Jae-ho, seems to be uncomfortable with her sister-in-law, Ye-ji. She is a freeloader who lives in her brother's house without any other job. When the close brother and sister's affection was being expressed boldly and the sister's obsession with her brother gets stronger day by day, Ha-ni got tired of her sister-in-law's behavior of entering their bedroom in her sexy underwear. Ha-ni goes to Ik-tae, the manager of the cabin and had a physical relationship. What could the real purpose of their trip to the mountain be, and what could be the fate of the married couple that is tangled like a thread around Ha-ni and her sister-in-law's relationship?","genre_ids":[18,10749],"media_type":"movie","popularity":1.4209,"vote_count":19,"poster_path":"/rQkCN5ozUpzXnaK9Sn0qsrqPMw6.jpg","release_date":"2020-06-10","vote_average":6.658,"backdrop_path":"/xNXKpsY1Rxq9Ncbw8WVs7j4ijZU.jpg","original_title":"시누이의 맛","original_language":"ko"},{"id":390634,"adult":false,"title":"Fate/stay night: Heaven's Feel II. Lost Butterfly","video":false,"overview":"Shirou has lost his Servant, Saber, and is no longer a Master in the Holy Grail War. Despite this, he refuses to leave the battle, determined to protect Sakura. Meanwhile, a mysterious shadow engulfs the city, killing Masters and Servants one by one. As Shirou faces new dangers, Sakura is drawn deeper into her own destiny as a mage.","genre_ids":[16,28,14,18,10749],"media_type":"movie","popularity":2.0728,"vote_count":256,"poster_path":"/4tS0iyKQBDFqVpVcH21MSJwXZdq.jpg","release_date":"2019-01-12","vote_average":6.969,"backdrop_path":"/Amvdexp1W0uqqSEkWlYjM9nDJfa.jpg","original_title":"劇場版「Fate/stay night [Heaven’s Feel]」Ⅱ.lost butterfly","original_language":"ja"},{"id":1150215,"adult":false,"title":"Squared Love Everlasting","video":false,"overview":"Monika and Enzo's whirlwind romance heads toward a fairy-tale ending until a bombshell revelation changes everything.","genre_ids":[10749,35],"media_type":"movie","popularity":0.4883,"vote_count":57,"poster_path":"/9o9FrpdnQnS0OQoQQxwIROxaOoE.jpg","release_date":"2023-03-28","vote_average":6.114,"backdrop_path":"/laF1i3X46RsPe1T79uSeKWUaOrw.jpg","original_title":"Miłość do kwadratu bez granic","original_language":"pl"},{"id":698438,"adult":false,"title":"Swapping: Perfect Neighbor","video":false,"overview":"Couple Jin-goo and Joo-hee have been experiencing a