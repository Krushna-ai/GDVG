rage":7.382,"backdrop_path":"/wcMlVCKjTIT3g3fQNo5iXo586mk.jpg","original_title":"국제시장","original_language":"ko"},{"id":566397,"adult":false,"title":"The Man Standing Next","video":false,"overview":"When the investigation of 'Koreagate' takes place, Park Yong-gak, a former KCIA director who knows everything about the government's operations, heads to the United States in exile.","genre_ids":[18,53],"media_type":"movie","popularity":1.946,"vote_count":147,"poster_path":"/iWavVXt7U20Vu2v5jX5ABE3e6gV.jpg","release_date":"2020-01-22","vote_average":7.088,"backdrop_path":"/m0Zp6dlmjfpolhMWx6KHJvmFlOk.jpg","original_title":"남산의 부장들","original_language":"ko"},{"id":72721,"adult":false,"title":"Nostalgia for the Light","video":false,"overview":"In Chile's Atacama Desert, astronomers peer deep into the cosmos in search for answers concerning the origins of life. Nearby, a group of women sift through the sand searching for body parts of loved ones, dumped unceremoniously by Pinochet's regime.","genre_ids":[99],"media_type":"movie","popularity":0.4777,"vote_count":164,"poster_path":"/j8NsCokx3dveFDL1YAvJPWHkrDx.jpg","release_date":"2010-10-27","vote_average":7.354,"backdrop_path":"/tCKmhgt72QgfbyDb3S6FL6m9Wd3.jpg","original_title":"Nostalgia de la luz","original_language":"es"},{"id":434119,"adult":false,"title":"Confidential Assignment","video":false,"overview":"When a crime organization from North Korea crosses borders and enters South Korean soil, a South Korean detective must cooperate with a North Korean detective to investigate their whereabouts.","genre_ids":[28,18],"media_type":"movie","popularity":1.8712,"vote_count":141,"poster_path":"/gw1iBP09ZaxUgHlvmPpC4Y7dgq6.jpg","release_date":"2017-01-18","vote_average":6.865,"backdrop_path":"/lrZXLxzq9NaFJ0TzyJOH2HKsrWH.jpg","original_title":"공조","original_language":"ko"},{"id":416153,"adult":false,"title":"Arctic Dogs","video":false,"overview":"Animals band together to save the day when the evil Otto Von Walrus hatches a sinister scheme to accelerate global warming and melt the Arctic Circle.","genre_ids":[16,12,35],"media_type":"movie","popularity":2.4477,"vote_count":140,"poster_path":"/5YHjyjd2N0ZXcnGuB8G1nIa6h9t.jpg","release_date":"2019-11-01","vote_average":6.057,"backdrop_path":"/201mKrWi37SE1YkdqRP7rE3QamK.jpg","original_title":"Arctic Dogs","original_language":"en"},{"id":74336,"adult":false,"title":"The Quiet Family","video":false,"overview":"A family decides to buy a lodge in a remote hiking area. Their first customer commits suicide and the distraught family buries his body to avoid the bad publicity. But their luck gets worse, the bodies start piling up, and the family becomes frantic to rectify the situation.","genre_ids":[27,35,80],"media_type":"movie","popularity":1.0806,"vote_count":200,"poster_path":"/VpCKOlhUaoeH0WypQBulnbh8fS.jpg","release_date":"1998-04-25","vote_average":7.02,"backdrop_path":"/tbI4gCfoCtNlZe5hQBwUWcxbPOE.jpg","original_title":"조용한 가족","original_language":"ko"},{"id":72445,"adult":false,"title":"Boat People","video":false,"overview":"A Japanese photojournalist revisits Vietnam after the liberation to document the nation, and begins following and documenting the young children from a poor Vietnamese family.","genre_ids":[18],"media_type":"movie","popularity":0.6039,"vote_count":56,"poster_path":"/bdyxE6bXtozYG2jQiWKZUz3u4LD.jpg","release_date":"1982-10-13","vote_average":7.6,"backdrop_path":"/8uxcz8W9GZ4dGiL7N6b4PvaZWwh.jpg","original_title":"投奔怒海","original_language":"cn"}],"similar_content":[{"id":279641,"adult":false,"title":"Whiskey Tango Foxtrot","video":false,"overview":"In 2002, cable news producer Kim Barker decides to shake up her routine by taking a daring new assignment in Kabul, Afghanistan. Dislodged from her comfortable American lifestyle, Barker finds herself in the middle of an out-of-control war zone. Luckily, she meets Tanya Vanderpoel, a fellow journalist who takes the shell-shocked reporter under her wing. Amid the militants, warlords and nighttime partying, Barker discovers the key to becoming a successful correspondent.","genre_ids":[35,18,10752],"popularity":1.0436,"vote_count":1027,"poster_path":"/xhWbp0lCig5vkdFZPiOGNRL9oMf.jpg","release_date":"2016-03-04","vote_average":6.311,"backdrop_path":"/7295GnkwMbNcHLEXkQkLNIWNa39.jpg","original_title":"Whiskey Tango Foxtrot","original_language":"en"},{"id":10237,"adult":false,"title":"The Honeymoon Killers","video":false,"overview":"Martha Beck, an obese nurse who is desperately lonely, joins a \"correspondence club\" and finds a romantic pen pal in Ray Fernandez. Martha falls hard for Ray, and is intent on sticking with him even when she discovers he's a con man who seduces lonely single women, kills them and then takes their money. She poses as Ray's sister and joins Ray on a wild killing spree, fueled by her lingering concern that Ray will leave her for one of his marks.","genre_ids":[80,18,10749,53],"popularity":0.7738,"vote_count":124,"poster_path":"/3n69M2qBFMWEYAOOQdvxYAaaDLM.jpg","release_date":"1970-02-04","vote_average":6.5,"backdrop_path":"/egrxDU6GM8Dv5u5e8Nm2Wlq7k2E.jpg","original_title":"The Honeymoon Killers","original_language":"en"},{"id":10265,"adult":false,"title":"Seoul Raiders","video":false,"overview":"Agent Lam (Tony Leung) sets out to track a pair of plates used to make fake American dollars. When he discovers the plates, they are conned out of him by enigmatic US Embassy workers Owen (Richie Ren) and JJ (Shu Qi). With the trail now leading to Korea, Lam sets off in hot pursuit. There, amidst the dangerous and glamorous urban landscape of Seoul, Lam finds himself confronting an underworld crime boss known as the Polar Bear, head of the biggest counterfeiting organisation in Asia.","genre_ids":[28,35,12],"popularity":1.2314,"vote_count":51,"poster_path":"/7r9Lqza4onv8tAFUrPjWBMIeo2q.jpg","release_date":"2005-02-05","vote_average":6.1,"backdrop_path":"/pJ1EfeYYqofKqOukkz0UofqULVa.jpg","original_title":"韓城攻略","original_language":"cn"},{"id":10273,"adult":false,"title":"Thelma","video":false,"overview":"Vincent, a down-at-the-heels French cab driver, desparately in need of cash for child support is intrigued when Thelma charters his cab for a trip to Crete. As they travel, talk and flirt, they become friends but the situation grows complicated when Vincent discovers that Telma is a trans woman. Will Vincent decide to explore a country that he's never been to?","genre_ids":[18],"popularity":2.2734,"vote_count":6,"poster_path":"/h5f7CiPLW3IQxGMMlOomIqaJ1im.jpg","release_date":"2002-06-19","vote_average":3.6,"backdrop_path":null,"original_title":"Thelma","original_language":"fr"},{"id":10312,"adult":false,"title":"Patch Adams","video":false,"overview":"The true story of Dr. Hunter \"Patch\" Adams, who in the 1970s found that humor is the best medicine, and was willing to do just anything to make his patients laugh—even if it meant risking his own career.","genre_ids":[35,18],"popularity":3.4721,"vote_count":3395,"poster_path":"/xN1aKur5ddWQSXTqvzDPJD2TCxe.jpg","release_date":"1998-12-25","vote_average":7.305,"backdrop_path":"/sPGgJ0w1oCVPBOW41dN0hpMouhI.jpg","original_title":"Patch Adams","original_language":"en"},{"id":10385,"adult":false,"title":"Hanging Up","video":false,"overview":"Three sisters - Georgia, Eve, and Maddy - do what they do best with life, love, and lunacy on the telephone lines that bind - when their curmudgeonly father, Lou, is admitted to a Los Angeles Hospital. After years of wild living, intermittent affection, and constant phoning, he is finally threatening to die.","genre_ids":[18,35],"popularity":1.1112,"vote_count":184,"poster_path":"/lnnFFGhIXi6ZDU3r29eKHKTHdq0.jpg","release_date":"2000-02-16","vote_average":5.3,"backdrop_path":"/9I9VYNau1KU77OQAcF6WnfOtGcU.jpg","original_title":"Hanging Up","original_language":"en"},{"id":10253,"adult":false,"title":"Dragon Wars: D-War","video":false,"overview":"Ethan learns he carries the spirit of a warrior who battled dragons in 16th-century Korea -- and one day he'll find a tattooed girl carrying the spirit of that warrior's beloved. Years later, he meets Sarah and dragons soon descend on Los Angeles seeking out the two souls of the ancient lovers.","genre_ids":[14,18,27,28,53,878],"popularity":1.2282,"vote_count":444,"poster_path":"/rEpvqWGu08coDLUpcpiz4sMoDYo.jpg","release_date":"2007-08-01","vote_average":4.6,"backdrop_path":"/5WWqrUIGrCb1QvZtYVaSfZgUG8n.jpg","original_title":"디 워","original_language":"ko"},{"id":10303,"adult":false,"title":"The Jewel of the Nile","video":false,"overview":"Joan Wilder is thrust back into a world of murder, chases, foreign intrigue... and love. This time out she's duped by a duplicitous Arab dignitary who brings her to the Middle East, ostensibly to write a book about his life. Of course, he's up to no good, and Joan is just another pawn in his wicked game. But Jack Colton and his sidekick Ralph show up to help our intrepid heroine save the day.","genre_ids":[12,28,35,10749],"popularity":2.6584,"vote_count":1243,"poster_path":"/6VjsIhnIcrz2XdQVHdsMj5DdSa1.jpg","release_date":"1985-08-01","vote_average":6.209,"backdrop_path":"/7Crr6NUGAhfLM2ybjcq1dtN8YUl.jpg","original_title":"The Jewel of the Nile","original_language":"en"},{"id":10355,"adult":false,"title":"Shiri","video":false,"overview":"North Korea's 8th Special Forces hijack a shipment of CTX, a potent new liquid explosive, and threatens South Korea as part of a plot to re-unify the two countries. Ryu and Lee, special agents of O.P.,  South Korea's secret intelligence service, attempt to track down the terrorists and find the CTX. Meanwhile Hee, the 8th's ultra-bad female sniper, resurfaces to wreak havoc and haunt Ryu.","genre_ids":[28,12,18,53],"popularity":1.1476,"vote_count":182,"poster_path":"/7rmye0ThMHMT2VhZj7zdyCcHQVe.jpg","release_date":"1999-02-13","vote_average":6.42,"backdrop_path":"/kwZvgDGG0gZdhOuV0fjEm32PYep.jpg","original_title":"쉬리","original_language":"ko"},{"id":862557,"adult":false,"title":"The Hill","video":false,"overview":"The story of Rickey Hill, who overcomes his physical disability and repairs his relationship with his father in a quest to become a major league baseball (MLB) player.","genre_ids":[36,18],"popularity":2.6643,"vote_count":299,"poster_path":"/e8Dx470lSbIL7OFj7TkFsWAONR5.jpg","release_date":"2023-08-18","vote_average":7.657,"backdrop_path":"/puUUsAri2UchyJgsbkpO3HZfKiw.jpg","original_title":"The Hill","original_language":"en"},{"id":10360,"adult":false,"title":"Hunger","video":false,"overview":"The story of Bobby Sands, the IRA member who led the 1981 hunger strike during The Troubles in which Irish Republican prisoners tried to win political status.","genre_ids":[18,36],"popularity":1.5884,"vote_count":1182,"poster_path":"/84HdTM39G2MzyTl8N9R0wVU9I5b.jpg","release_date":"2008-05-15","vote_average":7.241,"backdrop_path":"/34N9iKlR8FdXiu8r8pSpKcyFUVh.jpg","original_title":"Hunger","original_language":"en"},{"id":10400,"adult":false,"title":"The Hurricane","video":false,"overview":"The story of Rubin \"Hurricane\" Carter, a boxer wrongly imprisoned for murder, and the people who aided in his fight to prove his innocence.","genre_ids":[18],"popularity":1.832,"vote_count":1487,"poster_path":"/zhnxjsNnnpsBMF5V1H7Pzkec45Y.jpg","release_date":"1999-09-17","vote_average":7.4,"backdrop_path":"/ffAL7ZiUnCay51SeHFTrTEUpUkO.jpg","original_title":"The Hurricane","original_language":"en"},{"id":10435,"adult":false,"title":"Chaplin","video":false,"overview":"An aged Charlie Chaplin narrates his life to his autobiography's editor, including his rise to wealth and comedic fame from poverty, his turbulent personal life and his run-ins with the FBI.","genre_ids":[18],"popularity":4.1859,"vote_count":1176,"poster_path":"/53auOJUsPP2YE97HTYgBQ0WO2gO.jpg","release_date":"1992-12-17","vote_average":7.4,"backdrop_path":"/qjKUUw2AhUZnbEzQIOjAN3chjeE.jpg","original_title":"Chaplin","original_language":"en"},{"id":10511,"adult":false,"title":"In America","video":false,"overview":"A family of Irish immigrants adjusts to life on the mean streets of Hell's Kitchen while also grieving the death of a child.","genre_ids":[18],"popularity":1.1969,"vote_count":379,"poster_path":"/cUhMjWQyyApA0pFinogCsE2wy8g.jpg","release_date":"2003-09-22","vote_average":7.2,"backdrop_path":"/uJHm54Z8Y6WSTSDvhqGSeKjP88v.jpg","original_title":"In America","original_language":"en"},{"id":281957,"adult":false,"title":"The Revenant","video":false,"overview":"In the 1820s, a frontiersman, Hugh Glass, sets out on a path of vengeance against those who left him for dead after a bear mauling.","genre_ids":[37,18,12],"popularity":11.0229,"vote_count":19034,"poster_path":"/ji3ecJphATlVgWNY0B0RVXZizdf.jpg","release_date":"2015-12-25","vote_average":7.5,"backdrop_path":"/mNQtUJv1F3u0uSKILFrGjIHqkxx.jpg","original_title":"The Revenant","original_language":"en"},{"id":864734,"adult":false,"title":"Sijou","video":false,"overview":"Sijou is a small boy who lives in the village of Saikhonguri, a village in Baksa near the Indo-Bhutan border. He lives with his father. One day, his life takes a drastic shift when he becomes a victim of the Feudal Land Tenure System which was in practice in Bhutan till 1958. Gradually, his life takes drastic turns which eventually turn him into a monk.","genre_ids":[18,36],"popularity":0.1414,"vote_count":0,"poster_path":"/72UpujRYbKxSQ9Mh1gWLicCG5ZI.jpg","release_date":"2021-03-24","vote_average":9,"backdrop_path":null,"original_title":"Sijou","original_language":"ne"},{"id":664378,"adult":false,"title":"Yumurcak Köprüaltı Çocuğu","video":false,"overview":"Yumurcak is a very naughty boy, living with his father Nihat who is a cab driver. One day a bar singer named Aysel gets on his car, escaping from someone. Nihat saves her and becomes her driver. Bekir who is the partner of the bar, fancies Aysel and he is very jealous of her. Another gangster kills him and puts the blame on Nihat. Yumurcak's mother Selma, having learned the news, walks carelessly on the street and gets hit by a car in an accident and becomes blind. Yumurcak finds the gun of the crime in the garden, takes it to the judge and asks for his father's release. Bekir tries to escape and he kidnaps Yumurcak. However Nihat and the inspector reach just in time. Yumurcak and his family return to their happy days.","genre_ids":[35,18,12],"popularity":0.1752,"vote_count":3,"poster_path":"/5YXkPSHvuZ8Qqkq3KLT2qrpoOvR.jpg","release_date":"1970-01-01","vote_average":6,"backdrop_path":"/bICPPqtyCJcrpnWIW0t2RYr7Prw.jpg","original_title":"Yumurcak Köprüaltı Çocuğu","original_language":"tr"},{"id":12086,"adult":false,"title":"Machuca","video":false,"overview":"Santiago, capital of Chile during the Marxist government of elected, highly controversial president Salvador Allende. Father McEnroe supports his leftist views by introducing a program at the prestigious \"collegio\" (Catholic prep school) St. Patrick to allow free admission of some proletarian kids. One of them is Pedro Machuca, slum-raised son of the cleaning lady in Gonzalo Infante's liberal-bourgeois home. Yet the new classmates become buddies, paradoxically protesting together as Gonzalo gets adopted by Pedro's slum family and gang. But the adults spoil that too, not in the least when general Pinochet's coup ousts Allende, and supporters such as McEnroe.","genre_ids":[18],"popularity":0.6655,"vote_count":210,"poster_path":"/sP3ceWIvq7DZm8VLYWuFKzbDK43.jpg","release_date":"2004-02-24","vote_average":7.75,"backdrop_path":"/xPt9uunKOZ8EC2xukQbkSDh45oq.jpg","original_title":"Machuca","original_language":"es"},{"id":664423,"adult":false,"title":"The Windermere Children","video":false,"overview":"The story of the pioneering project to rehabilitate child survivors of the Holocaust on the shores of Lake Windermere.","genre_ids":[18,10752,36],"popularity":0.6847,"vote_count":119,"poster_path":"/4RnQMwVVxhJlZDJybptAOrrpt87.jpg","release_date":"2020-01-27","vote_average":7.4,"backdrop_path":"/4Bv9nFURVMUZ5fXK9RIvEneu4EH.jpg","original_title":"The Windermere Children","original_language":"en"},{"id":12093,"adult":false,"title":"Lilya 4-ever","video":false,"overview":"In a struggling post-Soviet community, Lilya a teenage girl is abandoned when her mother moves to the United States with her boyfriend. Facing neglect and poverty, she meets Andrei, who offers her a job in Sweden, giving her hope for a better life — and a journey that will change everything.","genre_ids":[18,80],"popularity":2.544,"vote_count":643,"poster_path":"/5i1uhvcdv2Iogx0Bb1znvUmkCvN.jpg","release_date":"2002-08-23","vote_average":7.617,"backdrop_path":"/fJeOpfzQSkzESNPmEXpyNLMmOtI.jpg","original_title":"Lilja 4-ever","original_language":"sv"}],"external_ids":{"imdb_id":"tt6878038","twitter_id":null,"facebook_id":null,"wikidata_id":"Q28698824","instagram_id":null,"metacritic_id":"movie/a-taxi-driver","rotten_tomatoes_id":"m/a_taxi_driver_2017"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":131111,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AU","release_dates":[{"note":"","type":3,"iso_639_1":"en","descriptors":[],"release_date":"2018-01-11T00:00:00.000Z","certification":"M"}]},{"iso_3166_1":"BR","release_dates":[{"note":"Consta no Filmow 16 e no IMDB 14. Decidi pelo site brasileiro.","type":3,"iso_639_1":"pt","descriptors":[],"release_date":"2018-01-11T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"CA","release_dates":[{"note":"Fantasia International Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2017-08-02T00:00:00.000Z","certification":""}]},{"iso_3166_1":"DE","release_dates":[{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":"2021-09-09T00:00:00.000Z","certification":"16"},{"note":"","type":5,"iso_639_1":"",