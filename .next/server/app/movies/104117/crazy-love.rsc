NIAdaeOD.jpg","original_title":"Deadpool & Wolverine","original_language":"en"},{"id":1011477,"adult":false,"title":"Karate Kid: Legends","video":false,"overview":"After a family tragedy, kung fu prodigy Li Fong is uprooted from his home in Beijing and forced to move to New York City with his mother. When a new friend needs his help, Li enters a karate competition – but his skills alone aren't enough. Li's kung fu teacher Mr. Han enlists original Karate Kid Daniel LaRusso for help, and Li learns a new way to fight, merging their two styles into one for the ultimate martial arts showdown.","genre_ids":[28,12,18],"media_type":"movie","popularity":12.5216,"vote_count":1107,"poster_path":"/c90Lt7OQGsOmhv6x4JoFdoHzw5l.jpg","release_date":"2025-05-08","vote_average":7.037,"backdrop_path":"/7Q2CmqIVJuDAESPPp76rWIiA0AD.jpg","original_title":"Karate Kid: Legends","original_language":"en"}],"similar_content":[{"id":462605,"adult":false,"title":"Wine War","video":false,"overview":"When a world renowned Chinese sommelier residing in France is contacted by his childhood buddy in China to help him auction for a bottle of 1855 vintage wine on behalf of the Chinese government, he agrees without question. Little does he realize he is about to be sucked into an age-old feud between rivaling vineyards and a historical mystery that might shatter the whole oenological industry.","genre_ids":[35,28],"popularity":0.3183,"vote_count":4,"poster_path":"/ml4xXVCGviddlIQFJi1ojqMRmRL.jpg","release_date":"2017-05-19","vote_average":6.5,"backdrop_path":"/9L5kRXYVHYR22FxlgPkpa8XLS1e.jpg","original_title":"搶紅","original_language":"zh"},{"id":462613,"adult":false,"title":"The Pugilist","video":false,"overview":"After his eldest son is murdered in a gangland hit, an absentee father desperately tries to protect what’s left of the shattered family he abandoned.","genre_ids":[18,80],"popularity":0.4199,"vote_count":5,"poster_path":"/yWFYOfUfoHs6HXomcgQM1IgBGBs.jpg","release_date":"2017-06-28","vote_average":6.8,"backdrop_path":"/s03W37zkC2XNQILnwqe5okZFdIh.jpg","original_title":"The Pugilist","original_language":"en"},{"id":462620,"adult":false,"title":"Bridesman","video":false,"overview":"After being asked to be 'Maid' of Honor for his sister and throw the bachelorette party, Johnny, a goofy alpha male who is out of money and out of options turns to the only guys he knows he can afford...Mexican day laborers.","genre_ids":[35],"popularity":0.2172,"vote_count":2,"poster_path":"/bWNrQF6Jo6ad3cGm4RQvMAoN1gC.jpg","release_date":"2016-05-19","vote_average":3.5,"backdrop_path":null,"original_title":"Bridesman","original_language":"en"},{"id":462623,"adult":false,"title":"Fanny Pack","video":false,"overview":"A young Indian-American woman who wants to follow her dreams, and a fanny pack clad Indian father who chases his daughter through an airport hoping that she will follow his.","genre_ids":[35],"popularity":0.5549,"vote_count":1,"poster_path":"/sjoOpIIlLibHt99L1zCYSZ44s0n.jpg","release_date":"2016-09-01","vote_average":5,"backdrop_path":null,"original_title":"Fanny Pack","original_language":"fr"},{"id":853646,"adult":false,"title":"The Railway and the Girl","video":false,"overview":"The short film shot within the movie \"Ritual\" (2000)","genre_ids":[18],"popularity":0.3452,"vote_count":0,"poster_path":"/aaGCXW15Q9XIf7nWMWIJI1KqtQM.jpg","release_date":"2003-07-24","vote_average":0,"backdrop_path":null,"original_title":"鉄道と少女","original_language":"ja"},{"id":853655,"adult":false,"title":"Article 12","video":false,"overview":"A young Colombian woman confronts her father and best friend, who resist her taking to the streets to protest for fear of the repression and violence that is taking place in the streets.","genre_ids":[18],"popularity":0.4849,"vote_count":0,"poster_path":"/pMGEQsbSYbrRYnEvVPESRlOJgGV.jpg","release_date":"2021-07-20","vote_average":0,"backdrop_path":null,"original_title":"Artículo 12","original_language":"es"},{"id":853662,"adult":false,"title":"Jaguar Man","video":false,"overview":"Two moments in the life of Pedro. First in 1997, he lives with his family in Rio de Janeiro and works at Gás do Brasil, a company that is undergoing a tough restructuring process, with layoffs and early retirements. Soon, privatization will come. In the second moment, two years later, Pedro lives retired in his hometown Barbosa, in the company of his childhood memories, his dog and his girlfriend. By interweaving these two moments in time, we put ourselves in Pedro's skin and experience his fears and delights.","genre_ids":[18],"popularity":0.1337,"vote_count":4,"poster_path":"/bEdbdPiipYf3SgmC0kjECGn7IoR.jpg","release_date":"2021-08-26","vote_average":4.2,"backdrop_path":"/syd9HgwwgAKSNiGYVLqooKb95Bl.jpg","original_title":"Homem Onça","original_language":"pt"},{"id":853665,"adult":false,"title":"The Fascist Jew","video":false,"overview":"Oberdan Rossi is half Jewish and a fascist. After coming back from the Ethiopian war, he becomes disillusioned and works as a journalist.","genre_ids":[18],"popularity":0.1637,"vote_count":2,"poster_path":"/rQRyAmYLU8q82ZwiIvnEl6Ocf9M.jpg","release_date":"1980-09-02","vote_average":2,"backdrop_path":null,"original_title":"L’ebreo fascista","original_language":"it"},{"id":1451309,"adult":false,"title":"De Grey, un Récit romanesque","video":false,"overview":"An elderly woman would like some company as her son is off venturing foreign lands and seducing women from lands afar. Her resident priest who seems to live in the same château as her does not agree and seems to have preconceptions and superstitions as to a family curse.","genre_ids":[18,10770],"popularity":0.1361,"vote_count":0,"poster_path":"/ph1IRlGgnV6awsL5kNd5IckXcGr.jpg","release_date":"1976-03-20","vote_average":0,"backdrop_path":"/Y6RTF7DS0uX4pAUSI3l5mBOthv.jpg","original_title":"De Grey, un Récit romanesque","original_language":"fr"},{"id":271223,"adult":false,"title":"The Plague","video":false,"overview":"A nurse in the Red Crescent (the Turkish equivalent of the Red Cross) fights to save the populace during a plague.","genre_ids":[18],"popularity":0.72,"vote_count":1,"poster_path":"/y5wJXWk6aBg1rhkXZnqlTYer10Y.jpg","release_date":"1954-01-01","vote_average":6,"backdrop_path":null,"original_title":"Salgin","original_language":"en"},{"id":271231,"adult":false,"title":"The Land","video":false,"overview":"The film deals with the harsh realities of village life and the problems of landholding The film, in an almost documentary style.","genre_ids":[18],"popularity":1.0146,"vote_count":0,"poster_path":"/p0LkUTw4cABSnYASLrqO6AsY2Sg.jpg","release_date":"1952-01-01","vote_average":0,"backdrop_path":"/cNFPWAOT5eQE5FhEfG6PrPuxfqR.jpg","original_title":"Toprak","original_language":"tr"}],"external_ids":{"imdb_id":"tt0107565","twitter_id":null,"facebook_id":null,"wikidata_id":"Q5183200","instagram_id":null,"mydramalist_id":"31468","rotten_tomatoes_id":"m/1077382-crazy_love"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":104117,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"HK","release_dates":[{"note":"","type":3,"iso_639_1":"cn","descriptors":[],"release_date":"1993-04-17T00:00:00.000Z","certification":"III"}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":{"id":680723,"name":"The Fruit is Ripe Series","poster_path":"/vP6QEHbKpl4IRvtmFZdEJxVjcak.jpg","backdrop_path":"/dRbKPalZnixqJCq6F33TRLBrOK8.jpg"},"collection_id":null,"wikidata_metadata":{},"mood_tags":null,"trope_tags":null,"vibe_description":null,"ai_enriched_at":null,"ai_enrichment_version":0}}]]
