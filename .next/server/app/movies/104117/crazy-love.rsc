5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Crazy Love\",\"description\":\"What was supposed to be summer school in England becomes an adventurous exotic and romantic journey for a beautiful teenage girl. [from the Tai Seng Catalog] A nice story of a free-sprited (or, depending on your viewpoint, prick-teasing) young woman on a short journey of discovery.\",\"image\":\"https://image.tmdb.org/t/p/w500/vM4Tb2Wxk2X0Sgfy1wAS9bzSZsa.jpg\",\"datePublished\":\"1993-04-17\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"cn\",\"genre\":[\"erotic film\",\"Comedy\",\"Romance\",\"Drama\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.3,\"bestRating\":10,\"ratingCount\":41}}"}}],["$","$L10",null,{"initialDrama":{"id":"cf6baf61-d62a-44d0-bf44-72a9296ed0f1","tmdb_id":79871,"imdb_id":"tt0107565","content_type":"movie","title":"Crazy Love","original_title":"蜜桃成熟時","overview":"What was supposed to be summer school in England becomes an adventurous exotic and romantic journey for a beautiful teenage girl. [from the Tai Seng Catalog] A nice story of a free-sprited (or, depending on your viewpoint, prick-teasing) young woman on a short journey of discovery.","poster_path":"/vM4Tb2Wxk2X0Sgfy1wAS9bzSZsa.jpg","backdrop_path":"/5hcouxgjYMIdH3e113LOLK3eD6D.jpg","release_date":"1993-04-17","first_air_date":null,"status":"published","original_language":"cn","origin_country":["HK"],"genres":[{"name":"erotic film"},{"id":35,"name":"Comedy"},{"id":10749,"name":"Romance"},{"id":18,"name":"Drama"},"erotic film"],"popularity":7.6097,"vote_average":6.3,"vote_count":41,"runtime":77,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:51:18.365455+00:00","updated_at":"2026-02-22T21:55:15.729+00:00","tagline":null,"homepage":null,"budget":0,"revenue":1575158,"production_companies":[{"id":11109,"name":"Ko Chi Sum Film