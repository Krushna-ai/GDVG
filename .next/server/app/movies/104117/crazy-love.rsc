th":"/7yADw2Bkp18djl1QiuwZRDIXgVF.png","iso_639_1":"zh","vote_average":0.166},{"width":1110,"height":322,"file_path":"/2CglncSm2MLojHvXR3FQ3DbgV8H.png","iso_639_1":"zh","vote_average":0.166},{"width":1036,"height":2854,"file_path":"/fTeUbS0DzmIg5y5oWZ9hhEs2vHi.png","iso_639_1":"zh","vote_average":0}],"posters":[{"width":1000,"height":1500,"file_path":"/vM4Tb2Wxk2X0Sgfy1wAS9bzSZsa.jpg","iso_639_1":"zh","vote_average":2.542},{"width":2000,"height":3000,"file_path":"/eDbaYa0ywZSkUneyh2BcdTUByla.jpg","iso_639_1":"zh","vote_average":2.542},{"width":1000,"height":1500,"file_path":"/3uU8W196YMZQbAb9BmCRAJK38s8.jpg","iso_639_1":"zh","vote_average":1.75},{"width":1000,"height":1500,"file_path":"/oj6TyTfm73dUToll45UhleECqXn.jpg","iso_639_1":"zh","vote_average":1.75},{"width":500,"height":750,"file_path":"/h7EZHd4aAN1zyiJzKaS2bdci8BJ.jpg","iso_639_1":"zh","vote_average":0.166},{"width":2000,"height":3000,"file_path":"/PWMuocSam7jhm15zUcKmHFkjXH.jpg","iso_639_1":"zh","vote_average":0.166},{"width":2000,"height":2660,"file_path":"/cHwUw9RLlLN8rRqy2YguuWSxs0W.jpg","iso_639_1":"zh","vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/5hcouxgjYMIdH3e113LOLK3eD6D.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/9yCMwZIIOJZWyeQ0qFvSrV7igEs.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/hRQoXV876Z9MflKY78QnjYpP8SX.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/cGGIM7v96f1dpY1eBTXAfSOr2yd.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/aCxSJuLR0Qg4FMIgeEekiCvKEFv.jpg","iso_639_1":null,"vote_average":2.278},{"width":1920,"height":1080,"file_path":"/aCXieHkIHMr2a1hL34GVeX7Ygzb.jpg","iso_639_1":null,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/Ah1gqAk1Sq5t3itwhrcr8FcoUT8.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/et0zQLb73NjMRe1t2PScMGVPgEX.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/xvtYPVKTFfUpVEKQgbGKFoax0ey.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/ihp4EQBd970Kfa3heu00yQoJje4.jpg","iso_639_1":"zh","vote_average":0},{"width":1920,"height":1080,"file_path":"/61phXU9BwiJvY7W1nKJfcLjWuL1.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/7TUMHuE0jAyl5vedvuvgFndpQaP.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/wpTenAPwZXMQ5SIYd3Bkpoy3yZz.jpg","iso_639_1":"zh","vote_average":0}]},"enriched_at":"2026-04-21T03:17:42.312+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Crazy Love","runtime":77,"tagline":"","homepage":"","overview":"What was supposed to be summer school in England becomes an adventurous exotic and romantic journey for a beautiful teenage girl. [from the Tai Seng Catalog] A nice story of a free-sprited (or, depending on your viewpoint, prick-teasing) young woman on a short journey of discovery."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"蜜桃成熟时","runtime":77,"tagline":"","homepage":"","overview":"富家女阿珍（李丽珍 饰）狂野不羁，自幼受父母溺爱的她深信自己的处世哲学，只想要追寻自由简单生活与浪漫炽热的爱情。暑假期间，父母安排其前往英国参加夏令营， 她却想趁此机会计划一个属于自己的假期，暗地里将机票送给 好友，自己却前往男友处准备与其过甜蜜的二人世界。岂料发现男友正与另一女子鬼混，她一气之下开始自己的孤独旅途，一路上遇到了各色人士，有好色的流氓、不羁的浪子、有趣的夫妻......到底珍能否找到心中所爱呢？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"蜜桃成熟時","runtime":0,"tagline":"","homepage":"","overview":"富家女 Jane 高中暑假期間被父母安排往英國深造英文。她將機票轉送他人，悄悄前往男友處準備與其二人世界，卻發現男友有了外遇，於是又憤然出走。在野外險遭強暴，僥倖逃脱。後遇到作家 David，兩人一見鍾情，雖然情意綿綿，但因某些原因而分離數日，但最後仍重修舊好。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Wat een zomerschool in Engeland had moeten zijn, wordt een avontuurlijke, exotische en romantische reis voor een mooi tienermeisje. [uit de Tai Seng Catalogus] Een mooi verhaal van een vrijgevochten (of, afhankelijk van je standpunt, prikplagende) jonge vrouw op een korte ontdekkingsreis."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"蜜桃成熟時","runtime":75,"tagline":"","homepage":"","overview":"富家女Jane高中暑假期間被父母安排往英國深造英文。她將機票轉送他人，悄悄前往男友處準備與其二人世界，卻發現男友有了外遇，於是又憤然出走。在野外險遭強暴，僥倖逃脫。後遇到作家David，兩人一見鍾情，雖然情意綿綿，但因某些原因而分離數日，但最後仍重修舊好。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"밀도성숙시","runtime":0,"tagline":"","homepage":"","overview":"아진은 부잣집 외동딸로 방학을 이용해 영국에서 열리는 하계 캠프에 가기로 한다. 단짝 친구 애이미와 그녀의 남자친구가 공항에서 서로의 이별을 아쉬워하 것을 보고 비행기표를 건네주고 영국행을 포기한다. 그녀는 자신의 남자친굴 찾아가는데 다른 여자와 있는 장면을 보고 그와 결별할 것을결심한다. 그리고 그녀는 진정한 사랑을 찾아 여행을 떠나가로 마음 먹는다. 여행길에 진은 여러가지 수난도 당하지만 해변에서 우연히 만난 히피에게 그의 사랑학에 대한 이야기를 듣고, 또한 극작가 지망생인 대위라는 남자를 만나 서로 사랑하게 된다. 하지만 둘 사이에 오해가 생겨 아진은 대위와 헤어지게 되고 다시 사랑을 찾아 떠난다. 그러나 그녀가 사랑할 수 있는 사람은 대위 밖에 없다는 것을 느끼게 된다. 그리고 우연히 다시만난 히피와 이야기를 나누며서 그녀가 진정으로 사랑하는 사람은 대위라는 것이 더욱 확실해 진다. 또한 사랑하는 사이라면 자존심도 버릴줄 알아야 된다고 생각하여 직접 그를 찾아가고 사랑을 확인한다. 그로써 그녀의 사랑 여행도 막을 내리게 된다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"O Fruto Maduro","runtime":76,"tagline":"","homepage":"","overview":"A jovem e rica estudante Jane, deveria ir junto a sua amiga Amy aos Estados Unidos durante as férias de verão do colégio para estudar inglês. Em vez disso entrega a passagem para que namorado de Amy a possa acompanahr, e Jane vai a casa do seu namorado John, mas descobre que ele a está traindo e foge com raiva. Depois de vários incidentes, parte em uma jornada exótica e romântica em busca do verdadeiro amor."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"รักผิดต้องลองใหม่","runtime":0,"tagline":"","homepage":"","overview":"สิ่งที่ควรจะเป็นโรงเรียนภาคฤดูร้อนในอังกฤษกลับกลายเป็นการเดินทางผจญภัย แปลกใหม่ และโรแมนติกสำหรับเด็กสาววัยรุ่นที่สวยงาม [จากแคตตาล็อก Tai Seng] เรื่องราวดีๆ ของหญิงสาวผู้มีจิตวิญญาณอิสระ (หรือขึ้นอยู่กับมุมมองของคุณ อาจเป็นการยั่วยวน) ในการเดินทางสั้นๆ สู่การค้นพบ"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Tình Ngây Dại","runtime":0,"tagline":"","homepage":"","overview":"Câu chuyện trong phim Tình Ngây Dại kể về một cô gái trẻ, giàu có, có tư tưởng tự do tên Jane (do Loletta Lee thủ vai ), vào một ngày nọ cô nàng xinh đẹp này đã quyết định đến thăm Hồng Kông thay vì chuyến du học sang Vương quốc Anh theo ý định của bố mẹ cô, để có thể đi được Hồng Kông thì Jane đã lừa bố mẹ chấp thuận sau khi phát hiện bạn trai lừa dối mình. Sau nhiều sự cố, cô gặp Kwan, người đang ở cùng khách sạn với cô. Cô có động lực để tìm kiếm một tình yêu đích thực, hạnh phúc và Kwan không đảm nhận vai trò đó, cũng kể từ đó mà mỗi người đi một đường khác nhau và không còn liên quan gì đến nhau nữa."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"}],"reviews_tmdb":[],"recommendations":[{"id":999278,"adult":false,"title":"The Goldsmith","video":false,"overview":"Determined to rob a goldsmith, three young robbers break into his country house. The man and his wife turn out to be less defenseless than they seem.","genre_ids":[27,53],"media_type":"movie","popularity":1.3147,"vote_count":101,"poster_path":"/6eUxBpQSfFvQx1tJLRe74lyMw13.jpg","release_date":"2022-10-08","vote_average":5.9,"backdrop_path":"/sBk6nzxhtTkrn9JZj32vaRki0QG.jpg","original_title":"L'Orafo","original_language":"it"},{"id":184068,"adult":false,"title":"An Amorous Woman of Tang Dynasty","video":false,"overview":"Rebellious Yu Yuan-gi becomes a Taoist priestess in order to avoid traditional roles designated to her as a woman by the society and focus on her studies and poetry. However, her trysts with both her maid and a ronin lead to trouble.","genre_ids":[10749,28,18],"media_type":"movie","popularity":1.3116,"vote_count":17,"poster_path":"/r3AKLf3zFFfRzhGLOrj9zzqHFmq.jpg","release_date":"1984-06-01","vote_averag