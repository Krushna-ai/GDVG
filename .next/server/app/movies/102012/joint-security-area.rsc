9:{"metadata":[["$","title","0",{"children":"Joint Security Area | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Two North Korean soldiers are killed in the border area between North and South Korea, prompting an investigation by a neutral body. The sergeant is the shooter, but the lead investigator, a Swiss-Korean woman, receives differing accounts from the two sides."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/102012/joint-security-area"}],["$","meta","5",{"property":"og:title","content":"Joint Security Area"}],["$","meta","6",{"property":"og:description","content":"Two North Korean soldiers are killed in the border area between North and South Korea, prompting an investigation by a neutral body. The sergeant is the shooter, but the lead investigator, a Swiss-Korean woman, receives differing accounts from the two sides."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/102012/joint-security-area"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/etoPOj0bXzfw0LBNslCxqO7MHuv.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Joint Security Area"}],["$","meta","12",{"name":"twitter:description","content":"Two North Korean soldiers are killed in the border area between North and South Korea, prompting an investigation by a neutral body. The sergeant is the shooter, but the lead investigator, a Swiss-Korean woman, receives differing accounts from the two sides."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/etoPOj0bXzfw0LBNslCxqO7MHuv.jpg"}],["$","link","14",{"rel":"icon","hre