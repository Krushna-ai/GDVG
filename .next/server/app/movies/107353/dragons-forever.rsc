9:{"metadata":[["$","title","0",{"children":"Dragons Forever | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"A hot-shot lawyer is hired by a Hong Kong chemical plant to dispose of opposition to their polluting ways. But when he falls for a beautiful woman out to stop the plant, he is torn in a conflict of interest and asks his trusty friends Samo and Biao to help out at least until they discover the true purpose of the plant."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/107353/dragons-forever"}],["$","meta","5",{"property":"og:title","content":"Dragons Forever"}],["$","meta","6",{"property":"og:description","content":"A hot-shot lawyer is hired by a Hong Kong chemical plant to dispose of opposition to their polluting ways. But when he falls for a beautiful woman out to stop the plant, he is torn in a conflict of interest and asks his trusty friends Samo and Biao to help out at least until they discover the true purpose of the plant."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/107353/dragons-forever"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/lt94C482UqyVlq1UdK5nvXukaw7.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Dragons Forever"}],["$","meta","12",{"name":"twitter:description","content":"A hot-shot lawyer is hired by a Hong Kong chemical plant to dispose of opposition to their polluting ways. But when he falls for a beautiful woman out to stop the plant, he is torn in a conflict of interest and asks his trusty friends Samo and Biao to help out at least until they discover the true purpose of th