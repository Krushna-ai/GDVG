average":0}],"backdrops":[{"width":2500,"height":1406,"file_path":"/h1vNqJzPCTPg9Hhfxtv2XdE6Pna.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/cIhBeI3bEQnLxXtnmPgw1Ewxjoi.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/aluDJ824EVmMfj1YBFxaOscwR4R.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/aqHEBoRTX5UGnXuZcf35BUhjKM2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/tbgaH7DholS2qQfrzFWYHe2jYxS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/nxFmdNclgPjgostBOh5pQZCsJsa.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/9QU9EdaUktuJ3Hz5UPfmfVOhSJo.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/zEAze4a2Cpn0GCRRmVWDjTshmkT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/jfa4rrHGYuwSLxqFZ40KXbiWhLP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1458,"height":820,"file_path":"/ifYqJmYKdUx32itJBkSWkippjly.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/xWlDWExYabPFnbRPDIz0vqqjYoj.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/e4xnUo8yOmlUvUcnQUS85Izp79q.jpg","iso_639_1":"ko","iso_3166_1":"KR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/tswStrBwuEcGr8EGdlV4z0iqIng.jpg","iso_639_1":"ko","iso_3166_1":"KR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/cE1qLvZxmn8zfBTYUYDausUCWpw.jpg","iso_639_1":"ja","iso_3166_1":"JP","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:47:47.767+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Thieves","runtime":135,"tagline":"All for the money. One for the revenge. Every man for himself.","homepage":"","overview":"A gang of South Korean thieves team up with a Hong Kong crew to steal a diamond necklace from a heavily-guarded casino safe in Macau. As the cops close in, old betrayals — and misunderstandings — resurface."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"The Thieves","runtime":135,"tagline":"Tudo pelo dinheiro. Um pela vingança. Cada um por si.","homepage":"","overview":"Ação Blockbuster em um assalto sofisticado e espetacular de um grupo de ladrões. Quando Popie e seus comparsas viajam para Macau para fazer um trabalho, eles descobrem que por trás do golpe de Estado um ex-parceiro de Popie. O plano é para roubar um diamante, \"Lágrimas do Sol\", que vale uma fortuna. O problema é que ninguém sabe, que cada um tem o seu próprio plano."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"夺宝联盟","runtime":135,"tagline":"","homepage":"","overview":"曾轰动全球且价值高达300亿的钻石太阳之泪惊现中国澳门，某神秘人物委托混迹赌场的盗贼朴澳门 组织人马侵入赌场金库，盗取钻石，事成之后报酬颇丰。在此之后，朴从韩国网罗了当年被他背叛的伙伴波比、詹姆帕诺、艾妮可、口香糖、百事，以及中国方面的陈、安德鲁、朱莉 、乔尼 等人。这些人中包括偷盗、绳索、路线、演技等各方面高手，实可谓一次强强联合。在朴澳门的周密策划下，偷盗行动有条不紊地展开。在此过程中两方人马暗暗较劲又相互帮衬配合，紧张有趣而意外迭出，上演了一出中韩盗贼大比拼。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"The Thieves","runtime":135,"tagline":"Dodookdeul","homepage":"","overview":"Popeye, yardımcısı Jampano, anne kız numarası yapan alkolik Chewing Gum ve seksi hırsız Anycall ile beraber Leesung Galeri'nin varlıklı sahibinden nadide bir eseri çalarlar. Ertesi günse Popeye'yi yakalamaya çalışan ve her adımını takip eden polis memuru tarafından tarafından basılırlar.  Kore'den kaçmak zorunda kalan çete Hong Kong'ta Popeye'nin eski patronu Park'ın çetesine katılır. Çete lideri Park'ın amacı Makau'de ağır güvenlik önlemleriyle korunan bir kumarhaneden 30 milyon dolar değerindeki \"Güneşin Gözyaşları\" isimli elmas kolyeyi çalmaktır..."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":135,"tagline":"","homepage":"","overview":"Popie, Yenicall, Chewinggum och Zampano och en grupp av professionella tjuvar i Sydkorea. Efter att de kommer över en värdefull antik vas, kontaktas de av Macao Park som föreslår ett väldigt lukrativt jobb i Macau. Samtidigt släpps Pepsee från fängelset genom en speciell benådning. För ett par år sedan jobbade Macao Park, Pepsee och Popie tillsammans. Macao Park och Pepsee var också ett par. Under ett guldrån brister en hisskabel och Macao Park försvinner med guldet, medan Pepsee blir gripen och sätts i fängelse. Nu är Popie, Yenicall, Chewinggum och Zampano på väg till Hong Kong för att jobba med Macao Park. Vad Macao Park inte vet är att Pepsee också kommer med dem..."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Dodookdeul","runtime":135,"tagline":"The Thieves","homepage":"","overview":"Om na hun laatste diefstal even van de radar te verdwijnen gaan Popeye en zijn dievenbende naar Macao waar ze een nieuwe opdracht hebben aangenomen. De opdrachtgever is niemand minder dan Macau Park, Popeye's voormalige partner. Enkele jaren geleden, bij hun laatste opdracht samen, verdween Macau Park spoorloos met 68 kilo goud. Naast de groep van Popeye heeft hij echter ook een Chinese dievenbende ingehuurd. Het plan is om een kostbare diamant te stelen uit een casino."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"The Thieves","runtime":135,"tagline":"","homepage":"","overview":"Um ein wenig Gras über ihren letzten Überfall wachsen zu lassen, nehmen Popeye und seine Partner einen Job im weit entfernten Macau an. Doch der Auftraggeber des Jobs ist Popeyes alter Partner Macau Park, der die Bande vor Jahren um deren Diebesgut betrog. Für sein nächstes Vorhaben hat Marcau auch andere chinesische Diebe kontaktiert, doch niemand weiß genau, was er vorhat. Der Plan nimmt für Macau eine überraschende Wendung, als Popeye Pepsi mit ins Spiel bringt, eine geniale Safe-Knackerin und ehemalige Geliebte von Macau. Das Ziel der Einbrecher ist ein 20 Millionen Dollar teurer Diamant, der in einem Casino-Safe gelagert wird. Während sie alle gemeinsam den Überfall planen, hat jeder insgeheim seine eigenen Gründe, um den Diamant für sich zu behalten zu wollen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"El gran golpe","runtime":135,"tagline":"Todos por el dinero. Uno por la venganza. Cada uno por su cuenta.","homepage":"","overview":"Popie y sus compinches viajan a Macao para un trabajo. Cuando llegan, descubren que el que está detrás del golpe no es otro que el antiguo socio de Popie. El plan es robar un diamante que vale una fortuna y que es conocido como la “lágrima del sol”. Lo que ninguno de ellos sabe es que cada uno tiene su propio plan."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Воры","runtime":135,"tagline":"","homepage":"","overview":"Интернациональная команда воров экстра-класса планирует грандиозное ограбление в Макао. Все участники банды — опытные профессионалы, бывали в переделках и способны эффективно работать в самых опасных и стрессовых условиях. Однако, несмотря на то, что все роли в безупречном плане преступления четко определены, многие из участников расклада совсем не собираются довольствоваться своей долей и коварно намереваются умыкнуть весь куш. К тому же один из них — полицейский «под прикрытием»…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"10 ดาวโจรปล้นโคตรเพชร","runtime":135,"tagline":"","homepage":"","overview":"The Thieves เป็นหนังแอ็กชั่นทริลเลอร์ที่เล่าเรื่องของ 5 สุดยอดนักโจรกรรมแห่งเกาหลีใต้ที่ได้รับคำสั่งจากอดีตเจ้านายให้รับงานขโมย โคตรเพชรที่มีชื่อว่า Tear of the Sun ซึ่งจะทำให้พวกเขาต้องเผชิญหน้ากับสุดยอดนักโจรกรรมแห่งฮ่องกง กับฉากหลังบ่อนกาสิโนในมาเก๊า เป็นงานแนวแอ็กชั่นจารกรรม ที่ตัวอย่างอาจทำให้หลายๆ คนนึกไปถึงงานประเภทเดียวกันอย่าง Ocean Eleven"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":135,"tagline":"10인의 도둑, 1개의 다이아몬드 그들이 움직이기 시작했다!","homepage":"","overview":"한 팀으로 활동 중인 한국의 도둑 뽀빠이와 예니콜, 씹던껌, 잠파노. 미술관을 터는데 멋지게 성공한 이들은 뽀빠이의 과거 파트너였던 마카오박이 제안한 홍콩에서의 새로운 계획을 듣게 된다. 여기에 마카오박이 초대하지 않은 손님, 감옥에서 막 출소한 금고털이 팹시가 합류하고 5명은 각자 인생 최고의 반전을 꿈꾸며 홍콩으로 향한다.  홍콩에서 한국 도둑들을 기다리고 있는 4인조 중국도둑 첸, 앤드류, 쥴리, 조니. 최고의 전문가들이 세팅된 가운데 서로에 대한 경계를 늦추지 않는 한국과 중국의 도둑들. 팽팽히 흐르는 긴장감 속에 나타난 마카오박은 자신이 계획한 목표물을 밝힌다. 그것은 마카오 카지노에 숨겨진 희대의 다이아몬드. 성공을 장담할 수 없는 위험천만한 계획이지만 2천만 달러의 달콤한 제안을 거부할 수 없는 이들은 태양의 눈물을 훔치기 위한 작업에 착수한다. 그러나 진짜 의도를 알 수 없는 비밀스런 마카오박과 그런 마카오박의 뒤통수를 노리는 뽀빠이, 마카오박에게 배신당한 과거의 기억을 잊지 못하는 팹시와 팀보다 눈 앞의 현찰을 먼저 챙기는 예니콜, 그리고 한국 도둑들을 믿지 않는 첸과 중국 도둑들까지. 훔치기 위해 모였지만 목적은 서로 다른 10인의 도둑들은 서서히 자신만의 플랜을 세우기 시작하는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"The Thieves","runtime":135,"tagline":"","homepage":"","overview":"Cinque ladri stanno preparando il loro più grande colpo: Popie è la forza e il cervello, Pepsee l'esperto scassinatore, Yenicall si arrampica sui muri, Zampano è lo stratega e Chewingum il maestro del travestimento. Obiettivo: il Tear of The Sun, diamante di 318 carati dal valore di 20 milioni di dollari."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Les Braqueurs","runtime":136,"tagline":"Dix voleurs, deux équipes, un seul diamant","homepage":"","overview":"Forcés de faire profil bas après leur dernier braquage, Popeye et sa bande partent à Macao pour un autre contrat. Mais l’homme derrière ce contrat n’est autre que Macao Park, l’ancien partenaire de Popeye, qui s’est échappé avec 68 kg d’or après leur dernier coup quelques années auparavant. Macao Park est lui-même accompagné de sa propre bande de gangsters venus de Chine. Tous réunis, ils tentent de voler un diamant à 20 millions de dollars, gardé précieusement dans un casino. Mais chacun aimerait garder le diamant pour lui-même…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"The Thieves","runtime":135,"tagline":"","homepage":"","overview":"Πέντε κλέφτες στην κορυφή της καριέρας τους σχεδιάζουν την μεγαλύτερη μπάζα. Ο Popie είναι ο μυς και το μυαλό, ο Pepsee είναι διαρρήκτης χρηματοκιβωτίων, ο Yenicall σκαρφαλώνει τοίχους, ο Zampano είναι άνθρωπος στρατηγικής και ο Chewingum είναι βασιλιάς της μεταμφίεσης. Ποιος μπορεί να αντισταθεί σε ένα διαμάντι 318 καρατίων, αξίας 20 εκ.δολαρίων, κλειδωμένο σε ένα καζίνο;"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"הגנבים","runtime":135,"tagline":"","homepage":"","overview":"מקאו פארק ופופאי היו בעברם שותפים לפשע. בהווה מארגן פארק שוד של תכשיט מיוחד המצוי בקזינו בעיר החופשית מקאו (מול הונג קונג) ולצורך כך מגייס את פופאי, חבריו הקוריאנים וצוות גדול נוסף של עבריינים מהונג קונג. במסורת \"אושן 11\", סרטו של צ'וי דונג הון פורש את רשת המעורבים, מביא מעברם ואישיותם, לפני שיאחד את הקבוצה הגדולה הזו לרגעי השיא של השוד עצמו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"O Grande Golpe","runtime":135,"tagline":"Tudo Pelo Dinheiro. Um para a vingança. Cada um por si.","homepage":"","overview":"Ação Blockbuster em um assalto sofisticado e espetacular de um grupo de ladrões. Quando Popie e seus comparsas viajam para Macau para fazer um trabalho, eles descobrem que por trás do golpe de Estado um ex-parceiro de Popie. O plano é para roubar um diamante, \"Lágrimas do Sol\", que vale uma fortuna. O problema é que ninguém sabe, que cada um tem o seu próprio plano."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"10人の泥棒たち","runtime":139,"tagline":"","homepage":"","overview":"世界に1つしかないダイヤモンドの強奪計画。集められたのは、アジア最強の10人の泥棒たち。3つの愛が絡みあいながら、今、争奪戦が始まった！韓国を拠点に活動する窃盗団。美術館所蔵の秘宝強奪を華麗に成功させた彼らは、巨大カジノでの新しい計画を聞かされる。集結した6人はそれぞれ人生最高の仕事を夢見て香港に向かう。指定された場所で彼らを待ち受けていたのは中国人窃盗団の4人組。集められた“10人の泥棒たち”のターゲットは、幻のダイヤモンド“太陽の涙”。チームでの強奪計画は、すべて完璧なはずだった―。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"神偷大劫案","runtime":135,"tagline":"","homepage":"","overview":"轟動全球並且價值高達300億的鑽石「太陽之淚」驚現澳門，混跡賭場的盜賊澳門朴從韓國網羅了當年被他背叛的夥伴卜派、帕諾、妮可、橡皮糖、佩希，以及香港的陳哥、安德魯、茱莉、強尼等人。身懷絕技的神偷們表面齊力斷金而團結合作，卻暗自身懷各種鬼胎，一場偷拐搶騙的驚險暗戰蓄勢待發……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Tolvajok","runtime":135,"tagline":"","homepage":"","overview":"Macao Park profi tolvaj, akinek épp egy nagyon drága gyémántra fáj a foga. Egy hongkongi maffiózó kaszinójában őrzik Makaón, és úgy tervezi, a rablás után egyszerűen visszavásároltatja az ékszert a tulajdonosával. Az akcióhoz meglehetősen zilált csapatot sikerül összegyűjtenie. Egykori társát, akivel négy évvel korábban haraggal váltak el; egy gyönyörű lányt, aki az átverés és a kötélmászás mestere; egy bájgúnárt, aki a huzalok kezelésében kiváló; egy idősödő csalót; valamint az ékszertolvajlásra specializálódott Chent két emberével. Csatlakozik még hozzájuk a szép Julie, aki a széfekhez ért, valamint nem várt módon Park volt barátnője is, aki épp a börtönből szabadul. Hogy Park dolga még nehezebb legyen, a csapat pár tagjára már egyébként is vadászik a rendőrség. Ezek után nem csoda, ha akció közben semmi sem úgy sül el, ahogyan azt eltervezték."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Крадците","runtime":135,"tagline":"","homepage":"","overview":"За да оставят проблемите от последния обир зад гърба си Попай и неговата престъпна група се насочват към Макао където ги чака ново предизвикателство. След пристигането си Попай с изненада открива, че поръчителя на задачата и негов потенциален съучастник е бившия му партньор Парк, който преди години го е измамил и е успял да избяга с 68 килограма злато. Въпреки напрежението между двамата те се съгласяват да извършат обира заедно. За да бъде всичко сигурно Попай привлича към екипа брилянтния разбивач на сейфове Пепси, който преди години също е бил измамен от Парк."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"盜賊門","runtime":135,"tagline":"","homepage":"","overview":"曾為竊盜集團首腦的澳門樸，計劃盜取香港黑社會老大衞鴻珍藏在澳門賭場價值聯城的稀世鑽石「太陽之淚」，因此找上先前的手下卜派 和團隊成員妮可、佩希 以及帕諾 和橡皮糖。而他們各有其神招奇才：百變美賊妮可專長使用飛繩飛簷走壁、佩希則是開鎖專家、帕諾負責監控掩護大家、橡皮糖擁有瞞天過海的演技及語言天份。\r 澳門樸更找到香港的陳哥、茱莉 與強尼 和安德魯，夥同一行人突破澳門賭場的森嚴警衞而準備大幹一場。身懷絕技的神偷們表面齊力斷金而團結合作，卻暗自身懷各種鬼胎，有人慾獨吞鑽石，也有人深藏此行最終目的，一場偷拐搶騙的驚險暗戰因而蓄勢待發……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Đội Quân Siêu Trộm","runtime":135,"tagline":"The Thieves","homepage":"","overview":"Trong phim, 5 siêu trộm tại Hàn Quốc đã đồng ý liên kết với Macao Park, siêu đạo chích cùng đội một thời, đã gác kiếm, để thực hiện một phi vụ đầy thách thức - trộm viên kim cương Giọt Lệ Thái Dương trị giá 20 triệu USD mà chiếc chìa khóa mở căn phòng chứa nằm trong… trái tim của người sở hữu nó. 5 người bọn họ với những kĩ năng khác nhau đã liên kết cùng 4 siêu trộm người Hoa khác để an toàn hơn khi đột nhập vào Casino tại Hong Kong.  Tuy nhiên, khi bắt tay vào kế hoạch, Macao Park cùng Popie nảy sinh mâu thuẫn. Giá trị quá lớn của viên kiêm cương đã làm cho một số người nảy sinh lòng tham khiến sợi dây liên kết từng người trong đội bị nới lỏng. Lòng tham, sự nghi ngờ, những dằn vặt về quá khứ… làm cho các siêu trộm lần lượt tách nhau ra, hành động độc lập và thậm chí là sát hại nhau, để rồi nhận về kết cục không như mong đợi."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"El gran cop","runtime":135,"tagline":"","homepage":"","overview":"Un grup de lladres internacionals es disposa a engegar un pla mestre per donar el cop del segle en un casino. Però com l'honor no existeix entre lladres, cadascun d'ells s'organitza a la seva manera."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":135,"tagline":"","homepage":"","overview":"Gang jihokorejských zlodějů se spojí s hongkongskou skupinou, aby ukradli diamantový náhrdelník z přísně střeženého sejfu kasina v Macau. Když se policisté přiblíží, staré zrady - a nedorozumění - se znovu vynoří."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"夺宝联盟","runtime":135,"tagline":"","homepage":"","overview":"曾轰动全球且价值高达300亿的钻石太阳之泪惊现中国澳门，某神秘人物委托混迹赌场的盗贼朴澳门 组织人马侵入赌场金库，盗取钻石，事成之后报酬颇丰。在此之后，朴从韩国网罗了当年被他背叛的伙伴波比、詹姆帕诺、艾妮可、口香糖、百事，以及中国方面的陈、安德鲁、朱莉 、乔尼 等人。这些人中包括偷盗、绳索、路线、演技等各方面高手，实可谓一次强强联合。在朴澳门的周密策划下，偷盗行动有条不紊地展开。在此过程中两方人马暗暗较劲又相互帮衬配合，紧张有趣而意外迭出，上演了一出中韩盗贼大比拼。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"Dodookdeul","runtime":135,"tagline":"","homepage":"","overview":"Om na hun laatste diefstal even van de radar te verdwijnen gaan Popeye en zijn dievenbende naar Macao waar ze een nieuwe opdracht hebben aangenomen. De opdrachtgever is niemand minder dan Macau Park, Popeye's voormalige partner. Enkele jaren geleden, bij hun laatste opdracht samen, verdween Macau Park spoorloos met 68 kilo goud. Naast de groep van Popeye heeft hij echter ook een Chinese dievenbende ingehuurd. Het plan is om een kostbare diamant te stelen uit een casino."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"The Thieves","runtime":135,"tagline":"","homepage":"","overview":"Um ein wenig Gras über ihren letzten Überfall wachsen zu lassen, nehmen Popeye und seine Partner einen Job im weit entfernten Macau an. Doch der Auftraggeber des Jobs ist Popeyes alter Partner Macau Park, der die Bande vor Jahren um deren Diebesgut betrog. Für sein nächstes Vorhaben hat Marcau auch andere chinesische Diebe kontaktiert, doch niemand weiß genau, was er vorhat. Der Plan nimmt für Macau eine überraschende Wendung, als Popeye Pepsi mit ins Spiel bringt, eine geniale Safe-Knackerin und ehemalige Geliebte von Macau. Das Ziel der Einbrecher ist ein 20 Millionen Dollar teurer Diamant, der in einem Casino-Safe gelagert wird. Während sie alle gemeinsam den Überfall planen, hat jeder insgeheim seine eigenen Gründe, um den Diamant für sich zu behalten zu wollen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"The Thieves","runtime":135,"tagline":"","homepage":"","overview":"Um ein wenig Gras über ihren letzten Überfall wachsen zu lassen, nehmen Popeye und seine Partner einen Job im weit entfernten Macau an. Doch der Auftraggeber des Jobs ist Popeyes alter Partner Macau Park, der die Bande vor Jahren um deren Diebesgut betrog. Für sein nächstes Vorhaben hat Marcau auch andere chinesische Diebe kontaktiert, doch niemand weiß genau, was er vorhat. Der Plan nimmt für Macau eine überraschende Wendung, als Popeye Pepsi mit ins Spiel bringt, eine geniale Safe-Knackerin und ehemalige Geliebte von Macau. Das Ziel der Einbrecher ist ein 20 Millionen Dollar teurer Diamant, der in einem Casino-Safe gelagert wird. Während sie alle gemeinsam den Überfall planen, hat jeder insgeheim seine eigenen Gründe, um den Diamant für sich zu behalten zu wollen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"CH","english_name":"German"}],"reviews_tmdb":[{"id":"584466dac3a3683e1600bfb8","url":"https://www.themoviedb.org/review/584466dac3a3683e1600bfb8","author":"Reno","content":"$11","created_at":"2016-12-04T18:56:26.482Z","updated_at":"2024-05-16T15:18:32.658Z","author_details":{"name":"Reno","rating":6,"username":"Rangan","avatar_path":"/6ZpVUJzqXMzH35VprEtnX0sNI3.jpg"}}],"recommendations":[{"id":55771,"adult":false,"title":"The Show Must Go On","video":false,"overview":"A middle-aged gangster's lifetime of mistakes catch up with him as his personal and professional life is destroyed.","genre_ids":[28,35,80],"media_type":"movie","popularity":0.8334,"vote_count":48,"poster_path":"/r32KWFc2jRItbAzHypGu9yHSfNs.jpg","release_date":"2007-04-05","vote_average":6.458,"backdrop_path":"/unOSRoUq6OgCYMFMsdrEh0py7qs.jpg","original_title":"우아한 세계","original_language":"ko"},{"id":54332,"adult":false,"title":"Lovers' Concerto","video":false,"overview":"A college student befriends two cute girls his age. He loses contact with them. He tries to find them years later.","genre_ids":[18,10749],"media_type":"movie","popularity":0.5883,"vote_count":41,"poster_path":"/vW1wzczT4ZYvwARJkZx3k4EfD0h.jpg","release_date":"2002-09-13","vote_average":7,"backdrop_path":"/6vxNxU6wOFDMXUyUfymZkfI7wCG.jpg","original_title":"연애소설","original_language":"ko"},{"id":409245,"adult":false,"title":"Big Bang Made - The Movie","video":false,"overview":"In April 2015, Big Bang made a comeback after a three-year hiatus, and their Made World Tour ended with a great success drawing 1.5 million people. The movie follows Big Bang from the beginning till the end of their world tour in a documentary format to give up close and personal view of their 340 days journey in the tour as they perform in 32 cities in 13 countries.  The movie will be a collection of the five singers off guard in their natural state having fun on-stage during the concerts, the behind-the-scenes videos of made concerts and albums, backstage and offstage. The film also included interviews with each member.","genre_ids":[10402,99],"media_type":"movie","popularity":0.262,"vote_count":7,"poster_path":"/jZ6BFrQEXI205TzNx3hYkOWTfmx.jpg","release_date":"2016-06-30","vote_average":8.143,"backdrop_path":"/sf6FGvQOOjqIcvLePRKPvubZwyB.jpg","original_title":"Big Bang Made - The Movie","original_language":"ko"},{"id":514879,"adult":false,"title":"KASANE –Beauty and Fate–","video":false,"overview":"Kasane Fuchi is the daughter of a beautiful, legendary actress. Kasane has excellent acting skills as well, but she is not attractive. She has a hard time due to her unattractiveness. Kasane has a lipstick left behind by her late mother. The lipstick holds a strange power. Whenever Kasane applies the lipstick and kisses someone, she takes that person's face.  Meanwhile, Nina Tanzawa is a beautiful actress with poor acting skills. She meets Kasane Fuchi and their fates change.","genre_ids":[9648,14],"media_type":"movie","popularity":0.8419,"vote_count":29,"poster_path":"/vzrkeaeq4Rzpwb3EhHo0tunI5m4.jpg","release_date":"2018-09-07","vote_average":6.845,"backdrop_path":"/aJCHfcB55CnZVfMfxTmipkpWO0X.jpg","original_title":"累 ―かさね―","original_language":"ja"},{"id":626109,"adult":false,"title":"Summer Bus","video":false,"overview":"In the everyday life of the bus, the world still hopes to find warmth.","genre_ids":[18],"media_type":"movie","popularity":0.0602,"vote_count":5,"poster_path":"/uOpOpZgh96sU0qnJ8zACAlSpxu4.jpg","release_date":"2017-09-15","vote_average":7.2,"backdrop_path":"/9KjO8SjkGxsHQduSOLnpBM7kcpW.jpg","original_title":"여름, 버스","original_language":"ko"},{"id":52585,"adult":false,"title":"Skeletons in the Closet","video":false,"overview":"The movie is about a dysfunctional family, each and every member with mental problems of his own. On top of that some old skeletons from the closet come back to haunt them.","genre_ids":[35,18],"media_type":"movie","popularity":0.5475,"vote_count":8,"poster_path":"/iUqwthDktgjP1qipxv1MZo6Q0H9.jpg","release_date":"2007-02-28","vote_average":6.938,"backdrop_path":"/fCusrq6ukn5aAGD8YWbp3FLakws.jpg","original_title":"좋지 아니한가","original_language":"ko"},{"id":239853,"adult":false,"title":"11 A.M.","video":false,"overview":"In the not-so distant future, researchers at a deep-sea laboratory have finally invented a time machine. Head researcher Woo-seok is promised funding from a mega-corporation if he completes a test flight. He and Young-eun carry out the mission and travel to 11 A.M. the next day, only to find the base on the verge of collapse. All the researchers are gone and someone is out to kill them.","genre_ids":[878,14],"media_type":"movie","popularity":0.3255,"vote_count":28,"poster_path":"/h4XCE1T5TFbWNGYkh7ExW7qv9UJ.jpg","release_date":"2013-11-28","vote_average":5.5,"backdrop_path":"/t9luZanKAJ0nrfK0L3yNy69CcM3.jpg","original_title":"열한시","original_language":"ko"},{"id":143315,"adult":false,"title":"Seven Something","video":false,"overview":"Three modern love stories focus on how digital privacy, fleeting fame and the power of personal reinvention can change one's romantic destiny.","genre_ids":[18,10749,35],"media_type":"movie","popularity":0.4481,"vote_count":13,"poster_path":"/xzYYJmdlOgc39Qc5SDYiBm2fs3Z.jpg","release_date":"2012-07-26","vote_average":5.9,"backdrop_path":"/yErLjeOff7M1m9qMKR0kKfBdQWk.jpg","original_title":"รัก 7 ปี ดี 7 หน","original_language":"th"},{"id":145738,"adult":false,"title":"40 Days and Nights","video":false,"overview":"When a colossal tectonic shift causes the sea level to start rising, a microbiologist gathers the DNA of as many species as she can, while the military creates an \"ark\" in a desperate attempt to preserve life on Earth.","genre_ids":[28,878,12,53],"media_type":"movie","popularity":0.5442,"vote_count":80,"poster_path":"/bAHXPIZy1t8kiEqb7hn4BRbuuBd.jpg","release_date":"2012-11-27","vote_average":2.944,"backdrop_path":"/zj7d7oH79LwICxl90rwXTyDRtbH.jpg","original_title":"40 Days and Nights","original_language":"en"},{"id":437116,"adult":false,"title":"A Special Lady","video":false,"overview":"A corrupt prosecutor plans for revenge against Hyun-jung's crime organization by using her loyal partner, Sang-hoon.","genre_ids":[28,80],"media_type":"movie","popularity":0.83,"vote_count":28,"poster_path":"/bsmv8sDlVJsrSOHtdrimWxIjDCD.jpg","release_date":"2017-11-09","vote_average":6.019,"backdrop_path":"/9d34v6lwBdzbqEthHHUkpf1tjrn.jpg","original_title":"미옥","original_language":"ko"},{"id":372921,"adult":false,"title":"Mutual Relations","video":false,"overview":"Ho-kyeong, Joo-yeong and Yeon-hee are students of an American university who are all pretty and sexy. They either know too much or know too little so they decide to find men who can satisfy them. A lean man who was a former nude model, a younger man who has perfect techniques and a man who thinks very highly of women; these guys start the project!","genre_ids":[35,10749],"media_type":"movie","popularity":4.9926,"vote_count":20,"poster_path":"/k8dsPTp1Ga67c0Ie00qyR3vcPG3.jpg","release_date":"2015-12-01","vote_average":6.55,"backdrop_path":"/flBvN0JFdf7jTMtr0RAHAToUQz9.jpg","original_title":"공즉시색","original_language":"ko"},{"id":18426,"adult":false,"title":"Daisy","video":false,"overview":"A painter in Amsterdam receives flowers from a mysterious admirer, while a hitman and cop find themselves in conflict.","genre_ids":[18,10749,28],"media_type":"movie","popularity":0.6795,"vote_count":101,"poster_path":"/twmYZWjyrHm0fhJnPxHcC4XtrA3.jpg","release_date":"2006-03-09","vote_average":7.1,"backdrop_path":"/4NTM2UfehhQueBQd06DCzzHMW5i.jpg","original_title":"데이지","original_language":"ko"},{"id":35010,"adult":false,"title":"A Man Who Was Superman","video":false,"overview":"A snobbish producer makes a documentary about the extraordinary behavior of her neighbor who believes himself to be Superman.","genre_ids":[35,18,10749],"media_type":"movie","popularity":0.5845,"vote_count":67,"poster_path":"/c4