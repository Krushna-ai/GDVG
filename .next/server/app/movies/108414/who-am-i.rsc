5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Who Am I?\",\"description\":\"A group of covert CIA operatives trailing a potential new energy source are double-crossed by corrupt agent Morgan, who causes a helicopter crash in remote South Africa. The sole survivor, suffering severe amnesia, is nursed to recovery by a kindly native tribe who call him \\\"Whoami\\\" after the question he keeps asking. With the help of a mysterious reporter Christine, Whoami pieces together his past and tracks the turncoat agent and his criminal cohorts.\",\"image\":\"https://image.tmdb.org/t/p/w500/9YDKLbBmWGpxG5bO3TBawtNNOAr.jpg\",\"datePublished\":\"1998-01-17\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"cn\",\"genre\":[\"action film\",\"comedy film\",\"martial arts film\",\"Adventure\",\"Action\",\"Comedy\",\"Thriller\",null,null,null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.1,\"bestRating\":10,\"ratingCount\":951}}"}}],["$","$L10",null,{"initialDrama":{"id":"d910efd5-bd26-4e61-9bc6-b48945045770","tmdb_id":8697,"imdb_id":"tt0127357","content_type":"movie","title":"Who Am I?","original_title":"我是誰","overview":"A group of covert CIA operatives trailing a potential new energy source are double-crossed by corrupt agent Morgan, who causes a helicopter crash in remote South Africa. The sole survivor, suffering severe amnesia, is nursed to recovery by a kindly native tribe who call him \"Whoami\" after the question he keeps asking. With the help of a mysterious reporter Christine, Whoami pieces together his past and tracks the turncoat agent and his criminal cohorts.","poster_path":"/9YDKLbBmWGpxG5bO3TBawtNNOAr.jpg","backdrop_path":"/c8jufUMUxgY5cLFgOF3oNbNiHYj.jpg","release_date":"1998-01-17","first_air_date":null,"status":"published","original_language":"cn","origin_country":["HK"],"genres":[{"name":"action film"},{"na