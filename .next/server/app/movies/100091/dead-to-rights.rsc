5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Dead to Rights\",\"description\":\"During the 1937 Nanjing Massacre, a postman poses as a photo developer, helping Japanese forces while secretly sheltering Chinese refugees. He later risks his life evacuating them and revealing evidence of the atrocities.\",\"image\":\"https://image.tmdb.org/t/p/w500/rx9xTly73NssFHPg9gKrX9tJdDI.jpg\",\"datePublished\":\"2025-07-19\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Drama\",\"War\",\"History\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8,\"bestRating\":10,\"ratingCount\":67}}"}}],["$","$L10",null,{"initialDrama":{"id":"efd49511-f99d-4a0a-b6e5-74a901e4a054","tmdb_id":1500536,"imdb_id":"tt36598036","content_type":"movie","title":"Dead to Rights","original_title":"南京照相馆","overview":"During the 1937 Nanjing Massacre, a postman poses as a photo developer, helping Japanese forces while secretly sheltering Chinese refugees. He later risks his life evacuating them and revealing evidence of the atrocities.","poster_path":"/rx9xTly73NssFHPg9gKrX9tJdDI.jpg","backdrop_path":"/ngLgoY3MTfLANqv9cpXr96saaFV.jpg","release_date":"2025-07-19","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":18,"name":"Drama"},{"id":10752,"name":"War"},{"id":36,"name":"History"}],"popularity":3.1035,"vote_average":8,"vote_count":67,"runtime":137,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T21:46:41.054489+00:00","updated_at":"2026-02-21T14:01:16.836+00:00","tagline":"Every Chinese will not forget the history.","homepage":null,"budget":20000000,"revenue":422785908,"production_companies":[{"id":269052,"name":"Super Lion","logo_path":null,"origin_country":"CN"},{"id":204269,"name":"Yuuya Midia","logo_path":null,"origin_country":"CN"},{"id":2270,"name":"China Film Group Corporation","logo_path":"/7osqu50JpFIh0klZU0s1CrnNqcc.png","origin_country":"CN"}],"production_countries":[{"name":"China","iso_3166_1":"CN"}],"spoken_languages":[{"name":"普通话","iso_639_1":"zh","english_name":"Mandarin"},{"name":"日本語","iso_639_1":"ja","english_name":"Japanese"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":"NR","keywords":[{"id":6025,"name":"photography"},{"id":2968,"name":"grave"},{"id":9672,"name":"based on true story"},{"id":10535,"name":"second sino-japanese war (1937-45)"},{"id":15060,"name":"period drama"},{"id":190931,"name":"nanking massacre china 1937"},{"id":192772,"name":"historical drama"},{"id":207883,"name":"1940s"},{"id":211669,"name":"photo studio"},{"id":214548,"name":"1930s"},{"id":217896,"name":"nanjing"},{"id":276605,"name":"serious"},{"id":315053,"name":"critical"},{"id":324886,"name":"bitter"}],"alternative_titles":[{"type":"","title":"吉祥照相馆","iso_3166_1":"CN"},{"type":"Transliteration","title":"Nan jing zhao xiang guan","iso_3166_1":"CN"},{"type":"Transliteration","title":"Nanjing Zhao Xiang Guan","iso_3166_1":"CN"},{"type":"","title":"Dead To Rights","iso_3166_1":"US"},{"type":"","title":"مرگ بر حق","iso_3166_1":"IR"}],"videos":[{"id":"68d9a994fc18143c40b9a199","key":"_PX1WNbKdAE","name":"Official Trailer","site":"YouTube","size":1080,"type":"Trailer","official":false,"iso_639_1":"en","iso_3166_1":"US","published_at":"2025-07-19T01:00:38.000Z"}],"watch_providers":{"results":{"CA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":5}],"link":"https://www.themoviedb.org/movie/1500536/watch?locale=CA","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":5}]},"KR":{"link":"https://www.themoviedb.org/movie/1500536/watch?locale=KR","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name