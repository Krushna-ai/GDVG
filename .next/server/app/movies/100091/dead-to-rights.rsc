,"iso_639_1":"zh","vote_average":0}],"posters":[{"width":2000,"height":3000,"file_path":"/lwrANgpPEBmYZ59oExpCiuv34Ou.jpg","iso_639_1":"zh","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/5w6PgAcPKragTVwIXdCHkwx4Y6C.jpg","iso_639_1":"ru","vote_average":3.334},{"width":1808,"height":2720,"file_path":"/u4iGWiLU4q0IrppWX2No3e3DvLv.jpg","iso_639_1":"fr","vote_average":3.334},{"width":1500,"height":2250,"file_path":"/rx9xTly73NssFHPg9gKrX9tJdDI.jpg","iso_639_1":"en","vote_average":2.278},{"width":2000,"height":3000,"file_path":"/5NYcSNBSQYYlgiAQeNqrHl1FirT.jpg","iso_639_1":"en","vote_average":2.278},{"width":2000,"height":3000,"file_path":"/cnNDgtHJaLnUeXntFsfzeOuYrUE.jpg","iso_639_1":"zh","vote_average":1.75},{"width":864,"height":1296,"file_path":"/nSkSkP2DeIvoaa7B5Q9mLxLQd4K.jpg","iso_639_1":"en","vote_average":1.222},{"width":2000,"height":2800,"file_path":"/29RDBq2PDxifrzeBgZ3IcZOPL9n.jpg","iso_639_1":"zh","vote_average":0.166},{"width":2000,"height":2799,"file_path":"/jnkcZZ5QxL2fOv85KSViokF6qbB.jpg","iso_639_1":"zh","vote_average":0.166},{"width":1500,"height":2250,"file_path":"/eeV65jSMUltU4LGGAmOOQ3Hv9Ji.jpg","iso_639_1":"en","vote_average":0.166},{"width":2000,"height":3000,"file_path":"/5CnjLEIhqVFvfXC4moDuTTOpIgD.jpg","iso_639_1":"zh","vote_average":0},{"width":1867,"height":2800,"file_path":"/yqTOlnCIY4S90FYaIz2TjL4ZsQL.jpg","iso_639_1":"zh","vote_average":0},{"width":1867,"height":2800,"file_path":"/aUmij9KIUEziwN0VF1U87jbxiQa.jpg","iso_639_1":"zh","vote_average":0},{"width":1280,"height":1919,"file_path":"/ePPktz4rTek3L1z9xDlP1fheKN6.jpg","iso_639_1":"zh","vote_average":0},{"width":1990,"height":2999,"file_path":"/xUJUcgNnYB7v4IeEkp0PDrVfJwP.jpg","iso_639_1":"zh","vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/ngLgoY3MTfLANqv9cpXr96saaFV.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/8GyOBWEfZTCqyW9pgvSPKi3KvsT.jpg","iso_639_1":null,"vote_average":2.066},{"width":3840,"height":2160,"file_path":"/faoZLhs1QqIxZZ6LViRf6x6byWz.jpg","iso_639_1":null,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/kCwq6aINmOahhirXHlu2I8yOsUI.jpg","iso_639_1":null,"vote_average":1.434},{"width":3840,"height":2160,"file_path":"/qiu0u5fa5OnHtGTOmzOffw5FpkW.jpg","iso_639_1":null,"vote_average":1.434},{"width":1920,"height":1080,"file_path":"/kqTC9Te1PdsmkMIdT1TaitHfIOE.jpg","iso_639_1":null,"vote_average":1.222},{"width":1280,"height":720,"file_path":"/fHosNUswz8uPcr3YyxslAKx07BR.jpg","iso_639_1":null,"vote_average":0.166},{"width":1425,"height":802,"file_path":"/lCRLLe8kiwb99JOlkTPAfchhqwk.jpg","iso_639_1":"zh","vote_average":0},{"width":2128,"height":1197,"file_path":"/cY91L52nr8ujtxyxAcM9vMLd8iR.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T08:26:48.299+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"南京照相馆","runtime":137,"tagline":"每一个中国人都不会忘记！","homepage":"","overview":"影片故事取材于南京大屠杀期间日军真实罪证影像。一群生活在南京的百姓躲在吉祥照相馆中避难，为了尽可能的多活一日，他们被迫帮助日军摄影师冲洗底片，却意外冲印出了能证明日军屠城的罪证照片。他们原本只想在大屠杀中保命活下去，面对日军在南京城内的暴行，他们决定让这些底片留存下去……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Dead to Rights","runtime":137,"tagline":"Every Chinese will not forget the history.","homepage":"","overview":"During the 1937 Nanjing Massacre, a postman poses as a photo developer, helping Japanese forces while secretly sheltering Chinese refugees. He later risks his life evacuating them and revealing evidence of the atrocities."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"南京照相館","runtime":137,"tagline":"","homepage":"","overview":"影片故事取材于南京大屠殺期間日軍真實罪證影像。一群生活在南京的百姓躲在吉祥照相館中避難，為了盡可能的多活一日，他們被迫幫助日軍攝影師衝洗底片，卻意外衝印出了能證明日軍屠城的罪證照片。他們原本只想在大屠殺中保命活下去，面對日軍在南京城內的暴行，他們決定讓這些底片留存下去……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"南京照相館","runtime":0,"tagline":"","homepage":"","overview":"一群素不相識的老百姓，在 1937 年的南京城，因一卷記錄日軍暴行的膠片意外被命運捆綁。影片故事取材於南京大屠殺期間日軍真實罪證影像。一群生活在南京的百姓躲在吉祥照相館中避難，為了儘可能的多活一日，他們被迫幫助日軍攝影師沖洗底片，卻意外沖印出了能證明日軍屠城的罪證照片。他們原本只想在大屠殺中保命活下去，面對日軍在南京城內的暴行，他們決定讓這些底片留存下去……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Нанкинский фотограф","runtime":137,"tagline":"«Это никогда не забудется китайским народом»","homepage":"","overview":"1937-ой год. Чтобы спастись во время Нанкинской резни, почтальон Су Лючан выдаёт себя за сотрудника фотоателье. Однако он не только проявляет снимки для японцев, но и прячет в фотостудии группу китайских солдат и гражданских. А также пытается безопасно переправить беженцев и обнародовать доказательства военных преступлений японской армии."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"난징사진관","runtime":137,"tagline":"1937년 난징, 사진 한 장으로 숨겨진 그 날의 진실이 밝혀진다","homepage":"","overview":"1937년, 젊은 우편 배달부 아창은 전쟁 속 목숨을 부지하기 위해 일본군 종군 기자 이토 히데오의 요청으로 난징의 한 사진관에서 사진을 인화하게 된다. 사진관 주인 진씨 가족과 그곳에 하나 둘 모인 피난민들 그리고 비밀리에 인화된 수백 장의 사진. 그 사진 속에는 일본군의 참혹한 만행과 살아 남기 위해 숨죽인 평범한 이들의 모습이 담겨 있었다. 정체가 드러날 위기 속, 아창은 사진관을 임시 피난처로 지키며 세상에 알려야 할 진실, 그 증거들을 모은다. 그리고 마침내 숨겨둔 필름 한 통이 전 세계에 알려지며 진실이 밝혀지는데.."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Le Studio photo de Nankin","runtime":137,"tagline":"","homepage":"","overview":"Au moment de la prise sanglante de Nankin (Chine) par l’armée japonaise en décembre 1937, un jeune homme échappe à la mort en prétendant pouvoir aider l’armée nippone à développer les photos de ses exactions. Il s’installe dans un studio photo qui devient alors un lieu de résistance, et risque sa vie pour sauver des familles et révéler les preuves des atrocités commises."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"El estudio fotográfico de Nankín","runtime":127,"tagline":"","homepage":"","overview":"Ambientada durante la Masacre de Nankín en 1937, \"El Estudio Fotográfico de Nankín\" relata la historia de A Chang, un cartero que, para salvar su vida, se hace pasar por un revelador de fotos en un estudio fotográfico controlado por fuerzas japonesas. Mientras desarrolla fotografías para el ejército invasor, secretamente ayuda a un grupo de civiles y soldados chinos refugiados en el estudio. Juntos, enfrentan la brutalidad y atrocidades cometidas por el ejército japonés y arriesgan todo para preservar pruebas visuales de los crímenes de guerra, con la esperanza de que estos documentos eventualmente sirvan para denunciar internacionalmente las atrocidades y mantener vivo el recuerdo histórico. La película, dirigida por Shen Ao y protagonizada por Liu Haoran entre otros, se basa en hechos reales y retrata la lucha por la supervivencia y la resistencia durante uno de los capítulos más oscuros de la historia china."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"El Estudio Fotográfico de Nankín","runtime":127,"tagline":"","homepage":"","overview":"Ambientada durante la Masacre de Nankín en 1937, \"El Estudio Fotográfico de Nankín\" relata la historia de A Chang, un cartero que, para salvar su vida, se hace pasar por un revelador de fotos en un estudio fotográfico controlado por fuerzas japonesas. Mientras desarrolla fotografías para el ejército invasor, secretamente ayuda a un grupo de civiles y soldados chinos refugiados en el estudio. Juntos, enfrentan la brutalidad y atrocidades cometidas por el ejército japonés y arriesgan todo para preservar pruebas visuales de los crímenes de guerra, con la esperanza de que estos documentos eventualmente sirvan para denunciar internacionalmente las atrocidades y mantener vivo el recuerdo histórico. La película, dirigida por Shen Ao y protagonizada por Liu Haoran entre otros, se basa en hechos reales y retrata la lucha por la supervivencia y la resistencia durante uno de los capítulos más oscuros de la historia china."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"ნანკინის ფოტო ატელიე","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"حقایق مرده","runtime":0,"tagline":"","homepage":"","overview":"در جریان قتل عام نانجینگ در سال 1937، یک پستچی‌ به نام چانگ برای نجات جان خود، وانمود می‌کند که در یک آتلیه عکاسی، عکس‌ها را ظاهر می‌کند و این کار را برای ارتش ژاپن انجام می‌دهد. او همچنین..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Nanjing: Luz na Escuridão","runtime":0,"tagline":"","homepage":"","overview":"Em 1937, um carteiro se passa por fotógrafo para os japoneses durante o Massacre de Nanjing. Enquanto colabora com as forças invasoras, ele esconde refugiados chineses e documenta secretamente a violência do conflito."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"บันทึกหนานจิง","runtime":0,"tagline":"","homepage":"","overview":"ในช่วงการสังหารหมู่ที่หนานจิงในปี 1937 พนักงานไปรษณีย์คนหนึ่งในปลอมตัวเป็นช่างภาพ และช่วยเหลือกองทัพญี่ปุ่น ในขณะที่แอบให้ที่หลบซ่อนแก่ผู้ลี้ภัยชาวญี่ปุ่นอย่างลับ ๆ ในภายหลังเขาได้เสี่ยงชีวิตในการเคลื่อนย้ายพวกเขา และเปิดเผยหลักฐานเกี่ยวกับความโหดร้ายที่เกิดขึ้น"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Tiệm Ảnh Nam Kinh","runtime":0,"tagline":"","homepage":"","overview":"Phim xoay quanh nhân vật A Chang do diễn viên Haoran Liu thủ vai, một người đưa thư phải giả làm thợ rửa ảnh cho quân đội Nhật để sinh tồn trong thời kỳ hỗn loạn. A Chang âm thầm che chở những người dân và binh lính Trung Quốc trong một tiệm ảnh, đồng thời đối mặt với áp lực từ Wang Guanghai – phiên dịch viên cho quân Nhật. Câu chuyện dựa trên những bức ảnh thật ghi lại tội ác chiến tranh, lấy cảm hứng từ tiệm ảnh Huadong, nơi lưu giữ những bằng chứng quan trọng cho Tòa án Chiến tranh Nam Kinh. Phim không chỉ gây ấn tượng với kịch bản sâu sắc mà còn được đầu tư kỹ lưỡng về âm nhạc của Fei Peng, hình ảnh quay phim của Wang Tianxing và hiệu ứng đặc biệt tinh tế, tạo nên không khí chân thực và ám ảnh."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"}],"reviews_tmdb":[],"recommendations":[{"id":1109237,"adult":false,"title":"The Monk and the Gun","video":false,"overview":"An American travels to Bhutan searching for a valuable antique rifle and crosses paths with a young monk who wanders through the serene mountains, instructed by his teacher to make things right again.","genre_ids":[35,18],"media_type":"movie","popularity":0.5559,"vote_count":108,"poster_path":"/nhGaCXeBvFo7495aIZr261l6kb0.jpg","release_date":"2023-10-17","vote_average":7.282,"backdrop_path":"/8nDmmnksfkTqwVa1en54KXDMRtg.jpg","original_title":"The Monk and the Gun","original_language":"dz"},{"id":508935,"adult":false,"title":"The Eight Hundred","video":false,"overview":"In 1937, eight hundred Chinese soldiers fight under siege from a warehouse in the middle of the Shanghai battlefield, completely surrounded by the Japanese army.","genre_ids":[10752,36,18,28],"media_type":"movie","popularity":1.9812,"vote_count":315,"poster_path":"/gWKYKGDLEMCSAyjQ1e0rpBSoRMD.jpg","release_date":"2020-08-14","vote_average":7,"backdrop_path":"/IRN1JuNwr1VKp88Dscgja2uR8H.jpg","original_title":"八佰","original_language":"zh"},{"id":1406607,"adult":false,"title":"The Stage","video":false,"overview":"During the Republican era, wars and conflicts were frequent. On stage, the \"Overlord\" sings with resounding passion, while below, the absurd spectacle of life unfolds. They must both secure the opera troupe's livelihood and appease the audience in their seats. Once the curtain rises, how should this play be performed?","genre_ids":[18,35],"media_type":"movie","popularity":1.332,"vote_count":39,"poster_path":"/wSFGtkoz8SW6yIgu1Xvxs584QQt.jpg","release_date":"2025-07-12","vote_average":7.256,"backdrop_path":"/6ggN6