io":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/6pgy8q6avxwNc8dNT5crS303etz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/eJwJBKwkBzT3TlpADaaAnZGBAUp.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/stDi1YdS2cA780Ob22ox8xmTQOp.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/ew0EoOBRVns4eE3uDUWp8vAp91l.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/tuO6untCSsOD2WysWBaNJzfrTDV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/bO8KnnPsI5DsZrwWxeNOciZdqEg.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/bsH2NMkdPfByCiYB0ReHWDvLNk6.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/dKdL4CIiZ9DaSmp2zIaGSfkq6Pl.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2846,"height":1601,"file_path":"/3qmGrzWb8WOaRurr33EzuCga1ec.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2874,"height":1617,"file_path":"/9X1qUb0aEmUAH3Y9OS3oJhkPnT3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2832,"height":1593,"file_path":"/5AN8JS2WOOjLAYEbs8tAo0LSxyB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2834,"height":1594,"file_path":"/aCGXVYoIBEp719kbTogAa8uAk12.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2836,"height":1595,"file_path":"/nkFwmD3Pg7xLcwvL7ltmeahy2dy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/uke1cfmMfcEjJMlW2yeGtxH83uG.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/aRg65Z7PB9vyln8Svcp8YW22kHh.jpg","iso_639_1":"ca","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T04:10:05.066+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"It Was Just an Accident","runtime":104,"tagline":"","homepage":"https://www.neonrated.com/film/it-was-just-an-accident","overview":"An unassuming mechanic is reminded of his time in an Iranian prison when he encounters a man he suspects to be his sadistic jailhouse captor."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"그저 사고였을 뿐","runtime":104,"tagline":"","homepage":"","overview":"어느 날, 나를 지옥으로 이끌던 삐걱 소리가 다시 들렸다. 나는 안다. 그가 맞다. “그저 사고였을 뿐? 누군가는 그걸 평생 기억해”"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Un semplice incidente","runtime":0,"tagline":"","homepage":"","overview":"Padre, madre e figlioletta percorrono di notte una strada in auto quando un cane finisce sotto le ruote. Ciò provoca un danneggiamento al veicolo che costringe ad una sosta per la riparazione temporanea. Un uomo che si trova sul posto cerca di non farsi vedere perché gli è parso di riconoscere nel conducente dell'auto un agente dei servizi segreti che lo ha sottoposto a violenza in carcere. Riesce successivamente a sequestrarlo ed è pronto a seppellirlo vivo quando gli viene il dubbio che si tratti di uno scambio di persona. Cercherà conferme in altri che, come lui seppure in misure diverse, hanno subito la ferocia dell'uomo."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":102,"tagline":"","homepage":"https://www.memento.eu/un-simple-accident/","overview":"Une famille est impliquée dans un petit accident de voiture, mais un inconnu va bouleverser leur journée."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"To był zwykły przypadek","runtime":101,"tagline":"Przebaczenie od zemsty dzieli jeden krok.","homepage":"https://aurorafilms.pl/film/to-byl-zwykly-przypadek/","overview":"Nocny kierowca Eghbal, jadąc z ciężarną żoną, zabija psa. Utknąwszy, szuka pomocy w garażu Vahida, nieświadomy, że jego wybawca uważa go za strażnika więziennego, który go torturował. Przekonany Vahid porywa Eghbala, aby go żywcem zakopać, ale wkrótce pojawiają się wątpliwości. Aby potwierdzić tożsamość Eghbala, Vahid werbuje inne ofiary. Podczas podróży rozważają moralność zabicia ich jeńca i czy faktycznie jest tym, za kogo go uważają."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"普通事故","runtime":0,"tagline":"","homepage":"","overview":"只是一场意外，却又超乎意外。驾车撞死一条狗，男子与妻女来到陌生车房。凭其义肢走动时的声响，车房工认出司机或是当年施酷刑的狱吏。仇人送上门，雪恨更待何时。然而，狱中受折磨时双眼被蒙，嫌疑犯是行刑者确实无误？从早到晚奔波一轮，找来几个狱友确认俘虏身份，痛苦回忆涌上心头。在无垠沙漠等待把他活埋私了，有若在人性荒原等待果陀，替天行道又是否问心无愧？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Foi Apenas Um Acidente","runtime":102,"tagline":"","homepage":"https://imovision.com.br/foi-apenas-um-acidente","overview":"Um homem está dirigindo à noite com sua esposa grávida quando atropela e mata um cachorro. O acidente danifica gravemente seu motor. Ele para numa oficina próxima, de propriedade de Vahid, que nota que o homem se parece muito com o policial que o torturou na prisão e arruinou sua vida."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Простая случайность","runtime":101,"tagline":"","homepage":"","overview":"Семья едет домой, и внезапно их машина попадает в аварию. В автомастерской механик Вахид узнает по скрипу протеза отца семейства — это человек, которому он давно мечтал отомстить. Вахид готовит похищение, но все сильнее сомневается, не ошибся ли он. Простая случайность приводит к череде серьезных последствий."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Ein einfacher Unfall","runtime":105,"tagline":"","homepage":"https://mubi.com/de/de/films/it-was-just-an-accident","overview":"Als der Automechaniker Vahid zufällig auf den Mann trifft, der ihn mutmaßlich im Gefängnis gefoltert hat, entführt er ihn, um Vergeltung zu üben. Doch der einzige Hinweis auf Eghbals Identität ist das unverkennbare Quietschen seiner Beinprothese. Auf der Suche nach Gewissheit wendet sich Vahid an einen zerstreuten Kreis anderer, inzwischen freigelassener Opfer. Doch je tiefer sie in ihre Vergangenheit eintauchen und je mehr ihre unterschiedlichen Weltanschauungen aufeinanderprallen, desto größer werden die Zweifel: Ist er es wirklich? Und was hieße Vergeltung überhaupt?"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Jedan običan incident","runtime":0,"tagline":"","homepage":"","overview":"Noćni vozač Eghbal, na putu sa svojom trudnom suprugom, ubija psa. Nasukan traži pomoć u Vahidovoj garaži, nesvjestan da njegov spasitelj vjeruje da je on zatvorski službenik koji ga je mučio. Uvjeren, Vahid otima Eghbala kako bi ga živog pokopao, ali ubrzo se pojavljuju sumnje. Kako bi potvrdio Eghbalov identitet, Vahid angažira druge žrtve. Tijekom vožnje razmišljaju o moralnosti ubijanja svog zarobljenika i je li on zapravo onaj za koga vjeruju da jest."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Un simple accidente","runtime":105,"tagline":"","homepage":"","overview":"Un hombre conduce de noche con su esposa embarazada cuando atropella y mata a un perro, lo que le obliga a llevar el coche a un taller dirigido por un hombre que se parece al oficial que lo torturó en prisión."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"純屬伊朗意外","runtime":0,"tagline":"","homepage":"","overview":"伊朗名導約化巴納希監禁獲釋後首部力作，繼《伊朗計程車笑看人生》、《伊朗無熊無懼》後，無畏打壓再度呈現伊朗極權下的市民日常，勇奪康城影展最高榮譽金棕櫚獎。故事以巴納希獄中第一身經歷為靈感，輕盈道出一個掙紮於洩憤與道德之間的耐人尋味復仇故事：因為一宗小小事故，幾個剛回到日常的升鬥市民意外參與一場衝動綁架，對象正是曾在獄中對他們施以酷刑的嫌疑者。正當真相越辯越烈，一個求救電話響起：「施刑者」的妻子臨盆在即⋯⋯"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Tas bija tikai negadījums","runtime":0,"tagline":"","homepage":"","overview":"Vēlā nakts stundā Ekbāls, braucot kopā ar sievu un meitu, nejauši notriec suni un sabojā auto dzinēju. Meklējot palīdzīgu roku, ģimene sastop bijušo politieslodzīto Vahidu, kurš atpazīst Ekbāla protēzes skaņu un uzdod viņu par savu kādreizējo spīdzinātāju. Vīrietis neatminas pāridarītāja seju un izskatu, tomēr atmiņa ir nepiekāpīga un rīcību priekšā teicoša. Ģimenei atgriežoties mājās, viņi nenojauš, ka nelaimīgais notikums ar nabaga suni pārvērtīs viņu visu dzīves…"},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Görünmez Kaza","runtime":0,"tagline":"","homepage":"","overview":"Azerbaycanlı araba tamircisi Vahid, bir zamanlar İran'da hapsedilmiş ve gözleri bağlı halde sorgulanmıştır. Bir gün, atölyesine Eghbal adında bir adam gelir. Adamın protez bacağından çıkan gıcırtı sesi, Vahid'in ona işkence edenlerden birini tanıdığını düşünmesine neden olur."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Проста випадковість","runtime":0,"tagline":"","homepage":"","overview":"Випадково автомеханік впізнає свого тюремного ката у водії, що потрапив у аварію. Жага помсти прокидається миттєво, але єдина зачіпка – це скрип протеза. Обличчя свого мучителя чоловік ніколи не бачив. Колишній політвʼязень викрадає водія й майже ховає його живцем, але в останню мить з’являються сумніви. Тоді головний вирушає на пошуки інших колишніх вʼязнів режиму, щоб встановити особу полоненого."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"It Was Just an Accident","runtime":106,"tagline":"","homepage":"","overview":"Vahid is aan het werk in de garage als er een klant binnenkomt die problemen heeft met z'n auto. Vahid schrikt als hij Eghbal denkt te herkennen, de officier die hem in de gevangenis heeft gemarteld. Hij ruikt wraak, maar tegelijkertijd nemen de twijfels toe. Samen met een aantal lotgenoten probeert hij wanhopig de waarheid boven tafel te krijgen. Het brengt ze van riskante tot ronduit absurde situaties. Hoe weten ze zeker dat ze de juiste man te pakken hebben?"},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Lihtsalt üks õnnetus","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"Ένα Απλό Ατύχημα","runtime":0,"tagline":"","homepage":"","overview":"Μετά από ένα ατύχημα με αυτοκίνητο, ένας άντρας υποψιάζεται ότι δίπλα του ίσως και να στέκεται ο βασανιστής του από το μακρινό παρελθόν…  Είναι αυτός όμως, πράγματι; Aυτό που ξεκινά ως ένα απλό ατύχημα θέτει σε κίνηση μια σειρά από κλιμακούμενες συνέπειες που κόβουν την ανάσα στον θεατή."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Bare et uhell","runtime":0,"tagline":"","homepage":"https://www.arthaus.no/movie/it-was-just-an-accident","overview":"Gullpalmevinneren! En tilfeldighet utløser en kjede av hendelser ingen har kontroll over. Mørk satire som utforsker temaer som moral, maktmisbruk og fortrengte minner."},"name":"Bokmål","iso_639_1":"nb","iso_3166_1":"NO","english_name":"Norwegian Bokmål"},{"data":{"title":"Foi só um Acidente","runtime":105,"tagline":"","homepage":"https://www.midas-filmes.pt/filmes/un-simple-accident/","overview":"Um simples acidente desencadeia uma série de acontecimentos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Det var bara en olycka","runtime":0,"tagline":"","homepage":"","overview":"En trafikolycka sätter igång en rad oväntade händelser. Vahid, en före detta politisk fånge, tror sig ha stött på mannen som torterade honom och samlar några andra överlevare för att konfrontera honom."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"یک تصادف ساده","runtime":0,"tagline":"","homepage":"","overview":"آنچه که به عنوان یک تصادف جزئی آغاز می‌شود، مجموعه‌ای از عواقب فزاینده‌ای را دنبال می‌کند..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Fue solo un accidente","runtime":0,"tagline":"","homepage":"","overview":"Vahid, un modesto mecánico iraní, se ve repentinamente forzado a rememorar su tiempo entre rejas a raíz de un encuentro casual con Eghbal, quien le recuerda a su sádico carcelero. Alarmado, Vahid reúne a sus antiguos compañeros de prisión para verificar la identidad de Eghbal. Pero… ¿Qué harán si resulta ser él?"},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"只是一場意外","runtime":0,"tagline":"","homepage":"","overview":"只是一場意外，卻又超乎意外。駕車撞死一條狗，男子與妻女來到陌生車房。憑其義肢走動時的聲響，車房工認出司機或是當年施酷刑的獄吏。仇人送上門，雪恨更待何時。然而，獄中受折磨時雙眼被蒙，嫌疑犯是行刑者確實無誤？從早到晚奔波一輪，找來幾個獄友確認俘虜身份，痛苦回憶湧上心頭。在無垠沙漠等待把他活埋私了，有若在人性荒原等待果陀，替天行道又是否問心無愧？以懸疑驚慄佈局，暗黑寫實的人物故事來自巴納希獄中親見親聞，將苛政、濫權、以暴易暴一一置於道德倫理的天秤上，丈量人性輕重；悲憤中不失幽默，連消帶打貪污賄賂之風。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Vị Khách Bất Ngờ","runtime":0,"tagline":"","homepage":"","overview":"Một cựu tù nhân chính trị nghi ngờ rằng người khách bước vào xưởng sửa xe của mình chính là kẻ từng tra tấn anh, buộc anh phải đối mặt với ký ức và nỗi ám ảnh quá khứ."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"แค้นนี้แค่อุบัติเหตุ","runtime":0,"tagline":"","homepage":"","overview":"วาฮิด ช่างยนต์ชาวอาเซอร์ไบจาน เคยถูกคุมขังโดยรัฐบาลอิหร่าน โดยในระหว่างการถูกคุมขังของเขา เขาได้ถูกสอบปากคำในขณะที่ถูกปิดตาไม่ให้มองเห็น จนกระทั่งวันหนึ่ง ชายคนหนึ่งที่มืชื่อว่า เอ็กบาล ได้เข้ามายังที่ทำงานของเขา พร้อมกับขาเทียมที่มีเสียงดังเอี๊ยด และ วาฮิด คิดขึ้นมาได้ว่า เขาจำหนึ่งในอดีตคนที่เคยทรมาณเขาได้แล้ว"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Un simplu accident","runtime":103,"tagline":"","homepage":"","overview":"Un eveniment aparent banal. Un accident ușor de mașină urmat de o oprire pentru reparații. Doar că Vahid, mecanicul auto de serviciu, are impresia că îl recunoaște în persoana șoferului pe fostul său torționar. Așa începe un șir de întâmplări cu consecințe devastatoare – cu atât mai devastatoare cu cât Vahid nu mai e sigur că a găsit pe cine trebuie."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Un simple accident","runtime":0,"tagline":"","homepage":"","overview":"En Vahid, un humil mecànic iranià, es veu sobtadament forçat a rememorar el seu temps entre reixes arran d'una trobada casual amb l'Eghbal, que li recorda el seu sàdic carceller. Alarmat, en Vahid reuneix els seus antics companys de presó per verificar la identitat de l'Eghbal. Però... què faran si resulta que és ell?"},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Csak egy baleset","runtime":0,"tagline":"","homepage":"","overview":"Eghbal éppen hazafelé tart a feleségével és a kislányával, amikor elütnek egy kutyát. A kocsi megsérül, a motor pedig meghibásodik, így útjuk az első szerelőműhelyhez vezet. Itt összefutnak Vahiddal, az egykori politikai elítélttel, akinek megüti a fülét valami ismerős hang: Eghbal protézislába nyikorgó zajt ad ki, pontosan olyat, mint Vahidot egykor a börtönben kínzó tiszté is. Vahid elrabolja Eghbalt, azt feltételezve, hogy ő az a korábbi kínzó. El is akarja temetni élve a sivatagban, de előtte kétségek gyötrik: vajon tényleg ő-e az igazi bűnös?"},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"シンプル・アクシデント／偶然","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"}],"reviews_tmdb":[{"id":"68ed7dd770500deeb3d69255","url":"https://www.themoviedb.org/review/68ed7dd770500deeb3d69255","author":"Manuel São Bento","content":"FULL SPOILER-FREE REVIEW @ https://fandomwire.com/it-was-just-an-accident-review/\r\n\r\n\"It Was Just an Accident is a testament to the unwavering courage of Jafar Panahi, a filmmaker who refuses to be silenced.\r\n\r\nIt's a brave protest executed as a psychological thriller that, despite occasionally stumbling in its own need to be overtly political — with the message sometimes delivered too directly — manages, in its conclusion, to transcend its narrative and raise moral questions that are difficult to ignore.\r\n\r\nAn intense and intrepid invitation to confront the inconvenient truth that, under an oppressive regime, the line between justice and fatality is often drawn by chance.\"\r\n\r\nRating: B","created_at":"2025-10-13T22:31:51.172Z","updated_at":"2025-10-13T22:31:51.245Z","author_details":{"name":"Manuel São Bento","rating":7,"username":"msbreviews","avatar_path":null}},{"id":"6908b546244c1efe05e131a2","url":"https://www.themoviedb.org/review/6908b546244c1efe05e131a2","author":"Brent Marchant","content":"$11","created_at":"2025-11-03T13:59:34.641Z","updated_at":"2025-11-03T14:03:29.343Z","author_details":{"name":"Brent Marchant","rating":8,"username":"Brent_Marchant","avatar_path":null}},{"id":"697c834caba485572626ad45","url":"https://www.themoviedb.org/review/697c834caba485572626ad45","author":"CinemaSerf","content":"$12","created_at":"2026-01-30T10:09:16.525Z","updated_at":"2026-01-30T10:09:16.629Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":78363,"adult":false,"title":"My Little Princess","video":false,"overview":"Young Violetta and her mother Hannah are a peculiar couple. Ten-year-old Violetta lives a quiet life with her grandmother, while her mother Hannah is an unpredictable photographer who lives off of the generosity of others. When Hannah forces her daughter to pose as a model, Violetta finds her life with her loving grandmother turned upside down.The resulting pictures quickly become a sensation for the trendy 70's Paris art scene, and Violetta finds herself caught in between her new stature as an art muse and her dull childhood.","genre_ids":[18],"media_type":"movie","popularity":1.0789,"vote_count":89,"poster_path":"/uHBBHx7AXfk3tNhy3zYgF8DttYm.jpg","release_date":"2011-06-29","vote_average":6.5,"backdrop_path":"/89MfnOg6pQbPPy70a5J5yhtrtIH.jpg","original_title":"My Little Princess","original_language":"fr"},{"id":1356670,"adult":false,"title":"Late Shift","video":false,"overview":"Dedicated nurse Floria navigates the relentless pace of her hospital’s understaffed surgical ward with humanity and warmth. As her overnight shift intensifies, she is pushed to the brink in a race against time.","genre_ids":[18],"media_type":"movie","popularity":4.8273,"vote_count":195,"poster_path":"/2X2FZIYdXYNwDbStJhgeoVn0pWH.jpg","release_date":"2025-02-27","vote_average":7.792,"backdrop_path":"/egNz2a18eQ9ycBfQQkQehSTeNwH.jpg","original_title":"Heldin","original_language":"de"},{"id":320006,"adult":false,"title":"Taxi","video":false,"overview":"A yellow cab is driving through the vibrant and colourful streets of Tehran. Very diverse passengers enter the taxi, each candidly expressing their views while being interviewed by the driver who is no one else but the director Jafar Panahi himself. His camera placed on the dashboard of his mobile film studio captures the spirit of Iranian society through this comedic and dramatic drive…","genre_ids":[35,18],"media_type":"movie","popularity":0.5912,"vote_count":465,"poster_path":"/lY2RW6pxRYyPmrgUF0rjqbeAnTu.jpg","release_date":"2015-04-15","vote_average":7.042,"backdrop_path":"/677ohgE1vEEMSIHZILT19z4rf58.jpg","original_title":"تاکسی","original_language":"fa"},{"id":11349,"adult":false,"title":"Cape Fear","video":false,"overview":"Sam Bowden witnesses a rape committed by Max Cady and testifies against him. When released after 8 years in prison, Cady begins stalking Bowden and his family but is always clever enough not to violate the law.","genre_ids":[53,18],"media_type":"movie","popularity":1.9123,"vote_count":611,"poster_path":"/xDqaHjMbnebtB05QWgAR8wW86sb.jpg","release_date":"1962-04-12","vote_average":7.448,"backdrop_path":"/gPqtCp55HWsJ2f3fEPsoXD77KQx.jpg","original_title":"Cape Fear","original_language":"en"},{"id":289143,"adult":false,"title":"Dofus - Book I: Julith","video":false,"overview":"The strange little guy in the blue hood is well known to Krosmoz. His name is Joris and he's proposing to take you on a fantastic adventure. Our hero is leading a happy life in his magic shop in the city of Bonta. But one day, when he seeks out his idol, a Gobbowl superstar, everything changes for the worst as Julith, the vengeful witch, is back in town!","genre_ids":[16,28,12,14,35],"media_type":"movie","popularity":0.4741,"vote_count":102,"poster_path":"/pRupT7qQEMWxZQMfeNPd0w05e3W.jpg","release_date":"2016-02-03","vote_average":7.471,"backdrop_path":"/1HQVcI3haceSQJl7X8a6KnbrwTg.jpg","original_title":"Dofus - Livre 1 : Julith","original_language":"fr"},{"id":42744,"adult":false,"title":"The Knack... and How to Get It","video":false,"overview":"A nebbish schoolteacher begs his smooth (and misogynistic) pal to teach him 'the knack' – how to score with women. Serendipitously, the men meet up with a new girl in town, as well as a friendly lunatic who can’t help but paint things white.","genre_ids":[35,10749],"media_type":"movie","popularity"