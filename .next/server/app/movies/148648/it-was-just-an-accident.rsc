,"iso_3166_1":"PL","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1366,"height":2048,"file_path":"/pF5TrkMcDiDehwiDOdOLBlFkrWF.jpg","iso_639_1":"th","iso_3166_1":"TH","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1996,"height":3000,"file_path":"/uZ9cCQVXiiQiFmzKrMt0OITBqJR.jpg","iso_639_1":"fa","iso_3166_1":"IR","vote_count":0,"aspect_ratio":0.665,"vote_average":0},{"width":1996,"height":3000,"file_path":"/krELbmQQtzEVjQXJAnVdwTowhii.jpg","iso_639_1":"fa","iso_3166_1":"IR","vote_count":0,"aspect_ratio":0.665,"vote_average":0},{"width":1000,"height":1500,"file_path":"/jsgpIvvG91JGWDe1SCPobXNcYZd.jpg","iso_639_1":"ro","iso_3166_1":"RO","vote_count":1,"aspect_ratio":0.667,"vote_average":0},{"width":1080,"height":1440,"file_path":"/8jDMcVVNdqfVFMvraCVHh9zVw8a.jpg","iso_639_1":"fa","iso_3166_1":"IR","vote_count":0,"aspect_ratio":0.75,"vote_average":0},{"width":1080,"height":1439,"file_path":"/kxvdUkDBfxveQGGlSfyHrMVmyI4.jpg","iso_639_1":"fa","iso_3166_1":"IR","vote_count":1,"aspect_ratio":0.751,"vote_average":0},{"width":1081,"height":1621,"file_path":"/m4hYzgjHEd6B5GQ3HX6dbeSZfbW.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1273,"height":1910,"file_path":"/hhha00oVdP27f9JiUt7mHJpHMDs.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.666,"vote_average":0},{"width":1787,"height":2516,"file_path":"/ajgu6khiXWeV6RlvzrZNWYn03UW.jpg","iso_639_1":"zh","iso_3166_1":"TW","vote_count":0,"aspect_ratio":0.71,"vote_average":0},{"width":1672,"height":2508,"file_path":"/zvxkvr2B84gR5rblNuCPupEneKW.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":1,"aspect_ratio":0.667,"vote_average":0},{"width":1428,"height":2048,"file_path":"/ahMzkAxEIH7HKabK2d0fO2Q08Zl.jpg","iso_639_1":"zh","iso_3166_1":"TW","vote_count":0,"aspect_ratio":0.697,"vote_average":0},{"width":1000,"height":1500,"file_path":"/mbIzzSyogd728brKV1uWaKaVO2G.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,