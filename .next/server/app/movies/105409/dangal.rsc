edb.org/movie/360814/watch?locale=YE","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZA":{"link":"https://www.themoviedb.org/movie/360814/watch?locale=ZA","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZM":{"link":"https://www.themoviedb.org/movie/360814/watch?locale=ZM","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZW":{"link":"https://www.themoviedb.org/movie/360814/watch?locale=ZW","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":4}]}}},"wikidata_id":"Q20762668","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"IN","main_poster":"/a8mHbR2bkTfP3T6GJBzl1ISPnpK.jpg","images":{"logos":[{"width":1276,"height":344,"file_path":"/w9Bxolh7pQY8SfNPPpuKahQhxkY.png","iso_639_1":"en","vote_average":3.334},{"width":960,"height":446,"file_path":"/lz1Ck0PaVrhJKXU9CURuvVjeomX.png","iso_639_1":"zh","vote_average":3.334},{"width":1389,"height":357,"file_path":"/yzP3WnRrH0UD5x7Sp2hGtPIERKv.png","iso_639_1":"zh","vote_average":0.166}],"posters":[{"width":1000,"height":1500,"file_path":"/a8mHbR2bkTfP3T6GJBzl1ISPnpK.jpg","iso_639_1":"zh","vote_average":3.334},{"width":2000,"height":2855,"file_path":"/rHr4IUX6VAFqf7HsRGjky1ycIeD.jpg","iso_639_1":"ko","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/j5M6e55pAhzPWUTP5k0Qyg6o876.jpg","iso_639_1":"zh","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/s4CGpFZVAoCLjdyHGRNBa9t0Ulr.jpg","iso_639_1":"ru","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/3n8888uKuaxPBBuDUqJhfhrWlgA.jpg","iso_639_1":null,"vote_average":3.334},{"width":2000,"height":2852,"file_path":"/4oJ2D6Q3lRXAg7m