dth":1407,"height":792,"file_path":"/A42ISHYgPS9wn1getLQJuefAxvd.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2814,"height":1584,"file_path":"/w8Vd3JoXcrwXPpKNJIQoZLzuCEj.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1385,"height":779,"file_path":"/yBDMKI22W6s7fTytlxB2sLJhPyd.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1414,"height":796,"file_path":"/aaWB8UznjMysyLNFDGMPfkqWTmb.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.776,"vote_average":0},{"width":1418,"height":798,"file_path":"/m5GUkqjJMopTzqiP8wk76uCEWiO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1396,"height":785,"file_path":"/Vpvo6GEa632saYNfENCDBfoSRL.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1425,"height":802,"file_path":"/hGUK7GloTgkdk4rAU5oMIt5PAw7.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2822,"height":1588,"file_path":"/5ANhE0YsLmreqXPChnms4JT5D0C.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0}]},"enriched_at":"2026-04-21T09:19:44.376+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":131,"tagline":"Quá khứ chưa ngủ yên, ngày mai liệu sẽ đến?","homepage":"","overview":"MAI xoay quanh câu chuyện về cuộc đời của một người phụ nữ cùng tên với bộ phim. Trên First-look Poster, Phương Anh Đào tạo ấn tượng mạnh với cái nhìn tĩnh lặng, xuyên thấu, đặc biệt, trên bờ môi nữ diễn viên là hình ảnh cô đang nằm nghiêng trên mặt nước. Được phủ một màn sương mờ ảo, poster đậm chất nghệ thuật của Mai gây tò mò với lời tựa: “Quá khứ chưa ngủ yên, ngày mai liệu sẽ đến?”."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":131,"tagline":"","homepage":"","overview":"When a struggling single mother falls for a wealthy heartbreaker, their risky romance could just turn their lives around — or tear their worlds apart."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Mai se lie d'amitié avec un homme mais son passé la rattrape..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"再愛一次","runtime":0,"tagline":"","homepage":"","overview":"阿梅出生在一個不幸的家庭，父親沈迷於賭博欠下大筆債務，在女孩最美的年紀，阿梅卻經歷了一場可怕的悲劇…長大後，阿梅靠著自己的能力，認真的工作、生活，本以為人生不可能再經歷愛情，卻遇上了對她窮追不捨的富家少爺阿當。阿梅最終接受了阿當真摯的愛，原本以為兩人從此過著王子公主般幸福快樂的生活，卻不知阿當的家庭會為兩人帶來毀天滅地的將來…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"รักของไม","runtime":0,"tagline":"","homepage":"","overview":"เมื่อแม่ลูกติดสู้ชีวิตได้พบรักกับเพลย์บอยหนุ่มฐานะดี ความสัมพันธ์สุดเสี่ยงครั้งนี้ก็อาจพลิกผันชีวิตหรือทำให้โลกของทั้งคู่ต้องพังทลาย"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"再爱一次","runtime":131,"tagline":"","homepage":"","overview":"麦是一个出生在一个不幸家庭的女孩，父亲沉迷于赌博。在女孩最美的年纪，麦却经历了一场无比可怕的悲剧。正因为如此，麦必须想尽一切办法赚钱才能在这座宏伟的城市生存。然后，命运推动麦成为一名按摩女郎。当然，与她的同事不同，麦只“出售她的艺术，而不是她的身体”。然而这份工作还是让她遭受了不少丑闻，被视为妓女。当她遇到了住在Mai房间对面的邻居Duong时，她的生活突然发生了转变。与Mai相反，Duong是一个出生在终点线的年轻人，他搬出去生活只是为了寻找创作灵感。他过着放荡不羁的生活，是一名“女人杀手”，并因向最好的朋友发起挑战而决心赢得麦。\r Mai 与所有和 Duong 睡过的女孩不同。她追他并不是为了乞求他的爱，只是想让他离她的生活越远越好。她说，她对男人的感情已经淡漠，一心只想赚钱。起初，也许Duong只是把Mai视为一个征服目标，让他享受路过的乐趣。她越是拒绝，他就越是逼迫。但与Mai接触得越多，Duong的心就越跳动。最终，他付出了最真挚的爱，只希望能和麦一起度过余生。但因为两个人的境遇如此不同，麦的心中始终有一种恐惧。她将幸福视为明天，是永远不会到来的东西。她的心现在已经有了那么多的划痕，已经不能再受伤害了。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"越南越愛","runtime":0,"tagline":"","homepage":"","overview":"阿梅在按摩院努力工作，咬緊牙關撐起一家人。直到遇上富家少爺阿當——外表玩世不恭，內心卻渴望擺脱母親掌控。電影笑料百出又不失温度，輕鬆帶出越南社會的真實困境。打破越南影史票房紀錄，成為口碑與票房雙贏的現象級作品。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Inquieta y atormentada por el pasado, Mai es recibida por un nuevo amanecer cuando se hace amiga a regañadientes del donjuán del vecindario. Pero cuando su ayer la alcanza hoy, ¿qué será de su mañana?"},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":131,"tagline":"","homepage":"","overview":"Quando uma mãe solteira em dificuldades se apaixona por um destruidor de corações rico, seu romance arriscado pode mudar suas vidas - ou destruir seus mundos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Май","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Mladá Vietnamka Mai si toho v životě hodně vytrpěla. Najde si nové bydlení, kde se seznámí se Sauem, svým sousedem. Jak se navzájem poznávají, jejich příběh se proměňuje, provází jej humor, smutek, štěstí i drama. Jejich cesta vyvrcholí v překvapivý závěr."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"}],"reviews_tmdb":[],"recommendations":[{"id":267583,"adult":false,"title":"Disney Presents: Main Street Electrical Parade - Farewell Season","video":false,"overview":"Catch the spark after dark at Disneyland Park. And say farewell to one of the Magic Kingdom's most celebrated traditions - The Main Street Electrical Parade. Where else, but in The Main Street Electrical Parade, could you see an illuminated 40-foot-long fire-breathing dragon? And hear the energy of its legendary melody one last time? It's unforgettable after-dark magic that will glow in your heart long after the last float has disappeared.","genre_ids":[99,10751],"media_type":"movie","popularity":0.1989,"vote_count":75,"poster_path":"/lRyfmbHKFcQxUeboRmJVIZBx6kF.jpg","release_date":"1996-11-25","vote_average":5.4,"backdrop_path":"/f1MplKJl4LveJJOa7JsirLtf3NR.jpg","original_title":"Disney Presents: Main Street Electrical Parade - Farewell Season","original_language":"en"},{"id":84533,"adult":false,"title":"Ek Main Aur Ekk Tu","video":false,"overview":"Rahul and Riana meet each other for the first time, get drunk, and awake the next morning to find that they have gotten legally married to each other.","genre_ids":[18,35,10749],"media_type":"movie","popularity":0.2315,"vote_count":152,"poster_path":"/yei87xHRcmf4OhritS6GAju8fdq.jpg","release_date":"2012-02-10","vote_average":5.6,"backdrop_path":"/pSBhZmx4uEatuPbcNm3ryABTWA0.jpg","original_title":"एक मैं और एक तू","original_language":"hi"},{"id":1155089,"adult":false,"title":"Justice League: Crisis on Infinite Earths Part One","video":false,"overview":"Death is coming. Worse than death: oblivion. Not just for our Earth, but for everyone, everywhere, in every universe! Against this ultimate destruction, the mysterious Monitor has gathered the greatest team of Super Heroes ever assembled. But what can the combined might of Superman, Wonder Woman, Batman, The Flash, Green Lantern and hundreds of Super Heroes from multiple Earths even do to save all of reality from an unstoppable antimatter armageddon?!","genre_ids":[16,878,28],"media_type":"movie","popularity":3.3964,"vote_count":390,"poster_path":"/zR6C66EDklgTPLHRSmmMt5878MR.jpg","release_date":"2024-01-08","vote_average":7.277,"backdrop_path":"/tWEcrdHbQLJUuetCQupgCJaTRQ9.jpg","original_title":"Justice League: Crisis on Infinite Earths Part One","original_language":"en"},{"id":1118224,"adult":false,"title":"Maharaja","video":false,"overview":"A barber seeks vengeance after his home is burglarized, cryptically telling police his \"Lakshmi\" has been taken, leaving them uncertain if it's a person or object, jeer at his request until they learn what they're really looking for.","genre_ids":[28,53,9648],"media_type":"movie","popul