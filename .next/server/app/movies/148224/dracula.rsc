t":0,"aspect_ratio":1.78,"vote_average":0},{"width":1408,"height":791,"file_path":"/nNdnGHuCwMSbBrd91cue2ayx7l7.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.78,"vote_average":0},{"width":1408,"height":791,"file_path":"/bMDbbq9y49O7RPASIzgyYzDb3VU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.78,"vote_average":0},{"width":1408,"height":791,"file_path":"/ggRjn6jpOgpvJ6thVZwyHozZu3S.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.78,"vote_average":0},{"width":1337,"height":751,"file_path":"/xPjUQAlCrVzCV3EmlAjVTSX4Ak6.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.78,"vote_average":0},{"width":1920,"height":1080,"file_path":"/yLaUYDCT3BqQbrZORLjKiojVJT5.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/4b5ExOBnC2wWYFK21FumzQznB58.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/gQOOYKMJ77xKf8kC40fAtB5XOw5.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/iSEozVhuJCU5oX2fnRA9SSnIRnK.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":1,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/s6kMFEVw71Ojsoj8DKBKky0kZpP.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/ti9OB4uWV6C9MCSIZee6XLKYK1M.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:45:27.29+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":130,"tagline":"He renounced his faith to become immortal. Passion, anger, vengeance, and hatred will be unleashed into the modern world.","homepage":"https://signature-entertainment.co.uk/distribution/titles/dracula","overview":"In late 15th-century Eastern Europe, Prince Vlad II’s bride is brutally murdered. As a result, he renounces God and damns Heaven itself. Cursed with eternal life, Vlad is reborn as Dracula, an immortal warlord who defies fate in a blood-soaked crusade to wrench his lost love back from death."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"드라큘라: 어 러브 테일","runtime":0,"tagline":"","homepage":"","overview":"거장 뤽 베송이 선사하는 전설의 화려한 부활, 그 태초의 이야기.\r 15세기, 신을 위해 칼을 들고 전장을 누비던 왕자 '블라드'. 하지만 신은 그의 헌신에 대한 대가로 가장 사랑하는 여인을 죽음으로 몰아넣는다. 찢어질 듯한 슬픔과 배신감에 사로잡힌 그는 십자가를 부수고 신을 저주하며, 영원히 죽지 못하는 어둠의 길을 선택한다.\r 피를 마시며 영겁의 시간을 견뎌온 괴물, 드라큘라. 세기를 넘어 다시금 그에게 운명처럼 찾아온 사랑의 흔적은 그를 광기와 열망의 소용돌이로 몰아넣는다.\r \"내 사랑을 앗아간 신에게 복수하고, 영원 속에서 당신을 다시 찾으리라.\"\r 칸 영화제 남우주연상 수상자 케일럽 랜드리 존스와 크리스토프 왈츠의 압도적인 연기, 그리고 뤽 베송 감독 특유의 미학적인 비주얼이 만나 탄생한 고딕 판타지. 공포를 넘어선 비극적이고도 아름다운 핏빛 서사시가 당신의 심장을 조여온다.\r 괴물이 될 수밖에 없었던 한 남자의 처절한 사랑, 그 거대한 비극의 막이 오른다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Dracula - L’amore perduto","runtime":129,"tagline":"Rinunciò alla sua fede per diventare immortale. Passione, rabbia, vendetta e odio saranno scatenati nel mondo moderno.","homepage":"","overview":"Transilvania, XV secolo. Il principe Vladimir, dopo la perdita improvvisa della sua amata, rinnega Dio, ereditando così una maledizione eterna: diventare un vampiro. Condannato a vagare nei secoli, sfida il destino e la morte stessa, guidato da un’unica speranza: ritrovare l’amore perduto."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":129,"tagline":"Il a renié sa foi pour devenir immortel. La passion, la colère, la vengeance et la haine se déchaîneront dans le monde moderne.","homepage":"https://www.snd-films.com/movies/47","overview":"Au XVe siècle, le Prince Vladimir renie Dieu après la perte brutale et cruelle de son épouse. Il hérite alors d’une malédiction : la vie éternelle. Il devient Dracula. Condamné à errer à travers les siècles, il n’aura plus qu’un seul espoir : celui de retrouver son amour perdu."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Dracula: Bản Tình Ca Bất Diệt","runtime":0,"tagline":"","homepage":"","overview":"Một hoàng tử tuyệt vọng biến thành Dracula và lang thang bất tận qua thời gian, sống chỉ vì lời hứa tìm lại tình yêu của đời mình."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Dracula - Die Auferstehung","runtime":129,"tagline":"","homepage":"","overview":"Die Geschichte von Prinz Vladimir aus dem 15. Jahrhundert, der nach dem Tod seiner geliebten Frau Gott verflucht und in einen Vampir verwandelt wird. Später, im London des 19. Jahrhunderts, entdeckt er die Doppelgängerin seiner Frau und verdammt sich selbst, indem er ihr nachstellt."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Граф Дракула: Історія кохання","runtime":0,"tagline":"","homepage":"","overview":"Після смерті дружини принц зрікається Бога і стає вампіром. Через віки, у Лондоні XIX століття, він бачить жінку, схожу на покійну кохану, і вирішує здобути її, прирікаючи себе на фатальні наслідки."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Drakula: Vječna ljubav","runtime":0,"tagline":"Odrekao se svoje vjere kako bi postao besmrtan. Strast, ljutnja, osveta i mržnja bit će oslobođeni u suvremeni svijet.","homepage":"","overview":"Nakon što izgubi svoju voljenu, princ se odriče Boga i pretvara u besmrtnog vampira. Stoljećima kasnije, u maglovitom Londonu 19. stoljeća, ugleda ženu koja neodoljivo podsjeća na njegovu izgubljenu ljubav. Vođen strašću i prokletstvom, kreće u lov koji će zauvijek obilježiti njegovu sudbinu."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Drácula - Uma História de Amor Eterno","runtime":129,"tagline":"A origem da história que atravessou séculos.","homepage":"","overview":"No século XV, o príncipe Vlad II perde o seu amor, a princesa Elisabeta. Tomado pela dor, rejeita a Deus e herda uma maldição eterna: vira o Conde Drácula, um vampiro condenado a vagar pelos séculos na esperança de reencontrar a amada."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Drácula","runtime":129,"tagline":"Renunció a su fe para ser inmortal. La pasión, la ira, la venganza y el odio se desatarán en el mundo moderno.","homepage":"","overview":"Tras la muerte de su esposa, un príncipe del siglo XV renuncia a Dios y se convierte en vampiro. Siglos más tarde, en el Londres del siglo XIX, ve a una mujer parecida a su difunta esposa y la persigue, sellando así su propio destino."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Дракула","runtime":0,"tagline":"«Он отрёкся от веры, чтобы стать бессмертным»","homepage":"","overview":"Принц Влад II, граф Дракула, живёт ради любви к жене, принцессе Елизавете. Вернувшись с победоносной войны, которую он вёл во имя церкви, принц узнаёт о смерти Елизаветы. Убитый горем он гневается на бога, который отнял у него самое дорогое, а, узнав, что его возлюбленная может возродиться, он отрекается от всего и обрекает себя на бессмертие. Спустя 400 лет ожидания Дракула вновь встречает свою любовь в облике юной Мины."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Drácula","runtime":0,"tagline":"","homepage":"","overview":"Tras una devastadora pérdida, el príncipe Vlad II, conde Drácula (Caleb Landy Jones), renuncia a Dios y es maldecido a la vida eterna, condenado a vagar solitario a lo largo de los siglos. Este es el relato sobre la historia de amor jamás contada del infame vampiro, que desafiará al destino y la mortalidad en busca de su amor perdido."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":129,"tagline":"","homepage":"","overview":"Wanneer de geliefde vrouw van prins Vladimir in de 15e eeuw sterft, keert hij zich vol woede af van God. Als straf wordt hij vervloekt tot een eeuwig bestaan als vampier. Gedreven door zijn intense verlangen naar zijn overleden vrouw zwerft hij eeuwenlang rond, gevangen tussen mens en monster. In het Londen van de 19e eeuw ontmoet hij een vrouw die sprekend op haar lijkt. Zijn verlangen om haar terug te winnen zet een tragisch liefdesverhaal in gang, vol gevaar, verleiding en de strijd tegen zijn eigen duistere lot."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Dracula. Historia wiecznej miłości","runtime":129,"tagline":"","homepage":"","overview":"Kiedy w XV wieku umiera ukochana żona księcia, wpada on w furię i odwraca się od Boga. Za karę zostaje skazany na wieczne istnienie jako wampir. Powodowany głęboką tęsknotą za zmarłą żoną, błąka się przez wieki, uwięziony między człowiekiem a potworem. W XIX-wiecznym Londynie spotyka kobietę, która jest do niej uderzająco podobna. Pragnienie jej odzyskania zapoczątkowuje tragiczną historię miłosną, pełną niebezpieczeństw, pokus i walki z własnym mrocznym przeznaczeniem."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Drakula","runtime":129,"tagline":"","homepage":"","overview":"Tragiškas, žavus ir labai žmogiškas grafas Drakula, nepaisydamas likimo, jau keturis šimtmečius ieško savo prarastos meilės blaškydamasis tarp kruvinų Transilvanijos pilies sienų, ar paslaptingai pasirodydamas prabanga spindinčiuose Paryžiaus aukštuomenės pokyliuose.  Kol vieną dieną išvysta ją - Miną, moterį, stulbinančiai panašią į kadaise mirusią jo gyvenimo meilę. Ji - iš seniai pamiršto sapno, iš gyvenimo, kuriame jis dar buvo gyvas... Minos žvilgsnis pažadina tai, kas buvo palaidota šimtmečius. Drakula stebi ją – ne kaip grobį, bet kaip gyvą atmintį, kaip liepsną, kurią svajoja vėl pajausti..."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Drakula: Večna ljubezen","runtime":0,"tagline":"","homepage":"","overview":"Zgodba o knezu Vladimirju iz 15. stoletja, ki se po smrti svoje ljubljene žene odreče Bogu in postane vampir. Kasneje, v Londonu 19. stoletja, sreča žensko, ki je osupljivo podobna njegovi pokojni ljubezni. Prepričan, da gre za njeno reinkarnacijo, se poda v nevarno igro strasti, hrepenenja in večne obsedenosti. A njegova nesmrtnost ima svojo ceno."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"Drakula","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Дракула: Любовна приказка","runtime":0,"tagline":"","homepage":"","overview":"Историята разказва за княз Владимир от 15-ти век, който, покрусен от смъртта на любимата си съпруга, проклина Бог и е превърнат във вампир. Столетия по-късно, през 19-ти век в Лондон, той открива жена, която е двойник на покойната му съпруга, и започва да я преследва, обсебен от нея."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"دراکولا : روایت عاشقانه","runtime":0,"tagline":"","homepage":"","overview":"داستان شاهزاده ولادیمیر در قرن پانزدهم که پس از مرگ همسر محبوبش، نفرین و به خون‌آشام تبدیل می‌شود. بعدها، در قرن نوزدهم در لندن، او همزاد همسرش را کشف می‌کند و با تعقیب او، خود را به کام مرگ می‌کشاند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Dracula: O poveste de dragoste","runtime":129,"tagline":"","homepage":"","overview":"Într-o reinterpretare gotică a clasicului lui Bram Stoker, regizată de Luc Besson, \"Dracula: O poveste de dragoste\" urmărește povestea unui prinț din secolul al XV-lea care, după moartea soției sale, renunță la credință și se transformă într-un vampir. Secole mai târziu, în Londra victoriană, el întâlnește o femeie ce seamănă izbitor cu iubita sa pierdută, declanșând o obsesie care îl condamnă să-și caute iubirea veșnică."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"德古拉","runtime":0,"tagline":"","homepage":"","overview":"故事讲述 15 世纪的弗拉基米尔王子，在爱妻离世后诅咒上帝，最终化作吸血鬼；此后在 19 世纪的伦敦，他遇见了与妻子容貌一模一样的分身，却因执意追寻她而自取毁灭。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Ο Δράκουλας, καταδικασμένος να περιπλανιέται στους αιώνες, αψηφά το πεπρωμένο και τον ίδιο τον θάνατο, καθοδηγούμενος από μια μοναδική ελπίδα: να ξαναενωθεί με την χαμένη του αγάπη."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"دراكولا: قصة حب","runtime":129,"tagline":"","homepage":"","overview":"قصة الأمير فلاديمير في القرن الخامس عشر، الذي لعنه الرب بعد وفاة زوجته الحبيبة، فتحوَّل إلى مصاص دماء. وفي لندن بالقرن التاسع عشر، يكتشف شبيهة زوجته، فيحكم على نفسه بالهلاك بمطاردتها."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"დრაკულა","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Drácula: Uma História de Amor","runtime":129,"tagline":"","homepage":"","overview":"Quando um príncipe do século XV renega Deus após a devastadora perda da sua mulher, herda uma maldição eterna; torna-se Drácula. Condenado a vaguear pelos séculos, desafia o destino e a própria morte, guiado por uma única esperança; reencontrar o seu amor perdido."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"דרקולה: סיפור אהבה","runtime":129,"tagline":"","homepage":"","overview":"בשנת 1480, ברומניה, הנסיך ולדימיר מתרחק מהדת לאחר מות אשתו האהובה והופך לערפד. לאחר מכן הוא יוצא לחפש את גלגול נשמתו ברחבי העולם. יותר מ-400 שנה מאוחר יותר, במאה ה-19, הוא מוצא אישה צעירה בפריז הדומה לאשתו המנוחה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Dracula: Příběh lásky","runtime":129,"tagline":"Zřekl se své víry, aby se stal nesmrtelným. V moderním světě se rozpoutá vášeň, hněv, pomsta a nenávist.","homepage":"","overview":"V 15. století přichází kníže Vlad o svou milovanou ženu. Ve chvíli zoufalství se odvrací od Boha a přijímá prokletí nesmrtelnosti. Stává se temným hrabětem Draculou. Odsouzený k věčnému putování staletími nese tíhu lásky i viny, která ho nikdy neopustí. O čtyři století později, v Londýně 19. století, potkává ženu nápadně podobnou své zesnulé manželce. Setkání, na které čekal celou věčnost, se stává začátkem posedlosti, která mu může přinést spásu i zkázu."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Dracula: A Love Tale","runtime":124,"tagline":"","homepage":"","overview":"På 1400-talet slits prins Vladimir brutalt från sin älskade hustru när hon plötsligt rycks ur livet. Förtvivlan förvandlas till rasande sorg, och i sin desperation vänder han Gud ryggen. Men olydnaden får ett fruktansvärt pris - en odödlig förbannelse läggs över honom. Förvandlad till den mytomspunna Dracula tvingas han vandra genom seklernas mörker, evigt förföljd av dödens skugga. Ändå brinner något kvar i hans hjärta: en glöd av hopp, om att en dag åter få omfamna sin förlorade kärlek."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"德古拉：愛情故事","runtime":0,"tagline":"","homepage":"","overview":"妻子過世後，一位15世紀的王子背棄上帝，變成了吸血鬼。幾個世紀後，在19世紀的倫敦，他看到一個酷似亡妻的女子，便追求她，最終注定了自己的命運。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":129,"tagline":"Il a renié sa foi pour devenir immortel. La passion, la colère, la vengeance et la haine se déchaîneront dans le monde moderne.","homepage":"","overview":"Au XVe siècle, le Prince Vladimir renie Dieu après la perte brutale et cruelle de son épouse. Il hérite alors d’une malédiction : la vie éternelle. Il devient Dracula. Condamné à errer à travers les siècles, il n’aura plus qu’un seul espoir : celui de retrouver son amour perdu."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Drakula: Szerelmes történet","runtime":129,"tagline":"Lemondott hitéről, hogy halhatatlan legyen. Szenvedély, harag, bosszú és gyűlölet szabadul fel a modern világban.","homepage":"","overview":"Bram Stoker klasszikus Drakulájának feldolgozásában a 15. században egy herceg a felesége elvesztése után megtagadja Istent, emiatt örök átok sújtja és Drakulává válik. A vérszívó élőhalott évszázadokon át vándorol, dacol a sorssal és a halállal, és egyetlen remény vezérli: újra találkozni elvesztett szerelmével. Egy pap azonban felismeri és szembeszáll vele azért, hogy elpusztítsa őt."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Når en prins på 1400-tallet vender Gud ryggen etter det knusende tapet av sin kone, faller en evig forbannelse over ham: han blir Dracula. Fordømt til å vandre gjennom århundrene trosser han både skjebnen og døden selv, drevet av ett eneste håp – å gjenforenes med sin tapte kjærlighet."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"","runtime":130,"tagline":"","homepage":"","overview":"Da en prins fra det 15. århundrede fordømmer Gud efter det forfærdelige tab af sin kone, arver han en evig forbandelse: han bliver til Dracula. Dømt til at vandre gennem århundreder trodser han skæbnen og selve døden, styret af et enkelt håb - at blive genforenet med sin tabte kærlighed."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"德古拉：愛情故事","runtime":0,"tagline":"","homepage":"","overview":"妻子過世後，一位15世紀的王子背棄上帝，變成了吸血鬼。幾個世紀後，在19世紀的倫敦，他看到一個酷似亡妻的女子，便追求她，最終註定了自己的命運"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Dracula: Príbeh lásky","runtime":0,"tagline":"Zriekol sa svojej viery, aby sa stal nesmrteľným. Vášeň, hnev, pomsta a nenávisť sa uvoľnia do moderného sveta.","homepage":"","overview":"Film Dracula: Príbeh lásky prináša pôsobivú romantickú a gotickú verziu legendy o nesmrteľnom upírovi. Princ Vladimír po tragickej smrti svojej manželky prekľaje Boha a je odsúdený na večný život ako Dracula. Stáročia blúdi svetom v osamelosti, až kým v 19. storočí nestretne ženu nápadne podobnú svojej stratenej láske. Tento nečakaný okamih v ňom prebudí nádej i vášeň a prinúti ho čeliť vlastnému prekliatiu, aby ešte raz získal šancu na lásku, za ktorú je ochotný obetovať všetko."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Дракула","runtime":0,"tagline":"","homepage":"","overview":"Када принц из 15. века осуди Бога након разарајућег губитка супруге, наслеђује вечно проклетство: постаје Дракула. ​​Осуђен да лута вековима, он пркоси судбини и самој смрти, вођен једном надом - да се поново сједини са својом изгубљеном љубављу."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Laastava kaotuse järel loobub 15 sajandi prints Jumalast ja talle pannakse igavese elu needus ta saab Draculaks. Nüüd avaneb kuulsa vampiiri seni rääkimata armastuslugu ta rändab läbi sajandite, trotsides saatust ja surelikkust otsides oma kaotatud armastust."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"แดร็กคูล่า","runtime":0,"tagline":"","homepage":"","overview":"เมื่อเจ้าชายจากศตวรรษที่ 15 สูญเสียภรรยาที่รัก เขา **สาบานว่าเลิกเชื่อในพระเจ้า** ด้วยความเศร้าโศกและความโกรธ จึงถูกสาปให้กลายเป็น **แดร็กคูล่า** — แวมไพร์อมตะผู้ต้องเดินทางเร่ร่อนข้ามยุคสมัยไม่รู้จบ 🦇 💔  **(คำบรรยายเรื่องหลักจาก IMDB)** ([IMDb][1])  แดร็กคูล่าถูกตราหน้าให้อยู่เป็นอมตะหลังจากการสูญเสียครั้งนี้ และถูกจารึกไว้ในประวัติศาสตร์คำเล่าขานว่าเป็นแวมไพร์ที่เฉื่อยชาแต่โหยหาความรักอันลึกซึ้งตลอดกาล"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Dràcula","runtime":0,"tagline":"","homepage":"","overview":"Després de la mort de la seva esposa, un príncep del segle XV renuncia a Déu i es converteix en vampir. Segles més tard, al Londres del segle XIX, veu una dona semblant a la seva difunta esposa i la persegueix, segellant així el seu propi destí."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"}],"reviews_tmdb":[{"id":"688fd3f6fc7dfcfa2c261fc0","url":"https://www.themoviedb.org/review/688fd3f6fc7dfcfa2c261fc0","author":"MovieGuys","content":"I rather like the fact that Luc Besson has gone off and done his own thing, with \"Dracula\". \r\n\r\nThis film freshly blends fantasy, romance, action and a dash of horror. There are lots of creative, dramatic aspects to this story. Its Dracula writ-large. Where it falls down somewhat is its rather abrupt final scenes. There's no real build up, things just happen, leaving it feeling somewhat perfunctory. \r\n\r\nIn summary, this is a creative, elaborately cinematic take, on the Dracula myth, with lots of lavish, over the top trappings. Certainly worth a look.","created_at":"2025-08-03T21:26:14.850Z","updated_at":"2025-08-03T21:28:10.812Z","author_details":{"name":"","rating":7,"username":"MovieGuys","avatar_path":null}}],"recommendations":[{"id":1330435,"adult":false,"title":"Ghost Killer","video":false,"overview":"After being possessed by the ghost of vengeful hitman Kudo, college student Fumika Matsuoka agrees to help him finish his quest for revenge from beyond the grave.","genre_ids":[28,35,14],"media_type":"movie","popularity":1.6093,"vote_count":38,"poster_path":"/uKIG4f25QHUpBmBv0MPWOzKMGAM.jpg","release_date":"2025-04-11","vote_average":7.2,"backdrop_path":"/vgXjOkMhlGeeAlacqtyQwBkARdS.jpg","original_title":"ゴーストキラー","original_language":"ja"},{"id":325373,"adult":false,"title":"Two Lovers and a Bear","video":false,"overview":"Set in a small town near the North Pole where roads lead to nowhere, the story follows Roman and Lucy, two burning souls who come together to make a leap for life and inner peace.","genre_ids":[18,10749],"media_type":"movie","popularity":0.6215,"vote_count":78,"poster_path":"/q8anLL9m6ON7kTJ4Pbcuofls4gQ.jpg","release_date":"2016-10-02","vote_average":6.5,"backdrop_path":"/DRPH4RxU6dQqZUfATtJfCUyVJz.jpg","original_title":"Two Lovers and a Bear","original_language":"en"},{"id":381325,"adult":false,"title":"The Exorcism of Anna Ecklund","video":false,"overview":"When a Priest and a Vatican investigator take a possessed housewife to a convent to perform an Exorcism, all hell breaks loose....","genre_ids":[53,27],"media_type":"movie","popularity":1.2179,"vote_count":97,"poster_path":"/8oiVf0S6IFbi9gt6isVjMFVBo16.jpg","release_date":"2016-03-07","vote_average":3.49,"backdrop_path":"/2hovrozDQMFJTTk9LNc18y2c02U.jpg","original_title":"The Exorcism of Anna Ecklund","original_language":"en"},{"id":1452176,"adult":false,"title":"Abraham's Boys: A Dracula Story","video":false,"overview":"Max and Rudy Van Helsing have spent their lives under the strict and overprotective rule of their father, Abraham. Unaware of his dark past, they struggle to understand his paranoia and increasingly erratic behavior. But when they begin to uncover the violent truths behind their father’s history with Dracula, their world unravels, forcing them to confront the terrifying legacy they were never meant to inherit.","genre_ids":[27],"media_type":"movie","popularity":4.2568,"vote_count":35,"poster_path":"/owUZI7rRIN85TnXJY8gD9LdMiGU.jpg","release_date":"2025-07-11","vote_average":5.414,"backdrop_path":"/b0yK9BHyTNHGS6fBFLXBFtLC9AW.jpg","original_title":"Abraham's Boys: A Dracula Story","original_language":"en"},{"id":1086260,"adult":false,"title":"The Astronaut","video":false,"overview":"After returning from her first space mission, astronaut Sam Walker is placed under NASA’s care at a high security house for rehabilitation and medical testing. However, when disturbing occurrences begin happening around the property, she fears that something extraterrestrial has followed her back to Earth","genre_ids":[878,27,53],"media_type":"movie","popularity":15.8961,"vote_count":211,"poster_path":"/souvvkJHYhztC1UqZ8lEVUiJa3J.jpg","release_date":"2025-09-26","vote_average":5.827,"backdrop_path":"/3C01kAcKGR6FwsUUSOvJ8N82pqr.jpg","original_title":"The Astronaut","original_language":"en"},{"id":1428213,"adult":false,"title":"Kontrabida Academy","video":false,"overview":"When a mysterious TV transports her to a school for on-screen villains, a restaurant worker finds new purpose — and a way to get back at her enemies.","genre_ids":[35,14],"media_type":"movie","popularity":0.9001,"vote_count":20,"poster_path":"/uiW2ff73RZzPABKtnjW5wmt43CU.jpg","release_date":"2025-09-10","vote_average":7.1,"backdrop_path":"/oYPm2zk8fBxm3UBEiaWMzUGHeFW.jpg","original_title":"Kontrabida Academy","original_language":"tl"},{"id":153538,"adult":false,"title":"Tony Bennett: An American Classic","video":false,"overview":"A celebration of the life of musical icon Tony Bennett on the occasion of his 80th birthday. The special charts Bennett’s career by faithfully re-creating venues from his past. Bennett is joined for each number by the artists that collaborated with him on his Duets album.","genre_ids":[10402,99],"media_type":"movie","popularity":0.5584,"vote_count":7,"poster_path":"/latgR04TgRnJtAglzJXRjYA2Dh3.jpg","release_date":"2006-11-22","vote_average":7.714,"backdrop_path":"/9vuuYq1b7xQiWcnL9EpUr9Jg6sn.jpg","original_title":"Tony Bennett: An American Classic","original_language":"en"},{"id":848514,"adult":false,"title":"Big Font. Large Spacing","video":false,"overview":"Tells the story of a night in the life of two psychology students who find out that the term's major essay is due in the next morning.","genre_ids":[18,35],"media_type":"movie","popularity":0.0431,"vote_count":4,"poster_path":"/gEyaL5dC2Ci4QyM0qLPIoK3liyg.jpg","release_date":"2009-01-01","vote_average":6,"backdrop_path":"/5yO0fPiQGXbMgn11exAqUNkosm3.jpg","original_title":"Big Font. Large Spacing","original_language":"en"},{"id":1383247,"adult":false,"title":"Agent Zero","video":false,"overview":"When police officer Ilias is shot and left in a coma, Alma must reconnect with her former identity as Badh, a ruthless intelligence operative and skilled assassin. She brutally eliminates members of the Khoury family one by one, unleashing the fury of their leader Mansour, only to discover that Mansour is working with Joana, her former secret service unit officer.","genre_ids":[28,53],"media_type":"movie","popularity":5.2063,"vote_count":16,"poster_path":"/diDNHFfccBZxw0CmQoVQkSuJIri.jpg","release_date":"2025-08-06","vote_average":5.2,"backdrop_path":"/lkkWEkEb0v8NKAlBQ6xLyiap3DY.jpg","original_title":"Badh","original_language":"fr"},{"id":1494458,"adult":false,"title":"Anak Indië","video":false,"overview":"","genre_ids":[99],"media_type":"movie","popularity":0.1041,"vote_count":2,"poster_path":"/oUvl5LjYRQUaYSzN5GYs44TrddV.jpg","release_date":"2025-06-26","vote_average":5.75,"backdrop_path":"/vXo78yeDNwktbVjTosVYQaIF2Rr.jpg","original_title":"Anak Indië","original_language":"nl"},{"id":1151586,"adult":false,"title":"Pig Hill","video":false,"overview":"Carrie has been fascinated by the local legend of the pig people of Pig Hill, revolting creatures who breed and cause havoc in the area. As the tenth woman goes missing, Carrie can't stop thinking that there could be more to these stories.","genre_ids":[27,9648],"media_type":"movie","popularity":0.6172,"vote_count":7,"poster_path":"/rXRDLLApEqoXXbkM4SQcaVeApzN.jpg","release_date":"2025-08-23","vote_average":3.857,"backdrop_path":"/rqiE0Vo5u1T64eAeQGh9ga2Jax.jpg","original_title":"Pig Hill","original_language":"en"},{"id":453661,"adult":false,"title":"Las cinéphilas","video":false,"overview":"Six elderly retired women, two from Buenos Aires, Argentina; two from Montevideo, Uruguay; and two from Madrid, Spain, have something in common, despite their different interests and lives: they go to the movies almost every day.","genre_ids":[99],"media_type":"movie","popularity":0.402,"vote_count":11,"poster_path":"/7kwmVWso2ZtpljhKjFrIK3s4eU7.jpg","release_date":"2017-04-20","vote_average":6.182,"backdrop_path":"/wTJw2Jhz4MB6oJgSkuPGl2D8l8M.jpg","original_title":"Las cinéphilas","original_language":"es"},{"id":1149504,"adult":false,"title":"Honey Don't!","video":false,"overview":"Honey O'Donahue, a small-town private investigator, delves into a series of strange deaths tied to a mysterious church.","genre_ids":[35,80],"media_type":"movie","popularity":6.6011,"vote_count":315,"poster_path":"/fJm3kmd9NLZWypMas7g34oNFgbk.jpg","release_date":"2025-08-21","vote_average":5.7,"backdrop_path":"/cjhq1eBLXgKq1xHDFeUnYzu61H6.jpg","original_title":"Honey Don't!","original_language":"en"},{"id":1053993,"adult":false,"title":"The Wait","video":false,"overview":"Eladio, hunting estate keeper, takes a bribe from a veteran hunter. Weeks later, his whole life falls apart. What looked like the opportunity of a lifetime, turns into a macabre descent to hell when he finds out that his misfortune might not be entirely by chance.","genre_ids":[27,18,14],"media_type":"movie","popularity":0.4447,"vote_count":46,"poster_path":"/uPcqiq0SQwsWYoRSbGDgtSN1gxD.jpg","release_date":"2023-12-15","vote_average":6,"backdrop_path":"/6HNjWuipxqHFOkN3GLw5VCQlGIC.jpg","original_title":"La espera","original_language":"es"},{"id":320846,"adult":false,"title":"Sky Sharks","video":false,"overview":"A team of Arctic geologists stumble across an abandoned laboratory in which the Nazis developed an incredible and brutal secret weapon during the final months of WW2. Deep in the ice, they accidentally awake a deadly army of flying zombie sharks ridden by genetically mutated, undead super-humans, who are unleashed into the skies, wreaking their bloodthirsty revenge on any aircraft that takes to the air. An elite task force is assembled to take on this deadly threat and stop the Sky Sharks from conquering the air, but as time runs out, the task force realises they will have to fight fire with fire, and the stage is set for the greatest flying super-mutant zombie shark air battle the world has ever seen....","genre_ids":[27,878,35],"media_type":"movie","popularity":0.8727,"vote_count":114,"poster_path":"/ihkbceq6vQlEVaIvHTu2tM6z0Do.jpg","release_date":"2020-10-07","vote_average":4.89,"backdrop_path":"/wKAidKCypwuxtZfZ4iP584PsWXV.jpg","original_title":"Sky Sharks","original_language":"de"},{"id":18843,"adult":false,"title":"Dr. Dolittle 3","video":false,"overview":"Lisa Dolittle sends her daughter to 'Durango', a Dude Ranch, to find herself. While there, she uses her talent to talk to the animals in order to save Durango from being taken over by a neighboring Ranch.","genre_ids":[35,10751,14],"media_type":"movie","popularity":1.3138,"vote_count":473,"poster_path":"/i4xF1guNryvrUZzjosHui5vpsKc.jpg","release_date":"2006-04-25","vote_average":5.1,"backdrop_path":"/qf7fKQbdrwnQPPdLTTahUF2ETcC.jpg","original_title":"Dr. Dolittle 3","original_language":"en"},{"id":454615,"adult":false,"title":"Black Water","video":false,"overview":"A deep cover operative awakens to find himself imprisoned on a submarine. With the help of a fellow prisoner and an amateur agent, he must race against the clock to escape the vessel and expose who set him up.","genre_ids":[28,53],"media_type":"movie","popularity":1.6415,"vote_count":270,"poster_path":"/tIcZAB5AmRN8fIDXfDZ2aUok9qa.jpg","release_date":"2018-05-18","vote_average":5.6,"backdrop_path":"/noNMHp461qETqftTGRC4xJtJ8Pf.jpg","original_title":"Black Water","original_language":"en"},{"id":913823,"adult":false,"title":"Fire of Love","video":false,"overview":"A doomed love triangle between intrepid French scientists Katia and Maurice Krafft, and their beloved volcanoes.","genre_ids":[99],"media_type":"movie","popularity":1.3339,"vote_count":238,"poster_path":"/9smEX8UP84yb2GisLwyAyQKvCWS.jpg","release_date":"2022-07-06","vote_average":7.54,"backdrop_path":"/3oRwn7WIMt4Vtw65mnydDQHthwQ.jpg","original_title":"Fire of Love","original_language":"en"},{"id":1242011,"adult":false,"title":"Together","video":false,"overview":"Years into their relationship, Tim and Millie find themselves at a crossroads as they move to the country, abandoning all that is familiar in their lives except each other. With tensions already flaring, a nightmarish encounter with a mysterious, unnatural force threatens to corrupt their lives, their love, and their flesh.","genre_ids":[27,10749],"media_type":"movie","popularity":11.1616,"vote_count":945,"poster_path":"/80slKYVM5teFH3kz6ouWrZXveqj.jpg","release_date":"2025-07-28","vote_average":6.992,"backdrop_path":"/39Niij05MXfibXBsHiUU0Ml0POX.jpg","original_title":"Together","original_language":"en"},{"id":1257009,"adult":false,"title":"Primitive War","video":false,"overview":"During the Vietnam War, a recon unit ventures to an isolated jungle valley to uncover the fate of a missing platoon. They soon find themselves in a fight for their lives against an unexpected enemy — prehistoric dinosaurs.","genre_ids":[28,27,10752,878],"media_type":"movie","popularity":13.9328,"vote_count":235,"poster_path":"/fZnY97zAyATRH50Q1I92fQy1hUg.jpg","release_date":"2025-08-21","vote_average":6.645,"backdrop_path":"/bWF5ImUscXXYia8owpm8coadR4m.jpg","original_title":"Primitive War","original_language":"en"}],"similar_content":[{"id":48709,"adult":false,"title":"My Man","video":false,"overview":"In Lyon, where many are unemployed, Marie is a prostitute who loves her work: she's thoughtful and exuberant toward clients old and young, slim or flabby. One night, a homeless man sleeps in the foyer of her apartment house; she gives him a hot meal, then a place on the floor to sleep by her radiator, then she offers herself. She falls in love, giving him new life, clothes, a place to live. When he grouses that he must bar hop while she uses the flat for her work, she finds them a larger flat. He grows restless, seducing a manicurist and pressing her to prostitution. He's arrested for procuring, so Marie must decide what to do; he, too, must face the consequences of his choices.","genre_ids":[10749,35,18],"popularity":0.7621,"vote_count":42,"poster_path":"/A2vNKPMD1JnsgOV0Adimhd9vIPA.jpg","release_date":"1996-01-31","vote_average":5.655,"backdrop_path":"/8mk1w1friPH3yEWrIPivk1XMIf9.jpg","original_title":"Mon homme","original_language":"fr"},{"id":48584,"adult":false,"title":"Spermula","video":false,"overview":"The story is based around \"spermulites\", the alien inhabitants of a dying planet. The only way they can save their planet is by sucking the men of planet earth dry of sperm, kind of like horny vampires.","genre_ids":[27,878],"popularity":0.9017,"vote_count":29,"poster_path":"/i6Ukxf2KsDM2mkpp1kyTPwfXAgV.jpg","release_date":"1976-07-07","vote_average":4.086,"backdrop_path":"/uuDoM1YmMgnulFsM8Jr3eo861m9.jpg","original_title":"Spermula","original_language":"fr"},{"id":48547,"adult":false,"title":"The Restoration","video":false,"overview":"This film recounts how Joseph Smith's search for truth led to a heavenly vision and the restoration of the gospel of Jesus Christ.","genre_ids":[18,10749,10751],"popularity":0.1859,"vote_count":3,"poster_path":"/bIQ9xt6yaf5h4o45nY9CgZS6JOx.jpg","release_date":"2004-06-01","vote_average":5.7,"backdrop_path":null,"original_title":"The Restoration","original_language":"en"},{"id":49017,"adult":false,"title":"Dracula Untold","video":false,"overview":"Vlad Tepes is a great hero, but when he learns the Sultan is preparing for battle and needs to form an army of 1,000 boys, he vows to find a way to protect his family. Vlad turns to dark forces in order to get the power to destroy his enemies and agrees to go from hero to monster as he's turned into the mythological vampire, Dracula.","genre_ids":[27,28,14],"popularity":3.415,"vote_count":6415,"poster_path":"/m5h3NtZ2ZfryIHl1MvatmANvIqQ.jpg","release_date":"2014-10-01","vote_average":6.5,"backdrop_path":"/oa0bHsnrD96miW3Yx10HWb211Sj.jpg","original_title":"Dracula Untold","original_language":"en"},{"id":48837,"adult":false,"title":"Midnight Son","video":false,"overview":"MIDNIGHT SON is the story of Jacob, a young man confined to a life of isolation, due to a rare skin disorder that prevents him from being exposed to sunlight. His world opens up when he meets Mary, a local bartender, and falls in love. Tragically, Jacob’s actions become increasingly bizarre as he struggles to cope with the effects of his worsening condition. Forced by the disease to drink human blood for sustenance, he must control his increasingly violent tendencies as local law enforcement narrow their focus on him as a suspect in a series of grisly murders.","genre_ids":[18,27],"popularity":0.4149,"vote_count":51,"poster_path":"/xwVaMTmE0qzKRQMzvvwZY1vBEBm.jpg","release_date":"2011-03-04","vote_average":5.7,"backdrop_path":"/2ABWCoX2kF6jdinOBADC30XtA7z.jpg","original_title":"Midnight Son","original_language":"en"},{"id":49391,"adult":false,"title":"From Time to Time","video":false,"overview":"A haunting ghost story spanning two worlds, two centuries apart. When 13 year old Tolly finds he can mysteriously travel between the two, he begins an adventure that unlocks family secrets laid buried for generations.","genre_ids":[12,14,18],"popularity":0.7566,"vote_count":114,"poster_path":"/4qVw09ZMpyXWsHt1odiFzdAPCFB.jpg","release_date":"2009-10-15","vote_average":6.3,"backdrop_path":"/mhBAhE2Nam28Wl32fKe9Xaln9p9.jpg","original_title":"From Time to Time","original_language":"en"},{"id":1298355,"adult":false,"title":"Nocturno der Liebe","video":false,"overview":"","genre_ids":[18,10749],"popularity":0.1757,"vote_count":0,"poster_path":null,"release_date":"1919-01-01","vote_average":0,"backdrop_path":null,"original_title":"Nocturno der Liebe","original_language":"de"},{"id":49130,"adult":false,"title":"Web of the Spider","video":false,"overview":"Alan Foster, a professional American journalist, travels to London to meet with Edgar Allan Poe for an interview. While in London, Alan soon finds himself in the company of Lord Blackwood, and Alan accepts a bet to spend a night in his castle","genre_ids":[27],"popularity":0.294,"vote_count":35,"poster_path":"/1FBfPu9jSdSBw0ZarW9UFeP9BvU.jpg","release_date":"1971-08-26","vote_average":5.671,"backdrop_path":"/jpi8Q7HCZTT5PdB3HMhw4G0XZIR.jpg","original_title":"Nella stretta morsa del ragno","original_language":"it"},{"id":707103,"adult":false,"title":"Emily","video":false,"overview":"The imagined life of one of the world’s most famous authors, Emily Brontë, as she finds her voice and writes the literary classic Wuthering Heights. Explore the relationships that inspired her – her raw, passionate sisterhood with Charlotte and Anne; her first aching, forbidden love for Weightman and her care for her maverick brother whom she idolises.","genre_ids":[36,18,10749],"popularity":4.5357,"vote_count":244,"poster_path":"/tgVBMIiJczfBWINRRd9yxE8ESln.jpg","release_date":"2022-10-14","vote_average":6.875,"backdrop_path":"/7DrLrDf3vVVjgOGRUf37knUu7Rx.jpg","original_title":"Emily","original_language":"en"},{"id":706693,"adult":false,"title":"Timestalker","video":false,"overview":"Hapless Agnes repeatedly falls for the wrong guy, dies a grim death, and is reincarnated a century later. As she experiences romantic misfortune spanning various eras, Agnes aims to avoid repeat mistakes and finally break the cycle.","genre_ids":[878,10749,14,35],"popularity":3.026,"vote_count":33,"poster_path":"/gUIBW4NKSFQ2GiJLLULDmtHT21.jpg","release_date":"2024-10-11","vote_average":5.288,"backdrop_path":"/k2vb1fl7j2mqGYpX8JKaCVmQWrN.jpg","original_title":"Timestalker","original_language":"en"},{"id":33156,"adult":false,"title":"Blood on the Highway","video":false,"overview":"On their way to a rock concert, Carrie, her boyfriend Sam, and Bone, her thug ex-boyfriend, get lost and wind up in Fate, Texas – a town populated by bloodthirsty, dimwitted vampires. Featuring genre favorites Nicholas Brendon and Tom Towles.","genre_ids":[35,27],"popularity":0.3864,"vote_count":15,"poster_path":"/aDvZvF9F17512wfiQ4ZxeUOVBOB.jpg","release_date":"2008-01-01","vote_average":3.9,"backdrop_path":null,"original_title":"Blood on the Highway","original_language":"en"},{"id":33218,"adult":false,"title":"Daddy Long Legs","video":false,"overview":"Wealthy American, Jervis Pendleton has a chance encounter at a French orphanage with a cheerful 18-year-old resident, and anonymously pays for her education at a New England college. She writes letters to her mysterious benefactor regularly, but he never writes back. Several years later, he visits her at school, while still concealing his identity, and—despite their large age difference—they soon fall in love.","genre_ids":[10402,10749],"popularity":0.5652,"vote_count":92,"poster_path":"/2Tt12RPDJP4KnepYsJ4hrEQS7El.jpg","release_date":"1955-05-05","vote_average":6.4,"backdrop_path":"/bM1LjObzhzqSnt1BR3ev7WO7kpz.jpg","original_title":"Daddy Long Legs","original_language":"en"},{"id":298663,"adult":false,"title":"Sweeney Todd: The Demon Barber of Fleet Street","video":false,"overview":"In 1846, Anthony Hope sails into London with the mysterious Sweeney Todd, a once-naive barber whose life and marriage was uprooted by a corrupt justice system. Todd confides in Nellie Lovett, the owner of a local meat pie shop, and the two become partners, as Todd swears revenge on those that have wronged him and decides to take up his old profession.","genre_ids":[27,53,18,10402,10770],"popularity":0.3307,"vote_count":7,"poster_path":"/2J2jjuty7fnnrvnCURlKBzRiRMA.jpg","release_date":"2014-09-26","vote_average":8.1,"backdrop_path":"/o3OE73OIO0hJvRJBHMKEBX0MMw6.jpg","original_title":"Sweeney Todd: The Demon Barber of Fleet Street","original_language":"en"},{"id":298833,"adult":false,"title":"Blood Ransom","video":false,"overview":"Crystal, the girlfriend of Roman, Jeremiah's American boss whom he kidnaps. As Jeremiah's plans fail, Roman sends Bill, a psychopathic hitman after them. Crystal and Jeremiah tread the dangerous path of a love on the run. But as they run farther and as they fall deeper, a dark secret burns even stronger.","genre_ids":[10749,14,27],"popularity":0.3889,"vote_count":13,"poster_path":"/kXJHlw7iRzQP6fnZItHVPbHVxLW.jpg","release_date":"2014-10-31","vote_average":5,"backdrop_path":"/cgZGbPpfaw8BMZG5CHDGTZ7iAeh.jpg","original_title":"Blood Ransom","original_language":"en"},{"id":33491,"adult":false,"title":"Venus Beauty Institute","video":false,"overview":"Aging beautician Angèle, already wounded by a long-ago romance, gets awkwardly dumped at a train station. Witnessing how she turns around a humiliating situation, younger sculptor Antoine becomes so smitten that he breaks up with his fiancée and sets out to win Angèle's heart. Meanwhile, Angèle attempts to quash the budding romance of her young co-worker, Marie, and a much older widowed client, despite their obvious rapport.","genre_ids":[35,18,10749],"popularity":0.5862,"vote_count":128,"poster_path":"/nQIv4yTGmjk3ZLnK9CWUiIu66R1.jpg","release_date":"1999-02-03","vote_average":5.8,"backdrop_path":"/5bM4eG1c3hSsyb7aBpmeKzF9htS.jpg","original_title":"Vénus beauté (institut)","original_language":"fr"},{"id":33521,"adult":false,"title":"Dracula","video":false,"overview":"Romanticized adaptation of Bram Stoker's 1897 classic. Count Dracula is a subject of fatal attraction to more than one English maiden lady, as he seeks an immortal bride.","genre_ids":[27,10749,14],"popularity":1.1601,"vote_count":280,"poster_path":"/gU0BMydJQV9HES5fRAEAPs2qw2M.jpg","release_date":"1979-07-20","vote_average":6.364,"backdrop_path":"/9aDnMjUHhfX0WaCicEaejdKgvlV.jpg","original_title":"Dracula","original_language":"en"},{"id":36213,"adult":false,"title":"Reign of the Gargoyles","video":false,"overview":"During World War 2 a group of brave US Airmen are downed in Nazi controlled Europe, after their aircraft is attacked by Nazi-controlled mythological Gargoyles.","genre_ids":[28,12,14],"popularity":0.4152,"vote_count":18,"poster_path":"/7yh6GEQY8IeG7wVvUbS5285c59y.jpg","release_date":"2007-03-24","vote_average":5.9,"backdrop_path":"/lgHJIPG8XKm8SCcOuT3K27xtw4U.jpg","original_title":"Reign of the Gargoyles","original_language":"en"},{"id":888097,"adult":false,"title":"Slayers","video":false,"overview":"A group of superstar influencers are drawn to a reclusive billionaire's mansion only to find themselves trapped in the lair of an evil vampire. The only way out is to be saved by a famous online gamer and an old school vampire hunter.","genre_ids":[27,35,14],"popularity":4.0434,"vote_count":90,"poster_path":"/1dgNc7FB5RMm6w4D6S0UpZhsUbW.jpg","release_date":"2022-10-21","vote_average":4.006,"backdrop_path":"/nKdCl2roOng0DiLRgk4W3P4RTSi.jpg","original_title":"Slayers","original_language":"en"},{"id":36421,"adult":false,"title":"Howling VI: The Freaks","video":false,"overview":"A villainous carnival owner traps a young werewolf to include in his growing menagerie of inhuman exhibits.","genre_ids":[27],"popularity":0.5462,"vote_count"