I5cq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1200,"height":1600,"file_path":"/lqPTPbOcdGDI0GMbLPo5szJaWBi.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":0.75,"vote_average":0},{"width":1000,"height":1333,"file_path":"/A5YlBSwH7kSuvhd79Fy3jqSslgO.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.75,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/7sRhA4MFBpbSg76gWyLFppT451u.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T03:28:07.784+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":81,"tagline":"They're Here.","homepage":"http://occupantsthemovie.com/","overview":"A documentarian named Annie has roped her husband into a project that involves setting up cameras throughout their house. Complications arise when the cameras start showing that same couple in an alternate universe."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Habitantes - Eles Estão Aqui","runtime":81,"tagline":"","homepage":"","overview":"Um jovem casal, Annie e Neil Curtis, planeja realizar um documentário sobre seu modo de vida e instala câmeras por toda sua casa. Durante o processo de gravação, o equipamento capta algo que eles não esperavam."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":90,"tagline":"","homepage":"","overview":"Una documentalista llamada Annie ha rodeado a su marido con un proyecto que consiste en instalar cámaras en toda su casa. Las complicaciones surgen cuando las cámaras comienzan a mostrar a esa misma pareja, en un universo alternativo."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"알.이.씨 오큐펀트","runtime":0,"tagline":"누군가 지켜보고 있다","homepage":"","overview":"다큐멘터리 작가 애니는 작품을 위해 남편을 설득해 집안 전체에 카메라를 설치한다. 카메라에 대체우주 속 그들과 똑같은 커플을 보여주며 문제가 시작된다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"}],"reviews_tmdb":[{"id":"58210c0c9251417cd80013b6","url":"https://www.themoviedb.org/review/58210c0c9251417cd80013b6","author":"Simon Foster","content":"\"He’s probably scratching his head at the protagonist’s home-tech set-up, but somewhere Rod Serling is also smiling warmly that his legacy is embraced with such skill and affection...\"\r\n\r\nRead the full review here: http://screen-space.squarespace.com/reviews/2016/11/8/occupants.html","created_at":"2016-11-07T23:19:40.578Z","updated_at":"2021-06-23T15:57:51.959Z","author_details":{"name":"Simon Foster","rating":8,"username":"Simon Foster","avatar_path":null}}],"recommendations":[{"id":359749,"adult":false,"title":"78/52","video":false,"overview":"The most famous murder scene in movie history comprises 78 camera settings and 52 cuts: the shower scene in Alfred Hitchcock's Psycho. 78/52 tells the story of the man behind the curtain and his greatest obsession.","genre_ids":[99],"media_type":"movie","popularity":0.5673,"vote_count":144,"poster_path":"/mJb3OTY0rc4dTUStQnxSeRacsTV.jpg","release_date":"2017-10-13","vote_average":7.2,"backdrop_path":"/4WGqXK1FHXKWlDXNkYlhWJmj6ME.jpg","original_title":"78/52","original_language":"en"},{"id":129705,"adult":false,"title":"Gonzaga: From Father to Son","video":false,"overview":"Luiz Gonzaga decides to change his destiny and leaves his childhood home for the big city to overcome a romance. When he arrives, he meets a woman he falls in love with, the Odaleia (Nanda Costa). After the birth of his son and his wife's health complications, he decides to return to the road to ensure a better future for his son. He has a friend in Rio de Janeiro and with him leaves the little one and heads to Brazil.  He didn't imagine that this distance between them would develop into a complicated relationship, enhanced by the strong personalities of both. Based on conversations between father and son, this is the story of Luiz Gonzaga, a singer and accordion player known as Rei do Baião or Gonzagão.","genre_ids":[18,36,10402],"media_type":"movie","popularity":0.1442,"vote_count":98,"poster_path":"/8LRWQiq43cIc03sC5ZLGB8zYrjU.jpg","release_date":"2012-10-26","vote_average":7.2,"backdrop_path":"/zBFEeQtRUeJ0884IE8nipEv4bhu.jpg","original_title":"Gonzaga: De Pai pra Filho","original_language":"pt"},{"id":428948,"adult":false,"title":"Infinity Chamber","video":false,"overview":"A man trapped in an automated prison must outsmart a computer in order to escape and try and find his way back to the outside world that may already be wiped out.","genre_ids":[878,9648,53],"media_type":"movie","popularity":1.3569,"vote_count":272,"poster_path":"/zaYlG8wZ4DN3Kevnov39u3PjOfh.jpg","release_date":"2016-12-03","vote_average":6.27,"backdrop_path":"/iYXLgv5NjRn00nyYahnkdaXCm6M.jpg","original_title":"Infinity Chamber","original_language":"en"},{"id":12623,"adult":false,"title":"Suspect","video":false,"overview":"When a Supreme Court judge commits suicide and his secretary is found murdered, all fingers point to Carl Anderson, a homeless veteran who's deaf and mute. But when public defender Kathleen Riley is assigned to his case, she begins to believe that Anderson may actually be innocent. Juror Eddie Sanger, a Washington lobbyist, agrees, and together the pair begins their own investigation of events.","genre_ids":[80,18,53],"media_type":"movie","popularity":1.4877,"vote_count":242,"poster_path":"/hL79lrrMgRZO21otWbTTiljufeU.jpg","release_date":"1987-10-23","vote_average":6.6,"backdrop_path":"/b2vMEdoIYcySuE5a5y1xe643zAI.jpg","original_title":"Suspect","original_language":"en"},{"id":145932,"adult":false,"title":"The Penitent Man","video":false,"overview":"The Penitent Man tells the story of psychologist Dr. Jason Pyatt, a man devoted to his work - a man torn from his family. With his struggling marriage and mounting bills, Jason is at a crossroads with the life he has chosen and the life he could have. When one of his clients - the mysterious Mr. Darnell - walks into his office and paints him a repentant tale of future economic and moral collapse, Jason's eyes are forever opened. With the help of his best friend Ovid, he embarks on a personal mission to change the course of his future, and possibly the world, forever.","genre_ids":[18,878],"media_type":"movie","popularity":0.1241,"vote_count":23,"poster_path":"/kHalOdvyHg1DEmKdTw6hgXCDHV5.jpg","release_date":"2010-03-29","vote_average":5.565,"backdrop_path":"/p6xIsQWUjlYDhugV9tYdfSil5cw.jpg","original_title":"The Penitent Man","original_language":"en"},{"id":467228,"adult":false,"title":"The Devil's Toy Box","video":false,"overview":"Cynthia O'Neil enters a haunted asylum known as the Madison Seminary in search of her father who went missing in the asylum while shooting a reality television show.","genre_ids":[27],"media_type":"movie","popularity":0.1057,"vote_count":9,"poster_path":"/uwYjDI8wwWXJ2rwYfASaESZulpT.jpg","release_date":"2017-01-16","vote_average":5.2,"backdrop_path":"/vMzcYIXDrw9R1BjZkPLl4M60CA5.jpg","original_title":"The Devil's Toy Box","original_language":"en"},{"id":440597,"adult":false,"title":"Wish Upon","video":false,"overview":"A teenage girl discovers a box with magical powers, but those powers comes with a deadly price.","genre_ids":[27,53,14],"media_type":"movie","popularity":1.6813,"vote_count":1449,"poster_path":"/u0vnocj57vJt5DHoBEqUOD1G4SU.jpg","release_date":"2017-07-07","vote_average":5.73,"backdrop_path":"/rYpOaLb908aDspCuaa1o7nn5Bf.jpg","original_title":"Wish Upon","original_language":"en"},{"id":16871,"adult":false,"title":"Drag Me to Hell","video":false,"overview":"After denying a woman the extension she needs to keep her home, loan officer Christine Brown sees her once-promising life take a startling turn for the worse. Christine is convinced she's been cursed by a Gypsy, but her boyfriend is skeptical. Her only hope seems to lie in a psychic who claims he can help her lift the curse and keep her soul from being dragged straight to hell.","genre_ids":[27,53],"media_type":"movie","popularity":4.2067,"vote_count":3990,"poster_path":"/fdyejM5Zd6dsa0YyWa02ZAKwQzK.jpg","release_date":"2009-05-27","vote_average":6.466,"backdrop_path":"/3tvwsRSIDgwJuaGdh67XZ942UMy.jpg","original_title":"Drag Me to Hell","original_language":"en"},{"id":76341,"adult":false,"title":"Mad Max: Fury Road","video":false,"overview":"An apocalyptic story set in the furthest reaches of our planet, in a stark desert landscape where humanity is broken, and most everyone is crazed fighting for the necessities of life. Within this world exist two rebels on the run who just might be able to restore order.","genre_ids":[28,12,878],"media_type":"movie","popularity":14.286,"vote_count":23777,"poster_path":"/hA2ple9q4qnwxp3hKVNhroipsir.jpg","release_date":"2015-05-13","vote_average":7.629,"backdrop_path":"/l0eIS009XtEO80aC6zjM3o3AkEl.jpg","original_title":"Mad Max: Fury Road","original_language":"en"},{"id":791373,"adult":false,"title":"Zack Snyder's Justice League","video":false,"overview":"Determined to ensure Superman's ultimate sacrifice was not in vain, Bruce Wayne aligns forces with Diana Prince with plans to recruit a team of metahumans to protect the world from an approaching threat of catastrophic proportions.","genre_ids":[28,12,14],"media_type":"movie","popularity":9.4916,"vote_count":10644,"poster_path":"/tnAuB8q5vv7Ax9UAEje5Xi4BXik.jpg","release_date":"2021-03-18","vote_average":8.096,"backdrop_path":"/13Nz8EchKRdCgJcKdEoJAnpiVn2.jpg","original_title":"Zack Snyder's Justice League","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":19.7563,"vote_count":11390,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg",