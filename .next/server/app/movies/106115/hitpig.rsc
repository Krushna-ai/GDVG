,{"width":1000,"height":1500,"file_path":"/dQCuullqvXMeOqdt9wpXEGgetja.jpg","iso_639_1":"he","vote_average":3.334},{"width":1080,"height":1620,"file_path":"/mI1qlNfeb2sl4kOi0kJgbKuX8YU.jpg","iso_639_1":null,"vote_average":3.334},{"width":2000,"height":3000,"file_path":"/tEpL23MRZGB4nlqeSushk0bIHLg.jpg","iso_639_1":"es","vote_average":3.334},{"width":1398,"height":2048,"file_path":"/tCIzCqlA95TNFLxWbMy06SuDBHR.jpg","iso_639_1":"pt","vote_average":3.334},{"width":1000,"height":1483,"file_path":"/8rLzJ6u1Prjt66wgW9GleHIztG9.jpg","iso_639_1":"en","vote_average":0},{"width":1000,"height":1483,"file_path":"/kCAEdk8cVVsNC4PsSRnqMOgpq1t.jpg","iso_639_1":"en","vote_average":0},{"width":1000,"height":1426,"file_path":"/4jqVyEeeK2zHQ0na1UrRZdWPDNw.jpg","iso_639_1":"en","vote_average":0},{"width":1000,"height":1426,"file_path":"/7qPNUBnc56kTpviyHlnEizNeKVr.jpg","iso_639_1":null,"vote_average":0},{"width":1000,"height":1500,"file_path":"/y78H4N34A8acFi9rPY30LZ83D20.jpg","iso_639_1":"en","vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/leobhCk6L86BEBnx1t6URQcIdQW.jpg","iso_639_1":null,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/ownr1JeuYB4Xnlcl2la88c3CE3z.jpg","iso_639_1":null,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/9428rjezwHsYPBR68JAzr7xokrp.jpg","iso_639_1":null,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/6QQlQLxlLh7IQXU4Wh0LaoJiARh.jpg","iso_639_1":"en","vote_average":0},{"width":1280,"height":720,"file_path":"/lciBgz6mRl5AbwzNyN8SD4di7DC.jpg","iso_639_1":"en","vote_average":0},{"width":1331,"height":748,"file_path":"/uRFUI3i6uySylNAKUPnO49UIpSc.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/z75c10w5tVc2aF39dYlN311Xfbf.jpg","iso_639_1":"sk","vote_average":0},{"width":1920,"height":1080,"file_path":"/f7rvDFJicDxiyIlzl1CamwWAPzm.jpg","iso_639_1":null,"vote_average":0},{"width":2120,"height":1192,"file_path":"/82FXkdqZdNwLGQYbHrndf7rse8w.jpg","iso_639_1":"pl","vote_average":0},{"width":1920,"height":1080,"file_path":"/gIATDvtCmFS0feznh4U6XwCdVqv.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T06:22:57.664+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":85,"tagline":"When you’re on the lam, they call the ham.","homepage":"","overview":"A porcine bounty hunter accepts his next hit: Pickles, a naive, ebullient elephant. Though he initially sets out to capture the perky pachyderm, the unlikely pair find themselves crisscrossing the globe on an adventure that brings out the best in both of them."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Super agente Hitpig","runtime":0,"tagline":"","homepage":"","overview":"HITPIG es un cerdo contratado por humanos para traer de vuelta a sus animales escapados.  No es fácil, pero es una vida! Su último éxito es Pickles, un  elefante ingenuo pero vivaz que ha escapado de las garras de un malvado showman de Las Vegas. Aunque HITPIG inicialmente se propone capturar al alegre paquidermo por mucho dinero, la extraña pareja se encuentra en una aventura inesperada que recorre el mundo y saca lo mejor de ambos. Ambientado en un mundo cyberpunk futurista, HITPIG demuestra que a veces lo que queremos no es lo que necesitamos."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":86,"tagline":"","homepage":"","overview":"Hitpig est un cochon futé qui gagne sa vie en capturant des animaux en cavale afin de les ramener à leur maître. Son prochain contrat risque cependant d’être son plus grand défi : il devra retourner l’éléphante dansante Miss Pickle à un machiavélique promoteur de Las Vegas, pour un million de dollars. Alors que sa mission dérape, Hitpig réalise que tout l’argent du monde ne pourra remplacer ses nouvelles amitiés"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Зверопоиск","runtime":86,"tagline":"","homepage":"","overview":"Охотник за головами по Кабан отправляется на поиски Слона, за которого назначена крупная награда. Но всё идёт не по плану — вместо того чтобы поймать свою добычу, Кабан отправляется в путешествии по всему миру вместе с этим свободолюбивым слоном."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"赏金猎猪","runtime":0,"tagline":"","homepage":"","overview":"一只被人类雇佣去抓捕那些逃亡动物的猪。在追捕一只从一个邪恶马戏团逃亡的大象时，与大象陷入了一场全球冒险之中，他的观念慢慢的被改变。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":86,"tagline":"De G.O.A.T. is een VARKEN!","homepage":"","overview":"Wat doe je als je huisdier ontsnapt? Of als, zoals in het geval van twee kerntechneuten, je bunzing ervandoor gaat? Dan bel je Hitpig! Hitpig is een varken dat gespecialiseerd is in het opsporen van ontsnapte dieren. Voor hem is het een job als elke andere—niet altijd makkelijk, maar het betaalt de rekeningen. Maar het loopt uit de hand wanneer hij op zoek moet naar de rebelse olifant Pukkie die ontsnapt is uit de klauwen van een beruchte showman uit Las Vegas. Gelukkig krijgt hij hulp van de energieke SuperHaan. Samen belanden ze in een avontuur vol onverwachte wendingen, vriendschap en de ontdekking dat wat je zoekt, niet altijd is wat je nodig hebt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"Quando você está foragido, eles chamam o presunto.","homepage":"","overview":"Um caçador de recompensas suíno aceita seu próximo alvo: Pickles, um elefante ingênuo e efervescente. Embora ele inicialmente tenha a intenção de capturar o paquiderme alegre, a dupla improvável se encontra cruzando o globo em uma aventura que traz à tona o melhor de ambos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Un cacciatore di taglie suino accetta la sua prossima vittima: Pickles, un elefante ingenuo ed esuberante. Sebbene inizialmente si prefigga di catturare il vivace pachiderma, l'improbabile coppia si ritrova ad attraversare il globo in un'avventura che tira fuori il meglio di entrambi."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Elefántos kaland","runtime":86,"tagline":"","homepage":"","overview":"Röff Ász utolérhetetlen fejvadász, aki képes előkeríteni bármilyen eltűnt állatot. Fő feladata, hogy az elveszett háziállatokat visszajuttassa a gazdáiknak. A malac nyomozó egy nap különleges megbízatást kap: egy elefántot kell felkutatnia. Röff Ász hamarosan rá is talál a szabadelvű elefántra, s kezdetét veszi kettejük világkörüli kalandja, amely során a páratlan páros életre szóló barátságot köt."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Hitpig!","runtime":0,"tagline":"NAJBOLJI u pronalaženju izgubljenih životinja je SVINJA","homepage":"","overview":"Kada vaša maca napusti grad, magarac je na slobodi, a krava kaže ciao, trebate pozvati Hitpiga! On je svinja i lovac na glave koji zarađuje hvatajući pobjegle životinje koje vraća njihovim vlasnicima. Vratio je smrdljivog tvora u opasan laboratorij, borbenu koalu u zoološki vrt prepun djece, i ljubaznog raka u kulinarsku emisiju. Hitpigov sljedeći zadatak je njegov najveći dosad: za milijun dolara treba vratiti plesnog slona maničnom showmanu iz Vegasa. No, ono što je trebalo biti lako zarađeni novac ubrzo se pretvara u kaos. Hitpig i slon kreću u divlju avanturu oko svijeta, a Hitpig se mora suočiti s moralnim dilema – treba li nastaviti loviti za novac ili osloboditi svog novog prijatelja?"},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"ХітПіг. Розшук домашніх тварин","runtime":100,"tagline":"","homepage":"","overview":"ХітПіг - найкрутіший у бізнесі. Бізнесі з розшуку домашніх тварин. Аж поки до нього не звертається приватний бізнесмен, в якого зникла… слониха! Ось такого виклику все життя чекав ХітПіг, найкрутіший у бізнесі з розшуку домашніх тварин"},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Agentas Hitpigas!","runtime":86,"tagline":"","homepage":"","overview":"Jei šarangė susirangė, o šepetys kaip repetys, jei kas žiba kaip žaltys – laikas kviesti jį: agentą Hitpigą! Šis ypatingos knyslės savininkas, tituluojamas geriausiu premijų medžiotoju, gauna milijono vertą užduotį: sugrąžinti šeimininkui pabėgusią… dramblę! Tačiau lengvas darbelis greitai pavirsta tikra kiaulyste – dramblė pasirodo esanti vaikščiojanti nelaimė, o jos šeimininkas – pikčiausias blogiukas. Dabar Hitpigui teks apsispręsti: ar verta siekti šlovės ir pripažinimo, ar svarbiausias atlygis yra nuoširdi draugystė, atrasta nuotykyje?"},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Hitpig! Świniak zawodowiec","runtime":85,"tagline":"Gdy zwierz ci zaginie, lepiej wezwij świnię!","homepage":"","overview":"Łowca nagród świni przyjmuje swój kolejny cel: Picklesa, naiwnego, pełnego życia słonia. Chociaż początkowo postanawia schwytać wesołego gruboskórego, ta nieprawdopodobna para krzyżuje się na całym świecie w przygodzie, która wydobywa z nich to, co najlepsze."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Searahakütt","runtime":0,"tagline":"","homepage":"","overview":"Kui tsirkusest kaob tantsiv elevant Kurgike ning tsirkuse juht pakub Searahakütile miljonit, siis arvab nutikas siga, et on saanud elu võimaluse väikese vaevaga sisse kasseerida elu suurim noos. Kuid Kurgikest kohates avastab Searahakütt, et veidi naiivne ja heatahtlik elevant ei soovi üldse tsirkusesse naasta ning tagasitee jooksul peab ta otsustama, mis on tähtsam, kas üks patakas raha või tõeline sõprus."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"Skotgrís!","runtime":0,"tagline":"","homepage":"","overview":"Mannaveiðarasvín tekur að sér nýtt verkefni: Pickles, barnalegan og eldfjörugan fíl. Þó að hann ætli upphaflega að fanga hinn hressilega þykkskinnung, þá enda þeir með því að þvælast um heiminn í ævintýri sem kallar fram það besta í þeim báðum."},"name":"Íslenska","iso_639_1":"is","iso_3166_1":"IS","english_name":"Icelandic"},{"data":{"title":"Kaçak Fil","runtime":0,"tagline":"Sıkıysa yakala kanka!","homepage":"","overview":"Ödül avcısı bir domuz, yakalamayı planladığı özgür ruhlu bir fille kendini dünyayı dolaşırken bulur."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Hľadá sa slon","runtime":0,"tagline":"Nevideli ste ho ?","homepage":"","overview":"HĽADÁ SA SLON ... konkrétne veľká a mimoriadne temperamentná slonica. Zmizla z Las Vegas, kde vystupovala v slávnej tanečnej show, a jej pán ju potrebuje čím skôr nájsť. Osloví preto najlepšieho agenta, ktorý sa špecializuje na hľadanie zatúlaných domácich maznáčikov a dosahuje vynikajúce výsledky. Pri veselej slonici však narazí na menší problém. Zistí totiž, že nie všetky stratené zvieratká chcú byť nájdené, a keď niektoré pustíte na slobodu, získate najbohatšiu odmenu všetkých čias – dobrých priateľov."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Голям Прас!","runtime":0,"tagline":"","homepage":"","overview":"Във филма едноименният герой вече е хванал всичко – от миризлив пор, през коала с лош нрав, до мил омар, но най-новата му мисия е нещо съвсем различно. Той трябва да върне танцуващия слон с голямо сърце Пикълс обратно при Лорд Скокльо – маниакален шоумен от Лас Вегас. Залогът? Един милион долара. Само че нищо не е толкова просто. Пикълс е оптимистка, изпълнена с живот и мечти и докато двамата бягат от фанатична активистка за права на животните и пресичат целия свят, Голям Прас започва да се разкъсва от вътрешни противоречия и да се пита дали мисията си струва цената и не е ли време да се откаже от наградата в името на приятелството.  Оригинално заглавие\r HITPIG"},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"ჰიტფიგი!","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"豬排特務","runtime":0,"tagline":"","homepage":"","overview":"豬排是一隻脾氣不太好的豬，還是個靠抓動物維生的賞金獵人！這次他的任務是追捕一隻逃亡的寵物大象「菜菜醬」，並將牠歸還馬戲團的主人「飛天大王」。菜菜醬不只會跑、還超會撒嬌耍萌，原本冷酷無情的豬排特務，逐漸被這隻天真可愛的大象打動，兩人意外成為一對性格迥異的拍檔。這場追逐不僅考驗他們的生存智慧，也讓豬排特務開始重新思考「自由」與「選擇」的真正意義。這是一場關於友情、自由的公路爆笑冒險，更是「工具豬」的覺醒大作戰！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"חברים על מלא","runtime":0,"tagline":"מטורללים? כן! חברים? הכי!","homepage":"","overview":"היט פיג הוא צייד ראשים חכם וקשוח שלוכד חיות שברחו לחופש ומחזיר אותן לבעליהן. המשימה הבאה שלו היא הגדולה ביותר עד כה: ללכוד פילה צעירה בשם פיקלס למופע קרקס מטורלל. אך המשימה יוצאת במהרה משליטה כאשר הציד הקשוח רוקם חברות מיוחדת עם הפילה ומגלה כי יש דברים חשובים יותר מעושר. כעת על הציידים האחרים בעקבותיהם, כאשר השניים יגלו שהשלל הגדול מכולם היא - החברות."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"هیت پیگ","runtime":0,"tagline":"","homepage":"","overview":"یک خوک شکارچی جایزه بگیر باید یک فیل رقاص را به سیرک لاس وگاس بازگرداند تا یک میلیون دلار جایزه خود را دریافت کند. با این حال، هنگامی که مشکلاتی برای ماموریت اصلی او پیش می‌آید،به زودی متوجه می‌شود ..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Agent Čuník","runtime":0,"tagline":"Ztratil se Vám slon? Volejte!","homepage":"","overview":"Čuník se živí jako lovec odměn. Chytá uprchlá zvířata a vrací je jejich majitelům. Tentokrát ho však čeká největší výzva: vrátit tančící slonici Majdu šílenému showmanovi z Vegas za odměnu milion dolarů. Jeho odvážná mise se však brzy změní v divoké dobrodružství napříč celým světem, díky kterému si Čuník uvědomí, že největší odměnu nezíská za něčí dopadení, ale za návrat na svobodu."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"En Hitpig és un porc contractat per humans per portar de tornada els animals que s'han escapat. No és fàcil, però és una vida! El seu últim èxit és en Pickles, un elefant ingenu però vivaç que ha escapat de les urpes d'un malvat showman de Las Vegas. Encara que en Hitpig inicialment es proposa capturar l'alegre paquiderm per molts diners, l'estranya parella es troba en una aventura inesperada que recorre el món i treu el millor de tots dos. Ambientat en un món ciberpunk futurista, en Hitpig demostra que de vegades allò que volem no és el que necessitem."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Super agente Hitpig","runtime":90,"tagline":"","homepage":"","overview":"Un cerdo cazarrecompensas se encuentra recorriendo el mundo con un elefante de espíritu libre al que pretendía capturar."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Hitpig: Purcelușul detectiv","runtime":86,"tagline":"","homepage":"","overview":"Hitpig este un purceluș angajat de oameni pentru a găsi și recupera animalele de companie ale acestora. Nu este deloc o treabă ușoară, dar este un câștig sigur! Murăturică reprezintă cel mai recent caz acceptat. Aceasta este o elefanțică foarte naivă și vioaie, salvată de o ecologistă din ghearele unui circar lacom din Las Vegas. Deși inițial, detectivul nostru pornește în misiune hotărât doar să facă bani, aventura îi duce pe cei doi într-o călătorie în jurul lumii și în situații care le vor arăta cât de importantă este prietenia."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"No Rukša neizspruksi","runtime":0,"tagline":"","homepage":"","overview":"Ja minka no mājām aizgājis, ja alnis no meža pazudis, tad jums jāzvana Ruksim! Ruksis ir profesionālis, kurš notvers jebkuru izbēgušu dzīvnieku un nogādās to atpakaļ saimniekiem. Viņa nākamais darbiņš ir lielāks par viņu pašu, šoreiz jānotver un mājās jānogādā dejojošs zilonis. Un atlīdzība ir liela – miljons dolāru! Ziloņa ķeršana izvēršas par traku piedzīvojumu. Taču beigās Ruksis saprot, ka lielākais apbalvojums reizēm ir nevis kāda sagūstīšana, bet gan palaišana brīvībā."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"}],"reviews_tmdb":[],"recommendations":[{"id":537921,"adult":false,"title":"Fixed","video":false,"overview":"After learning he's getting neutered, a dog has 24 hours to squeeze in one last balls-to-the-wall adventure with the boys.","genre_ids":[16,35],"media_type":"movie","popularity":2.9232,"vote_count":137,"poster_path":"/udtlwWSJ45S0uQm29BvFvjPJGW0.jpg","release_date":"2025-08-13","vote_average":6.237,"backdrop_path":"/vmWgToiWzgWxzGtdbeQFrtuS2BN.jpg","original_title":"Fixed","original_language":"en"},{"id":682075,"adult":false,"title":"The Adventure of A.R.I.: My Robot Friend","video":false,"overview":"A teenager summons the courage to help a friendly robot known as A.R.I. kidnapped by a ruthless lab director working for a powerful corporation seeking to turn him into a dangerous weapon in order to rule the world.","genre_ids":[10751,878],"media_type":"movie","popularity":1.471,"vote_count":27,"poster_path":"/txcjXiyhBvsSFyZtgCHWW7CyIeN.jpg","release_date":"2022-01-13","vote_average":6.926,"backdrop_path":"/xPTefQ4CZpWapxiEsAZsxtidS49.jpg","original_title":"The Adventure of A.R.I.: My Robot Friend","original_language":"en"},{"id":266500,"adult":false,"title":"Dr. Cabbie","video":false,"overview":"An unemployed doctor turned cab driver becomes a local hero when he converts his taxi into a mobile clinic.","genre_ids":[35],"media_type":"movie","popularity":0.5493,"vote_count":33,"poster_path":"/1vSIZssks2ohIl4RKaJVexOC6tj.jpg","release_date":"2014-09-19","vote_average":5.4,"backdrop_path":"/ApWt9TSunECxulO3jXg5uK8v7A7.jpg","original_title":"Dr. Cabbie","original_language":"en"},{"id":66034,"adult":false,"title":"Mad Dog Time","video":false,"overview":"With his boss in the madhouse, a mobster is temporary boss of the criminal empire just as vicious rivals threaten the control of the empire.","genre_ids":[28,35,80],"media_type":"movie","popularity":0.8255,"vote_count":48,"poster_path":"/9VEmCk5wrVsW6841P28LzUh8AkU.jpg","release_date":"1996-11-08","vote_average":5.229,"backdrop_path":"/uuPB4j1O4lz44SPpM9un8QygZym.jpg","original_title":"Mad Dog Time","original_language":"en"},{"id":1136867,"adult":false,"title":"Materialists","video":false,"overview":"A young, ambitious New York City matchmaker finds herself torn between the perfect match and her imperfect ex.","genre_ids":[10749,18],"media_type":"movie","popularity":7.7208,"vote_count":1038,"poster_path":"/zh4kaa2dGhVjojHulCWt3AR4b2l.jpg","release_date":"2025-06-12","vote_average":6.407,"backdrop_path":"/lqwwGkwJHtz9QgKtz4zeY19YgDg.jpg","original_title":"Materialists","original_language":"en"},{"id":668489,"adult":false,"title":"Havoc","video":false,"overview":"When a drug heist swerves lethally out of control, a jaded cop fights his way through a corrupt city's criminal underworld to save a politician's son.","genre_ids":[28,80,53,18],"media_type":"movie","popularity":8.1439,"vote_count":1153,"poster_path":"/ubP2OsF3GlfqYPvXyLw9d78djGX.jpg","release_date":"2025-04-25","vote_average":6.373,"backdrop_path":"/7rKyFSg6SdLoCRCVoWLjL5k658k.jpg","original_title":"Havoc","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":22.369,"vote_count":11381,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":466272,"adult":false,"title":"Once Upon a Time... in Hollywood","video":false,"overview":"Los Angeles, 1969. TV star Rick Dalton, a struggling actor specializing in westerns, and stuntman Cliff Booth, his best friend, try to survive in a constantly changing movie industry. Dalton is the neighbor of the young and promising actress and model Sharon Tate, who has just married the prestigious Polish director Roman Polanski…","genre_ids":[35,18,53],"media_type":"movie","popularity":13.9409,"vote_count":14570,"poster_path":"/8j58iEBw9pOXFD2L0nt0ZXeHviB.jpg","release_date":"2019-07-24","vote_average":7.423,"backdrop_path":"/kKTPv9LKKs5L3oO1y5FNObxAPWI.jpg","original_title":"Once Upon a Time... in Hollywood","original_language":"en"},{"id":475557,"adult":false,"title":"Joker","video":false,"overview":"During the 1980s, a failed stand-up comedian is driven insane and turns to a life of crime and chaos in Gotham City while becoming an infamous psychopathic crime figure.","genre_ids":[80,53,18],"media_type":"movie","popularity":20.2141,"vote_count":27334,"poster_path":"/udDclJoHjfjb8Ekgsd4FDteOkCU.jpg","release_date":"2019-10-01","vote_average":8.128,"backdrop_path":"/hO7KbdvGOtDdeg0W4Y5nKEHeDDh.jpg","original_title":"Joker","original_language":"en"},{"id":260513,"adult":false,"title":"Incredibles 2","video":false,"overview":"Elastigirl springs into action to save the day, while Mr. Incredible faces his greatest challenge yet – taking care of the problems of his three children.","genre_ids":[28,12,16,10751],"media_type":"movie","popularity":8.0553,"vote_count":13507,"poster_path":"/9lFKBtaVIhP7E2Pk0IY1CwTKTMZ.jpg","release_date":"2018-06-14","vote_average":7.453,"backdrop_path":"/mabuNsGJgRuCTuGqjFkWe1xdu19.jpg","original_title":"Incredibles 2","original_language":"en"},{"id":497582,"adult":false,"title":"Enola Holmes","video":false,"overview":"While searching for her missing mother, intrepid teen Enola Holmes uses her sleuthing skills to outsmart big brother Sherlock and help a runaway lord.","genre_ids":[12,9648,80],"media_type":"movie","popularity":8.0584,"vote_count":6447,"poster_path":"/riYInlsq2kf1AWoGm80JQW5dLKp.jpg","release_date":"2020-09-23","vote_average":7.235,"backdrop_path":"/pQQggUuDMleFSl2tQYxzTmKIiLU.jpg","original_title":"Enola Holmes","original_language":"en"},{"id":414906,"adult":false,"title":"The Batman","video":false,"overview":"In his second year of fighting crime, Batman uncovers corruption in Gotham City that connects to his own family while facing a serial killer known as the Riddler.","genre_ids":[80,9648,53],"media_type":"movie","popularity":17.0483,"vote_count":11638,"poster_path":"/74xTEgt7R36Fpooo50r9T25onhq.jpg","release_date":"2022-03-01","vote_average":7.656,"backdrop_path":"/rvtdN5XkWAfGX6xDuPL6yYS2seK.jpg","original_title":"The Batman","original_language":"en"},{"id":363088,"adult":false,"title":"Ant-Man and the Wasp","video":false,"overview":"Just when his time under house arrest is about to end, Scott Lang once again puts his freedom at risk to help Hope van Dyne and Dr. Hank Pym dive into the quantum realm and try to accomplish, against time and any chance of success, a very dangerous rescue mission.","genre_ids":[28,12,878],"media_type":"movie","popularity":8.1995,"vote_count":14004,"poster_path":"/cFQEO687n1K6umXbInzocxcnAQz.jpg","release_date":"2018-07-04","vote_average":6.905,"backdrop_path":"/2tcTm5oRlRN5fKFvY4Gbrwp8h38.jpg","original_title":"Ant-Man and the Wasp","original_language":"en"},{"id":76600,"adult":false,"title":"Avatar: The Way of Water","video":false,"overview":"Set more than a decade after the events of the first film, learn the story of the Sully family (Jake, Neytiri, and their kids), the trouble that follows them, the lengths they go to keep each other safe, the battles they fight to stay alive, and the tragedies they endure.","genre_ids":[28,12,878],"media_type":"movie","popularity":37.4795,"vote_count":13734,"poster_path":"/t6HIqrRAclMCA60NsSmeqe9RmNV.jpg","release_date":"2022-12-14","vote_average":7.598,"backdrop_path":"/cd8YDn7M0lfaHhZdU6MvCDxPalP.jpg","original_title":"Avatar: The Way of Water","original_language":"en"},{"id":19995,"adult":false,"title":"Avatar","video":false,"overview":"In the 22nd century, a paraplegic Marine is dispatched to the moon Pandora on a unique mission, but becomes torn between following orders and protecting an alien civilization.","genre_ids":[28,12,14,878],"media_type":"movie","popularity":37.3012,"vote_count":33496,"poster_path":"/gKY6q7SjCkAU6FqvqWybDYgUKIF.jpg","release_date":"2009-12-16","vote_average":7.6,"backdrop_path":"/vL5LR6WdxWPjLPFRLe133jXWsh5.jpg","original_title":"Avatar","original_language":"en"},{"id":337401,"adult":false,"title":"Mulan","video":false,"overview":"When the Emperor of China issues a decree that one man per family must serve in the Imperial Chinese Army to defend the country from Huns, Hua Mulan, the eldest daughter of an honored warrior, steps in to take the place of her ailing father. She is spirited, determined and quick on her feet. Disguised as a man by the name of Hua Jun, she is tested every step of the way and must harness her innermost strength and embrace her true potential.","genre_ids":[12,14,28],"media_type":"movie","popularity":6.6237,"vote_count":6968,"poster_path":"/aKx1ARwG55zZ0GpRvU2WrGrCG9o.jpg","release_date":"2020-09-04","vote_average":6.837,"backdrop_path":"/zMrk2G3XsnfYKiIp1NEfdtvDyBH.jpg","original_title":"Mulan","original_language":"en"},{"id":436969,"adult":false,"title":"The Suicide Squad","video":false,"overview":"Supervillains Harley Quinn, Bloodsport, Peacemaker and a collection of nutty cons at Belle Reve prison join the super-secret, super-shady Task Force X as they are dropped off at the remote, enemy-infused island of Corto Maltese.","genre_ids":[28,35,12],"media_type":"movie","popularity":12.3652,"vote_count":9398,"poster_path":"/q61qEyssk2ku3okWICKArlAdhBn.jpg","release_date":"2021-07-28","vote_average":7.468,"backdrop_path":"/jlGmlFOcfo8n5tURmhC7YVd4Iyy.jpg","original_title":"The Suicide Squad","original_language":"en"},{"id":324857,"adult":false,"title":"Spider-Man: Into the Spider-Verse","video":false,"overview":"Struggling to find his place in the world while juggling school and family, Brooklyn teenager Miles Morales is unexpectedly bitten by a radioactive spider and develops unfathomable powers just like the one and only Spider-Man. While wrestling with the implications of his new abilities, Miles discovers a super collider created by the madman Wilson \"Kingpin\" Fisk, causing others from across the Spider-Verse to be inadvertently transported to his dimension.","genre_ids":[16,28,12,878],"media_type":"movie","popularity":18.3258,"vote_count":16894,"poster_path":"/iiZZdoQBEYBv6id8su7ImL0oCbD.jpg","release_date":"2018-12-06","vote_average":8.393,"backdrop_path":"/8mnXR9rey5uQ08rZAvzojKWbDQS.jpg","original_title":"Spider-Man: Into the Spider-Verse","original_language":"en"},{"id":398818,"adult":false,"title":"Call Me by Your Name","video":false,"overview":"In the summer of 1983, a 17-year-old Elio spends his days in his family's villa in Italy. One day Oliver, a graduate student, arrives to assist Elio's father, a professor of Greco-Roman culture. Soon, Elio and Oliver discover a summer that will alter their lives forever.","genre_ids":[10749,18],"media_type":"movie","popularity":9.3674,"vote_count":12600,"poster_path":"/mZ4gBdfkhP9tvLH1DO4m4HYtiyi.jpg","release_date":"2017-10-01","vote_average":8.096,"backdrop_path":"/fwf4L3r2ZU9ptOB9nOo5nuVLo1i.jpg","original_title":"Call Me by Your Name","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":29.365,"vote_count":26819,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.902,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"}],"similar_content":[{"id":11199,"adult":false,"title":"Wild Hogs","video":false,"overview":"Restless and ready for an adventure, four suburban bikers leave the safety of their subdivision and head out on the open road. But complications ensue when they cross paths with an intimidating band of New Mexico bikers known as the Del Fuegos.","genre_ids":[28,12,35],"popularity":3.1721,"vote_count":2412,"poster_path":"/qYyPCZcpNGZwbyBo1gwdCiW5hHC.jpg","release_date":"2007-03-02","vote_average":5.967,"backdrop_path":"/es74vwJqbT6cwMdJmTeSIcjJjoo.jpg","original_title":"Wild Hogs","original_language":"en"},{"id":11201,"adult":false,"title":"Verliebte Jungs","video":false,"overview":"Oliver and Michael want to enjoy life, but the 20-year-olds don't have enough money to do so, so when they are offered jobs in a trendy beer garden, they jump at the chance. There they learn from their colleagues that the waiters at the pub organize a competition every year. The winner is the one who can boast the most amorous adventures. There's no question that Oliver and Michel want to be at the forefront.","genre_ids":[35,10770],"popularity":1.5183,"vote_count":11,"poster_path":"/hXgR0Ehp1sinw7fYUMXVKcPosfX.jpg","release_date":"2001-05-09","vote_average":4.182,"backdrop_path":"/167hPw51JM5AneMxXaPsQhm1tD8.jpg","original_title":"Verliebte Jungs","original_language":"de"},{"id":11210,"adult":false,"title":"Robinson Crusoe","video":false,"overview":"Robinson Crusoe flees Britain on a ship after killing his friend over the love of Mary. A fierce ocean storm wrecks his ship and leaves him stranded by himself on an uncharted island. Left to fend for himself, Crusoe seeks out a tentative survival on the island, until he meets Friday, a tribesman whom he saves from being sacrificed. Initially, Crusoe is thrilled to finally have a friend, but he has to defend himself against the tribe who uses the island to sacrifice tribesman to their gods. During time their relationship changes from master-slave to a mutual respected friendship despite their difference in culture and religion.","genre_ids":[28,12,18],"popularity":1.5373,"vote_count":262,"poster_path":"/93uRPzVpf4ZVjDfswmpsrAmBS4w.jpg","release_date":"1997-06-11","vote_average":5.968,"backdrop_path":"/ynpag8C3nhpPrHIghrKH6kKXOSO.jpg","original_title":"Robinson Crusoe","original_language":"en"},{"id":11260,"adult":false,"title":"Meet Dave","video":false,"overview":"A crew of miniature aliens operate a spaceship that has a human form. While trying to save their planet, the aliens encounter a new problem, as their ship becomes smitten with an Earth woman.","genre_ids":[35,878,12,10751],"popularity":2.6194,"vote_count":1509,"poster_path":"/3Qfav5aVRcZmq854olMjJ795JJ2.jpg","release_date":"2008-07-08","vote_average":5.3,"backdrop_path":"/azheZwmLAiWZyDuL416NL0IxvFp.jpg","original_title":"Meet Dave","original_language":"en"},{"id":11354,"adult":false,"title":"The Upside of Anger","video":false,"overview":"After her husband runs off with his secretary, Terry Wolfmeyer is left to fend for herself -- and her four daughters. As she hits rock bottom, Terry finds a friend and drinking buddy in next-door neighbor Denny, a former baseball player. As the two grow closer, and her daughters increasingly rely on Denny, Terry starts to have reservations about where their relationship is headed.","genre_ids":[35,18],"popularity":0.9715,"vote_count":287,"poster_path":"/UdLPKVq6Cfw7ig1ancmDkclfZg.jpg","release_date":"2005-03-11","vote_average":6.3,"backdrop_path":"/bPkP368pQkRY3m89nP2nWYjIxRC.jpg","original_title":"The Upside of Anger","original_language":"en"},{"id":11375,"adult":false,"title":"Hollywood Homicide","video":false,"overview":"Joe Gavilan and his new partner K. C. Calden, are detectives on the beat in Tinseltown. Neither one of them really wants to be a cop, Gavilan moonlights as a real estate broker, and Calden is an aspiring actor moonlighting as a yoga instructor. When the two are assigned a big case they must work out whether they want to solve the case or follow their hearts.","genre_ids":[28,12,35,53],"popularity":1.421,"vote_count":681,"poster_path":"/Am7AhZYG7HLksY5E35oaEJ3Desz.jpg","release_date":"2003-06-09","vote_average":5.2,"backdrop_path":"/fQnbVD4wXaKeTHEYk6y2pn0GVAM.jpg","original_title":"Hollywood Homicide","original_language":"en"},{"id":11185,"adult":false,"title":"See No Evil, Hear No Evil","video":false,"overview":"A murder takes place in the shop of David Lyons, a deaf man who fails to hear the gunshot being fired. Outside, blind man Wally Karue hears the shot, but cannot see the perpetrator. Both are arrested, but escape to form an unlikely partnership. Being chased by both the law AND the original killers, can the pair work together to outwit them all?","genre_ids":[35,80],"popularity":2.5219,"vote_count":1048,"poster_path":"/e9JrnUotqhKTUQEgg2UzDQ7nME2.jpg","release_date":"1989-05-12","vote_average":6.757,"backdrop_path":"/e39yv0bmJMt8w0nD0hMGdZuTjkn.jpg","original_title":"See No Evil, Hear No Evil","original_language":"en"},{"id":279769,"adult":false,"title":"Ruby Jean and Joe","video":false,"overview":"In a tale set in the rough and tumble world of professional rodeo, an over-the-hill former champion broncobuster and a young hitchhiker develop a special friendship.","genre_ids":[10770,35,18],"popularity":0.2566,"vote_count":1,"poster_path":"/6nKYyYLCOuevi8vlSocKZKPPCVr.jpg","release_date":"1996-01-01","vote_average":6,"backdrop_path":"/aW7e9W8GIHK48RxMIhmn7OM5dzg.jpg","original_title":"Ruby Jean and Joe","original_language":"en"},{"id":11292,"adult":false,"title":"Girl's Life, Boy's World","video":false,"overview":"At seventeen, girls are all about looking good, dressing right and making out with the cutest boys. Or they're like Luka, who's an ace in boxing and couldn't care less about her looks or her appeal to boys. When she breaks a schoolmate's nose, her parents send her off to boarding school to acquire some ladylike manners. There she's mistaken for Frankie, a boy who hasn't shown up, and takes on his identity. With her boxing skills, she instantly wins over her three roommates Chico, Toby and Jo, and strikes up a particularly close friendship with Chico. Her uncompromising honesty and loyalty to her new friends, however, soon get her into trouble with the headmistress and her nephew, the school bully.","genre_ids":[35,10770],"popularity":0.2957,"vote_count":12,"poster_path":"/oUgbUWfPlAQhKLPnX6N9gAjKkvJ.jpg","release_date":"2003-02-06","vote_average":4.792,"backdrop_path":null,"original_title":"Seventeen - Mädchen sind die besseren Jungs","original_language":"de"},{"id":11293,"adult":false,"title":"Paper Moon","video":false,"overview":"During the Great Depression, a con man finds himself saddled with a young girl who may or may not be his daughter, and the two forge an unlikely partnership.","genre_ids":[35,80,18],"popularity":1.6374,"vote_count":802,"poster_path":"/3GHG0kTcBWHKdXjj3RdK8GjBCd6.jpg","release_date":"1973-05-09","vote_average":7.9,"backdrop_path":"/2Cf8V0iQx0c52IxeLdxOvjI2bBf.jpg","original_title":"Paper Moon","original_language":"en"},{"id":11852,"adult":false,"title":"The Hot Chick","video":false,"overview":"Not only is Jessica Spencer the most popular girl in school -- she is also the meanest. But things change for the attractive teen when a freak accident involving a cursed pair of earrings and a chance encounter at a gas station causes her to switch bodies with Clive, a sleazy crook. Jessica, in the form of the repulsive Clive, struggles to adjust to this radical alteration and sets out to get her own body back before the upcoming prom.","genre_ids":[35,14],"popularity":4.289,"vote_count":2129,"poster_path":"/lnnGE4TKa05t20SZ2batuAhXCp4.jpg","release_date":"2002-12-13","vote_average":6.357,"backdrop_path":"/vK8uTRjiNkJ7P2VINNLxYWiiw0z.jpg","original_title":"The Hot Chick","original_language":"en"},{"id":280391,"adult":false,"title":"Animal Kingdom: Let's Go Ape","video":false,"overview":"Based on the novel 'Evolution Man' by Roy Lewis, this tells the story about the first man - young Edward - to descend from apes. Edward is ejected by his tribe, but is very resourceful. He learns to walk, discovers fire, manages to hunt - and we follow him as he evolves. He has a generous nature, and search for true humanity - a world where we don't eat our fathers.","genre_ids":[12,35,16],"popularity":1.015,"vote_count":361,"poster_path":"/7qccdwXUMazLqkMKm4ZJ7lAnzUF.jpg","release_date":"2015-04-08","vote_average":5.3,"backdrop_path":"/vq2TVlQmOUE6uZnRIZD475IcoAX.jpg","original_title":"Pourquoi j'ai pas mangé mon père","original_language":"fr"},{"id":11866,"adult":false,"title":"Flight of the Phoenix","video":false,"overview":"When an oil rig in the Gobi Desert of Mongolia proves unproductive, an aircraft crew are sent to shut the operation down and fly them out. On the flight out over the desert on the way to Beijing, Capt. Frank Towns and co-pilot A.J. are unable to keep their cargo plane, a C-119 Flying Boxcar, in the air when a violent sandstorm strikes. Crash-landing in a remote uncharted part of the desert, the two pilots and their passengers -- a crew of oil workers and a drifter -- must work together to survive by rebuilding the aircraft. Soon, low supplies and a band of merciless smugglers add even greater urgency to their task.","genre_ids":[28,12,18],"popularity":2.0585,"vote_count":919,"poster_path":"/pcj6unMsKCw0ogWFlUXmbc9gKap.jpg","release_date":"2004-12-17","vote_average":5.99,"backdrop_path":"/mWXU29QjfjEG37d0c2hE11MWRGq.jpg","original_title":"Flight of the Phoenix","original_language":"en"},{"id":11867,"adult":false,"title":"Barb Wire","video":false,"overview":"A sexy nightclub owner, Barb Wire moonlights as a mercenary in Steel Harbor, one of the last free zones in the now fascist United States. When scientist Cora Devonshire wanders into Barb's establishment, she gets roped into a top-secret government plot involving biological weapons. Soon Barb is reunited with her old flame Axel Hood, who is now Cora's husband and a guerrilla fighter, resulting in plenty of tense action.","genre_ids":[878,28,12],"popularity":1.0659,"vote_count":476,"poster_path":"/jW5TLptY7PL1Mllq1g1uMjwXLXT.jpg","release_date":"1996-05-02","vote_average":4.101,"backdrop_path":"/o7bxmFoHfEP5JiBzVYY5QgLiSfU.jpg","original_title":"Barb Wire","original_language":"en"},{"id":11775,"adult":false,"title":"Intolerable Cruelty","video":false,"overview":"A revenge-seeking gold digger marries a womanizing Beverly Hills lawyer with the intention of making a killing in the divorce.","genre_ids":[35,10749,80],"popularity":2.4005,"vote_count":1624,"poster_path":"/7K8hDwOWsZv0MluyrB8nWlhJOgB.jpg","release_date":"2003-10-10","vote_average":5.955,"backdrop_path":"/x1BTLDDijvms3Yi9NZoxxniTDGA.jpg","original_title":"Intolerable Cruelty","original_language":"en"},{"id":11790,"adult":false,"title":"Peter's Friends","video":false,"overview":"After inheriting a large country estate from his late father, Peter invites his friends from college: married couple Roger and Mary, the lonely Maggie, fashionable Sarah, and writer Andrew, who brings his American TV star wife, Carol. Sarah's new boyfriend, Brian, also attends. It has been 10 years since college, and they find their lives are very different.","genre_ids":[35,18],"popularity":0.7272,"vote_count":212,"poster_path":"/8ly4EB83JlOkjBD6wOTU0ReXMQN.jpg","release_date":"1992-09-18","vote_average":6.6,"backdrop_path":"/hvvWpJlIAnUxvmqHO5crATLVNzP.jpg","original_title":"Peter's Friends","original_language":"en"},{"id":11836,"adult":false,"title":"The SpongeBob SquarePants Movie","video":false,"overview":"There's trouble brewing in Bikini Bottom. Someone has stolen King Neptune's crown, and it looks like Mr. Krab, SpongeBob's boss, is the culprit. Though he's just been passed over for the promotion of his dreams, SpongeBob stands by his boss, and along with his best pal Patrick, sets out on a treacherous mission to Shell City to reclaim the crown and save Mr. Krab's life.","genre_ids":[10751,35,12,16,14],"popularity":7.6881,"vote_count":3129,"poster_path":"/1rvzKV1d18EbDVaEd4VDzK3cgnY.jpg","release_date":"2004-11-19","vote_average":7.069,"backdrop_path":"/i2fZIltljrhFPsUK9PN6O6ZE7M4.jpg","original_title":"The SpongeBob SquarePants Movie","original_language":"en"},{"id":11966,"adult":false,"title":"Short Circuit 2","video":false,"overview":"Robot Johnny 5 moves to the city to help his friend Ben Jahrvi with his toy manufacturing enterprise, only to be manipulated by criminals who want to use him for their own nefarious purposes.","genre_ids":[35,10751,878,18],"popularity":1.737,"vote_count":641,"poster_path":"/vXzkNsPEA59EON5PMVXsURe8o67.jpg","release_date":"1988-07-06","vote_average":6.207,"backdrop_path":"/hyI49UsyxEeljfjyjjXIXHQkw6V.jpg","original_title":"Short Circuit 2","original_language":"en"},{"id":11967,"adult":false,"title":"Young Guns","video":false,"overview":"A group of young gunmen, led by Billy the Kid, become deputies to avenge the murder of the rancher who became their benefactor. But when Billy takes their authority too far, they become the hunted.","genre_ids":[37,28,12],"popularity":2.5241,"vote_count":1003,"poster_path":"/3AgCq7xY1rHRAAn0iVcnNr2OWL.jpg","release_date":"1988-08-12","vote_average":6.67,"backdrop_path":"/AoFo9HeJU7jiHAUNawpwhs3zQbd.jpg","original_title":"Young Guns","original_language":"en"},{"id":11971,"adult":false,"title":"Much Ado About Nothing","video":false,"overview":"In this Shakespearean farce, Hero and her groom-to-be, Claudio, team up with Claudio's commanding officer, Don Pedro, the week before their wedding to hatch a matchmaking scheme. Their targets are sharp-witted duo Benedick and Beatrice -- a tough task indeed, considering their corresponding distaste for love and each other. Meanwhile, meddling Don John plots to ruin the wedding.","genre_ids":[18,35,10749],"popularity":2.4431,"vote_count":791,"poster_path":"/tvltGP6vYOkHdURag0jPSjhPUAV.jpg","release_date":"1993-05-07","vote_average":6.9,"backdrop_path":"/fe5a9dB8tylKUpcXq88ioXpNSsm.jpg","original_title":"Much Ado About Nothing","original_language":"en"}],"external_ids":{"imdb_id":"tt13176330","twitter_id":null,"facebook_id":null,"wikidata_id":"Q114853077","instagram_id":null,"metacritic_id":"movie/hitpig","rotten_tomatoes_id":"m/hitpig"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":106115,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"CZ","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-03-13T00:00:00.000Z","certification":"U"}]},{"iso_3166_1":"EE","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-02-07T00:00:00.000Z","certification":""}]},{"iso_3166_1":"ES","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-09-12T00:00:00.000Z","certification":"A"}]},{"iso_3166_1":"HR","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-02-20T00:00:00.000Z","certification":""}]},{"iso_3166_1":"HU","release_dates":[{"note":"","type":3,"iso_639_1":"hu","descriptors":[],"release_date":"2025-05-01T00:00:00.000Z","certification":"12"}]},{"iso_3166_1":"IT","release_dates":[{"note":"24FRAME Future