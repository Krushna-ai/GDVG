9:{"metadata":[["$","title","0",{"children":"A Chinese Ghost Story | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"A naïve young tax collector for the imperial government winds up spending the night in a haunted temple. There he falls in love with a beautiful woman who, unfortunately, is dead. With the aid of a powerful Daoist Swordsman, he must defeat undead hordes, overcome a sinister Tree Demoness, and descend to the pits of hell, to fight for the spirit he loves."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/102851/a-chinese-ghost-story"}],["$","meta","5",{"property":"og:title","content":"A Chinese Ghost Story"}],["$","meta","6",{"property":"og:description","content":"A naïve young tax collector for the imperial government winds up spending the night in a haunted temple. There he falls in love with a beautiful woman who, unfortunately, is dead. With the aid of a powerful Daoist Swordsman, he must defeat undead hordes, overcome a sinister Tree Demoness, and descend to the pits of hell, to fight for the spirit he loves."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/102851/a-chinese-ghost-story"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/pGQy2KB3I0DouwnKNjChyCgULJQ.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"A Chinese Ghost Story"}],["$","meta","12",{"name":"twitter:description","content":"A naïve young tax collector for the imperial government winds up spending the night in a haunted temple. There he falls in love with a beautiful woman who, unfortunately, is dead. With the aid of a powerful Dao