5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"A Chinese Ghost Story\",\"description\":\"A naïve young tax collector for the imperial government winds up spending the night in a haunted temple. There he falls in love with a beautiful woman who, unfortunately, is dead. With the aid of a powerful Daoist Swordsman, he must defeat undead hordes, overcome a sinister Tree Demoness, and descend to the pits of hell, to fight for the spirit he loves.\",\"image\":\"https://image.tmdb.org/t/p/w500/pGQy2KB3I0DouwnKNjChyCgULJQ.jpg\",\"datePublished\":\"1987-07-18\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"cn\",\"genre\":[\"romance film\",\"fantasy film\",\"comedy horror\",\"film based on literature\",\"Fantasy\",\"Action\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.276,\"bestRating\":10,\"ratingCount\":324}}"}}],["$","$L10",null,{"initialDrama":{"id":"31d321fa-0e07-4c71-88f3-0406a04eb53f","tmdb_id":30421,"imdb_id":"tt0093978","content_type":"movie","title":"A Chinese Ghost Story","original_title":"倩女幽魂","overview":"A naïve young tax collector for the imperial government winds up spending the night in a haunted temple. There he falls in love with a beautiful woman who, unfortunately, is dead. With the aid of a powerful Daoist Swordsman, he must defeat undead hordes, overcome a sinister Tree Demoness, and descend to the pits of hell, to fight for the spirit he loves.","poster_path":"/pGQy2KB3I0DouwnKNjChyCgULJQ.jpg","backdrop_path":"/8qDJ594juzFixXFhDumgU1xhdbZ.jpg","release_date":"1987-07-18","first_air_date":null,"status":"published","original_language":"cn","origin_country":["HK"],"genres":[{"name":"romance film"},{"name":"fantasy film"},{"name":"comedy horror"},{"name":"film based on literature"},{"id":14,"name":"Fantasy"},{"id":28,"name":"Action"}],"popularity":4.2541,"vote_average":7.276,"vote_count":324,"runtim