qiBpNpNFDnOV20ognIADY.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2048,"height":1152,"file_path":"/h9vlTZUiTXkdvjYeaGkwCMhPJu9.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2048,"height":1152,"file_path":"/ljh71goViUPasR1dE8Zs4iVIh8f.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1765,"height":992,"file_path":"/6OIr1IvwP24MdceM5UhjLXQ9jOr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":1765,"height":992,"file_path":"/nnFOr8aAOILifUF82iObVMcYi1e.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":1771,"height":995,"file_path":"/r3wHHsRTlGQ58G9cBzYZ0t6oIyn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.78,"vote_average":0},{"width":1771,"height":995,"file_path":"/wRtKqEDS0Dz8t5l6HBqE599QzHB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.78,"vote_average":0},{"width":3827,"height":2150,"file_path":"/4yvwNO3GG96Eeh3lo3yw9yuW46B.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.78,"vote_average":0},{"width":3827,"height":2150,"file_path":"/q2FgbHb1oHLojNdKDGP4D3FNgDE.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.78,"vote_average":0},{"width":3830,"height":2151,"file_path":"/TDw9Sbf7wcOSEEgj9Zz4zBcTmO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.781,"vote_average":0}]},"enriched_at":"2026-04-21T09:12:24.425+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":149,"tagline":"The World Is Not Only For Humans ...","homepage":"","overview":"An ornithologist who commits suicide returns as fifth force to wreack vengeance on mankind for harming birds with mobile phone radiation. The only thing that is standing in his way is 2.0, the upgraded version of Chitti, the robot."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"宝莱坞机器人2.0：重生归来","runtime":107,"tagline":"","homepage":"","overview":"　　印度某市，所有人的手机突然被来自天空的神秘力量席卷吸走，手机销售大亨、电信运营老板、国家电信部高官等与手机相关的许多人相继离奇死去；城市上空，巨型变异鸟怪（阿克谢•库玛尔 饰）突然出现，大开杀戒，向所有手机用户宣战，民众陷入恐慌……危机时刻，科学家瓦西博士（拉吉尼坎塔 饰）在美女助理妮娜（艾米•杰克逊 饰）的帮助下，一路追踪事件真相，但后果已无法挽回，能够拯救人类的唯一方法只有——重启机器人“七弟”，他将如何变身新一代超级英雄，与这股亦正亦邪的势力开启昏天黑地、脑洞大开的鏖战？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Робот 2.0","runtime":148,"tagline":"","homepage":"","overview":"Миру угрожает монструозный крылатый злодей, покусившийся на самое святое, что есть у человечества — мобильные телефоны. Бессовестное чудовище в прямом смысле слова подчиняет себе устройства и создаёт из них могучую армию, способную трансформироваться во что угодно. Так и проиграли бы люди этот неравный бой, если бы не другое важное изобретение — робот Читти."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"로봇 2","runtime":0,"tagline":"","homepage":"","overview":"바시가란 박사와 (라지니칸트) 그의 안드로이드 조수 닐라는 (에이미 잭슨) 불가사의하게도 첸나이 사람들의 손에서 휴대 전화가 날아가기 시작하자 도움을 요청받는다. 비시가란은 새의 형태로 나타나는 파크시라잔의 (악쉐이 쿠마르) 초능력을 물리치기 위해 믿음직한 로봇 치티를 (라지니칸트) 소환한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":149,"tagline":"","homepage":"","overview":"മനുഷ്യശക്തിക്കതീതമായ ഭീഷണിയിൽ നിന്നും  ഡോ.വസീഗരൻ  തന്റെ ഹ്യൂമനോയിഡ് റോബോർട്ടായ ചിറ്റിയുടെ സഹായത്താൽ  മനുഷ്യരാശിയെ രക്ഷിക്കാൻ ശ്രമിക്കുന്നു."},"name":"","iso_639_1":"ml","iso_3166_1":"IN","english_name":"Malayalam"},{"data":{"title":"Robot 2.0","runtime":0,"tagline":"","homepage":"","overview":"İntihar eden bir ornitolog, cep telefonu radyasyonu olan kuşlara zarar vermek için insanlığa intikam almak için beşinci bir güç olarak geri dönüyor. Yolda duran tek şey 2.0, robot olan Chitti'nin yükseltilmiş hali."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":150,"tagline":"","homepage":"","overview":"À Chennai, le Dr. Vaseegaran réveille son robot Chitti pour enquêter sur des téléphones portables qui s'envolent des mains de leurs propriétaires."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":148,"tagline":"","homepage":"","overview":"De bewoners van de stad Madras komen in de problemen wanneer hun mobiele telefoons plots uit hun handen vliegen. Dr. Vaseegaran en zijn assistente Nila worden gevraagd het probleem te onderzoeken en op te lossen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"寶萊塢機器人之戀2.0","runtime":0,"tagline":"","homepage":"","overview":"清奈發生多人手機神秘失蹤的事件之後，瓦西博士（拉吉尼坎斯飾演）和他的機器人助手妮拉（艾米傑克森飾演）被找來協助。瓦西博士召回了他所信賴的機器人七弟（拉吉尼坎斯飾演），阻止帕錫拉揚（阿克夏庫馬飾演）的鳥身怪物的攻擊。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"தமிழ்","iso_639_1":"ta","iso_3166_1":"IN","english_name":"Tamil"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"2.0","runtime":0,"tagline":"","homepage":"","overview":"เมื่อดอกเตอร์วาซีการัน (ราชินิกานท์) และหุ่นแอนดรอยด์ผู้ช่วยของเขา นิลา (เอมี่ แจ็กสัน) ต้องออกช่วยเหลือ เมื่อจู่ ๆ โทรศัพท์มือถือก็ลอยหลุดจากมือชาวเจนไน"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"ロボット2.0","runtime":0,"tagline":"","homepage":"https://robot2-0.com/","overview":"突如街中からスマホが次々と失踪し、それらは合体して意思を持つ巨大なロボットに姿を変え人々に襲い掛かる。インドの街が崩壊の危機にさらされ、ついに解体されたロボット、チッティはスーパーパワーを身に着けたバージョン2.0として再起動！地球を救うため、予測不能なバトルを繰り広げる！！"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":189,"tagline":"","homepage":"","overview":"Un ornitolog care se sinucide revine ca a cincea forță pentru a se răzbuna asupra omenirii pentru că a făcut rău păsărilor cu radiația telefonului mobil. Singurul lucru care îi stă în cale este 2.0, versiunea îmbunătățită a lui Chitti, robotul."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"2.0","runtime":0,"tagline":"","homepage":"","overview":"Một nhà nghiên cứu chim tự tử trở lại như là lực lượng thứ năm để trả thù nhân loại vì đã làm hại chim bằng bức xạ điện thoại di động. Thứ duy nhất cản đường anh là 2.0, phiên bản nâng cấp của Chitti, robot."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"寶萊塢機器人之戀 2.0","runtime":0,"tagline":"","homepage":"","overview":"清奈發生多人手機神秘失蹤的事件之後，瓦西博士（拉吉尼坎斯飾演）和他的機器人助手妮拉（艾米傑克森飾演）被找來協助。瓦西博士召回了他所信賴的機器人七弟（拉吉尼坎斯飾演），阻止帕錫拉揚（阿克夏庫馬飾演）的鳥身怪物的攻擊。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":366080,"adult":false,"title":"Kabali","video":false,"overview":"A gangster in Malaysia goes in search of his family after 25 years of imprisonment.","genre_ids":[28,80,18],"media_type":"movie","popularity":0.8718,"vote_count":90,"poster_path":"/va0M1xhP3sUUERWfHeSKGVhtJHW.jpg","release_date":"2016-07-22","vote_average":5.978,"backdrop_path":"/12DJjwUO8rr3ds2CAXpPNwhPet6.jpg","original_title":"கபாலி","original_language":"ta"},{"id":148284,"adult":false,"title":"Enthiran","video":false,"overview":"Dr. Vaseegaran creates Chitti, a powerful robot in his own image, but it is rejected by the scientific body AIRD due to its lack of human behaviour and emotions. After a lightning strike triggers emotions in Chitti, he begins to develop human-like feelings. However, Chitti falls in love with Dr. Vaseegaran's fiancée, Sana, and turns against his creator, leading to dangerous consequences.","genre_ids":[28,878,12],"media_type":"movie","popularity":1.9621,"vote_count":243,"poster_path":"/hai6CSCLxULO1RThjDP3lWAqOtQ.jpg","release_date":"2010-10-01","vote_average":6.572,"backdrop_path":"/fvsSPqeVq4yhp7oZTGXA99uDQ1v.jpg","original_title":"எந்திரன்","original_language":"ta"},{"id":792358,"adult":false,"title":"Jana Gana Mana","video":false,"overview":"After the mysterious death of a college professor triggers nationwide protests, a police officer’s pursuit of justice unravels layers of political manipulation and moral conflict, exposing how truth and power collide in the pursuit of justice.","genre_ids":[80,53,18],"media_type":"movie","popularity":0.7887,"vote_count":68,"poster_path":"/1bSPVn6HlkGYTQ4tJYJ0UGWnQM9.jpg","release_date":"2022-04-28","vote_average":7.216,"backdrop_path":"/qo4WSjKvtw6KztqhgK1tXsLuVP4.jpg","original_title":"ജന ഗണ മന","original_language":"ml"},{"id":24049,"adult":false,"title":"Sivaji: The Boss","video":false,"overview":"A wealthy engineer arrives in India with the mission of serving the nation and investing in the country's welfare but is met with strong opposition from corrupt officials and politicians. After being faced with insurmountable hardships, he decides to take drastic measures.","genre_ids":[28,18],"media_type":"movie","popularity":1.3251,"vote_count":136,"poster_path":"/yBvsYnhrrTs1ZgHQNQTSdVA6uo8.jpg","release_date":"2007-06-08","vote_average":7,"backdrop_path":"/vpVF5tPI5v7h9knuwnwpPSaRToW.jpg","original_title":"சிவாஜி","original_language":"ta"},{"id":570910,"adult":false,"title":"Thackeray","video":false,"overview":"Based on the life of Keshav Thackeray, an Indian politician who is also known as Balasaheb Thackeray.","genre_ids":[18,36],"media_type":"movie","popularity":0.1798,"vote_count":18,"poster_path":"/yfjEuYlASO9xoT8nLp8pVqKCtZN.jpg","release_date":"2019-01-25","vote_average":