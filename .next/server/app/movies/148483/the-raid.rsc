1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/y1gNQTKVOtBejVPSWwqhdtzXu6A.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2560,"height":1440,"file_path":"/7D2TCcU9Uo9F8HsyhuSoxggx4v8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/8nG5aBs1mfWVW5L6HFf7Tt8NfHX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/zVsw4mzgQAHQsVaRteCha5sTzXD.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/yZkrSl9hJ9cWY1yemwra941T7As.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2158,"file_path":"/guBG9oH3jnFGukaDuXPa4plGoOt.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":3840,"height":2160,"file_path":"/k2QB7CBmKFji4cwk5OSjqnlZM27.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/pCZwmTdTXT4EfmLZRb3etw8PUgO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/6ZYYw7WCN7Dm2du2brxHyQlL7xy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/30K1ONk0mabBXXzaFNVuPaD91rK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/uFKyFiR96BAhhhmCZhvJQty1BnW.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/2Lh8E8SM8bioMXildWJSp95EgeS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/8dBYdjZW1BCoxfiqzz4hHbt4ee2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/2kMbFzlj8KZMukHqZqHoBGdm9Tf.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/co7IjdfdFq9I5iu7BP6TIAZCTCr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/sW6ToKXip8uIJCCVXa06HhHNPC8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/d5gXlVDeIpHh6haPpYleJNbbYiX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/tbO4gQ3kwgkPqcDCQAmYSfymXDC.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/dT7p6OdCm98VTt2xQ6W4J8FR2x1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3402,"height":1914,"file_path":"/hLvYBPnin7dO0t7yBIe384JjlC2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3840,"height":2160,"file_path":"/fFkmDa7mJrhfmR9mnPYFY6BXgiP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/5Gv0wb5gkajschULX95GNrqfWaM.jpg","iso_639_1":"sv","iso_3166_1":"SE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/rbavZA6x9hdHghfNrMY9l95HoYO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/hI0dbttWi2qPMVRxaSN5XZX056N.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/fhORoyIa0UsGHDAYlvKv7q3RhUi.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T03:29:16.971+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Raid","runtime":101,"tagline":"1 Ruthless Crime Lord, 20 Elite Cops, 30 Floors of Hell.","homepage":"http://www.sonyclassics.com/theraid/","overview":"Deep in the heart of Jakarta's slums lies an impenetrable safe house for the world's most dangerous killers and gangsters. Until now, the run-down apartment block has been considered untouchable to even the bravest of police. Cloaked under the cover of pre-dawn darkness and silence, an elite swat team is tasked with raiding the safe house in order to take down the notorious drug lord that runs it.  But when a chance encounter with a spotter blows their cover and news of their assault reaches the drug lord, the building's lights are cut and all the exits blocked. Stranded on the sixth floor with no way out, the unit must fight their way through the city's worst to survive their mission. Starring Indonesian martial arts sensation Iko Uwais."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"The Raid","runtime":101,"tagline":"","homepage":"","overview":"Sekelompok tim SWAT tiba di sebuah blok apartemen yang tidak terurus dengan misi menangkap pemiliknya seorang raja bandar narkotik bernama TAMA. Blok ini tidak pernah digerebek atau pun tersentuh oleh Polisi sebelumnya."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"Операцията: Изкупление","runtime":101,"tagline":"","homepage":"","overview":"В един от най-опасните квартали на Джакарта се намира сграда, в която се срещат най-опасните престъпници в страната.  Те са недосегаеми от полицията и спокойно разработват поредните си атаки в сградата. Но полицията изпраща отряд на специалните части, който да проникне в постройката, за да арестува опасен наркодилър.  Командосите успяват да проникнат в сградата, но когато стигат шестия етаж, електричеството е прекъснато, а всички изходи блокирани.  Предстои битка на живот и смърт между добре обучените спец ченгета и престъпниците, които знаят всеки таен изход и липсата на осветление не може да ги възпрепятства."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"The Raid","runtime":101,"tagline":"20 Elite Cops. 30 Floors of Hell.","homepage":"","overview":"In einem Appartementblock im Zentrum Jakartas wohnen der skrupellose Gangsterboss Tama Riyadi und seine Gang. Eines Tages wagt sich ein 20-köpfiges SWAT-Team unter der Leitung von Sergeant Jaka in das Gebäude. Doch die Polizisten werden entdeckt, die Ausgänge sind plötzlich verrammelt und der Strom abgestellt. Langsam kämpft sich das SWAT-Team die Stockwerke hoch. Während die Gruppe durch Bewohner und Gang immer mehr dezimiert wird, kommen sie dennoch näher an den Gangsterboss heran."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"The Raid - Uppgörelsen","runtime":101,"tagline":"","homepage":"http://nobleentertainment.com/movie/Serbuan_Maut","overview":"Ett SWAT-team planerar att infiltrera ett bostadshus i Jakartas slum fyllt av stadens farligaste gangsters och mördare ledda av den ondskefulle ledaren Tama. Metodiskt tar de sig genom huset - våning för våning - tills de upptäcks av Tamas hantlangare. Snart är jägarna bytet och de i teamet som fortfarande lever måste ta sig igenom en hord av blodtörstiga gangsters för att en gång för alla sätta stopp för Tamas skräckvälde."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Рейд","runtime":101,"tagline":"Спецназ против мафии. Брат против брата. 30 этажей ада","homepage":"","overview":"Отряд спецназовцев получает задание проникнуть в многоэтажный дом, расположенный в самом сердце трущоб Джакарты, и арестовать обосновавшегося там наркобарона, которого охраняет целая армия вооруженных до зубов головорезов. Операцию нужно провести без лишнего шума, но нелепая случайность нарушает планы служителей закона. Теперь бойцам негде спрятаться и некуда бежать. Перед ними 30 этажей ада, где смертью грозит каждый неверный шаг. Война по правилам кончилась. Выживает сильнейший!"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Baskın","runtime":0,"tagline":"1 acımasız baron, 20 elit polis, 30 kat cehennem.","homepage":"","overview":"Film, bir özel harekat timinin şehrin merkezinden uzak bir mahalledeki bir apartmanın uyuşturucu tüccarı olan sahibini yakalamak için kapıya dayanmasıyla başlıyor. Ancak her bir katı psikopatlar, katiller, çeteler ve hırsızlar için sığınak olmuş bu binaya daha önce hiç baskın düzenlenmemiştir. Haberin yayılmasıyla ışıklar söndürülür ve çıkışlar kapatılır. Vurucu timdeki polisler kısa bir süre sonra kapana kıstırılır ve acımasızca öldürülür. Hayatta kalan sadece bir avuç polis binada mahsur kalır. Kurtulabilmek için apartmanın en üst katına doğru ilerlemeleri gerekmektedir. 30 katı da ayrı bir cehennem olan binada yüzyılın savaşı başlar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"The Raid","runtime":101,"tagline":"1 seigneur du crime impitoyable, 20 flics d'élite, 30 étages d'enfer.","homepage":"","overview":"Au cœur des quartiers pauvres de Jakarta, se trouve une citadelle imprenable dans laquelle se cache le plus dangereux trafiquant du pays. Une équipe de policiers d’élite est envoyée donner l’assaut lors d’un raid secret mené aux premières lueurs du jour. Mais grâce à ses indics, le baron de la drogue est déjà au courant et a eu amplement le temps de se préparer. À l’instant où le groupe d’intervention pénètre dans l’immeuble, le piège se referme : les portes sont condamnées, l’électricité est coupée et une armée d’hommes surentrainés débarque. Piégés dans cet immeuble étouffant, les policiers vont devoir se battre étage après étage pour avoir une chance de survivre."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"The Raid: Redenção","runtime":101,"tagline":"1 Chefe Criminoso e Cruel, 20 Policias de Elite e 30 Andares de Inferno.","homepage":"","overview":"Em Jacarta, na Indonésia, o tenente Wahyu organiza a invasão a um prédio de apartamentos, onde fica a residência segura do poderoso e cruel traficante Tama e da sua gangue. A equipa da SWAT invade o edifício, mas um vigia vê e avisa os bandidos, e as forças policiais ficam encurraladas no sétimo andar. Os homens sob o comando do tenente Wahyu descobrem que este não informou os seus superiores sobre esta operação. Devido a tais circunstâncias, a equipa da SWAT tem que lutar com poucas munições, contra bandidos armados e perigosos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"The Raid: Redemption","runtime":100,"tagline":"","homepage":"","overview":"En indsatsstyrke stormer en 30-etagers bygning, som menes at huse en bandeleder samt hans hær af hensynsløse dræbere. Men elitestyrken er ikke forberedt på det kaos, der venter, da husets eksploderer i et intensivt voldsorgie.  Denne indonesiske actionfilm, instrueret af Gareth Evans (Merantau Warrior), er et langt action-volds orgie, der har fået filnørder over hele verdenen til at gå amok. Hvem har brug for en historie, når bare der er masser af automatvåben?"},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Zátah: Vykoupení","runtime":101,"tagline":"Speciální policejní komando má za úkol proniknout do přísně střeženého domu a zneškodnit šéfa gangu. Tým je však brzy prozrazen a zbytek nájemníků stojí před jednoduchou volbou. Když se nepřidají na policejní stranu, budou už navždy bydlet zadarmo...","homepage":"","overview":"Rama je mladý policista, který je povolán do nebezpečné akce. V chudinské čtvrti Jakarty je bytový dům, jehož horní patro obývá nebezpečný zločinec Tama Riyadi. Svůj dům pronajímá dalším zločincům, kteří mu ochotně slouží, žijí tam však i obyčejní lidé. Rama společně s dalšími asi dvaceti kolegy má za úkol nepozorovaně vniknout do domu a Tamu zlikvidovat, případně zajmout. Není to snadný úkol, dům je pomocí kamerového systému zcela pod zločincovou kontrolou. Když Tama zjistí, že mu do objektu vstoupili policisté, vyhlásí domovním rozhlasem, že každý, kdo pomůže zabít nezvané hosty, má od něj doživotní bydlení zadarmo. To je velké lákadlo, takže se rozpoutá velmi krutý boj na život a na smrt..."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"The Raid: Redemption","runtime":101,"tagline":"","homepage":"","overview":"Jakartaan sijoittuva tarina kertoo nuoresta poliisin erikoisjoukoissa työskentelevästä Ramasta, joka valmistautuu kersantti Jakan johdolla tekemään selvää paikallisesta rikoslordi Tama Riaydista, joka on pitänyt Jakartan alamaailmaa tiukassa otteessa kahden apualaisen Mad Dogin ja Andin kanssa. Tama Riaydi asuu 30-kerroksisen kerrostalon uumenissa. Jakan johtama erikoisjoukko saapuu kyseiselle talolle raskaasti aseistettuna ja melkein jokaisella on jotain hampaankolossa Tama Riaydia vastaan. Tietenkin tehtävä on luultua haasteellisempi, sillä rakennus on varsinainen linnake. Sen kaikkia käytäviä valvotaan ja ylimielinen Tama lietsoo kovaäänisen kautta talon asukkaita päästämään poliisit päiviltä. Vastineena hän lupaa ilmaisen vuokran ja toivottaa päälle työn iloa. Poliisit joutuvat luottamaan älyynsä ja aseettomaan taistelutaitoonsa selvitäkseen hengissä huipulle asti. Samalla alkaa myös valjeta, miksi poliisijohtaja Wahyulla on pakkomielle tappaa Tama."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Redada asesina (The Raid)","runtime":101,"tagline":"Cuando no hay ningún lugar para correr o esconderse... Tienes que luchar o morir.","homepage":"","overview":"Todo el mundo en Jakarta sabe que en los barrios bajos de la ciudad hay un edificio que sirve de refugio para los criminales más peligrosos de Indonesia. Algo así como una fortaleza del mal cuya leyenda crece día a día y a la que incluso la policía teme acercarse. Pese a ello, un grupo de fuerzas especiales de élite intentará derribar sus defensas y penetrar en sus entrañas. Pero la operación no sale según lo previsto, y los policías se encontrarán atrapados en el edificio, sin escapatoria posible y rodeados de asesinos y gángsters."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"突袭","runtime":101,"tagline":"","homepage":"","overview":"在雅加达的贫民窟的深处，世界上最危险的杀手和黑帮集结在一个坚不可摧的房子内。到现在为止，破旧的公寓甚至被神勇的警察也视为无法接近的。在黎明前黑暗和寂静的掩护下，一个身兼重要任务精英特警队与执法人员慢慢接近了房子，以便接近臭名昭著的毒枭。但他们袭击的消息被毒枭偶然发现，接 着建筑物的灯光被切断，所有的通道被堵。这群特警必须要在世界上最残酷的环境下为生存展开搏斗。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"The Raid: Redemption","runtime":101,"tagline":"","homepage":"","overview":"Een SWAT-team komt vast te zitten in een appartementencomplex, dat tot de nok toe volzit met bewapende drugsdealers en moordenaars. Terwijl het team zich een weg probeert te banen door het doolhof van kamers en etages, beginnen de genadeloze moordenaars een gevecht tegen de agenten."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"The Raid - Redenzione","runtime":101,"tagline":"","homepage":"http://merantaufilms.com/the-raid/","overview":"Giacarta, Indonesia. Un palazzo inespugnabile per la polizia è un vero e proprio covo dove si nascondono ladri, assassini o stupratori. Una squadra di Swat deve irrompere nell'edificio per arrestarne il proprietario, Tama, noto e potente signore della droga."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Raid","runtime":101,"tagline":"1 Bezwzględny Przestępca, 20 Policjantów, 30 Pięter Piekła","homepage":"","overview":"Elitarna jednostka SWAT wkracza do siedziby kartelu narkotykowego. Komandosi nie wiedzą, że wieżowiec zamieniono w twierdzę pełną bezwzględnych, brutalnych i świetnie przygotowanych do ataku przestępców. Oddział wpada w pułapkę. Jedyną szansą na ucieczkę jest przedarcie się przez trzydzieści pięter wieżowca.  [opis dystrybutora dvd]"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"ฉะ! ทะลุตึกนรก","runtime":100,"tagline":"","homepage":"","overview":"เรื่องราวของ จากา นายทหารผู้ไม่ใส่ใจกับลาภยศหรือตำแหน่งสูงๆ เขาเป็นทหารผู้อุทิศตนเพื่อต่อสู้กับอาชญากรรม จากาเป็นทหารผู้ผ่านประสบการณ์ต่างๆ ที่ซึ่งเขาได้เห็นเพื่อนร่วมทีมได้รับบาดเจ็บจนถึงชีวิตหรือถูกยิงตายต่อหน้าต่อตาเขา เขาเคยทำผิดพลาดมาแต่เขาก็ประสบความสำเร็จด้วยเช่นกัน แสดงให้เห็นว่าเขารู้ว่าเขาทำอะไรอยู่และเขาต้องทำอะไร ดังนั้น การบุกอาคาร 30 ชั้นก็ไม่ใช่เรื่องใหม่สำหรับเขา จาการู้ดีว่าการบุกอาคารแห่งนี้เป็นเรื่องเสี่ยงอันตรายอย่างมาก เขาก็เลยอยากทำให้แน่ใจว่าลูกทีมทั้งหมดของเขาจะรอดชีวิตจากภารกิจนี้น่ะ เพราะหนทางข้างหน้าคืออาชญากรตัวพ่อที่โฉดและโหดเป็นอย่างที่สุด"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"A rajtaütés","runtime":0,"tagline":"","homepage":"","overview":"Mélyen, Jakarta nyomornegyedének szívében áll egy bevehetetlen menedékház, a világ legveszedelmesebb gengszterei és gyilkosai lakják. Egészen mostanáig a lepusztult lakótelepi ház még a legelszántabb rendőrök számára is érinthetetlenként volt elkönyvelve. A pirkadat előtti sötétség és csend leple alatt egy elit kommandóra hárul a feladat, hogy rajtaüssön a menedékházon, annak érdekében, hogy elkapják a hírhedt drogbárót, aki működteti. Ám mikor a gengsztervezér hírét veszi a razziának, az épület fényeit lekapcsolják, a kijáratokat lezárják. A bevetési egység tagjai a hatodikon rekednek kiút nélkül. Az alakulatnak élethalálharcot kell vívnia a metropolisz legkeményebb helyén azért, hogy egyáltalán túléljék a küldetést."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Επιχείρηση: Χάος","runtime":101,"tagline":"1 αδίστακτος «εγκέφαλος» του εγκλήματος, 20 κορυφαίοι αστυνομικοί, 30 ορόφοι χάους.","homepage":"https://www.facebook.com/TheRaidUS","overview":"Μια επίλεκτη ομάδα ειδικών δυνάμεων έχει αναλάβει να εξοντώσει τον Tama, τον πιο αδίστακτο εγκληματία της Τζακάρτα που εδρεύει σε ένα τεράστιο ρημαγμένο κτίριο παρέα με δολοφόνους, βιαστές, ναρκομανείς και κλέφτες. Η αποστολή εκτός από μυστική είναι και η πρώτη που συμμετέχει ο Rama, ένα νεοσύλλεκτο μέλος της ομάδας των αστυνομικών. Όταν η αποστολή αποκαλύπτεται κι ο Tama υπόσχεται ασυλία σε όποιον προσφερθεί να σκοτώσει τους αστυνομικούς-εισβολείς, ο Rama θα χρειαστεί να επιστρατεύσει όλο του το θάρρος για να βγει ζωντανός από μια εφιαλτική δοκιμασία που τον περιμένει σε κάθε ένα από τους 30 ορόφους του κτιρίου."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"הפשיטה: הגאולה","runtime":0,"tagline":"","homepage":"","overview":"עמוק בתוך שכונות העוני של ג'קרטה שוכן בית מבטחים בלתי נגיש של הכנופיה המסוכנת והרצחנית בעולם. עד עכשיו בניין הדירות היה בלתי נגיש אפילו לשוטר האמיץ ביותר. יחידת עלית של המשטרה בהנהגתו של קצין בשם ראמה יוצאת בשקט במסווה החשכה לפני עלות השחר כדי לפשוט על בית המבטחים של הכנופיה ולהפיל את ראש הכנופיה, סוחר סמים בשם טאמה. אבל במהלך הפשיטה אחד מהתצפתינים מזהה את היחידה. ובכדי לסכל את הפשיטה הם מנתקים ומכבבים את כל אורות הבניין וחוסמים את כל היציאות. כעת היחידה מוצאת את עצמה כלואה בקומה השישית בלי דרך ברורה החוצה. הדרך היחידה לצאת מחוץ לבניין עוברת דרך הגרועים והמסוכנים ביותר מבין פושעי ג'קרטה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Рейд: Спокута","runtime":201,"tagline":"","homepage":"","overview":"Загін спецпризначення потрапив у пастку кримінального ватажка та його армії головорізів..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"ザ・レイド","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"레이드: 첫번째 습격","runtime":101,"tagline":"하나의 범죄조직, 20명의 특수경찰, 30층의 지옥.","homepage":"","overview":"10년 동안 경찰을 포함해 외부인의 습격을 단 한차례도 받아본 적이 없는 낡은 30층 아파트. 마치 치외법권 지역과도 같은 이곳에 모든 범죄의 정점에 서 있는 갱단의 보스 ‘타마’를 제거하라는 비밀 작전 수행을 위해 20명의 정예요원으로 구성된 SWAT 대원들이 출동, 건물 안으로 잠입한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Operação Invasão","runtime":101,"tagline":"1 Cruel Chefe Criminoso, 20 Policiais de Elite. 30 Andares de Inferno.","homepage":"","overview":"Em Jacarta, na Indonésia, o Tenente Wahyu organiza a invasão de um prédio que, depois de ser abandonado, se tornou o porto seguro do poderoso e cruel traficante Tama. Para desmontar esse ninho do crime, um time da SWAT invade o local, mas acaba preso numa armadilha no sexto andar. Surpreendidos pela notícia que o tenente Wahyu não informou seus superiores sobre a operação, os agentes resistem sozinhos e com munição limitada."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"全面突襲","runtime":101,"tagline":"","homepage":"","overview":"一支特警隊準備突襲一幫躲在30層高樓的毒販，打算在黎明前進行攻堅行動，剷除黑幫。但他們深入的是全世界最危險的殺手聚集地，特警隊在大樓中受到強烈反擊。他們無路可退，唯有殺出一條血路才能活命。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"突擊死亡塔","runtime":101,"tagline":"拳拳搏命 真打實鬥 史上最密集秒殺行動","homepage":"","overview":"RAMA (Iko Uwais 飾) 與 20 名特警好兄弟直搗龍潭突襲兇殘大毒梟，怎料卻遭到伏擊，被困在樓高 30 層的毒販大本營，為了生存也為完成任務，他們必須深入全世界最危險的殺手聚集地，殺出一條血路才能活命，頂樓的毒梟卻虎視眈眈，更派出手下殺人機器誓要將這班特警逐個擊破！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Đột Kích: Chuộc Tội","runtime":0,"tagline":"","homepage":"","overview":"Phim nói về 1 khu chung cư bị bỏ hoang ở Jarkata đã lâu. Khu nhà này trở thành 1 nơi mà đến lực lượng cảnh sát chưa bao giờ muốn đến thăm! Lợi dụng ngôi nhà bỏ hoang không ai thèm đến, các băng đảng và các nhóm buôn ma túy đã chọn nơi này làm cứ điểm của chúng. Trong đó đặc biệt nhất là trùm buôn ma túy khét tiếng Tama. Một đội SWAT được trang bị vũ khí tối tân để săn lùng và tiêu diệt tên trùm buôn ma túy khét tiếng Tama này. Liệu họ có thành công?"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"La Redada","runtime":101,"tagline":"","homepage":"","overview":"Todo el mundo en Jakarta sabe que en los barrios bajos de la ciudad hay un edificio que sirve de refugio para los criminales más peligrosos de Indonesia. Algo así como una fortaleza del mal cuya leyenda crece día a día y a la que incluso la policía teme acercarse. Pese a ello, un grupo de fuerzas especiales de élite intentará derribar sus defensas y penetrar en sus entrañas. Pero la operación no sale según lo previsto, y los policías se encontrarán atrapados en el edificio, sin escapatoria posible y rodeados de asesinos y gángsters."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Prepadovka","runtime":101,"tagline":"1 bezohľadný zločinecký boss, 20 elitných policajtov, 30 poschodí pekla.","homepage":"","overview":"Rama je mladý policajt, ​​ktorý je povolaný do nebezpečnej akcie. V chudobnej štvrti Jakarty je bytový dom, ktorého horné poschodie obýva nebezpečný zločinec Tama Riyadi. Svoj dom prenajíma ďalším zločincom, ktorí mu ochotne slúžia, žijú tam však aj obyčajní ľudia. Rama spoločne s ďalšími asi dvadsiatimi kolegami má za úlohu nepozorovane vniknúť do domu a Tamu zlikvidovať, prípadne zajať. Nie je to ľahká úloha, dom je pomocou kamerového systému úplne pod zločincovou kontrolou. Keď Tama zistí, že mu do objektu vstúpili policajti, vyhlási domovým rozhlasom, že každý, kto pomôže zabiť nepozvaných hostí, má od neho doživotné bývanie zadarmo. To je veľké lákadlo, takže sa rozpúta veľmi krutý boj na život a na smrť..."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"الغارة","runtime":0,"tagline":"1 لورد الجريمة الذي لا يرحم ، 20 من رجال الشرطة النخبة ، 30 طابق من الجحيم","homepage":"","overview":"في قلب الأحياء الفقيرة في جاكرتا ، يوجد منزل آمن لا يمكن اختراقه لأخطر القتلة ورجال العصابات في العالم. حتى الآن ، يعتبر المبنى السكني المتهالك غير قابل للمس حتى من أشجع رجال الشرطة. متخفيًا تحت غطاء الظلام والصمت قبل الفجر ، تم تكليف فريق من النخبة في سوات بمداهمة المنزل الآمن من أجل القضاء على أباطرة المخدرات سيئ السمعة الذي يديره. ولكن عندما تنفجر فرصة لقاء مصادفة بغطاءهم وتصل أخبار اعتداءهم إلى رب المخدرات ، تنقطع أضواء المبنى وتُغلق جميع المخارج. بعد أن تقطعت بهم السبل في الطابق السادس دون مخرج ، يجب أن تشق الوحدة طريقها عبر أسوأ ما في المدينة للنجاة من مهمتها. بطولة إحساس فنون الدفاع عن النفس الإندونيسي إيكو أويس."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Reidas: Atpirkimas","runtime":0,"tagline":"","homepage":"","overview":"Specialios paskirties policijos būrys gauna užduoti sulaikyti prekeivių narokitais gaują pačiame Džakartos centre. Trisdešimties aukštų pastate knibždėte knibžda ginkluotų nusikaltėlių. Kvailas atsitiktinumas sugriauna operaciją. Prasideda karas be jokių taisyklių. Dvidešimt kietų farų. Vienas išprotėjęs narkotikų baronas. Trisdešimt pragariškų aukštų."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"The Raid: Redemption","runtime":101,"tagline":"","homepage":"","overview":"Terperangkap dalam bangunan tenemen semasa serbuan, sepasukan SWAT harus mencari jalan untuk melawan konco raja dadah yang menjadi sasaran misi pembunuhan mereka."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"The Raid: Redemption","runtime":101,"tagline":"","homepage":"","overview":"Terperangkap dalam bangunan tenemen semasa serbuan, sepasukan SWAT harus mencari jalan untuk melawan konco raja dadah yang menjadi sasaran misi pembunuhan mereka."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"SG","english_name":"Malay"},{"data":{"title":"The Raid","runtime":100,"tagline":"","homepage":"","overview":"Et SWAT-team planlegger å infiltrere et bolighus i Jakartas slum fylt av byens farligste gangstere og mordere ledet av den hensynsløse lederen Jama. Metodisk tar de seg gjennom huset etasje for etasje til de blir oppdaget av Jamas håndlangere. Snart er jegerne byttet og de i teamet som fortsatt lever må komme seg forbi en horde av blodtørstige gangstere for å en gang for alle sette en stopper for Jamas skrekkvelde."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Raidul","runtime":0,"tagline":"","homepage":"","overview":"În inima mahalalelor din Jakarta se află un adăpost impenetrabil pentru cei mai periculoși criminali și gangsteri din lume. Până acum, blocul de apartamente dărăpănate a fost considerat de neatins chiar și de cei mai curajoși polițiști. Ascunsă sub acoperirea întunericului și a tăcerii de dinainte de răsărit, o echipă de elită SWAT este însărcinată să atace casa conspirativă pentru a-l doborî pe faimosul lord al drogurilor care o conduce. Dar când o întâlnire întâmplătoare cu un observator le distruge acoperirea și când vestea asaltului lor ajunge la lordul drogurilor, luminile clădirii sunt tăiate și toate ieșirile sunt blocate. Blocați la etajul șase, fără nicio ieșire, unitatea trebuie să se lupte cu cei mai răi oameni din oraș pentru a supraviețui misiunii lor. În rolul principal, senzația indoneziană a artelor marțiale Iko Uwais."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Racija","runtime":0,"tagline":"1 neusmiljen gospodar kriminala, 20 elitnih policistov, 30 nadstropij pekla.","homepage":"","overview":"Globoko v džakartskih slumih je stolpnica, zatočišče najnevarnejših gangsterjev in morilcev, ki ga celo najpogumnejši policisti dojemajo kot nedostopno. Elitna enota specialcev dobi nalogo prodreti v kriminalno gnezdo v močno zaščiteni 15-nadstropni stavbi in ujeti brutalnega šefa mamilarske združbe. Ko oboroženi kriminalci ubijejo Jako kot vodjo ekipe specialcev, mora mladi novinec Rama nenadoma prevzeti glavno vlogo. Njegov cilj: prebiti se skozi vsa nadstropja, izpolniti misijo in predvsem preživeti."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"}],"reviews_tmdb":[{"id":"525be58819c2951f1c08a3a9","url":"https://www.themoviedb.org/review/525be58819c2951f1c08a3a9","author":"Andres Gomez","content":"Oh, good, the plot, the dialogues and the performances of the characters are plainly terrible.\r\n\r\nOther than that, if you are looking for an action movie with tons of \"dancing\" fights, this is your movie.","created_at":"2013-10-14T12:37:28.915Z","updated_at":"2021-06-23T15:57:22.470Z","author_details":{"name":"Andres Gomez","rating":7,"username":"tanty","avatar_path":null}},{"id":"5c4718109251415e34504c88","url":"https://www.themoviedb.org/review/5c4718109251415e34504c88","author":"Gimly","content":"Despite being an early entry, _The Raid_ is arguably the most revolutionary action movie of the past decade. And the decade is almost over. Iko Uwais is clear talent when it comes to this sort of stunt work, and with the exception of a little too much shakey-cam near the start, you get a really look at him (and the rest of the cast) doing their thing, a lesson which the majority of Hollywood action movies nowadays apparently needs to re-learn.\r\n\r\n_Final rating:★★★★ - Very strong appeal. A personal favourite._","created_at":"2019-01-22T13:18:08.060Z","updated_at":"2021-06-23T15:58:16.315Z","author_details":{"name":"Gimly","rating":8,"username":"Ruuz","avatar_path":"/xUObnJSvHrFPsIpoDmb1jiQZLq7.jpg"}},{"id":"67beecdef9755fe09d5620ae","url":"https://www.themoviedb.org/review/67beecdef9755fe09d5620ae","author":"CinemaSerf","content":"$12","created_at":"2025-02-26T10:28:46.592Z","updated_at":"2025-02-26T10:32:10.596Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":180299,"adult":false,"title":"The Raid 2","video":false,"overview":"After fighting his way through an apartment building populated by an army of dangerous criminals and escaping with his life, SWAT team member Rama goes undercover, joining a powerful Indonesian crime syndicate to protect his family and uncover corrupt members of his own force.","genre_ids":[28,80,53],"media_type":"movie","popularity":3.5114,"vote_count":2527,"poster_path":"/olA39iaXISiKEkACdELgr0ZRvIF.jpg","release_date":"2014-03-27","vote_average":7.608,"backdrop_path":"/wJD1VaO6XMkOSAacUGLkzOKAd4D.jpg","original_title":"The Raid 2: Berandal","original_language":"id"},{"id":9316,"adult":false,"title":"Ong-Bak","video":false,"overview":"When the head of a statue sacred to a village is stolen, a young martial artist goes to the big city and finds himself taking on the underworld to retrieve it.","genre_ids":[28,80],"media_type":"movie","popularity":4.9599,"vote_count":1830,"poster_path":"/oagqAwp48dMPoCT94yDJUDOCVPi.jpg","release_date":"2003-01-31","vote_average":7.131,"backdrop_path":"/wdHIYawEp7lnf1XNzp6rWxLYgUG.jpg","original_title":"องค์บาก","original_language":"th"},{"id":403605,"adult":false,"title":"Headshot","video":false,"overview":"A young man washes ashore, his memory gone - but his past comes back to haunt him after he is nursed back to health and his killing ability is needed when he takes on a powerful drug lord.","genre_ids":[28,53,18],"media_type":"movie","popularity":2.2413,"vote_count":473,"poster_path":"/dpdmO3PNKwCOzf68y8J4Gu19i3r.jpg","release_date":"2016-09-24","vote_average":6.431,"backdrop_path":"/sEyYwNHJ6AO1Wnh0JuRTBmlZ8No.jpg","original_title":"Headshot","original_language":"id"},{"id":346808,"adult":false,"title":"Momentum","video":false,"overview":"When Alex, an infiltration expert with a secret past, accidentally reveals her identity during what should have been a routine heist, she quickly finds herself mixed up in a government conspiracy and entangled in a deadly game of cat-and-mouse with a master assassin and his team of killers.  Armed with her own set of lethal skills, Alex looks to exact revenge for her murdered friends while uncovering the truth.","genre_ids":[28,80,53],"media_type":"movie","popularity":1.5046,"vote_count":569,"poster_path":"/49bPrxvgwUqEtvOfvTe3x92hEFV.jpg","release_date":"2015-10-15","vote_average":5.655,"backdrop_path":"/7nYZxYAb1vkLd1a5i7qDcH5kBsK.jpg","original_title":"Momentum","original_language":"en"},{"id":10045,"adult":false,"title":"District B13","video":false,"overview":"Set in the ghettos of Paris in 2010, an undercover cop and ex-thug try to infiltrate a gang in order to defuse a neutron bomb.","genre_ids":[28,53,878],"media_type":"movie","popularity":5.5477,"vote_count":1950,"poster_path":"/uYIDJ15RLBsFFBSAkqjIirZCgVi.jpg","release_date":"2004-11-09","vote_average":6.809,"backdrop_path":"/dSbXXdDcnQFimUf1mhkPk5dkQU3.jpg","original_title":"Banlieue 13","original_language":"fr"},{"id":449985,"adult":false,"title":"Triple Threat","video":false,"overview":"A crime syndicate places a hit on a billionaire's daughter, making her the target of an elite assassin squad. A small band of down-and-out mercenaries protects her, fighting tooth and nail to stop the assassins from reaching their target.","genre_ids":[53,28],"media_type":"movie","popularity":2.7939,"vote_count":624,"poster_path":"/cSpM3QxmoSLp4O1WAMQpUDcaB7R.jpg","release_date":"2019-03-19","vote_average":6.424,"backdrop_path":"/AukoTjDSvjB4g0YTDxRNVwS4uFR.jpg","original_title":"Triple Threat","original_language":"en"},{"id":449992,"adult":false,"title":"The Night Comes for Us","video":false,"overview":"After sparing a girl's life during a massacre, an elite Triad assassin is targeted by an onslaught of murderous gangsters.","genre_ids":[28,80,53],"media_type":"movie","popularity":2.48,"vote_count":768,"poster_path":"/8lI1p5cPqgXN2qrKZrmI3mhKBfs.jpg","release_date":"2018-10-05","vote_average":6.879,"backdrop_path":"/9uoZrTXUiByDECmWopkIJhZxSzw.jpg","original_title":"The Night Comes for Us","original_language":"id"},{"id":77016,"adult":false,"title":"End of Watch","video":false,"overview":"Two young officers are marked for death after confiscating a small cache of money and firearms from the members of a notorious cartel during a routine traffic stop.","genre_ids":[80,18,53],"media_type":"movie","popularity":3.8381,"vote_count":3533,"poster_path":"/pDeVKQICkcdwwjHxGj0MeS14YJ6.jpg","release_date":"2012-09-20","vote_average":7.349,"backdrop_path":"/l53K8Fp1WcOMRL33CMsnnMUPiWg.jpg","original_title":"End of Watch","original_language":"en"},{"id":79108,"adult":false,"title":"Starbuck","video":false,"overview":"David Wozniak is a perpetual adolescent who discovers that, as a sperm donor, he has fathered 533 children. He is advised that more than 100 of his offspring are trying to force the fertility clinic to reveal the true identity of \"Starbuck,\" the pseudonym he used when donating his sperm. To make matters worse, his girlfriend Valérie is pregnant with his child, but doesn't feel that he is mature enough to be a father.","genre_ids":[35],"media_type":"movie","popularity":5.0538,"vote_count":464,"poster_path":"/t7ZyIR941krELzP7POiFUu0yhFq.jpg","release_date":"2011-07-27","vote_average":6.9,"backdrop_path":"/98SMte6G9hUxLpe2OZuF8UvJkTL.jpg","original_title":"Starbuck","original_language":"fr"},{"id":21453,"adult":false,"title":"Wicked City","video":false,"overview":"A peace treaty between the Earth and the Black World, a parallel universe of demons, is coming to an end. Two cops, Taki, a human male, and Maki, a female demon, are assigned to protect a diplomat who will help secure another treaty. A radical group of demons from the Black World are out to assassinate the diplomat and prevent the treaty; only the bond that forms between the two cops can save the Earth from destruction.","genre_ids":[16,14,27],"media_type":"movie","popularity":1.6162,"vote_count":280,"poster_path":"/aFtLwGv6pcqO72M1v5iQYZOCkZ5.jpg","release_date":"1987-04-19","vote_average":6.705,"backdrop_path":"/rmhhTF2fr8w6iNh8KHNi6EqWLZv.jpg","original_title":"妖獣都市","original_language":"ja"},{"id":448491,"adult":false,"title":"Little Forest","video":false,"overview":"A young woman leaves the city to return to her hometown in the countryside. Seeking to escape the hustle and bustle of the city, she becomes self-sufficient in a bid to reconnect with nature.","genre_ids":[18],"media_type":"movie","popularity":1.5267,"vote_count":172,"poster_path":"/gKmPuyjmALswSQUF94PWXoAvkKM.jpg","release_date":"2018-02-28","vote_average":7.602,"backdrop_path":"/vTw1MjLJfCFzFdq5iElKpjI0LIV.jpg","original_title":"리틀 포레스트","original_language":"ko"},{"id":33908,"adult":false,"title":"Three... Extremes","video":false,"overview":"Features an anthology centred on the experiences of a witch doctor, a film-maker and a disgruntled extra determined to take revenge on him, and a novelist as well as her twin sister.","genre_ids":[27],"media_type":"movie","popularity":0.9908,"vote_count":402,"poster_path":"/r0UzUF15suxLatzvNK3TQKxp10h.jpg","release_date":"2004-08-20","vote_average":6.779,"backdrop_path":"/lJ5lUT0yccP3ejklErN0HqlGMwv.jpg","original_title":"쓰리, 몬스터","original_language":"ko"},{"id":436391,"adult":false,"title":"The Battleship Island","video":false,"overview":"During the Japanese colonial era, roughly 400 Korean people, who were forced onto Battleship Island 'Hashima Island' to mine for coal, attempt to escape.","genre_ids":[28,36,18,10752],"media_type":"movie","popularity":2.3461,"vote_count":282,"poster_path":"/fBjgHOtN10glbcGRtqS76iKPYJ0.jpg","release_date":"2017-07-26","vote_average":7.149,"backdrop_path":"/sdgmx9smLbSdnR4bUNVNdcF0HHx.jpg","original_title":"군함도","original_language":"ko"},{"id":9742,"adult":false,"title":"Werner and the Wizard of Booze","video":false,"overview":"Comic artist Brösel trades a magic pen that helps him come up with funny stories for the promise to fulfill one of Rumpelstiltskin's wishes. The resulting animated films show episodes of the life of Werner, a plumber apprentice and motorbike enthusiast and his friends. They are interspersed with the live-action portions.","genre_ids":[16,35,28],"media_type":"movie","popularity":1.0277,"vote_count":186,"poster_path":"/vptblYAQRE8qrYJmYVnl6pSU7YA.jpg","release_date":"1990-11-29","vote_average":6.6,"backdrop_path":"/kZWSn5WgIUNwxLlUdSlaOwWJc1T.jpg","original_title":"Werner - Beinhart!","original_language":"de"},{"id":411736,"adult":false,"title":"Batman: Return of the Caped Crusaders","video":false,"overview":"Adam West and Burt Ward returns to their iconic roles of Batman and Robin. The film sees the superheroes going up against classic villains like The Joker, The Riddler, The Penguin and Catwoman, both in Gotham City… and in space.","genre_ids":[28,16,12,80,878,10751],"media_type":"movie","popularity":1.2871,"vote_count":288,"poster_path":"/i6qL5EYGXI4867S4KwZ1mPWvmTx.jpg","release_date":"2016-10-08","vote_average":6.488,"backdrop_path":"/oBwzYKdcbT7K8CEkKDbTspPAJkG.jpg","original_title":"Batman: Return of the Caped Crusaders","original_language":"en"},{"id":4786,"adult":false,"title":"Rudo & Cursi","video":false,"overview":"Tato and Beto are poor stepbrothers living on a banana plantation in Mexico. Both are talented soccer players, but their dreams lay elsewhere: tone-deaf Tato wants to be a singer, while Beto is content to remain on the plantation. One day, a sports agent sees the two young men playing soccer and offers to take one of them to Mexico City for a chance at sports stardom.","genre_ids":[35,18],"media_type":"movie","popularity":0.6076,"vote_count":220,"poster_path":"/2J3puhJdawCVeVKLDXTpgY4TAl3.jpg","release_date":"2008-12-19","vote_average":7,"backdrop_path":"/bmjo4w9MoLag2BjayBIHCAl0w0e.jpg","original_title":"Rudo y Cursi","original_language":"es"},{"id":284289,"adult":false,"title":"Beyond the Reach","video":false,"overview":"A high-rolling corporate shark and his impoverished young guide play the most dangerous game during a hunting trip in the Mojave Desert.","genre_ids":[53],"media_type":"movie","popularity":1.6695,"vote_count":395,"poster_path":"/t6m6ICEG7KrnyYQpROISURkuCD5.jpg","release_date":"2014-09-06","vote_average":5.901,"backdrop_path":"/a0wiBOMVRkGaj5gjWFVJ2TTBLHB.jpg","original_title":"Beyond the Reach","original_language":"en"},{"id":10705,"adult":false,"title":"Henry V","video":false,"overview":"In 1415, in the midst of the Hundred Years' War, the young King Henry V of England embarks on the conquest of France.","genre_ids":[10752,18,36],"media_type":"movie","popularity":1.8656,"vote_count":402,"poster_path":"/w9R2HsYNnfF3m9uEo2UAmPNJr8a.jpg","release_date":"1989-10-05","vote_average":7.146,"backdrop_path":"/uAIsWqlLwsL5YN40HYce04wz7Xb.jpg","original_title":"Henry V","original_language":"en"},{"id":347689,"adult":false,"title":"Pee-wee's Big Holiday","video":false,"overview":"A fateful meeting with a mysterious stranger inspires Pee-wee Herman to take his first-ever holiday.","genre_ids":[12,35,10751],"media_type":"movie","popularity":0.7449,"vote_count":247,"poster_path":"/k5bZS2NsgVswuThBfyJYaV6T6zu.jpg","release_date":"2016-03-15","vote_average":6.089,"backdrop_path":"/6UWkQY3osYYH70kzHCxAtadzE4e.jpg","original_title":"Pee-wee's Big Holiday","original_language":"en"},{"id":362046,"adult":false,"title":"4Got10","video":false,"overview":"Brian Barnes (Johnny Messner) wakes up in the desert wounded and with no memory and no idea why he's surrounded by eight bodies, a van with four million in cash and a van full of cocaine. Brian is pursued by not only notorious drug lord Danny Perez (Danny Trejo) who desperately want his money back, and DEA Agent Rooker (Dolph Lundgren), but also a by the corrupt Sheriff Olson (Michael Pare) who will stop at nothing to get his hand on the new found fortune. On the run, Brian discovers the more he remembers the less he wants to know about who he really is.","genre_ids":[28],"media_type":"movie","popularity":0.5061,"vote_count":104,"poster_path":"/A8UEl6UEg8ZgXJ5ZJpPcjfzggkz.jpg","release_date":"2015-09-11","vote_average":5.135,"backdrop_path":"/eykpPHuG4lNeIYEJ6gBz5rxYjou.jpg","original_title":"4Got10","original_language":"en"}],"similar_content":[{"id":8202,"adult":false,"title":"Æon Flux","video":false,"overview":"400 years into the future, disease has wiped out the majority of the world's population, except one walled city, Bregna, ruled by a congress of scientists. When Æon Flux, the top operative in the underground 'Monican' rebellion, is sent on a mission to kill a government leader, she uncovers a world of secrets.","genre_ids":[878,28,53],"popularity":4.3601,"vote_count":2400,"poster_path":"/5958Nt4QX6aRSUdQnvNw8wqjTJQ.jpg","release_date":"2005-11-30","vote_average":5.644,"backdrop_path":"/uTqxyztRGHSq96JYhByyNFuqqld.jpg","original_title":"Æon Flux","original_language":"en"},{"id":8439,"adult":false,"title":"Bus 174","video":false,"overview":"Documentary depicts what happened in Rio de Janeiro on June 12th 2000, when bus 174 was taken by an armed young man, threatening to shoot all the passengers. Transmitted live on all Brazilian TV networks, this shocking and tragic-ending event became one of violence's most shocking portraits, and one of the scariest examples of police incompetence and abuse in recent years.","genre_ids":[99,80],"popularity":1.2513,"vote_count":140,"poster_path":"/30v64yPfBbNSmnYHShExuWlXUJh.jpg","release_date":"2002-10-22","vote_average":7.311,"backdrop_path":"/purLFx9MR327mRclyc4sFYjE1cv.jpg","original_title":"Ônibus 174","original_language":"pt"},{"id":8456,"adult":false,"title":"Never Back Down","video":false,"overview":"Jake, full of anger after his father's death, is just starting to find a place for himself at his new Orlando high school - until Ryan, head of an underground MMA fight club, picks Jake out as a prime opponent. After being trounced by Ryan in front of the entire school, Jake begins training under the firm, moral guidance of a MMA master, where he learns how to fight... and how to avoid a fight. But it becomes obvious that a rematch will be inevitable if Jake wants to stop Ryan and his bullying, once and for all.","genre_ids":[18,28],"popularity":4.4077,"vote_count":2442,"poster_path":"/8oRUTyP1QAtGDMvRpKZyuyFPG0U.jpg","release_date":"2008-03-04","vote_average":6.8,"backdrop_path":"/h71xyiurUscD6uIPbECyso1Lwb9.jpg","original_title":"Never Back Down","original_language":"en"},{"id":8512,"adult":false,"title":"Devil in a Blue Dress","video":false,"overview":"In late 1940s Los Angeles, Easy Rawlins is an unemployed black World War II veteran with few job prospects. At a bar, Easy meets DeWitt Albright, a mysterious white man looking for someone to investigate the disappearance of a missing white woman named Daphne Monet, who he suspects is hiding out in one of the city's black jazz clubs. Strapped for money and facing house payments, Easy takes the job, but soon finds himself in over his head.","genre_ids":[53,80,9648],"popularity":3.0907,"vote_count":444,"poster_path":"/5lcJhwKGavLbPva17QkTBhLfqEk.jpg","release_date":"1995-09-29","vote_average":6.45,"backdrop_path":"/n6SFCz0OsyZ800ZSlaD5WpNmqCj.jpg","original_title":"Devil in a Blue Dress","original_language":"en"},{"id":8584,"adult":false,"title":"Shanghai Noon","video":false,"overview":"Chon Wang, a clumsy imperial guard, trails Princess Pei Pei when she's kidnapped from the Forbidden City and transported to America. Wang follows her captors to Nevada, where he teams up with an unlikely partner, outcast outlaw Roy O'Bannon, and tries to spring the princess from her imprisonment.","genre_ids":[12,28,35,37],"popularity":5.2033,"vote_count":2708,"poster_path":"/b0WwWRcDiDahkah5vZ0KjB4N9ZZ.jpg","release_date":"2000-05-26","vote_average":6.414,"backdrop_path":"/x4dH86KvLTGlIBMQb7kNTB0svy5.jpg","original_title":"Shanghai Noon","original_language":"en"},{"id":8592,"adult":false,"title":"Dick Tracy","video":false,"overview":"The comic strip detective finds his life vastly complicated when Breathless Mahoney makes advances towards him while he is trying to battle Big Boy Caprice's united mob.","genre_ids":[12,35,80],"popularity":4.6454,"vote_count":1012,"poster_path":"/sjeP4bpgsUvAGE8oFcICy2GaHxw.jpg","release_date":"1990-04-05","vote_average":6.147,"backdrop_path":"/zkIMr5t0B95nZPhY4AvI4v3qYH.jpg","original_title":"Dick Tracy","original_language":"en"},{"id":661668,"adult":false,"title":"The Last Eve","video":false,"overview":"\"The Last Eve\" is a film that takes the audience on an emotional adventure through history. In a way never before seen, the story of Eve is shown from front to back. We start in the future and ride all the way back to the loss of all innocence. Our ride through time shows us three greatly contrasting tales that in their own unique ways reveal the dark tragedy at the heart of all romance.","genre_ids":[14,28,878],"popularity":0.1377,"vote_count":1,"poster_path":"/aEY1RbKt5t18UbGsVt20zrFHkgo.jpg","release_date":"2004-12-14","vote_average":6,"backdrop_path":null,"original_title":"The Last Eve","original_language":"en"},{"id":8382,"adult":false,"title":"Today You Die","video":false,"overview":"A former thief who is trying to go straight seeks vengeance on those who framed him.","genre_ids":[28,80,12,53],"popularity":0.8781,"vote_count":121,"poster_path":"/fSL56vXRp4Qh23vXPiAhJMFKZgB.jpg","release_date":"2005-09-13","vote_average":4.3,"backdrop_path":"/9XpbzvX38LUi21QYvBlVyp3yBMv.jpg","original_title":"Today You Die","original_language":"en"},{"id":661617,"adult":false,"title":"The Chinese Tiger","video":false,"overview":"The \"Organization\" will go to any lengths to sell their drugs. But this time, they made a mistake... a big mistake. They never counted on The Chinese Tiger, Master of Kung-Fu.","genre_ids":[28,80],"popularity":0.1259,"vote_count":0,"poster_path":"/3gsWD4OLhX8ziYRVuUqaC7TxYfR.jpg","release_date":"1974-07-19","vote_average":0,"backdrop_path":null,"original_title":"Tong shan meng hu","original_language":"zh"},{"id":8831,"adult":false,"title":"Timecop","video":false,"overview":"In 2004, an officer for a security agency that regulates time travel must fend for his life against a shady politician who has a tie to his past.","genre_ids":[53,878,28,80],"popularity":2.6426,"vote_count":1275,"poster_path":"/bgxP6ws8ErBiarnb4S93vv0lkf4.jpg","release_date":"1994-09-15","vote_average":6.005,"backdrop_path":"/iNfDwioDBzqodomLbMfV8ZXj0yL.jpg","original_title":"Timecop","original_language":"en"},{"id":8845,"adult":false,"title":"Under Siege","video":false,"overview":"A disgruntled ex-CIA operative, his assistant and their assembled group of terrorists seize a battleship with nuclear blackmail in mind. They've planned for every contingency but ignore the ship's cook, former Navy SEAL Casey Ryback—an error that could be fatal.","genre_ids":[28,53],"popularity":3.1849,"vote_count":1679,"poster_path":"/myHxm9p8fhEsXyaLO6DawYJKolg.jpg","release_date":"1992-10-08","vote_average":6.292,"backdrop_path":"/ihBDaN7OwT7D9DVri8SmxCnuRLB.jpg","original_title":"Under Siege","original_language":"en"},{"id":8961,"adult":false,"title":"Bad Boys II","video":false,"overview":"Detectives Marcus Burnett and Mike Lowrey of the Miami Narcotics Task Force are tasked with stopping the flow of the drug Ecstasy into Miami. They track the drugs to the whacked-out Cuban drug lord Johnny Tapia, who is also involved in a bloody war with Russian and Haitian mobsters. If that isn't bad enough, there's tension between the two detectives when Marcus discovers that playboy Mike is secretly romancing Marcus’ sister, Syd.","genre_ids":[28,80,35],"popularity":6.4976,"vote_count":5826,"poster_path":"/yCvB5fG5aEPqa1St7ihY6KEAsHD.jpg","release_date":"2003-07-18","vote_average":6.655,"backdrop_path":"/gxSVZCUlDd8upT1G2wdrUdz2hxG.jpg","original_title":"Bad Boys II","original_language":"en"},{"id":8978,"adult":false,"title":"Assault on Precinct 13","video":false,"overview":"On New Year's Eve, inside a police station that's about to be closed for good, officer Jake Roenick must cobble together a force made up cops and criminals to save themselves from a mob looking to kill mobster Marion Bishop.","genre_ids":[53,28,12,80],"popularity":1.2115,"vote_count":1172,"poster_path":"/oBpsRvMN1ONl8oFHuWt1rasDYFJ.jpg","release_date":"2005-01-19","vote_average":6.179,"backdrop_path":"/2c0Ls3EwFoWJWVqWuaMyCUAgmzD.jpg","original_title":"Assault on Precinct 13","original_language":"en"},{"id":8856,"adult":false,"title":"The Karate Kid Part II","video":false,"overview":"Summoned by his dying father, Miyagi returns to his homeland of Okinawa, with Daniel, after a 40-year exile. There he must confront Yukie, the love of his youth, and Sato, his former best friend turned vengeful rival. Sato is bent on a fight to the death, even if it means the destruction of their village. Daniel finds his own love in Yukia's niece, Kumiko, and his own enemy in Sato's nephew, the vicious Chozen. Now, far away from the tournaments, cheering crowds and safety of home, Daniel will face his greatest challenge ever when the cost of honor is life itself.","genre_ids":[12,18,28,10749,10751],"popularity":3.5398,"vote_count":2416,"poster_path":"/k0OwgRR6PNu7h3SiqpCbRdZWNaG.jpg","release_date":"1986-06-18","vote_average":6.335,"backdrop_path":"/7rfcRXbFD0xr8NteNq1hwXUd4Af.jpg","original_title":"The Karate Kid Part II","original_language":"en"},{"id":277690,"adult":false,"title":"Yasmine","video":false,"overview":"Yasmine, a high school student from Brunei, fed up with studying and her strict father, decides to learn silat, a martial art practiced in Southeast Asia, after a boy displays his own knowledge of silat in order to impress her.","genre_ids":[18,28],"popularity":0.2021,"vote_count":8,"poster_path":"/mIc30cgSPATaF0bPNT10zT21gdO.jpg","release_date":"2014-08-16","vote_average":6.75,"backdrop_path":"/nwcXG0QnS5aeJDYQ7ozTDVeiL8V.jpg","original_title":"Yasmine","original_language":"ms"},{"id":8814,"adult":false,"title":"Doom","video":false,"overview":"A team of space marines known as the Rapid Response Tactical Squad, led by Sarge, is sent to a science facility on Mars after somebody reports a security breach. There, they learn that the alert came after a test subject, a mass murderer purposefully injected with alien DNA, broke free and began killing people. Dr. Grimm, who is related to team member Reaper, informs them all that the chromosome can mutate humans into monsters -- and is highly infectious.","genre_ids":[28,27,878],"popularity":4.2513,"vote_count":2383,"poster_path":"/y50lH061yWOvEstoZRn7lYs0huk.jpg","release_date":"2005-10-20","vote_average":5.181,"backdrop_path":"/9EpgaLS44zlXoTSAOhGiJmkIA4B.jpg","original_title":"Doom","original_language":"en"},{"id":9303,"adult":false,"title":"Bound","video":false,"overview":"Corky, a tough female ex-convict working on an apartment renovation in a Chicago building, meets a couple living next door, Caesar, a paranoid mobster, and Violet, his seductive girlfriend, who is immediately attracted to her.","genre_ids":[18,53,80],"popularity":4.3521,"vote_count":1053,"poster_path":"/9qAy6UWVw44dGrsyKrdEMt5qIUM.jpg","release_date":"1996-09-13","vote_average":7.22,"backdrop_path":"/k1HwxcuoCrKzfZ4UbU1fnNKgXGV.jpg","original_title":"Bound","original_language":"en"},{"id":9312,"adult":false,"title":"Mortal Kombat","video":false,"overview":"For nine generations an evil sorcerer has been victorious in hand-to-hand battle against his mortal enemies. If he wins a tenth Mortal Kombat tournament, desolation and evil will reign over the multiverse forever. To save Earth, three warriors must overcome seemingly insurmountable odds, their own inner demons, and superhuman foes.","genre_ids":[28,14],"popularity":3.1524,"vote_count":2462,"poster_path":"/fcK7tzSSXMYiMN8E9KlZJL1BYyp.jpg","release_date":"1995-08-18","vote_average":5.874,"backdrop_path":"/dfU9xyEEyLxvZ5unTn05Whm9Lce.jpg","original_title":"Mortal Kombat","original_language":"en"},{"id":9320,"adult":false,"title":"The Avengers","video":false,"overview":"British Ministry agent John Steed, under direction from \"Mother\", investigates a diabolical plot by arch-villain Sir August de Wynter to rule the world with his weather control machine. Steed investigates the beautiful Doctor Mrs. Emma Peel, the only suspect, but simultaneously falls for her and joins forces with her to combat Sir August.","genre_ids":[28,12,53,878,35],"popularity":2.7429,"vote_count":763,"poster_path":"/1p5thyQ4pCy876HpdvFARqJ62N9.jpg","release_date":"1998-08-13","vote_average":4.44,"backdrop_path":"/nMjfRk5SBNuxT01f5FYO5rJLwnI.jpg","original_title":"The Avengers","original_language":"en"},{"id":9053,"adult":false,"title":"DOA: Dead or Alive","video":false,"overview":"Four beautiful rivals at an invitation-only martial-arts tournament join forces against a sinister threat. Princess Kasumi is an aristocratic warrior trained by martial-arts masters. Tina Armstrong is a wrestling superstar. Helena Douglas is an athlete with a tragic past. Christie Allen earns her keep as a thief and an assassin-for-hire.","genre_ids":[12,28,53],"popularity":2.3784,"vote_count":895,"poster_path":"/gtlai95IERRDgRhPCK0WEuwCRP0.jpg","release_date":"2006-09-07","vote_average":5.256,"backdrop_path":"/m9mdYhZgowQjuF9LQwkoJLMInGf.jpg","original_title":"DOA: Dead or Alive","original_language":"en"}],"external_ids":{"imdb_id":"tt1899353","twitter_id":null,"facebook_id":null,"wikidata_id":"Q1573662","instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148483,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,