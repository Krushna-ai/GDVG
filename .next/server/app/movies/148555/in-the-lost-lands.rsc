:0,"aspect_ratio":0.667,"vote_average":0},{"width":960,"height":1280,"file_path":"/z7Bd1qN9AvjAshc45gwxfwwxq7y.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.75,"vote_average":0},{"width":1000,"height":1426,"file_path":"/lbAQpohMZnxCg5FEhSO0HzNekle.jpg","iso_639_1":"ka","iso_3166_1":"GE","vote_count":0,"aspect_ratio":0.701,"vote_average":0},{"width":1920,"height":2880,"file_path":"/g55mtoKdGA6dZpOEODkY2FYXir2.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":989,"height":1417,"file_path":"/e6gZUW5IJrtKxmzSrL1oHFpMcjI.jpg","iso_639_1":"ko","iso_3166_1":"KR","vote_count":0,"aspect_ratio":0.698,"vote_average":0},{"width":900,"height":1350,"file_path":"/mCDvZaILBJEO4G3NRXciQ5wePUH.jpg","iso_639_1":"th","iso_3166_1":"TH","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1356,"height":1918,"file_path":"/7gztLl8G4OKCNe6M9v6VVR1ruZM.jpg","iso_639_1":"cs","iso_3166_1":"CZ","vote_count":0,"aspect_ratio":0.707,"vote_average":0},{"width":1920,"height":2560,"file_path":"/252PUa4vgH06085IqkgHlmTyFfH.jpg","iso_639_1":"pl","iso_3166_1":"PL","vote_count":0,"aspect_ratio":0.75,"vote_average":0},{"width":604,"height":854,"file_path":"/zxqZ6oqSEzJNve1c6jmmrzmsNTt.jpg","iso_639_1":"pl","iso_3166_1":"PL","vote_count":0,"aspect_ratio":0.707,"vote_average":0},{"width":900,"height":1350,"file_path":"/d7gEVDPrizImLsKhER19YYq3gGc.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":900,"height":1350,"file_path":"/UnknVxN6De38nzFpx2nIn0Jk3j.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":2831,"file_path":"/iL7XhmTUpBHocjGumilOawM4n4Z.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":0.706,"vote_average":0},{"width":2000,"height":3000,"file_path":"/5Egony6PSMQV53O1FHzWATYaVWA.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":0.667,"vote_average":0}]