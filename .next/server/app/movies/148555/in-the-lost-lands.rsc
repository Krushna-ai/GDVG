"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/6aMwAAw42szeNqUyUUf1Qkwss4M.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1390,"height":782,"file_path":"/tlYUC8gOtVKdYNjkEG8ogkJi0fO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.777,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/cKhDW95ytJo39ma6VFNfU7MbXhl.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/rFZsAWrsYRjf8hy6cvApshjRzg3.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2765,"height":1555,"file_path":"/l1pLH7IZkKbKj9gnFXyIkbY9Mva.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/TzpFgzLkPC4aZjQ70OHKeRWbGI.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/2Hd2QLBelHGIGhAVLMeXBNfcP6S.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/qegmjRNzQKLHPBhjx5RcwTj7Xst.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/uxs6N1G0RxVmVIzIDKpqCxx2Wfo.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/dJTP3krJQWuolp5imZbfuiJycfS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/2MFWFRiDnGBTb7NUNlZIBwQ7Sbe.jpg","iso_639_1":"zh","iso_3166_1":"HK","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/spLQWk9i1hg9BBbng2rWl8dHttj.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/xvIMiYOKKT5qmnQ8GxsMGMv29GX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/eiPInBYlUOhDf5HQjWDxZx7FMVq.jpg","iso_639_1":"zh","iso_3166_1":"HK","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/yRG3Hza91z5VS9R4TzYt1PqJ81E.jpg","iso_639_1":"fr","iso_3166_1":"CA","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/2ZSSYtT5zyJ65wCe44s4Zrv5faP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/1ksV1zkqS2eGxMkKmZ36PMFKEkq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/dXknveVKO29gAx6bMNIA6GDuS3m.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/78XmERzRzmdmEsOnzf7okzuF66b.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/8DRBOpEaoA3MoFulbeLbZaT6RQI.jpg","iso_639_1":"pl","iso_3166_1":"PL","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/7hAt7KirNzdgatsuvk5m5NPlSsF.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/nS9hCFcZHIpKmPlvStNOlyaGrBi.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T03:50:45.719+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":102,"tagline":"She seeks the power to free her people.","homepage":"https://inthelostlands.com","overview":"A queen sends the powerful and feared sorceress Gray Alys to the ghostly wilderness of the Lost Lands in search of a magical power, where she and her guide, the drifter Boyce, must outwit and outfight both man and demon."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"В потерянных землях","runtime":101,"tagline":"","homepage":"","overview":"После гибели техногенной цивилизации в мир вернулись магия и монстры. По тайному заданию королевы ведьма Серая Элис отправляется из последнего города Земли в опасные Потерянные земли. Вместе с проводником Бойсом ей предстоит до полной Луны найти источник силы, что может обращать человека в зверя. Путников преследует безжалостная армия крестоносцев, а за каждым поворотом поджидают порождения тьмы."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Tierras Perdidas","runtime":0,"tagline":"","homepage":"","overview":"Una reina, desesperada por obtener el don de cambiar de forma, hace una jugada audaz: contrata a la hechicera Gray Alys, una mujer tan temida como poderosa. Enviada al desierto fantasmal de las Tierras Perdidas, Alys y su guía, el vagabundo Boyce, deben burlar y luchar contra el hombre y el demonio en una fábula que explora la naturaleza del bien y el mal, la deuda y la satisfacción, el amor y la pérdida."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Nas Terras Perdidas","runtime":101,"tagline":"Ela busca o poder para libertar seu povo.","homepage":"https://www.diamondfilms.com.br/filmes/nas-terras-perdidas","overview":"Uma rainha, desesperada para ganhar o dom da mudança de forma, toma uma atitude ousada: contrata a feiticeira Gray Alys, uma mulher tão temida quanto poderosa. Enviada para a selva fantasmagórica das Terras Perdidas, Alys e seu guia, o andarilho Boyce, devem enganar e lutar contra o homem e o diabo em uma fábula que explora a natureza do bem e do mal, da dívida e da satisfação, do amor e da perda."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Tierras perdidas","runtime":0,"tagline":"Ella busca el poder para liberar a su pueblo.","homepage":"","overview":"Basada en el relato de George R. R. Martin. Una reina (Amara Okereke), desesperada por encontrar la felicidad en el amor, envía a la poderosa bruja Gray Alys (Milla Jovovich) a las Tierras Perdidas, en busca de un poder mágico que permite a una persona transformarse en un hombre lobo. Con el misterioso cazador Boyce (Dave Bautista), que la apoya en la lucha contra criaturas oscuras y despiadadas, Gray deambula por un mundo inquietante y peligroso. Pero solo ella sabe que, cada deseo que se concede, tiene consecuencias inimaginables."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Kayıp Dünya","runtime":0,"tagline":"","homepage":"","overview":"Bu fantastik macera, aynı adı taşıyan George R.R. Martin öykülerinden uyarlanmıştır. Bir büyücü, Kayıp Diyarlar’a doğru yolculuk eder. Amacı, bir kişinin kurt adam dönüşümüne olanak tanıyan sihirli bir gücü bulmaktır. Bu mistik hikâye, iyilik ve kötülük, borç ve tatmin, aşk ve kayıp gibi temaları keşfeder. Büyü ve yaratıklarla dolu bu dünyada, büyücü Alys ve rehberi, gezgin Boyce, insanlar ve iblislerle mücadele ederken zorlu bir yolculuğa çıkarlar. Büyülü bir dünyada gerilim ve macera dolu bir yolculuğa katılın."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Vùng Đất Bị Quên Lãng","runtime":0,"tagline":"","homepage":"","overview":"Một nữ hoàng đã phái nữ phù thủy quyền năng và đáng sợ Gray Alys đến vùng đất ma quái Lost Lands để tìm kiếm sức mạnh ma thuật, nơi cô và người hướng dẫn của mình, kẻ lang thang Boyce, phải đánh bại cả con người và ác quỷ."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":101,"tagline":"Elle cherche le pouvoir pour libérer son peuple.","homepage":"https://www.inthelostlands.com/","overview":"Une reine pactise avec la puissante et redoutée sorcière Gray Alys afin qu’elle lui rapporte un trésor capable de lui conférer un pouvoir immense. Alys et son guide, le vagabond Boyce, doivent s’aventurer dans les dangereuses Contrées Perdues. Là, ils devront déjouer et combattre hommes et démons pour honorer leur part du contrat…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Čarodějnice a lovec","runtime":0,"tagline":"","homepage":"","overview":"Svět se změnil k nepoznání. Lidstvo je téměř vyhlazeno a přeživší se ukrývají v posledním útočišti – Městě pod horou. Za jeho hradbami se rozprostírají Pusté země, děsivá území plná nebezpečí. V těchto ruinách vládnou nestvůry a mýtičtí tvorové, kteří povstali z temnot po pádu lidstva. Nejvíce obávaným z nich je vlkodlak. V zoufalé touze po svobodě vyšle královna mocnou čarodějku Gray Alys do nehostinných Pustých zemí, aby odhalila tajemství vlkodlačí přeměny. Na cestě plné nástrah a děsivých tvorů ji doprovází neohrožený dobrodruh Boyce. Společně musí čelit nejen hordě smrtících nepřátel…"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"У загублених землях","runtime":90,"tagline":"","homepage":"","overview":"Старий світ давно загинув, і на Загублених Землях тепер новий порядок, в якому чужинцям міста немає. Відьма Грей Еліс та найманець Бойз об’єднуються заради власної місії на просторах Загублених Земель."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"U izgubljenim zemljama","runtime":0,"tagline":"","homepage":"","overview":"Kraljica koja je očajna u pokušaju da ostvari svoju ljubav, povlači smion potez: šalje moćnu i zastrašujuću čarobnicu Gray Alys u sablasnu divljinu Izgubljenih zemalja u potrazi za magičnom moći. Tamo čarobnica i njezin vodič, lutalica Boyce, moraju nadmudriti i nadjačati ljude i demone."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"ארץ האבודים","runtime":0,"tagline":"","homepage":"","overview":"סרט פעולה-הרפתקאות-פנטזיה המבוסס על סיפור מאת ג'ורג' ר. ר. מרטין ('משחקי הכס'). מכשפה יוצאת למסע לארץ האבודים במרדף אחר כוח נדיר המאפשר למחזיקים בו לשנות צורה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Prarastose žemėse","runtime":101,"tagline":"","homepage":"","overview":"Desperatiškai meilės trokštančios karalienės Melanžos pavedimu ragana vardu Pilkoji Alisa leidžiasi į itin pavojingą kelionę su dar pavojingesne užduotimi. Ragana turi keliauti į Prarastąsias Žemes ir ten surasti bei karalienei parnešti paslaptingą magišką dovaną, leidžiančią žmogui pavirsti vilkolakiu.\r Savo pasaulyje visas gyvas būtybes bauginanti ragana Prarastosiose Žemėse pati jaučiasi nejaukiai – čia knibždėte knibžda paslaptingų tamsos padarų, ką jau kalbėti apie tykančius priešus. Į magiškojo talismano paieškas ragana pasikviečia ir medžiotoją-vienišių Boisą. Visgi, kad ir nebe viena, vykdydama pavestą misiją, Pilkoji Alisa nepaliauja baimintis. Ji puikiai žino, kad ši karalienės užgaida turi neįsivaizduojamai šiurpias pasekmes..."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Čarodejnica a lovec","runtime":0,"tagline":"","homepage":"","overview":"Svet sa zmenil na nepoznanie. Ľudstvo je takmer vyhladené a tí, ktorí prežili, sa ukrývajú v poslednom útočisku - v Meste pod horou. Za jeho múrmi sa rozprestiera Pustatina, desivá krajina plná nebezpečenstva. Týmto ruinám vládnu príšery a mýtické bytosti, ktoré povstali z temnoty po páde ľudstva. Najobávanejším z nich je vlkolak. Kráľovná, ktorá zúfalo túži po slobode, vyšle do nehostinných Pustín mocnú čarodejnicu Gray Alys, aby odhalila tajomstvo vlkodlačej premeny. Na ceste plnej nástrah a desivých tvorov ju sprevádza nebojácny dobrodruh Boyce. Spoločne musia čeliť nielen hordám smrtiacich nepriateľov."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"در سرزمین های گمشده","runtime":0,"tagline":"","homepage":"","overview":"ملکه ای که ناامید از یافتن خوشبختی در عشق است، گامی جسورانه برمیدارد: او جادوگر قدرتمند و ترسناک گری آلیس را به سرزمین های گمشده می فرستد تا به او هدیه جادویی تبدیل شدن به گرگینه را بدهد. گری آلیس با شکارچی مرموز بویس که از او در مبارزه با موجودات تاریک و دشمنان بی رحم حمایت می کند، در دنیایی ترسناک و خطرناک پرسه می زند. و فقط او می داند که هر آرزویی که برآورده می کند عواقب غیر قابل تصوری دارد..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"","runtime":102,"tagline":"","homepage":"https://constantin.film/kino/in-the-lost-lands/","overview":"Eine Königin, verzweifelt auf der Suche nach der Erfüllung ihres Liebesglücks, macht einen gewagten Schritt: Sie schickt die mächtige und gefürchtete Hexe Gray Alys, um ihr die magische Gabe zu verschaffen, sich in einen Werwolf zu verwandeln. Mit dem geheimnisvollen Jäger Boyce, der ihr im Kampf gegen düstere Kreaturen und gnadenlose Gegner zur Seite steht, durchstreift Gray Alys eine unheimliche und gefährliche Welt. Und nur sie weiß, dass jeder Wunsch, den sie erfüllt, ungeahnte Konsequenzen hat …"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"魔域女巫","runtime":0,"tagline":"","homepage":"","overview":"在危機四伏的強權國度，有位強大的女巫姬艾莉絲（米娜祖華域芝\r 飾），只要向她付出代價，就能實現任何願望。為了幫助渴求愛情的皇后達成心願，姬找來了熟悉荒野的獵人波伊斯（戴夫巴蒂斯達\r 飾），一同殺入號稱「失落之地」的兇險魔域，試圖奪取狼人的變形異能。沿途除了激戰令人聞風喪膽的妖獸，兩人還要擺脱來勢洶洶的「聖國」追兵。然而，他們的命運其實早已注定…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"인 더 로스트 랜드","runtime":101,"tagline":"인류의 운명을 결정할 디스토피아 블록버스터","homepage":"","overview":"원하는 모든 걸 이루어 줄 수 있는 거대한 힘을 가졌으나 어떤 거절도 할 수 없는 운명을 지닌 마녀 앨리스는, 도시의 지배자 여왕에게 불가능한 요청을 받게 된다. 바로 인간 이상의 힘을 얻게 해달라는 것! 앨리스는 여왕의 요청을 들어주기 위해, 살아 돌아올 수 없는 로스트 랜드의 길을 아는 사냥꾼 보이스와 어둠의 힘을 찾아 짐승과 악마의 땅으로 나선다. 한편, 마녀의 존재를 부정하는 종교 집단은 앨리스를 처치하기 위해 그들을 추적하기 시작하는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Μια βασίλισσα (Arly Jover), αποφασισμένη να εκπληρώσει τον έρωτά της, κάνει ένα απελπισμένο παιχνίδι: προσλαμβάνει τη μάγισσα Gray Alys (Milla Jovovich), μια γυναίκα τόσο φοβισμένη όσο και ισχυρή. Απεσταλμένοι στην απόκοσμη έρημο των Χαμένων Χωρών, η Alys και ο οδηγός της (Dave Bautista) αγωνίζονται να ολοκληρώσουν την αποστολή. Σταδιακά διαπιστώνουν ότι οι σύμμαχοι και οι εχθροί μπορούν να είναι ένα και το αυτό και ότι τίποτα δεν είναι αυτό που φαίνεται..."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"在失落之地","runtime":101,"tagline":"","homepage":"","overview":"　　故事根据乔治·马丁的短片小说改编，讲述一位想要获得变换身形能力 的皇后做出大胆尝试，雇佣了一个拥有强大力量，并且令人恐惧的女人格雷·阿里斯。阿里斯和她的向导流浪汉博伊斯被送到了失落之地，在这里他们需要用智慧战胜人类和恶魔，并且他们需要探究善与恶、罪过与成就、爱与失去的本质。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"A Kárhozott Vidék","runtime":0,"tagline":"Arra törekszik, hogy felszabadítsa népét.","homepage":"","overview":"A világ csupán árnyéka egykori önmagának. A civilizáció a múlté. Kevés ember él már csak, akik az egyetlen megmaradt városban tengődnek, biztonságban a városfalakon kívüli veszélyektől, amiket a Kárhozott Vidék rejteget. A Kárhozott Vidékre kevesen merészkedtek, és még senki sem tért vissza. Névtelen teremtmények és pokoli szörnyetegek népesítik be, amik mindig is léteztek, ám csak az emberiség bukása után merészkedtek a földfelszínre. A legrettegettebb lény ebben a kaotikus világban: a mitikus vérfarkas, ami a Kárhozott Vidék túlsó felén leledzik, a kiszáradt Koponya Folyó mentén. A megmaradt emberi közösség uralkodónője, hogy beteljesítse szerelmét, vakmerő hazárdjátékba kezd: a nagy hatalommal bíró és rettegett boszorkányt, Szürke Alyst meneszti a Kárhozott Vidék kísérteties vadonjába a vérfarkas mágikus erejének megszerzése érdekében. Szürke Alys útitársa Boyce, a magányos fegyverforgató lesz. Kettejüknek túl kell járnia emberek és démonok eszén egyaránt."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"В изгубените земи","runtime":0,"tagline":"","homepage":"","overview":"Историята се върти около кралица, която в името на отчаяната си любов, предприема дързък ход - изпраща могъщата и страховита магьосница Сивата Алис (Мила Йовович) в призрачната пустош на Изгубените земи в търсене на магическа сила. Там Алис и нейният водач, скитникът Бойс (Дейв Батиста), трябва да надхитрят и да премерят сили с хора и демони...  Базиран на едноименния разказ от Джордж Р. Р. Мартин ."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"魔域女巫","runtime":0,"tagline":"","homepage":"","overview":"神秘女巫接受了皇后一項不尋常的委託。為了完成目標，她必須對付傳說中凶狠無比的狼人，因此找來戴夫巴蒂斯達飾演的資深獵人協助。不過除了可怕的狼人，兩人在旅途上還要面對士兵追殺，並激戰危險妖獸！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Na zaginionych ziemiach","runtime":0,"tagline":"","homepage":"","overview":"Czarodziejka wyrusza na poszukiwania magicznej mocy, która pozwala człowiekowi przemienić się w wilkołaka."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Nas Terras Perdidas","runtime":0,"tagline":"","homepage":"","overview":"Uma rainha, desesperada por obter o poder de mudar de forma, contrata a feiticeira Gray Alys, uma mulher temida e poderosa. Enviada para as misteriosas Terras Perdidas, Alys e o seu guia, o errante Boyce, enfrentam desafios sobrenaturais e humanos numa fábula que explora os limites entre o bem e o mal, dívida e realização, amor e perda."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"Išče moč, da bi osvobodila svoje ljudstvo.","homepage":"","overview":"Kraljica pošlje močno in strah vzbujajočo čarovnico Sivo Alys v divjino Izgubljenih dežel v iskanju magične moči, kjer se morata čarovnica in njen vodnik, potepuh Boyce, z zvijačnostjo in bojem izogibati ljudem in demonom."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"","runtime":102,"tagline":"","homepage":"","overview":"Een koningin droomt ervan om de gave van gedaanteverwisseling te krijgen. Ze huurt de heks Gray Alys in, een vrouw die even gevreesd als machtig is. Alys en haar gids, de zwerver Boyce, worden naar de Lost Lands gestuurd en moeten de mens en demon te slim af zijn en bevechten in een fabel die de aard van goed en kwaad, schuld en vervulling, liefde en verlies onderzoekt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"في الأراضي المفقودة","runtime":0,"tagline":"","homepage":"","overview":"تُرسل ملكة الساحرة القوية والمخيفة 'غراي أليس' إلى البرية المسكونة في 'الأراضي المفقودة' بحثًا عن قوة سحرية، حيث يجب على الساحرة ومرشدها، الرحال 'بويز'، أن يتفوقا على البشر والشياطين باستخدام ذكائهما وقوتهما."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"แดนทมิฬ เมืองต้องสาป","runtime":0,"tagline":"","homepage":"","overview":"ราชินีส่งแม่มดเกรย์ อลิสผู้ทรงพลังและน่าเกรงขามไปยังดินแดนรกร้างแห่งวิญญาณของดินแดนสาบสูญเพื่อตามหาพลังเวทมนตร์ ซึ่งแม่มดและผู้นำทางของเธอ บอยซ์ ผู้พเนจรจะต้องเอาชนะและต่อกรกับมนุษย์และปีศาจ"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"În ținuturile pierdute","runtime":0,"tagline":"","homepage":"","overview":"Pelicula de aventuri fantasy In the Lost Lands adaptează trei povești scrise de George R.R. Martin, cunoscut în special datorită serialului de succes Game of Thrones. În prima poveste, o regină o angajează pe vrăjitoarea Gray Alys să-i aducă un dar dintr-un ținut pierdut care o va ajuta să se transforme într-un vârcolac, însă va descoperi că are de plătit un preț prea mare pentru asta. În a doua poveste, războinica Sharra trebuie să se lupte cu un dragon, care este paznicul celor 7 lumi, pentru a ajunge la iubitul ei, Kaydar, însă pe traseu îl întâlnește pe lordul Laren Dorr, care o seduce, făcând-o să rămână cu el și să uite de scopul ei inițial. Iar în final, o tânără barbară e fermecată de o vrăjitoare într-o navă spațială, care îi va oferi dragoste și frumusețe, însă se va dovedi a fi doar o plasă de minciuni și înșelătorii."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"Cerca il potere di liberare il suo popolo.","homepage":"","overview":"Una maga si reca nelle Terre Perdute alla ricerca di un potere magico che permette di trasformarsi in un lupo mannaro."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"En drottning skickar den mäktiga och fruktade häxan Gray Alys till en spöklik vildmark för att söka efter en magisk kraft. Tillsammans med sin guide Boyce måste Gray Alys överlista och besegra både människor och demoner för att nå sitt mål."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":100,"tagline":"","homepage":"","overview":"En dronning sender den magtfulde og frygtede troldkvinde Grey Alys til det spøgelsesagtige ødemark i De Forsvundne Lande på jagt efter en magisk magt, hvor hun og hendes guide, dreven Boyce, skal overliste og bekæmpe både mand og dæmon."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"დაკარგულ მიწებზე","runtime":0,"tagline":"","homepage":"","overview":"დედოფალი, რომელიც სასოწარკვეთილად ეძებს ბედნიერებას სიყვარულში, გაბედულ ნაბიჯს დგამს: ის ძლიერ და საშიშ ჯადოქარ გრეი ალისს აგზავნის „დაკარგულ მიწებზე“, რათა მას მაქციად გადაქცევის ჯადოსნური ნიჭი მისცეს. იდუმალ მონადირე ბოისთან ერთად, რომელიც მას ბნელ არსებებთან და დაუნდობელ მტრებთან ბრძოლაში ეხმარება, გრეი ალისი უცნაურ და საშიშ სამყაროში დახეტიალობს. და მხოლოდ მან იცის, რომ მის მიერ ასრულებულ ყველა სურვილს წარმოუდგენელი შედეგები მოჰყვება..."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"في الأراضي المفقودة","runtime":102,"tagline":"","homepage":"","overview":"تُرسل ملكة الساحرة القوية والمخيفة 'غراي أليس' إلى البرية المسكونة في 'الأراضي المفقودة' بحثًا عن قوة سحرية، حيث يجب على الساحرة ومرشدها، الرحال 'بويز'، أن يتفوقا على البشر والشياطين باستخدام ذكائهما وقوتهما."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"Dans les contrées perdues","runtime":101,"tagline":"Elle cherche le pouvoir pour libérer son peuple.","homepage":"","overview":"Une reine pactise avec la puissante et redoutée sorcière Gray Alys afin qu’elle lui rapporte un trésor capable de lui conférer un pouvoir immense. Alys et son guide, le vagabond Boyce, doivent s’aventurer dans les dangereuses Contrées Perdues. Là, ils devront déjouer et combattre hommes et démons pour honorer leur part du contrat…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Terres perdudes","runtime":0,"tagline":"","homepage":"","overview":"Una reina envia una poderosa bruixa a les Terres Perdudes, buscant un poder màgic que permet transformar-se en un home llop."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"}],"reviews_tmdb":[{"id":"67dacee6c536af65bba6d248","url":"https://www.themoviedb.org/review/67dacee6c536af65bba6d248","author":"CinemaSerf","content":"$11","created_at":"2025-03-19T14:04:22.517Z","updated_at":"2025-03-19T14:11:03.144Z","author_details":{"name":"CinemaSerf","rating":6,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}},{"id":"67dca0cbd67d7dc3c86bb262","url":"https://www.themoviedb.org/review/67dca0cbd67d7dc3c86bb262","author":"r96sk","content":"<em>'In the Lost Lands'</em> is oddly one that didn't do it for me. I say oddly because I really enjoyed all of the cast here, it's just the story that totally failed to claw me in; I honestly would struggle to give you a suitable recap of the plot even so soon after watching it.\r\n\r\nThose onscreen, however, are all pluses. Dave Bautista is good, so is Milla Jovovich. Arly Jover works, as do Amara Okereke and Fraser James. Simon Lööf is the weakest main cast member and even he is fine. It is rare for me to not like a film where the cast bring positive displays.\r\n\r\nThe world built and the effects used looked pleasing enough to me too, it really is just the plot that hampers this one for me personally. That's a shame, really. It feels like a missed opportunity.","created_at":"2025-03-20T23:12:11.722Z","updated_at":"2025-03-20T23:12:11.808Z","author_details":{"name":"","rating":6,"username":"r96sk","avatar_path":"/mwR7rFHoDcobAx1i61I3skzMW3U.jpg"}},{"id":"67f846faea80d85175997cf9","url":"https://www.themoviedb.org/review/67f846faea80d85175997cf9","author":"MovieGuys","content":"\"In the Lost Lands\" is a basic watch, accompanied by a dose of the by now predictable, DEI indoctrination. \r\n\r\nThis feels like a paired down \"Resident Evil\" sci fi, with a medieval fantasy overlay and a few spaghetti Western elements, thrown in. You could also draw comparisons, to the series \"Into the Badlands\" but this film is nowhere near, as polished or engaging. \r\n\r\nThis a fundamentally, a simple, exposition driven affair, with a basic story, incorporating the usual DEI prerequisites and a lots of CGI green screen, \"not so special\", effects. Acting from the cast actually lifts this film somewhat but it never really escapes, the prison of its own self imposed, mediocrity. \r\n\r\nIn summary, if you like sci fi, fantasy mash ups, you'll probably find this a \"mostly\" acceptable, if unremarkable watch.","created_at":"2025-04-10T22:32:26.482Z","updated_at":"2025-07-19T00:30:50.338Z","author_details":{"name":"","rating":6,"username":"MovieGuys","avatar_path":null}},{"id":"694fefb55e919f6fc20735d6","url":"https://www.themoviedb.org/review/694fefb55e919f6fc20735d6","author":"surferuk","content":"Reminds me of of the films Priest and legion but only half as good. There seem no suprise element throughout, as if you've seen it all before. A lot of films with Milla Jovovich as the action hero have that in common along with a dystopian element. Its worth a watch at very least. The actors carry the film given the storyline. There was a double headed snake that gained my interest early on, but after that it lacked a purpose bit flat and too somber. (I was hoping it was going to go along the lines of using clever ways to kill enemies with all manner of creatures... but no.) There needed to be a hope element or some purpose. The witch that will not hang ... they only tried once.","created_at":"2025-12-27T14:39:49.687Z","updated_at":"2025-12-27T16:35:18.220Z","author_details":{"name":"","rating":null,"username":"surferuk","avatar_path":null}}],"recommendations":[{"id":1293286,"adult":false,"title":"Gunslingers","video":false,"overview":"When the most wanted man in America surfaces in a small Kentucky town, his violent history -- and a blood-thirsty mob seeking vengeance and a king’s ransom -- soon follow. As brothers face off against one another and bullets tear the town to shreds, this lightning-fast gunslinger makes his enemies pay the ultimate price for their greed.","genre_ids":[37],"media_type":"movie","popularity":5.3683,"vote_count":96,"poster_path":"/O7REXWPANWXvX2jhQydHjAq2DV.jpg","release_date":"2025-04-11","vote_average":6.1,"backdrop_path":"/zksO4lVnRKRoaSYzh2EDn2Z3Pel.jpg","original_title":"Gunslingers","original_language":"en"},{"id":1045938,"adult":false,"title":"G20","video":false,"overview":"After the G20 Summit is overtaken by terrorists, President Danielle Sutton must bring all her statecraft and military experience to defend her family and her fellow leaders.","genre_ids":[28,9648,18],"media_type":"movie","popularity":3.5076,"vote_count":638,"poster_path":"/wv6oWAleCJZUk5htrGg413t3GCy.jpg","release_date":"2025-04-10","vote_average":6.419,"backdrop_path":"/k32XKMjmXMGeydykD32jfER3BVI.jpg","original_title":"G20","original_language":"en"},{"id":950387,"adult":false,"title":"A Minecraft Movie","video":false,"overview":"Four misfits find themselves struggling with ordinary problems when they are suddenly pulled through a mysterious portal into the Overworld: a bizarre, cubic wonderland that thrives on imagination. To get back home, they'll have to master this world while embarking on a magical quest with an unexpected, expert crafter, Steve.","genre_ids":[10751,14,35,12],"media_type":"movie","popularity":22.8482,"vote_count":2801,"poster_path":"/yFHHfHcUgGAxziP1C3lLt0q2T4s.jpg","release_date":"2025-03-31","vote_average":6.275,"backdrop_path":"/2Nti3gYAX513wvhp8IiLL6ZDyOm.jpg","original_title":"A Minecraft Movie","original_language":"en"},{"id":1312833,"adult":false,"title":"A Knight's War","video":false,"overview":"A fearless knight braves a deadly realm to save the Chosen One’s soul. Facing witches, demons, and brutal foes, he discovers her return could ignite chaos and doom humanity.","genre_ids":[27,28,14],"media_type":"movie","popularity":1.2084,"vote_count":58,"poster_path":"/janjdSMrTRGtPrI1p9uOX66jv7x.jpg","release_date":"2025-02-07","vote_average":6.043,"backdrop_path":"/cJCW78MZsyyXBKHo4V25WctK00V.jpg","original_title":"A Knight's War","original_language":"en"},{"id":1195506,"adult":false,"title":"Novocaine","video":false,"overview":"When the girl of his dreams is kidnapped, everyman Nate turns his inability to feel pain into an unexpected strength in his fight to get her back.","genre_ids":[28,35,53],"media_type":"movie","popularity":7.3959,"vote_count":1461,"poster_path":"/xmMHGz9dVRaMY6rRAlEX4W0Wdhm.jpg","release_date":"2025-03-12","vote_average":6.8,"backdrop_path":"/lyBH2mFFU6qrHwD5QKotL2JnEb6.jpg","original_title":"Novocaine","original_language":"en"},{"id":1128650,"adult":false,"title":"The Prosecutor","video":false,"overview":"A poor young man is wrongly charged with drug trafficking after being deceived. An ex-prosecutor investigates the case, uncovers a corrupt lawyer team's scheme, and restores justice despite obstruction from evil forces.","genre_ids":[28,18,80,53],"media_type":"movie","popularity":8.7544,"vote_count":183,"poster_path":"/n3ZnFqp988MWfIkT8OHofEJfjlt.jpg","release_date":"2024-12-08","vote_average":6.921,"backdrop_path":"/4frrYwamVG0eXhdMTy3cpNNcCBp.jpg","original_title":"誤判","original_language":"cn"},{"id":1233069,"adult":false,"title":"Exterritorial","video":false,"overview":"When her son vanishes inside a US consulate, ex-special forces soldier Sara does everything in her power to find him — and uncovers a dark conspiracy.","genre_ids":[53,28],"media_type":"movie","popularity":4.5282,"vote_count":621,"poster_path":"/micQGmD3K7Ni0wzyaSgBKGxrFWn.jpg","release_date":"2025-04-29","vote_average":6.61,"backdrop_path":"/14UFWFJsGeInCbhTiehRLTff4Yx.jpg","original_title":"Exterritorial","original_language":"de"},{"id":620705,"adult":false,"title":"Crater","video":false,"overview":"After the death of his father, a boy growing up on a lunar mining colony takes a trip to explore a legendary crater, along with his four best friends, prior to being permanently relocated to another planet.","genre_ids":[878,28,12,10751],"media_type":"movie","popularity":4.0006,"vote_count":280,"poster_path":"/n8ZpMwYT02XjpQHpSxn1eJw5Zpz.jpg","release_date":"2023-05-12","vote_average":6.6,"backdrop_path":"/wUMDnvi1xa8iMEpRDVAXrcAtqus.jpg","original_title":"Crater","original_language":"en"},{"id":1125899,"adult":false,"title":"Cleaner","video":false,"overview":"When a group of radical activists take over an energy company's annual gala, seizing 300 hostages, an ex-soldier turned window cleaner suspended 50 storeys up on the outside of the building must save those trapped inside, including her older brother.","genre_ids":[28,53],"media_type":"movie","popularity":6.5634,"vote_count":435,"poster_path":"/mwzDApMZAGeYCEVjhegKvCzDX0W.jpg","release_date":"2025-02-19","vote_average":6.324,"backdrop_path":"/gsQJOfeW45KLiQeEIsom94QPQwb.jpg","original_title":"Cleaner","original_language":"en"},{"id":1229730,"adult":false,"title":"Carjackers","video":false,"overview":"By day, they're invisible—valets, hostesses, and bartenders at a luxury hotel. By night, they're the Carjackers, a crew of skilled drivers who track and rob wealthy clients on the road. As they plan their ultimate heist, the hotel director hires a ruthless hitman, to stop them at all costs. With danger closing in, can Nora, Zoe, Steve, and Prestance pull off their biggest score yet?","genre_ids":[28,12],"media_type":"movie","popularity":3.3714,"vote_count":214,"poster_path":"/wbkPMTz2vVai7Ujyp0ag7AM9SrO.jpg","release_date":"2025-03-27","vote_average":6.061,"backdrop_path":"/is9bmV6uYXu7LjZGJczxrjJDlv8.jpg","original_title":"Carjackers","original_language":"fr"},{"id":1289601,"adult":false,"title":"Life After Fighting","video":false,"overview":"Retired martial arts world champion Alex Faulkner has settled into a simple life, when the disappearance of two of his students leads to an unthinkable discovery close to home. Just when all hope of finding the children is lost, he locates the imprisoned girls and unsurfaces an international child trafficking operation, which draws him back into the fight of his life against those behind it.","genre_ids":[28,18,53],"media_type":"movie","popularity":2.9487,"vote_count":66,"poster_path":"/uKWAk4BHzyEOMmLKUDXoIAPhH36.jpg","release_date":"2024-06-07","vote_average":7.28,"backdrop_path":"/7TIoq6DRnMn2aDViSRfPooWZkga.jpg","original_title":"Life After Fighting","original_language":"en"},{"id":1373723,"adult":false,"title":"The Codes of War","video":false,"overview":"War stories about family, ethics and honor include the true story of two U.S. Marines who in a span of six seconds, must stand their ground to stop a suicide truck bomb, a Navy Corpsman who attempts to hold on to his humanity, and a WW2 soldier who gets separated from his squad and is forced to re-evaluate his code.","genre_ids":[28,10752],"media_type":"movie","popularity":2.1585,"vote_count":62,"poster_path":"/oXeiQAfRK90pxxhP5iKPXQqAIN1.jpg","release_date":"2025-03-20","vote_average":6.2,"backdrop_path":"/ibF5XVxTzf1ayzZrmiJqgeQ39Qk.jpg","original_title":"The Codes of War","original_language":"en"},{"id":676685,"adult":false,"title":"Panda Bear in Africa","video":false,"overview":"A young adventurous panda travels from China to Africa to rescue his best friend, Jielong the Dragon, who has been kidnapped. On his journey, he discovers a strange amazing new world of mountains, deserts and jungles.","genre_ids":[16,12,35,10751],"media_type":"movie","popularity":4.2869,"vote_count":76,"poster_path":"/wxpu7svVqA0ALYpofQBPujGelN3.jpg","release_date":"2024-03-15","vote_average":7.072,"backdrop_path":"/youmOAJwM4XCoHAgeYNXACA7Buc.jpg","original_title":"Pandabeer in Afrika","original_language":"nl"},{"id":1186350,"adult":false,"title":"Marco","video":false,"overview":"The adoptive son of the Adattu family, Marco, sets off on a ruthless quest for vengeance after his brother is brutally murdered, finding only betrayal, loss and unimaginable brutality at every step.","genre_ids":[28,80,53],"media_type":"movie","popularity":8.6479,"vote_count":106,"poster_path":"/il3ao5gcF6fZNqo1o9o7lusmEyU.jpg","release_date":"2024-12-20","vote_average":6.5,"backdrop_path":"/a6RkQIOZ6wThQOEDv6lHsfH53hD.jpg","original_title":"മാർക്കോ","original_language":"ml"},{"id":1414048,"adult":false,"title":"Day of Reckoning","video":false,"overview":"Put-upon lawman John Dorsey is on the verge of losing his wife and his job as sheriff, so he posses up with bullish U.S. Marshall Butch Hayden to hold outlaw Emily Rusk hostage. A battle of wills ensues as Emily turns the posse on themselves, but as her marauding husband and his gang approach, Emily and John realize they will need each other to survive.","genre_ids":[37,28],"media_type":"movie","popularity":1.6395,"vote_count":37,"poster_path":"/cVSjSQryFUERYSdOmdgJ2m0eBte.jpg","release_date":"2025-03-28","vote_average":6.432,"backdrop_path":"/gIm5sjPSm973yKf6sbvd5lOkg3X.jpg","original_title":"Day of Reckoning","original_language":"en"},{"id":774100,"adult":false,"title":"Alexander and the Terrible, Horrible, No Good, Very Bad Road Trip","video":false,"overview":"Eleven-year-old Alexander and his family embark on a dream Spring Break vacation to Mexico City only to have all their plans go terribly wrong when they discover a cursed idol.","genre_ids":[10751,35],"media_type":"movie","popularity":1.0854,"vote_count":74,"poster_path":"/AhyvU3nIZ6uzop8lMgRB5N3AY9l.jpg","release_date":"2025-03-26","vote_average":6.209,"backdrop_path":"/aJZ33UhVlInyFENbH4GK4s0k6E0.jpg","original_title":"Alexander and the Terrible, Horrible, No Good, Very Bad Road Trip","original_language":"en"},{"id":1466938,"adult":false,"title":"A Deadly American Marriage","video":false,"overview":"A chilling 911 call. A gruesome scene. What really happened inside a family's quiet suburban home? Murder or self-defense? Told from both sides, this documentary explores Jason Corbett's brutal death.","genre_ids":[80,99],"media_type":"movie","popularity":1.2937,"vote_count":74,"poster_path":"/yzPpsg2HX6BcavbE43NzpgDig9F.jpg","release_date":"2025-05-09","vote_average":6.574,"backdrop_path":"/nqfgAh16N1w5T5LVodFG30QhnKP.jpg","original_title":"A Deadly American Marriage","original_language":"en"},{"id":1461714,"adult":false,"title":"My Mom Jayne","video":false,"overview":"Through deeply personal interviews with her siblings and an examination of the photographs, letters, and belongings left behind, Mariska assembles a new portrait of her mother Jayne Mansfield, an extraordinary and complex woman.","genre_ids":[99],"media_type":"movie","popularity":1.5675,"vote_count":42,"poster_path":"/wNIdUakKOG6xUgqgGb6UeC3vNIS.jpg","release_date":"2025-06-20","vote_average":8.012,"backdrop_path":"/k4MZdogt1DZX0b2tlkr17EFUvP5.jpg","original_title":"My Mom Jayne","original_language":"en"},{"id":650033,"adult":false,"title":"Free Fall","video":false,"overview":"In the near future, humanity has successfully colonized space and build a giant orbital station \"Delta\". Max is a repairman working on the station. After a disaster caused by a proton storm, he is left alone without his crew members, drifting into space. His space suit is broken, he is exhausted, and he lacks communication with people. But suddenly a dispatcher named Anna comes to help. She is the only one who can guide Max through difficulties and get him to the station. Max has to risk everything to save his life, but he has no idea what Anna is up to.","genre_ids":[878,53],"media_type":"movie","popularity":1.458,"vote_count":21,"poster_path":"/oY1b65zg8IwsbNdr7SEiQ7ohZ7u.jpg","release_date":"2025-05-21","vote_average":5.75,"backdrop_path":"/kXxriYfAWtMJNHGHVYr09c37L07.jpg","original_title":"Свободное падение","original_language":"ru"},{"id":1261050,"adult":false,"title":"The Quiet Ones","video":false,"overview":"In 2008, a group of men from Denmark and across Europe pull off the biggest heist of all time on Danish soil. Kasper, a boxer with few chances left in life, is offered the opportunity to plan the robbery by its foreign initiators.","genre_ids":[28,18],"media_type":"movie","popularity":1.1985,"vote_count":69,"poster_path":"/7NLY1jNwtZX1yVzwVoBeAhaBE8i.jpg","release_date":"2024-10-31","vote_average":5.804,"backdrop_path":"/jrrBTFdaacnvCRF6HhTjnR9UX0p.jpg","original_title":"De lydløse","original_language":"da"}],"similar_content":[{"id":58,"adult":false,"title":"Pirates of the Caribbean: Dead Man's Chest","video":false,"overview":"Jack's got a blood debt to pay: he owes his soul to the legendary Davy Jones, ghastly Ruler of the Ocean Depths.  But ever-crafty Jack isn't about to go down without a fight.","genre_ids":[12,14,28],"popularity":13