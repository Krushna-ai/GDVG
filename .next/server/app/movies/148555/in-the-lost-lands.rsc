cn2WSR6qdXy8Q.jpg","original_title":"Ночной дозор","original_language":"ru"},{"id":3176,"adult":false,"title":"Battle Royale","video":false,"overview":"In the future, the Japanese government captures a class of ninth-grade students and forces them to kill each other under the revolutionary \"Battle Royale\" act.","genre_ids":[18,53,28],"popularity":4.7403,"vote_count":3730,"poster_path":"/aLGKAQKgzWpJ6egyWzzC11jXBRJ.jpg","release_date":"2000-12-16","vote_average":7.3,"backdrop_path":"/amBvmIshdsSkOtvVIgxl7YSQ9Dg.jpg","original_title":"バトル・ロワイアル","original_language":"ja"},{"id":6435,"adult":false,"title":"Practical Magic","video":false,"overview":"Sally and Gillian Owens, born into a magical family, have mostly avoided witchcraft themselves. But when Gillian's vicious boyfriend, Jimmy Angelov, dies unexpectedly, the Owens sisters give themselves a crash course in hard magic. With policeman Gary Hallet growing suspicious, the girls struggle to resurrect Angelov -- and unwittingly inject his corpse with an evil spirit that threatens to end their family line.","genre_ids":[10749,35,14],"popularity":4.3332,"vote_count":1677,"poster_path":"/AwmToSgf2IL3aHv0QRVsR5KvChv.jpg","release_date":"1998-10-16","vote_average":6.766,"backdrop_path":"/mGznDQ8opBuRd004ChVWhDqjAyW.jpg","original_title":"Practical Magic","original_language":"en"},{"id":6520,"adult":false,"title":"First Knight","video":false,"overview":"The timeless tale of King Arthur and the legend of Camelot are retold in this passionate period drama. Arthur is reluctant to hand the crown to Lancelot, and Guinevere is torn between her loyalty to her husband and her growing love for his rival. But Lancelot must balance his loyalty to the throne with the rewards of true love.","genre_ids":[28,12,18,10749],"popularity":2.2362,"vote_count":1314,"poster_path":"/dJH5bwtu3UxbwRsSlhlhmMrV8ZH.jpg","release_date":"1995-07-07","vote_average":6.102,"backdrop_path":"/tsgEdYjwWVhdGHv01djx7KdXDJm.jpg","original_title":"First Knight","original_language":"en"},{"id":276877,"adult":false,"title":"Orgy of the Damned","video":false,"overview":"Fosco, a 300 year old vampire, lives in a beautiful mansion with his wife Sabina and their son Dimitri. Their lives are a non-stop lust orgy where anything goes and always does! Until, Fauna, a naive young woman, and her boyfriend, Micah, show up and turn the ecstasy-driven clan into murderous back-stabbers, hell-bent on revenge and power.","genre_ids":[27,14,53],"popularity":0.2798,"vote_count":10,"poster_path":"/nletd6ob7UBESmxONnLEvOtgIHo.jpg","release_date":"2010-10-07","vote_average":1.8,"backdrop_path":"/1dB7mmRpk9FUatzkz5cmyaRcyVR.jpg","original_title":"Orgy of the Damned","original_language":"en"},{"id":7299,"adult":false,"title":"Equilibrium","video":false,"overview":"In a dystopian future, a totalitarian regime maintains peace by subduing the populace with a drug, and displays of emotion are punishable by death. A man in charge of enforcing the law rises to overthrow the system.","genre_ids":[28,878,53],"popularity":8.1226,"vote_count":4902,"poster_path":"/yQuovle5Ov6q69XSdTNdH52eANc.jpg","release_date":"2002-12-06","vote_average":7.045,"backdrop_path":"/mBdZvD8jCDXDHmtVDLOJeAErxVw.jpg","original_title":"Equilibrium","original_language":"en"},{"id":581,"adult":false,"title":"Dances with Wolves","video":false,"overview":"Wounded Civil War soldier John Dunbar tries to commit suicide—and becomes a hero instead. As a reward, he's assigned to his dream post, a remote junction on the Western frontier, and soon makes unlikely friends with the local Sioux tribe.","genre_ids":[12,18,37],"popularity":5.7679,"vote_count":4586,"poster_path":"/hw0ZEHAaTqTxSXGVwUFX7uvanSA.jpg","release_date":"1990-03-30","vote_average":7.833,"backdrop_path":"/ywWva4trKw7f3wtbz81Fe3FnrtC.jpg","original_title":"Dances with Wolves","original_language":"en"},{"id":587,"adult":false,"title":"Big Fish","video":false,"overview":"Throughout his life Edward Bloom has always been a man of big appetites, enormous passions and tall tales. In his later years, he remains a huge mystery to his son, William. Now, to get to know the real man, Will begins piecing together a true picture of his father from flashbacks of his amazing adventures.","genre_ids":[12,14,18],"popularity":5.4649,"vote_count":7633,"poster_path":"/tjK063yCgaBAluVU72rZ6PKPH2l.jpg","release_date":"2003-12-10","vote_average":7.758,"backdrop_path":"/bLqUd0tBvKezDr9MEla7k34i3rp.jpg","original_title":"Big Fish","original_language":"en"},{"id":603,"adult":false,"title":"The Matrix","video":false,"overview":"Set in the 22nd century, The Matrix tells the story of a computer hacker who joins a group of underground insurgents fighting the vast and powerful computers who now rule the earth.","genre_ids":[28,878],"popularity":22.54,"vote_count":27419,"poster_path":"/p96dm7sCMn4VYAStA6siNz30G1r.jpg","release_date":"1999-03-31","vote_average":8.238,"backdrop_path":"/tlm8UkiQsitc8rSuIAscQDCnP8d.jpg","original_title":"The Matrix","original_language":"en"},{"id":604,"adult":false,"title":"The Matrix Reloaded","video":false,"overview":"The Resistance builds in numbers as humans are freed from the Matrix and brought to the city of Zion. Neo discovers his superpowers, including the ability to see the code inside the Matrix. With machine sentinels digging to Zion in 72 hours, Neo, Morpheus and Trinity must find the Keymaker to ultimately reach the Source.","genre_ids":[12,28,53,878],"popularity":11.1102,"vote_count":11727,"poster_path":"/aA5qHS0FbSXO8PxcxUIHbDrJyuh.jpg","release_date":"2003-05-15","vote_average":7.069,"backdrop_path":"/ihOJcrorpDQtHTzIOrobbOhpJsj.jpg","original_title":"The Matrix Reloaded","original_language":"en"},{"id":605,"adult":false,"title":"The Matrix Revolutions","video":false,"overview":"The human city of Zion defends itself against the massive invasion of the machines as Neo fights to end the war at another front while also opposing the rogue Agent Smith.","genre_ids":[12,28,53,878]