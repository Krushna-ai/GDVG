Mk4CD9WUCB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.781,"vote_average":0},{"width":1920,"height":1080,"file_path":"/mQCrpfrib1ZcZrTwR95bosGaSlG.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/iUel0VedyIiWJ29ApctSAgPx8cN.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/A61b2pjZ45wPN4r4dOqlvukfeUR.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/sopvsXaxSjBdEHz4ZqJ0loFBBc0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/yRaTNPN4T8t85ggE0uVgWNKCVhG.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T06:46:28.317+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":0,"tagline":"Todo comenzó con la clave del wifi...","homepage":"https://www.netflix.com/title/81388078","overview":"Raquel lleva toda la vida loca por Ares, su atractivo y misterioso vecino. Lo observa sin ser vista y es que, muy a su pesar, no han intercambiado ni una palabra. Raquel tiene muy claro su objetivo: conseguir que Ares se enamore de ella. Pero ella no es una niña inocente y no está dispuesta a perderlo todo por el camino, y mucho menos a sí misma..."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Through My Window","runtime":112,"tagline":"It all started with the Wi-Fi password...","homepage":"https://www.netflix.com/title/81388078","overview":"Raquel's longtime crush on her next-door neighbor turns into something more when he starts developing feelings for her, despite his family's objections."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"À travers ma fenêtre","runtime":112,"tagline":"Tout a commencé avec un mot de passe Wi-Fi...","homepage":"https://www.netflix.com/title/81388078","overview":"Amoureuse depuis longtemps, Raquel découvre enfin que ses sentiments pour son voisin sont réciproques. Mais la famille du jeune homme ne voit pas l'histoire d'un bon œil."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"스루 마이 윈도","runtime":113,"tagline":"","homepage":"https://www.netflix.com/kr/title/81388078","overview":"옆집에 사는 남자를 오랫동안 짝사랑해온 라켈. 가족의 반대에도 불구하고 그 남자 역시 라켈에게 마음을 열기 시작하자, 그녀의 감정도 커져간다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Láska přes okno","runtime":0,"tagline":"","homepage":"","overview":"Raquel je už dlouho tajně zamilovaná do sexy souseda Arese. Nespustí z něj oči, ale zatím nesebrala odvahu si s ním promluvit. Dokáže ho přimět, aby se do ní zakoukal?"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Através da Minha Janela","runtime":113,"tagline":"","homepage":"","overview":"Raquel é louca pelo vizinho Ares há muito tempo. Ela o observa de longe, mas nunca falou com ele. Será que vai dar match?"},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Крізь моє вікно","runtime":0,"tagline":"Все почалося з пароля Wi-Fi...","homepage":"","overview":"Давня закоханість Ракель у її сусіда переростає в дещо значно більше, коли він починає відповідати їй взаємністю, попри супротив його родини."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Dalla mia finestra","runtime":112,"tagline":"Tutto è cominciato con la password Wi-Fi...","homepage":"","overview":"Raquel è perdutamente innamorata dell'attraente e misterioso vicino di casa Ares, ma lo osserva da lontano perché purtroppo non si sono mai parlati. La ragazza però ha chiaro in mente un piano: fare innamorare Ares. Tutt'altro che innocente e indifesa, Raquel non è preparata a perdere tutto per ottenere ciò che vuole... sicuramente non se stessa."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Through my Window - Ich sehe nur dich","runtime":0,"tagline":"Es begann alles mit dem Wi-Fi-Passwort...","homepage":"","overview":"Raquels langjährige Schwärmerei für ihren Nachbarn wird zu mehr, als er trotz der Einwände seiner Familie Gefühle für sie entwickelt."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Penceremden","runtime":0,"tagline":"Her şey Wi-Fi şifresiyle başladı...","homepage":"","overview":"Genç bir kız olan Raquel, gönlünü yakışıklı komşusu Ares'e kaptırır. Çocukluğundan beri hissettiği duygularını kimseyle paylaşmayan Raquel, henüz Ares ile konuşmamıştır. Utangaç bir genç olan Raquel, Ares'i sadece gizlice izlemekle yetinir. Ancak artık Ares'i kendisine aşık etmeye karar verir ve harekete geçer."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Из моего окна","runtime":116,"tagline":"","homepage":"","overview":"Ракель уже давно тайно влюблена в своего соседа. Но все меняется, когда он начинает отвечать ей взаимностью несмотря на протесты родителей."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Qua Ô Cửa Sổ","runtime":0,"tagline":"","homepage":"","overview":"Raquel thích chàng hàng xóm từ lâu, và giờ tình ý ấy bỗng tiến triển xa hơn khi anh bắt đầu có tình cảm với cô – bất chấp sự phản đối của gia đình."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"隔窗恋爱","runtime":113,"tagline":"","homepage":"","overview":"拉克尔对隔壁邻居暗恋已久。当这位邻居不顾家人反对开始对她产生感情时，事情开始变得复杂起来。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"מבעד לחלוני","runtime":0,"tagline":"הכל התחיל בסיסמה לוויי-פיי...","homepage":"","overview":"ראקל מאוהבת כבר המון זמן בשכן החתיך שלה. כשהוא מתחיל סוף-סוף לגלות בה עניין, מתפתח ביניהם קשר רומנטי – למרות התנגדות משפחתו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Przez moje okno","runtime":0,"tagline":"","homepage":"","overview":"Raquel jest szaleńczo zakochana w Aresie, swoim przystojnym i tajemniczym sąsiedzie, z którym - ku jej rozczarowaniu - nigdy nie zamieniła ani jednego słowa. Obserwuje go z oddali, ale ma jasno określony cel - sprawić, aby chłopak ją pokochał. Raquel nie jest jednak niewinną, bezradną dziewczyną gotową oddać wszystko - również siebie - aby zrealizować swoje zamiary."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":113,"tagline":"Todo empezó con la contraseña del Wi-Fi...","homepage":"","overview":"Raquel lleva toda la vida loca por Ares, su atractivo y misterioso vecino. Lo observa sin ser vista y es que, muy a su pesar, no han intercambiado ni una palabra. Raquel tiene muy claro su objetivo: conseguir que Ares se enamore de ella. Pero ella no es una niña inocente y no está dispuesta a perderlo todo por el camino, y mucho menos a sí misma…"},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Az ablakomon át","runtime":0,"tagline":"","homepage":"","overview":"Egy lány fülig szerelmes a titokzatos szomszédjába, akit csak távolról figyel. Arra a végső következtetésre jut, hogy mindent el kell követnie azért, hogy a fiú szerelmes legyen belé"},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Genom mitt fönster","runtime":0,"tagline":"","homepage":"","overview":"Raquels långvariga förälskelse i sin granne tar en vändning när grannen börjar få känslor för henne, trots hans familjs invändningar."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Kroz moj prozor","runtime":0,"tagline":"","homepage":"","overview":"Raquelina dugotrajna zatreskanost u susjeda preraste u nešto više nakon što on unatoč protivljenju svoje obitelji počne razvijati osjećaje prema njoj."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Da Minha Janela","runtime":0,"tagline":"","homepage":"","overview":"A paixoneta de longa data de Raquel pelo vizinho torna-se algo mais quando ele, apersar das objeções da família, começa a nutrir sentimentos por ela."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Μέσα απ' το Παράθυρο","runtime":116,"tagline":"Όλα ξεκίνησαν με τον κωδικό πρόσβασης Wi-Fi...","homepage":"","overview":"Το κόλλημα της Raquel με τον γείτονά της αποκτά νέες διαστάσεις, όταν εκείνος αρχίζει να νιώθει πράγματα για εκείνη, παρά τις αντιρρήσεις της οικογένειάς του."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"心動隔扇窗","runtime":0,"tagline":"","homepage":"","overview":"蕾凱兒暗戀鄰居男孩很久了，當他不顧家人的反對，也開始喜歡她時，兩人之間的關係有了變化。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"รักผ่านหน้าต่าง","runtime":0,"tagline":"","homepage":"","overview":"เมื่อหนุ่มข้างบ้านที่ราเกลแอบปิ๊งมานานเริ่มจะมีใจให้ ความสัมพันธ์แสนหวานจึงเริ่มต้นขึ้น แต่จะทำอย่างไรเมื่อครอบครัวเขาไม่ปลื้มกับรักครั้งนี้"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"スルー・マイ・ウィンドウ","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"ჩემი ფანჯრიდან","runtime":0,"tagline":"","homepage":"","overview":"რაკელის დიდი ხნის მიჯაჭვულობა მეზობელზე გადაიქცევა უფრო მეტად, როდესაც ის იწყებს გრძნობების გამომჟღავნებას მის მიმართ, მიუხედავად მისი ოჯახის წინააღმდეგობისა."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"À travers ma fenêtre","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ca-fr/title/81388078","overview":"Raquel est obsédée depuis longtemps par son voisin, mais ses sentiments se transforment quand celui-ci, malgré l'opposition de sa famille, se met à s'intéresser à elle."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"De la fereastra mea","runtime":113,"tagline":"","homepage":"https://www.netflix.com/title/81388078","overview":"Pasiunea lui Raquel pentru vecinul ei se transformă în ceva mai mult când sentimentele devin reciproce, în ciuda obiecțiilor familiei lui."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Pro mano langą","runtime":0,"tagline":"","homepage":"","overview":"Ilgametis Raquel įsimylėjimas šalia esančiam kaimynui virsta kažkuo daugiau, kai jis pradeda jai jausti jausmus, nepaisant jo šeimos prieštaravimų."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"През прозореца ми","runtime":0,"tagline":"","homepage":"","overview":"Ракел е прекарала целия си живот лудо влюбена в съседа си Арес, но никога не му е казвала какво чувства към него, защото никога не са си разменили нито дума. След поредица от събития, това ще се промени коренно..."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"}],"reviews_tmdb":[{"id":"61ff3cdeb3e6270068dd7af9","url":"https://www.themoviedb.org/review/61ff3cdeb3e6270068dd7af9","author":"SeanDillon","content":"A teen romance like there are hundreds of others: a girl a boy, different social classes, one not quite attracted to the other, blah blah blah, they fall in love. If you're in the mood for a romantic movie that follows the most basic template of romantic movies, then watch it. But if you want something original that will surprise and excite you then look elsewhere.","created_at":"2022-02-06T03:13:34.450Z","updated_at":"2022-02-17T17:56:08.480Z","author_details":{"name":"","rating":2,"username":"SeanDillon","avatar_path":null}}],"recommendations":[{"id":988078,"adult":false,"title":"Through My Window: Across the Sea","video":false,"overview":"After a year of long-distance, Raquel and Ares reunite on a steamy beach trip. Faced with fresh flirtations and insecurities, will their love prevail?","genre_ids":[10749,18,35],"media_type":"movie","popularity":4.8626,"vote_count":950,"poster_path":"/3kULr3y7ZhdY3oCHKwwNT2hqys0.jpg","release_date":"2023-06-23","vote_average":6.6,"backdrop_path":"/zFsB4MB4BwVYE5tqXe9sYdCH3Vr.jpg","original_title":"A través del mar","original_language":"es"},{"id":1139566,"adult":false,"title":"Through My Window 3: Looking at You","video":false,"overview":"After the events of the summer, Ares and Raquel they don't see a way forward in their relationship and decide to go separate ways. But when they meet again in the winter in Barcelona, the love and desire they feel for each other is undeniable. Will they be able to find a way to get back together?","genre_ids":[10749,18,35],"media_type":"movie","popularity":5.9808,"vote_count":663,"poster_path":"/gwpTgtwVAwmvivBN8rAQABpx9Am.jpg","release_date":"2024-02-23","vote_average":6.866,"backdrop_path":"/iWzu3dVJGNfQUkLfK9xpTWoi5mh.jpg","original_title":"A través de mi ventana 3: A través de tu mirada","original_language":"es"},{"id":772272,"adult":false,"title":"Tall Girl 2","video":false,"overview":"After Jodi Kreyman gains popularity, her miscommunications start causing rifts with those around her and now she really needs to \"stand tall\".","genre_ids":[35,10749,18],"media_type":"movie","popularity":1.1823,"vote_count":397,"poster_path":"/eyKkLdst2vFRjCC89C3NqGCLpNE.jpg","release_date":"2022-02-10","vote_average":5.7,"backdrop_path":"/7mGSBKuIGrFc9HNfp85bppQcFhs.jpg","original_title":"Tall Girl 2","original_language":"en"},{"id":790142,"adult":false,"title":"The Royal Treatment","video":false,"overview":"Isabella runs her own salon and isn’t afraid to speak her mind, while Prince Thomas runs his own country and is about to marry for duty rather than love. When Izzy and her fellow stylists get the opportunity of a lifetime to do the hair for the royal wedding, she and Prince Thomas learn that taking control of their own destiny requires following their hearts.","genre_ids":[10749,35],"media_type":"movie","popularity":1.2359,"vote_count":793,"poster_path":"/mYAv0YUoXJzLxIdEirOken8Quwf.jpg","release_date":"2022-01-20","vote_average":6.66,"backdrop_path":"/on1p1AdcfxmlyHhVXoycWt75D8H.jpg","original_title":"The Royal Treatment","original_language":"en"},{"id":899405,"adult":false,"title":"Anonymously Yours","video":false,"overview":"After an accidental text message turns into a digital friendship, Vale and Alex start crushing on each other without realizing they've met in real life.","genre_ids":[18,10749],"media_type":"movie","popularity":3.1666,"vote_count":375,"poster_path":"/kQu9rNkiB0nSSRGQX0B6u9sxwfw.jpg","release_date":"2021-12-10","vote_average":7.528,"backdrop_path":"/AjfboLPgxFmUBHJzXBl2S5KS53L.jpg","original_title":"Anónima","original_language":"es"},{"id":245842,"adult":false,"title":"The King's Daughter","video":false,"overview":"King Louis XIV's quest for immortality leads him to capture and steal a mermaid's life force, a move that is further complicated by his illegitimate daughter's discovery of the creature.","genre_ids":[14,12,10751],"media_type":"movie","popularity":1.876,"vote_count":712,"poster