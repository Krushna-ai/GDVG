4X0fmCMfgEs2ww5IyMgFm.jpg","release_date":"1953-04-22","vote_average":8,"backdrop_path":"/hTP6H7sNlWXdGxAciXQSjNJ1ob7.jpg","original_title":"Le Salaire de la peur","original_language":"fr"},{"id":207,"adult":false,"title":"Dead Poets Society","video":false,"overview":"At an elite, old-fashioned boarding school in New England, a passionate English teacher inspires his students to rebel against convention and seize the potential of every day, courting the disdain of the stern headmaster.","genre_ids":[18],"popularity":10.9794,"vote_count":12322,"poster_path":"/l5NbiHKUmahlAT3Q1ig8Tyl9xrc.jpg","release_date":"1989-06-02","vote_average":8.301,"backdrop_path":"/yYvBNN96Ym3wtPxGCFl7F888WwB.jpg","original_title":"Dead Poets Society","original_language":"en"},{"id":271373,"adult":false,"title":"The Abandoned Documents of a Dead Woman","video":false,"overview":"Based on the novel by Güzide Sabri, the film tells the story of a woman suffering from a forbidden love.","genre_ids":[18,10749],"popularity":0.1377,"vote_count":0,"poster_path":"/4pRq4XcqkiuxjUmBD9TcjK7nZ9D.jpg","release_date":"1956-01-01","vote_average":0,"backdrop_path":null,"original_title":"Ölmüş Bir Kadının Evrak-ı Metrukesi","original_language":"tr"},{"id":245,"adult":false,"title":"About a Boy","video":false,"overview":"Will Freeman is a good-looking, smooth-talking bachelor whose primary goal in life is avoiding any kind of responsibility. But when he invents an imaginary son in order to meet attractive single moms, Will gets a hilarious lesson about life from a bright, but hopelessly geeky 12-year-old named Marcus. Now, as Will struggles to teach Marcus the art of being cool, Marcus teaches Will that you're never too old to grow up.","genre_ids":[18,35,10749],"popularity":2.6714,"vote_count":2353,"poster_path":"/qoZ1bD0q9EFqcNiEYbEigsRcNCt.jpg","release_date":"2002-04-26","vote_average":6.69,"backdrop_path":"/xxiPjhXigJ4zPiqqrA77FK10ULo.jpg","original_title":"About a Boy","original_language":"en"},{"id":252,"adult":false,"title":"Willy Wonka & the Chocolate Factory","video":false,"overview":"When eccentric candy man Willy Wonka promises a lifetime supply of sweets and a tour of his chocolate factory to five lucky kids, penniless Charlie Bucket seeks the golden ticket that will make him a winner.","genre_ids":[10751,14,35],"popularity":5.6585,"vote_count":3872,"poster_path":"/vmpsZkrs4Uvkp9r1atL8B3frA63.jpg","release_date":"1971-06-29","vote_average":7.483,"backdrop_path":"/aAL7kV0l3yZtbCFs7J8m4gXldqR.jpg","original_title":"Willy Wonka & the Chocolate Factory","original_language":"en"},{"id":257,"adult":false,"title":"Oliver Twist","video":false,"overview":"When 9-year-old orphan Oliver Twist dares to ask his cruel taskmaster, Mr. Bumble, for a second serving of gruel, he's hired out as an apprentice. Escaping that dismal fate, young Oliver falls in with the street urchin known as the Artful Dodger and his criminal mentor, Fagin. When kindly Mr. Brownlow takes Oliver in, Fagin's evil henchman Bill Sikes plots to kidnap the boy.","genre_ids":[80,18,10751],"popularity":2.0641,"vote_count":1226,"poster_path":"/zhPdYZ3x2uanhM1SyBj4CuL6hSa.jpg","release_date":"2005-09-23","vote_average":6.747,"backdrop_path":"/s4H3XiCwHrjtMP4cBCO5L5tDVg3.jpg","original_title":"Oliver Twist","original_language":"en"},{"id":93,"adult":false,"title":"Anatomy of a Murder","video":false,"overview":"Semi-retired Michigan lawyer Paul Biegler takes the case of Army Lt. Manion, who murdered a local innkeeper after his wife claimed that he raped her. Over the course of an extensive trial, Biegler parries with District Attorney Lodwick and out-of-town prosecutor Claude Dancer to set his client free, but his case rests on the victim's mysterious business partner, who's hiding a dark secret.","genre_ids":[80,18,9648],"popularity":1.6093,"vote_count":1126,"poster_path":"/b2G1QSAwtBv9luhEwErIgSRaU92.jpg","release_date":"1959-07-01","vote_average":7.835,"backdrop_path":"/xfEU7DOlQPwz8Y0TBhKmpETuNIc.jpg","original_title":"Anatomy of a Murder","original_language":"en"},{"id":118,"adult":false,"title":"Charlie and the Chocolate Factory","video":false,"overview":"A young boy wins a tour through the most magnificent chocolate factory in the world, led by the world's most unusual candy maker.","genre_ids":[12,35,10751,14],"popularity":10.2553,"vote_count":15937,"poster_path":"/iKP6wg3c6COUe8gYutoGG7qcPnO.jpg","release_date":"2005-07-13","vote_average":7.039,"backdrop_path":"/3nqxXZ7QixMeWoQD10cw6FZf277.jpg","original_title":"Charlie and the Chocolate Factory","original_language":"en"},{"id":266,"adult":false,"title":"Contempt","video":false,"overview":"A philistine in the art film business, Jeremy Prokosch is a producer unhappy with the work of his director. Prokosch has hired Fritz Lang to direct an adaptation of \"The Odyssey,\" but when it seems that the legendary filmmaker is making a picture destined to bomb at the box office, he brings in a screenwriter to energize the script. The professional intersects with the personal when a rift develops between the writer and his wife.","genre_ids":[18,10749],"popularity":2.3387,"vote_count":937,"poster_path":"/kNElbRcp4Qz6wmJ9kH5vdY004Hq.jpg","release_date":"1963-10-29","vote_average":7.031,"backdrop_path":"/qBpRJrbaofPzb9pwgi5LiuNDLmM.jpg","original_title":"Le Mépris","original_language":"fr"},{"id":271,"adult":false,"title":"Ronia: The Robber's Daughter","video":false,"overview":"Ronia lives happily in her father's castle until she comes across a new playmate, Birk, in the nearby dark forest. The two explore the wilderness, braving dangerous Witchbirds and Rump-Gnomes. But when their families find out Birk and Ronia have been playing together, they forbid them to see each other again. Indeed, their fathers are competing robber chieftains and bitter enemies. Now the two spunky children must try to tear down the barriers that have kept their families apart for so long.","genre_ids":[12,18,14,10751],"popularity":2.8965,"vote_count":193,"poster_path":"/gatMa1qfwpJqiawPjJxodUvdB0.jpg","release_date":"1984-12-14","vote_average":7,"backdrop_path":"/lPYts3qpBDMlJaGjzd7nA5Piyd2.jpg","original_title":"Ronja Rövardotter","original_language":"sv"},{"id":274,"adult":false,"title":"The Silence of the Lambs","video":false,"overview":"Clarice Starling is a top student at the FBI's training academy.  Jack Crawford wants Clarice to interview Dr. Hannibal Lecter, a brilliant psychiatrist who is also a violent psychopath, serving life behind bars for various acts of murder and cannibalism.  Crawford believes that Lecter may have insight into a case and that Starling, as an attractive young woman, may be just the bait to draw him out.","genre_ids":[80,53,18],"popularity":3.7028,"vote_count":17611,"poster_path":"/uS9m8OBk1A8eM9I042bx8XXpqAq.jpg","release_date":"1991-02-14","vote_average":8.346,"backdrop_path":"/aYcnDyLMnpKce1FOYUpZrXtgUye.jpg","original_title":"The Silence of the Lambs","original_language":"en"}],"external_ids":{"imdb_id":"tt14463484","twitter_id":null,"facebook_id":null,"wikidata_id":"Q110833192","instagram_id":"atdmvnetflix","rotten_tomatoes_id":"m/through_my_window"},"social_ids":{"twitter":null,"facebook":null,"instagram":"atdmvnetflix"},"gdvg_id":148732,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"BR","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2022-02-04T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"CZ","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"cs","descriptors":[],"release_date":"2022-02-04T00:00:00.000Z","certification":"16+"}]},{"iso_3166_1":"DE","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"de","descriptors":[],"release_date":"2022-02-04T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"ES","release_dates":[{"note":"