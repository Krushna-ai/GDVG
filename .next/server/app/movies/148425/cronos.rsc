ath":"/mrRicAvK52bEYNMUpYnmKLB8UQ0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/89inyplgD8T1ciEpdA767AmRN9E.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/rsigaVeGnjYM1EuPxDmSL3a9Ar7.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/uF7P7GBMnYkshILQPEmZETa4IGz.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":2,"aspect_ratio":1.778,"vote_average":0.166},{"width":1904,"height":1071,"file_path":"/eNgiMPUaGtQKqpP97GqJnDVlLwE.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1904,"height":1071,"file_path":"/3tfBSwTmzRadHvbObcYC7kDaY00.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1904,"height":1071,"file_path":"/bl7nviGfAPgFUJHxAbJ9NTBPu5r.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1904,"height":1071,"file_path":"/oZgG2RJcdsqsVz7NNrlprUv295N.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1904,"height":1071,"file_path":"/thfrKY8lJ8rAfvpCQOcjnCdqh0L.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1904,"height":1071,"file_path":"/8ByEILnmlpOFEl49Dq1myaw26S8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1904,"height":1071,"file_path":"/l1tMTXiQzPeKs3V75qgmsiDp9Ab.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1600,"height":900,"file_path":"/fW9MfsARFrIRtvBpn3xWi06MrBL.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1600,"height":900,"file_path":"/qBK8ktbEadktKOPc5sbu50P6Z9b.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1600,"height":900,"file_path":"/mQVRZVsbqFm2zoyhesScpeU2sRb.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/ktSNp0962TR3kk9GFv1MYy9uf4A.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":1,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/riqod4LW6aLVfbYgfAF9uQkLHmT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3270,"height":1839,"file_path":"/xXVeKi4t1IxcwylcXDztS9MLD4L.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3208,"height":1804,"file_path":"/gyVd01b2gIp0j7JVZOxM7VRi8At.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3179,"height":1788,"file_path":"/gmP6SsjUhq0LB868yYOfCyTi8rj.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3162,"height":1778,"file_path":"/oCImG3xDRzCb5rJPwZGmqIzM9XB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3157,"height":1776,"file_path":"/tL7wxh6Xpxwfn1eRqVzyX7FXyc9.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3175,"height":1786,"file_path":"/h6O4W61kyMK64Lhr8xe3u26zWVu.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3176,"height":1786,"file_path":"/AqHxr7zLhdLL2D4rrUVHl4CuVd.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3170,"height":1783,"file_path":"/8p7bon3DNQOVS2yDFPwfo70Boy8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3197,"height":1798,"file_path":"/xnRYxtHQrtvl5fjpjqO1VRWclY4.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":null,"enrichment_cycle":0,"translations":[{"data":{"title":"","runtime":94,"tagline":"An ancient device. A modern discovery. A terrifying tale of the eternal.","homepage":"","overview":"Faced with his own mortality, an ingenious alchemist tried to perfect an invention that would provide him with the key to eternal life. It was called the Cronos device. When he died more than 400 years later, he took the secrets of this remarkable device to the grave with him. Now, an elderly antiques dealer has found the hellish machine hidden in a statue and learns about its incredible powers. The more he uses the device, the younger he becomes...but nothing comes without a price. Life after death is just the beginning as this nerve-shattering thriller unfolds and the fountain of youth turns bloody."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":94,"tagline":"","homepage":"","overview":"Au XIVe siècle, à Veracruz au Mexique, un alchimiste créée l'horloge Cronos, un scarabée d'or mécanique dont une piqure de son dard offrirait l'immortalité à son utilisateur. Ce dernier finit par trouver la mort dans l'effondrement  d'un immeuble en 1937, la peau blanchie comme du marbre. 60 ans plus tard, l'horloge est retrouvée par un vieil antiquaire, Jésus Gris, qui  l'active involontairement sur lui. Il en ressent les effets, mais développe aussi une dépendance envers l'objet et une soudaine soif de sang. Il ne tarde pas à être la cible d'un riche homme d'affaire mourant, prêt à tout pour s'emparer de l'horloge."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Cronos","runtime":94,"tagline":"","homepage":"","overview":"Cronos es un artefacto creado por un alquimista medieval, en cuyo interior se encuentra instalado un insecto, que se alimenta de sangre y tiene el poder de ofrecer la eterna juventud. Premiada película con excelentes críticas."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":94,"tagline":"","homepage":"","overview":"Em 1535, um alquimista constroi um mecanismo extraordinário encapsulado num pequeno aparelho dourado. A invenção, que pretendia conferir vida eterna ao seu utilizador, sobrevive ao seu criador até 1997, quando surge num antiquário. Fascinado com o estranho aparelho, Gris não repara que há mais uma pessoa há procura dele. A promessa de vida eterna tornou-se uma obsessão para o velho e doente Mr. De la Guardia. Ele e o seu sobrinho farão tudo para apanhar o «Cronos»."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Хронос","runtime":92,"tagline":"","homepage":"","overview":"«Хронос» — это чудесное маленькое устройство, которое, сбежавший из Испании в Мексику гениальный алхимик Умберто Фальконелли, изобрел в 1536 году. Устройство, дарующее бессмертие… Правда, в 1937 году жизнь алхимика все-таки оборвалась в результате трагической случайности. Потому что «Хронос» обещал вечную жизнь при условии, что владелец будет собственной кровью питать его…  Имущество особняка, где жил алхимик, было продано с молотка. И вот однажды хозяин антикварного магазина старик Хесус Грис расковырял фигурку ангела и, обнаружив внутри странную коробочку, привел в действие ее заводной механизм… Так у «Хроноса» появился новый владелец, но не только ему был известен секрет бессмертия…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Dem Antiquitätenhändler Jesus Gris fällt ein geheimnisvoller Apparat in die Hände: Die Cronos-Maschine. Sie verleiht ewiges Leben, aber wer sie benutzt wird durstig nach Blut. Um in ihren Besitz zu kommen, schreckt ein reicher, sterbenskranker Industrieller auch vor Mord nicht zurück - doch die Toten kehren zurück..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"קרונוס","runtime":0,"tagline":"","homepage":"","overview":"סרט האימה המסוגנן של הבמאי המקסיקני גיירמו דל-טורו (\"בלייד\", \"המבוך של פאן\") על מתקן לחיי נצח שפותח ע\"י אלכימאי ומוצא את דרכו, כעבור דורות, למוכר עתיקות מבוגר. זכה בכל פרס אפשרי כולל כל הפרסים החשובים של האקדמיה המקסיקאית ובפסטיבל קאן."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Antikacı dükkanı işletmekte olan Jesus Gris tesadüfen, 450 yıl önce bir simyacı tarafından icat edilmiş mekanik bir kapsül bulur. Filmde, yapıştığı kişiye gençlik ve güç aşılayan, örümcek şeklinde olan bu altın kapsülün aynı zamanda insan kanı içilmeden bastırılamayan bir açlık getirdiğini de farkeden Gris'in insandan vampire dönüşme süreci anlatılır. İçinde bulunduğu karışık durumdan çıkış yolu bulamayan Gris'in vücudundaki kapsülün peşinde olan başkalarının da olduğunu öğrenmesi uzun sürmeyecektir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Een vernuftig toestelletje in 24 karaat-goud, met binnenin een complex mechanisme van tandwieltjes, radertjes en veertjes, zou volgens een alchemist die het voorwerp maakte, het eeuwige leven verschaffen aan diegene die het in z'n bezit heeft. Een Europese industrieel vindt eeuwen later het begeleidende dagboek en raakt erdoor geobsedeerd. Het voorwerp zelf komt in handen van een nietsvermoedende antiekhandelaar uit Mexicostad."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"크로노스","runtime":0,"tagline":"","homepage":"","overview":"1536년 한 연금술사에 의해 영원한 삶을 주는 조그마한 기계인 '크로노스'라는 것이 발명된다. 연금술사는 순금의 달걀 모양인 크로노스의 사용법을 일기장에 적어둔 채 홀연히 사라져 버린다. 400년이 지난 후 골동품상을 경영하던 헤수스(Jesus Gris: Federico Luppi 분)는 유독 이상한 석고상을 찾는 손님을 이상하게 생각하던 중 창고 속에 보관되어 있던 석고상에서 정체를 알 수 없는 기계 크로노스를 발견한다.  우연한 기회에 크로노스를 사용하게 된 헤수스는 그것이 주는 젊음의 정체를 알지 못한채 중독되어 점점 뱀파이어로 변해가게 되고, 크로노스의 사용법이 적힌 연금술사의 일기장을 손에 넣은 데테(Dieter de la Guardia: Claudio Brook 분)의 부하 엔젤(Angel de la Guardia: Ron Perlman 분)에게 쫓기게 된다. 결국 헤수스는 데테와 엔젤을 죽이지만 크로노스의 비밀을 알고나서 마지막 선택의 딜레마에 빠져든다. 크로노스에 의지해 영원히 뱀파이어로 살것인가, 아니면 뱀파이어로의 삶을 포기하고 인간으로 죽음을 맞이할 것인가."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"クロノス","runtime":0,"tagline":"存在してはならなかった。","homepage":"","overview":"16世紀、ある錬金術師によって作り出された金色の奇妙なスカラベ。永遠の命をもたらす「クロノス」と呼ばれる謎の精密機械だった。時は流れて現代、骨董商ヘススは売り物の天使像の中からクロノスを発見し手に乗せたとたん突然動き、彼の手に食い込むと長い針を刺し液体を注入した。不死を得ようとクロノスを探す病床の大富豪デ・ラ・グァルディアは、甥アンヘルから発見の報せを受ける。孫娘アウロラの不安をよそにクロノスの虜となっていくヘススは次第に若返っていくが、同時に血への渇望も沸き起こっていた。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"魔鬼银爪","runtime":94,"tagline":"","homepage":"","overview":"四百多年前一位练金术士为寻求永生，而完成了神奇的「克隆斯」装置。本世纪练金术士意外死亡之后，克隆斯几经流传来到了一家古董店。店主格里斯在不知情下误用了克隆斯，虽然有返老还童之效，却也招致许多麻烦。大企业主迪拉加迪亚寻找克隆斯历经40年之久，得知为格里斯拥有之后，千方百计想置他于死地并夺走克隆斯。然而永生并不是那么悦人之事，你必须依赖人血为生，全身蜕皮如同雪白的毛虫。格里斯不想犯下大错，便将克隆斯损毁，并在亲人的接纳与柔情中等待其生命的终结…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Хронос","runtime":0,"tagline":"Давній пристрій. Нове дослідження. Жахлива історія безсмертя.","homepage":"","overview":"Хронос — це чудовий маленький пристрій, що дарує безсмертя..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"","runtime":94,"tagline":"","homepage":"","overview":"I  året 1535 opfinder en alkymist en usædvanlig mekanisme, som han placerer i en lille guldkapsel. Opfindelsen, som er beregnet på at give sin ejermand evigt liv, dukker i nyere tid op hos en antikvitetshandler, der bliver så fascineret af den mystiske kapsel, at han ikke bemærker, at andre også er ude efter den. Ved udsigten til et evigt liv vil den syge og gamle Mr. La Guardia med hjælp fra sin nevø gøre hvad som helst for at få fingrene i den."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Kronos","runtime":0,"tagline":"","homepage":"","overview":"Paslaptingas alchemiko sukurtas prietaisas, suteikiantis jo naudotojui amžinąjį gyvenimą, prabėgus keturiems šimtmečiams, netikėtai atsiranda, atnešdamas tik pragaištį."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"La invención de Cronos","runtime":0,"tagline":"","homepage":"","overview":"Cronos es un artefacto creado por un alquimista medieval, en cuyo interior se encuentra instalado un insecto, que se alimenta de sangre y tiene el poder de ofrecer la eterna juventud. Premiada película con excelentes críticas."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"Um dispositivo antigo. Uma descoberta moderna. Uma história aterrorizante do eterno.","homepage":"","overview":"Em 1536, o alquimista Humberto Oganelli desembarcou em Veracruz, no México. Lá ele criou um objeto de ouro chamado Cronos, que concede vida eterna a quem o detém. Quatro séculos depois, a queda de parte de um prédio gera algumas vítimas. Entre elas está um homem de pele estranha, alquimista. As autoridades localizam sua residência, mas jamais divulgam o que encontraram no local. Após uma rápida investigação, o conteúdo da mansão é leiloado. Com isso Cronos chega às mãos de um vendedor de antiguidades que, acidentalmente, dispara seu mecanismo. De seu interior sai uma aranha, que injeta no corpo de seu portador um estranho líquido. Aos poucos ele percebe que seu corpo está rejuvenescendo, mas também passa a ter uma obsessão por sangue."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Stroj času","runtime":0,"tagline":"","homepage":"","overview":"V roce 1536 alchymista Uberto Fulcanelli, skrývající se před inkvizicí v Mexiku, započal práci na zařízení, které mělo svému majiteli dopomoci k věčnému životu. To zařízení se jmenovalo Cronos. O čtyři století později nalezne starožitník Jesus Gris podivný přístroj ukrytý v starobylé sošce archanděla. Jesus kouzlu mechanického skarabea, jenž odměnou za lidkskou krev propůjčuje svému majiteli novou životní energii, záhy podléhá. Není však sám, kdo o existenci Cronosu ví..."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Stroj času","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"","runtime":94,"tagline":"Un dispositif ancien. Une découverte moderne. Un terrifiant conte de l'éternel.","homepage":"","overview":"Au XIVe siècle, un alchimiste enferme le secret de l'éternité dans une petite boite. Plus de six siècles après, en 1997, un antiquaire est sur le point de libérer cette force inconnue. Cronos est le premier long métrage réalisé par le metteur en scène mexicain Guillermo Del Toro. On y retrouve déjà quelques-uns de ses thèmes récurrents, notamment à travers l'usage fréquent de symboles religieux, comme le nom du personnage principal du film, Jésus Gris."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"A Cronos egy XVI. századi alkimista találmány, ami az alany testére csatlakozva halhatatlanná is mutálja azt. Dieter de la Guardia, a haldokló üzletember mindent megtenne, hogy megszerezze a szerkezetet. Balszerencséjére Jesús Gris, az idős antikvárius előbb bukkan a masinára, és hiába gyilkoltatja meg őt a riválisa, a vámpírrá transzformálódott öreg megszökik a boncasztalról, hogy bosszút álljon a gyilkosán."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"L'antiquario Jésus Gris entra in possesso di un misterioso congegno ad orologeria, posto alla base della statuetta di un angelo, costruito da un alchimista sfuggito in Messico ad una condanna dell'Inquisizione verso la metà del XVI secolo. All'interno è racchiuso uno scarabeo meccanico la cui puntura dona l'immortalità."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"W 1535 roku skonstruowane zostało tajemnicze urządzenie zapewniające wieczne życie wszystkim, którzy wejdą w jego posiadanie. Kilkaset lat później, w 1997 roku, właścicielem cudownego wynalazku zostaje starzejący się antykwariusz Jesus Gris. Antykwariusz nie zdaje sobie sprawy, że mechanizmu poszukują także umierający Dieter de la Guardia i jego bratanek Angel, który za wszelką cenę chce przedłużyć życie swojego wuja."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"魔鬼銀爪","runtime":0,"tagline":"","homepage":"","overview":"四百多年前，一名煉金術士為求長生不老，發明了一種叫做「魔鬼銀爪」的裝置，沒想到進入二十世紀，卻死於一場意外。多年後，這個奇異的裝置藏在一尊天使雕像裡進了一家古董店。上了年紀的店主無意間啟動了它，竟然產生返老還童之效，但也招來意外麻煩……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"魔鬼銀爪","runtime":0,"tagline":"","homepage":"","overview":"四百多年前，一名煉金術士為求長生不老，發明瞭一種叫做「魔鬼銀爪」的裝置，沒想到進入二十世紀，卻死於一場意外。多年後，這個奇異的裝置藏在一尊天使雕像裏進了一家古董店。上了年紀的店主無意間啟動了它，竟然產生返老還童之效，但也招來意外麻煩……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":24232,"adult":false,"title":"Daria in 'Is It College Yet?'","video":false,"overview":"All vile things must come to an end, and for Daria Morgendorffer that means it's time to look beyond high school to college. Our little girl has grown up so fast. It's time for higher learning, lowered expectations, and a heavy dose of sarcasm. Life can't suck more after high school, can it?","genre_ids":[16,35,10770],"media_type":"movie","popularity":0.6011,"vote_count":78,"poster_path":"/ws4PQmOVgRvCUlwyHv7JnJnrY3M.jpg","release_date":"2002-01-21","vote_average":7.295,"backdrop_path":"/hutD3pVcdogYQnhOyDKVDPMnCYG.jpg","original_title":"Daria in 'Is It College Yet?'","original_language":"en"},{"id":110204,"adult":false,"title":"The Killing Game","video":false,"overview":"Eve Duncan is contacted, 10 years after the disappearance and murder of her 7-year-old daughter Bonnie, by a man claiming to be her killer. Taunted by his clues about Bonnie's case and his threats to kill again, she throws herself into her career as a forensic sculptor and works to close the case.","genre_ids":[9648,53,10770],"media_type":"movie","popularity":0.4066,"vote_count":21,"poster_path":"/si8hSXOzBRQgzMP8aRb6fCrXpvc.jpg","release_date":"2011-10-30","vote_average":6.1,"backdrop_path":"/c7BgkM5snY6DoSEepCONrwjf74C.jpg","original_title":"The Killing Game","original_language":"en"},{"id":160004,"adult":false,"title":"Geometry","video":false,"overview":"A boy is tired of failing geometry, so he summons a demon.","genre_ids":[35,27],"media_type":"movie","popularity":0.2169,"vote_count":58,"poster_path":"/2Ch38McqOKI22C3r0q9U3ZJuy1X.jpg","release_date":"1987-01-01","vote_average":6.103,"backdrop_path":"/gJaNmOM7YPQHeKlOgnz2W2zgRUx.jpg","original_title":"Geometría","original_language":"es"},{"id":930835,"adult":false,"title":"Ryan Reynolds: I'm a Laureate?","video":false,"overview":"Ryan Reynolds reflects on his childhood, family and career—punctuated by diversions into the charitable side of Twitter to appeal to his Canadian sense of self.","genre_ids":[99,35],"media_type":"movie","popularity":0.2227,"vote_count":2,"poster_path":"/pS7SATwmGwaB7HhqkiOkGivTh22.jpg","release_date":"2021-11-29","vote_average":6.5,"backdrop_path":null,"original_title":"Ryan Reynolds: I'm a Laureate?","original_language":"en"},{"id":67655,"adult":false,"title":"Bloodlust Zombies","video":false,"overview":"A military weapons manufacturer creates a chemical weapon that causes victims to become blood-lusting killers. A lab accident causes the building to go into lock-down and the employees are trapped inside with the crazed killers.","genre_ids":[27,35],"media_type":"movie","popularity":0.5463,"vote_count":27,"poster_path":"/2h0y7ifXEixCtzUNDB280M6HXgx.jpg","release_date":"2011-07-05","vote_average":3.759,"backdrop_path":"/qaWIFESGipZwkz2XNkI3fpdwz3o.jpg","original_title":"Bloodlust Zombies","original_language":"en"},{"id":417499,"adult":false,"title":"Comeback","video":false,"overview":"Amador is a retired and ostracized gunman. Alone and bitter, he collects newspaper clippings of his old crimes in an album. After several humiliations, he will react with violence to the world’s hostility that surrounds him while also trying to get back to action.","genre_ids":[18,37],"media_type":"movie","popularity":1.4371,"vote_count":17,"poster_path":"/qTMWYZuBZKqAEkUdBC4sSBkX7wC.jpg","release_date":"2017-05-21","vote_average":6.5,"backdrop_path":null,"original_title":"Comeback","original_language":"pt"},{"id":1480623,"adult":false,"title":"We, the Waves","video":false,"overview":"On her anniversary, Sofia gathers her three daughters - writer Vyara, devoted mother Nadya and lost soul Lyuba. But the celebration is shaken by an unexpected incident - Nadya's husband Stefan mysteriously disappears. This reveals deeply buried secrets and forces the women to confront the past, the choices they have made and the fragile bonds between them.","genre_ids":[18,10751,53],"media_type":"movie","popularity":0.1684,"vote_count":1,"poster_path":"/cUDRlKQEzwtcBpSXJxVtvEolNVN.jpg","release_date":"2025-04-05","vote_average":9,"backdrop_path":"/xy39k96WTuFtCuBa9Mj3OmQBdcb.jpg","original_title":"Те, вълните","original_language":"bg"},{"id":290802,"adult":false,"title":"Night Will Fall","video":false,"overview":"When Allied forces liberated the Nazi concentration camps in 1944-45, their terrible discoveries were recorded by army and newsreel cameramen, revealing for the first time the full horror of what had happened. Making use of British, Soviet and American footage, the Ministry of Information’s Sidney Bernstein (later founder of Granada Television) aimed to create a documentary that would provide lasting, undeniable evidence of the Nazis’ unspeakable crimes. He commissioned a wealth of British talent, including editor Stewart McAllister, writer and future cabinet minister Richard Crossman – and, as treatment advisor, his friend Alfred Hitchcock. Yet, despite initial support from the British and US Governments, the film was shelved, and only now, 70 years on, has it been restored and completed by Imperial War Museums under its original title \"German Concentration Camps Factual Survey\".","genre_ids":[99],"media_type":"movie","popularity":0.5494,"vote_count":85,"poster_path":"/lEsfJbN5BBw1wlqCvzxuBLGwitt.jpg","release_date":"2014-06-07","vote_average":7.6,"backdrop_path":"/kj4Q9NHNLvdFx0PlfBSxo0mpmCU.jpg","original_title":"Night Will Fall","original_language":"en"},{"id":34372,"adult":false,"title":"The Execution of Mary, Queen of Scots","video":false,"overview":"A short film depicting the execution of Mary, Queen of the Scots. Mary is brought to the execution block and made to kneel down with her neck over it. The executioner lifts his axe ready to bring it down. After that frame Mary has been replaced by a dummy. The axe comes down and severs the head of the dummy from the body. The executioner picks up the head and shows it around for everyone else to see. One of the first camera tricks to be used in a movie.","genre_ids":[36],"media_type":"movie","popularity":0.2035,"vote_count":123,"poster_path":"/gfofUsszXObBAvH9FLXfO3mwaXJ.jpg","release_date":"1895-08-28","vote_average":6.3,"backdrop_path":"/6Boy7ZCX6em6KQLIOrt6YdJdj4b.jpg","original_title":"The Execution of Mary, Queen of Scots","original_language":"xx"},{"id":17991,"adult":false,"title":"Tetsuo II: Body Hammer","video":false,"overview":"A Japanese salaryman finds his body transforming into a weapon through sheer rage after his son is kidnapped by a gang of violent thugs.","genre_ids":[878,27,18],"media_type":"movie","popularity":0.4133,"vote_count":132,"poster_path":"/w2We4S0SmRP72BKpvtOfyu9cF6H.jpg","release_date":"1992-10-03","vote_average":6.2,"backdrop_path":"/bMYcQ5l9AxLSgXwP8ImqqqtYKkN.jpg","original_title":"鉄男II BODY HAMMER","original_language":"ja"},{"id":24735,"adult":false,"title":"Agnes of God","video":false,"overview":"When a dead newborn is found, wrapped in bloody sheets, in the bedroom wastebasket of a young novice, psychiatrist Martha Livingston is called in to determine if the seemingly innocent novice, who knows nothing of sex or birth, is competent enough to stand trial for the murder of the baby.","genre_ids":[18,9648],"media_type":"movie","popularity":0.7719,"vote_count":133,"poster_path":"/m2QrxkojSmQb9k4DN6qhovDHLwD.jpg","release_date":"1985-09-13","vote_average":6.3,"backdrop_path":"/jtpnnGqe8tiDPsFsW91kB8wHKfa.jpg","original_title":"Agnes of God","original_language":"en"},{"id":86814,"adult":false,"title":"News from Home","video":false,"overview":"Impersonal and beautiful images of Akerman's life in New York are combined with letters from her loving but manipulative mother, read by Akerman herself.","genre_ids":[99],"media_type":"movie","popularity":0.4242,"vote_count":86,"poster_path":"/nWqWaEySdo8hAKJsd1IS9mdnZpF.jpg","release_date":"1977-05-20","vote_average":7,"backdrop_path":"/A37wxjHIy75UhpAi5K0p8iFRQgC.jpg","original_title":"News from Home","original_language":"fr"},{"id":1433,"adult":false,"title":"The Devil's Backbone","video":false,"overview":"Spain, 1939. In the last days of the Spanish Civil War, the young Carlos arrives at the Santa Lucía orphanage, where he will make friends and enemies as he follows the quiet footsteps of a mysterious presence eager for revenge.","genre_ids":[14,18,27,53],"media_type":"movie","popularity":1.5023,"vote_count":1328,"poster_path":"/iP1z1aJzPnkP8FHg77TS7ukqoEZ.jpg","release_date":"2001-04-20","vote_average":7.281,"backdrop_pa