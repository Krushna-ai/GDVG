9:{"metadata":[["$","title","0",{"children":"Curse of the Golden Flower | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"During China's Tang dynasty the emperor has taken the princess of a neighboring province as his wife. She has borne him two sons and raised his eldest. Now his control over his dominion is complete, including the royal family itself."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/102028/curse-of-the-golden-flower"}],["$","meta","5",{"property":"og:title","content":"Curse of the Golden Flower"}],["$","meta","6",{"property":"og:description","content":"During China's Tang dynasty the emperor has taken the princess of a neighboring province as his wife. She has borne him two sons and raised his eldest. Now his control over his dominion is complete, including the royal family itself."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/102028/curse-of-the-golden-flower"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/gHkkDpfo5YnOrbVfwtDHi91BkrU.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Curse of the Golden Flower"}],["$","meta","12",{"name":"twitter:description","content":"During China's Tang dynasty the emperor has taken the princess of a neighboring province as his wife. She has borne him two sons and raised his eldest. Now his control over his dominion is complete, including the royal family itself."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/gHkkDpfo5YnOrbVfwtDHi91BkrU.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]