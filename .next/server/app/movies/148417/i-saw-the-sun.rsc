TR","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/yceigg3PMKQPnCTJrbDEfnvfGDC.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/1CpKklOt4f4mKTqnNb4dzDV110D.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1537,"height":865,"file_path":"/aL1nc6Ps6eTNyLYP0y16WMMcLRi.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1579,"height":888,"file_path":"/aOEgF9jjiXmxD3p1nieel6gZRMR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:58:34.891+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"I Saw the Sun","runtime":115,"tagline":"Children here don't shape their own destiny.","homepage":"","overview":"In the southeast region of Turkey, the Kurdish family of Altun lives in a small mountainside village plagued by a 25-year war that makes their daily lives a hellish struggle. As the war intensifies, the family is forced to migrate west to the city of Istanbul."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":114,"tagline":"Buradaki çocukların kaderlerini kim yazıyor?","homepage":"","overview":"Her türlü ayrımcılığa ve ötekileştirilmeye karşı duran, savaşın, kavganın, kendine benzemeyeni hor görmenin sorunun ta kendisinin olduğunu anlatan bu film, bir anlamda \"Türkiye’nin hikayesi\"…Kars Sarıkamış’ın bir dağ köyünde yaşayan Ramo ve ailesi, bölgede yaşanan terör sorununun göbeğinde hayatlarını sürdürmektedirler. Mayın ve silah patlamaları, asker ve dağa çıkmış gerillalar arasında süren savaş onların gündelik hayatlarının bir parçası olmuştur. Ancak çıkan bir çatışma sonucunda köye gelen komutan, ailelerden köyü boşaltmalarını ister. Ramo ve ailesi çareyi İstanbul’a gitmekte bulur. Beyoğlu’nun arka sokaklarından birine yerleşen aile burada şansını denemeye karar verir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Günesi Gördüm - Ich habe die Sonne gesehen","runtime":120,"tagline":"","homepage":"","overview":"Die kurdische Großfamilie Altun lebt in einem ostanatolischen Dorf in der Nähe von Kars. Haydar Altun ist sehbehindert, hat drei Söhne Ramo, Mamo und den femininen Kadri (Kado). Ramo hat vier Töchter, davon eine geistig behindert, und eine Frau Havar. Davut Altun hat eine Frau und drei Söhne, der jüngste Sohn Azat hat bei einer Minenexplosion ein Bein verloren, der andere Sohn Serhat hat sich den Guerillakämpfern angeschlossen, in weiterer kämpft beim türkischen Militär gegen Terroristen. Ramo wünscht sich nichts sehnlicher als einen Sohn."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"战火重生","runtime":0,"tagline":"","homepage":"","overview":"此片献给和平与孩子们。 一座大山阻隔了两个截然不同的世界。在这里世世代代安居乐业，然而随着大批政府军队的入侵，一切都将不复从前。两个部落成员，海达和伊沙在伊斯坦布尔定居，另一位阿尔顿则与妻子和孩子搬到了挪威。影片跨过了25年的时间，讲述了三组失散的家庭的故事。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":120,"tagline":"","homepage":"","overview":"In een grensdorp in het oosten van Turkije zit te midden van landmijnen een groep hulpeloze mensen al 25 jaar lang tussen twee vuren. Als gevolg van gedwongen migratie zijn de leden van familie Altun genoodzaakt hun geboortegrond te verlaten. Ze worden van hun wortels losgerukt en gaan op weg. Het onbekende tegemoet. Davut Altun wil zo snel mogelijk met zijn gezin naar Noorwegen, al moet dat op illegale wijze, en de weg van Haydar Altun en zijn gezin leidt naar Istanboel. De reis is begonnen..."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Vi el sol","runtime":0,"tagline":"Los niños aquí no dan forma a su propio destino.","homepage":"","overview":"En la región sureste de Turquía, la familia Altun vive en una pequeña aldea en la ladera de una montaña asolada por una guerra de 25 años, lo que hace de su vida diaria una lucha infernal. A medida que la guerra continúa intensificándose, la familia se ve obligada a emigrar hacia el oeste a la ciudad de Estambul. Mientras Haydar e Isa Altun deciden quedarse en Turquía con sus hijos pequeños, Davut Altun y su familia emigran al norte a Noruega, solicitando la ayuda de contrabandistas. Finalmente llegan a su destino y encuentran trabajo en un supermercado, pero la vida como refugiados es implacable. Su hijo se hace amigo de un grupo de travestis, lo que le ayuda a comprender por qué se ha sentido diferente toda su vida. Si bien es liberador, su nueva identidad es vista como una vergüenza para el resto de su familia, lo que lo lleva a huir del abuso que produce."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Я видел Солнце","runtime":0,"tagline":"","homepage":"","overview":"В юго-восточной Турции идет многолетняя война, от которой люди стараются укрыться в горных пещерах. Уходя от огня и лишений, главные герои картины решаются на разлуку – одни представители семьи остаются в Стамбуле, на родине, а другие, с помощью контрабандистов, уезжают в Норвегию. Их участь, как и судьба других эмигрантов, нелегка – с трудом найдя работу в супермаркете, они живут как беженцы, готовые в любую минуту сорваться с места. Тем временем, оставшаяся в Стамбуле семья несчастлива по-своему: героиня картины переносит операцию из-за осложнений, возникших во время беременности, а ее сын сходится с компанией трансвеститов, которые стараются внушить ему новую систему ценностей.."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Günesi Gördüm","runtime":0,"tagline":"","homepage":"","overview":"L’histoire de la famille Altun ressemble à celle de 2,5 millions de Kurdes : ils ont quitté leur région d’origine car ils ne se sentaient plus chez eux en Turquie. Pour la Famille Altun comme pour les autres Kurdes, le départ n’a pas été volontaire, loin de là. C’est l’histoire de leur vie, une vie mouvementée qui les a menés du sud-ouest de la Turquie vers Istanbul ou vers des pays lointains comme la Norvège.  Un des fils Altun s’est enrôlé dans l’armée turque. Un autre a rejoint les rangs des combattants kurdes. Quant au plus jeune fils des Altun, il a perdu ses deux jambes après avoir marché sur une mine antipersonnel. Jour après jour, les familles qui vivent encore dans les villages kurdes prennent le chemin de l’exil et rejoignent les nombreux réfugiés des villes. Et pour Kadri, un autre fils de la famille Altun, la situation est encore plus complexe. Au cœur de la tourmente et de la guerre, il souffre de ne pouvoir vivre librement son homosexualité."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Günesi Gördüm","runtime":0,"tagline":"Aqui, as crianças não moldam o seu próprio destino.","homepage":"","overview":"Na região sudeste da Turquia, a família curda Altun vive numa pequena aldeia nas montanhas, assolada por uma guerra de 25 anos que torna o seu dia a dia uma luta infernal. À medida que a guerra se intensifica, a família é forçada a migrar para oeste, para a cidade de Istambul."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"}],"reviews_tmdb":[],"recommendations":[{"id":321050,"adult":false,"title":"The Miracle","video":false,"overview":"1960s Turkey countryside. A newly assigned teacher finds out that the solitary village is missing a school. He gets fond of the village people and especially a disabled man. The teacher helps the village to build a new school and educate the children and the disabled man.","genre_ids":[35,18,10749],"media_type":"movie","popularity":1.4486,"vote_count":120,"poster_path":"/baXozaGF8180QrZFuqlPrlLqCQc.jpg","release_date":"2015-01-01","vote_average":7.113,"backdrop_path":"/gFJ9i3eANzMo8kpowofbFQMHJyV.jpg","original_title":"Mucize","original_language":"tr"},{"id":11109,"adult":false,"title":"Vera Drake","video":false,"overview":"Abortionist Vera Drake finds her beliefs and practices clash with the mores of 1950s Britain – a conflict that leads to tragedy for her family.","genre_ids":[18],"media_type":"movie","popularity":1.0624,"vote_count":385,"poster_path":"/556fElboCLlEmP8UULaYosU45Bc.jpg","release_date":"2004-10-22","vote_average":7.2,"backdrop_path":"/mk2QjEa8qh7DsoIrtelJdvK8Uuq.jpg","original_title":"Vera Drake","original_language":"en"},{"id":20825,"adult":false,"title":"I Hate Valentine's Day","video":false,"overview":"A love story set in Manhattan, where a florist who abides by a strict five-date-limit with any man finds herself wanting more with the new restaurateur in town.","genre_ids":[35,10749],"media_type":"movie","popularity":0.7514,"vote_count":273,"poster_path":"/j0iHgzfThoAlrgoiuix7BS1ezao.jpg","release_date":"2009-06-27","vote_average":5.352,"backdrop_path":"/nwriVtJ2YF7ZX196Ddp8tpJVrSs.jpg","original_title":"I Hate Valentine's Day","original_language":"en"},{"id":300490,"adult":false,"title":"Whisper If I Forget","video":false,"overview":"An old pop singer who has Alzheimer's returns to her old house where she remembers her old days of climbing the stairs of fame and fortune while trying to deal with her older sister who holds her responsible for her ruined life.","genre_ids":[10402,18],"media_type":"movie","popularity":0.1948,"vote_count":58,"poster_path":"/91cc9UlIwJBJwi8O8qVls4SVm72.jpg","release_date":"2014-10-29","vote_average":7.31,"backdrop_path":"/homTx1TmRkmk8tt42PuWtlLABa6.jpg","original_title":"Unutursam Fısılda","original_language":"tr"},{"id":17903,"adult":false,"title":"A Frozen Flower","video":false,"overview":"A historical drama set in the Koryo dynasty and focused on the relationship between a king and his bodyguard.","genre_ids":[18],"media_type":"movie","popularity":4.1411,"vote_count":155,"poster_path":"/jvGmbNUh0eq9ShQmMSof0DXXHWY.jpg","release_date":"2008-12-30","vote_average":6.852,"backdrop_path":"/9bvn5SWwAK6qB79UevNi0jqhfke.jpg","original_title":"쌍화점","original_language":"ko"},{"id":18063,"adult":false,"title":"Gallipoli","video":false,"overview":"The Gallipoli campaign of World War I was so controversial & devastating, it changed the face of battle forever. Using diaries, letters, photographs and memoirs, acclaimed director, Tolga Ornek, traces the personal journeys of Australian, New Zealand, British and Turkish soldiers, from innocence and patriotism to hardship and heartbreak.","genre_ids":[99,10752],"media_type":"movie","popularity":0.7475,"vote_count":28,"poster_path":"/nx5e5QdHQfmxKwkRIP8W7vAcRC4.jpg","release_date":"2005-03-18","vote_average":7.1,"backdrop_path":"/xOXduXMMxMaFkn8pIzcRkt5Gh1J.jpg","original_title":"Gelibolu","original_language":"en"},{"id":443041,"adult":false,"title":"Vezir Parmağı","video":false,"overview":"In this story set in ancient times, 31 women who lost their husbands, fathers, and children in war rise up against their lack of men after many years and demand that the state send them men to marry and have children. Five single men from different regions and cultures are selected at a porter market in Istanbul to marry these 31 women. The selected men, unaware of what awaits them, believe they are going to war. However, the porters, referred to as \"human donkeys,\" find themselves in a completely different adventure instead of the front lines.","genre_ids":[18,35],"media_type":"movie","popularity":0.198,"vote_count":18,"poster_path":"/iQUByrwG9TZUJ5o0DNirUfXrjMm.jpg","release_date":"2017-01-25","vote_average":3.8,"backdrop_path":"/oAPzlfqFYwlsrblMFx3c8CwwgvQ.jpg","original_title":"Vezir Parmağı","original_language":"tr"},{"id":137180,"adult":false,"title":"Aiyyaa","video":false,"overview":"Meenakshi, a Marathi gal with an ultra-sensitive sense of smell, lives her life in her dreams, dancing and enacting her favourite actresses Sridevi, Madhuri and Juhi. Not believing in arranged marriages, Meenakshi awaits her prince when she comes across Tamil artist Surya, to whom she is strangely attracted to.","genre_ids":[10749,35],"media_type":"movie","popularity":0.1922,"vote_count":30,"poster_path":"/gz4zgMZGg3zYOLYL7qzOQwDP13.jpg","release_date":"2012-10-12","vote_average":4.7,"backdrop_path":"/dwAADvsDwXUHbHE8JtOYMhy2aaq.jpg","original_title":"अइय्या","original_language":"hi"},{"id":1052,"adult":false,"title":"Blow-Up","video":false,"overview":"A successful mod photographer in London whose world is bounded by fashion, pop music, marijuana, and easy sex, feels his life is boring and despairing. But in the course of a single day he unknowingly captures a death on film.","genre_ids":[18,9648,53],"media_type":"movie","popularity":1.9999,"vote_count":1340,"poster_path":"/jVDVpydUw8Z50naUDAG4NbRCrSa.jpg","release_date":"1966-12-18","vote_average":7.328,"backdrop_path":"/rWtRkNGkg05rET8taCA96c7heLb.jpg","original_title":"Blow-Up","original_language":"en"},{"id":19458,"adult":false,"title":"Princess Protection Program","video":false,"overview":"When her nation is invaded, a young princess is taken into the Princess Protection Program. She is relocated to Louisiana, where she stays with a covert agent and his tomboyish daughter, and must learn how to behave like an ordinary teenager.","genre_ids":[10751,10770,35,18],"media_type":"movie","popularity":2.4111,"vote_count":1747,"poster_path":"/tPKD9hmuYxclAQnfup47qLx8a5T.jpg","release_date":"2009-06-08","vote_average":6.648,"backdrop_path":"/fAPuRLDC1SHFdv3epZJbLLJsZFo.jpg","original_title":"Princess Protection Program","original_language":"en"},{"id":29917,"adult":false,"title":"Exam","video":false,"overview":"Eight talented candidates have reached the final stage of selection to join the ranks of a mysterious and powerful corporation. Entering a windowless room, where an armed guard keeps watch, they are given 80 minutes to answer one simple question.","genre_ids":[53,9648],"media_type":"movie","popularity":2.2467,"vote_count":2239,"poster_path":"/i1J2zBCyOQJKsQipqJ0qXERC1Ma.jpg","release_date":"2009-06-19","vote_average":6.7,"backdrop_path":"/AedRhfioYP2stHjsrLo8Qu6YBHK.jpg","original_title":"Exam","original_language":"en"},{"id":625568,"adult":false,"title":"Unhinged","video":false,"overview":"Rachel is a divorced single mother whose bad day gets even worse. She's running late to drop her son off at school when she honks her horn impatiently at a fellow driver during rush-hour traffic. After an exchange of words, she soon realizes that the mysterious man is following her and her young son in his truck. A case of road rage quickly escalates, at horrifyingly psychotic proportions, into full-blown terror as Rachel discovers the psychopath's sinister plan for revenge. He is single-mindedly determined to teach her a deadly lesson.","genre_ids":[28,53,27],"media_type":"movie","popularity":3.5011,"vote_count":2460,"poster_path":"/xfIcONZO4AiWpzm3jEpbR4llzVX.jpg","release_date":"2020-07-16","vote_average":6.439,"backdrop_path":"/wXk9y36eTmNl6XwEuOfw6yNNClr.jpg","original_title":"Unhinged","original_language":"en"},{"id":51739,"adult":false,"title":"The Secret World of Arrietty","video":false,"overview":"14-year-old Arrietty and the rest of the Clock family live in peaceful anonymity as they make their own home from items \"borrowed\" from the house's human inhabitants. However, life changes for the Clocks when a human boy discovers Arrietty.","genre_ids":[14,16,10751],"media_type":"movie","popularity":4.5226,"vote_count":3089,"poster_path":"/3lSRaSjDp2nkXMQkzzjpRi3035O.jpg","release_date":"2010-07-16","vote_average":7.7,"backdrop_path":"/7Z7WVzJsSReG8B0CaPk0bvWD7tK.jpg","original_title":"借りぐらしのアリエッティ","original_language":"ja"},{"id":800158,"adult":false,"title":"The Killer","video":false,"overview":"After a fateful miss, an assassin battles his employers, and himself, on an international manhunt he insists isn't personal.","genre_ids":[80,53],"media_type":"movie","popularity":5.7535,"vote_count":2697,"poster_path":"/e7Jvsry47JJQruuezjU2X1Z6J77.jpg","release_date":"2023-10-25","vote_average":6.583,"backdrop_path":"/mRmRE4RknbL7qKALWQDz64hWKPa.jpg","original_title":"The Killer","original_language":"en"},{"id":339964,"adult":false,"title":"Valerian and the City of a Thousand Planets","video":false,"overview":"In the 28th century, Valerian and Laureline are special operatives charged with keeping order throughout the human territories. On assignment from the Minister of Defense, the two undertake a mission to Alpha, an ever-expanding metropolis where species from across the universe have converged over centuries to share knowledge, intelligence, and cultures. At the center of Alpha is a mysterious dark force which threatens the peaceful existence of the City of a Thousand Planets, and Valerian and Laureline must race to identify the menace and safeguard not just Alpha, but the future of the universe.","genre_ids":[12,878,28],"media_type":"movie","popularity":6.3922,"vote_count":7869,"poster_path":"/vlc95gl3PtrjxSEuM8RhTtSm2xU.jpg","release_date":"2017-07-19","vote_average":6.63,"backdrop_path":"/5rYnygKCkmqWuMv1O5yAnzGF8gV.jpg","original_title":"Valerian and the City of a Thousand Planets","original_language":"en"},{"id":156022,"adult":false,"title":"The Equalizer","video":false,"overview":"McCall believes he has put his mysterious past behind him and dedicated himself to beginning a new, quiet life. But when he meets Teri, a young girl under the control of ultra-violent Russian gangsters, he can’t stand idly by – he has to help her. Armed with hidden skills that allow him to serve vengeance against anyone who would brutalize the helpless, McCall comes out of his self-imposed retirement and finds his desire for justice reawakened. If someone has a problem, if the odds are stacked against them, if they have nowhere else to turn, McCall will help. He is The Equalizer.","genre_ids":[53,28,80],"media_type":"movie","popularity":14.7973,"vote_count":9757,"poster_path":"/9u4yW7yPA0BQ2pv9XwiNzItwvp8.jpg","release_date":"2014-09-24","vote_average":7.281,"backdrop_path":"/wNAfVj1ObGNye5fQM4tJXJGtU0.jpg","original_title":"The Equalizer","original_language":"en"},{"id":138843,"adult":false,"title":"The Conjuring","video":false,"overview":"Paranormal investigators Ed and Lorraine Warren work to help a family terrorized by a dark presence in their farmhouse. Forced to confront a powerful entity, the Warrens find themselves caught in the most terrifying case of their lives.","genre_ids":[27,53],"media_type":"movie","popularity":12.0575,"vote_count":12515,"poster_path":"/wVYREutTvI2tmxr6ujrHT704wGF.jpg","release_date":"2013-07-18","vote_average":7.539,"backdrop_path":"/aQCCpAIdWAp6wyFgjMry4okwrZo.jpg","original_title":"The Conjuring","original_language":"en"},{"id":11324,"adult":false,"title":"Shutter Island","video":false,"overview":"World War II soldier-turned-U.S. Marshal Teddy Daniels investigates the disappearance of a patient from a hospital for the criminally insane, but his efforts are compromised by troubling visions and a mysterious doctor.","genre_ids":[18,53,9648],"media_type":"movie","popularity":15.5164,"vote_count":25455,"poster_path":"/nrmXQ0zcZUL8jFLrakWc90IR8z9.jpg","release_date":"2010-02-14","vote_average":8.2,"backdrop_path":"/8xt8AMb1OKC63AdhNSaYBWxB4Iq.jpg","original_title":"Shutter Island","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":23.0611,"vote_count":11386,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":475557,"adult":false,"title":"Joker","video":false,"overview":"During the 1980s, a failed stand-up comedian is driven insane and turns to a life of crime and chaos in Gotham City while becoming an infamous psychopathic crime figure.","genre_ids":[80,53,18],"media_type":"movie","popularity":19.3785,"vote_count":27338,"poster_path":"/udDclJoHjfjb8Ekgsd4FDteOkCU.jpg","release_date":"2019-10-01","vote_average":8.128,"backdrop_path":"/hO7KbdvGOtDdeg0W4Y5nKEHeDDh.jpg","original_title":"Joker","original_language":"en"}],"similar_content":[],"external_ids":{"imdb_id":"tt1347521","twitter_id":null,"facebook_id":null,"wikidata_id":"Q942852","instagram_id":null,"mydramalist_id":"168499"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148417,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"TR","release_dates":[{"note":"Source: https://www.themoviedb.org/movie/27960-g-ne-i-g-rd-m/edit?active_nav_item=release_information&language=en-GB","type":1,"iso_639_1":"tr","descriptors":[],"release_date":"2009-03-13T00:00:00.000Z","certification":""}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":"Southeastern Anatolia Region","review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikidata_metadata":{"distributors":["Pinema","Netflix"]},"mood_tags":null,"trope_tags":null,"vibe_description":null,"ai_enriched_at":null,"ai_enrichment_version":0}}]]
