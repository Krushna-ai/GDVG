rl2JoqOJqJxo9O4jHgQ.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":4,"aspect_ratio":0.696,"vote_average":0.958},{"width":666,"height":1000,"file_path":"/8cEUqclITeRZDYaQSDCqr0qTUTy.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":2,"aspect_ratio":0.666,"vote_average":0.166},{"width":812,"height":1200,"file_path":"/xLUksp4bwRhE8wlpsX6HapVsLoH.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":0.677,"vote_average":0.166},{"width":2000,"height":3000,"file_path":"/cJwaFPD8aD7otcqGTZf9oSENn5b.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/8o7zVCurUVtOb9A6G34MCeRaZaZ.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/hzDhyxSSHFxfTxXcnrl3hnKG3yg.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/c7tQ6auyiA8JAy6oBPwBG3kJIAR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1340,"height":754,"file_path":"/cormKw93ziHgyDOuigZusyKC7GO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.777,"vote_average":2.542},{"width":3840,"height":2160,"file_path":"/i4BuNikk3oFEzDhURl7vFG0FyL6.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":2.278},{"width":1280,"height":720,"file_path":"/6D3yIGGlhCGN3Ktx6439eZsq2D1.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":2,"aspect_ratio":1.778,"vote_average":0.166}]},"enriched_at":"2026-02-26T03:44:26.569+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":127,"tagline":"How many lives are you willing to sacrifice?","homepage":"","overview":"A special forces team is sent to snuff out a drug den, but find themselves trapped inside it after being set-up and betrayed."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"บายบัสต์ แผนล่อทะลวงถิ่น","runtime":0,"tagline":"","homepage":"","overview":"ในย่านสลัมที่เหมือนเขาวงกตแห่งกรุงมะนิลา ท่ามกลางสงครามของชาวเมืองผู้โกรธแค้นและแก๊งการค้ายาสุดเหี้ยม เจ้าหน้าที่พิเศษนีน่า มานิแกนต้องต่อสู้ผ่านคืนอันโหดร้ายนี้ให้ได้"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"BuyBust","runtime":128,"tagline":"","homepage":"","overview":"La nouvelle recrue Nina Manigan est une policière assignée à la brigade d'élite des stups. Son équipe est sélectionnée pour escorter des officiers de la police locale ayant organisé une saisie de drogues dans les bidonvilles de Manille. Quand la situation tourne au vinaigre, elle et ses collègues se retrouvent coincés en territoire ennemi. Ils doivent se prémunir des attaques des trafiquants, mais aussi de celles des résidents du coin qui s'en prennent à eux en représailles pour les victimes civiles tuées lors des opérations précédentes. Peu importe leur entraînement, rien ne les a préparés à ce qui deviendra pour eux la plus longue nuit de leurs vies."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"슬럼가 대습격","runtime":0,"tagline":"","homepage":"","overview":"마닐라의 경찰 특수부대가 마약조직 보스를 잡기 위해 거미줄처럼 복잡한 슬럼가에 진입한다. 기밀이 누설된 듯 조직원의 반격은 상상 이상으로 강하고, 슬럼가 주민들도 그들의 거리를 습격한 경찰을 공격한다. 를 벤치마킹한 듯, 후반부 한 시간 가량 이어지는 액션 장면이 돋보인다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Кървав арест","runtime":127,"tagline":"","homepage":"","overview":"Спецакция на Филипинската агенция за борба с наркотиците по залавянето на виден престъпен бос в най-опасния квартал в Манила прераства в кървава касапница..."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Nina Manigan  je príslušníčka filipínskej špeciálnej protidrogovej jednotky. Je chytrá, neortodoxná, uprednostňujúca vlastný inštinkt pred slepým vykonávaním rozkazov, čo jej v spojení so skutočnosťou, že ako jediná prežila vyhladenie jej špeciálnej jednotky, nepridáva na popularite u nadriadených a ani u kolegov. Ako jedinej sa jej nápad ísť pod rúškom tmy za jedným z vodcov narkomafie, Biggie Chenom do husto obývaného slumu Gracia Ni Maria na predmestí Manily vôbec nepozdáva. A vývoj udalosti jej dá za pravdu, jednotka uviazne v pasci. Na jednej strane sú tu po zuby ozbrojení príslušníci gangu, na strane druhej hordy nasrdených krvilačných obyvateľov štvrte, ktorí už majú po krk všetkých tých nekonečných záťahov. Nine a jej spolubojovníkom neostáva nič iné, než si cestu von vynútiť použitím sily."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"La agente Nina Manigan afronta una nueva misión: un operativo antidroga en el peor barrio de Manila, Filipinas. La misión se vuelve brutalmente peligrosa cuando la situación se complica y los vecinos se ponen en contra de los agentes."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Το Buy Bust είναι μια ταινία δράσης με στοιχεία τοπικών πολεμικών τεχνών,\r όπου πρωταγωνιστεί η Anne Curtis μαζί με τον πρωταθλητή βαρέων βαρών\r της ONE FC, Brandon Vera, σε μια ιστορία μιας ομάδας δίωξης ναρκωτικών\r που εισέρχονται στις φαβέλες της Μανίλα για να συλλάβει έναν μεγαλέμπορο.\r Όμως... ο εφιάλτης καραδοκεί."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"משימה במנילה","runtime":0,"tagline":"","homepage":"","overview":"בשכונת עוני דמוית-מבוך במנילה, הסוכנת המיוחדת נינה מניגן מנסה לשרוד לילה סוער במיוחד בקרב אזרחים זועמים וקרטל אכזרי."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Agenten Nina Manigan måste kämpa för sitt liv när ett tillslag mot en knarkliga förvandlas till ett krig mellan civila och en knarkkartell i Manilas slum."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Numa favela de Manila que mais parece um labirinto, o povo enfrenta um cartel violento, e a agente especial Nina Manigan precisa lutar pela vida em uma noite violenta."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Контрольная закупка","runtime":0,"tagline":"","homepage":"","overview":"В самом очаге сюжета данной истории оказываются две команды спецназа. Однажды они примут участие в контрольной закупке партии наркотиков, с целью вывести на чистую воду наркобаронов. Все дело в том, что преступники смогли развернуть в манильских трущобах целую нарколабораторию. Именно ее необходимо ликвидировать нашим героям.\r Однако, в данной операции что-то явно пошло не по сценарию. Теперь спецназовцы вынуждены провести довольно трудный вечер. Им необходимо продемонстрировать все свое боевое мастерство, чтобы банально выжить и попытаться довести миссию до логического завершения."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"BuyBust","runtime":127,"tagline":"","homepage":"","overview":"Eine Spezialeinheit macht Jagd auf Verbrecher im gefährlichsten Viertel von Manila und steht kurz davor einen besonderen Coup zu landen. Man hat Biggie Chen, einen der größten Drogenbosse, im Visier. Doch um ihn zu schnappen, braucht es die Besten der Besten, die die kommandierenden Offiziere Dela Cruz und Alvarez bei diesem Einsatz haben wollen. Gemeinsam müssen sie alle tief in die Slums von Manila vordringen. Doch die taffe, rebellische Nina Manigan, die gerade als Einzige eine von korrupten Polizisten verratene Razzia überlebt hat, ahnt schnell, dass sie erneut in einen Hinterhalt laufen. Und so sitzen die Polizisten bald mitten im Slum fest - umzingelt von Chens Schergen und den ihnen nur in seltenen Fällen freundlich gesinnten Anwohnern."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":127,"tagline":"","homepage":"","overview":"Een speciale politie-eenheid wordt erop uitgestuurd om de sloppenwijken van Manilla te ontruimen. Al gauw blijkt echter dat dit een vast opgezet plan was en worden zij verraden. Een race tegen de klok begint wanneer zij zich uit hun benarde situatie willen redden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"卧底","runtime":127,"tagline":"","homepage":"","overview":"在如同迷宫般的马尼拉平民窟，特别探员妮娜·曼尼根与对被煽动的人民和凶残的贩毒集团开战，她必须全力以赴才能度过这个紧张的夜晚。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"BuyBust","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Uyuşturucu Baskını","runtime":0,"tagline":"","homepage":"","overview":"Manila'nın labirente benzeyen bir gecekondu bölgesinde öfkeli halk ve acımasız bir kartelle mücadele eden özel ajan Nina, şiddet dolu bir geceyi atlatmak zorundadır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"掃毒師姐","runtime":127,"tagline":"","homepage":"","overview":"在馬尼拉迷宮般的貧民窟中，槓上憤怒群眾和殘暴販毒集團的特務妮娜·麥迪根，必須在槍林彈雨的夜晚中殺出一條血路。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Specialagenten Nina Manigan må kæmpe sig gennem en hård nat i et labyrintisk slumkvarter i Manila, hvor rasende civile og et brutalt forbrydersyndikat bekriger hinanden."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"}],"reviews_tmdb":[],"recommendations":[{"id":452558,"adult":false,"title":"Paradox","video":false,"overview":"When a Hong Kong police negotiator is informed about the sudden disappearance of his 16-year-old daughter in Thailand,  he travels there to search for her whereabouts.","genre_ids":[28,12,80,53,18],"media_type":"movie","popularity":1.587,"vote_count":205,"poster_path":"/c8cLJXp0DzUtpRUyszFZMPAwUTA.jpg","release_date":"2017-08-25","vote_average":6.7,"backdrop_path":"/nNy9b1jS0sswrbfcSJ4PYrAEPOY.jpg","original_title":"殺破狼·貪狼","original_language":"cn"},{"id":403605,"adult":false,"title":"Headshot","video":false,"overview":"A young man washes ashore, his memory gone - but his past comes back to haunt him after he is nursed back to health and his killing ability is needed when he takes on a powerful drug lord.","genre_ids":[28,53,18],"media_type":"movie","popularity":2.2413,"vote_count":473,"poster_path":"/dpdmO3PNKwCOzf68y8J4Gu19i3r.jpg","release_date":"2016-09-24","vote_average":6.431,"backdrop_path":"/sEyYwNHJ6AO1Wnh0JuRTBmlZ8No.jpg","original_title":"Headshot","original_language":"id"},{"id":1257009,"adult":false,"title":"Primitive War","video":false,"overview":"During the Vietnam War, a recon unit ventures to an isolated jungle valley to uncover the fate of a missing platoon. They soon find themselves in a fight for their lives against an unexpected enemy — prehistoric dinosaurs.","genre_ids":[28,27,10752,878],"media_type":"movie","popularity":13.5432,"vote_count":235,"poster_path":"/fZnY97zAyATRH50Q1I92fQy1hUg.jpg","release_date":"2025-08-21","vote_average":6.645,"backdrop_path":"/bWF5ImUscXXYia8owpm8coadR4m.jpg","original_title":"Primitive War","original_language":"en"},{"id":347762,"adult":false,"title":"Most Likely to Die","video":false,"overview":"A group of former classmates gather for a pre-party at one of their homes the night before their 10-year high school reunion, and one by one, they are brutally slain in a manner befitting each's senior yearbook superlative.","genre_ids":[27],"media_type":"movie","popularity":0.4063,"vote_count":200,"poster_path":"/4lesaz8ReKloTAyhFzbZIiwYfbQ.jpg","release_date":"2015-08-30","vote_average":4.3,"backdrop_path":"/5DedH2CBC7SXT3ER6Z36XFKIg12.jpg","original_title":"Most Likely to Die","original_language":"en"},{"id":741636,"adult":false,"title":"Bloodthirsty","video":false,"overview":"When indie singer Grey struggles to write her sophomore album, she teams up with a mysterious producer at his secluded cabin. Though their bond strengthens her music, it also starts to irreparably alter Grey’s body and mind.","genre_ids":[27],"media_type":"movie","popularity":0.2944,"vote_count":70,"poster_path":"/49a2fQEFO2R190Ng5ksJedRJun6.jpg","release_date":"2021-04-23","vote_average":4.964,"backdrop_path":"/ciIx6jRtGkZnPue195dSJM4zUrw.jpg","original_title":"Bloodthirsty","original_language":"en"},{"id":421871,"adult":false,"title":"Quaker Oaths","video":false,"overview":"To make their divorce final, a Quaker couple must follow tradition by seeking out everyone who came to their wedding...and asking them to cross their names off the marriage certificate.","genre_ids":[35,10749],"media_type":"movie","popularity":0.2554,"vote_count":1,"poster_path":"/h2EIyvVyVjhRDkxUkbPVZH93Vqe.jpg","release_date":"2016-10-16","vote_average":4,"backdrop_path":"/8FgkXzM6fIdt8BOvv3Ua3QMZSRq.jpg","original_title":"Quaker Oaths","original_language":"en"},{"id":495507,"adult":false,"title":"Twisted Pair","video":false,"overview":"Identical twin brothers become hybrid A.I (artificial intelligence) entities, yet torn in different directions to achieve justice for humanity.","genre_ids":[53,878,18],"media_type":"movie","popularity":0.6323,"vote_count":41,"poster_path":"/xiPOh9yTEhyW33z5yjDNT0QmEwA.jpg","release_date":"2018-10-03","vote_average":5.2,"backdrop_path":"/enSrPdn12q0ZHH2a6aFUkOq0TFw.jpg","original_title":"Twisted Pair","original_language":"en"},{"id":491094,"adult":false,"title":"The Portrait","video":false,"overview":"A musical tale about two impoverished sisters' anguish over whether or not to sell the final masterpiece of their recluse father days before the second world war, in Manila.","genre_ids":[18,10751,36,10402],"media_type":"movie","popularity":0.3803,"vote_count":4,"poster_path":"/aD1031bOh3t3L3XWFdxBdUUCsLk.jpg","release_date":"2017-12-25","vote_average":7,"backdrop_path":"/sNE1H6zx5w92K5QXAXh4d3yaVvr.jpg","original_title":"Ang Larawan","original_language":"tl"},{"id":76600,"adult":false,"title":"Avatar: The Way of Water","video":false,"overview":"Set more than a decade after the events of the first film, learn the story of the Sully family (Jake, Neytiri, and their kids), the trouble that follows them, the lengths they go to keep each other safe, the battles they fight to stay alive, and the tragedies they endure.","genre_ids":[28,12,878],"media_type":"movie","popularity":33.915,"vote_count":13746,"poster_path":"/t6HIqrRAclMCA60NsSmeqe9RmNV.jpg","release_date":"2022-12-14","vote_average":7.598,"backdrop_path":"/cd8YDn7M0lfaHhZdU6MvCDxPalP.jpg","original_title":"Avatar: The Way of Water","original_language":"en"},{"id":13510,"adult":false,"title":"Eden Lake","video":false,"overview":"When a young couple goes to a remote wooded lake for a romantic getaway, their quiet weekend is shattered by an aggressive group of local kids. Rowdiness quickly turns to rage as the teens terrorize the couple in unimaginable ways, and a weekend outing becomes a bloody battle for survival.","genre_ids":[27,53],"media_type":"movie","popularity":4.608,"vote_count":2024,"poster_path":"/tOg6ElTe1mJwaCFN0172U4oso22.jpg","release_date":"2008-09-12","vote_average":6.832,"backdrop_path":"/s9v1QZMVhwShQ7415jPhtfqzyjG.jpg","original_title":"Eden Lake","original_language":"en"},{"id":1106289,"adult":false,"title":"The Pickup","video":false,"overview":"A routine cash pickup takes a wild turn when mismatched armored truck drivers Russell and Travis are ambushed by ruthless criminals led by savvy mastermind Zoe.","genre_ids":[28,35,80],"media_type":"movie","popularity":9.3461,"vote_coun