9:{"metadata":[["$","title","0",{"children":"The Dark Knight Rises | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Following the death of District Attorney Harvey Dent, Batman assumes responsibility for Dent's crimes to protect the late attorney's reputation and is subsequently hunted by the Gotham City Police Department. Eight years later, Batman encounters the mysterious Selina Kyle and the villainous Bane, a new terrorist leader who overwhelms Gotham's finest. The Dark Knight resurfaces to protect a city that has branded him an enemy."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/105976/the-dark-knight-rises"}],["$","meta","5",{"property":"og:title","content":"The Dark Knight Rises"}],["$","meta","6",{"property":"og:description","content":"Following the death of District Attorney Harvey Dent, Batman assumes responsibility for Dent's crimes to protect the late attorney's reputation and is subsequently hunted by the Gotham City Police Department. Eight years later, Batman encounters the mysterious Selina Kyle and the villainous Bane, a new terrorist leader who overwhelms Gotham's finest. The Dark Knight resurfaces to protect a city that has branded him an enemy."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/105976/the-dark-knight-rises"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/hr0L2aueqlP2BYUblTTjmtn0hw4.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"The Dark Knight Rises"}],["$","meta","12",{"name":"twitter:description","content":"Following the death of District Attorney Harvey Dent, Batman assum