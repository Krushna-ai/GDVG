5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Dark Knight Rises\",\"description\":\"Following the death of District Attorney Harvey Dent, Batman assumes responsibility for Dent's crimes to protect the late attorney's reputation and is subsequently hunted by the Gotham City Police Department. Eight years later, Batman encounters the mysterious Selina Kyle and the villainous Bane, a new terrorist leader who overwhelms Gotham's finest. The Dark Knight resurfaces to protect a city that has branded him an enemy.\",\"image\":\"https://image.tmdb.org/t/p/w500/hr0L2aueqlP2BYUblTTjmtn0hw4.jpg\",\"datePublished\":\"2012-07-17\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"GB\",\"inLanguage\":\"en\",\"genre\":[\"superhero film\",\"crime thriller film\",\"drama film\",\"thriller film\",\"action film\",\"Action\",\"Crime\",\"Drama\",\"Thriller\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.791,\"bestRating\":10,\"ratingCount\":23968}}"}}],["$","$L10",null,{"initialDrama":{"id":"a00074e0-1adc-4f73-a51e-eae55bd20bff","tmdb_id":49026,"imdb_id":"tt1345836","content_type":"movie","title":"The Dark Knight Rises","original_title":"The Dark Knight Rises","overview":"Following the death of District Attorney Harvey Dent, Batman assumes responsibility for Dent's crimes to protect the late attorney's reputation and is subsequently hunted by the Gotham City Police Department. Eight years later, Batman encounters the mysterious Selina Kyle and the villainous Bane, a new terrorist leader who overwhelms Gotham's finest. The Dark Knight resurfaces to protect a city that has branded him an enemy.","poster_path":"/hr0L2aueqlP2BYUblTTjmtn0hw4.jpg","backdrop_path":"/y2DB71C4nyIdMrANijz8mzvQtk6.jpg","release_date":"2012-07-17","first_air_date":null,"status":"published","original_language":"en","origin_country":["GB","US"],"genres":[{"name":"superhero film"},{"