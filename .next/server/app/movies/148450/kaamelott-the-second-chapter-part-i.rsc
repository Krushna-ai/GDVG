J0WhIkmyjjczMaIEVWU.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":680,"height":1000,"file_path":"/rLibn8WqZxYNEkkqvK1MMG8cLzu.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.68,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/8hH8oViZnmWqyd7edBqlRjizoel.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/toVtxeqXUF8BoWblq0dItDxOKQr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/yOXc4UgxA5O2GaJuSIYisRDxzRQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/A2p2U0oBfmZ8zDwxjgDEDC9KfxH.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/7BJAdVtwbn2ps9TgJcuVyyTheao.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/jb1n6e2LHCQmUfry2jwgG4lf0ON.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/1RHgSttOIueUUiECAwb4ANCojWO.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/xSxl3bLCRthJ2Gk17HgYm9WMASC.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/A0dZfheF4qGzMi91pSP5pTmVwL0.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/iOjMnBgJLadMlGUtAWekUJNQssJ.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T02:47:32.565+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Kaamelott: The Second Chapter (Part I)","runtime":139,"tagline":"","homepage":"","overview":"After reclaiming Kaamelott from Lancelot's tyrannical rule, Arthur spares his life, defying Celtic gods. Knights must prove themselves for Table Round seats while Arthur faces new threats as king."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":139,"tagline":"Qui part à l'aventure ?","homepage":"https://www.kaamelott.com/","overview":"Les Dieux sont en colère contre Arthur ! Après la destruction de Kaamelott, son refus obstiné de tuer Lancelot précipite le Royaume de Logres à sa perte. Il réunit ses Chevaliers, novices téméraires et vétérans désabusés, autour de la Nouvelle Table Ronde et les envoie prouver leur valeur aux quatre coins du Monde, des Marais Orcaniens aux terres glacées du Dragon Opalescent."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":139,"tagline":"","homepage":"https://www.sphere-films.ca/cinema/kaamelott-deuxieme-volet-partie-1/","overview":"La suite des aventures du roi Arthur, selon Alexandre Astier."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Kaamelott: Deuxième Volet: Partie 1","runtime":139,"tagline":"","homepage":"","overview":"Drugą część Kaamelottu stanowi rozdział, w którym Artur wysyła swoich rycerzy – weteranów lub nowicjuszy, długoletnich towarzyszy lub rekrutów z tego roku – po przygodę."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Камелот - Глава вторая: часть первая","runtime":135,"tagline":"","homepage":"","overview":"После освобождения Камелота от тиранического правления Ланселота, Артур сохраняет ему жизнь, бросая вызов кельтским богам. Рыцарям предстоит проявить себя, чтобы заслужить место за Круглым столом, в то время как Артур как король сталкивается с новыми угрозами."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Poté, co Artuš osvobodil Kaamelott od Lancelotovy tyranské vlády, ušetřil mu život a vzepřel se keltským bohům. Rytíři musí prokázat svou hodnotu, aby získali místo u Kulatého stolu, zatímco Artuš jako král čelí novým hrozbám."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[{"id":35,"adult":false,"title":"The Simpsons Movie","video":false,"overview":"After Homer accidentally pollutes the town's water supply, Springfield is encased in a gigantic dome by the EPA and the Simpsons are declared fugitives.","genre_ids":[16,35,10751],"popularity":7.6436,"vote_count":8433,"poster_path":"/s3b8TZWwmkYc2KoJ5zk77qB6PzY.jpg","release_date":"2007-07-25","vote_average":7.019,"backdrop_path":"/8ln5VUVk7gnNGIb2VNgw8nICDVt.jpg","original_title":"The Simpsons Movie","original_language":"en"},{"id":463116,"adult":false,"title":"The Stolen Princess","video":false,"overview":"This wonderful story happened in the age of valiant knights, beautiful princesses, and battling sorcerers. Ruslan, a wandering artist dreaming to become a knight, met beautiful Mila and fell in love with her; he didn’t even suspect that she is the King’s daughter. However, the lovers’ happiness wasn’t meant to last too long. Chernomor, the evil sorcerer, appeared in a magic vortex and stole Mila right before Ruslan’s eyes to transform her power of love into his own magic power. Without further ado, Ruslan sets out on a chase after the stolen princess to overcome all obstacles and to prove that real love is stronger than magic.","genre_ids":[16,35,12,10751],"popularity":0.5453,"vote_count":184,"poster_path":"/jJaRhOk9FaPTIqP8L4NqnOYEXHo.jpg","release_date":"2018-03-07","vote_average":6.799,"backdrop_path":"/tZkRuGSa4we7D1SdGBN8qqtT4SI.jpg","original_title":"Викрадена принцеса: Руслан і Людмила","original_language":"uk"},{"id":462927,"adult":false,"title":"Fantastica: A Boonie Bears Adventure","video":false,"overview":"Boonie bears and Bald Qiang work together with secret primitive girl to smash a conspiracy to destroy old-growth forest.","genre_ids":[16,14,10751,28],"popularity":0.5021,"vote_count":15,"poster_path":"/wgmfCGzVViXqW02Pt29ylUFOP8v.jpg","release_date":"2017-01-28","vote_average":6.4,"backdrop_path":"/scr8SGoh0e65Q37ka1cIigiQ8Wt.jpg","original_title":"熊出没·奇幻空间","original_language":"zh"},{"id":5608,"adult":false,"title":"Whom the Gods Wish to Destroy","video":false,"overview":"Siegfried of Xanten snatches the Nibelung treasure from the king of the underworld and slays the dragon Fafnir, whose blood makes him invulnerable. Siegfried falls in love with Kriemhild, the sister of the Burgundian king. But only if Siegfried helps Gunther marry Brunhild will he be allowed to marry Kriemhild. He fulfills this condition, but the two women bring ruin upon Xanten and Burgundy...","genre_ids":[18,12,14],"popularity":0.4266,"vote_count":17,"poster_path":"/z9lKgq8Ij1DBf7PMSR32kNhTj8Z.jpg","release_date":"1966-12-13","vote_average":6.4,"backdrop_path":"/rLk4BWyKX4LTfHbK0YTTfBRvVhO.jpg","original_title":"Die Nibelungen, Teil 1: Siegfried","original_language":"de"},{"id":5609,"adult":false,"title":"Whom the Gods Wish to Destroy 2","video":false,"overview":"Now Brunhild knows by which treason she was won for king Gunther of Burgund by Siegfried of Xanthen, and has been revenged by his foul murder by Hagen, more bloody revenge is inevitable. Hagen steals the Nibelungen-treasure to sink it in the stream and manages to kill Alberich and seize his invisibility-cap. Queen Kriemhild is packed of to an abbey so her son may grow up to become a prelate, but Hagen's men raid them and kill the child. She now accepts to become the wife of Etzel, king of the truly barbaric Hun nomads and invites the Burgund court nomenclature at their Danube court for their heir's baptism a few years later, but prepared a bloody conspiracy with her xenophobic brother-in-law behind her surprisingly chivalric husband's back, while Gunther accepts, hoping to avoid a far bloodier war, despite the danger for his party of knights, which materializes...","genre_ids":[18,12,14],"popularity":0.3664,"vote_count":16,"poster_path":"/iQHpbrsTfLtin3kzHI2rVNszBZx.jpg","release_date":"1967-02-16","vote_average":6.2,"backdrop_path":"/y6nc02wVHGOTjoXlydRGe4G5I6Y.jpg","original_title":"Die Nibelungen, Teil 2: Kriemhilds Rache","original_language":"de"},{"id":1256917,"adult":false,"title":"Planet Prince","video":false,"overview":"A mysterious hero must intervene when a nefarious presence from outer space arrives to steal a powerful new rocket fuel.","genre_ids":[878,28,12,10751],"popularity":0.148,"vote_count":1,"poster_path":"/hnyk5GgC7b5anj4t3maFzCotMpr.jpg","release_date":"1959-05-19","vote_average":6,"backdrop_path":null,"original_title":"遊星王子","original_language":"ja"},{"id":1256919,"adult":false,"title":"Planet Prince - The Terrifying Spaceship","video":false,"overview":"Sequel to 1959's Planet Prince","genre_ids":[878,28,12,10751],"popularity":0.1274,"vote_count":0,"poster_path":"/gdcPxfuO4139K5BxCJPQBq3QLP6.jpg","release_date":"1959-05-25","vote_average":0,"backdrop_path":null,"original_title":"遊星王子 恐怖の宇宙船","original_language":"ja"},{"id":1266002,"adult":false,"title":"The Real Bros of Simi Valley: The Movie","video":false,"overview":"With the 10-year high school reunion around the corner, Xander and his squad embark on a journey to become the dopest versions of themselves in time to flex on all of their old classmates.","genre_ids":[35],"popularity":0.3379,"vote_count":8,"poster_path":"/mB9MUN88ygekmN2bxFEH0QvofBG.jpg","release_date":"2024-07-04","vote_average":6,"backdrop_path":"/481qQhMRQWcaWlEvQanGi45fiN3.jpg","original_title":"The Real Bros of Simi Valley: The Movie","original_language":"en"},{"id":14711,"adult":false,"title":"Afro Samurai: Resurrection","video":false,"overview":"Afro Samurai avenged his father and found a life of peace. But the legendary master is forced back into the game by a beautiful and deadly woman from his past. The sparks of violence dropped along Afro’s bloody path now burn out of control – and nowhere are the flames of hatred more intense than in the eyes of Sio.","genre_ids":[16,28,12,18,14,878,10770],"popularity":1.194,"vote_count":212,"poster_path":"/6snrLj3Ydmbu5L9giAYtiSNwE0U.jpg","release_date":"2009-10-16","vote_average":6.858,"backdrop_path":"/4rNjTccVltQHKKJd6INzqHtfV5x.jpg","original_title":"Afro Samurai: Resurrection","original_language":"en"},{"id":285650,"adult":false,"title":"Pretty Cure All Stars New Stage 3: Eternal Friends","video":false,"overview":"\"Pretty Cure All Stars New Stage 3:  Eternal Friends\") is the sixth of the Pretty Cure All Stars crossover movie series featuring all current Pretty Cure characters and the last of the \"New Stage\" film.","genre_ids":[16,28,14,35,12,10751],"popularity":0.9414,"vote_count":9,"poster_path":"/k9xygRdJhqRPmu6Spr2QhmYrmdu.jpg","release_date":"2014-03-15","vote_average":7.1,"backdrop_path":"/glS0pd1Qw0G9gjKqJxa67EmhaJ.jpg","original_title":"映画 プリキュアオールスターズNewStage3 永遠のともだち","original_language":"ja"},{"id":1467486,"adult":false,"title":"You and Idol Precure♪ the Movie For You! Our Kirakilala Concert!","video":false,"overview":"\"You and Idol Precure♪\" will appear at the \"No.1 Universe\" Idol Festival!  What is the secret hidden on the mysterious island...?  One day, Uta and her friends are invited by the coral fairy, Totto to appear in the \"Super Miracle Idol Festival\" held on a mysterious island called AiAi Island!  In a hu~ge venue, many different idols, including robots and animals, gather♪  The biggest idol festival in the universe is about to begin! Or so they thought...?  Suddenly, a mysterious monster appears, and AiAi Island and the world are caught up in a crisis...  And what's more, they've been transported back in time!?  The clue to saving them from this crisis is hidden in the legend of the island's goddess and the mysterious idol-hating girl Tera, whom they met on the island...?  That's not all! \"Wonderful Precure!\" and \"Soaring Sky! Precure\" will also be rushing over to AiAi Island!  C'mon! Sing, dance, and please the crowd - a kirakiLive concert is about to begin!☆","genre_ids":[16,28,12,35,10751,14,10402],"popularity":0.9132,"vote_count":1,"poster_path":"/iIHepEUwpTUC5clPWi5leMShbNS.jpg","release_date":"2025-09-12","vote_average":10,"backdrop_path":"/78zJ02IwuK2QRJgdyCeM4aqoBVx.jpg","original_title":"映画キミとアイドルプリキュア♪お待たせ！キミに届けるキラッキライブ！","original_language":"ja"},{"id":1266540,"adult":false,"title":"Wonderful PreCure! The Movie: A Grand Adventure in a Thrilling♡Game World!","video":false,"overview":"Komugi, Iroha, Yuki, Mayu, Daifuku, and Satoru have gathered to play the super popular game \"Doki Doki♡TanuKingdom\"!  Everyone starts the game happily! Or so they thought...  But it seems they've been sucked into a world of the game with a suspicious tanuki...  And now they're in even more trouble! Komugi has been separated from Iroha and the others...!?  \"I want to be by Iroha's side forever and ever!\"  To meet her beloved Iroha, Komugi decides to challenge herself to various game battles!  How on earth did this happen...? What is the secret hidden in the world of the game...?  The clue is in the hands of Natsuki, the young girl who created the game.  \"Soaring Sky! Precure\" and \"Witchy Precure!\" have also gathered together! When everyone's feelings come together, will a wonderful miracle unfold?!","genre_ids":[16,28,12,35,10751,14,878],"popularity":1.0286,"vote_count":5,"poster_path":"/70AROxaNAKN5fmX8rNn7YV8wpdY.jpg","release_date":"2024-09-13","vote_average":5.4,"backdrop_path":"/af84jqi8uy7UB5s4FqMu2MKxVUj.jpg","original_title":"わんだふるぷりきゅあ！ざ・むーびー！ ドキドキ♡ゲームの世界で大冒険！","original_language":"ja"},{"id":1078012,"adult":false,"title":"Boonie Bears: Guardian Code","video":false,"overview":"Briar and Bramble, who lost their mother Barbara when they were cubs, are thrown into danger when escorting a scientist, which may lead them to a family reunion.","genre_ids":[16,35,878,10751,12],"popularity":1.8724,"vote_count":13,"poster_path":"/lIR8h3Os8peWOave8CGE7xsTFoi.jpg","release_date":"2023-01-22","vote_average":6.923,"backdrop_path":"/arT10FrsPdxJOFBrHMrVvoDJCqR.jpg","original_title":"熊出没·伴我“熊芯”","original_language":"zh"},{"id":15371,"adult":false,"title":"The Castle of Cagliostro","video":false,"overview":"After a successful robbery leaves famed thief Lupin the Third and his partner Jigen with nothing but a large amount of expertly crafted counterfeit bills, he decides to track down the forgers responsible—and steal any other treasures he may find in the Castle of Cagliostro, including the 'damsel in distress' he finds imprisoned there.","genre_ids":[16,12,35,80],"popularity":4.1046,"vote_count":1114,"poster_path":"/hSFdyWptoDHuXlFZGzIrfVell4Q.jpg","release_date":"1979-07-06","vote_average":7.515,"backdrop_path":"/fCf8WfsRJEDFf1N6gA6o4ICRYp.jpg","original_title":"ルパン三世 カリオストロの城","original_language":"ja"},{"id":1078835,"adult":false,"title":"Ohsama Sentai King-Ohger: Adventure Heaven","video":false,"overview":"During the grand coronation ceremony of Gira as king, the door to \"Hakabaka, the Land of the Dead\" is suddenly opened! What unprecedented ordeal awaits Gira and the other six kings in the Land of the Dead? Will the young kings be able to return to their original world? Will Gira, the \"self-proclaimed king,\" become the true King of Shugoddam?!","genre_ids":[28,18,14],"popularity":0.577,"vote_count":5,"poster_path":"/4cU6GyloJxnhfZ9yBJr9B11Py0t.jpg","release_date":"2023-07-28","vote_average":7.3,"backdrop_path":"/zEMgaiWyJW8qjdnwcfQ4VnT5Y1.jpg","original_title":"映画 王様戦隊キングオージャー アドベンチャー・ヘブン","original_language":"ja"},{"id":15691,"adult":false,"title":"Doctor Who","video":false,"overview":"The Seventh Doctor becomes the Eighth. And on the streets of San Francisco – alongside new ally Grace Holloway - he battles the Master.","genre_ids":[10770,12,878],"popularity":1.9072,"vote_count":236,"poster_path":"/cwae2p7JcRNtz1CvNCzpX5ad96V.jpg","release_date":"1996-05-12","vote_average":6.2,"backdrop_path":"/26MVKVGQf1J0yrzJx97Ww4DLslV.jpg","original_title":"Doctor Who","original_language":"en"},{"id":16068,"adult":false,"title":"Babylon 5: The Legend of the Rangers - To Live and Die in Starlight","video":false,"overview":"After being punished for retreat from combat, Ranger David Martel is given command of the Liandra, a haunted 20-year old Minbari fighting ship. He's escorting ambassadors to a secret archaeological site, the oldest city on record and a clue to a dangerous ancient race.","genre_ids":[878,12,28],"popularity":0.548,"vote_count":105,"poster_path":"/bIhOn8xKsOQGjiNCQ8sKoQyYmNa.jpg","release_date":"2002-04-30","vote_average":5.962,"backdrop_path":"/1ola13YEBnxBIigCg5TI8w05PAe.jpg","original_title":"Babylon 5: The Legend of the Rangers - To Live and Die in Starlight","original_language":"en"},{"id":16110,"adult":false,"title":"Thomas and the Magic Railroad","video":false,"overview":"Mr. Conductor's supply of magic gold dust, which allows him to travel between Shining Time and Thomas's island, is critically low. Unfortunately, he doesn't know how to get more. Meanwhile, Thomas is fending off attacks by the nasty diesel engines. Getting more gold dust will require help from Mr. C's slacker cousin, his new friend Lily and her morose grandfather, plus the secret engine.","genre_ids":[10751,14,12],"popularity":0.993,"vote_count":92,"poster_path":"/aPEJ36e8a7gLu28KVfsGDQdmruk.jpg","release_date":"2000-07-14","vote_average":5.4,"backdrop_path":"/QpDVV6g1nyQ54o5oYX3HF8mWri.jpg","original_title":"Thomas and the Magic Railroad","original_language":"en"},{"id":1468460,"adult":false,"title":"MiBots","video":false,"overview":"Young prodigy Mi Anderson is enamored with robots. She designs, builds and - most of all - loves her bots. But they're not real, they're not - alive. One day, she uncovers an ancient discovery - bots. These are not your ordinary bots. They are special. They're from the past yet they're hi-tech - and they're hilarious. A real pack of stooges. Their zest for their new lives together leads them to hijinks and adventure. The bots are everything Mi has ever dreamed of. Until the evil Dr. Shultz discovers the enchanting power of Mi's bots. He wants to use them for military purposes, or worse. Can Mi and her MiBots learn the spirit of their magic before its too late?","genre_ids":[16,12,35,878],"popularity":0.4667,"vote_count":0,"poster_path":null,"release_date":"","vote_average":0,"backdrop_path":null,"original_title":"MiBots","original_language":"en"},{"id":1468667,"adult":false,"title":"CRUSADE","video":false,"overview":"An upcoming epic gothic fantasy film from ConfusedSelect.","genre_ids":[14,12,27,28],"popularity":0.322,"vote_count":0,"poster_path":null,"release_date":"","vote_average":0,"backdrop_path":null,"original_title":"CRUSADE","original_language":"en"}],"external_ids":{"imdb_id":"tt34624872","twitter_id":"Kaamelott_tweet","facebook_id":"KaamelottOff","wikidata_id":"Q133798538","instagram_id":"kaamelott.officiel"},"social_ids":{"twitter":"Kaamelott_tweet","facebook":"KaamelottOff","instagram":"kaamelott.officiel"},"gdvg_id":148450,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"BE","release_dates":[{"note":"Belga Films","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-10-22T00:00:00.000Z","certification":""}]},{"iso_3166_1":"CA","release_dates":[{"note":"Sphère Films Québec","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-10-24T00:00:00.000Z","certification":""}]},{"iso_3166_1":"CH","release_dates":[{"note":"As