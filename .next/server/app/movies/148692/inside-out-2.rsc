e_average":0},{"width":3840,"height":2160,"file_path":"/euDavGekleEItJQq2pRATfsU1yL.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/bAqiEofAk12UXJvcOSyZotjuG5N.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/uU3Ucq9PMXHL0DxtdrFyH61Y8hM.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/4hr0Kwncm3bHqc3rOsehTyC6N2S.jpg","iso_639_1":"ja","iso_3166_1":"JP","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/ut5hzEBSZoTrqXo3yIXorIzrrZu.jpg","iso_639_1":"ja","iso_3166_1":"JP","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/e5zGobWxJsUVikspN5JVWwKNmA6.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/f9Eu7PL6LzYr3Z5LjsUisl6rBOf.jpg","iso_639_1":"da","iso_3166_1":"DK","vote_count":1,"aspect_ratio":1.778,"vote_average":0},{"width":2903,"height":1632,"file_path":"/4lVJ93JSl5Hpvxh2ddtbV6sjueL.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":2903,"height":1632,"file_path":"/xlS1ZUYQ9p5bzUS7izKUKzwk4CP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":2903,"height":1632,"file_path":"/jmBL8lFwkWGxpxMVg581EOlDSpg.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":3840,"height":2160,"file_path":"/dUaxb0drA7MXZjr6WdgVj8quEhS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/z2AkTdnIHeDcA89I9tTi1t39MRW.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/fWKJdIC64CUhJaYEjRHSgBsTmps.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/q8ZXoKbY3fMiwUOiD7J81JIWkaP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/26M4Vzdk6Dh0rmM645MAa79reyx.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T04:13:10.198+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":97,"tagline":"Make room for new emotions.","homepage":"https://movies.disney.com/inside-out-2","overview":"Teenager Riley's mind headquarters is undergoing a sudden demolition to make room for something entirely unexpected: new Emotions! Joy, Sadness, Anger, Fear and Disgust, who’ve long been running a successful operation by all accounts, aren’t sure how to feel when Anxiety shows up. And it looks like she’s not alone."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Del revés 2 (Inside Out 2)","runtime":96,"tagline":"Deja espacio para nuevas emociones.","homepage":"https://www.disney.es/peliculas/del-reves-2","overview":"Riley entra en la adolescencia y el Cuartel General de su cabeza sufre una repentina reforma para hacerle hueco a algo totalmente inesperado propio de la pubertad: ¡nuevas emociones! Alegría, Tristeza, Ira, Miedo y Asco, con años de impecable gestión a sus espaldas (según ellos...) no saben muy bien qué sentir cuando aparece con enorme ímpetu Ansiedad. Y no viene sola: le acompañan envidia, vergüenza y aburrimiento."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"인사이드 아웃 2","runtime":0,"tagline":"비상! 새로운 감정들이 몰려온다!","homepage":"","overview":"13살이 된 라일리의 행복을 위해 매일 바쁘게 머릿속 감정 컨트롤 본부를 운영하는 ‘기쁨’, ‘슬픔’, ‘버럭’, ‘까칠’, ‘소심’. 그러던 어느 날, 낯선 감정인 ‘불안’, ‘당황’, ‘따분’, ‘부럽’이가 본부에 등장하고, 언제나 최악의 상황을 대비하며 제멋대로인 ‘불안’이와 기존 감정들은 계속 충돌한다. 결국 새로운 감정들에 의해 본부에서 쫓겨나게 된 기존 감정들은 다시 본부로 돌아가기 위해 위험천만한 모험을 시작하는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Những Mảnh Ghép Cảm Xúc 2","runtime":0,"tagline":"Nhường đường cho các cảm xúc mới nào.","homepage":"","overview":"Những Mảnh Ghép Cảm Xúc 2 sẽ quay trở lại phần tâm trí mới của cô bé thiếu niên Riley. Một ngày, trụ sở chính đột ngột bị phá hủy để nhường chỗ cho một thứ hoàn toàn mới: Một cảm xúc mới! Vui Vẻ, Buồn Bã, Giận Dữ, Sợ Hãi và Chán Ghét phải 'chào đón' sự xuất hiện của một loại cảm xúc mới là Lo Âu. Và có vẻ như cô ấy không chỉ xuất hiện một mình."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Ters Yüz 2","runtime":96,"tagline":"Yeni duygulara yer açın!","homepage":"https://www.disney.com.tr/filmler/ters-yuz-2","overview":"Disney ve Pixar'ın \"Ters Yüz 2\" filminde, ergenliğe adım atan Riley'nin zihnine döneriz. Merkez'de aniden bir tadilat başlar ve hiç hesapta olmayan yeni Duygular'a yer açılır! Uzun zamandır işleri başarıyla yürüten Neşe, Üzüntü, Öfke, Korku ve Tiksinti, Kaygı geldiğinde neler hissedeceklerini bilemez. Üstelik Kaygı yalnız değildir, beraberinde Utanç, Gıpta ve Bıkkınlık da gelmiştir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Vice-versa 2","runtime":0,"tagline":"Prêts pour un tourbillon d'émotions ?","homepage":"https://www.pixar.com/inside-out-2","overview":"Riley, adolescente depuis peu, au moment où le Quartier Cérébral doit être démoli pour faire place à un événement totalement inattendu : de nouvelles Émotions ! Joie, Tristesse, Colère, Peur et Dégoût, qui ont longtemps su contrôler les choses avec succès, ne savent pas comment réagir à l'arrivée d'Anxiété. Et il semblerait qu'elle ne soit pas seule. Elle est venue accompagnée d'Embarras, Envie et Ennui."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Alles steht Kopf 2","runtime":0,"tagline":"Voll emotional!","homepage":"https://www.disney.de/filme/alles-steht-kopf-2","overview":"Im Kopf des nun frischgebackenen Teenagers Riley wird plötzlich das Hauptquartier abgerissen, um Platz für etwas völlig Unerwartetes zu schaffen: neue Emotionen! Freude, Trauer, Wut, Angst und Ekel, die seit langem erfolgreich Rileys Kopf managen, sind sich nicht sicher, was sie fühlen sollen, als Zweifel auftaucht. Und es sieht so aus, als ob sie nicht die einzige Neue ist!"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Divertida-Mente 2 (Inside Out 2)","runtime":96,"tagline":"Preparem-se para novas emoções.","homepage":"https://www.disney.pt/filmes/divertida-mente-2","overview":"Na mente de Riley, recém-chegada à adolescência, o Quartel General é alvo de uma demolição súbita para dar espaço a algo totalmente inesperado: novas Emoções! A Alegria, a Tristeza, a Raiva, o Medo e a Repulsa, que têm feito, sem dúvida, uma boa gestão, não sabem como reagir à chegada da Ansiedade. E parece que ela não veio sozinha."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Τα Μυαλά που Κουβαλάς 2","runtime":0,"tagline":"Κάντε χώρο για νέα συναισθήματα.","homepage":"https://www.disney.gr/tainies/inside-out-2","overview":"Τα κεντρικά γραφεία του μυαλού της έφηβης πλέον Ράιλι υφίστανται μια ξαφνική κατεδάφιση προκειμένου να δημιουργηθεί χώρος για κάτι εντελώς απροσδόκητο: νέα συναισθήματα! Η Χαρά, η Λύπη, ο Θυμός, ο Φόβος και η Αηδία, που εδώ και πολύ καιρό κάνουν καλή δουλειά, όπως και να το δει κανείς, δεν είναι σίγουροι πώς να αισθάνονται όταν εμφανίζεται η Ανησυχία. Και φαίνεται ότι δεν είναι μόνη."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Binnenstebuiten 2","runtime":0,"tagline":"Maak ruimte voor nieuwe emoties.","homepage":"https://www.disney.nl/films/binnenstebuiten-2","overview":"Het hoofdkwartier van tiener Riley wordt plotseling gesloopt om plaats te maken voor iets geheel onverwachts: nieuwe emoties! Vreugde, Verdriet, Woede, Angst en Walging, die in alle opzichten al lange tijd succesvol zijn, weten niet goed hoe ze zich moeten voelen als angst de kop opsteekt. En het lijkt erop dat ze niet de enige is."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"V hlavě 2","runtime":0,"tagline":"Udělejte si místo na nové emoce.","homepage":"https://www.disney.cz/filmy/v-hlave-2","overview":"V hlavě čerstvé teenagerky Riley se dějí velké věci – ve velícím centru probíhají neočekávané stavební práce, aby se sem vešli překvapiví noví hosté: zbrusu nové emoce! Radost, Smutek, Vztek, Strach a Nechuť, kterým se už dlouho dařilo mít všechno pěkně pod kontrolou, se ocitají na rozpacích, když se jejich společnost rozroste o Úzkost, Závist, Nostalgii a Nudu..."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"V hlave 2","runtime":0,"tagline":"Urobte si priestor pre nové emócie!","homepage":"https://www.cinemart.sk/filmy/v-hlave-2/","overview":"Pokračovanie mimoriadne obľúbeného a úspešného animovaného rodinného filmu V HLAVE od študiá Disney a Pixar “VHLAVE  2” sa vracia opäť do mysle tentokrát už čerstvej tínedžerky Riley a to práve v čase, keď ústredie prechádza náhlou demoláciou, aby uvoľnilo miesto pre niečo úplne nečakané. Film V hlave 2 prináša Veľké zmeny – Nové Emócie! Radosť, Smútok, Hnev, Strach a Znechutenie, ktoré podľa všetkého dlho úspešne fungovali, si nie sú isté, ako sa majú cítiť, keď sa objaví Úzkosť. A zdá sa, že nie je sama."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Отвътре навън 2","runtime":96,"tagline":"","homepage":"","overview":"Райли вече е тийнейджър и в контролния център в главата ѝ настъпват изменения, за да се направи място на нещо напълно неочаквано: нови емоции! Познатите ни любими герои Радост, Тъга, Бяс Лют, Страх и Отврат, които до този момент са се справяли доста успешно (по всички параграфи) с навигирането на живота на момичето, не са съвсем сигурни как точно да се чувстват и какво да направят, когато в редиците им с гръм и трясък се появява Тревожност. По всичко изглежда, че тя няма да стои със скръстени ръце, а и не е сама..."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"قلبا وقالبا 2","runtime":0,"tagline":"‏إفسح المجال لمشاعر جديدة.‏","homepage":"","overview":"يتبع العمل رايلي في مرحلة المراهقة، حيث تستكشف العديد من المشاعر الجديدة مثل القلق والحسد."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Думками навиворіт 2","runtime":0,"tagline":"Знайди місце для нових емоцій","homepage":"","overview":"Продовження мультфільму від Disney та Pixar повертає глядачів у свідомість новоспеченої підлітки Райлі. Головна контора у голові дівчини зіштовхується з раптовим виселенням, щоб звільнити місце для чогось вкрай несподіваного: нових Емоцій! Радість, Печаль, Гнів, Страх та Відраза вже давно успішно працюють разом. Тому вони не знають, що відчувати, коли зʼявляється Тривожність. І, схоже, вона прийшла не сама."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Divertida Mente 2","runtime":100,"tagline":"Libere o espaço para novas emoções.","homepage":"https://www.disney.com.br/filmes/divertidamente-2","overview":"\"Divertida Mente 2\", da Disney e da Pixar, retorna à mente da adolescente Riley, e o faz no momento em que a sala de comando está passando por uma demolição repentina para dar lugar a algo totalmente inesperado: novas emoções! Alegria, Tristeza, Raiva, Medo e Nojinho não sabem bem como reagir quando Ansiedade aparece, e tudo indica que ela não está sozinha."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"头脑特工队2","runtime":96,"tagline":"","homepage":"","overview":"小女孩莱莉刚步入青春期，在她的大脑总部，正经历着一场突如其来的大拆迁，为意想不到的新情绪腾出空间。一直以来配合默契的情绪小伙伴乐乐、忧忧、怒怒、怕怕和厌厌，在新情绪焦焦的突然到来时变得不知所措，并且她看起来不是孤身一人。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"Fai spazio a nuove emozioni.","homepage":"https://www.disney.it/film/inside-out-2","overview":"Nella mente dell'ormai adolescente Riley, il quartier generale viene improvvisamente demolito per far posto a qualcosa di completamente inaspettato. Gioia, Tristezza, Rabbia, Paura e Disgusto, che a detta loro gestiscono da tempo un'attività di successo, non sanno come comportarsi quando arriva Ansia... e sembra che non sia sola."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"IntensaMente 2","runtime":96,"tagline":"Hagan espacio para nuevas emociones.","homepage":"https://www.disneylatino.com/peliculas/intensamente-2","overview":"Riley, ahora adolescente, enfrenta una reforma en la Central de sus emociones. Alegría, Tristeza, Ira, Miedo y Asco deben adaptarse a la llegada de nuevas emociones: Ansiedad, Vergüenza, Envidia y Ennui."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Agymanók 2.","runtime":100,"tagline":"Szorítsd be az új érzelmeket.","homepage":"https://www.disney.hu/filmek/agymanok-2","overview":"A Disney és a Pixar új filmjében visszatérünk Riley fejébe, aki immáron tinédzser! A Főhadiszállás egy napon komoly átalakításokon esik át, hogy helyet kaphasson benne valami egészen váratlan: új érzelmek! Derűben, Bánatban, Haragban, Majréban és Undorban, akik így együtt már jó ideje navigálnak sikerrel, vegyes érzések kezdenek kavarogni, amikor felbukkan Feszkó. Ráadásul úgy tűnik, nem egyedül van."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Innsiden ut 2","runtime":0,"tagline":"Gjør plass til nye følelser.","homepage":"https://www.disney.no/filmer/innsiden-ut-2","overview":"Disney og Pixars \"Innsiden ut 2\" går tilbake til sinnet til den ferske tenåringen Riley idet hovedkvarteret plutselig gjennomgår en riving for å gi plass til noe uventet: nye følelser! Glede, Sorg, Sinne og Avsky, som lenge har drevet en vellykket virksomhet, er usikre på hva de skal føle når Angst dukker opp. Og hun er visst ikke alene. Hun har tatt med seg Forlegenhet, Misunnelse og Ennui."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"มหัศจรรย์อารมณ์อลเวง 2","runtime":95,"tagline":"หลีกทางให้เหล่าอารมณ์ใหม่","homepage":"","overview":"เดินทางกลับสู่โลกของเสียงเล็ก ๆ ในหัวของ ไรลีย์ ที่กำลังจะกลายเป็นวัยรุ่น แต่แล้ววันหนึ่งเหล่าอารมณ์จะต้องพบกับการเปลี่ยนแปลงครั้งใหญ่ กับเหล่าอารมณ์รุ่นใหม่! โดย ลั้นลา, เศร้าซึม, ฉุนเฉียว, กลั๊วกลัว และ หยะแหยง  ที่สามารถจัดการอารมณ์ของไรลีย์ได้อย่างลงตัวมาโดยตลอด กลับทำตัวไม่ถูกเมื่ออารมณ์ใหม่อย่าง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Insidan ut 2","runtime":0,"tagline":"Gör plats för nya känslor.","homepage":"https://www.disney.se/filmer/insidan-ut-2","overview":"Jenny har nu blivit tonåring. I och med det flyttar ett gäng helt nya känslor in i hennes huvud."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Inderst inde 2","runtime":0,"tagline":"Gør plads til nye følelser.","homepage":"https://www.disney.dk/film/inderst-inde-2","overview":"Disney og Pixars “Inderst inde 2” vender tilbage til den friskbagte teenager Rileys sind, hvor hovedkvarteret pludselig er under nedrivning for at gøre plads til noget fuldkommen uventet: nye Følelser! Glæde, Triste, Vrede, Frygt og Afsky, som angiveligt længe har drevet et velsmurt maskineri, ved ikke, hvad de skal mene, da Bekymring dukker op. Og det ser ud til, at hun ikke er alene."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Inside Out - mielen sopukoissa 2","runtime":0,"tagline":"Raivaa tilaa uusille tunteille.","homepage":"https://www.disney.fi/elokuvat/inside-out-mielen-sopukoissa-2","overview":"Jo kerran  tunteiden tasapainon  löytäneen teinitytön Rileyn mielen päämajassa käynnistyy suuri romutusurakka, jolla tehdään tilaa odottamattomalle yllätykselle: uusille tunteille! Ilo, Suru, Kiukku, Pelko ja Inho, jotka ovat pitkään pyörittäneet Rileyn mieltä hyvällä menestyksellä, eivät tiedä, mitä pitäisi ajatella, kun kuvioihin ilmestyy Ahdistus. Eikä hän taida olla edes ainoa uusi tulokas!"},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"W głowie się nie mieści 2","runtime":96,"tagline":"Nie TŁUM emocji.","homepage":"https://www.disney.pl/filmy/w-glowie-sie-nie-miesci-2","overview":"W głowie się nie mieści 2 to powrót do umysłu Riley, obecnie świeżo upieczonej nastolatki. Centrala sterowania przechodzi gruntowny remont, bo pojawiły się nowe Emocje! Radość, Smutek, Złość, Strach i Odraza, które dotąd z powodzeniem kierowały całym przedsięwzięciem, z pewnym wahaniem witają nowego przybysza: Niepewność. A to dopiero początek zmian."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"הקול בראש 2","runtime":0,"tagline":"פנו מקום לרגשות חדשים.","homepage":"https://www.disney.co.il/sratim/inside-out-2","overview":"\"הקול בראש 2\" חוזר למוחה של הנערה המתבגרת הטרייה, ריילי, כאשר המפקדה עוברת הריסה פתאומית על מנת לפנות מקום לדבר בלתי צפוי: רגשות חדשים! שמחה, עצב, כעס, פחד וגועל, שמנהלים את העניינים בהצלחה כבר זמן רב, לא בטוחים כיצד להרגיש כשחרדה מופיעה. ונראה שהיא לא לבד. היא הביאה איתה את מבוכה, קנאה ושיממון."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Головоломка 2","runtime":0,"tagline":"«Найди Место для Новых Эмоций»","homepage":"","overview":"Головной отдел мозга Райли внезапно подвергается капитальному ремонту в тот момент, когда необходимо освободить место для чего-то совершенно неожиданного: новых эмоций.  Радость, Печаль, Гнев, Страх и Брезгливость, которые уже давно успешно руководят эмоциональными процессами, не знают, что и чувствовать, когда появляется некая… Тревожность. И похоже, не только она."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"У мојој глави 2","runtime":0,"tagline":"Велике промене. Нове емоције.","homepage":"","overview":"Главни штаб у глави тинејџерке Рајли изненада бива растурен како би се направило места за нешто потпуно неочекивано: нове емоције! Радост, Туга, Бес, Страх и Гађење, који су дуго времена водили успешну операцију по свим параметрима, нису сигурни како се осећају када се Анксиозност појави. И чини се да није сама."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"腦筋急轉彎2","runtime":0,"tagline":"","homepage":"","overview":"睽違9年《腦筋急轉彎》正宗續集終於來啦! 皮克斯 2024最新動畫《腦筋急轉彎2》故事跟著萊莉來到了令人聞風喪膽的青春期，除了最受觀眾喜愛的情緒主角樂樂、憂憂、怒怒、厭厭、驚驚再度登場，更深入探索踏上青春期的萊莉內心，全新情緒角色也將全面解鎖，即將隨著她的嶄新生活一一登場，但一場「腦內革命」也無可避面地隨之爆發! 萊莉的內心世界再度陷入空前危機，樂樂和大夥們因而展開全新旅程，勢必奪回主控權讓大腦能順利升級…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"インサイド・ヘッド２","runtime":0,"tagline":"どんな感情も、きっと宝物になる―","homepage":"https://www.disney.co.jp/movie/insidehead2","overview":"どんな感情も、きっと宝物になる―ディズニー＆ピクサーが贈る、あなたの中に広がる＜感情たち＞の世界。少女ライリーを子どもの頃から見守ってきた頭の中の感情・ヨロコビたち。  ある日、高校入学という人生の転機を控えたライリーの中に、シンパイ率いる＜大人の感情＞たちが現れる。  「ライリーの将来のために、あなたたちはもう必要ない」―シンパイたちの暴走により、追放されるヨロコビたち。巻き起こる“感情の嵐”の中で、ライリーは自分らしさを失っていく…。  彼女を救うカギは、広大な世界の奥底に眠る“ある記憶”に隠されていた―。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Išvirkščias pasaulis 2","runtime":0,"tagline":"","homepage":"","overview":"Laukia didžiuliai pokyčiai! Mieli ir spalvingi nuotaikų žmogučiai įsikūrę Riley galvoje pažįsta mergaitę iš vidaus ir išorės, tačiau viskas pasikeičia pasirodžius naujai emocijai: Nerimui."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"თავდაყირა 2","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"玩轉腦朋友 2","runtime":97,"tagline":"","homepage":"","overview":"韋莉轉眼已踏入 13 歲，一班「腦朋友」——阿樂、阿愁、阿驚、阿燥、阿憎將「大腦總部」打理得井井有條，一切運作順利。豈料大腦總部有日突然響起警號，一大隊清拆隊全面進場，將大腦總部拆改得面目全非。原來一切只為騰出空間，迎接全新登場的腦朋友——阿焦 (Anxiety)！\r 阿焦的出現完全反轉大腦總部的秩序，雖然阿焦是全新成員，但她絕非等閒小角色。從預告可見，她的登場相當隆重，一抽二掕地攜帶了足足六箱行李，更在對白透露她並非隻身登場，似乎暗示今集將有更多腦朋友湧現！\r 隨著韋莉踏入青春期，在預告可見其大腦總部的控制台已經加建更多按鈕，控制台的顏色更變成橙色，與阿焦的顏色一樣！看來阿焦的出現，將為韋莉的大腦總部帶來一聯串翻天覆地的轉變，有更多大龍鳳即將發生！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Del revés 2","runtime":0,"tagline":"Fes lloc per a noves emocions.","homepage":"","overview":"Seqüela de ‘Del revés’ (2015). La Riley acaba d’entrar a l’adolescència i, ara, la seva ment ha de fer lloc a noves emocions. Quan apareix l'Angoixa, les velles emocions (la Joia, la Tristesa, la Ira, la Por, el Fàstic...) no saben què fer ni què sentir. I a més, sembla que la intrusa no ha vingut tota sola."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Izvrnuto obrnuto 2","runtime":0,"tagline":"Velike promjene. Nove emocije.","homepage":"https://www.blitzgroup.eu/movie-data/izvrnuto-obrnuto-2","overview":"Emocije Sreća, Strah, Tuga, Bijes i Gadljivost imaju novog posla u Rajkinom umu. Dok su se u prvom nastavku morale nositi s privikavanjem na novu okolinu zbog selidbe u novi grad, sada dobivaju društvo novih emocija jer Rajka ipak odrasta u mladu djevojku. Tinejdžerske godine znaju biti emotivno jako zahtjevne."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"درون و بیرون ۲","runtime":0,"tagline":"برای احساسات جدید جا باز کنید.","homepage":"","overview":"مرکز فرماندهی ذهن رایلی نوجوان دستخوش یک تخریب ناگهانی قرار گرفته است تا جا برای چیزی کاملاً غیرمنتظره باز کند: احساسات جدید! شادی، غم، خشم، ترس و نفرت، که مدت‌ها بی‌تردید مدیریت موفقی را اجرا کرده‌اند، مطمئن نیستند که چه احساسی باید داشته باشند وقتی اضطراب ظاهر می‌شود. و به نظر می‌رسد که او تنها نیست."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"","runtime":0,"tagline":"Maak plaats voor nieuwe emoties.","homepage":"https://nl.disney.be/films/inside-out-2","overview":"In “Disney-Pixar Binnenstebuiten 2” zijn we terug in het hoofd van de nieuwbakken tiener Riley, als ineens de slopers het hoofdkwartier binnenvallen. Ze komen ruimte maken voor iets totaal onverwachts: nieuwe Emoties! De oude rotten Plezier, Verdriet, Woede, Angst en Afkeer weten niet wat ze met Onzekerheid aan moeten. En die is niet alleen, want daar zijn ook nog eens Verlegenheid, Jaloezie en Ennui."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"Sens dessus dessous 2","runtime":96,"tagline":"Faites de la place pour de nouvelles émotions.","homepage":"","overview":"À l'adolescence, les émotions continuent à se chamailler dans le cerveau de Riley."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Vrvež v moji glavi 2","runtime":0,"tagline":"Naredite prostor za nova čustva.","homepage":"","overview":"Vrvež v moji glavi 2 se vrača v misli najstnice Riley, ravno v trenutku, ko se začenja prenova njenega možganskega nadzornega centra, kjer se ustvarja nov prostor za nekaj povsem nepričakovanega – nova Čustva! Veselje, Žalost, Jeza, Strah in Gnus, ki že dolgo uspešno vodijo čustvene operacije, niso prepričani, kako se počutijo, ko se med njimi pojavi Tesnoba, za katero pa se zdi, da ni prišla popolnoma sama."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"Întors pe dos 2","runtime":0,"tagline":"Păstrați loc pentru noi emoții.","homepage":"https://www.disney.ro/filme/intors-pe-dos-2","overview":"„Întors pe dos 2”, de la Disney și Pixar, revine în mintea proaspetei adolescente Riley, tocmai când totul este brusc dat peste cap din cauza unei surprize neașteptate: apariția unor noi Emoții! Bucuria, Tristețea, Furia, Frica și Dezgustul, emoțiile care s-au înțeles una pe alta și au condus mult timp o operațiune de succes din toate punctele de vedere, nu sunt sigure cum să reacționeze atunci când apare Anxietatea. Și se pare că Ea nu a venit singură."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"","iso_639_1":"co","iso_3166_1":"CO","english_name":"Corsican"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"","iso_639_1":"ku","iso_3166_1":"TR","english_name":"Kurdish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"Галаваломка 2","runtime":0,"tagline":"Знайдзі месца для новых эмоцый.","homepage":"","overview":"Працяг мультфільма ад Disney і Pixar вяртае гледачоў у свядомасць новаспечанай падлеткі Райлі. Галоўная кантора ў галаве дзяўчыны сутыкаецца з раптоўным выселеннем, каб вызваліць месца для нечага надзвычай нечаканага: новых Эмоцый! Радасць, Смутак, Гнеў, Страх і Агіда ўжо даўно паспяхова працуюць разам. Таму яны не ведаюць, што адчуваць, калі з'яўляецца Трывожнасць. І, здаецца, яна прыйшла не адна."},"name":"беларуская мова","iso_639_1":"be","iso_3166_1":"BY","english_name":"Belarusian"},{"data":{"title":"Prāta spēles 2","runtime":0,"tagline":"","homepage":"","overview":"Railijas prāta vadības galvenajā birojā notiek kapitālais remonts tieši tajā brīdī, kad ir nepieciešams atbrīvot tajā vietu kaut kam pavisam negaidītam - jaunām emocijām. Laime, Nemiers, Niknums, Nepatika un Melanholija, kuras jau sen un ļoti veiksmīgi regulē visus procesus, ir apjukušas un nesaprot ko iesākt, kad parādās...Trauksme. Un izskatās, ka viņa nav viena."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Pahupidi 2","runtime":0,"tagline":"Tehke ruumi uutele emotsioonidele","homepage":"","overview":"Kõik meie tuttavad emotsioonid - Rõõm, Kurbus, Hirm, Viha ja Vastikus - on tagasi, aga kuna Raili on saanud juba 13-aastaseks ja astunud seega haprasse murdeikka, saabub ühel päeval \"peakorterisse\" täiesti uus emotsioon - Ärevus. Ja nagu sellest veel vähe oleks - tal on kaasas ka tema lahutamatud sõbrad Kadedus, Piinlikkus ja Tülpimus. Loomulikult on nende saabumine ajastatud täiuslikult, sest Raili on suundumas just oma esimesse hokilaagrisse, kus on vaja otsusele jõuda, kuidas võita endale uusi sõpru ilma, et oma praeguseid parimaid sõpru eemale peletada, kuidas võita treeneri poolehoid ilma, et sind pugejaks ei peetaks ja kuidas teha ülilihtsaid asju selgeks oma vanematele, kes ei näi otsekui üleöö mitte millestki aru saavat."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"shqip","iso_639_1":"sq","iso_3166_1":"AL","english_name":"Albanian"},{"data":{"title":"Inside Out 2","runtime":0,"tagline":"","homepage":"","overview":"Hugur unglingsstúlkunnar Riley er að ganga í gegnum sannkallaðar hamfarir til að búa til rými fyrir eitthvað algjörlega óvænt; nýjar tilfinningar! Gleði, Sorg, Reiði, Ótti og Ógeð, sem lengi hafa hafa notið lífsins og gengið vel, vita ekki hvað þau eiga að halda þegar Kvíði birtist. Og svo virðist sem hún sé ekki ein á ferð."},"name":"Íslenska","iso_639_1":"is","iso_3166_1":"IS","english_name":"Icelandic"}],"reviews_tmdb":[{"id":"666193da58a1f88965b77e41","url":"https://www.themoviedb.org/review/666193da58a1f88965b77e41","author":"Hotplix","content":"\"Inside Out 2\" is a heartwarming and imaginative sequel that successfully builds on the emotional depth of its predecessor. Directed by Kelsey Mann, the film revisits Riley as she navigates the complexities of teenage life, with her emotions—Joy, Sadness, Anger, Fear, and Disgust—returning to guide her. The movie introduces new emotions, adding fresh dynamics and challenges. The animation is vibrant and expressive, capturing the nuanced portrayal of inner emotional worlds. With its clever storytelling, humor, and poignant moments, \"Inside Out 2\" resonates deeply with audiences, offering a thoughtful exploration of growing up and emotional resilience.","created_at":"2024-06-06T10:47:54.037Z","updated_at":"2024-06-06T21:26:59.866Z","author_details":{"name":"Hotplix","rating":8,"username":"Hotplix","avatar_path":"/5LdGr01PGRmrg6Hh3LYPGlOOdUx.jpg"}},{"id":"6669f31a282af652f2d05392","url":"https://www.themoviedb.org/review/6669f31a282af652f2d05392","author":"garethmb","content":"$11","created_at":"2024-06-12T19:12:26.637Z","updated_at":"2024-06-12T19:12:26.711Z","author_details":{"name":"","rating":null,"username":"garethmb","avatar_path":null}},{"id":"666fd74e159c95894aa651db","url":"https://www.themoviedb.org/review/666fd74e159c95894aa651db","author":"CinemaSerf","content":"$12","created_at":"2024-06-17T06:27:26.802Z","updated_at":"2024-06-17T06:27:26.904Z","author_details":{"name":"CinemaSerf","rating":6,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}},{"id":"667202b04234e2d0e5343999","url":"https://www.themoviedb.org/review/667202b04234e2d0e5343999","author":"Chris Sawin","content":"_Inside Out 2_ is a harmless sequel that is fun for all ages but also absolutely unnecessary. The film recycles three-quarters of the original while introducing a quarter of new characters and ideas.\r\n\r\n**Full review:** https://bit.ly/PixarClone","created_at":"2024-06-18T21:57:04.460Z","updated_at":"2024-06-18T21:57:04.666Z","author_details":{"name":"Chris Sawin","rating":5,"username":"ChrisSawin","avatar_path":null}},{"id":"66732d170db8b2a0d56eac29","url":"https://www.themoviedb.org/review/66732d170db8b2a0d56eac29","author":"MannyD","content":"$13","created_at":"2024-06-19T19:10:15.534Z","updated_at":"2024-06-20T14:43:14.219Z","author_details":{"name":"MannyD","rating":null,"username":"MannyDavis","avatar_path":"/86nX44xQOuSoufxpUetPmA9jAzz.jpg"}},{"id":"66765c24ba3378eba6232971","url":"https://www.themoviedb.org/review/66765c24ba3378eba6232971","author":"heyitsmestoney","content":"This movie is not bad at all. they left to open to more movies and I am good with that they kids haven’t a good franchise since toy store movies so ya I hope they keep making them!!","created_at":"2024-06-22T05:07:48.082Z","updated_at":"2024-06-24T14:32:33.810Z","author_details":{"name":"","rating":7,"username":"heyitsmestoney","avatar_path":null}},{"id":"668d477e9d1b57031f5c0507","url":"https://www.themoviedb.org/review/668d477e9d1b57031f5c0507","author":"TheSceneSnobs","content":"$14","created_at":"2024-07-09T14:21:50.441Z","updated_at":"2024-07-12T18:44:39.744Z","author_details":{"name":"","rating":8,"username":"TheSceneSnobs","avatar_path":null}},{"id":"669b5f392294f2f7fdde9851","url":"https://www.themoviedb.org/review/669b5f392294f2f7fdde9851","author":"minion196","content":"\"Inside Out 2\" brilliantly follows up its predecessor with a heartwarming and deeply insightful exploration of the human mind. Directed by Pete Docter and produced by Pixar Animation Studios, this sequel delves even deeper into the complexities of emotions, creating a movie that is as intellectually stimulating as it is emotionally resonant.\r\n\r\nThe film continues the story of Riley, now a teenager, navigating the tumultuous waters of adolescence. The return of our beloved emotions—Joy, Sadness, Anger, Fear, and Disgust—offers a delightful reunion while introducing new emotional characters that reflect the evolving complexity of Riley's inner world. Each emotion is beautifully voiced, bringing authenticity and depth to their characters. Amy Poehler’s Joy and Phyllis Smith’s Sadness once again shine, their dynamic evolving in ways that are both surprising and deeply moving.","created_at":"2024-07-20T06:54:49.787Z","updated_at":"2024-07-22T15:27:31.154Z","author_details":{"name":"","rating":null,"username":"minion196","avatar_path":null}},{"id":"67246aa4c1212313ac7ebcb3","url":"https://www.themoviedb.org/review/67246aa4c1212313ac7ebcb3","author":"moviepoptime","content":"$15","created_at":"2024-11-01T05:44:04.684Z","updated_at":"2024-11-04T17:31:04.991Z","author_details":{"name":"","rating":null,"username":"moviepoptime","avatar_path":null}}],"recommendations":[{"id":519182,"adult":false,"title":"Despicable Me 4","video":false,"overview":"Gru and Lucy and their girls—Margo, Edith and Agnes—welcome a new member to the Gru family, Gru Jr., who is intent on tormenting his dad. Gru also faces a new nemesis in Maxime Le Mal and his femme fatale girlfriend Valentina, forcing the family to go on the run.","genre_ids":[10751,35,16,878,28],"media_type":"movie","popularity":15.987,"vote_count":3080,"poster_path":"/wWba3TaojhK7NdycRhoQpsG0FaH.jpg","release_date":"2024-06-20","vote_average":6.993,"backdrop_path":"/twsxsfao6ZOVvT8LfudH603MMi6.jpg","original_title":"Despicable Me 4","original_language":"en"},{"id":150540,"adult":false,"title":"Inside Out","video":false,"overview":"When 11-year-old Riley moves to a new city, her Emotions team up to help her through the transition. Joy, Fear, Anger, Disgust and Sadness work together, but when Joy and Sadness get lost, they must journey through unfamiliar places to get back home.","genre_ids":[16,10751,12,18,35],"media_type":"movie","popularity":16.5969,"vote_count":23190,"poster_path":"/2H1TmgdfNtsKlU9jKdeNyYL5y8T.jpg","release_date":"2015-06-17","vote_average":7.909,"backdrop_path":"/o3i6AfTcWAuNvzAUV3q5lOmi6Gx.jpg","original_title":"Inside Out","original_language":"en"},{"id":533535,"adult":false,"title":"Deadpool & Wolverine","video":false,"overview":"A listless Wade Wilson toils away in civilian life with his days as the morally flexible mercenary, Deadpool, behind him. But when his homeworld faces an existential threat, Wade must reluctantly suit-up again with an even more reluctant Wolverine.","genre_ids":[28,35,878],"media_type":"movie","popularity":22.6059,"vote_count":8294,"poster_path":"/8cdWjvZQUExUUTzyp4t6EDMubfO.jpg","release_date":"2024-07-24","vote_average":7.557,"backdrop_path":"/ufpeVEM64uZHPpzzeiDNIAdaeOD.jpg","original_title":"Deadpool & Wolverine","original_language":"en"},{"id":653346,"adult":false,"title":"Kingdom of the Planet of the Apes","video":false,"overview":"Several generations following Caesar's reign, apes – now the dominant species – live harmoniously while humans have been reduced to living in the shadows. As a new tyrannical ape leader builds his empire, one young ape undertakes a harrowing journey that will cause him to question all he's known about the past and to make choices that will define a future for apes and humans alike.","genre_ids":[878,12,28],"media_type":"movie","popularity":11.4341,"vote_count":4103,"poster_path":"/gKkl37BQuKTanygYQG1pyYgLVgf.jpg","release_date":"2024-05-08","vote_average":7.054,"backdrop_path":"/iHYh4cdO8ylA3W0dUxTDVdyJ5G9.jpg","original_title":"Kingdom of the Planet of the Apes","original_language":"en"},{"id":786892,"adult":false,"title":"Furiosa: A Mad Max Saga","video":false,"overview":"As the world falls, young Furiosa is snatched from the Green Place of Many Mothers into the hands of a great biker horde led by the warlord Dementus. Sweeping through the wasteland, they encounter the citadel presided over by Immortan Joe. The two tyrants wage war for dominance, and Furiosa must survive many trials as she puts together the means to find her way home.","genre_ids":[28,878,12],"media_type":"movie","popularity":13.5751,"vote_count":4678,"poster_path":"/iADOJ8Zymht2JPMoy3R7xceZprc.jpg","relea