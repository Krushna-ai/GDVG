_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"link":"https://www.themoviedb.org/movie/418472-ahlat-agaci/watch?locale=US","rent":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":6},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}]}}},"wikidata_id":"Q31193168","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-20T21:55:46.329192+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":[{"data":{"title":"The Wild Pear Tree","runtime":188,"tagline":"All these small-minded, bigoted people like peas in a pod.","homepage":"http://www.nbcfilm.com/ahlat/ahlat.php","overview":"Fresh out of university, a Turkish young man with literary aspirations returns to his home village and starts scraping together money to publish his book. While trying to reconnect with his old friends and environment; his uncertainty, existential struggle and his father’s gambling addiction bring him grave difficulties."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Le Poirier Sauvage","runtime":188,"tagline":"Ce qu'un père garde caché se révèle avec son fils.","homepage":"http://distribution.memento-films.com/film/infos/91","overview":"Passionné de littérature, Sinan a toujours voulu être écrivain. De retour dans son village natal d’Anatolie, il met toute son énergie à trouver l’argent nécessaire pour être publié, mais les dettes de son père finissent par le rattraper…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":188,"tagline":"","homepage":"","overview":"Sinan (Aydın Doğu Demirkol) oldum olası edebiyatla ilgili bir genç adamdır ve yazar olmak istemektedir. Anadolu'da doğduğu köye dönen genç adam kitabını bastıracak parayı bulmak için tüm enerjisini harcamaya başlar ancak babasının geçmişten kalan borçları başına dert olacaktır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Дикая груша","runtime":188,"tagline":"","homepage":"","overview":"Синан обожает литературу и всегда хотел быть писателем. Вернувшись в родную деревню он прикладывает невероятные усилия, чтобы собрать денег, которые нужны для издания книги. Но все собранные средства уходят на оплату долгов, которые оставил отец."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"L'albero dei frutti selvatici","runtime":188,"tagline":"","homepage":"","overview":"Un aspirante scrittore torna nel suo villaggio natale nella Turchia rurale, dove viene travolto dai debiti del padre."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"El peral salvaje","runtime":188,"tagline":"Lo que un padre mantiene oculto se revela en el hijo.","homepage":"","overview":"Un aspirante a escritor regresa a su pueblo natal en Turquía, pero se siente abrumado por las deudas y problemas que tiene su padre."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"야생 배나무","runtime":0,"tagline":"","homepage":"","overview":"대학에서 문학을 전공한 시난은 교사로 취직하여 가계에 도움을 주기 위해 고향으로 돌아온다. 하지만 그가 정말 원하는 것은 그의 첫 소설을 출판하는 것. 출판을 위한 자금을 마련하고자 애쓰지만, 아버지 이드리스의 소소한 도박 때문에 가족은 빚 독촉과 생활고에 늘 시달리며 녹록지 않은 삶을 살고 있다. 그런 시난에게 아버지는 사랑과 미움의 대상이다. 세 시간이 넘는 상영 시간 동안 시난과 그의 주변 사람들, 그리고 그들이 나누는 끝없는 대화를 들려주는 는 이야기의 중심에 시난과 이드리스 두 부자를 병치시키며 위기의 남성성을 관찰한다. 짐짓 장황하게 들리는 대화들은 시간이 흐를수록 서로 꼬리를 물며 묘한 리듬을 자아내고, 그 속에서 시난은 때로는 애처롭고 때로는 밉살스럽게 등장한다. 자신의 언어가 가진 역능을 믿는 시난과, 물 한 방울 나오지 않는 우물을 묵묵히 파는 이드리스, 두 남자가 자아내는 긴장은 영화의 마지막, 묵직하고 강렬한 마법적인 순간을 향해 나아간다. 터키 북서부의 차낙칼레와 근교의 풍광은 언어로 전달되지 않는 어떤 심성을 시난의 이야기에 더해주는 또 하나의 캐릭터다.  (2018년 제23회 부산국제영화제/박진형)"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"野梨樹","runtime":0,"tagline":"","homepage":"","overview":"描述在探討父子間難以割捨的連結，劇情描述一名才華橫溢的作家，為了新書出版返鄉籌錢，不料在家鄉等著他的，竟是父親遺留下來的大筆債務。他只得暫時放下人生規劃，卻在努力償還債務之時，發現更多父親不為人知的秘密。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Дивата круша","runtime":188,"tagline":"Онова, което бащата е съумял да скрие, се проявява в характера на сина.","homepage":"","overview":"Филмът разказва историята на Синан, който се завръща в родното си село и прави всичко възможно да събере необходимите средства, за да издаде все още непубликуваната си книга. Дълговете на баща му обаче ще попречат на героя да сбъдне своята мечта."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"A Árvore dos Frutos Selvagens","runtime":188,"tagline":"","homepage":"","overview":"Sinan é um jovem apaixonado por literatura que sempre sonhou em se tornar um grande escritor. Ao retornar para o vilarejo em que nasceu, ele faz de tudo para conseguir juntar dinheiro e investir na sua primeira publicação. O problema é que seu pai deixou uma dívida que atrapalhará os seus planos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"野梨树","runtime":188,"tagline":"","homepage":"","overview":"志在成为作家的锡南（艾登·多古·德米科尔 饰）大学毕业后回到家乡，希望能凑足资金出版自己的第一部小说。他在镇上徘徊，遇到旧日恋人与固执的守旧派，并发现自己年轻的抱负与那位赌博成瘾的父亲（穆拉特·杰姆吉尔 饰）被搁置的梦想愈发冲突。当他的幻想与现实交织，锡南不得不与塑造了他身份的人们和这片土地展开周旋。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Det Vilde Pæretræ","runtime":0,"tagline":"","homepage":"","overview":"Sinans store kærlighed til litteratur og drømmen om at blive forfatter sender ham tilbage til sin fødeby, da han som færdiguddannet beslutter sig for at forfølge sin drøm. I fødebyen, en lille tyrkisk landsby, kæmper han for at få skrabet penge sammen til at få udgivet sin første roman. Sinan ligger hele sit hjerte og sjæl i projektet, men farens store spillegæld og familiens forventninger om at han skal blive lærer, er blot nogle af Sinans forhindringer på vejen mod at nå sin store drøm. I landsbyen går det op for ham, at han ikke længere er den samme, som da han forlod den. Han står ikke længere inde for dens traditioner og kultur, hvilket fører til en personlig indre kamp om at skille sig af med den."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"עץ האגס הפראי","runtime":0,"tagline":"","homepage":"","overview":"סרטו של אמן הקולנוע הטורקי נורי בילה ג'יילאן, שסרטיו הקודמים \"היו זמנים באנטוליה\" ו\"שנת חורף\" הציבו אותו בשורה אחת עם יוצרי הקולנוע הטובים בעולם, הוא סרט שכבר תואר כ\"שירה קולנועית\" – דרמה אנושית, מרגשת ועוצרת נשימה ביופיה.  סינאן חוזר לכפר שבו נולד וגדל, אחרי שנים בהן הסתובב בעולם, היישר אל חיק משפחתו שנדמה כי לא השתנתה כלל – אמו הכנועה, אחותו שעוד לא סיימה את לימודיה ואביו, שתמיד היה הרוח החיה של המשפחה, אבל אף פעם לא הצליח לשמור על הכסף שלו ליותר מדי זמן. סינאן, שמאז ומתמיד חלם להיות סופר, עובד יום וליל על מנת לגייס את הסכום הדרוש לו להוציא לאור את הספר הראשון שכתב. אך בדיוק כשנדמה שייתכן שהחלום שלו יתגשם, החובות הכספיים של אביו, שנדמה שפזורים בכל הכפר, משיגים אותו…"},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Det vildväxande päronträdet","runtime":188,"tagline":"","homepage":"","overview":"Sinan är en passionerad litteraturälskare och har alltid velat bli författare. När han återvänder till byn där han föddes lägger han ner hjärta och själ för att skrapa ihop pengarna för att bli publicerad, men trots blod, svett och tårar hinner pappans skulder ikapp honom."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Η Άγρια Αχλαδιά","runtime":188,"tagline":"","homepage":"","overview":"Ήρωας στην Άγρια Αχλάδια» είναι ένας νεαρός ο οποίος επιστρέφει απρόθυμα μετά τις σπουδές του στο χωριό που μεγάλωσε, και στο σπίτι των γονιών του, φιλοδοξώντας να αποφασίσει τι θα κάνει με το μέλλον του και να προσπαθήσει να εκδώσει το πρώτο του βιβλίο. Καθώς οι μέρες περνούν, ο Σινάν περιπλανιέται στον σχεδόν ασφυκτικό μικρόκοσμο του χωριού του, συναντά συγγενείς και φίλους και σιγά-σιγά συνειδητοποιεί τόσο την αντιπάθειά του για το μέρος που τον περιβάλλει όσο και για τον πατέρα του- έναν ανεύθυνο καθηγητή και οικογενειάρχη, πνιγμένο στα χρέη και με αδυναμία στον τζόγο."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Le poirier sauvage","runtime":0,"tagline":"","homepage":"https://www.mk2mile-end.com/films/le-poirier-sauvage/","overview":"Passionné de littérature, Sinan a toujours voulu être écrivain. De retour dans son village natal d’Anatolie, il met toute son énergie à trouver l’argent nécessaire pour être publié, mais les dettes de son père finissent par le rattraper…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"A vadkörtefa","runtime":188,"tagline":"","homepage":"","overview":"Egy ígéretes író visszatér szülőfalujába, ahol szembesülnie kell apja adósságaival."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"A Pereira Brava","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Дрво дивље крушке","runtime":0,"tagline":"","homepage":"","overview":"Синан страствен љубитељ књижевности, одувек је сањао да постане писац. По повратку у своје родно село, он се из свег срца труди да прикупи новац неопходан за објављивање своје прве књиге. Али очеви дугови га сустижу…"},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Dzika grusza","runtime":0,"tagline":"","homepage":"","overview":"Absolwent pedagogiki Sinan, przed ostatnimi egzaminami wraca do rodzinnego Çan w północno-zachodniej Turcji. Jako przybysz z większego miasta patrzy z mieszanką niechęci i pobłażania na prowincjonalną społeczność, którą opuścił przed laty. Stopniowo jednak życie w Çan angażuje go coraz bardziej, a marzenia o sukcesie - i wymarzonej karierze pisarza - okazują się trudne do urzeczywistnienia."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":188,"tagline":"","homepage":"","overview":"Sinan is een grote literatuurliefhebber en droomt er al jaren van om schrijver te worden. Nadat hij in zijn geboortedorp in Anatolië terugkeert, stelt hij alles in het werk om gepubliceerd te raken. Het zijn echter de schulden van zijn vader die hem inhalen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Der wilde Birnbaum","runtime":181,"tagline":"‎Was ein Vater versteckt, offenbart sich im Sohn.‎","homepage":"","overview":"Der von einer Leidenschaft für Literatur gepackte Sinan wollte schon immer nicht nur Lehrer, sondern auch Schriftsteller werden. Nun hat er nach Abschluss seines Studiums auch ein Buch geschrieben und hofft das Manuskript an den Mann zu bringen. Doch zurück in seinem anatolischen Heimatdorf holen ihn die Schulden seines Vaters Idris ein. Der hat durch seine Wettsucht nämlich alles verspielt, sieht aber schon einen Ausweg. Er hat angeblich ein Vermögen in Aussicht..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"野梨樹","runtime":0,"tagline":"","homepage":"","overview":"入選第71屆坎城影展主競賽片。曾以《冬日甦醒》摘下金棕櫚獎的土耳其導演努瑞貝其錫蘭新作。\r 他為出書返鄉籌錢，迎接他的卻是父親的龐大債務… 剛從大學畢業的年輕作家錫南（Dogu Demirkol 飾），正準備出版他的第一本小說《野梨樹》。缺乏資金的他，於是返鄉尋求資金。不料迎接他的，竟是父親（Murat Cemcir 飾）債台高築的殘酷事實。錫南父親伊德利本是村裡的國小教師，卻因賭馬欠下一屁股債，即使變賣所有家產，原本聲譽仍毀於一旦。不齒父親行徑的錫南，為了一圓出版夢，只得靠自己四處籌錢。他找上了村裡的議員、商人、教長等尋求協助，卻也因父親引發一波波爭執而不歡而散。但在過程中，錫南卻發現父親一個不為人知的秘密，更使彼此關係雪上加霜。錫南出版新書《野梨樹》的夢想，最終能實現嗎？他與父親水火不容的關係，又能獲得解決嗎？當他憶起父親從小教他認識的「野梨樹」特質時，對於人性的異同與生命的多貌，在瞬間似乎有了頓悟。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"El peral silvestre","runtime":188,"tagline":"Drama | Familia","homepage":"","overview":"Un aspirante a escritor regresa a su pueblo natal en Turquía, pero se siente abrumado por las deudas y problemas que tiene su padre."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Cây Lê Dại","runtime":0,"tagline":"","homepage":"","overview":"Một nhà văn trở về quê hương sau khi tốt nghiệp, nơi anh ta tìm kiếm các nhà tài trợ để xuất bản cuốn sách của mình trong khi đối phó với sự buông thả của cha mình vào cờ bạc."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Laukinė kriaušė","runtime":0,"tagline":"","homepage":"","overview":"Jaunas, arogantiškas rašytojas Sinanas po universiteto studijų grįžta į gimtąjį miestą, tikėdamsis rasti pinigų savo pirmajai knygai išleisti. Vaikino ir jo tėvo – žirgų lenktynėse prasilošusio, tad pagarbą praradusio miestelio mokytojo – tarpusavio santykiai tampa istorijos pagrindu. Personažų būsenos kinta drauge su metų laikais ir jų veikiama stulbinančia Turkijos gamta. Kanų festivalyje ne kartą apdovanotas, o 2014 m. – ir už geriausią filmą, Ceylanas, kaip jam įprasta, pasakoja ramiai, išmintingai ir įtraukiančiai."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"}],"reviews_tmdb":[],"recommendations":[{"id":74879,"adult":false,"title":"Once Upon a Time in Anatolia","video":false,"overview":"A group of men lead a search for a victim of a murder to whom a suspect named Kenan and his mentally challenged brother confessed. However, the search is proving more difficult than expected as Kenan is fuzzy as to the body's location. As the group continues looking and the night begins dragging on, its members can't help but chat with each other about everyday life, as the conversations turn more and more serious, revealing their deeper secrets and profound stories.","genre_ids":[18,80],"media_type":"movie","popularity":1.3625,"vote_count":524,"poster_path":"/bN84guFndgvtWIvFC7sTD8AAJDE.jpg","release_date":"2011-09-23","vote_average":7.5,"backdrop_path":"/213Gdu9zjGsVeWQl6p5gJrBq8n8.jpg","original_title":"Bir Zamanlar Anadolu'da","original_language":"tr"},{"id":491303,"adult":false,"title":"Butterflies","video":false,"overview":"Three strangers with one thing in common — the same father — come to a Turkish village to bury him, and learn about him and each other.","genre_ids":[18,35],"media_type":"movie","popularity":3.0183,"vote_count":108,"poster_path":"/7FfL2IFkVnwqK95mQVY3IYJK9kR.jpg","release_date":"2018-03-30","vote_average":6.9,"backdrop_path":"/zytLXz0ZCPmaca6R5qAnhJmElUy.jpg","original_title":"Kelebekler","original_language":"tr"},{"id":507537,"adult":false,"title":"Kızım ve Ben","video":false,"overview":"Doruk, the only child of a wealthy family, fulfills his dream by entering the police academy and graduating at the top of his class. He falls in love with Serap, whom he meets during an operation, and they get married. Shortly after their daughter Zeynep is born, Serap falls into a depression and leaves home. Doruk, a heroic special operations police officer, takes on both the role of mother and father to his daughter Zeynep while juggling his demanding duties. Just as a beautiful bond forms between father and daughter, Serap, who had left home, returns. A difficult period begins in the lives of father and daughter.","genre_ids":[18,10749,80],"media_type":"movie","popularity":0.1295,"vote_count":5,"poster_path":"/b0HEe3cnvxUijEL9RFK3MrNQrUo.jpg","release_date":"2018-04-06","vote_average":6.6,"backdrop_path":"/kMA9rn3ZvZIQSBzlv7a6aAKlYqL.jpg","original_title":"Kızım ve Ben","original_language":"tr"},{"id":72579,"adult":false,"title":"Noukadubi","video":false,"overview":"Rameshchandra Chaudhry, a lawyer by profession, is in love with Hemnalini, and is displeased when he finds that his father wants him to marry Sushilla, the daughter of a widow. He initially refuses despite of his father disowning him, but changes his mind when the bride's mother pleads with him, and gets married without even seeing, leave alone getting to know his bride. After the marriage, they board a boat which overturns after a storm, and they end up being the only survivors. Unable to get Hemnalini out of his mind, he refuses to be intimate with his bride. On talking with her gradually over the next few months, it slowly sinks in that she is not Sushilla but Kamla - the bride of another male! The question remains: what can he do under these circumstances, and what impact will this have on Kamla - who has traditionally accepted him as her husband.","genre_ids":[10749,18],"media_type":"movie","popularity":0.1454,"vote_count":7,"poster_path":"/xebG4lhLu3R6yAePRVrXrYA4lWD.jpg","release_date":"2011-05-20","vote_average":6.9,"backdrop_path":"/eFBE12jjD7vRDhL0fTnzvgSoJc.jpg","original_title":"নৌকাডুবি","original_language":"bn"},{"id":612172,"adult":false,"title":"A Long Cold Winter","video":false,"overview":"A documentary about the shooting session of the film \"Winter Sleep\" by Nuri Bilge Ceylan. 'Winter Sleep' had been shot in about 14 weeks in Cappadocia region of Anatolia.","genre_ids":[99],"media_type":"movie","popularity":0.1034,"vote_count":2,"poster_path":"/lnzI6DWAG4zireZ7HiycWa5NBXz.jpg","release_date":"2014-12-31","vote_average":8,"backdrop_path":null,"original_title":"A Long Cold Winter","original_language":"tr"},{"id":653831,"adult":false,"title":"John Wayne - America at All Costs","video":false,"overview":"This is the story of a man who climbed the Hollywood ladder, one rung at a time, until he reached the top and became the most popular American actor of his era.","genre_ids":[99],"media_type":"movie","popularity":0.149,"vote_count":9,"poster_path":"/oTwOCKk8sXaJQDNy0uqS1klkBfT.jpg","release_date":"2019-10-14","vote_average":6.7,"backdrop_path":"/1P0vQoZYoMG1LvtHKgLl6pV2XQL.jpg","original_title":"John Wayne - L'Amérique à tout prix","original_language":"fr"},{"id":446210,"adult":false,"title":"No Way! 2","video":false,"overview":"Barber Adnan is the neighborhood gossip. He knows everything about his customers in the neighborhood. When Adnan learns he's about to be fired, he clings to his job. Aykut, who is trying to become an internet sensation through his daughter's social media accounts, Merve, who left her city life behind to move to the village, and Meriç, who faced every possible mishap while visiting a village to ask for a girl's hand in marriage—these are the entertaining stories Adnan shares with the audience...","genre_ids":[35],"media_type":"movie","popularity":0.1368,"vote_count":19,"poster_path":"/lPGrsssEkHZzUuhTjhAHrKqPrMN.jpg","release_date":"2016-10-07","vote_average":4.7,"backdrop_path":"/oG6i6TrF7PV9lGSlcK3F7BRQjlu.jpg","original_title":"Yok Artık! 2","original_language":"tr"},{"id":520273,"adult":false,"title":"The Gentle Indifference of the World","video":false,"overview":"After her father's untimely death, Saltanat is forced to trade her idyllic countryside life for the cruel city. She has to find money to pay off the large family debt that her father left behind, in order to save her mother from jail. Friends since their village childhood, her loyal, but penniless admirer Kuandyk follows her just to make sure his sweetheart is safe. Saltanat's uncle introduces her to a possible groom, who promises to pay off her family's debts. But Saltanat's hopes are dashed, when she discovers that the men in this city don't keep their word. When Kuandyk tries to help Saltanat get the money through other ways, he ends up finding himself in more trouble than he bargained for. Although life keeps dealing them bad hands, Saltanat and Kuandyk never give up, no matter what the odds.","genre_ids":[18],"media_type":"movie","popularity":0.1601,"vote_count":10,"poster_path":"/rH3lxvjMfeDbehgKtKZEJHNd3Qy.jpg","release_date":"2018-10-24","vote_average":5.1,"backdrop_path":"/uaqhszA9bVavbmsD8gtHgeVFF86.jpg","original_title":"Әлемнің ерке енжарлығы","original_language":"kk"},{"id":589836,"adult":false,"title":"Ozone Hole: How We Saved the Planet","video":false,"overview":"Discover the forgotten story of the hole in the ozone layer and how the world came together to fix it. Hear from the scientists and politicians who persuaded Ronald Reagan and Margaret Thatcher to take action and solve the planetary problem.","genre_ids":[99],"media_type":"movie","popularity":0.045,"vote_count":3,"poster_path":"/7iOsMEgcpEq1XsSIxIiArfSkBKY.jpg","release_date":"2019-04-08","vote_average":8.3,"backdrop_path":"/vVgqeTsXO4lYc0YevPYhkFHKFHY.jpg","original_title":"Ozone Hole: How We Saved the Planet","original_language":"en"},{"id":572676,"adult":false,"title":"Murphy's Law","video":false,"overview":"Bahman's daughter is kidnapped. Farokh recently fired as a police man is going to help him find his daughter.","genre_ids":[35,28],"media_type":"movie","popularity":0.0948,"vote_count":7,"poster_path":"/9zzMFQzYgbLeMEFUpCcZtSGYRze.jpg","release_date":"2019-01-02","vote_average":4.571,"backdrop_path":null,"original_title":"قانون مورفی","original_language":"fa"},{"id":265169,"adult":false,"title":"Winter Sleep","video":false,"overview":"Aydın is a hotel owner and a retired actor in rural Turkey. As winter emerges he begins navigating the conflicts within the relationships with his wife, sister and existence.","genre_ids":[18],"media_type":"movie","popularity":0.9522,"vote_count":610,"poster_path":"/95j83qOqH3Ivz4RYkaSjGT0VSNr.jpg","release_date":"2014-06-13","vote_average":7.5,"backdrop_path":"/4JuoO0XywrCDeHLy4kTB9FU5U2C.jpg","original_title":"Kış Uykusu","original_language":"tr"},{"id":83567,"adult":false,"title":"Somersault in a Coffin","video":false,"overview":"Mahsun Supertitiz is an unemployed homeless man who steals cars at night so that he can sleep in a heated place during the winter. Mahsun lives in Rumelihisar, an old section of Istanbul, and makes ends meet by getting the local fishermen to help him. Mahsun loves the cars he robs, cleans and polishes them, and drives them through the streets of Rumelihisar during the daytime.","genre_ids":[18],"media_type":"movie","popularity":0.5761,"vote_count":79,"poster_path":"/wZFHPRHKyN8nXEsZJ6tqTUbACuZ.jpg","release_date":"1996-04-01","vote_average":7.418,"backdrop_path":"/3deAGN09WpwQXxtxUYHvbNAAowA.jpg","original_title":"Tabutta Rövaşata","original_language":"tr"},{"id":31026,"adult":false,"title":"Distant","video":false,"overview":"A young man from rural Turkey arrives in Istanbul with dreams of working on a ship and stays with a cousin while he searches for work. Over time, the former’s struggles to find employment and the latter’s troubles and disappointments strain their relationship and living situation.","genre_ids":[18],"media_type":"movie","popularity":1.1522,"vote_count":254,"poster_path":"/7XKGrHh1BRnMiIRMRYRsWPQDJfh.jpg","release_date":"2002-12-20","vote_average":7.11,"backdrop_path":"/rsFMqISY2t9Qv642DPSfX34Lh1Y.jpg","original_title":"Uzak","original_language":"tr"},{"id":477274,"adult":false,"title":"My Travel Buddy","video":false,"overview":"Days before Eid, a salesman fired from his job drives to meet his girlfriend's family, but the trip goes astray due to his zany travel buddy.","genre_ids":[35],"media_type":"movie","popularity":0.902,"vote_count":67,"poster_path":"/1TZUXLdXusbak3GspmvprQQ0CZo.jpg","release_date":"2017-10-27","vote_average":5.925,"backdrop_path":"/wd7Vx3LI8etvsvKibIAPhHfjuV.jpg","original_title":"Yol Arkadaşım","original_language":"tr"},{"id":52111,"adult":false,"title":"The Small Town","video":false,"overview":"A story in four parts is told from the perspective of two children, showing life in school, in nature, with family and at home. All of this unfolding along with the seasons. The Small Town depicts life in the village, while also portraying the relationships between members of a small-town family, in a long centerpiece scene around a campfire with family members talking about the past, life and its disappointments. Both brother and sister witness the complexities and darkness of the adult world, as well as the mysteries of nature and wildlife.","genre_ids":[18],"media_type":"movie","popularity":0.7362,"vote_count":114,"poster_path":"/3l8X5JRmdZckhaHbIml0UY0mbP5.jpg","release_date":"1997-11-28","vote_average":6.5,"backdrop_path":"/f0hZnbxYGOrgTqd2Pv60Pz4A1OU.jpg","original_title":"Kasaba","original_language":"tr"},{"id":312849,"adult":false,"title":"Ivy","video":false,"overview":"After the owner's bankruptcy, the crew is stranded on a freighter for months. Dealing with the stress of isolation, seafarers gradually surrender to madness and terror.","genre_ids":[18,14,53],"media_type":"movie","popularity":0.3011,"vote_count":105,"poster_path":"/jsqgoFLDX4o0dNkdjB8UG83Rzng.jpg","release_date":"2015-01-26","vote_average":7.781,"backdrop_path":"/pw9oCxdHISiiWYjthGO9iXXcVtw.jpg","original_title":"Sarmaşık","original_language":"tr"},{"id":382892,"adult":false,"title":"Paris 05:59 / Théo & Hugo","video":false,"overview":"Théo and Hugo meet in a club and form an immediate bond. Once the desire and elation of this first moment has passed, the two young men, now sober, wander through the empty streets of nocturnal Paris, having to confront the love they sense blossoming between them.","genre_ids":[18,10749],"media_type":"movie","popularity":1.3658,"vote_count":113,"poster_path":"/hcxPzjmNJ797OS19ohuvgrDx4Yt.jpg","release_date":"2016-04-27","vote_average":6.7,"backdrop_path":"/5iGt8QkPa71RbcyBzkORYZOW531.jpg","original_title":"Théo et Hugo dans le même bateau","original_language":"fr"},{"id":8905,"adult":false,"title":"Three Monkeys","video":false,"overview":"A family battles against the odds to stay together when small lies grow into an extravagant cover-up. In order to avoid hardship and responsibilities that would otherwise be impossible to endure, the family chooses to ignore the truth, not to see, hear or talk about it. But does playing “Three Monkeys” invalidate the truth of its existence?","genre_ids":[18,53],"media_type":"movie","popularity":0.9466,"vote_count":219,"poster_path":"/tyIKP8SSTkw9xEXAG9lj5jEnIfW.jpg","release_date":"2008-05-16","vote_average":6.792,"backdrop_path":"/tD7zvUWcx6Uw54GiE0xzpGK15pT.jpg","original_title":"Üç maymun","original_language":"tr"},{"id":8319,"adult":false,"title":"Chapter 27","video":false,"overview":"A film about Mark David Chapman in the days leading up to the infamous murder of Beatle John Lennon.","genre_ids":[18,80],"media_type":"movie","popularity":0.9175,"vote_count":271,"poster_path":"/mvjreS7Mgz13IkyhmWNCiEbmhlh.jpg","release_date":"2007-01-25","vote_average":5.4,"backdrop_path":"/6TCkbdywBFuTSmih31awDSCCHss.jpg","original_title":"Chapter 27","original_language":"en"},{"id":474444,"adult":false,"title":"The Wild Boys","video":false,"overview":"Island of La Réunion, in the beginning of the 20th century. Five teenagers commit a savage crime. As punishment, a Dutch captain takes them to a supernatural island with luxuriant vegetation and bewitching powers.","genre_ids":[18,12,14],"media_type":"movie","popularity":0.5644,"vote_count":169,"poster_path":"/m1W1JFnlNwtEr99SYclKYhORMXQ.jpg","release_date":"2017-06-13","vote_average":6.503,"backdrop_path":"/zAdnO2Ju3IALOruGiHRco1ik1jx.jpg","original_title":"Les Garçons sauvages","original_language":"fr"}],"similar_content":[{"id":164,"adult":false,"title":"Breakfast at Tiffany's","video":false,"overview":"Holly Golightly is an eccentric New York City playgirl determined to marry a Brazilian millionaire. But when young writer Paul Varjak moves into her apartment building, her past threatens to get in their way.","genre_ids":[35,10749,18],"popularity":4.1802,"vote_count":4421,"poster_path":"/79xm4gXw4l7A5D0XukUOJRocFYQ.jpg","release_date":"1961-10-06","vote_average":7.626,"backdrop_path":"/jXZ2tyJl44yKvh22I6ooQwU5rFM.jpg","original_title":"Breakfast at Tiffany's","original_language":"en"},{"id":192,"adult":false,"title":"The Name of the Rose","video":false,"overview":"14th-century Franciscan monk William of Baskerville and his young novice arrive at a conference to find that several monks have been murdered under mysterious circumstances. To solve the crimes, William must rise up against the Church's authority and fight the shadowy conspiracy of monastery monks using only his intelligence; which is considerable.","genre_ids":[18,53,9648],"popularity":3.342,"vote_count":3249,"poster_path":"/d6dlbTBb3N7nXDz7tQslDJs2jgv.jpg","release_date":"1986-09-24","vote_average":7.491,"backdrop_path":"/v4d6PPfqHeUNSdcyBVQ2Xb8yBk0.jpg","original_title":"The Name of the Rose","original_language":"en"},{"id":763893,"adult":false,"title":"Three Blades","video":false,"overview":"One family, three men, three generations, all living together with their contrasting aspirations, within the contradictions of daily life in southern Haïti. Tensions mount between them, their ever-present machetes on-hand, defining them.","genre_ids":[18],"popularity":0.422,"vote_count":1,"poster_path":"/58vnB3kmLdwKrzVvausyuuaSkxB.jpg","release_date":"2019-01-24","vote_average":5,"backdrop_path":null,"original_title":"Trois machettes","original_language":"ht"},{"id":665,"adult":false,"title":"Ben-Hur","video":false,"overview":"In 26 AD, Judah Ben-Hur, a Jew in ancient Judea, opposes the occupying Roman empire.  Falsely accused by a Roman childhood friend-turned-overlord of trying to kill the Roman governor, he is put into slavery and his mother and sister are taken away as prisoners.","genre_ids":[36,18,12],"popularity":9.7246,"vote_count":3041,"poster_path":"/m4WQ1dBIrEIHZNCoAjdpxwSKWyH.jpg","release_date":"1959-11-18","vote_average":7.882,"backdrop_path":"/sU3gFo7Gn67zjtKXIvzJ4omcUbH.jpg","original_title":"Ben-Hur","original_language":"en"},{"id":686,"adult":false,"title":"Contact","video":false,"overview":"A radio astronomer receives the first extraterrestrial radio signal ever picked up on Earth. As the world powers scramble to decipher the message and decide upon a course of action, she must make some difficult decisions between her beliefs, the truth, and reality.","genre_ids":[18,878,9648],"popularity":8.3408,"vote_count":4861,"poster_path":"/bCpMIywuNZeWt3i5UMLEIc0VSwM.jpg","release_date":"1997-07-11","vote_average":7.438,"backdrop_path":"/yFkUPqBuUnbhYbQL8VFpTrAT9za.jpg","original_title":"Contact","original_language":"en"},{"id":696,"adult":false,"title":"Manhattan","video":false,"overview":"Manhattan explores how the life of a middle-aged television writer dating a teenage girl is further complicated when he falls in love with his best friend's mistress.","genre_ids":[35,18,10749],"popularity":3.3444,"vote_count":2566,"poster_path":"/k4eT3EvfxW1L9Wmt04UqJqCvCR6.jpg","release_date":"1979-04-25","vote_average":7.718,"backdrop_path":"/adnSTomHU9YyqV2lx38CgM0UxLS.jpg","original_title":"Manhattan","original_language":"en"},{"id":2014,"adult":false,"title":"The Edge of Heaven","video":false,"overview":"The lives of six German-Turkish immigrants are drawn together by circumstance: An old man and a prostitute forging a partnership, a young scholar reconciling his past, two young women falling in love, and a mother putting the shattered pieces of her life back together.","genre_ids":[18],"popularity":0.8825,"vote_count":347,"poster_path":"/kqhVVpXFtOotSlK0npVaBHXUqxV.jpg","release_date":"2007-09-27","vote_average":7.222,"backdrop_path":"/s3kGgVwM946SWj3iXShDbeJALiT.jpg","original_title":"Auf der anderen Seite","original_language":"de"},{"id":1126133,"adult":false,"title":"Harlot's Prayer","video":false,"overview":"Kiran, a Muslim woman, loses her faith and falls into promiscuity after a hard-line Islamic organization, meant to strengthen her faith, ends up depriving her of it.","genre_ids":[18,53],"popularity":0.2518,"vote_count":7,"poster_path":"/yoFM29YBj4O6nGhwP046TQChoen.jpg","release_date":"2024-05-22","vote_average":7.429,"backdrop_path":"/wsP4Ro0EewUPB0ofhERmQWMxBki.jpg","original_title":"Tuhan, Izinkan Aku Berdosa","original_language":"id"},{"id":780,"adult":false,"title":"The Passion of Joan of Arc","video":false,"overview":"A classic of the silent age, this film tells the story of the doomed but ultimately canonized 15th-century teenage warrior. On trial for claiming she'd spoken to God, Jeanne d'Arc is subjected to inhumane treatment and scare tactics at the hands of church court officials. Initially bullied into changing her story, Jeanne eventually opts for what she sees as the truth. Her punishment, a famously brutal execution, earns her perpetual martyrdom.","genre_ids":[18,36],"popularity":1.3469,"vote_count":1060,"poster_path":"/tAgV9yxY6AC1bsPt3qJJQpD4s8.jpg","release_date":"1928-04-21","vote_average":7.99,"backdrop_path":"/cFgCf2XqnhErS3HmgSOBCe4kL4d.jpg","original_title":"La Passion de Jeanne d'Arc","original_language":"fr"},{"id":249660,"adult":false,"title":"God's Not Dead","video":false,"overview":"After he refuses to disavow his faith, a devout Christian student must prove the existence of God or else his college philosophy professor will fail him.","genre_ids":[18],"popularity":1.9006,"vote_count":949,"poster_path":"/yKUzBolWrwyByevBtDPfy3kIumv.jpg","release_date":"2014-03-21","vote_average":5.988,"backdrop_path":"/8pl2t8FvYHHEAT6ly8YtJJWd1bn.jpg","original_title":"God's Not Dead","original_language":"en"},{"id":421749,"adult":false,"title":"Pope John Paul II","video":false,"overview":"Bio-drama tracing the life and career of Polish cardinal Karol Wojtyla from his days as a young activist in Poland to his rise and installation in 1978 as Pope of the Catholic world.","genre_ids":[18,36,10770],"popularity":0.3313,"vote_count":4,"poster_path":"/ApjFk8LbmUBLGqmfg3FS5ctJvqV.jpg","release_date":"1984-04-22","vote_average":6.9,"backdrop_path":"/7bU7ip4cRpuOq1cebcm0z5c3nwP.jpg","original_title":"Pope John Paul II","original_language":"en"},{"id":251736,"adult":false,"title":"Listen Up Philip","video":false,"overview":"Anger rages in Philip as he awaits the publication of his second novel. He feels pushed out of his adopted home city by the constant crowds and noise, a deteriorating relationship with his photographer girlfriend Ashley, and his own indifference to promoting the novel. When Philip's idol Ike Zimmerman offers his isolated summer home as a refuge, he finally gets the peace and quiet to focus on his favorite subject: himself.","genre_ids":[35,18],"popularity":1.0161,"vote_count":153,"poster_path":"/rHfrGEdTEW20W6L26qbJ0DFNDKo.jpg","release_date":"2014-10-17","vote_average":5.859,"backdrop_path":"/yuDDViMJppRKiDXTGXpHdofhkgx.jpg","original_title":"Listen Up Philip","original_language":"en"},{"id":824,"adult":false,"title":"Moulin Rouge!","video":false,"overview":"A celebration of love and creative inspiration takes place in the infamous, gaudy and glamorous Parisian nightclub, at the cusp of the 20th century. A young poet, who is plunged into the heady world of Moulin Rouge, begins a passionate affair with the club's most notorious and beautiful star.","genre_ids":[18,10749,10402],"popularity":5.0024,"vote_count":4769,"poster_path":"/2kjM5CUZRIU5yOANUowrbJcRL9L.jpg","release_date":"2001-05-18","vote_average":7.536,"backdrop_path":"/vvcLSgiviCIU0J0UcwLqWdU8Iup.jpg","original_title":"Moulin Rouge!","original_language":"en"},{"id":445,"adult":false,"title":"Caché","video":false,"overview":"George, host of a television show focusing on literature, receives videos shot on the sly that feature his family, along with disturbing drawings that are difficult to interpret. He has no idea who has made and sent him the videos. Progressively, the contents of the videos become more personal, indicating that the sender has known George for a long time.","genre_ids":[9648,18,53],"popularity":1.931,"vote_count":1221,"poster_path":"/vTzjRi0Uhy0tt3Rjw8SARZZJHlX.jpg","release_date":"2005-10-05","vote_average":7.039,"backdrop_path":"/mOYIUiSdoLWynoZIGDZSAAUZ3ss.jpg","original_title":"Caché","original_language":"fr"},{"id":261,"adult":false,"title":"Cat on a Hot Tin Roof","video":false,"overview":"An alcoholic ex-football player drinks his days away, having failed to come to terms with his sexuality and his real feelings for his football buddy who died after an ambiguous accident. His wife is crucified by her desperation to make him desire her: but he resists the affections of his wife. His reunion with his father—who is dying of cancer—jogs a host of memories and revelations for both father and son.","genre_ids":[18],"popularity":1.4832,"vote_count":818,"poster_path":"/5djZZECgqDGuSI1INmrdAcGRBb0.jpg","release_date":"1958-08-29","vote_average":7.629,"backdrop_path":"/3Yz8IcUBPZ8zDff0ktHZk24Rot0.jpg","original_title":"Cat on a Hot Tin Roof","original_language":"en"},{"id":276,"adult":false,"title":"The Edukators","video":false,"overview":"Three activists cobble together a kidnapping plot after they encounter a businessman in his home.","genre_ids":[18,35],"popularity":1.1937,"vote_count":371,"poster_path":"/jpiXFtvBYemLbAktLPNx5xDGvJn.jpg","release_date":"2004-10-25","vote_average":7.155,"backdrop_path":"/whgmJ6vRE7o8zszh60kicT1vVSy.jpg","original_title":"Die fetten Jahre sind vorbei","original_language":"de"},{"id":16878,"adult":false,"title":"Saving God","video":false,"overview":"Ex Con Armstrong Cane (Ving Rhames) returns to home a changed man looking to take over his father's old church and congregation. The neighborhood though is full of drugs and gangs. Those who are able are leaving for more prosperous areas and falling in with a slick preacher (Ricardo Chivara). Even with a dangerous gang leader (Dean McDermott) threatening his flock, Armstrong won't give up.","genre_ids":[80,18],"popularity":0.834,"vote_count":20,"poster_path":"/q16Hoe5oqE9rRxakSzNikqFvy3P.jpg","release_date":"2008-10-14","vote_average":5.3,"backdrop_path":null,"original_title":"Saving God","original_language":"en"},{"id":15450,"adult":false,"title":"Tyler Perry's The Family That Preys","video":false,"overview":"Wealthy socialite Charlotte Cartwright and her dear friend Alice Pratt, a working class woman of high ideals, have enjoyed a lasting friendship throughout several decades. Recently, their lives have become mired in turmoil as their adult children’s extramarital affairs, unethical business practices, and a dark secret threaten to derail family fortunes and unravel the lives of all involved. Charlotte and Alice decide to take a breather from it all by making a cross-country road trip in which they rediscover themselves and possibly find a way to save their families from ruin.","genre_ids":[18,10749],"popularity":1.4791,"vote_count":90,"poster_path":"/2iztlY0BvlDa0HZkMnI4PlPrswd.jpg","release_date":"2008-09-12","vote_average":6.7,"backdrop_path":"/7FVuYMbCVIa32yMhrGmnaPAUYpJ.jpg","original_title":"Tyler Perry's The Family That Preys","original_language":"en"},{"id":16229,"adult":false,"title":"Prozac Nation","video":false,"overview":"When talented young writer Elizabeth Wurtzel earns a scholarship to Harvard, she sees it as her chance to escape the pressures of her working-class background and concentrate on her true talent. But what starts out so promising leads to self-destructive behavior and paralyzing depression that reflects an entire generation's struggle to navigate the effects of divorce, drugs, sex, and high expectations.","genre_ids":[18,10749],"popularity":1.0596,"vote_count":329,"poster_path":"/4QB1h6mxlmQVM8BtYMybTwL2foc.jpg","release_date":"2003-06-13","vote_average":6.324,"backdrop_path":"/j06D4plPJNP1s0h3FKB8qwGRGpW.jpg","original_title":"Prozac Nation","original_language":"en"},{"id":16351,"adult":false,"title":"Ararat","video":false,"overview":"Interrogated by a customs officer, a young man recounts how his life was changed during the making of a film about the Armenian genocide.","genre_ids":[18,10752,36],"popularity":4.3049,"vote_count":93,"poster_path":"/kQkn715VQYLIs2nddAUf19Bz5Wj.jpg","release_date":"2002-05-20","vote_average":6.1,"backdrop_path":"/xJZmoX5r5zcvJNbeqBGgdizC0d9.jpg","original_title":"Ararat","original_language":"en"}],"external_ids":{"imdb_id":"tt6628102","twitter_id":null,"facebook_id":"","wikidata_id":"Q31193168","instagram_id":"","metacritic_id":"movie/the-wild-pear-tree","mydramalist_id":"311058","rotten_tomatoes_id":"m/the_wild_pear_tree"},"social_ids":{"twitter":null,"facebook":"","instagram":""},"gdvg_id":110988,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"CA","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2018-11-30T00:00:00.000Z","certification":""}]},{"iso_3166_1":"DE","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2020-06-18T00:00:00.000Z","certification":"6"}]},{"iso_3166_1":"DK","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2019-05-16T00:00:00.000Z","certification":""}]},{"iso_3166_1":"ES","release_dates":[{"note":"","type":3,"iso_639_1":"es","descriptors":[],"release_date":"2019-08-02T00:00:00.000Z","certification":""}]},{"iso_3166_1":"FR","release_dates":[{"note":"Festival de Cannes","type":1,"iso_639_1":"","descriptors":[],"