"zh","vote_average":1.75},{"width":1123,"height":1600,"file_path":"/d1499JewZjwbf24CRPLKFKGmQuS.jpg","iso_639_1":"zh","vote_average":1.75},{"width":1080,"height":1620,"file_path":"/uwB0yTkLEM8gENuXxHtkYaG3HEx.jpg","iso_639_1":"en","vote_average":1.75},{"width":2000,"height":3000,"file_path":"/3M61K1OavfcCJY6XQkSamW7qxYw.jpg","iso_639_1":"zh","vote_average":1.75},{"width":1080,"height":1620,"file_path":"/m1GbjGnv2x3A9d6jxRaXZjvalo9.jpg","iso_639_1":"en","vote_average":0.166},{"width":2000,"height":3000,"file_path":"/w6IUyaGxRxroQvCqqeZpz4V9dgt.jpg","iso_639_1":"zh","vote_average":0.166},{"width":1152,"height":1728,"file_path":"/35tMfBHYOV7HMfKuzPgbp5DtNiO.jpg","iso_639_1":"pt","vote_average":0.166},{"width":1434,"height":2048,"file_path":"/xBJF7eSZ8PbvULXTHZVdHpqB7cJ.jpg","iso_639_1":"zh","vote_average":0},{"width":2000,"height":3000,"file_path":"/1MTU98BWcJ53qHjtpJ9wTwd3YxQ.jpg","iso_639_1":"zh","vote_average":0},{"width":2000,"height":2979,"file_path":"/2LyuWRgvXs5vWAqz23I8DE7hBHf.jpg","iso_639_1":"vi","vote_average":0},{"width":2000,"height":2847,"file_path":"/rhmu8ePA306X8ooQrcA195nBgsg.jpg","iso_639_1":"zh","vote_average":0}],"backdrops":[{"width":2048,"height":1152,"file_path":"/lAtuFCx6cYkNBmTMSNnLE0qlCLx.jpg","iso_639_1":null,"vote_average":3.334},{"width":2048,"height":1152,"file_path":"/jpbFGX79CEFvtV7Xn7Urn0iGY0b.jpg","iso_639_1":null,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/dy8IFyfuaZoL5vWEXCoj0Uqafro.jpg","iso_639_1":null,"vote_average":1.75},{"width":2171,"height":1221,"file_path":"/m1CaWCU35gS7DkUDSCJAMbExm85.jpg","iso_639_1":"zh","vote_average":0},{"width":2271,"height":1277,"file_path":"/dOfjxTxOPkx9iN9R3sPNBN3pgIn.jpg","iso_639_1":"zh","vote_average":0},{"width":1600,"height":900,"file_path":"/r1fgAwOytdkm0dyMPXLDPqa6guU.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/aRM8Y1m2OOqpK6AMUJH9L5xHwfh.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/7VTQphn3NN1ANL0cdQdRbqVwCok.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/dZpnAkiDfOXheFkvIwDFXEzhjeX.jpg","iso_639_1":null,"vote_average":0},{"width":2271,"height":1277,"file_path":"/sdNXWspaW9zs39EOT9Z6kXZNOAp.jpg","iso_639_1":"zh","vote_average":0}]},"enriched_at":"2026-04-21T02:30:18.102+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":117,"tagline":"每秒鐘 生存倒數 。每分鐘 人性抉擇","homepage":"https://linkgoods.com/wowingmovie","overview":"前拆彈專家宋康任與未婚妻黃欣搭上一台被放置炸彈的高鐵。與此同時，陷入外遇醜聞的知名物理補習班老師劉楷，為了追回搭乘上一班高鐵負氣返鄉的妻子婷娟，也搭上了這班炸彈列車…究竟，這次能夠順利地拆除炸彈嗎？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"96 Minutes","runtime":117,"tagline":"","homepage":"","overview":"Former bomb disposal expert, Song Kang-Ren, and his fiancée, Huang Xin, board a high-speed train that contains a bomb. At the same time, Liu Kai, a well-known physics teacher who was involved in an affair scandal, also boards this same train in order to win back his wife, Ting Juan, who took the prior high-speed rail to return home in frustration…  After all, can the bomb be successfully defused this time? and resolve the crisis?"},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"96分钟：列车爆炸案","runtime":0,"tagline":"","homepage":"","overview":"前拆弹专家和他的未婚妻登上装有炸弹的高铁，卷入外遇丑闻的物理老师，也为了挽回乘坐高铁的妻子，登上了这趟列车。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"96분","runtime":118,"tagline":"","homepage":"","overview":"타이베이에서 가오슝까지 단 96분 만에 도달하는 고속열차. 그 열차에 전직 폭탄 처리반 장교 캉런과 그의 약혼녀가 타고 있다. 그들은 3년 전의 대형 쇼핑몰 폭발 사고 피해자 추도식에 참석한 뒤 돌아가는 중이다. 그 사건에서 모두를 구하지 못했다는 죄책감에 캉런은 일을 그만두었고 복귀하라는 상관의 요청도 거절해 왔다. 하지만 그들이 탄 열차에 폭탄이 설치되어 있다는 경고를 접하고 멈출 수 없는 속도로 질주하는 열차에서 그는 다시 폭탄과 맞서야 하는 상황에 마주한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"⼀場震驚全台的炸彈攻擊案，以無辜死傷的悲劇收場，拆彈專家宋康任（林柏宏 飾）從此⼀蹶不振、退出前線。三年後，他與刑警妻⼦黃欣（宋芸樺 飾）搭上台北直達⾼雄、僅需96分鐘的⾼鐵列⾞，卻在途中接獲前上司李傑（李李仁 飾）傳來的警告──列⾞上藏有炸彈！\r 為挽回婚姻，物理補教名師劉楷（王柏傑 飾）也搭上這班列⾞，同⾞乘客還有昔⽇爆炸案罹難者的家屬、準備求婚的戀⼈、返鄉的⽣意⼈⋯⋯全都被捲入這場突如其來的死亡危機。\r 列⾞⼀路往南疾駛，時間緊迫倒數。宋康任不僅必須在96分鐘內找出炸彈、解除危機，更要直視⾃⼰深埋⼼底、不可告⼈的秘密。在雙重壓⼒逼迫下，他能否成功拯救所有⼈的性命？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"96 Minutos","runtime":0,"tagline":"","homepage":"","overview":"Un experto en bombas y su prometida suben a un tren que contiene explosivos, mientras un profesor de física envuelto en un escándalo toma el mismo tren con la esperanza de reconciliarse con su esposa, quien partió en un tren anterior."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"96 Minutos","runtime":120,"tagline":"","homepage":"","overview":"Un experto en bombas y su prometida suben a un tren que contiene explosivos, mientras un profesor de física envuelto en un escándalo toma el mismo tren con la esperanza de reconciliarse con su esposa, quien partió en un tren anterior."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"96 Phút Sinh Tử","runtime":119,"tagline":"Một Giây Chậm, Trăm Mạng Mất.","homepage":"","overview":"Ba năm sau thảm kịch tại trung tâm mua sắm, trên chuyến tàu cao tốc định mệnh, nữ cảnh sát Huỳnh Hân (Tống Vân Hoa) và chồng cô là cựu chuyên gia gỡ bom - Tống Khang Nhân (Lâm Bách Hoành), cùng đội trưởng Lý Kiệt (Lý Lý Nhân) bất ngờ nhận được tin nhắn thông báo một quả bom đã được cài sẵn trên tàu. Vụ việc lần này còn phức tạp hơn khi kẻ khủng bố dường tính toán vô cùng tinh vi. Khi thời gian cạn dần, Tống Khang Nhân buộc phải ngăn thảm kịch xảy ra bằng mọi giá, đồng thời đối mặt với những ám ảnh kinh hoàng từ vụ nổ năm xưa."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"96 นาทีชีวิต","runtime":0,"tagline":"","homepage":"","overview":"ชายคนหนึ่งขึ้นรถไฟด่วนความเร็วสูงที่มีระเบิดติดตั้งอยู่ ทำให้เขาต้องเร่งหาทางกู้ระเบิดและรักษาชีวิตผู้โดยสารที่ติดอยู่บนรถไฟขบวนนี้"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"96 Minutos","runtime":120,"tagline":"","homepage":"","overview":"Um especialista em bombas embarca com sua noiva em um trem contendo explosivos, enquanto um professor de física assolado por escândalos pega o mesmo trem na esperança de se reconciliar com sua esposa, que partiu em um trem anterior."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"96 Minutes","runtime":0,"tagline":"","homepage":"","overview":"Après avoir embarqué dans un train à grande vitesse piégé, un homme mène une course contre la montre désespérée pour désamorcer une bombe et sauver la vie des passagers."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"96 минут","runtime":0,"tagline":"","homepage":"","overview":"Бывший сапер Сун Кан Жэнь и его невеста Хуан Синь оказываются в высокоскоростном поезде с заложенной бомбой. К ним в ловушку попадает и учитель физики Лю Кай, который сел на этот поезд, чтобы помириться с женой после скандала с изменой."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"96 دقيقة","runtime":0,"tagline":"","homepage":"","overview":"حين يستقل رجل قطارًا سريعًا مفخخًا بالمتفجرات، يتعين عليه أن يسابق الزمن لتعطيلها وإنقاذ أرواح الركاب الموجودين على متن القطار."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"96 دقيقة","runtime":0,"tagline":"","homepage":"","overview":"تدور أحداث الفيلم حول سونغ كانغ رين، خبير سابق في تفكيك القنابل، وخطيبته هوانغ شين، اللذين يستقلان قطارًا فائق السرعة ليتبيّن أنه يحتوي على قنبلة. وفي الوقت نفسه، يصعد إلى القطار نفسه ليو كاي، مدرس فيزياء معروف تورّط في فضيحة علاقة عاطفية، في محاولة يائسة لاستعادة زوجته تينغ جوان التي سبقته إلى مسقط رأسها غاضبة. ومع تصاعد التوتر وضيق الوقت، يبقى السؤال: هل يمكن تفكيك القنبلة بنجاح وإنهاء هذه الأزمة قبل فوات الأوان؟"},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"96 دقیقه","runtime":0,"tagline":"","homepage":"","overview":"یک کارشناس بمب و نامزدش سوار قطاری می‌شوند که مواد منفجره دارد، در حالی که یک معلم فیزیک که رسوایی‌ها را به هم می‌زند، به امید آشتی با همسرش که با قطار قبلی رفته بود، سوار همان قطار می‌شود."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[],"external_ids":{"imdb_id":"tt34381460","twitter_id":null,"facebook_id":"96minutes.mit","wikidata_id":"Q136230962","instagram_id":"96minutes.mit"},"social_ids":{"twitter":null,"facebook":"96minutes.mit","instagram":"96minutes.mit"},"gdvg_id":103588,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"CN","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2026-01-10T00:00:00.000Z","certification":""}]},{"iso_3166_1":"HK","release_dates":[{"note":"","type":2,"iso_639_1":"","descriptors":[],"release_date":"2025-10-29T00:00:00.000Z","certification":""},{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-10-30T00:00:00.000Z","certification":""}]},{"iso_3166_1":"JP","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2026-03-13T00:00:00.000Z","certification":""}]},{"iso_3166_1":"KR","release_dates":[{"note":"Bucheon International Fantastic Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-07-07T00:00:00.000Z","certification":"12"}]},{"iso_3166_1":"SG","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-09-25T00:00:00.000Z","certification":"NC16"}]},{"iso_3166_1":"TW","release_dates":[{"note":"Taipei Film Festival","t