5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Tae Guk Gi: The Brotherhood of War\",\"description\":\"When two brothers are forced to fight in the Korean War, the elder decides to take the riskiest missions if it will help shield the younger from battle.\",\"image\":\"https://image.tmdb.org/t/p/w500/vyG8qpimh3XSlxc6OmPq8LJRJl.jpg\",\"datePublished\":\"2004-02-05\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"action fiction\",\"drama film\",\"drama fiction\",\"historical film\",\"war film\",\"Action\",\"Adventure\",\"Drama\",\"History\",\"War\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.983,\"bestRating\":10,\"ratingCount\":753}}"}}],["$","$L10",null,{"initialDrama":{"id":"9a03ce0e-8f79-4863-95a7-d69136280765","tmdb_id":11658,"imdb_id":"tt0386064","content_type":"movie","title":"Tae Guk Gi: The Brotherhood of War","original_title":"태극기 휘날리며","overview":"When two brothers are forced to fight in the Korean War, the elder decides to take the riskiest missions if it will help shield the younger from battle.","poster_path":"/vyG8qpimh3XSlxc6OmPq8LJRJl.jpg","backdrop_path":"/oqaKsofz49zjNhi48sxQIq8U73X.jpg","release_date":"2004-02-05","first_air_date":null,"status":"published","original_language":"ko","origin_country":["KR"],"genres":[{"name":"action fiction"},{"name":"drama film"},{"name":"drama fiction"},{"name":"historical film"},{"name":"war film"},{"id":28,"name":"Action"},{"id":12,"name":"Adventure"},{"id":18,"name":"Drama"},{"id":36,"name":"History"},{"id":10752,"name":"War"}],"popularity":1.7102,"vote_average":7.983,"vote_count":753,"runtime":148,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:50:31.430506+00:00","updated_at":"2026-02-21T16:03:07.242+00:00","tagline":"One country, one family… divided by war.","homepage":null,"budget":1500000,"revenue":0,"pro