_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3000,"height":1688,"file_path":"/vLmjdtV3Ss24ovBkjDZVILOD1eX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1920,"height":1080,"file_path":"/j0I2mqhqkMsPf96jxMYCiLvnweD.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/pQtv70zmpEs6VTP7CymqApNJsf1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2399,"height":1349,"file_path":"/kHXblysahey0anR3M2dYoYw51FD.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2500,"height":1406,"file_path":"/xhhC1BadLhgDgtlHfeCk8jxK9Ct.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/oyDd7VWgfL0CF2UwaorBlq0m8Ie.jpg","iso_639_1":"zh","iso_3166_1":"HK","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3200,"height":1800,"file_path":"/fnWJNbTKeox6fuxg8tuzeAupDP7.jpg","iso_639_1":"zh","iso_3166_1":"HK","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2596,"height":1460,"file_path":"/wPIl7g3ZHJ7X4ioRjMk5Lc8AAnb.jpg","iso_639_1":"zh","iso_3166_1":"HK","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-09T08:45:40.764+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Raging Fire","runtime":125,"tagline":"","homepage":"https://www.wellgousa.com/films/raging-fire","overview":"Cheung Sung-bong is a highly respected cop with a long history of success in dangerous cases. However, his past soon comes back to haunt him when a former protégé resurfaces, seeking revenge."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Raging Fire","runtime":123,"tagline":"Ce jour-là, nous sommes devenus ennemis","homepage":"","overview":"Cheung Tit-shan est un policier vertueux qui est admiré par la police pour avoir résolu de nombreux cas. Un jour, son passé revient le hanter lorsque son opération est attaquée par un mystérieux groupe de criminels dirigé par Yau Kong-ngo, son ancien protégé. Ngo était autrefois un policier talentueux qui admirait et respectait Shan. Cependant, un terrible accident l'a envoyé en prison il y a trois ans, le transformant en un homme furieux dans le but de tuer tous ceux qui lui ont fait du tort, y compris son ancien mentor."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Перекрёстный огонь","runtime":126,"tagline":"","homepage":"","overview":"Честный и принципиальный полицейский Бон отказывается прогнуться под начальство и пойти на сделку с совестью, из-за чего его команду не берут на спецоперацию по захвату давно разыскиваемого преступника. Но на месте появляется банда неизвестных в масках и убивает почти всех копов, в том числе начальника Бона. Оказывается, бывший полицейский Нго, некогда подававший большие надежды, вышел из тюрьмы и теперь жаждет расквитаться со всеми, из-за кого его жизнь пошла наперекосяк."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Raging Fire","runtime":126,"tagline":"","homepage":"","overview":"Shan \"Donnie YEN\" is een rechtvaardige politieagent die door de politie wordt bewonderd omdat hij veel zaken heeft opgelost. Op een dag komt zijn verleden terug om hem te achtervolgen wanneer zijn geheime operatie wordt aangevallen door een mysterieuze groep criminelen onder leiding van Ngo \"Nicholas TSE\", zijn voormalige protégé. Ngo was ooit een getalenteerde agent die Shan bewonderde en respecteerde. Drie jaar geleden belandde hij echter door een vreselijk ongeluk in de gevangenis, waardoor hij een woedende man werd met als doel iedereen te vermoorden die hem onrecht aandeed, inclusief zijn voormalige mentor."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"怒火","runtime":0,"tagline":"","homepage":"","overview":"重案組警察張崇邦（甄子丹飾）在圍剿國際毒梟時，遇上了一幫「黑吃黑」的蒙面悍匪，冷血屠殺警察。面對員警慘死，張崇邦努力追查悍匪行蹤，驚訝發現首領竟是昔日戰友邱剛敖（謝霆鋒飾）。原來邱剛敖曾是警隊的明日之星，他與張崇邦更是亦師亦友的警隊夥伴，而宿命讓二人再次面對往日的恩怨情仇，他們將如何作出了斷……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"怒火·重案","runtime":128,"tagline":"","homepage":"","overview":"香港動作殿堂級導演陳木勝最後遺作，傾力執導心血結晶，甄子丹與謝霆鋒上演世紀大戰  重案組警察張崇邦（甄子丹飾）在圍剿國際毒梟時，遇上了一幫「黑吃黑」的蒙面悍匪，冷血屠殺警察。面對員警慘死，張崇邦努力追查悍匪行蹤，驚訝發現首領竟是昔日戰友邱剛敖（謝霆鋒飾）。原來邱剛敖曾是警隊的明日之星，他與張崇邦更是亦師亦友的警隊夥伴，而宿命讓二人再次面對往日的恩怨情仇，他們將如何作出了斷……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Raging Fire","runtime":126,"tagline":"","homepage":"","overview":""},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"怒火","runtime":126,"tagline":"","homepage":"","overview":"警方佈下天羅地網圍捕毒梟，千鈞一髮間，竟殺出一群蒙面神祕悍匪「黑吃黑」！不但劫走毒品，更屠殺在場眾警！重案組督察張祟邦（甄子丹 飾）來遲一步，親睹屍橫遍野，悲憤交雜。連夜調查下，發現驚人消息，跨國販毒集團背後的殺警辣手，竟是昔日同袍邱剛敖（謝霆鋒 飾）！疤痕背後，原來敖曾是警隊明日之星，而當日將敖推入罪惡深淵的人，卻正是邦！命運無情，宿命再次糾纏；一切恩怨，是時候來個了斷……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Raging Fire","runtime":126,"tagline":"","homepage":"","overview":"Cheung Sung-bong (Donnie Yen) ist ein rechtschaffener Polizist, der von seiner Behörde dafür bewundert wird, viele Fälle gelöst zu haben. Eines Tages holt ihn seine Vergangenheit ein, als sein Einsatz von einer mysteriösen Gruppe Krimineller, angeführt von seinem ehemaligen Schützling Yau Kong-Ngo (Nicholas Tse), angegriffen wird. Yau Kong-Ngo war einst ein talentierter Polizist, der Cheung bewunderte und respektierte. Doch ein schrecklicher Unfall, der ihn vor drei Jahren ins Gefängnis brachte, verwandelte ihn in einen wütenden Mann mit dem Ziel, jeden zu töten, der ihm Unrecht getan hat – einschließlich seines ehemaligen Mentors."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Raging Fire","runtime":128,"tagline":"Bir dedektifin sınavı başlıyor","homepage":"","overview":"Hong Kong polisi içinde geçen çatışmalar ve ihanet temalarını işlerken, izleyicilere yoğun bir gerilim sunmaktadır. Hikâye, eski bir polis memuru olan ve şimdi bir dedektif olarak görev yapan Chan etrafında döner. Chan, geçmişteki bir operasyon sırasında birlikte çalıştığı bir grup polisin, bir suç çetesi tarafından hedef alındığını öğrenir. Bu durum, Chan'ı hem mesleki hem de kişisel bir mücadeleye sürükler. Eski dostlarıyla yüzleşmek zorunda kalırken, aynı zamanda kendi karanlık geçmişiyle de hesaplaşmak zorundadır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Shan adalah seorang polisi yang diharapkan untuk menjajah sekelompok penjahat misterius.  Kelompok penjahat misterius tersebut ternyata dipimpin oleh Ngo, yang merupakan salah satu anak didiknya di kepolisian yang pernah menghormati dan mengaguminya.  Tapi Ngo telah berubah, sebuah kecelakaan mengerikan mengirimnya ke penjara tiga tahun yang lalu.  Setelah 3 tahun di penjara, muncul dengan dendam mengakar dan misi untuk menghancurkan semua orang yang pernah berbuat salah padanya —- termasuk mentornya — -."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"Frente à Frente","runtime":126,"tagline":"","homepage":"","overview":"Shan é um policial justo que é admirado pelos companheiros por ter resolvido muitos casos. Um dia, seu passado volta para assombrá-lo quando sua operação policial é atacada por um misterioso grupo de criminosos liderados por Ngo, seu ex-protegido. Ngo já foi um policial talentoso que admirava e respeitava Shan. No entanto, um terrível acidente o levou à prisão há três anos, transformando-o em um homem furioso, com o objetivo de matar todos que o prejudicaram – incluindo seu ex-mentor."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Nộ Hỏa: Trọng Án","runtime":0,"tagline":"","homepage":"","overview":"Raging Fire xoay quanh nhân vật Trương Tuý Bang (Chân Tử Đan), một cảnh sát được kính trọng và có bề dày thành tích trong nhiều vụ trọng án. Trong khi cùng đồng đội tiến hành đột kích, vây bắt một tay trùm ma tuý, nhóm cảnh sát đã chạm trán với một băng nhóm tội phạm bịt mặt và tất cả đã bị sát hại ngay tại đó. Khi Trương Tuý Bang tiến hành điều tra, anh nhận ra kẻ đứng đằng sau âm mưu này chính là Cương Ngao (Tạ Đình Phong), người từng là đồng đội của anh.Cương Ngao trước đây cũng là một cảnh sát tài năng, người từng kính trọng và ngưỡng mộ Trương Tuý Bang. Tuy nhiên, một sai lầm từ ba năm trước đã khiến anh phải ngồi tù. Trong suốt quá trình đó, Cương Ngao đã dần trở thành một kẻ giận dữ, với sự hận thù và bắt đầu lên kế hoạch tiêu diệt tất cả những kẻ khiến anh ta rơi xuống vực sâu, bao gồm cả Trương Tuý Bang."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"레이징 파이어","runtime":126,"tagline":"그날, 우리는 적이 되었다","homepage":"","overview":"강력 범죄 수사대에서 함께 믿고 일하던 베테랑 경찰 `장충방`과 그의 후배 `추강아오`.  어느 날 같은 임무를 맡은 두 사람은 돌이킬 수 없는 사건으로 인해 한순간에 운명이 뒤바뀌게 되고 동료에서 적이 되어버린다. 서로가 서로의 표적이 된 그들은 피할 수 없는 대결을 시작하게 되는데…. 둘 중 하나는 죽어야 끝난다!"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Tomboló tűz","runtime":0,"tagline":"","homepage":"","overview":"Shan sikeres zsaru, aki karrierje során számos rejtélyt oldott meg. Egy nap azonban visszatérnek a múlt árnyai, amikor egy régi bűnbanda bukkan fel ismét a színen."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Cara a Cara (Raging Fire)","runtime":126,"tagline":"","homepage":"","overview":"Shan es un policía honrado que es admirado por todo el cuerpo por haber resuelto muchos casos. Un día, su pasado regresa para atormentarle; en plena operación es atacado por un misterioso grupo de criminales liderado por Ngo, que fue su discípulo."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Бушуващ огън","runtime":0,"tagline":"","homepage":"","overview":"Отделът за тежки престъпления започва операция за залавяне на международен наркобарон, когато група маскирани гангстери внезапно нахлуват и хладнокръвно убиват целия екип. Полицейскиия инспектор Шан Чунбан (Дони Йен) става свидетел на убийството на другарите си и научава, че престъпниците, убили бившите му хора, работят под ръководството на Чи Гангао (Никълъс Тце). Чи някога е била изгряваща звезда в силите на реда и протеже на Шан, но Шан го вкарва в затвора за три години. След като излиза от затвора Чи е решен да отмъсти на всички вкарали го в затвора включително и на бившият си покровител."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Nekonečná zuřivost","runtime":0,"tagline":"","homepage":"","overview":"Shan je velmi uznávaný policista s dlouhou historií úspěchů v nebezpečných případech, avšak jeho minulost se mu brzy vrátí, když se jeho bývalý chráněnec snaží pomstít všem, kteří mu ublížili."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Wściekły glina","runtime":0,"tagline":"","homepage":"","overview":"Cheung Sung-bong jest funkcjonariuszem Regionalnego Oddziału Kryminalnego, który przez wiele lat pracował na froncie. Jego protegowany, Yau Kong-ngo, szanuje go i udaje mu się do niego dotrzeć. Jednak los stawia ich przeciwko sobie."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Cara a Cara","runtime":126,"tagline":"","homepage":"","overview":"Shan es un policía honrado que es admirado por todo el cuerpo por haber resuelto muchos casos. Un día, su pasado regresa para atormentarle; en plena operación es atacado por un misterioso grupo de criminales liderado por Ngo, que fue su discípulo."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Raging Fire - Fuoco incrociato","runtime":0,"tagline":"","homepage":"","overview":"Un onesto poliziotto ammirato per aver risolto così tanti casi, un giorno viene nuovamente messo alla prova, quando è perseguitato dal passato e l'operazione sotto il suo comando viene minacciata da un misterioso gruppo di criminali."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Raging Fire","runtime":0,"tagline":"","homepage":"","overview":"Ο Cheung Sung-bong είναι αξιωματικός της Περιφερειακής Μονάδας Εγκλήματος που εργάστηκε στην πρώτη γραμμή για πολλά χρόνια. Ο προστατευόμενός του, Yau Kong-ngo, τον σέβεται και καταφέρνει να τον πλησιάσει. Ωστόσο, η μοίρα τους φέρνει αντιμέτωπους."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"โคตรเดือดฉะเดือด","runtime":0,"tagline":"","homepage":"","overview":"ชาน (ดอนนี่ เยน) ตำรวจระดับปรมาจารย์ ต้องรับมือกับคดีก่อการร้ายทั่วเมือง ที่ตัวบงการคืออดีตลูกศิษย์มือหนึ่งอย่าง โอ (เซียะถิงฟง) ชายที่เต็มไปด้วยโทสะแรงกล้า พร้อมสังหารทุกคนที่มีส่วนทำให้เขาต้องเข้าคุก ไม่ว่ามันจะเป็นใครหน้าไหน หรือแม้แต่อาจารย์ของเขาก็ตาม"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Перехресний вогонь","runtime":0,"tagline":"","homepage":"","overview":"Головний герой - надзвичайно чесний та відданий справі детектив поліції Ченг Сон-Бон. Все життя він присвятив боротьбі зі злочинністю, тому має немало ворогів. Однак серед колег він не популярний ізгой. Важкий та прямий характер офіцера не сприяє його кар’єрі. А ще виникають проблеми з колишім протеже та напарником Яу Конг-нго, який стає шахраєм. Ченг Сон-Бон дав свідчення проти нього в суді, і відбувши покарання Яу повертається, аби помститись..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"זעם הנקמה","runtime":0,"tagline":"","homepage":"","overview":"צונג בואנג הוא קצין במשטרה שלא מוכן להתכופף בשביל אף אחד. והולך תמיד עם האמת שלו גם אם מדובר בחבר הכי קרוב לו שהופך לבסוף לאוייב המר ביותר שלו. לאחר שבואנג האשים אותו ואת שותפיו ברצח.\r הסרט בשפה הקנטונזית"},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"レイジング・ファイア","runtime":0,"tagline":"","homepage":"","overview":"東九龍警察本部のチョン警部は凶悪犯とベトナムの組織による麻薬取引を摘発しようとするが、取引現場にはチョンの仲間のチームが向かう。そこにマスクを着けた5人組が現われ、人々を殺して麻薬を奪う。去り際、5人組のリーダーは自分がかつてチョンを慕っていた元警官ンゴウだと明かす。4年前、ある事件の捜査で失敗をしたンゴウは仲間4人とともに刑務所に入れられ、以来、チョン、警察の副総監らに復讐心を燃やしていて……。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"شان شرطي يحظى باحترام كبير وله تاريخ طويل من النجاح في القضايا الخطيرة، ومع ذلك، سرعان ما يعود ماضيه ليطارده عندما يسعى ربيبه السابق للانتقام من كل من ظلموه."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Raging Fire","runtime":0,"tagline":"","homepage":"","overview":"မင်းသားကြီး Donnie Yen ဟာ ကျန်းချုံးပန်းဆိုတဲ့ ဖြောင့်မတ်တဲ့မှုခင်းရဲအရာရှိတစ်ယောက်နေနဲ့သရုပ်ဆောင်ထားပြီး ရဲဝန်ထမ်းတွေကြားမှာတင်အကောင်းအဆိုးကိုရှင်းရှင်းလင်းလင်းဖော်ပြထားပါတယ်Donnie Yen နဲ့Nicholas Tse တို့ဟာရင်းနှီးတဲ့လက်ဖော်ကိုင်ဖက်တွေဖြစ်ခဲ့ဖူးကြတယ်မူးယစ်ဆေးဝါးရောင်းဝယ်မှုကိုလိုက်နေချိန်မှာ လူမိုက်ကိုလူမိုက်ပြန်သတ်မှုတွေဖြစ်လာတယ်သူတို့နဲ့ဒါတွေကဘယ်လိုပတ်သတ်နေလဲ ဘယ်အရာကသူတို့ရဲ့လမ်းကြောင်းတွေကိုကွဲသွားစေလဲ‌‌အညိုးအတေးတွေကိုဘယ်လိုဖြေရှင်းကြမလဲဆိုတာ စိတ်ဝင်စားဖွယ်ကြည့်ရှုရမှာဖြစ်ပါတယ်"},"name":"","iso_639_1":"my","iso_3166_1":"MY","english_name":"Burmese"},{"data":{"title":"Mânie Furibundă","runtime":0,"tagline":"","homepage":"","overview":"Bong, un polițist dedicat și respectat, se confruntă cu cel mai periculos caz al carierei sale atunci când o echipă de foști ofițeri, conduși de fostul său protejat Ngo, începe să terorizeze orașul. Ngo, trădat și încarcerat în trecut, caută răzbunare împotriva celor care l-au abandonat. Pe măsură ce violența escaladează, Bong trebuie să își folosească toate abilitățile pentru a opri bandele criminale și a-l înfrunta pe fostul său discipol într-o luptă explozivă între justiție și răzbunare. „Raging Fire” este un thriller de acțiune intens, plin de scene spectaculoase de luptă și o poveste captivantă despre loialitate și trădare."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"}],"reviews_tmdb":[],"recommendations":[{"id":213955,"adult":false,"title":"The Green Hornet","video":false,"overview":"After the superstardom and early death of Bruce Lee, 20th Century Fox decided to cobble together a couple of theatrical feature films from this property, of which this 1974 effort is the first. The bulk of the film consists of four episodes crudely spliced together. Scattered throughout are bizarrely irrelevant fight scenes from other episodes, which make the already disjointed plotting quite surreal. The television image was cropped to make a widescreen film, which means the tops of heads and hats are lopped off the frame with alarming regularity.","genre_ids":[28,35],"media_type":"movie","popularity":0.3235,"vote_count":35,"poster_path":"/vBLxQ5gbOCThld8lo0coirOiZE8.jpg","release_date":"1974-03-21","vote_average":6.757,"backdrop_path":"/x9LZI8CUNzt3wCxKZjdDIhlj7ju.jpg","original_title":"The Green Hornet","original_language":"en"},{"id":287888,"adult":false,"title":"Paradise in Service","video":false,"overview":"Set in the island Kinmen, often seen as the most dangerous military base because it’s geographically close to China, \"Paradise in Service\" follows the adventure of a boy who serves his military service in Unit 831 from 1969 to 1972, in preparation for a war that could erupt anytime. Through an unlucky lottery draw result, Pao, a twenty-something young man from Southern Taiwan has to serve the military in the remote and perilous Kinmen. Moreover, he is assigned to the Sea Dragon (ARB), a unit noted for the toughest physical training. It never occurs to Pao, however, that the greatest challenge in his military service lies not in the Sea Dragon but in Unit 831, a special task he is later appointed to… In this peculiar assignment, Pao vows to keep his virginity against all odds.","genre_ids":[10749,18,36],"media_type":"movie","popularity":1.2009,"vote_count":37,"poster_path":"/4vl6TzTNkEfkJaXyOEbrHsVvt78.jpg","release_date":"2014-09-05","vote_average":6.7,"backdrop_path":"/a6eBgUh3cAVS1XIyrDn9zHvTAtM.jpg","original_title":"軍中樂園","original_language":"zh"},{"id":404114,"adult":false,"title":"Mobile Suit Gundam Thunderbolt: December Sky","video":false,"overview":"During the One Year War of U.C. 0079, the Earth Federation and Principality of Zeon engage in a fierce battle at the \"Thunderbolt Sector\", a shoal zone in the former Colony Side 4 \"Moore\". After successfully infiltrating Zeon's sniper field, ace Federation pilot and jazz enthusiast Io Fleming is given control of the latest Gundam prototype.","genre_ids":[28,16,18,878,10752],"media_type":"movie","popularity":0.9374,"vote_count":26,"poster_path":"/9lkEs98koT3et0Csyb996apllOm.jpg","release_date":"2016-06-25","vote_average":7.5,"backdrop_path":"/f6NlnBzQH7hoMp0BPpgNErd9iTj.jpg","original_title":"機動戦士ガンダム サンダーボルト DECEMBER SKY","original_language":"ja"},{"id":166302,"adult":false,"title":"Five Golden Flowers","video":false,"overview":"A Peng meets a girl named Jinhua at a festival and they agree to meet the next year but she fails to turn up. He searches for her and finds other girls named Jinhua.","genre_ids":[10402,10749],"media_type":"movie","popularity":0.1991,"vote_count":7,"poster_path":"/ipjO0r83bRpcXmbHdZVHxjY7z5h.jpg","release_date":"1959-10-01","vote_average":6.7,"backdrop_path":"/zMJ0cm38UGOCSfIRi5MaiybI1L1.jpg","original_title":"五朵金花","original_language":"zh"},{"id":674813,"adult":false,"title":"Beyond the Dream","video":false,"overview":"Lok is a recovering schizophrenic who yearns for love. One day, he encounters the young and beautiful Yan and quickly falls in love with her. The pair develops a relationship that is beyond their wildest dreams.","genre_ids":[10749,18],"media_type":"movie","popularity":0.8873,"vote_count":20,"poster_path":"/gTuVEZ1Dpmgy9ZZlSS8vT6Nwxl.jpg","release_date":"2020-07-02","vote_average":7,"backdrop_path":"/nU7nUWeGWac0OVH4kHwOV7bChLH.jpg","original_title":"幻愛","original_language":"cn"},{"id":391939,"adult":false,"title":"Moriyamachu Driving School","video":false,"overview":"Kiyotaka Sato (Shuhei Nomura) is a university student. He is sociable, but he looks like he doesn't have interest in those around him. During his summer vacation, Kiyotaka Sato plans to get his driver's license to impress schoolmate Matsuda (Yukino Kishii).  At this time, a yakuza boss (Ken Mitsuishi) orders Todoroki (Kento Kaku) to get his driver’s license. Todoroki doesn't show his feelings outwardly.  Later, Todoroki drives a car without a driver’s license and he hits Kiyotaka Sato. To cover up the accident, Kiyotaka Sato is placed in a car and taken to away. He arrives at an unofficial driving school. The driving school is run by the Uehara family. There, Kiyotaka Sato and Todoroki learn that they graduated from the same high school. They spend their summer at the driving school.","genre_ids":[35],"media_type":"movie","popularity":0.4158,"vote_count":4,"poster_path":"/t7k1x0EmuT5jmsjUqz6IQgFG9OX.jpg","release_date":"2016-07-09","vote_average":6,"backdrop_path":"/lGnRcFDAxNZSb1JW4IksowEMv0q.jpg","original_title":"森山中教習所","original_language":"ja"},{"id":545814,"adult":false,"title":"How The Young Ones Changed Comedy","video":false,"overview":"This documentary explores the legacy of one of the most notorious British sitcoms of all time. Launching alternative comedy onto our screens, the show made household names of its performers and writers and proved to be a huge influence, despite the BBC reportedly being baffled by what they'd commissioned back in 1982. Never before had a flagship comedy show contained so much violence, depravity and anarchy - it was a shot across the bow to mainstream comedians that things would never be the same again.","genre_ids":[99,35],"media_type":"movie","popularity":0.2819,"vote_count":2,"poster_path":"/xCWtx7wuR5t0tTcgPc4TsqxruOW.jpg","release_date":"2018-05-26","vote_average":7,"backdrop_path":"/k3DZulkuUDnAz43LYfM8J1OZS3t.jpg","original_title":"How The Young Ones Changed Comedy","original_language":"en"},{"id":773569,"adult":false,"title":"The Soul","video":false,"overview":"Wang Shicong, chairman of the famous group, died tragically at home. The prosecutor Liang Wenchao and his wife, Abang, learned during the investigation that the deceased’s long-term partner, Dr. Wan, and his ex-wife’s Son Wang Tianyou, young newlywed wife Li Yan, and even the dead ex-wife, each suspect has an intricate connection. As more clues gradually surfaced, they gradually discovered the rich. The amazing secret hidden behind the murder...","genre_ids":[9648,878,53],"media_type":"movie","popularity":0.9028,"vote_count":101,"poster_path":"/hrLX0HY408IFiVdSFytOtqcfLAs.jpg","release_date":"2021-01-08","vote_average":6.9,"backdrop_path":"/upesCDlcWdcctY4LGanfpzHiOur.jpg","original_title":"緝魂","original_language":"zh"},{"id":543504,"adult":false,"title":"Detective vs. Sleuths","video":false,"overview":"When Hong Kong is rocked by multiple gruesome murders, the police forms a task force to investigate.","genre_ids":[28,80,9648,53],"media_type":"movie","popularity":1.1112,"vote_count":95,"poster_path":"/sNAeYA5EZ7ouoHnVxQ0vMbfgiEi.jpg","release_date":"2022-07-02","vote_average":6.795,"backdrop_path":"/wcR9krcWcpAusD761uOQzKEBl3M.jpg","original_title":"神探大戰","original_language":"cn"},{"id":44839,"adult":false,"title":"Yulenka","video":false,"overview":"A university professor, who wants to slow down a little, moves with his wife and daughter, from the big city to a small town and starts a new job as a teacher in a girls' gymnasium. Something weird is happening with the class, they seem to hide a secret. As it turns out, these girls don't play with dolls...","genre_ids":[53,18,27],"media_type":"movie","popularity":0.7198,"vote_count":61,"poster_path":"/oGgoCkw7IC6bF7hhGu0oldbrmIW.jpg","release_date":"2009-02-19","vote_average":5.713,"backdrop_path":"/sQZ3VkcKoFpuvY2hbu6mIKPwv5T.jpg","original_title":"Юленька","original_language":"ru"},{"id":382220,"adult":false,"title":"Master","video":false,"overview":"Korea’s biggest network marketing scam reveals a far greater network of corruption and conspiracy lurking underneath.","genre_ids":[80,28],"media_type":"movie","popularity":1.4054,"vote_count":103,"poster_path":"/onDrDG7BxvSIcmdWSdz3t92yPb.jpg","release_date":"2016-12-21","vote_average":6.951,"backdrop_path":"/a9aOR8P37bc4A6VPXhZX01CtJbu.jpg","original_title":"마스터","original_language":"ko"},{"id":503917,"adult":false,"title":"Enter the Fat Dragon","video":false,"overview":"After being dumped by his fiancé, heartbroken Hong Kong police officer Fallon Zhu gains 200+ pounds. His superiors demote him to the job of escorting convicts to Japan. When a convict in his custody mysteriously dies, he must team up with citizen Thor to solve the mystery.","genre_ids":[28,35,80],"media_type":"movie","popularity":1.2979,"vote_count":128,"poster_path":"/fQqqsj0WhANqGqHQ8BhBE7iI4bk.jpg","release_date":"2020-01-23","vote_average":6.266,"backdrop_path":"/9SuQNQDldTshRJv0McGdtcquEri.jpg","original_title":"肥龍過江","original_language":"cn"},{"id":512954,"adult":false,"title":"Leaving Afghanistan","video":false,"overview":"1988-1989. The end of the Soviet-Afghan war. The USSR begins its withdrawal from Afghanistan. Soviet General Vasiliev's son - a pilot named Alexander gets kidnapped by the mujahideen after his airplane crashes. As a result the 108th motorized infantry division's long awaited return home gets put on hold for one last mission: bring the General's son back. Based on true events the previously untold story of the courageous and tragic withdrawal campaign (through the Salang pass) reveals the danger the horror and the complexity of human nature during wartime.","genre_ids":[18,28,10752],"media_type":"movie","popularity":0.7278,"vote_count":92,"poster_path":"/bZUkKnT3P0Ja2RUfjRhL2qHcXZH.jpg","release_date":"2019-05-10","vote_average":6.6,"backdrop_path":"/vhCoKNu3HkVCFCV2E2SNqxbOC3z.jpg","original_title":"Братство","original_language":"ru"},{"id":1289601,"adult":false,"title":"Life After Fighting","video":false,"overview":"Retired martial arts world champion Alex Faulkner has settled into a simple life, when the disappearance of two of his students leads to an unthinkable discovery close to home. Just when all hope of finding the children is lost, he locates the imprisoned girls and unsurfaces an international child trafficking operation, which draws him back into the fight of his life against those behind it.","genre_ids":[28,18,53],"media_type":"movie","popularity":2.9487,"vote_count":66,"poster_path":"/uKWAk4BHzyEOMmLKUDXoIAPhH36.jpg","release_date":"2024-06-07","vote_average":7.28,"backdrop_path":"/7TIoq6DRnMn2aDViSRfPooWZkga.jpg","original_title":"Life After Fighting","original_language":"en"},{"id":844069,"adult":false,"title":"Guimoon: The Lightless Door","video":false,"overview":"In 1990, at a secluded community center, the custodian murders all the guest lodgers and kills himself. Ever since, on every Old Year's Night, paranormal events begin to take place within the building. Eventually, the center is shut down and left abandoned for years. A renowned paranormal investigator who had lost his mother during an exorcism and three college students who heard about the rumor of the unexplained phenomena heads over to the building, resolved to uncover the buried secret.","genre_ids":[27,53],"media_type":"movie","popularity":0.6671,"vote_count":81,"poster_path":"/e1cZ4LaYv1M1RThyUh1sVi21Loe.jpg","release_date":"2021-08-25","vote_average":6.66,"backdrop_path":"/s8ryrjpl6GjSLoEHagzmgE4Yl2f.jpg","original_title":"귀문","original_language":"ko"},{"id":606740,"adult":false,"title":"Voice of Silence","video":false,"overview":"Two guys who are working for cartels as cleaners get a request to monitor an 11-year-old kidnapped girl, but the situation gets worse when their supervisor gets killed.","genre_ids":[18,80],"media_type":"movie","popularity":0.4574,"vote_count":94,"poster_path":"/vQZ9xinTItmEmFIqfxJ8bKwOCOH.jpg","release_date":"2020-10-15","vote_average":7.441,"backdrop_path":"/uvxgr5tcF6oYCn2wUgfxzHZdDN5.jpg","original_title":"소리도 없이","original_language":"ko"},{"id":538246,"adult":false,"title":"La Dama del Corvette","video":false,"overview":"No one could've ever imagined that this beautiful women who never leaves her sports car has the guts to collect debts in cold blood.","genre_ids":[28,80],"media_type":"movie","popularity":0.0956,"vote_count":94,"poster_path":"/1zG6IWEDM15TFkIYHM9t0Mc34il.jpg","release_date":"2016-01-01","vote_average":6.383,"backdrop_path":"/89znt7oJAcueBnGb98tizxeoVmY.jpg","original_title":"La Dama del Corvette","original_language":"es"},{"id":47002,"adult":false,"title":"Love Letter","video":false,"overview":"Hiroko attends the memorial service of her fiancé, Itsuki Fujii, who died in a mountain-climbing incident. Although Itsuki's mother says that their old house is gone, Hiroko records the address listed under his name in his yearbook and sends him a letter. Surprisingly, she receives a reply, and discovers it came from his old classmate, a girl who also happens to be called Itsuki Fujii.","genre_ids":[18,10749],"media_type":"movie","popularity":2.8126,"vote_count":249,"poster_path":"/e5lkke4fKEZNfl28gCOe6MrAjhA.jpg","release_date":"1995-03-25","vote_average":7.787,"backdrop_path":"/sglHi1esLqxACQYmEXHExJHzP6Z.jpg","original_title":"ラブレター","original_language":"ja"},{"id":524348,"adult":false,"title":"The Report","video":false,"overview":"The story of Daniel Jones, lead investigator for the US Senate’s sweeping study into the CIA's Detention and Interrogation Program, which was found to be brutal, immoral and ineffective. With the truth at stake, Jones battled tirelessly to make public what many in power sought to keep hidden.","genre_ids":[18],"media_type":"movie","popularity":2.0797,"vote_count":1130,"poster_path":"/sG5NI6TMNR9ftOdTIXmG0hrBYSY.jpg","release_date":"2019-09-12","vote_average":7.037,"backdrop_path":"/fnTrZiCRXCk3I6mnYvJwiMZf6pF.jpg","original_title":"The Report","original_language":"en"},{"id":204553,"adult":false,"title":"Cold Eyes","video":false,"overview":"Ha Yoon-ju becomes the newest member of a unit within the Korean Police Forces Special Crime Department that specializes in surveillance activities on high-profile criminals. She teams up with Hwang Sang-jun, the veteran leader of the unit, and tries to track down James who is the cold-hearted leader of an armed criminal organization.","genre_ids":[80,28,53],"media_type":"movie","popularity":1.8151,"vote_count":369,"poster_path":"/i1a1rk2qPrxIF5pYyBB2oSTa6OR.jpg","release_date":"2013-07-03","vote_average":7.534,"backdrop_path":"/bE4XWNy9CZD4TbJoFlRejbjI71X.jpg","original_title":"감시자들","original_language":"ko"}],"similar_content":[{"id":24,"adult":false,"title":"Kill Bill: Vol. 1","video":false,"overview":"An assassin is shot by her ruthless employer, Bill, and other members of their assassination circle – but she lives to plot her vengeance.","genre_ids":[28,80],"popularity":14.7451,"vote_count":18603,"poster_path":"/v7TaX8kXMXs5yFFGR41guUDNcnB.jpg","release_date":"2003-10-10","vote_average":8,"backdrop_path":"/iffzIhuLAO38Po6sh1s6ZEVwlNL.jpg","original_title":"Kill Bill: Vol. 1","original_language":"en"},{"id":59,"adult":false,"title":"A History of Violence","video":false,"overview":"An average family is thrust into the s