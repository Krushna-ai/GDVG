9:{"metadata":[["$","title","0",{"children":"The Monkey King | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Sun Wukong is a monkey born from a heavenly stone who acquires supernatural powers. After rebelling against heaven and being imprisoned under a mountain for 500 years, he later accompanies the monk Xuanzang on a journey to India. Thus, according to legend, Buddhism is brought to ancient China."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148568/the-monkey-king"}],["$","meta","5",{"property":"og:title","content":"The Monkey King"}],["$","meta","6",{"property":"og:description","content":"Sun Wukong is a monkey born from a heavenly stone who acquires supernatural powers. After rebelling against heaven and being imprisoned under a mountain for 500 years, he later accompanies the monk Xuanzang on a journey to India. Thus, according to legend, Buddhism is brought to ancient China."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148568/the-monkey-king"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/p9Atjcbidu4DsM7EQltiTZbrvkM.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"The Monkey King"}],["$","meta","12",{"name":"twitter:description","content":"Sun Wukong is a monkey born from a heavenly stone who acquires supernatural powers. After rebelling against heaven and being imprisoned under a mountain for 500 years, he later accompanies the monk Xuanzang on a journey to India. Thus, according to legend, Buddhism is brought to ancient China."}],["$","meta","13",{"name":"twitter:image","content":"https://image.