iso_639_1":"th","iso_3166_1":"TH","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":500,"height":750,"file_path":"/fFecIT00SkF3PMsyJJ0mrq44dJR.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/57da8mazzw0DXJBB2e8L92VUzqL.jpg","iso_639_1":"vi","iso_3166_1":"VN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1067,"height":1600,"file_path":"/h1Csrl1jVYB3iK8MTH50YuI8nTr.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/hURDTkArtjxaLvAl7CMSCosY0Fq.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1067,"height":1600,"file_path":"/j1QQuO0QF0K895YO4KuFpW9xZW3.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1067,"height":1600,"file_path":"/gOSJvjvTekG7PHV9ATiDj2CLBOa.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/js1bXvDkJsDgfiCZftijT8GuBnB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/xW6ZbgVox0olPGxhu8Rvycy8y8G.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/mn0Sqq42KJtJ4mdJTFnIgVwzcic.jpg","iso_639_1":"th","iso_3166_1":"TH","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/czewD1NhaHTRmBpQnZYlRDaO9FV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:48:21.67+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Monkey King","runtime":119,"tagline":"","homepage":"http://themonkeyking.com/","overview":"Sun Wukong is a monkey born from a heavenly stone who acquires supernatural powers. After rebelling against heaven and being imprisoned under a mountain for 500 years, he later accompanies the monk Xuanzang on a journey to India. Thus, according to legend, Buddhism is brought to ancient China."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Der Affenkönig - Aufruhr im Himmel","runtime":0,"tagline":"Aufruhr im Himmel","homepage":"","overview":"Die himmlischen Abenteuer des Affenkönigs Sun Wukong. Vom Berg der Blumen und Früchte hinein in das Schlachtengetümmel in den Palästen des Drachenkönigs und des mächtigen Jadekaisers. Mit List und Witz bezwingt der schlagfertige Sun 100.000 himmlische Soldaten und bringt die göttliche Ordnung gehörig ins Wanken."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"The Monkey King","runtime":119,"tagline":"","homepage":"","overview":""},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"ไซอิ๋ว 1 กำเนิดราชาวานร","runtime":120,"tagline":"","homepage":"","overview":"อภิมหาภาพยนตร์ทุนสร้างกว่า 2,000 ล้านบาท สุดยอดสเปเชียลเอฟเฟกต์โดยทีมผู้สร้าง Avatar และ 300 การกลับมาอีกครั้งของหนัง ไซอิ๋ว ที่ครั้งนี้มาในแบบ 3 มิติ โดดเด่นด้วยนักแสดงชั้นนำ ทั้ง ดอนนี่ เยน, โจวเหวินฟะ ซึ่งภาคนี้จะเต็มไปด้วยเรื่องราวอภินิหารของซุนหงอคง ในช่วงที่เขาได้ฝึกวิชาฝีมือจนไร้ผู้ต่อต้าน จนหาญกล้าต่อกรทั้งสวรรค์ ต้องเผชิญหน้ากับเทพและมารที่ยากจะรับมือได้"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"西游记之大闹天宫","runtime":0,"tagline":"","homepage":"","overview":"魔界之王牛魔王（郭富城 饰）与玉帝（周润发 饰）为首的神界展开战斗，神界被毁，女娲（张梓琳 饰）化身晶石修补天庭，遗落下的一小颗晶石落到人间成了一只石猴，而牛魔王则战败被迫带着妻子铁扇公主（陈乔恩 饰）躲到了火焰山。若干年后石猴得到了菩提老祖（海一天 饰）的教导被赐名孙悟空（甄子丹 饰），孙悟空来到花果山自立为王，还抢走了东海龙王（刘桦 饰）的定海神针当武器。同时牛魔王立志东山再起，利用了孙悟空与青梅竹马的小狐狸精（夏梓桐 饰）的感情煽动孙悟空大闹天宫，又串通了二郎神（何润东 饰）一起破坏了南天门，孙悟空势在必得，天庭危在旦夕。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Maymun Kral","runtime":0,"tagline":"","homepage":"","overview":"Maymun Kral geleneksel bir Çin romanı olan \"Batı'ya Yolculuk'dan\" bir parçaya dayanıyor. Film, Maymun Kralın doğuşu ve maceraları, kışkırtılma sonucu Cennetin Yeşim İmparatoruna olan isyanını konu ediniyor..."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"The Monkey King","runtime":0,"tagline":"","homepage":"","overview":"Ο Σαν Γιουκόνγκ είναι ένας πίθηκος γεννημένος από παραδεισένιο λίθο που του δίνει υπερφυσικές δυνάμεις. Όταν επαναστατεί ενάντια του παράδεισου, συλλαμβάνεται και κρατείται δέσμιος για 500 χρόνια. Βγαίνοντας, συναντά τον μοναχό Ξουαζάνγκ και ταξιδεύει στην Ινδία."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Le Roi singe","runtime":119,"tagline":"Des ravages au paradis","homepage":"","overview":"Depuis la nuit des temps, ce sont les divinités qui maintiennent l’équilibre entre le ciel et la terre. Mais les démons n’en pouvant plus d’être asservis par les dieux, le leader de la tribu des démons, le Roi-buffle, lance une attaque contre les dieux du ciel mais est tenu en échec par l’empereur Jade et ses guerriers avant d’être renvoyé dans les montagnes enflammées sur Terre. Afin de retrouver une harmonie entre les dieux, les démons et les hommes, la déesse Nuwa se transforme en cristaux multicolores afin de reconstruire le paradis et la porte Sud, protégée par de tels pouvoirs qu’un démon s’en approchant serait immédiatement réduit en cendres. Mais la déesse laisse échapper un cristal sur Terre. Celui-ci va donner naissance à un singe divin, pièce essentielle de la sécurité des cieux."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"The Monkey King","runtime":119,"tagline":"","homepage":"","overview":"Sun Wukong, (De ApenKoning) is een aap geboren uit een hemelse steen die bovennatuurlijke krachten bevat. Nadat hij zich verzet tegen de hemel wordt hij 500 jaar opgesloten onder een berg. Later vergezelt hij de monnik Xuanzang op reis naar India. Op deze manier wordt volgens de legende boeddhisme naar China gebracht."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"The Monkey King","runtime":0,"tagline":"","homepage":"","overview":"Il film si apre con il Re Demone Bull ( Aaron Kwok ) guerra contro il cielo. Gran parte del Cielo è distrutto durante la battaglia, e il Re Demone Bull affronta l' Imperatore di Giada ( Chow Yun-Fat ), il sovrano del Cielo. Il Re Demone Bull è sconfitto, ma prima che l'Imperatore di Giada può uccidere il Re Demone Bull, sua sorella e amante Bull Demon King della principessa di ferro Fan ( Joe Chen ) interviene"},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Opičí Král","runtime":119,"tagline":"","homepage":"","overview":"Snímek vypráví o pouti vybraných postav dnes již klasického příběhu čínské literatury \"Putování na západ\", jinak známého pod názvem Opičí král autora knižní předlohy Wu Cheng-ena a zavádí nás do děje, kdy se Opičí král bouří proti Nefritovému císaři a tím vyvolá chaos, jenž je úvodem do dalších dobrodružství."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"몽키킹: 손오공의 탄생","runtime":0,"tagline":"수 천년 동안 해와 달의 에너지를 받아 태어난 슈퍼 히어로 손오공  전설의 그가 여의봉을 들고 다시 돌아왔다!","homepage":"","overview":"신과 요괴, 인간의 평화를 지키던 천상은 마계 우마왕 군단의 침입으로 황폐해진다. 우마왕과의 전투에서 힘겹게 승리한 옥황상제는 여신의 희생으로 얻은 신비의 수정으로 천궁을 복원한다.  그 중 땅으로 떨어진 하나의 수정에서 수 천년 동안 해와 달의 힘을 받아 선과 악을 동시에 지닌 슈퍼 히어로 손오공이 태어난다. 신들보다 뛰어난 능력을 지녔지만 제멋대로인 손오공은 결국 스승에게 쫓겨나지만, 바다 용궁에 있던 신비의 무기 여의봉을 얻으며 원숭이들의 왕으로 군림한다.  한편, 수 천년 전 전쟁에서 패하고 지하세계에 갇히게 된 마계의 수장 우마왕은 손오공을 이용해 다시 천계를 공격하려 한다. 하지만 그의 속셈을 알게 된 손오공은 천상과 친구들을 지키기 위해 그와 피할 수 없는 대결을 펼치게 되는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Viaje al Oeste. Las aventuras del Rey Mono","runtime":0,"tagline":"","homepage":"","overview":"Sun Wukong, (El Rey Mono) es un mono nacido de una piedra celestial que adquiere poderes sobrenaturales. Tras rebelarse contra el cielo y ser encarcelado bajo una montaña de 500 años, que más tarde acompaña al monje Xuanzang en un viaje a la India. Por lo tanto, según la leyenda, el budismo es llevado a la antigua China. Esta historia muy querido, es una parte tan importante de la cultura asiática como La Ilíada y la Odisea o El mago de Oz se encuentran al oeste. Esta primera entrega de una trilogía de películas de acción en vivo en 3-D es en realidad una precuela de El Viaje al Oeste, la historia mucho hablado de las aventuras del Rey Mono en el camino a la India."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Король обезьян","runtime":0,"tagline":"","homepage":"","overview":"Всемогущий Король Обезьян однажды прогневил богов и был заключен ими в ледяную бездну среди Мраморных Гор. Спустя 500 лет маленький мальчик случайно снимает заклятие и освобождает героя.  Теперь Короля ждет новое испытание: ему предстоит сразиться с Кровожадным Драконом. Сможет ли великий герой, владевший магией и кунг-фу, спасти людей и победить Могучего Дракона?"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"The Monkey King","runtime":90,"tagline":"","homepage":"","overview":"Första delen i trilogin om Sun Wukong, (The Monkey King) en legendarisk krigare född från en magisk sten och som kom objuden till Jade Kejsarens bankett. Wukong blev senare fängslad i 500 år under ett berg. Men berättelsen tar vid då han i bekantskap med munken Xuanzang beger sig till Indien."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"A Lenda do Rei Macaco: Tumulto no Reino Celestial","runtime":119,"tagline":"","homepage":"","overview":"Sun Wukong, o Rei Macaco, é um macaco que nasceu com habilidades mágicas por causa dos poderes fantásticos de uma pedra celestial. Ele se rebela contra os deuses e é aprisionado durante 500 anos, sob uma montanha. Quando seu tempo encarcerado termina, ele parte com um monge, atravessando as terras da Índia, levando o budismo à China."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Кралят на Маймуните","runtime":0,"tagline":"","homepage":"","overview":"Историята на филма разказва за популярния персонаж от китайската митология Сън Уконг познат още като \"кралят на маймуните\". Смята се, че той е отчасти отговорен за широкото разпространение на будизма в Китай. Филмът се фокусира върху произхода и ранните години на Сън Уконг. Историята обхваща голяма част от преживяванията на Сън - от раждането му до вкарването му в затвора заради извършени престъпления в свещените планини на Китай. По пътя си към самоусъвършенстването Сън се сдобива с невероятни физически и психически сили, преборва се с изпратени от боговете армии и се превръща в един от най-опасните врагове на подземните демони."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"モンキー・マジック 孫悟空誕生","runtime":0,"tagline":"","homepage":"","overview":"天界と魔界の争いにより天界が破壊され、天界を補修したときに落ちたかけらに命が宿り、下界の人間界で猿として誕生。猿は天界の須菩提祖師に孫悟空と名付けられ、術などを覚えていく。一方、天界の玉帝に敗れた魔界の牛魔王は、悟空のパワーを悪用し天界をつぶそうとたくらむ。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"El rey Mono","runtime":120,"tagline":"","homepage":"","overview":"Sun Wukong, (El Rey Mono) es un mono nacido de una piedra celestial que adquiere poderes sobrenaturales. Tras rebelarse contra el cielo y ser encarcelado bajo una montaña de 500 años, que más tarde acompaña al monje Xuanzang en un viaje a la India. Por lo tanto, según la leyenda, el budismo es llevado a la antigua China. Esta historia muy querido, es una parte tan importante de la cultura asiática como La Ilíada y la Odisea o El mago de Oz se encuentran al oeste. Esta primera entrega de una trilogía de películas de acción en vivo en 3-D es en realidad una precuela de El Viaje al Oeste, la historia mucho hablado de las aventuras del Rey Mono en el camino a la India."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Tây Du Ký: Đại Náo Thiên Cung","runtime":0,"tagline":"The Monkey King (2014)","homepage":"","overview":"Đại Náo Thiên Cung là câu chuyện về cuộc đời của Tôn Ngộ Không trước chuyến tháp tùng Đường Tăng đi Ấn Độ thỉnh kinh. Ngưu Ma Vương vì muốn đưa người vợ yêu là Thiết phiến công chúa và con trai là Hồng hài nhi lên thiên đàng nên đã xúi giục Tôn Ngộ Không tấn công triều đình. Do phạm tội đại náo thiên cung nên Tôn Ngộ Không bị Phật Tổ Như Lai phạt nhốt dưới Ngũ Hành Sơn 500 năm cho đến khi được Tam Tạng giải thoát và theo ông đi thỉnh kinh."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"西遊記之大鬧天宮","runtime":0,"tagline":"","homepage":"","overview":"魔界之王牛魔王（郭富城飾）與玉帝（周潤發飾）為首的神界展開戰鬥，神界被毀，女媧（張梓琳飾）化身晶石修補天庭，遺落下的一小顆晶石落到人間成了一隻石猴，而牛魔王則戰敗被迫帶著妻子鐵扇公主（陳喬恩飾）躲到了火焰山。若幹年後石猴得到了菩提老祖（海一天飾）的教導被賜名孫悟空（甄子丹飾），孫悟空來到花果山自立為王，還搶走了東海龍王（劉樺飾）的定海神針當武器。同時牛魔王立志東山再起，利用了孫悟空與青梅竹馬的小狐狸精（夏梓桐飾）的感情煽動孫悟空大鬧天宮，又串通了二郎神（何潤東飾）一起破壞了南天門，孫悟空勢在必得，天庭危在旦夕。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":351694,"adult":false,"title":"Monkey King: Hero Is Back","video":false,"overview":"The all-powerful Monkey King once roamed freely between Heaven and Earth, but after angering the Gods, he was imprisoned within an ice cage deep within the mountains. 500 years later, monsters attack a small village and a child flees to the mountains. Unknowingly, the child releases the Monkey King from his curse. With the help and encouragement from this special child, Monkey King saves the village from the evil monsters.","genre_ids":[14,16,35],"media_type":"movie","popularity":1.8965,"vote_count":286,"poster_path":"/xHme10Y5jVdH8KeSGgStndjatF5.jpg","release_date":"2015-07-10","vote_average":6.925,"backdrop_path":"/xESy6kg2k4JsGzHU0ILkOL9qYec.jpg","original_title":"西游记之大圣归来","original_language":"zh"},{"id":381902,"adult":false,"title":"The Monkey King 2","video":false,"overview":"Taking place 500 years after the Havoc in Heaven, the Tang Priest is appointed by Buddha to go to the West to fetch the sacred scriptures, only to accidentally free the Monkey King. With Lady White aiming to break up the team assembled to defeat her, the Monkey King must fight in order to save his world!","genre_ids":[28,12,14],"media_type":"movie","popularity":1.6525,"vote_count":110,"poster_path":"/iOApsyuFG05NaDCNHnicrln1ztM.jpg","release_date":"2016-01-22","vote_average":5.9,"backdrop_path":"/jQHjvKOc3FG3ShoKTJfp1tXoKnQ.jpg","original_title":"西遊記之孫悟空三打白骨精","original_language":"zh"},{"id":14539,"adult":false,"title":"An Empress and the Warriors","video":false,"overview":"After the death of her father, a woman is forced to take over as empress and fight to save her kingdom.","genre_ids":[28,12,36],"media_type":"movie","popularity":1.1736,"vote_count":128,"poster_path":"/czFkHXSAWBYhurfGNVKotfBhso2.jpg","release_date":"2008-02-09","vote_average":6.043,"backdrop_path":"/j9ysoNYUIGa2zCh1Nx5Hcys2sL1.jpg","original_title":"江山美人","original_language":"zh"},{"id":254003,"adult":false,"title":"Golden Chickensss","video":false,"overview":"Working as a prostitute since she was 16, Kam has witnessed the highs and lows of Hong Kong over the decades.  Kamis now a “madam” who manages a stable of high-end prostitutes, entertaining and hosting parties for rich men. She has seen it all. On the surface she embraces the prosperity of the ‘New HK’ but like countless middle-class HK citizens, she laments the lossof the old Hong Kong that once belonged to the people.  Over the hill mob boss, Gordon, was put behind bars before the Hong Kong Handover in 1997. Gordon’s appearance and mindset are still stuck in the colonial past. Recently released from prison, he is unable to cope with the New Hong Kong. His sole source of solace is his old flame, Kam.","genre_ids":[35,18],"media_type":"movie","popularity":0.8299,"vote_count":36,"poster_path":"/x9aDB6mPX2ZpCGLbw5NRqSCkFaA.jpg","release_date":"2014-01-30","vote_average":5.7,"backdrop_path":"/nGdQakDSzXImn1ztZ2vDZUI2ftr.jpg","original_title":"金雞SSS","original_language":"cn"},{"id":369384,"adult":false,"title":"Te rompo el rating","video":false,"overview":"A television network infiltrates an inept employee (Porcel) in the competition and he begins to ruin all the programs but, instead of subtracting audience, he only managed to improve it.","genre_ids":[35],"media_type":"movie","popularity":0.0888,"vote_count":21,"poster_path":"/nyGJUDVisvYDXfJuGzrDKBPsGiT.jpg","release_date":"1981-04-16","vote_average":5.8,"backdrop_path":"/swR0O5hsEsJnYqBPq1ZLJrKmDPw.jpg","original_title":"Te rompo el rating","original_language":"es"},{"id":264728,"adult":false,"title":"Thomas & Friends: Wobbly Wheels & Whistles","video":true,"overview":"Travel along with Thomas for a wonderfully wobbly and wheel-spinning good time! The No. 1 blue engine has bridges to cross and tracks to uncover in these exciting adventures. When Victor gets overloaded with too many tasks, can Thomas help him let out steam? And while trying to get Scruff as clean as a whistle, will Thomas have to get his own wheels dirty? Just when things seem to be rolling along, will Ol' Wheezy make a wobbly mess of Thomas' special delivery? Hold on for exciting surprises waiting to be delivered just for you! Featuring the episodes: Jumping Jobi Wood!, Thomas and Scruff, Victor Says Yes and Toby and the Whistling Woods. The Australian release contains two additional episode; Creaky Cranky and Tickled Pink.","genre_ids":[10751,16],"media_type":"movie","popularity":0.1391,"vote_count":4,"poster_path":"/DWKxJc3LNiTIERU7138a22WHa4.jpg","release_date":"2011-01-04","vote_average":6,"backdrop_path":"/52eYsV5wJYMQhqEIDP3lRLqodLF.jpg","original_title":"Thomas & Friends: Wobbly Wheels & Whistles","original_language":"en"},{"id":2008,"adult":false,"title":"The Promise","video":false,"overview":"An orphaned girl, driven by poverty at such a young age, makes a promise with an enchantress. In return for beauty and the admiration of every man, she will never be with the man she loves. This spell cannot be broken unless the impossible happens: snow falling in spring and the dead coming back to life. Now a grown and beautiful princess, she regrets her promise, for all of the men she's loved has always been met with tragedy.","genre_ids":[14,18,28,53,10749],"media_type":"movie","popularity":1.7836,"vote_count":131,"poster_path":"/tdm4mlc27S1d72ub4Y4xcU2OlDD.jpg","release_date":"2005-12-15","vote_average":5.5,"backdrop_path":"/AwlJ2bQGjfEuXLsL5XJAaxOmMuV.jpg","original_title":"无极","original_language":"zh"},{"id":156965,"adult":false,"title":"Concussion","video":false,"overview":"After a blow to the head, Abby decides she can't do it anymore. Her life just can't be only about the house, the kids and the wife. She needs more: she needs to be Eleanor.","genre_ids":[18],"media_type":"movie","popularity":2.3316,"vote_count":111,"poster_path":"/uib2Khi2wynz9BEAoUBIvEE64vB.jpg","release_date":"2013-01-17","vote_average":5.2,"backdrop_path":"/l26bnx29wzK7FuGxef8JO8GPbTv.jpg","original_title":"Concussion","original_language":"en"},{"id":35648,"adult":false,"title":"Roujin Z","video":false,"overview":"Mr. Takazawa, an elderly invalid who is cared for at his home by Haruko, a young nursing student, is chosen by the Japanese Ministry of Public Welfare to test the Z-001, a computerized hospital bed with robotic features that allegedly displays more efficiency and skills than any human nurse, but Haruko mistrusts a machine unable to consider human feelings.","genre_ids":[16,18,878],"media_type":"movie","popularity":1.4226,"vote_count":131,"poster_path":"/kpJBEfjC9l7BFhmmGPmkNB8gl6h.jpg","release_date":"1991-09-14","vote_average":6.534,"backdrop_path":"/dfP5F5i3a4FfkVXiEAdLgo61lGj.jpg","original_title":"老人Z","original_language":"ja"},{"id":525660,"adult":false,"title":"Dynasty Warriors","video":false,"overview":"In the turbulent late Eastern Han Dynasty, ambitious Dong Zhuo controls the court and the commonalty, and heroes from all over the country begin to rise.","genre_ids":[28,12,14],"media_type":"movie","popularity":1.5687,"vote_count":139,"poster_path":"/7BCTdek5LFHglcgl7shsm7igJAH.jpg","release_date":"2021-04-27","vote_average":5.892,"backdrop_path":"/iJ2HVOZT9Kjayrhy21pbGIJs9ey.jpg","original_title":"真・三國無双","original_language":"cn"},{"id":12232,"adult":false,"title":"The Thief of Bagdad","video":false,"overview":"When Prince Ahmad is blinded and cast out of Bagdad by the nefarious Jaffar, he joins forces with the scrappy thief Abu to win back his royal place, as well as the heart of a beautiful princess.","genre_ids":[12,14,10749],"media_type":"movie","popularity":1.1523,"vote_count":290,"poster_path":"/8Fs29JYTOkDluTXgbvLRIaps6PO.jpg","release_date":"1940-02-19","vote_average":7.135,"backdrop_path":"/kIGfEkETCQUU94ougWCYwem4CV2.jpg","original_title":"The Thief of Bagdad","original_language":"en"},{"id":26881,"adult":false,"title":"The Incredible Hulk Returns","video":false,"overview":"Years after the end of the original series, David Banner continues his wandering search for a cure for the condition that turns him into the Hulk. He reunites with former colleague Don Blake, unaware of his mystical connection to Thor. When a criminal organization threatens their lives, Banner is forced to unleash the Hulk once again, marking the character’s return after the series finale.","genre_ids":[28,18,12,10770],"media_type":"movie","popularity":0.7347,"vote_count":159,"poster_path":"/dw7eBKL26HEkA89BKvNVsjx7gGL.jpg","release_date":"1988-05-22","vote_average":6.2,"backdrop_path":"/bRlsLlie6DXLAnHBg8IwfOAN87z.jpg","original_title":"The Incredible Hulk Returns","original_language":"en"},{"id":335777,"adult":false,"title":"The Nut Job 2: Nutty by Nature","video":false,"overview":"When the evil mayor of Oakton decides to bulldoze Liberty Park and build a dangerous amusement park in its place, Surly Squirrel and his ragtag group of animal friends need to band together to save their home, defeat the mayor, and take back the park.","genre_ids":[16,10751,12,35],"media_type":"movie","popularity":3.7674,"vote_count":456,"poster_path":"/xOfdQHNF9TlrdujyAjiKfUhxSXy.jpg","release_date":"2017-08-11","vote_average":6.12,"backdrop_path":"/snobCf0u4ex9OKNNFuNQKmGe3gJ.jpg","original_title":"The Nut Job 2: Nutty by Nature","original_language":"en"},{"id":12289,"adult":false,"title":"Red Cliff","video":false,"overview":"In 208 A.D., in the final days of the Han Dynasty, shrewd Prime Minster Cao convinced the fickle Emperor Han the only way to unite all of China was to declare war on the kingdoms of Xu in the west and East Wu in the south. Thus began a military campaign of unprecedented scale. Left with no other hope for survival, the kingdoms of Xu and East Wu formed an unlikely alliance.","genre_ids":[12,18,36,28,10752],"media_type":"movie","popularity":4.7892,"vote_count":872,"poster_path":"/eEelFTjUYJJDlwqd53VfSA8xMfj.jpg","release_date":"2008-07-10","vote_average":7.1,"backdrop_path":"/pkcW3uu862e41ol1JXEVP4RSo0N.jpg","original_title":"赤壁","original_language":"zh"},{"id":14506,"adult":false,"title":"The Adventures of Baron Munchausen","video":false,"overview":"An account of Baron Munchausen's supposed travels and fantastical experiences with his band of misfits.","genre_ids":[14,12,35],"media_type":"movie","popularity":2.8071,"vote_count":982,"poster_path":"/oiOwGRqwrKpg1EMUlPgRjVC49bn.jpg","release_date":"1988-12-07","vote_average":7,"backdrop_path":"/mBh3NXCkSCasZGovzAuc9UlFCru.jpg","original_title":"The Adventures of Baron Munchausen","original_language":"en"},{"id":11049,"adult":false,"title":"Interstella 5555: The 5tory of the 5ecret 5tar 5ystem","video":false,"overview":"Four talented alien musicians are kidnapped by a record producer who disguises them as humans. Shep, a space pilot in love with bass player Stella, follows them to Earth. Reprogrammed to forget their real identities and renamed The Crescendolls, the group quickly becomes a huge success playing soulless corporate pop. At a concert, Shep manages to free all the musicians except Stella, and the band sets out to rediscover who they really are — and to rescue Stella.","genre_ids":[16,878,10402,12],"media_type":"movie","popularity":1.8496,"vote_count":505,"poster_path":"/n0K6mjU8aVnag2mi93FuvJsjZi.jpg","release_date":"2003-05-28","vote_average":7.794,"backdrop_path":"/p1XtUnWJrmVNqyhYJGIatMNt8C1.jpg","original_title":"Interstella 5555: The 5tory of the 5ecret 5tar 5ystem","original_language":"en"},{"id":450001,"adult":false,"title":"Master Z: Ip Man Legacy","video":false,"overview":"Following his defeat by Master Ip, Cheung Tin Chi tries to make a life with his young son in Hong Kong, waiting tables at a bar that caters to expats. But it's not long before the mix of foreigners, money, and triad leaders draw him once again to the fight.","genre_ids":[28,80,18],"media_type":"movie","popularity":3.5651,"vote_count":578,"poster_path":"/6VxEvOF7QDovsG6ro9OVyjH07LF.jpg","release_date":"2018-12-20","vote_average":6.492,"backdrop_path":"/oEFTbg7xlg6eEq9wN5qhTLdDoax.jpg","original_title":"葉問外傳：張天志","original_language":"cn"},{"id":46528,"adult":false,"title":"The Warrior's Way","video":false,"overview":"A warrior-assassin is forced to hide in a small town in the American Badlands after refusing a mission.","genre_ids":[12,14,28,37,53],"media_type":"movie","popularity":2.006,"vote_count":651,"poster_path":"/otjBqNDpZ3C9mzfDOI4kaiib3Qd.jpg","release_date":"2010-12-01","vote_average":6.568,"backdrop_path":"/6FhmSHAmSjm5FGpLe2xqAl7ekFP.jpg","original_title":"The Warrior's Way","original_language":"en"},{"id":10015,"adult":false,"title":"Heartbreak Ridge","video"