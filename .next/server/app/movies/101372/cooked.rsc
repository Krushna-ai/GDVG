.jpg","iso_639_1":"es","vote_average":0},{"width":2000,"height":3000,"file_path":"/dCrQE2XefiXMo9kAHMlINMEy4AA.jpg","iso_639_1":"el","vote_average":0},{"width":2000,"height":3000,"file_path":"/71NbmbdBdQbGbQLnuffj7tfsZKH.jpg","iso_639_1":"it","vote_average":0},{"width":1000,"height":1500,"file_path":"/gva6lWB1IvuIjtcEtgd13TdT9vL.jpg","iso_639_1":"he","vote_average":0},{"width":2000,"height":3000,"file_path":"/rdn3Iv6CWqPkBxAWH0NhBhkpd5u.jpg","iso_639_1":"fr","vote_average":0},{"width":1333,"height":2000,"file_path":"/7C0flZzxt76wQIqTij91k54P6fu.jpg","iso_639_1":"tr","vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/mnrqxJaBMLGmqJKlq2UfFZFDdSr.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/8em4LdozgDQ6RYcCo0VD8hoDGOS.jpg","iso_639_1":"he","vote_average":3.334},{"width":1920,"height":1080,"file_path":"/4uRpEU4LjJXx9uPJ2mG8QLzUgD2.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/9tB3KbvUiwrvFAVFsGTcTkHB44t.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/bWzqKYCIKJOJalt616eikr5a851.jpg","iso_639_1":"he","vote_average":0},{"width":3840,"height":2160,"file_path":"/nQHYV9nov10ZoQb6WzytOBAWCEJ.jpg","iso_639_1":"es","vote_average":0},{"width":3840,"height":2160,"file_path":"/89dIKTVwPJrGwHJznu6ffMhAzII.jpg","iso_639_1":"en","vote_average":0},{"width":3840,"height":2160,"file_path":"/pa1tKvwuWdaQOYFxI4oM2VZKi03.jpg","iso_639_1":"el","vote_average":0},{"width":3840,"height":2160,"file_path":"/q8hCUirheTgg6NN8S2OyuIJ2O3T.jpg","iso_639_1":"it","vote_average":0},{"width":3840,"height":2160,"file_path":"/xA8Ykkzj8lQI5VSsPRWiOsuMd0Q.jpg","iso_639_1":"it","vote_average":0},{"width":3840,"height":2160,"file_path":"/ktqjXzEquRB9y6akYzKsVi7tjQJ.jpg","iso_639_1":"tr","vote_average":0},{"width":3840,"height":2160,"file_path":"/2vu5jTk9JojKrM3hFOPjA66yz3c.jpg","iso_639_1":"el","vote_average":0},{"width":3840,"height":2160,"file_path":"/5YqvVXdGKkg2qrXCyBhyqwThKHi.jpg","iso_639_1":"tr","vote_average":0},{"width":3840,"height":2160,"file_path":"/rYhn66KB29lGPXU4UpM5WvUvBDW.jpg","iso_639_1":"en","vote_average":0},{"width":3840,"height":2160,"file_path":"/uvKh1lDU8PFMK21OiwD660cmaAM.jpg","iso_639_1":"fr","vote_average":0}]},"enriched_at":"2026-04-21T07:38:53.898+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":0,"tagline":"Düşünecek az zaman, yapılacak çok iş var.","homepage":"https://www.disneyplus.com/tr-tr/movies/umami/7bON3YXW6t1x","overview":"İstanbul’un en prestijli restoranlarından birinin sahibi şef Sina Bora, yılın en hareketli gecesinde hem profesyonel hem de kişisel hayatını tehdit eden zorluklarla yüzleşir. Babasının acil ameliyat haberi, eksik malzemeler, gergin personel ve eski mentoruyla hesaplaşmalar arasında sıkışan Sina, krizleri yönetmeye çalışırken büyük kararlarla karşı karşıya kalır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Cooked","runtime":120,"tagline":"","homepage":"https://www.hulu.com/movie/2578b8d5-5624-456f-b858-5a2db3f3c9c7","overview":"Chef and owner Sina Bora faces personal and professional challenges on one of his restaurant's busiest nights. His father's emergency surgery, staff tensions and his former mentor Renzo's plans to take over push Sina to make tough decisions."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"אומאמי","runtime":102,"tagline":"","homepage":"https://www.apps.disneyplus.com/il/movies/vmmy/1271381733","overview":"סיפור הלילה יוצא הדופן של השף סינה בורה, כשהוא נאבק בלחצים של ניהול מסעדה מצליחה ומפנקת באיסטנבול, תוך שהוא נאלץ להתמודד עם חייו האישיים ועם הדרישות של הצוות שלו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Ébullition","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/movies/ebullition/7bON3YXW6t1x","overview":"Sina Bora, chef et propriétaire de l'un des restaurants les plus fréquentés d'Istanbul, vit une nuit pleine de défis personnels et professionnels. Avant l'ouverture, Sina apprend que son père doit être opéré d'urgence. Tiraillé entre sa famille et son restaurant en difficulté, Sina doit aussi gérer des problèmes d’approvisionnement, un personnel sous tension et une inspection inattendue. La situation empire avec l’offre de rachat de Renzo, son ancien mentor. Au fil de la nuit, Sina va devoir jongler entre sa famille et son travail, entre son côté humain et son rôle de chef. « Umami » est un film captivant qui plonge les spectateurs dans le dur univers de la cuisine, à travers les épreuves d’un chef talentueux poussé dans ses retranchements."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Umami","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/de-de/movies/umami/7bON3YXW6t1x","overview":"Chefkoch und Inhaber Sina Bora steht an einem der geschäftigsten Abende in seinem Restaurant vor persönlichen und beruflichen Herausforderungen. Die Notoperation seines Vaters, fehlende Zutaten, Spannungen in der Belegschaft und die Pläne seines ehemaligen Mentors Renzo, das Restaurant zu übernehmen, zwingen Sina zu schwierigen Entscheidungen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"HIERVE (UMAMI)","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/es-es/movies/hierve-umami/7bON3YXW6t1x","overview":"El chef y propietario Sina Bora lidia con desafíos personales y profesionales en una de las noches más concurridas de su restaurante. La operación urgente de su padre, ingredientes perdidos, tensiones entre el personal y la pretensión de control de su mentor Renzo obligan a Sina a tomar decisiones difíciles."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Umami - Chef Stellato","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/it-it/movies/umami-chef-stellato/7bON3YXW6t1x","overview":"Sina Bora, chef e proprietario di un ristorante, vive sfide personali e professionali nella serata più impegnativa del suo locale. Il padre deve essere operato d’urgenza, mancano ingredienti, ci sono tensioni tra lo staff e il suo ex mentore Renzo punta a soffiargli il locale. Tutto ciò costringerà Sina a prendere decisioni difficili."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Umami: O Sabor da Ambição","runtime":0,"tagline":"","homepage":"","overview":"Como chef e proprietário de um dos restaurantes mais populares de Istambul, Sina Bora enfrenta uma noite cheia de desafios pessoais e profissionais. Antes da abertura do restaurante, ele fica sabendo que seu pai precisa de uma cirurgia de emergência. Em conflito entre sua família e as dificuldades do restaurante, Sina também se depara com ingredientes faltando, tensões entre a equipe e uma inspeção inesperada. A situação piora quando seu antigo mentor, o famoso chef Renzo, chega. Durante toda a noite, Sina precisa resolver várias crises enquanto equilibra sua devoção à família e ao trabalho. Sua jornada testa seus limites como chef, líder, filho e ser humano."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/es-mx/movies/umami/7bON3YXW6t1x","overview":"El chef y dueño Sina Bora enfrenta desafíos personales y profesionales en una de las noches más concurridas de su restaurante. La cirugía de emergencia de su padre, ingredientes faltantes, tensiones entre el personal y los planes de su antiguo mentor Renzo por tomar el control llevan a Sina a tomar decisiones difíciles."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/cs-cz/movies/umami/7bON3YXW6t1x","overview":"Šéfkuchař a majitel restaurace Sina Bora čelí během jednoho z nejhektičtějších večerů, jaké kdy restaurace zažila, osobním a profesním výzvám. Sina musí kvůli tátově akutní operaci, chybějícím surovinám, napětí mezi zaměstnanci a tomu, že ho chce jeho bývalý mentor Renzo vystrnadit, činit těžká rozhodnutí."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/da-dk/movies/umami/7bON3YXW6t1x","overview":"Køkkenchef og ejer Sina Bora står over for en personlig og faglig krise på sin restaurants travleste aften. Hans fars hasteoperation, manglende ingredienser, spændinger blandt personalet og hans tidligere mentor Renzos planer om at tage over presser Sina til at træffe svære beslutninger."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/nl-nl/movies/umami/7bON3YXW6t1x","overview":"Chef-kok/eigenaar Sina Bora maakt een persoonlijke en professionele crisis door op een van de drukste avonden in zijn restaurant. De spoedoperatie van zijn vader, ontbrekende ingrediënten, spanningen onder het personeel en de overnameplannen van zijn voormalige mentor Renzo dwingen Sina om moeilijke beslissingen te nemen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/fi-fi/movies/umami/7bON3YXW6t1x","overview":"Kokki ja ravintolan omistaja Sina Bora kohtaa henkilökohtaisia ja ammatillisia kriisejä yhtenä ravintolansa kiireisimmistä illoista. Hänen isänsä hätäleikkaus, puuttuvat ainesosat, työntekijöiden väliset jännitteet ja hänen entisen mentorinsa Renzon suunnitelmat astua remmiin ajavat Sinan vaikeiden päätösten eteen."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Ébullition","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/fr-ca/movies/ebullition/7bON3YXW6t1x","overview":"Le chef Sina Bora fait face à une crise personnelle et professionnelle lors d'un service intense dans son restaurant. Son père doit être opéré d’urgence, le personnel est sous tension et l’approvisionnement se complique. L’ancien mentor de Sina veut prendre la relève du restaurant. Le chef doit prendre des décisions difficiles."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Ουμάμι","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/el-gr/movies/cooked/7bON3YXW6t1x","overview":"Ο σεφ Σινά Μπόρα αντιμετωπίζει προσωπικές και επαγγελματικές προκλήσεις σε μια από τις πιο κατάμεστες βραδιές του εστιατορίου του. Το επείγον χειρουργείο του πατέρα του, τα υλικά που λείπουν, οι εντάσεις του προσωπικού και τα σχέδια του πρώην μέντορά του να πάρει τον έλεγχο της επιχείρησης, τον πιέζουν να πάρει δύσκολες αποφάσεις."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Cooked","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/hu-hu/movies/cooked/7bON3YXW6t1x","overview":"A séf és tulajdonos, Sina Bora szakmai és személyes válsággal néz szembe éttermének egyik legforgalmasabb éjszakáján. Apja sürgős műtétje, hiányzó alapanyagok, személyzeti feszültségek és korábbi mentora, Renzo üzletszerzési tervei mind kemény döntések elé állítják."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/no-no/movies/umami/7bON3YXW6t1x","overview":"Sjefskokk og eier Sina Bora møter på personlige og profesjonelle utfordringer på en av de travleste dagene på restauranten sin. Akuttoperasjonen til faren, manglende ingredienser, anspent stemning blant de ansatte, og hans tidligere mentor Renzos planer om å ta over, presser Sina til å ta tunge avgjørelser."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/pl-pl/movies/umami/7bON3YXW6t1x","overview":"Sina Bora, szef kuchni i właściciel restauracji, stawia czoła osobistym i zawodowym wyzwaniom podczas jednej z najbardziej pracowitych nocy w swoim lokalu. Nagła operacja jego ojca, braki w zaopatrzeniu, napięcia w zespole i plany przejęcia władzy przez jego byłego mentora Renzo zmuszają Sinę do podejmowania trudnych decyzji."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/pt-pt/movies/umami/7bON3YXW6t1x","overview":"O chef e dono Sina Bora enfrenta desafios pessoais e profissionais numa das noites mais movimentadas do seu restaurante. A cirurgia de emergência do seu pai, a falta de ingredientes, as tensões na equipa e os planos do seu antigo mentor, Renzo, para assumir o controlo obrigam Sina a tomar decisões difíceis."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/ro-ro/movies/umami/7bON3YXW6t1x","overview":"Sina Bora, chef și patron, are parte de provocări personale și profesionale într-o seară aglomerată de la restaurantul lui. Operația urgentă a tatălui său, lipsa ingredientelor, tensiunile dintre angajați și planurile lui Renzo, fostul său mentor, de a prelua localul îl fac pe Sina să ia decizii grele."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/sk-sk/movies/umami/7bON3YXW6t1x","overview":"Šéfkuchár Sina Bora čelí vo svojej reštaurácii počas jedného z najrušnejších večerov osobným a pracovným výzvam. Jeho otca musia operovať, chýbajú mu ingrediencie, medzi jeho zamestnancami to vrie a, navyše, jeho bývalý mentor mu chce prevziať reštauráciu."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.disneyplus.com/sv-se/movies/umami/7bON3YXW6t1x","overview":"Kocken och ägaren Sina Bora står inför personliga och professionella utmaningar under en av hans restaurangs mest hektiska kvällar. Hans fars akuta operation, saknade ingredienser, spänningar bland personalen och hans tidigare mentor Renzos planer på att ta över tvingar Sina att fatta svåra beslut."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"鲜味人生","runtime":120,"tagline":"","homepage":"","overview":"讲述了厨师Sina Bora非凡的夜晚的故事，他与在伊斯坦布尔经营一家成功而豪华的餐厅的压力作斗争，同时还必须应对他的个人生活和团队的需求。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Пища Богов","runtime":0,"tagline":"","homepage":"","overview":"Фильм рассказывает об одном из рабочих дней шеф-повара Сины Бора, который управляется успешным и роскошным рестораном в Стамбуле, а также пытается разобраться с личной жизнью и требованиями своей команды."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"اومامی","runtime":0,"tagline":"","homepage":"","overview":"فیلم داستان سرآشپز و مالک رستورانی به نام سینا بورا را روایت می‌کند که در یکی از شلوغ‌ترین شب‌های رستورانش با چالش‌های شخصی و حرفه‌ای متعددی روبه‌رو می‌شود. او با فشارهای ناشی از راه‌اندازی یک رستوران موفق و مجلل در استانبول دست و پنجه نرم می‌کند و در عین حال مجبور است با زندگی شخصی و خواسته‌های تیمش کنار بیاید و ..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Зірковий шеф Умамі","runtime":0,"tagline":"","homepage":"","overview":"Історія дуже важкої та незвичайної ночі професійного шеф-кухаря, який зіштовхується з тиском управління успішним та розкішним рестораном в центрі Стамбула. При цьому головний герой мусить докласти чималих зусиль, аби зрештою виконати низку вимог своєї команди, борючись із нелегким особистим життям."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Umami","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bosanski","iso_639_1":"bs","iso_3166_1":"BS","english_name":"Bosnian"}],"reviews_tmdb":[],"recommendations":[{"id":271954,"adult":false,"title":"Water and Fire","video":false,"overview":"A pretty young girl falls for an enigmatic, shy man who sweeps her off her feet. She becomes pregnant but is not allowed to tell him. His advisers are adamant. Back home, they have set up a wedding with the daughter of an antagonistic family and marriage will put an end to the blood feud between them.","genre_ids":[18,10749],"media_type":"movie","popularity":1.4636,"vote_count":177,"poster_path":"/7Q91NanJYGIUljUM7STDLECllyq.jpg","release_date":"2013-11-15","vote_average":7.9,"backdrop_path":"/7CRI8G7pm0HjEptiEEPiCMv3GEV.jpg","original_title":"Su ve Ateş","original_language":"tr"},{"id":551994,"adult":false,"title":"The Shed","video":false,"overview":"The story of Stan, an orphaned teenager stuck living with his abusive grandfather and tasked with routinely protecting his best friend from high school bullies. When Stan discovers a murderous creature has taken refuge inside the tool shed in his backyard, he tries to secretly battle the demon alone until his bullied friend discovers the creature and has a far more sinister plan in mind.","genre_ids":[27,53],"media_type":"movie","popularity":0.6633,"vote_count":139,"poster_path":"/aV9n5MyLZQsoXNfbZG5OOf16IkP.jpg","release_date":"2019-10-25","vote_average":5.86,"backdrop_path":"/y2WqsZYVI0yVdC0hgDmYvzfJzqr.jpg","original_title":"The Shed","original_language":"en"},{"id":970947,"adult":false,"title":"The Shrouds","video":false,"overview":"Inconsolable since the death of his wife, Karsh, a prominent businessman, invents a revolutionary and controversial technology that enables the living to monitor their dear departed in their shrouds. One night, multiple graves, including that of Karsh’s wife, are desecrated, and he sets out to track down the perpetrators.","genre_ids":[878,53,27,18,9648],"media_type":"movie","popularity":1.657,"vote_count":207,"poster_path":"/6J4lPto3rjlHZwhIhCy9cOWNnqb.jpg","release_date":"2025-04-03","vote_average":5.848,"backdrop_path":"/wMgT2Q0WcNLYrS46q9WCHImBCEc.jpg","original_title":"The Shrouds","original_language":"en"},{"id":1179051,"adult":false,"title":"Undercover Party Crasher","video":false,"overview":"In order to get evidence for her case and dismantle a criminal organization, an uptight undercover cop crashes a high school graduation trip to a party-heavy beach in Brazil.","genre_ids":[35,28],"media_type":"movie","popularity":0.5887,"vote_count":19,"poster_path":"/dcoc4C57lCpAzBr2qojFjRCKO9E.jpg","release_date":"2025-01-17","vote_average":6.789,"backdrop_path":"/yrDVPArD1OY0P9jFfNB1UdHIi7L.jpg","original_title":"Missão Porto Seguro","original_language":"pt"},{"id":1036487,"adult":false,"title":"Eflatun","video":false,"overview":"Eflatun, a blind woman since childhood, has been able to get a hold of her life with the help  of her father’s various shadow and sound plays. Eflatun inherits her father’s profession of  clock repair. She waits for a man with who she had fallen in love with his voice. One day a  man whose voice is identical to the man she’s searching for comes into the shop.","genre_ids":[18,10749,16],"media_type":"movie","popularity":0.3037,"vote_count":2,"poster_path":"/xExjJp5aU7Sdh81TeGR8fbKxEiv.jpg","release_date":"2023-01-23","vote_average":8,"backdrop_path":"/lxC0TPqCq5FBiUeTfG9Fph2lB5Z.jpg","original_title":"Eflâtun","original_language":"tr"},{"id":1084199,"adult":false,"title":"Companion","video":false,"overview":"During a weekend getaway at a secluded lakeside estate, a group of friends finds themselves entangled in a web of secrets, deception, and advanced technology. As tensions rise and loyalties are tested, they uncover unsettling truths about themselves and the world around them.","genre_ids":[27,878,53],"media_type":"movie","popularity":12.2385,"vote_count":2087,"poster_path":"/oCoTgC3UyWGfyQ9thE10ulWR7bn.jpg","release_date":"2025-01-22","vote_average":7.015,"backdrop_path":"/qA6MHDGDY0LyutjLUgFJRbPXLpW.jpg","original_title":"Companion","original_language":"en"},{"id":445571,"adult":false,"title":"Game Night","video":false,"overview":"Max and Annie's weekly game night gets kicked up a notch when Max's brother Brooks arranges a murder mystery party -- complete with fake thugs and federal agents. So when Brooks gets kidnapped, it's all supposed to be part of the game. As the competitors set out to solve the case, they start to learn that neither the game nor Brooks are what they seem to be. The friends soon find themselves in over their heads as each twist leads to another unexpected turn over the course of one chaotic night.","genre_ids":[9648,35,80],"media_type":"movie","popularity":5.4721,"vote_count":6174,"poster_path":"/85R8LMyn9f2Lev2YPBF8Nughrkv.jpg","release_date":"2018-02-15","vote_average":6.847,"backdrop_path":"/aKPCZwkSZy2ASLo0QKeYmcoplfA.jpg","original_title":"Game Night","original_language":"en"},{"id":758323,"adult":false,"title":"The Pope's Exorcist","video":false,"overview":"Father Gabriele Amorth, Chief Exorcist of the Vatican, investigates a young boy's terrifying possession and ends up uncovering a centuries-old conspiracy the Vatican has desperately tried to keep hidden.","genre_ids":[27,53],"media_type":"movie","popularity":4.2597,"vote_count":3069,"poster_path":"/jFC4LS5qTAT3PinzdEzINfu1CV9.jpg","release_date":"2023-04-05","vote_average":6.919,"backdrop_path":"/3oqmk6mNWPatBKcjOOJLp5WW9zN.jpg","original_title":"The Pope's Exorcist","original_language":"en"},{"id":436969,"adult":false,"title":"The Suicide Squad","video":false,"overview":"Supervillains Harley Quinn, Bloodsport, Peacemaker and a collection of nutty cons at Belle Reve prison join the super-secret, super-shady Task Force X as they are dropped off at the remote, enemy-infused island of Corto Maltese.","genre_ids":[28,35,12],"media_type":"movie","popularity":12.5847,"vote_count":9393,"poster_path":"/q61qEyssk2ku3okWICKArlAdhBn.jpg","release_date":"2021-07-28","vote_average":7.469,"backdrop_path":"/jlGmlFOcfo8n5tURmhC7YVd4Iyy.jpg","original_title":"The Suicide Squad","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":21.4528,"vote_count":11363,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.036,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":337401,"adult":false,"title":"Mulan","video":false,"overview":"When the Emperor of China issues a decree that one man per family must serve in the Imperial Chinese Army to defend the country from Huns, Hua Mulan, the eldest daughter of an honored warrior, steps in to take the place of her ailing father. She is spirited, determined and quick on her feet. Disguised as a man by the name of Hua Jun, she is tested every step of the way and must harness her innermost strength and embrace her true potential.","genre_ids":[12,14,28],"media_type":"movie","popularity":6.3592,"vote_count":6966,"poster_path":"/aKx1ARwG55zZ0GpRvU2WrGrCG9o.jpg","release_date":"2020-09-04","vote_average":6.837,"backdrop_path":"/zMrk2G3XsnfYKiIp1NEfdtvDyBH.jpg","original_title":"Mulan","original_language":"en"},{"id":797394,"adult":false,"title":"Secret Magic Control Agency","video":false,"overview":"The Secret Magic Control Agency sends its two best agents, Hansel and Gretel, to fight against the witch of the Gingerbread House.","genre_ids":[16,35,14],"media_type":"movie","popularity":1.1607,"vote_count":391,"poster_path":"/4ZSzEDVdxWVMVO4oZDvoodQOEfr.jpg","release_date":"2021-03-18","vot