5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Second Life\",\"description\":\"28 years ago, Liang gives birth to a boy named \\\"Little Bean Jelly\\\" in prison. When the kid turns one, the mother and son lose contact. Years later, Green Dragon Group's henchman \\\"Ghost\\\" is ambushed during a mission and becomes blind. When Liang is released from prison, she meets Ghost. One wants only to complete the assassination, while the other wants to make amends to rebuild their mother-son relationship. By an unexpected combination of circumstances, this mother and son help each other redeem themselves and return to the right path.\",\"image\":\"https://image.tmdb.org/t/p/w500/ldTBSOK8czliedL8pb1FEsQ1TZQ.jpg\",\"datePublished\":\"2024-08-15\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Action\",\"Comedy\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.7,\"bestRating\":10,\"ratingCount\":3}}"}}],["$","$L10",null,{"initialDrama":{"id":"0618a908-2b1f-40af-9172-2f5f0a4dc0fb","tmdb_id":1329643,"imdb_id":"tt33111253","content_type":"movie","title":"Second Life","original_title":"重见天日","overview":"28 years ago, Liang gives birth to a boy named \"Little Bean Jelly\" in prison. When the kid turns one, the mother and son lose contact. Years later, Green Dragon Group's henchman \"Ghost\" is ambushed during a mission and becomes blind. When Liang is released from prison, she meets Ghost. One wants only to complete the assassination, while the other wants to make amends to rebuild their mother-son relationship. By an unexpected combination of circumstances, this mother and son help each other redeem themselves and return to the right path.","poster_path":"/ldTBSOK8czliedL8pb1FEsQ1TZQ.jpg","backdrop_path":"/vcdubpI9Oo1OQHECBmv8fcC31q.jpg","release_date":"2024-08-15","first_air_date":null,"status":"published","or