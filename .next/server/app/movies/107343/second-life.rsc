s":[{"width":1080,"height":1620,"file_path":"/ldTBSOK8czliedL8pb1FEsQ1TZQ.jpg","iso_639_1":"zh","vote_average":1.75},{"width":1080,"height":1620,"file_path":"/w8j0eIBIsUvmXPFTOj2YdQxr3ou.jpg","iso_639_1":"zh","vote_average":1.75},{"width":800,"height":1200,"file_path":"/p64uUsnt6xHWCsHqmBBLBEWEOFt.jpg","iso_639_1":"zh","vote_average":0.166},{"width":780,"height":1080,"file_path":"/eNuyQ2AbY7gITtelX36yVTYrWIH.jpg","iso_639_1":"vi","vote_average":0.166}],"backdrops":[{"width":1920,"height":1080,"file_path":"/1xa9po2DMkpA1084roW78TNncBQ.jpg","iso_639_1":"zh","vote_average":0},{"width":1280,"height":720,"file_path":"/vcdubpI9Oo1OQHECBmv8fcC31q.jpg","iso_639_1":"en","vote_average":0},{"width":1280,"height":720,"file_path":"/piEzktitgdYVQSLFmyN4mZeTP7Y.jpg","iso_639_1":"zh","vote_average":0}]},"enriched_at":"2026-04-21T05:20:02.479+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"重见天日","runtime":106,"tagline":"","homepage":"","overview":"讲述了女子监狱中令人闻风丧胆的“慈母”老梁（元秋饰）和青龙帮“昔日杀神”儿子阿鬼（伍允龙饰），在错误的时机错误相遇，却成就了一段彼此救赎、彼此成全的奇妙缘分，引发了一系列啼笑皆非却热血澎湃的乌龙事件。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Second Life","runtime":0,"tagline":"","homepage":"https://www.iq.com/album/second-life-2024-xxlxrt2rs0","overview":"28 years ago, Liang gives birth to a boy named \"Little Bean Jelly\" in prison. When the kid turns one, the mother and son lose contact. Years later, Green Dragon Group's henchman \"Ghost\" is ambushed during a mission and becomes blind. When Liang is released from prison, she meets Ghost. One wants only to complete the assassination, while the other wants to make amends to rebuild their mother-son relationship. By an unexpected combination of circumstances, this mother and son help each other redeem themselves and return to the right path."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"重見天日","runtime":0,"tagline":"","homepage":"","overview":"講述了女子監獄中令人聞風喪膽的“慈母”老梁（元秋飾）和青龍幫“昔日殺神”兒子阿鬼（伍允龍飾），在錯誤的時機錯誤相遇，卻成就了一段彼此救贖、彼此成全的奇妙緣分，引發了一系列啼笑皆非卻熱血澎湃的烏龍事件。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"중견천일","runtime":0,"tagline":"","homepage":"","overview":""},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Cuộc Đời Thứ 2","runtime":0,"tagline":"","homepage":"","overview":"Trong nhà tù nữ, “Chiến thần” Lão Lương (do Nguyên Thu thủ vai) – người khiến ai cũng khiếp sợ, và A Quỷ (do Ngô Vĩnh Long thủ vai) – sát thủ mù lòa của băng Thanh Long từng một thời nổi tiếng, vô tình gặp lại nhau. Từ đó, giữa hai mẹ con tại một tiệm thuốc Đông y đã xảy ra một loạt những cuộc đấu trí, đấu sức đầy kịch tính. Một người là bậc thầy võ học Đông y, đã thất lạc con trai nhiều năm, luôn mong muốn yêu thương con bằng cách tốt nhất; người kia là một đứa trẻ mồ côi bị băng đảng bỏ rơi, nay đã quay về gia đình nhưng lại luôn tìm cách ám sát mẹ mình. Cả hai gặp lại nhau trong hoàn cảnh sai lầm, thời điểm sai lầm, dẫn đến hàng loạt các màn đối đầu võ thuật đỉnh cao, gây ra những tình huống dở khóc dở cười nhưng cũng đầy nhiệt huyết, cuối cùng tạo nên một mối duyên kỳ diệu về sự cứu rỗi lẫn nhau và cùng hoàn thiện lẫn nhau."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"ตัวมัมประจำคุก","runtime":0,"tagline":"","homepage":"","overview":"เมื่อ 28 ปีที่แล้ว เหล่าเหลียงให้กำเนิดลูกชายชื่อ \"เสี่ยวเหลียงเฝิ่น\" ในคุก เมื่อลูกอายุได้ 1 ขวบ แม่และเด็กก็แยกจากกันไร้ซึ่งการติดต่อใด ๆ หลายปีต่อมา \"พี่กุ่ย\" นักสู้ของกลุ่มชิงหลงถูกลอบทำร้ายระหว่างปฏิบัติภารกิจและตาบอด เมื่อเหล่าเหลียงได้รับการปล่อยตัวจากคุก เขาได้พบกับอากุ่ย คนหนึ่งเพียงต้องการไขคดีฆาตกรรม ส่วนอีกคนต้องการชดเชยความสัมพันธ์ในครอบครัว ด้วยสถานการณ์ที่ไม่คาดคิด ทำให้แม่และลูกชายต้องชดเชยกันและกลับไปสู่เส้นทางที่ถูกต้อง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Вторая жизнь","runtime":106,"tagline":"","homepage":"","overview":""},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"}],"reviews_tmdb":[],"recommendations":[{"id":936245,"adult":false,"title":"Hidden Face","video":false,"overview":"Su-yeon, a cellist in an orchestra led by her fiancé and conductor Sung-jin, disappears one day, leaving behind only a video recording. Sung-jin is devasted over the loss of Su-yeon, but feels a strong attraction to Mi-ju, a cellist who fills in for his fiancée. Then one rainy night, Sung-jin and Mi-ju get swept away by their mutual desires for each other and commit an unforgivable act at Su-yeon's house.","genre_ids":[9648,53],"media_type":"movie","popularity":7.0325,"vote_count":61,"poster_path":"/slRaAeEWbU8gM834X10qNhBhVIv.jpg","release_date":"2024-11-20","vote_average":4.975,"backdrop_path":"/jgySLjw9ZDKbnGf0VlhlHT7iHSi.jpg","original_title":"히든페이스","original_language":"ko"},{"id":10481,"adult":false,"title":"102 Dalmatians","video":false,"overview":"Get ready for a howling good time as an all new assortment of irresistible animal heroes are unleashed in this great family tail! In an unlikely alliance, the outrageous Waddlesworth - a parrot who thinks he's a Rottweiler - teams up with Oddball - an un-marked Dalmatian puppy eager to earn her spots! Together they embark on a laugh-packed quest to outwit the ever-scheming Cruella De Vil.","genre_ids":[10751,35],"media_type":"movie","popularity":2.226,"vote_count":1448,"poster_path":"/ueE6u2GTECzGBtas6PFx7wwi9y0.jpg","release_date":"2000-10-07","vote_average":5.508,"backdrop_path":"/eqZ5t82asfprFcNS56eVruNT5G5.jpg","original_title":"102 Dalmatians","original_language":"en"},{"id":41446,"adult":false,"title":"Scream 4","video":false,"overview":"Fifteen years after the original Woodsboro murders, Sidney Prescott returns home to promote her new book about surviving trauma, only for a new Ghostface killer to emerge, targeting a new group of teens.","genre_ids":[27,9648],"media_type":"movie","popularity":9.3002,"vote_count":4055,"poster_path":"/tcrI37K98TVopLbcZBa55mWhLT1.jpg","release_date":"2011-04-13","vote_average":6.473,"backdrop_path":"/c5EmNhLQsTTKAyUHULnKYQjlloz.jpg","original_title":"Scream 4","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":29.365,"vote_count":26818,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.902,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":11324,"adult":false,"title":"Shutter Island","video":false,"overview":"World War II soldier-turned-U.S. Marshal Teddy Daniels investigates the disappearance of a patient from a hospital for the criminally insane, but his efforts are compromised by troubling visions and a mysterious doctor.","genre_ids":[18,53,9648],"media_type":"movie","popularity":14.7749,"vote_count":25448,"poster_path":"/nrmXQ0zcZUL8jFLrakWc90IR8z9.jpg","release_date":"2010-02-14","vote_average":8.2,"backdrop_path":"/8xt8AMb1OKC63AdhNSaYBWxB4Iq.jpg","original_title":"Shutter Island","original_language":"en"},{"id":9502,"adult":false,"title":"Kung Fu Panda","video":false,"overview":"Chosen by prophecy but doubted by all, Po is an unlikely Dragon Warrior—a clumsy panda thrust into the world of kung fu as a deadly enemy threatens the Valley of Peace. Guided by Master Shifu and the Furious Five, Po must embrace who he is to unlock the power that no scroll can teach.","genre_ids":[16,10751,35,28],"media_type":"movie","popularity":13.4344,"vote_count":12405,"poster_path":"/wWt4JYXTg5Wr3xBW2phBrMKgp3x.jpg","release_date":"2008-06-04","vote_average":7.315,"backdrop_path":"/qdthf9WrRDSaIkGVQGhhJ9pz1hn.jpg","original_title":"Kung Fu Panda","original_language":"en"},{"id":13510,"adult":false,"title":"Eden Lake","video":false,"overview":"When a young couple goes to a remote wooded lake for a romantic getaway, their quiet weekend is shattered by an aggressive group of local kids. Rowdiness quickly turns to rage as the teens terrorize the couple in unimaginable ways, and a weekend outing becomes a bloody battle for survival.","genre_ids":[27,53],"media_type":"movie","popularity":5.1689,"vote_count":2022,"poster_path":"/tOg6ElTe1mJwaCFN0172U4oso22.jpg","release_date":"2008-09-12","vote_average":6.831,"backdrop_path":"/s9v1QZMVhwShQ7415jPhtfqzyjG.jpg","original_title":"Eden Lake","original_language":"en"},{"id":110160,"adult":false,"title":"Laurence Anyways","video":false,"overview":"The story of an impossible love between a woman named Fred and a transgender woman named Laurence who reveals her inner desire to become her true self.","genre_ids":[18,10749],"media_type":"movie","popularity":2.2523,"vote_count":889,"poster_path":"/d8BpJ9qOQE7VFFqaV1XDdGfMsP7.jpg","release_date":"2012-05-18","vote_average":7.6,"backdrop_path":"/lNUP9ymEHolzjLIHyoAkpHRQZxq.jpg","original_title":"Laurence Anyways","original_language":"fr"},{"id":1498,"adult":false,"title":"Teenage Mutant Ninja Turtles","video":false,"overview":"A quartet of humanoid turtles, trained by their mentor in ninjitsu, must learn to work together to face the menace of Shredder and the Foot Clan.","genre_ids":[878,28,12,35,10751],"media_type":"movie","popularity":3.8285,"vote_count":1909,"poster_path":"/shfAU6xIIEAEtsloIT3n9Fscz2E.jpg","release_date":"1990-03-30","vote_average":6.702,"backdrop_path":"/qXM08jXRwlT9rm10iAC2uoq0Kn.jpg","original_title":"Teenage Mutant Ninja Turtles","original_language":"en"},{"id":2770,"adult":false,"title":"American Pie 2","video":false,"overview":"After a year apart - attending different schools, meeting different people - the guys rent a beach house and vow to make this the best summer ever. As it turns out, whether that will happen or not has a lot to do with the girls. Between the wild parties, outrageous revelations and yes, a trip to band camp, they discover that times change and people change, but in the end, it's all about sticking together.","genre_ids":[35,10749],"media_type":"movie","popularity":4.8459,"vote_count":5204,"poster_path":"/854ZZxXdeabAs90mrV72NqShJqR.jpg","release_date":"2001-08-10","vote_average":6.249,"backdrop_path":"/sgU7YubDFMosoJQLtcrBCcEG1sq.jpg","original_title":"American Pie 2","original_language":"en"},{"id":22538,"adult":false,"title":"Scott Pilgrim vs. the World","video":false,"overview":"As bass guitarist for a garage-rock band, Scott Pilgrim has never had trouble getting a girlfriend; usually, the problem is getting rid of them. But when Ramona Flowers skates into his heart, he finds she has the most troublesome baggage of all: an army of ex-boyfriends who will stop at nothing to eliminate him from her list of suitors.","genre_ids":[28,35,10749],"media_type":"movie","popularity":6.0739,"vote_count":8410,"poster_path":"/g5IoYeudx9XBEfwNL0fHvSckLBz.jpg","release_date":"2010-08-12","vote_average":7.485,"backdrop_path":"/4jSTo5o597cURiEROqi9pVCCSbg.jpg","original_title":"Scott Pilgrim vs. the World","original_language":"en"},{"id":11024,"adult":false,"title":"Scooby-Doo 2: Monsters Unleashed","video":false,"overview":"A masked villain wreaks mayhem on the city of Coolsville with a monster machine that creates real-life versions of Mystery Inc.'s former foes like The 10,000 Volt Ghost, The Cotton Candy Glob, The Skelemen and The Pterodactyl Ghost. Fred, Daphne, Shaggy, Velma and Scooby-Doo launch an investigation into the monster outbreak that leaves Shaggy and Scooby questioning their roles in Mystery Inc. Eager to prove their detective skills, the ever-ravenous duo comes up with a secret plan to solve the mystery all by themselves. Can the gang unravel their most challenging case?","genre_ids":[9648,12,35],"media_type":"movie","popularity":2.7879,"vote_count":2873,"poster_path":"/5BrXCJrs22bR5KR6mLHluYo6y4m.jpg","release_date":"2004-03-24","vote_average":6.092,"backdrop_path":"/m8y7OjvCBLmJfG6CIb5gpXFSLec.jpg","original_title":"Scooby-Doo 2: Monsters Unleashed","original_language":"en"},{"id":248705,"adult":false,"title":"The Visitors: Bastille Day","video":false,"overview":"Stuck in the corridors of time, Godefroy de Montmirail and his faithful servant Jacquouille are projected to a time of profound political and social upheavals: the French Revolution... specifically, The Terror, time of great dangers, during which the descendants of Godefroy and Jacquouille had their castle and all their property confiscated by arrogant aristocrats, fleeing and lifes hanging by a thread.","genre_ids":[35,14],"media_type":"movie","popularity":0.8219,"vote_count":712,"poster_path":"/z2AV9HgEjTPwY2FMzyqI36Wdqb7.jpg","release_date":"2016-03-23","vote_average":4.159,"backdrop_path":"/qfKTXby3fKjCKvt8M6uYD3l3SvD.jpg","original_title":"Les Visiteurs : La Révolution","original_language":"fr"},{"id":42949,"adult":false,"title":"Arthur 3: The War of the Two Worlds","video":false,"overview":"With Maltazard now seven feet tall and Arthur still two inches small, our hero must find a way to grow back to his normal size and stop the Evil M once and for all, with the help of Selenia and Betameche.","genre_ids":[16,12,14,10751],"media_type":"movie","popularity":2.1459,"vote_count":1590,"poster_path":"/wBT40NqmBz65WYmIGhDnWcgzPcA.jpg","release_date":"2010-08-22","vote_average":5.8,"backdrop_path":"/ArzlBZ7uPYl4GjNf950U57DUCmT.jpg","original_title":"Arthur 3: la guerre des deux mondes","original_language":"fr"},{"id":49012,"adult":false,"title":"Arthur","video":false,"overview":"A drunken playboy stands to lose a wealthy inheritance when he falls for a woman that his family doesn't like.","genre_ids":[35,10749],"media_type":"movie","popularity":1.3094,"vote_count":778,"poster_path":"/foUTAJurvnbUoIUbnuUk5dyHx7M.jpg","release_date":"2011-04-08","vote_average":5.5,"backdrop_path":"/p2h886S7r4znUYvp1ELOTq7jqUZ.jpg","original_title":"Arthur","original_language":"en"},{"id":1370,"adult":false,"title":"Rambo III","video":false,"overview":"Combat has taken its toll on Rambo, but he's finally begun to find inner peace in a monastery. When Rambo's friend and mentor Col. Trautman asks for his help on a top secret mission to Afghanistan, Rambo declines but must reconsider when Trautman is captured.","genre_ids":[28,12,53,10752],"media_type":"movie","popularity":5.1084,"vote_count":3405,"poster_path":"/uycbt9iVlAnKkQIisqUWuO8hVcm.jpg","release_date":"1988-05-24","vote_average":6.199,"backdrop_path":"/Afkcvov0y7osi6NwubwpPL6pfrA.jpg","original_title":"Rambo III","original_language":"en"},{"id":48769,"adult":false,"title":"Gramps Is in the Resistance","video":false,"overview":"It is 1943 in Paris. Like so many others, the Bourbelle family's home has been taken over by the Germans and they now live in their cellar. Little do they know that the son, Guy-Hubert Bourdelle, is far from being the cowardly hairdresser he pretends. He is in truth the Germans’ most feared opponent: le super-résistant!","genre_ids":[35,10752],"media_type":"movie","popularity":1.4318,"vote_count":429,"poster_path":"/tYAaRDKCHSofMnUDqjg6AIAmTfi.jpg","release_date":"1983-10-26","vote_average":6.865,"backdrop_path":"/gWP0xqcpeapXBqKKPFqLFc2rxDQ.jpg","original_title":"Papy fait de la résistance","original_language":"fr"},{"id":9387,"adult":false,"title":"Conan the Barbarian","video":false,"overview":"A horde of rampaging warriors massacre the parents of young Conan and enslave the young child for years on The Wheel of Pain. As the sole survivor of the childhood massacre, Conan is released from slavery and taught the ancient arts of fighting. Transforming himself into a killing machine, Conan travels into the wilderness to seek vengeance on Thulsa Doom, the man responsible for killing his family. In the wilderness, Conan takes up with the thieves Valeria and Subotai. The group comes upon King Osric, who wants the trio of warriors to help rescue his daughter who has joined Doom in the hills.","genre_ids":[12,14,28],"media_type":"movie","popularity":5.9972,"vote_count":2723,"poster_path":"/qw2A587Ee61IwcSOLNFRhuOACZZ.jpg","release_date":"1982-03-16","vote_average":6.8,"backdrop_path":"/6cYPpzjHcxcSaXEQc8s3sMbcfZS.jpg","original_title":"Conan the Barbarian","original_language":"en"},{"id":4232,"adult":false,"title":"Scream","video":false,"overview":"A year after the murder of her mother, a teenage girl is terrorized by a masked killer who targets her and her friends by using scary movies as part of a deadly game.","genre_ids":[80,27,9648],"media_type":"movie","popularity":17.0095,"vote_count":7705,"poster_path":"/lr9ZIrmuwVmZhpZuTCW8D9g0ZJe.jpg","release_date":"1996-12-20","vote_average":7.4,"backdrop_path":"/4w6nQYAY0eb7B0VVRDXilXcgAUV.jpg","original_title":"Scream","original_language":"en"},{"id":261023,"adult":false,"title":"Black Mass","video":false,"overview":"The true story of Whitey Bulger, the brother of a state senator and the most infamous violent criminal in the history of South Boston, who became an FBI informant to take down a Mafia family invading his turf.","genre_ids":[18,80,36],"media_type":"movie","popularity":3.3961,"vote_count":3532,"poster_path":"/zfwciv4LIJkNQsfuhYGv0Nkiweg.jpg","release_date":"2015-09-17","vote_average":6.526,"backdrop_path":"/mK4J2Qk4S4UQGOeMqsgei9DyPwW.jpg","original_title":"Black Mass","original_language":"en"}],"similar_content":[{"id":1259935,"adult":false,"title":"PENCOERIAN BALIK!","video":false,"overview":"","genre_ids":[28,12,36],"popularity":0.2327,"vote_count":0,"poster_path":"/k7N9jzlOK8Scz5S9VS2THtdF2e4.jpg","release_date":"2024-04-22","vote_average":0,"backdrop_path":"/2XGhoHdN5g3rqngdmWfTcROkRtY.jpg","original_title":"PENCOERIAN BALIK!","original_language":"id"},{"id":10222,"adult":false,"title":"Kickboxer","video":false,"overview":"If your enemy refuses to be humbled... Destroy him. Accompanied by his brother Kurt, American kickboxing champion Eric Sloane, arrives in Thailand to defeat the Eastern warriors at their own sport. His opponent: ruthless fighter and Thai champion, Tong Po. Tong not only defeats Eric, he paralyzes him for life. Crazed with anger, Kurt vows revenge.","genre_ids":[28,53,18],"popularity":5.4151,"vote_count":1540,"poster_path":"/tzEOkUn5708fQvF0bOPB5bLLRNk.jpg","release_date":"1989-04-20","vote_average":6.837,"backdrop_path":"/sl7hpSJR11FlfcewMJ6ihsbbAuJ.jpg","original_title":"Kickboxer","original_language":"en"},{"id":10228,"adult":false,"title":"Pokémon: The First Movie","video":false,"overview":"Determined to prove its superiority, a bio-engineered Pokémon called Mewtwo lures Ash, Pikachu and others into a Pokemon match like none before.","genre_ids":[16,10751,12,14,28],"popularity":5.5007,"vote_count":1549,"poster_path":"/xPW3AeK3iQi1Zd9dCbdNLijE48o.jpg","release_date":"1998-07-18","vote_average":6.9,"backdrop_path":"/eA0qc5ihjSKG05tdJO4QPgYPAwY.jpg","original_title":"劇場版ポケットモンスター ミュウツーの逆襲","original_language":"ja"},{"id":10252,"adult":false,"title":"Animal","video":false,"overview":"His name: infamous. His reputation: ruthless. But when James \"Animal\"Allen is locked up in a maximum security prison, he meets a revolutionary who changes his life. Now a reformed man, James is released only to find that his own son has assumed a life of crime and violence. Can a father haunted by his past redeem his family from the very streets he created, or will he be forced to make the ultimate sacrifice?","genre_ids":[28,18],"popularity":2.6181,"vote_count":48,"poster_path":"/f0r2kdF3TitkTxAwb0kKdsTfIvi.jpg","release_date":"2005-05-01","vote_average":5.6,"backdrop_path":"/2PYSbjodqH6ytgXaeDtWitFjK1l.jpg","original_title":"Animal","original_language":"en"},{"id":10270,"adult":false,"title":"The Challenge","video":false,"overview":"Welcome to the future. Civilization has been obliterated by natural catastrophes and global economic collapse. In the rotting skeletons of once great cities, the remnants of mankind struggle to survive under the brutal reign of vicious warlords who rule by fear and the power of the fist. The only hope for a courageous band of street urchins is the brave fighter Jonas, the last surviving keeper of the secrets of an ancient martial arts dynasty. Jonas must challenge the heartless Bosco in a fight for freedom or death ... only then can he become master of mankind's destiny.","genre_ids":[28],"popularity":0.365,"vote_count":18,"poster_path":"/dmGEcsuOdNscE8Lh8o8awk8hiCB.jpg","release_date":"2005-01-01","vote_average":5,"backdrop_path":"/naSQoPLn3qYjLrtOdLJ5PjhFzNw.jpg","original_title":"Kampfansage - Der letzte Schüler","original_language":"de"},{"id":10275,"adult":false,"title":"Shaolin Temple","video":false,"overview":"The Tang emperor is betrayed by one of his generals, who installs himself as emperor in the East Capital. The son of one of his slave workers escapes to the Shaolin Temple, learns kung fu, and sets out to kill the traitor who killed his father.","genre_ids":[28],"popularity":1.335,"vote_count":136,"poster_path":"/mKt2c9nvc9qHIoa530XdZi4X1WZ.jpg","release_date":"1982-01-21","vote_average":7.004,"backdrop_path":"/iAzySCUzm0GOEMM6MgM3WzvJ246.jpg","original_title":"少林寺","original_language":"zh"},{"id":10315,"adult":false,"title":"Fantastic Mr. Fox","video":false,"overview":"The Fantastic Mr. Fox, bored with his current life, plans a heist against the three local farmers. The farmers, tired of sharing their chickens with the sly fox, seek revenge against him and his family.","genre_ids":[12,16,35,10751],"popularity":7.9017,"vote_count":5953,"poster_path":"/euZyZb6iGreujYKrGyZHRddhUYh.jpg","release_date":"2009-10-14","vote_average":7.813,"backdrop_path":"/pKqGRxoQgrIk3nLJ3jxYyIzbCMo.jpg","original_title":"Fantastic Mr. Fox","original_language":"en"},{"id":10377,"adult":false,"title":"My Cousin Vinny","video":false,"overview":"Two carefree pals traveling through rural Alabama on their way back to college are mistakenly arrested and charged with murder. Fortunately, one of them has a cousin who's a lawyer - Vincent Gambini, a former auto mechanic from Brooklyn who has just passed his bar exam after his sixth try. When he arrives with his leather-clad girlfriend to try his first case, it's a real shock - for him and the Deep South!","genre_ids":[35,18],"popularity":3.7746,"vote_count":1803,"poster_path":"/iwSURa8nS2ujwrU3s1lfxxX7voH.jpg","release_date":"1992-03-13","vote_average":7.504,"backdrop_path":"/uEoaOfvWibpvjBNxFoj4MxWn0OH.jpg","original_title":"My Cousin Vinny","original_language":"en"},{"id":10378,"adult":false,"title":"Big Buck Bunny","video":false,"overview":"Follow a day of the life of Big Buck Bunny when he meets three bullying rodents: Frank, Rinky, and Gamera. The rodents amuse themselves by harassing helpless creatures by throwing fruits, nuts and rocks at them. After the deaths of two of Bunny's favorite butterflies, and an offensive attack on Bunny himself, Bunny sets aside his gentle nature and orchestrates a complex plan for revenge.","genre_ids":[16,35,10751],"popularity":0.5638,"vote_count":194,"poster_path":"/i9jJzvoXET4D9pOkoEwncSdNNER.jpg","release_date":"2008-04-10","vote_average":6.497,"backdrop_path":"/xtdybjRRZ15mCrPOvEld305myys.jpg","original_title":"Big Buck Bunny","original_language":"en"},{"id":10381,"adult":false,"title":"Plunkett & MacLeane","video":false,"overview":"Will Plunkett and Captain James Macleane, two men from different ends of the social spectrum in 18th-century England, enter a gentlemen's agreement: They decide to rid the aristocrats of their belongings. With Plunkett's criminal know-how and Macleane's social connections, they team up to be soon known as \"The Gentlemen Highwaymen\". But when one day these gentlemen hold up Lord Chief Justice Gibson's coach, Macleane instantly falls in love with his beautiful and cunning niece, Lady Rebecca Gibson. Unfortunately, Thief Taker General Chance, who also is quite fond of Rebecca, is getting closer and closer to getting both.","genre_ids":[28,35,18],"popularity":3.3975,"vote_count":149,"poster_path":"/9LASEwSyW2h7Zql0t1ksURC70MG.jpg","release_date":"1999-01-22","vote_average":6.081,"backdrop_path":"/tKQH4kTV9PHtDTghmlPTiLVMuWE.jpg","original_title":"Plunkett & MacLeane","original_language":"en"},{"id":10385,"adult":false,"title":"Hanging Up","video":false,"overview":"Three sisters - Georgia, Eve, and Maddy - do what they do best with life, love, and lunacy on the telephone lines that bind - when their curmudgeonly father, Lou, is admitted to a Los Angeles Hospital. After years of wild living, intermittent affection, and constant phoning, he is finally threatening to die.","genre_ids":[18,35],"popularity":1.432,"vote_count":184,"poster_path":"/lnnFFGhIXi6ZDU3r29eKHKTHdq0.jpg","release_date":"2000-02-16","vote_average":5.3,"backdrop_path":"/9I9VYNau1KU77OQAcF6WnfOtGcU.jpg","original_title":"Hanging Up","original_language":"en"},{"id":10394,"adult":false,"title":"Gangster No. 1","video":false,"overview":"An old gangster is advised that Freddie Mays would leave jail after thirty years in prison. His mood changes and he recalls when he was a young punk and who joined Freddie's gang—a man he both envied and ultimately betrayed.","genre_ids":[28,18,53,80],"popularity":1.1193,"vote_count":228,"poster_path":"/t8eUSsD2reaIR9qmklU7O2GCVn4.jpg","release_date":"2000-06-09","vote_average":6.384,"backdrop_path":"/8zmWwgtiPCWBzxCiRHdmBZoPvXc.jpg","original_title":"Gangster No. 1","original_language":"en"},{"id":470408,"adult":false,"title":"Le Médecin malgré lui","video":false,"overview":"","genre_ids":[35,10770],"popularity":0.1654,"vote_count":0,"poster_path":"/qcLxHpLreanszkXgxfC86PG8mqa.jpg","release_date":"1973-08-31","vote_av