9:{"metadata":[["$","title","0",{"children":"Second Life | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"28 years ago, Liang gives birth to a boy named \"Little Bean Jelly\" in prison. When the kid turns one, the mother and son lose contact. Years later, Green Dragon Group's henchman \"Ghost\" is ambushed during a mission and becomes blind. When Liang is released from prison, she meets Ghost. One wants only to complete the assassination, while the other wants to make amends to rebuild their mother-son relationship. By an unexpected combination of circumstances, this mother and son help each other redeem themselves and return to the right path."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/107343/second-life"}],["$","meta","5",{"property":"og:title","content":"Second Life"}],["$","meta","6",{"property":"og:description","content":"28 years ago, Liang gives birth to a boy named \"Little Bean Jelly\" in prison. When the kid turns one, the mother and son lose contact. Years later, Green Dragon Group's henchman \"Ghost\" is ambushed during a mission and becomes blind. When Liang is released from prison, she meets Ghost. One wants only to complete the assassination, while the other wants to make amends to rebuild their mother-son relationship. By an unexpected combination of circumstances, this mother and son help each other redeem themselves and return to the right path."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/107343/second-life"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/ldTBSOK8czliedL8pb1FEsQ1TZQ.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Second Life"}],["$","meta","12",{"name":"twitter:description","content":"28 years ago, Liang gives birth to a boy named \"Little Bean Jelly\" in prison. When the kid turns one, the mother and son lose contact. Years later, Green Dragon Group's henchman \"Ghost\" is ambushed during a mission and becomes blind. When Liang is released from prison, she meets Ghost. One wants only to complete the assassination, while the other wants to make amends to rebuild their mother-son relationship. By an unexpected combination of circumstances, this mother and son help each other redeem themselves and return to the right path."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/ldTBSOK8czliedL8pb1FEsQ1TZQ.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
