9:{"metadata":[["$","title","0",{"children":"Don't Follow Me | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Obsessed with going viral with her videos of ghosts and paranormal events, aspiring influencer Carla moves into a famous haunted building. There, she begins faking ghostly apparitions to gain more followers, unaware that a real evil entity resides in her apartment and will torment her until no one, not even she, can distinguish what's real and what isn't."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148359/don-t-follow-me"}],["$","meta","5",{"property":"og:title","content":"Don't Follow Me"}],["$","meta","6",{"property":"og:description","content":"Obsessed with going viral with her videos of ghosts and paranormal events, aspiring influencer Carla moves into a famous haunted building. There, she begins faking ghostly apparitions to gain more followers, unaware that a real evil entity resides in her apartment and will torment her until no one, not even she, can distinguish what's real and what isn't."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148359/don-t-follow-me"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/wBYicLV0zfdtXweWXcoiou3moNu.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Don't Follow Me"}],["$","meta","12",{"name":"twitter:description","content":"Obsessed with going viral with her videos of ghosts and paranormal events, aspiring influencer Carla moves into a famous haunted building. There, she begins faking ghostly apparitions to gain more followers, unaware that a real evil entit