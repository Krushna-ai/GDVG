.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3010,"height":1693,"file_path":"/xhqjm9ykAjk4JbfCNkH4iddVYL9.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2995,"height":1685,"file_path":"/7rqelh5QM8oBXI86H5wkHqM11oB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2894,"height":1628,"file_path":"/iWVpLzyFVRoyE1xqAGmpMoXMyhT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2990,"height":1682,"file_path":"/kpfmZ3owhiiFVffWazGlAIfvMPY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2986,"height":1680,"file_path":"/daTXght7sKdT4gV2npdpZJV0hOQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1280,"height":720,"file_path":"/zoEuFnbRasYz0fJHKicVLGzaVXg.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T06:49:10.296+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":83,"tagline":"Follow. Like. Die.","homepage":"","overview":"Carla sueña con convertirse en una gran influencer, para lograrlo decide fingir un embasa en su apartamento. Sin embargo, al jugar con estas fuerzas oscuras, accidentalmente deja entrar a una entidad maligna real."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Don't Follow Me","runtime":83,"tagline":"Follow. Like. Die.","homepage":"","overview":"Obsessed with going viral with her videos of ghosts and paranormal events, aspiring influencer Carla moves into a famous haunted building. There, she begins faking ghostly apparitions to gain more followers, unaware that a real evil entity resides in her apartment and will torment her until no one, not even she, can distinguish what's real and what isn't."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":83,"tagline":"","homepage":"","overview":"Carla sueña con convertirse en una gran influencer, para lograrlo decide fingir un embasa en su apartamento. Sin embargo, al jugar con estas fuerzas oscuras, accidentalmente deja entrar a una entidad maligna real."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Инферно","runtime":0,"tagline":"","homepage":"","overview":"Одержимая идеей стать вирусной благодаря своим видеороликам о призраках и паранормальных явлениях, начинающая блогерша Карла переезжает в знаменитое здание с привидениями. Там она начинает изображать духов, чтобы привлечь больше подписчиков, не подозревая, что в доме обитает настоящая злая сущность и будет мучить её до тех пор, пока никто, даже она сама, не сможет отличить, что реально, а что нет."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Obcecada por viralizar com os seus vídeos de fantasmas e eventos paranormais, a aspirante a influenciadora Carla muda-se para um prédio famoso por ser assombrado. Lá, ela começa a fingir aparições fantasmagóricas para ganhar mais seguidores, sem saber que uma entidade maligna real reside no seu apartamento e a atormentará até que ninguém, nem mesmo ela, consiga distinguir o que é real do que não é."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"千万不要跟着我","runtime":0,"tagline":"","homepage":"","overview":"怀揣着成为网红的梦想，卡拉痴迷于让自己拍摄的鬼魂和超自然事件视频走红，于是搬进了一栋著名的闹鬼大楼。在那里，她开始伪造鬼魂现身的景象，以期获得更多粉丝，却没意识到她的公寓里住着一个真正的邪恶实体，这个实体将会不断折磨她，直到所有人，甚至包括她自己，都无法分辨真假。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Obsédée par l'idée de devenir virale grâce à ses vidéos de fantômes et d'événements paranormaux, Carla, une influenceuse en herbe, emménage dans un immeuble hanté réputé. Là, elle commence à simuler des apparitions fantomatiques pour gagner des abonnés, ignorant qu'une véritable entité maléfique réside dans son appartement et la tourmentera jusqu'à ce que plus personne, pas même elle, ne puisse distinguer le réel de l'imaginaire."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"鬼追蹤","runtime":0,"tagline":"","homepage":"","overview":"網紅卡拉經營靈異與超自然頻道，為了追求流量與關注，她在暗戀對象安德烈斯的幫助下，搬進墨西哥盛傳鬧鬼的老舊公寓裡，並邀請在網路上小有名氣的好友一起拍片，試圖自導自演各種超自然事件。隨著影片流傳，卡拉的頻道竄紅。然而，在名氣來臨的同時，家中也開始出現難以解釋的詭異身影。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Não Me Siga","runtime":0,"tagline":"","homepage":"","overview":"Uma jovem de 26 anos sonha em se tornar uma grande influenciadora. Ela decide fingir um encantamento em seu apartamento. No entanto, ao brincar com essas forças sombrias, acaba deixando entrar acidentalmente uma entidade maligna real."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"}],"reviews_tmdb":[],"recommendations":[{"id":29514,"adult":false,"title":"Two Evil Eyes","video":false,"overview":"A duo of Edgar Allan Poe adaptations about a greedy wife's attempt to embezzle her dying husband's fortune, and a sleazy reporter's adoption of a strange black cat.","genre_ids":[27],"media_type":"movie","popularity":2.0732,"vote_count":324,"poster_path":"/zVWaQfaSZ7AWE0XqbMT57szVmXo.jpg","release_date":"1990-01-25","vote_average":6.133,"backdrop_path":"/wWucXwUmJiA5iUNqegJHbcy2Mzy.jpg","original_title":"Due occhi diabolici","original_language":"en"},{"id":1099088,"adult":false,"title":"Rewind 2: 1996","video":false,"overview":"When Marty's car is stolen, he sets out on a mission to find it; however, he soon realizes that the person who stole it is much more dangerous than he thinks.","genre_ids":[27,35],"media_type":"movie","popularity":0.1862,"vote_count":13,"poster_path":"/6OaIG3MlMjdDuOrnHQ1bsiUGNFa.jpg","release_date":"2022-12-23","vote_average":3.538,"backdrop_path":"/2dvJYzfe7ZKcPbJKX9W6afuSOaI.jpg","original_title":"Rewind 2: 1996","original_language":"en"},{"id":1133564,"adult":false,"title":"Rewind 3: The Final Chapter","video":false,"overview":"An unfortunate highschooler finds an ancient book that summons Allentown's deadliest maniacs back from the dead.","genre_ids":[27,28],"media_type":"movie","popularity":0.0874,"vote_count":12,"poster_path":"/dkA7kdMnpYH4qHOtmLqLCBfn7Cs.jpg","release_date":"2023-08-17","vote_average":5.333,"backdrop_path":"/3RvmiJTzarRJQDKfIqBHMDtzY1y.jpg","original_title":"Rewind 3: The Final Chapter","original_language":"en"},{"id":591275,"adult":false,"title":"Fear Street: 1666","video":false,"overview":"In 1666, a colonial town is gripped by a hysterical witch-hunt that has deadly consequences for centuries to come, and it's up to teenagers in 1994 to finally put an end to their town's curse, before it's too late.","genre_ids":[9648,27],"media_type":"movie","popularity":1.7374,"vote_count":1949,"poster_path":"/rmEPtz3Ufzol2VWUAZYzOFaBio3.jpg","release_date":"2021-07-14","vote_average":7.092,"backdrop_path":"/jLeOzQLZJEpmAMDnfKMmORFGuV.jpg","original_title":"Fear Street: 1666","original_language":"en"},{"id":942,"adult":false,"title":"Lethal Weapon 2","video":false,"overview":"Riggs and Murtaugh are on the trail of South African diplomats using their immunity to engage in criminal activities.","genre_ids":[28,53,80],"media_type":"movie","popularity":5.8273,"vote_count":3657,"poster_path":"/ZsUGxTnZ4TzTrHSAfUPJcliL1K.jpg","release_date":"1989-07-07","vote_average":7.026,"backdrop_path":"/zjRkl5PZvFujbRndrNbf4ZKbeNC.jpg","original_title":"Lethal Weapon 2","original_language":"en"},{"id":66489,"adult":false,"title":"Bad","video":false,"overview":"Hazel runs a beauty salon out of her house, but makes extra money by providing ruthless women the oppurtunity to perform hit jobs. L.T. is a parasite, and contacts Hazel looking for work after he runs out of money. She is reluctant to use him for a hit, since she prefers using women, but decides to try him on a trial basis. Meanwhile, the cop she pays off wants an arrest to make it look like he's doing his job, but Hazel doesn't want to sacrifice any of her \"associates\". The sleazy side of life is explored in this delightfully dark and deadpan film.","genre_ids":[27,35,80],"media_type":"movie","popularity":3.1285,"vote_count":52,"poster_path":"/jEO4qgv3KXRoEPg3wEJKX7ITD7O.jpg","release_date":"1977-05-04","vote_average":6.3,"backdrop_path":"/bTIuMOGh4RW3jLyHvVjrrKi7jY7.jpg","original_title":"Bad","original_language":"en"},{"id":437544,"adult":false,"title":"People","video":false,"overview":"Six vignettes pit an assortment of characters against each other in everyday situations.","genre_ids":[18],"media_type":"movie","popularity":1.3974,"vote_count":9,"poster_path":"/tXKAlTxGsiMkmomgXouIUU26gmt.jpg","release_date":"2016-04-22","vote_average":5.9,"backdrop_path":"/e125vbf6UsyfwYU3tlAAKu8D9jx.jpg","original_title":"People","original_language":"en"},{"id":359628,"adult":false,"title":"Assassination Classroom: Graduation","video":false,"overview":"A mysterious creature destroys part of the moon and then warns that if it is not destroyed before March of the following year, Earth will be next. It also demands to become the homeroom teacher of Class E, a third-year class at Kunugigaoka High School. As the deadline for the assassination and the date of the end of the world approach, the students discover their true abilities and Koro-sensei's shocking identity.","genre_ids":[35,28,878],"media_type":"movie","popularity":1.0755,"vote_count":103,"poster_path":"/77fTE8nJY5ZMm7b4Nk8ntBC6ccf.jpg","release_date":"2016-03-25","vote_average":7.121,"backdrop_path":"/5vdlA9FvBqrqZVaeeMWCkdj8nWO.jpg","original_title":"暗殺教室 卒業編","original_language":"ja"},{"id":755812,"adult":false,"title":"Miraculous World: New York, United HeroeZ","video":false,"overview":"Marinette’s class is headed to New York, the city of superheroes, for French-American Friendship Week.","genre_ids":[16,10751,10770,28,12],"media_type":"movie","popularity":2.1916,"vote_count":1121,"poster_path":"/9YbyvcrHmY2SVbdfXpb8mC4Fy0g.jpg","release_date":"2020-09-25","vote_average":8.1,"backdrop_path":"/2BZ7PC9aISswNXV2tugmjGiriaB.jpg","original_title":"Miraculous World : New York, les héros unis","original_language":"fr"},{"id":688335,"adult":false,"title":"Close Encounters of the Fifth Kind","video":false,"overview":"Dr. Steven Greer’s previous works, SIRIUS and UNACKNOWLEDGED, broke crowdfunding records and ignited a grassroots movement. CLOSE ENCOUNTERS OF THE FIFTH KIND features groundbreaking video and photographic evidence and supporting interviews from prominent figures such as Adam Curry of Princeton’s PEAR Lab; legendary civil rights attorney Daniel Sheehan, and Dr. Russell Targ, who headed the CIA’s top secret remote viewing program. Their message: For thousands of people, contact has begun. This is their story.","genre_ids":[99],"media_type":"movie","popularity":0.4859,"vote_count":92,"poster_path":"/R0rmE1wDbxMb2W0MyDE3HKPhOR.jpg","release_date":"2020-04-07","vote_average":6.967,"backdrop_path":"/efiDNmExd9GweIqmQKcwIt09hi7.jpg","original_title":"Close Encounters of the Fifth Kind","original_language":"en"},{"id":13649,"adult":false,"title":"High School Musical 2","video":false,"overview":"The East High Wildcats are gearing up for big fun as they land the coolest summer jobs imaginable. Troy, Gabriella, Chad, and Taylor have scored sweet gigs at the Lava Springs Country Club owned by Sharpay and Ryan's family. Sharpay's first rule of business: Get Troy. As Troy experiences a life of privilege he's never known, will he give up the Wildcats and Gabriella to rise to the top?","genre_ids":[35,18,10751,10402,10749,10770],"media_type":"movie","popularity":2.0614,"vote_count":3838,"poster_path":"/la2kiVWDm