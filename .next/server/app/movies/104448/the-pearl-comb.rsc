5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Pearl Comb\",\"description\":\"A doctor, hell-bent on proving a woman’s place is in the home and not practising medicine, is sent to investigate her miraculous claim - only to discover the source of her unearthly power...\",\"image\":\"https://image.tmdb.org/t/p/w500/737hppvYVz8Wx9I2McyQPHCD7PB.jpg\",\"datePublished\":\"2025-03-06\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"GB\",\"inLanguage\":\"en\",\"genre\":[\"Horror\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.5,\"bestRating\":10,\"ratingCount\":3}}"}}],["$","$L10",null,{"initialDrama":{"id":"2599697e-a4d3-4a28-ac72-f0cc67600ae3","tmdb_id":1445698,"imdb_id":"tt33019528","content_type":"movie","title":"The Pearl Comb","original_title":"The Pearl Comb","overview":"A doctor, hell-bent on proving a woman’s place is in the home and not practising medicine, is sent to investigate her miraculous claim - only to discover the source of her unearthly power...","poster_path":"/737hppvYVz8Wx9I2McyQPHCD7PB.jpg","backdrop_path":"/wNyAyZ7M9dtOo6tbx1OVigLGdBf.jpg","release_date":"2025-03-06","first_air_date":null,"status":"published","original_language":"en","origin_country":["GB"],"genres":[{"id":27,"name":"Horror"}],"popularity":4.8082,"vote_average":7.5,"vote_count":3,"runtime":21,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:54:18.500048+00:00","updated_at":"2026-02-21T07:32:01.297+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":74390,"name":"Stigma Films","logo_path":"/dP2JoIyAHBGp2V9r0r8LkHcGXHP.png","origin_country":"GB"}],"production_countries":[{"name":"United Kingdom","iso_3166_1":"GB"}],"spoken_languages":[{"name":"English","iso_639_1":"en","english_name":"English"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","cont