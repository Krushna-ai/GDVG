?locale=RS","flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":6}]},"SE":{"link":"https://www.themoviedb.org/movie/1445698-the-pearl-comb/watch?locale=SE","flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":0}]},"SI":{"link":"https://www.themoviedb.org/movie/1445698-the-pearl-comb/watch?locale=SI","flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":6}]},"SK":{"link":"https://www.themoviedb.org/movie/1445698-the-pearl-comb/watch?locale=SK","flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":0}]},"SM":{"link":"https://www.themoviedb.org/movie/1445698-the-pearl-comb/watch?locale=SM","flatrate":[{"logo_path":"/97yvRBw1GzX7fXprcF80er19ot.jpg","provider_id":337,"provider_name":"Disney Plus","display_priority":23}]}}},"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"WESTERN","main_poster":"/cL4HB3LnQPFs7UUmCtcNSTzbobD.jpg","images":{"logos":[],"posters":[{"width":1395,"height":2048,"file_path":"/cL4HB3LnQPFs7UUmCtcNSTzbobD.jpg","iso_639_1":null,"vote_average":3.334},{"width":736,"height":1080,"file_path":"/737hppvYVz8Wx9I2McyQPHCD7PB.jpg","iso_639_1":"en","vote_average":3.334},{"width":1272,"height":1866,"file_path":"/s8uEybLq4eUihYdu90tqLJRzSGg.jpg","iso_639_1":null,"vote_average":0},{"width":1476,"height":2197,"file_path":"/3ErVo0nwAJfV89Oh0RHbN4oCjXQ.jpg","iso_639_1":"en","vote_average":0},{"width":1000,"height":1500,"file_path":"/hUTWq36T3b6LCWDhqOK6WsIdf08.jpg","iso_639_1":"ru","vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/wNyAyZ7M9dtOo6tbx1OVigLGdBf.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T07:37:36.286+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":21,"tagline":"","homepage":"","overview":"A doctor, hell-bent on proving a woman’s place is in the home and not practising medicine, is sent to investigate her miraculous claim - only to discover the source of her unearthly power..."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":20,"tagline":"","homepage":"","overview":"En 1893, l'attachante épouse d'un pêcheur des Cornouailles attire l'attention du corps médical : elle est la première personne à guérir quelqu'un de la tuberculose. Un médecin, déterminé à prouver que la place d'une femme est au foyer et non en médecine, est envoyé enquêter sur ce prétendu miracle, mais il découvrira la source de son pouvoir surnaturel."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Rok 1893. Urocza żona rybaka z Kornwalii zyskuje rozgłos, gdy jako pierwsza w historii leczy chorego na gruźlicę. Sceptyczny lekarz, przekonany, że miejsce kobiety jest w kuchni, przybywa, by zbadać ten cudowny przypadek. Jednak niespodziewanie odkrywa źródło nieziemskich mocy kobiety."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"En 1893, la encantadora esposa de un pescador de Cornualles se convierte en la primera persona en curar a alguien de tuberculosis. Un médico, decidido a demostrar que el lugar de la mujer es el hogar, es enviado a investigar su milagroso logro, solo para descubrir la fuente de su poder sobrenatural."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"În 1893, soția unui pescar din Cornwall uimește lumea medicală: e prima persoană care vindecă tuberculoza. Un medic, convins că locul femeii e la cratiță, e trimis să-i investigheze leacul miraculos. Ajuns acolo, el descoperă sursa puterii ei nepământene."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Жемчужный гребень","runtime":0,"tagline":"","homepage":"","overview":"Врач, одержимый идеей доказать, что место женщины - дома, а не в медицине, отправляется расследовать её заявление о чудесах - только для того, чтобы обнаружить источник неземной силы..."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"En 1893, la encantadora esposa de un pescador de Cornualles se convierte en la primera persona en curar a alguien de tuberculosis. Un médico, decidido a demostrar que el lugar de la mujer es el hogar, es enviado a investigar su milagroso logro, solo para descubrir la fuente de su poder sobrenatural."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Lékař, odhodlaný dokázat, že místo ženy je v domácnosti a ne v lékařské praxi, je vyslán, aby prošetřil její zázračné tvrzení – jen aby odhalil zdroj její nadpřirozené síly..."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[{"id":594872,"adult":false,"title":"Rautakylän vanha parooni","video":false,"overview":"The Drakenhjelm family has lived in the Rautakylä manor for over 150 years. The current master of the house, elderly baron Magnus, has been living for a long time in an unregistered relationship with his housekeeper Lisette, with whom he also has a son, Sebastian. After the baron falls gravely ill Lisette starts getting worried about losing everything, so with Sebastian on her side she demands the baron to write a letter to the pastor and ask him to come over to perform a wedding ceremony. Right after Sebastian has left to fetch the pastor, a threesome seeking shelter from the storm comes to the manor and wreaks havoc on the marriage plans.","genre_ids":[18,27],"popularity":0.167,"vote_count":1,"poster_path":"/8C1LfqIj2KHshcCg8jssCJWRcVs.jpg","release_date":"1923-04-01","vote_average":5,"backdrop_path":null,"original_title":"Rautakylän vanha parooni","original_language":"fi"},{"id":9095,"adult":false,"title":"Mary Reilly","video":false,"overview":"A housemaid falls in love with Dr. Jekyll and his darkly mysterious counterpart, Mr. Hyde.","genre_ids":[18,27,53],"popularity":1.0557,"vote_count":336,"poster_path":"/cW5wTiv5fdtBOd22utmAIZBCMS3.jpg","release_date":"1996-02-23","vote_average":5.757,"backdrop_path":"/mErnrp6gxgSw7eYVnuos3k8EkWf.jpg","original_title":"Mary Reilly","original_language":"en"},{"id":9608,"adult":false,"title":"The Legend of Sleepy Hollow","video":false,"overview":"Ichabod Crane, a Yankee wanderer, arrives in Sleepy Hollow and becomes the new schoolmaster. He meets Katrina Van Tassel, and blissfully fantasizes about how can marry her, ultimately, inherit her father's rich estate. Her suitor Brom Bones, the blacksmith, wants to scare him away and dresses up as the legendary Headless Horseman. During the prank, the real ghost appears and drives Ichabod off","genre_ids":[14,27,9648],"popularity":0.3464,"vote_count":23,"poster_path":"/2Ac7FIoV5pVkMm6EZBqgzh1iUDR.jpg","release_date":"1999-10-23","vote_average":5.63,"backdrop_path":"/dgmF11HX6rVosnsTyzHpAQPIv4C.jpg","original_title":"The Legend of Sleepy Hollow","original_language":"en"},{"id":628,"adult":false,"title":"Interview with the Vampire","video":false,"overview":"A vampire relates his epic life story of love, betrayal, loneliness, and dark hunger to an over-curious reporter.","genre_ids":[27,18,14],"popularity":6.6281,"vote_count":6304,"poster_path":"/2162lAT2MP36MyJd2sttmj5du5T.jpg","release_date":"1994-11-11","vote_average":7.384,"backdrop_path":"/3fChciF2G1wXHsyTfJD9y7uN6Il.jpg","original_title":"Interview with the Vampire","original_language":"en"},{"id":426063,"adult":false,"title":"Nosferatu","video":false,"overview":"A gothic tale of obsession between a haunted young woman and the terrifying vampire infatuated with her, causing untold horror in its wake.","genre_ids":[27,14],"popularity":9.944,"vote_count":3451,"poster_path":"/5qGIxdEO841C0tdY8vOdLoRVrr0.jpg","release_date":"2024-12-25","vote_average":6.7,"backdrop_path":"/fYnEbgoNCxW9kL0IgOgtJb9JTBU.jpg","original_title":"Nosferatu","original_language":"en"},{"id":1304433,"adult":false,"title":"Sweeney Todd: The Demon Barber of Fleet Street","video":false,"overview":"In 1846, Anthony Hope sails into London with the mysterious Sweeney Todd, a once-naive barber whose life and marriage was uprooted by a corrupt justice system. Todd confides in Nellie Lovett, the owner of a local meat pie shop, and the two become partners, as Todd swears revenge on those that have wronged him and decides to take up his old profession.","genre_ids":[27,53,10770],"popularity":0.1909,"vote_count":1,"poster_path":"/sAi3NFHYeuWOxZfEf3DonuoOytl.jpg","release_date":"1995-10-31","vote_average":10,"backdrop_path":"/5rAB4eCZOo5bMIVjw0EIXDIfpN2.jpg","original_title":"Sweeney Todd: El Barber Diabòlic del Carrer Fleet","original_language":"ca"},{"id":1142204,"adult":false,"title":"Hoffmann's Eyes","video":false,"overview":"A retelling of E.T.A Hoffmann's gothic story \"The Sandman\" and the opera \"Tales of Hoffmann\", ever since childhood, Hoffmann has been haunted by The Sandman and believed that a visitor to his father was really The Sandman, while traveling to Veneice he encounters a strange glass vendor who reappears through out his life. This film was never completed.","genre_ids":[16,18,27,14],"popularity":0.5736,"vote_count":0,"poster_path":"/4akCcopdyRz34Y5QkyxuWMyGdXn.jpg","release_date":"1993-01-01","vote_average":0,"backdrop_path":"/An23x14Euj8SHv6oIEB0OpO8HZm.jpg","original_title":"Hoffmanns Ögon","original_language":"sv"},{"id":11773,"adult":false,"title":"Village of the Damned","video":false,"overview":"In a small English village everyone suddenly falls unconscious. When they awake every woman of child bearing age is pregnant. The resulting children have the same strange blond hair, eyes and a strong connection to each other.","genre_ids":[27,878],"popularity":0.8511,"vote_count":483,"poster_path":"/qcpXud1UjQzlSe9A062w8Wqgira.jpg","release_date":"1960-06-16","vote_average":7.185,"backdrop_path":"/tlQ2OBQAC7woOTZgk1vE9U69vQT.jpg","original_title":"Village of the Damned","original_language":"en"},{"id":11366,"adult":false,"title":"Uzumaki","video":false,"overview":"The inhabitants of a small Japanese town become increasingly obsessed with and tormented by spirals.","genre_ids":[9648,14,27],"popularity":1.0182,"vote_count":255,"poster_path":"/71SkvX0U1FinnoQkDAtrNyrYhtT.jpg","release_date":"2000-02-11","vote_average":5.9,"backdrop_path":"/ju66IP5AkqoHthl0T7efb7qosnS.jpg","original_title":"うずまき","original_language":"ja"},{"id":1306764,"adult":false,"title":"Outside","video":false,"overview":"A family retreats to an isolated farm during a zombie outbreak, but years of painful secrets take a toll as they navigate their desolate world.","genre_ids":[27,53],"popularity":1.545,"vote_count":152,"poster_path":"/mPfPeTe1hEdWwJBOnuuPZdfYGsl.jpg","release_date":"2024-10-16","vote_average":6.171,"backdrop_path":"/AeGgtElKvBQY9f9350fztaGLAvH.jpg","original_title":"Outside","original_language":"tl"},{"id":778211,"adult":false,"title":"Harp Brothers","video":false,"overview":"A film about America’s first serial killers. These brothers terrorized Kentucky and went across the state on a killing spree. The film is loosely based on the true story of the brothers. Filmed in historically accurate locations.","genre_ids":[27,36,80],"popularity":0.1803,"vote_count":0,"poster_path":"/e4ymAOiZ4k8VcfHdWzVGQhT3L1a.jpg","release_date":"2020-09-05","vote_average":0,"backdrop_path":null,"original_title":"Harp Brothers","original_language":"en"},{"id":432713,"adult":false,"title":"Murrain","video":false,"overview":"When a mystery illness infects the pigs of a village farmer and a local boy is also taken ill, the villagers try to convince a veterinarian that it is caused by a curse from a woman they believe to be a witch.","genre_ids":[18,27,9648,10770],"popularity":0.1898,"vote_count":3,"poster_path":"/4qDwhZw4XKCPjUN1TIvrQFIxgNa.jpg","release_date":"1975-07-27","vote_average":6.7,"backdrop_path":"/3752e6kITtKsnMdCRhW1uhJn8uL.jpg","original_title":"Murrain","original_language":"en"},{"id":12122,"adult":false,"title":"Village of the Damned","video":false,"overview":"An American village is visited by some unknown life form which leaves the women of the village pregnant. Nine months later, the babies are born, and they all look normal, but it doesn't take the \"parents\" long to realize that the kids are not human or humane.","genre_ids":[53,27,878],"popularity":1.4264,"vote_count":892,"poster_path":"/pXXNmSVqkvSMoMitsdjK0V8Dkna.jpg","release_date":"1995-04-28","vote_average":6.104,"backdrop_path":"/udqpyMs0zvaP9MjETzhWg04zVKe.jpg","original_title":"Village of the Damned","original_language":"en"},{"id":1484061,"adult":false,"title":"The Quinta's Ghost","video":false,"overview":"In seclusion at La Quinta del Sordo, Goya confronts illness, memories, and haunting visions, exorcising his demons through the Black Paintings —sacrificing peace, sanity, and self to immortalize his torment.","genre_ids":[16,27],"popularity":0.246,"vote_count":2,"poster_path":"/8HFU2SHcRtW6CUW4XXjhk7w7ave.jpg","release_date":"2025-06-07","vote_average":7,"backdrop_path":"/ksDr2JjVclfbkPScMuz4L4Nt2DJ.jpg","original_title":"El fantasma de la Quinta","original_language":"es"},{"id":1306525,"adult":false,"title":"The Elixir","video":false,"overview":"An elixir unleashes the undead in a village. A family at odds with one another must unite and fight to survive as their hometown collapses.","genre_ids":[27,53],"popularity":4.5176,"vote_count":177,"poster_path":"/A6aJLPhtmin9ZTWC2h7dnrMHU4z.jpg","release_date":"2025-10-22","vote_average":5.9,"backdrop_path":"/cNmGq1bfUDhrZEHvJ77zwiWfoNA.jpg","original_title":"Abadi Nan Jaya","original_language":"id"},{"id":1138508,"adult":false,"title":"Pamali: The Corpse Village","video":true,"overview":"A group of medical volunteers who are sent to a remote village to help residents affected by a deadly epidemic while keeping many secrets related to Pamali.","genre_ids":[27,9648],"popularity":0.6671,"vote_count":8,"poster_path":"/4tYOjqJf3i76dc978kdc87qbhrX.jpg","release_date":"2023-10-12","vote_average":6.8,"backdrop_path":"/5SSJHyOELbzbiFtProbaee0tOhJ.jpg","original_title":"Pamali: Dusun Pocong","original_language":"id"},{"id":2668,"adult":false,"title":"Sleepy Hollow","video":false,"overview":"Skeptical young detective Ichabod Crane gets transferred to the hamlet of Sleepy Hollow, New York, where he is tasked with investigating the decapitations of three people – murders the townsfolk attribute to a legendary specter, The Headless Horseman.","genre_ids":[14,53,9648,27],"popularity":6.627,"vote_count":7240,"poster_path":"/1GuK965FLJxqUw9fd1pmvjbFAlv.jpg","release_date":"1999-11-19","vote_average":7.188,"backdrop_path":"/nVi8CINgtMbWmCQ0XxXgW2H1ZTW.jpg","original_title":"Sleepy Hollow","original_language":"en"},{"id":7131,"adult":false,"title":"Van Helsing","video":false,"overview":"Famed monster slayer Gabriel Van Helsing is dispatched to Transylvania to assist the last of the Valerious bloodline in defeating Count Dracula. Anna Valerious reveals that Dracula has formed an unholy alliance with Dr. Frankenstein's monster and is hell-bent on exacting a centuries-old curse on her family.","genre_ids":[27,12,28],"popularity":9.6585,"vote_count":6468,"poster_path":"/gsFun8nATm52aGHeT8ueAel98nE.jpg","release_date":"2004-05-03","vote_average":6.393,"backdrop_path":"/d72ROyJqXQtw2OupW0l15eicRAF.jpg","original_title":"Van Helsing","original_language":"en"},{"id":6114,"adult":false,"title":"Bram Stoker's Dracula","video":false,"overview":"Count Dracula, a 15th-century prince, is condemned to live off the blood of the living for eternity. Young lawyer Jonathan Harker is sent to Dracula's castle to finalise a land deal, but when the Count sees a photo of Harker's fiancée, Mina, the spitting image of his dead wife, he imprisons him and sets off for London to track her down.","genre_ids":[10749,27],"popularity":8.2606,"vote_count":5646,"poster_path":"/jSxCIZXudp5q8wQO8VERGX8hRAl.jpg","release_date":"1992-11-13","vote_average":7.445,"backdrop_path":"/jhs21DDKZM6J9k448R1m0w67pD.jpg","original_title":"Bram Stoker's Dracula","original_language":"en"},{"id":2971,"adult":false,"title":"Alraune","video":false,"overview":"In the 1800s, a stormy love relationship develops quickly between a young medical student and a woman believing herself to be the daughter of his scientist uncle, the student having never heard of her before their chance encounter and both unaware that she is the result of the scientist's illegal experiments with artificial insemination..","genre_ids":[18,878,10749,27],"popularity":0.2803,"vote_count":19,"poster_path":"/9T8yyIROsNmggyeM4qAcoCBit0Z.jpg","release_date":"1952-10-22","vote_average":5.368,"backdrop_path":"/i5Nstf74IDOU7rKxVt7rx23V34Z.jpg","original_title":"Alraune","original_language":"de"}],"external_ids":{"imdb_id":"tt33019528","twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":"thepearlcombfilm"},"social_ids":{"twitter":null,"facebook":null,"instagram":"thepearlcombfilm"},"gdvg_id":104448,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":