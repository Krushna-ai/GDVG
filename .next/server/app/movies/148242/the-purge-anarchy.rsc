5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Purge: Anarchy\",\"description\":\"One night per year, the government sanctions a 12-hour period in which citizens can commit any crime they wish -- including murder -- without fear of punishment or imprisonment. Leo, a sergeant who lost his son, plans a vigilante mission of revenge during the mayhem. However, instead of a death-dealing avenger, he becomes the unexpected protector of four innocent strangers who desperately need his help if they are to survive the night.\",\"image\":\"https://image.tmdb.org/t/p/w500/qwqHHZLZSUvMkAMQ47ymtfjEifY.jpg\",\"datePublished\":\"2014-07-17\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"FR\",\"inLanguage\":\"en\",\"genre\":[\"Horror\",\"Thriller\",null,null,null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.629,\"bestRating\":10,\"ratingCount\":6631}}"}}],["$","$L10",null,{"initialDrama":{"id":"0a584070-f3ce-4836-a66c-71e1130ae8f1","tmdb_id":238636,"imdb_id":"tt2975578","content_type":"movie","title":"The Purge: Anarchy","original_title":"The Purge: Anarchy","overview":"One night per year, the government sanctions a 12-hour period in which citizens can commit any crime they wish -- including murder -- without fear of punishment or imprisonment. Leo, a sergeant who lost his son, plans a vigilante mission of revenge during the mayhem. However, instead of a death-dealing avenger, he becomes the unexpected protector of four innocent strangers who desperately need his help if they are to survive the night.","poster_path":"/qwqHHZLZSUvMkAMQ47ymtfjEifY.jpg","backdrop_path":"/blfZnm6StMPnTY35kaooPBCsSVp.jpg","release_date":"2014-07-17","first_air_date":null,"status":"published","original_language":"en","origin_country":["FR","US"],"genres":[{"id":27,"name":"Horror"},{"id":53,"name":"Thriller"},"horror film","thriller film","dystopian film","actio