vVB9fbrO4e2jlaLEgua2UWIB.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/30fzW21IEupCyfhtSSjxqthHi37.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/8VAtLuYRiCzn7uuGIyeekbpxT9E.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/xPrJCpaHoBrUEZDX5Q0CEBc7rLB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/pW8JLmz3JSVmUpTmDGkCZFytLSo.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/fXmUurhdcrDahAcdB1bDMB8IbYe.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/paOhpcJEnBWT5XlrfZ3r9B7aQ46.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/1cLrEms6ncDn3a6h4o1dxzMxjah.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/mG1eMw9QKgXmlRmAFRfcEXoGgcA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/dHRrjIXhEYfTwzq2bRB3csjDfRk.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/mIXcHI3kFWmqYIOM4uSnRuWnqly.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2048,"height":1152,"file_path":"/xRJg3VvAaddQlAohKb6pJsrrihs.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/6eDMkHXB7nqkmTmDD4qr6oNeHYN.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/nip2Ul1Qct1rlpGsznSqclpQkgK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1422,"height":800,"file_path":"/whtX9Cyk554ApKZqcEmTToBMevR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:45:56.044+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":103,"tagline":"","homepage":"","overview":"One night per year, the government sanctions a 12-hour period in which citizens can commit any crime they wish -- including murder -- without fear of punishment or imprisonment. Leo, a sergeant who lost his son, plans a vigilante mission of revenge during the mayhem. However, instead of a death-dealing avenger, he becomes the unexpected protector of four innocent strangers who desperately need his help if they are to survive the night."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Anarchy: La noche de las bestias","runtime":100,"tagline":"Bienvenidos a una nueva era. Una noche al año el crimen es legal.","homepage":"","overview":"El crimen hace estragos en Estados Unidos y las cárceles están llenas. El gobierno decide que una noche al año, durante doce horas, cualquier actividad criminal, incluso el asesinato, será legal. No se puede llamar a la policía, los hospitales no admiten pacientes, los ciudadanos deben arreglárselas solos porque cometer un delito no está castigado. Durante esa noche plagada de peligros, 5 personas que se han quedado fuera de sus casas deciden juntarse para poder enfrentarse mejor a los ciudadanos salvajes que buscan calmar sus ansias de violencia."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"American Nightmare 2 : Anarchy","runtime":103,"tagline":"Une nuit par an, tous les crimes sont permis.","homepage":"","overview":"Shane et Liz, formant un jeune couple se retrouvent bloqués dans leur voiture pendant la purge annuelle et ne savent plus quoi faire, pendant ce temps, Eva et Cali sont sauvés de justesse d'un kidnapping par Léo, un homme participant à la purge annuelle, les deux groupes finissent par se retrouver dans la rue et coopèrent pour survivre à cette nuit."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Судная ночь 2","runtime":103,"tagline":"«Добро пожаловать в идеальное будущее, где одну ночь в году все преступления легальны»","homepage":"","overview":"Добро пожаловать в идеальный мир будущего, мир без преступности и войн. И только один раз в году роскошная спокойная жизнь сменяется анархией. Этой ночью дозволено все: во тьме улиц одни жаждут мести, другие ищут развлечений, остальные пытаются дожить до рассвета..."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":100,"tagline":"Einmal im Jahr sind alle Verbrechen legal.","homepage":"","overview":"Amerika anno 2023. Seit sechs Jahren finden schon die zwölfstündigen Säuberungen statt, in denen eine Nacht lang Mord ungesühnt bleibt. Ausgerechnet zwei Stunden vor Beginn der Anarchie bleibt das Auto des Pärchens Liz und Shane liegen - eine maskierte Bande hat sie als Opfer auserkoren. Auf ihrer Flucht verstecken sie sich im Wagen von Leo, der eigentlich mit mörderischen Absichten loszog. Nun muss er das Paar sowie die von Nachbarn und einer ganzen Armee gejagte Eva und ihre Tochter Cali schützen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"A Purga: Anarquia","runtime":103,"tagline":"Uma tradição americana","homepage":"","overview":"Várias pessoas tentam sobreviver à Noite da Purga, um período de 12 horas em que todos os crimes são permitidos. Sem lugar onde se proteger, todos tentam sobreviver ao caos e à violência que invadem as ruas."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Anarchia - La notte del giudizio","runtime":103,"tagline":"Benvenuto in America dove una notte all'anno ogni crimine diventa legale","homepage":"http://blumhouse.com/film/thepurgeanarchy","overview":"In un America distrutta dalla criminalità e con le prigioni stracolme di malviventi, il governo ha deciso di instaurare un giorno all’anno in cui per 12 ore ogni tipo di crimine, incluso l’omicidio, diventa legale. Non è possibile chiamare la polizia. Gli ospedali sono chiusi. E’ una notte nella quale i cittadini si autogestiscono senza il pericolo di essere puniti per le loro azioni."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":103,"tagline":"","homepage":"","overview":"Eens per jaar vindt 'The Purge' plaats: een nacht waarin geen wetten of regels gelden. We maken kennis met een stad waar niemand een werkend beveiligingssysteem heeft. Een jong koppel is op desbetreffende avond onderweg naar huis, wanneer het tweetal te kampen krijgt met autopech. De zon begint te dalen en ze besluiten hun auto te verlaten."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"人类清除计划2","runtime":0,"tagline":"","homepage":"","overview":"2023年，美国新政府所推行的“人类清除计划”迎来了第六个年头。剑走偏锋的极端政策，旨在抑制持续上升的失业率和犯罪率，在此期间却也有越来越多的无辜之人遇害，而富人们则斟好杯中酒，脑满肠肥欣赏甚至以看似高贵优雅的姿态参与一年一度的屠杀狂欢。在大屠杀即将开始之际，面临分手的情侣谢恩和莉兹的车在路上抛锚，他们慌乱不安地寻找藏身之地。刚刚失去最重要亲人的伊娃及其女儿卡莉躲在家中亦难免厄运临头，关键时刻母女被逡巡在城市巷尾的中士救下，与此同时谢恩和莉兹也阴差阳错搭上了中士的车。新仇旧恨以及对世界的各种愤懑不满，在这个夜晚集中爆发，脆弱的生命面临最惨烈的考验……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"A megtisztulás éjszakája: Anarchia","runtime":0,"tagline":"","homepage":"","overview":"Amerika Új Alapító Atyái meghívnak téged az éves Megtisztulás ünnepére. Ezen az éjszakán minden bűn törvényessé válik 12 órára. Míg az előző rész, A bűn éjszakája egy család sorsát követte nyomon a Megtisztulás végzetes éjszakáján, az anarchia éjszakája egy csapat véletlenül összeverődött ember viszontagságainak krónikája a bűn éjszakáján a pokollá változott városban, ahol minden sarkon újabb veszély, és újabb fordulat leselkedik."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"הטיהור 2: לשרוד את הלילה","runtime":0,"tagline":"ברוכים הבאים לאמריקה בה לילה בה לילה אחד בשנה... הוא חוקי!","homepage":"","overview":"זוג צעיר נתקע על כביש ראשי במכוניתם ברגע בו מתחיל ליל הטיהור השנתי. בזמן שכל האזרחים שומרי החוק מסתגרים בבתיהם, השניים מנסים למצוא מסתור בלילה ארוך מאוד בו אף אזרח לא פותח את דלת ביתו לסייע לזולת והאזרחים נרדפים על ידי פושעים חסרי תקנה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Očista: Anarchie","runtime":103,"tagline":"Dnes v noci budou všechny zločiny legální. Zkuste ji přežít.","homepage":"","overview":"Jednou za rok se americké ulice vždy na dvanáct nočních hodin promění v peklo. Nepracuje ani jedna ze složek záchranného systému a všechny zločiny jsou zcela legální. Téhle brutální noci se říká Očista. V noc Očisty by se po ulicích pohyboval jenom sebevrah nebo člověk s neodolatelnou touhou po zabíjení. Jedním z nich je chlap, který chce dočasnou beztrestnost využít k tomu, aby „potrestal\" opilého řidiče, jenž mu před časem přejel dítě. Nebude to mít jednoduché, protože všichni ti, kdo tuhle noc chtějí přežít, se před vypuknutím Očisty snaží zabezpečit. Manželé, kterým se krátce před jejím začátkem porouchalo auto, měli v tomhle směru smůlu. Stejně tak matka s dcerou, které se marně pokusily proměnit svůj byt v nedobytnou tvrz. Náhoda svede tyhle čtyři bezbranné zoufalce dohromady s výše uvedeným mstitelem. Je jim jasné, že pokud mají mít aspoň nepatrnou šanci na přežití, musí se ho za každou cenu držet. Jenže on má svůj plán a v něm vyděšení „civilisti\" nehrají žádnou roli."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"The Purge: Anarki","runtime":0,"tagline":"","homepage":"","overview":"Den enlige mor Eva forsøger på bedste vis at få enderne til at nå sammen og det er ikke altid let, når man bor i den mindre pæne del af byen. Og hvad værre er. Hun har ikke råd til de samme sikkerhedsforanstaltninger som byens rige indbyggere. Da hun og datteren Cali bliver overfaldet af maskerede overfaldsmænd, må de flygte ud af deres lejlighed. Her løber de bogstaveligt talt ind i Joe, som noget modvilligt beslutter sig for at hjælpe dem og har sin egen dagsorden for at være ude i de 12 timer, hvor anarki råder i gaderne. Sammen med parret Shane og Liz, der søger ly i Leos pansrede bil, må de nu sammen forsøge at kæmpe sig igennem den årlige udrensning."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Očista: Anarchia","runtime":0,"tagline":"","homepage":"","overview":"Raz za 2 roky sa americké ulice vždy na dvanásť nočných hodín premenia na peklo. Nepracuje ani jedna zo zložiek záchranného systému a všetky zločiny, vrátane tých najťažších, sú úplne legálne. Táto brutálna noc sa volá Očista."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Arınma Gecesi: Anarşi","runtime":0,"tagline":"","homepage":"","overview":"Yılda sadece bir gece boyunca tüm suçların serbest olduğu bir dünyada geçen film, Arınma Gecesi öncesi çocuklarıyla birlikte eve dönen bir çiftin gerilimini beyazperdeye taşıyor. Güvenli evlerine ulaşmaya çalışan ailenin benzini yolda biter. Tam da bu esnada oğlunu öldüren adamdan intikam almak için Leo sokaklara çıkmıştır. Bir anne ise kızıyla birlikte yağmalanan evinden canını zor kurtarır. Los Angeles.'ın bu en haşin gecesinde hayatta kalmaya çalışan 5 kişinin yolu kesişecektir..."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":104,"tagline":"","homepage":"","overview":"Ett ungt par kämpar för att överleva på gatorna efter att deras bil går sönder precis när den årliga utrensningen börjat."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Чистката: Анархия","runtime":0,"tagline":"Една нощ годишно всички престъпления са законни","homepage":"","overview":"Годишната Чистка започва по залез слънце и трае 12 часа – до изгрева на следващия ден. В тази нощ Правителството легализира всички престъпления, включително убийството, и отзовава силите на реда и спешната помощ. Като позволяват на всеки да отприщи най-тъмните си страсти, властите съумяват да намалят нивото на престъпността през остатъка от годината. В страната цари мир на цената на Чистката.  В навечерието на поредната Чистка един мъж се въоръжава, въпреки молбите на близките му. Една млада двойка се оказва на улицата след залез слънце."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Noc Oczyszczenia: Anarchia","runtime":103,"tagline":"Witajcie w Ameryce, gdzie w jedną noc w roku zbrodnie są legalne.","homepage":"","overview":"Nowi Ojcowie Założyciele Ameryki zapraszają cię na coroczne oczyszczenie. W tę jedną noc w roku, noc oczyszczenia, wszystkie zbrodnie są legalne. To czas na wyrównanie rachunków, na zemstę – ale czasami po prostu na to, by dać upust frustracji. Służby ratownicze, szpitale, straż pożarna i policja nie działają przez 12 godzin, od 19:00 jednego dnia do 7:00 drugiego. Nie ma obowiązku uczestniczenia w oczyszczeniu, ale gdy samochód dwojga młodych ludzi psuje się na środku ulicy tuż przed godziną 19-tą, są oni zmuszeni uciekać przed zamaskowanymi motocyklistami, by ratować życie. Młody mężczyzna wyrusza w drogę, by zemścić się za śmierć synka. Matka i córka uciekają z domu, do którego włamują się bezwzględni napastnicy. Tych pięcioro ludzi musi połączyć siły, by przetrwać noc oczyszczenia w Los Angeles."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Κάθαρση: Αναρχία","runtime":103,"tagline":"Καλωσορίσατε στην Αμερική όπου μία νύχτα τον χρόνο κάθε έγκλημα είναι νόμιμο.","homepage":"","overview":"Η Αμερική είναι υπό το καθεστώς της «κάθαρσης» και βρισκόμαστε ένα χρόνο μετά τα γεγονότα της οικογένειας Σαντίν. Μόνο που τώρα οι κυνηγημένοι δεν θα μείνουν στο σπίτι τους, αλλά θα πρέπει να επιβιώσουν της τρομερής νύχτας, μεταβαίνοντας από το ένα σημείο σε άλλο, καταμεσής χάους."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"더 퍼지: 거리의 반란","runtime":0,"tagline":"사이렌이 울리고, 암흑으로 뒤덮인 도시  모든 분노를 표출할 운명의 그 날이 시작되었다!","homepage":"","overview":"1년 전, 단 하나뿐인 아들을 잃은 뒤 복수를 위해 나선 한 남자  갑작스런 차 고장으로 거리 한복판에 갇힌 위기의 커플  가장 안전하다고 믿었던 집에서 무장 집단들에게 끌려 나온 모녀  오직 재미를 위해 도시를 접수한 가면을 쓴 무리들  법의 통제는 사라지고, 살인이 허락된 단 12시간  지금, 당신도 ‘퍼지데이’에 동참하라!"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Судна ніч 2: Анархія","runtime":103,"tagline":"Вітаємо до Америки, де одну ніч на рік усі злочини законні","homepage":"","overview":"Ласкаво просимо в ідеальний світ майбутнього - світ без злочинності і воєн. І тільки один раз в році розкішне спокійне життя змінюється анархією. Цієї ночі всі злочини законні. Поспішайте додому - свято анархії вже близько..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Noaptea judecății: Anarhia","runtime":103,"tagline":"Bun venit în America, unde o noapte pe an toate crimele sunt legale.","homepage":"","overview":"În timpul unei nopți de haos, aprobată de conducere, misiunea unui bărbat de a-și răzbuna fiu decedat se transformă într-o încercare de a proteja un grup de străini de agresorii violenți."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Puhdistuksen yö: Anarkia","runtime":0,"tagline":"","homepage":"","overview":"Eletään vuotta 2023. Yhdysvaltojen uudet vallanpitäjät antavat kansalaisille vuosittain yhden yön aikaa toteuttaa pimeää puoltaan: 12 tunnin \"Puhdistuksen\" ajan kaikki rikokset ovat sallittuja ja hätäpalvelut poissa käytöstä. Vuosittaisen puhdistuksen jälleen alkaessa Leo, poikansa kuoleman riivaama arvoituksellinen oman tiensä kulkija, janoaa kostoa. Hyökkäyksen kohteeksi joutunut yksinhuoltajaäiti Eva joutuu jättämään asuntonsa tyttärensä Calin kanssa. Nuoren pariskunnan Shanen ja Lizin auto ryöstetään. He hakevat turvaa Leon panssaroidusta autosta ja päätyvät yhdistämään voimansa näiden kolmen muun tuntemattoman ihmisen kanssa. Pian tälle sattuman yhdistämälle ryhmälle selviää, kuinka pitkälle he ovat valmiita menemään puolustaessaan itseään ja toisiaan. Heidän täytyy vain selvitä hengissä yön yli."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Uma Noite de Crime: Anarquia","runtime":103,"tagline":"Uma noite por ano, todos os crimes são permitidos.","homepage":"","overview":"Assim que a Noite de Crime deste ano começa, Leo, um enigmático solitário, assombrado pela morte de seu filho, quer vingança. Eva, uma mãe solteira, é forçada, junto com sua filha Cali, a sair de seu apartamento quando são atacadas. Shane e Liz, um jovem casal, tornamse vítimas de um roubo de carro. Buscando refúgio no carro blindado de Leo, Shane e Liz formam um grupo com esses outros três estranhos. Agora, essa improvável equipe vai descobrir até aonde serão capazes de chegar para se proteger entre si, enquanto lutam para sobreviver à terrível noite."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"La Purge : Anarchie","runtime":103,"tagline":"Une tradition américaine","homepage":"","overview":"La purge est devenue une tradition américaine. Une fois par année, pendant 12 heures, la population est invitée à libérer ses pulsions violentes et meurtrières sans aucunes représailles de l'État. Leo est bien armé et il roule dans la nuit à la quête de sa cible. Eva et sa fille Cali se sont barricadées dans leur maison, mais un événement inattendu les oblige à fuir dans les rues dangereuses. Puis il y a ce couple en instance de séparation qui panique lorsque leur véhicule tombe en panne au milieu de nulle part. Leurs chemins vont bientôt se croiser..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Прочишћење 2: Анархија","runtime":0,"tagline":"","homepage":"","overview":"У свету будућности људи живе мирно, без криминала и стреса. Једном годишње, током 12-сатног периода, Влада дозвољава прочишћење када је свима допуштено да почине било какав злочин, без обзира колико год страшан био. Већина становништва тај се дан сакрије и затвори у својим кућама или склоништима чекајући да крволочни припадници друштва задовоље своје потребе. Када се скупини тинејџера поквари аутомобил на путу према њиховом дому и заклону, они ће се наћи лице у лице с помахниталим суграђанима који су жељни крви…"},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Pročišćenje: Anarhija","runtime":0,"tagline":"Dobrodošli na novu razinu Pročišćenja.","homepage":"","overview":"Američka vlada, koju su sada reorganizirali Novi osnivači Amerike, odobrila je godišnje 12-satno Pročišćenje kako bi se pobrinula da razina zločina ostane ispod jedan posto ostatak godine. Dok policija i bolnice uskraćuju pomoć, to je noć kada se građanstvo regulira samo bez primisli na kaznu ili straha od odmazde. To je vrijeme kada na ulicama vlada anarhija. Nova priča prati neočekivanu skupinu od pet građana koji, tijekom te noći, otkriju točno dokle su spremni ići da zaštite sebe i, na kraju, jedni druge dok se bore da prežive noć punu nemogućih odluka."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Išvalymas: Anarchija","runtime":0,"tagline":"","homepage":"","overview":"Ateities Amerika yra atradusi puikų nusikalstamumo suvaldymo įrankį. Vieną naktį metuose leidžiami bet kokie nusikaltimai – už juos nebaudžiama. Per tas dvylika valandų, kai nedirba nė viena policijos nuovada, ligoninė ar bet kuri kita viešosios tvarkos palaikymo tarnyba, žmonės išlieja visą viduje susikaupusį įtūžį ir likusias 364 dienas visuomenėje vyrauja tvarka, harmonija, draugiškumas bei tarpusavio supratimas. Tiesa, jei esi ne nusikaltėlis, o potenciali auka, ši naktis gali tapti baisiausiu (ir paskutiniu gyvenime) košmaru. Šįkart žudynių nakties košmaras viduryje miesto užklumpa jauną porą, skubėjusią namo pas vaikus, kuomet automobilyje baigėsi degalai."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"12 Horas para sobrevivir","runtime":103,"tagline":"Bienvenidos a EE.UU. Donde una noche al año todo crimen es legal.","homepage":"","overview":"El crimen hace estragos en Estados Unidos y las cárceles están llenas. El gobierno decide que una noche al año, durante doce horas, cualquier actividad criminal, incluso el asesinato, será legal. No se puede llamar a la policía, los hospitales no admiten pacientes, los ciudadanos deben arreglárselas solos porque cometer un delito no está castigado. Durante esa noche plagada de peligros, 5 personas que se han quedado fuera de sus casas deciden juntarse para poder enfrentarse mejor a los ciudadanos salvajes que buscan calmar sus ansias de violencia."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"國定殺戮日：無法無天","runtime":103,"tagline":"歡迎來到美國 每年有一個晚上 任何犯行皆合法","homepage":"","overview":"國定殺戮日當晚，因緣際會相遇的五位陌生人該如何自保，甚至互相保護，才能熬過這個充滿痛苦抉擇的夜晚……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"คืนอำมหิต: คืนล่าฆ่าไม่ผิด","runtime":0,"tagline":"บุรุษผู้ก่อตั้งอเมริกาใหม่ขอเชื้อเชิญคุณเข้าร่วมงานชำระบาปประจำปี","homepage":"","overview":"12 ชั่วโมง ซึ่งอาชญากรรมทุกประเภท รวมถึงฆาตกรรมกลายเป็นสิ่งถูกกฎหมาย ค่ำคืนที่พลเมืองปลดปล่อยตัวตนโดยไม่คำนึงถึงบทลงโทษ สภาพบ้านเมืองตกอยู่ในภาวะไร้กฎหมาย ร่วมลุ้นระทึกไปกับการเอาชีวิตรอดของ 5 ชีวิต ที่ต้องเผชิญกับค่ำคืนสุดโหดและกระเสือกกระสนหนีตายจากคมมีด, กระสุนปืน และเกมไล่ล่าชีวิตมนุษย์"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"パージ：アナーキー","runtime":0,"tagline":"最恐の12時間再び。","homepage":"","overview":"国民の憎悪を発散させ、それによって治安を維持しようと、アメリカ政府は1年に1晩だけ殺人などの全犯罪を認める日、パージを制定する。その日を迎え、家路を急ぐものの車がパンクしたために街をさまよう夫婦。何者かに襲われ、拉致されそうになる母娘。武装した男に救われた彼らは、協力し合いながら無法地帯となった街からの脱出を試みる。次々と襲い掛かってくる殺人者たちを倒していく。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Tīrīšana: Anarhija","runtime":0,"tagline":"","homepage":"","overview":"Laipni lūgti ideālajā nākotnes pasaulē - pasaulē bez noziedzības un kariem. Tikai reizi gadā mierīgo dzīvi nomaina anarhija, jo šajā naktī visi noziegumi ir atļauti un paliek nesodīti. Leo (Frank Grillo) \"tīrīšanas\" nakts ir iespēja atriebt sava dēla nāvi."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"國定殺戮日：全民瘋殺","runtime":0,"tagline":"煽動國民獸性 促進國家繁榮 一年12小時 殺人合法化 一夜 絕對自由;全城 片甲不留!","homepage":"","overview":"美國政府誠邀各位一起參與一年一度的國定殺戮日。在「國定殺戮日」的 12 個小時，任何罪行（包括殺人）均毋須背負刑責，警察和醫院將全面暫停提供所有緊急服務。這一天，有人以暴易暴，為求報仇雪恨；有人肆意犯罪，為滿足一己之慾；有人掙紮求存，只望絕境逢生。這一天，全美再次進入無政府狀態…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Očiščenje: Anarhija","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Ngày Thanh Trừng: Hỗn Loạn","runtime":0,"tagline":"","homepage":"","overview":"The Purge: Anarchy lấy bối cảnh thế giới tương lai vào năm 2023, khi nước Mỹ trở thành \"một quốc gia tái sinh”, với tỷ lệ tội phạm và thất nghiệp ở mức rất thấp. Để giữ mức ổn định này, chính phủ hàng năm đều tiến hành một chiến dịch có tên gọi Lễ Thanh Trừng để con người có thể tự do giải thoát mọi cảm xúc tiêu cực của họ. Trong vòng 12 tiếng, tất cả mọi hành vi phạm tội bao gồm cả giết người đều không bị truy xét trước pháp luật. Tuy nhiên, điều này đã kéo theo hàng loạt sự kiện thanh trừng vô cùng khủng khiếp gây náo loạn, càng đẩy tình trạng hỗn loạn vượt ra ngoài tầm kiểm soát..."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"განკითხვის ღამე 2: ანარქია","runtime":0,"tagline":"","homepage":"","overview":"კეთილი იყოს თქვენი მობრძანება მომავლის იდეალურ სამყაროში, სამყაროში დანაშაულისა და ომების გარეშე. და მხოლოდ წელიწადში ერთხელ, მდიდრული, მშვიდი ცხოვრება იცვლება ანარქიით. ამ ღამეს ყველაფერი ნებადართულია: ქუჩების სიბნელეში ზოგი შურს იძიებს, ზოგი გართობას, ზოგიც ცდილობს გათენებამდე გადარჩეს.."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":103,"tagline":"","homepage":"","overview":"مرحبا بكم في أمريكا حيث ليلة واحدة في السنة كل جريمة قانونية\r ليلة واحدة في السنة، تفرض الحكومة عقوبات على فترة 12 ساعة يمكن للمواطنين خلالها ارتكاب أي جريمة يرغبون فيها - بما في ذلك القتل - دون خوف من العقاب أو السجن. يخطط ليو ، الرقيب الذي فقد ابنه ، لمهمة أهلية للانتقام أثناء الفوضى. ومع ذلك ، بدلا من المنتقم الذي يتعامل مع الموت ، يصبح الحامي غير المتوقع لأربعة غرباء أبرياء يحتاجون بشدة إلى مساعدته إذا أرادوا البقاء على قيد الحياة في الليل."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"","runtime":103,"tagline":"","homepage":"","overview":"في هذا الجزء القاتم، يبذل عامّة المواطنين أقصى جهودهم للنجاة بحياتهم حين تُصبح كلّ الجرائم شرعية، بما فيها القتل، على مدار اثنتي عشرة ساعة."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"","runtime":103,"tagline":"Einmal im Jahr sind alle Verbrechen legal.","homepage":"","overview":"In dieser düsteren Fortsetzung müssen Bürger um ihr Leben fürchten. Denn während der alljährlichen Generalamnestie kommen Verbrecher 12 Stunden lang straffrei davon."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"","runtime":103,"tagline":"Einmal im Jahr sind alle Verbrechen legal.","homepage":"","overview":"In dieser düsteren Fortsetzung müssen Bürger um ihr Leben fürchten. Denn während der alljährlichen Generalamnestie kommen Verbrecher 12 Stunden lang straffrei davon."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"CH","english_name":"German"},{"data":{"title":"","runtime":103,"tagline":"","homepage":"","overview":"In deze donkere sequel doen gewone burgers hun best om te overleven tijdens een jaarlijkse amnestie van 12 uur waarin elk misdrijf mag worden gepleegd."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"El crim fa estralls als Estats Units i les presons són plenes. El govern decideix que una nit cada any, durant dotze hores, qualsevol activitat criminal, fins i tot l'assassinat, serà legal. No es pot trucar a la policia, els hospitals no admeten pacients, els ciutadans s'han d'espavilar sols perquè cometre un delicte no està castigat. Durant aquella nit plena de perills, 5 persones que s'han quedat fora de casa decideixen ajuntar-se per poder enfrontar-se millor als ciutadans salvatges que busquen calmar les seves ànsies de violència."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"پاکسازی: هرج و مرج","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Tre grupper som prøver å overleve utrenskningsnatten må ta umulige avgjørelser og finne ut hvor langt de er villige til å gå for å beskytte seg selv og, til syvende og sist, hverandre."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"}],"reviews_tmdb":[{"id":"5831958d92514162cb024b14","url":"https://www.themoviedb.org/review/5831958d92514162cb024b14","author":"Gimly","content":"When _The Purge_ was announced, it was a hugely promising premise, that ended up being wasted in nothing more than an answer to the horror movie question of \"why don't they just call the cops?\".\r\n\r\n_Anarchy_, however, delivers on that promise.\r\n\r\n_Final rating:★★★½ - I strongly recommend you make the time._","created_at":"2016-11-20T12:22:37.477Z","updated_at":"2021-06-23T15:57:52.129Z","author_details":{"name":"Gimly","rating":7,"username":"Ruuz","avatar_path":"/xUObnJSvHrFPsIpoDmb1jiQZLq7.jpg"}},{"id":"58c17308c3a368263d00a5b7","url":"https://www.themoviedb.org/review/58c17308c3a368263d00a5b7","author":"mattwilde123","content":"Inevitable sequel. Good idea though. It was interesting to see the poor deal with the night of terror this time. The acting wasn't great nor was it great the first time though. The first film did have a few good actors though. And the jump scares failed most of the time.\r\n\r\nThe last thirty minutes reminded me of the satirical class dividing futures of 'Black Mirror', ' Hostel' and 'The Hunger Games' but it lacked the interesting writing.\r\n\r\n★★½","created_at":"2017-03-09T15:21:44.397Z","updated_at":"2021-06-23T15:57:55.500Z","author_details":{"name":"","rating":5,"username":"mattwilde123","avatar_path":"/wCTsgKvihctPGp4Ms7Y373baeHm.jpg"}},{"id":"5a12ebb9c3a368628f06c530","url":"https://www.themoviedb.org/review/5a12ebb9c3a368628f06c530","author":"inaneswine","content":"A total mess of a film. It clearly tries to expand on the bigger picture that we missed out on last time - but the fact is that past the initial frightening idea, _The Purge: Anarchy_ is an exercise in mindless bloodshed (as is the eponymous Purge itself), and lacks emotional depth or a coherent story.","created_at":"2017-11-20T14:50:33.840Z","updated_at":"2021-06-23T15:58:02.832Z","author_details":{"name":"","rating":5,"username":"inaneswine","avatar_path":null}}],"recommendations":[{"id":316727,"adult":false,"title":"The Purge: Election Year","video":false,"overview":"Two years after choosing not to kill the man who killed his son, former police sergeant Leo Barnes has become head of security for Senator Charlene Roan, the front runner in the next Presidential election due to her vow to eliminate the Purge. On the night of what should be the final Purge, a betrayal from within the government forces Barnes and Roan out onto the street where they must fight to survive the night.","genre_ids":[28,27,53],"media_type":"movie","popularity":4.5553,"vote_count":5437,"poster_path":"/gg7tlp45xqGWMra0sqQVPvybje2.jpg","release_date":"2016-06-29","vote_average":6.384,"backdrop_path":"/a7V3ZXCDAk3P7GjpgfN0IInjh0r.jpg","original_title":"The Purge: Election Year","original_language":"en"},{"id":158015,"adult":false,"title":"The Purge","video":false,"overview":"Given the country's overcrowded prisons, the U.S. government begins to allow 12-hour periods of time in which all illegal activity is legal. During one of these free-for-alls, a family must protect themselves from a home invasion.","genre_ids":[878,27,53],"media_type":"movie","popularity":7.1881,"vote_count":8732,"poster_path":"/46X1ei9uf13nkkr0OhWldGyr5Uh.jpg","release_date":"2013-05-31","vote_average":6.252,"backdrop_path":"/9J3HHP3kQ5ZStyirJyWPWtvvrHY.jpg","original_title":"The Purge","original_language":"en"},{"id":442249,"adult":false,"title":"The First Purge","video":false,"overview":"To push the crime rate below one percent for the rest of the year, the New Founding Fathers of America test a sociological theory that vents aggression for one night in one isolated community. But when the violence of oppressors meets the rage of the others, the contagion will explode from the trial-city borders and spread across the nation.","genre_ids":[28,27,53],"media_type":"movie","popularity":4.4594,"vote_count":4171,"poster_path":"/litjsBoiydO6JlO70uOX4N3WnNL.jpg","release_date":"2018-07-04","vote_average":6.002,"backdrop_path":"/r4clWIxKeWoqrHspQP0XunuUmB7.jpg","original_title":"The First Purge","original_language":"en"},{"id":184346,"adult":false,"title":"Deliver Us from Evil","video":false,"overview":"When a frightening wave of violence sweeps through New York City, troubled cop Sarchie fails to find a rational explanation for the bizarre crimes. However, his eyes are opened to a frightening alternate reality when renegade Jesuit priest Mendoza convinces him that demonic possession may be to blame for the gruesome murders. Together, they wage a valiant supernatural struggle to rid the city of an otherworldly evil.","genre_ids":[53,80,27],"media_type":"movie","popularity":3.3733,"vote_count":2185,"poster_path":"/Uz32ERsyCmGwV8Eg2wmT2ooWpo.jpg","release_date":"2014-07-01","vote_average":6.247,"backdrop_path":"/JFQJDXEHnZmfJC1sWNbIrz0WS7.jpg","original_title":"Deliver Us from Evil","original_language":"en"},{"id":193612,"adult":false,"title":"The Quiet Ones","video":false,"overview":"A professor and his students perform a dangerous experiment that causes a young woman to lose her sanity.","genre_ids":[27],"media_type":"movie","popularity":0.9747,"vote_count":675,"poster_path":"/wLULlJrFzhWhJhmjgBTUw0OYv3P.jpg","release_date":"2014-04-25","vote_average":5.1,"backdrop_path":"/fme0BJIU46w1aGfOYXcUTDnLTQF.jpg","original_title":"The Quiet Ones","original_language":"en"},{"id":250546,"adult":false,"title":"Annabelle","video":false,"overview":"A couple begins to experience terrifying supernatural occurrences involving a vintage doll shortly after their home is invaded by satanic cultists.","genre_ids":[27],"media_type":"movie","popularity":6.7623,"vote_count":6481,"poster_path":"/yLsuU2P2SpDYFwtZQ7dtfVAf6TE.jpg","release_date":"2014-10-01","vote_average":5.8,"backdrop_path":"/pWZ0srAfPx4XyJMlFkKBlmYfx3C.jpg","original_title":"Annabelle","original_language":"en"},{"id":242512,"adult":false,"title":"Ouija","video":false,"overview":"A group of friends must confront their most terrifying fears when they awaken the dark powers of an ancient spirit board.","genre_ids":[27],"media_type":"movie","popularity":2.5123,"vote_count":2750,"poster_path":"/gwjHlGjK2xXKpjd65BWyAMwzTWC.jpg","release_date":"2014-10-24","vote_average":5.1,"backdrop_path":"/fsuA3wUYixjLeE97CyyPGdPoQF3.jpg","original_title":"Ouija","original_language":"en"},{"id":242224,"adult":false,"title":"The Babadook","video":false,"overview":"A grieving single mother and her child fall into a deep well of paranoia when an eerie children's book manifests in their home.","genre_ids":[18,27],"media_type":"movie","popularity":3.2578,"vote_count":6322,"poster_path":"/qt3fqapeo94TfvMyld8P7gkpXLz.jpg","release_date":"2014-05-22","vote_average":6.53,"backdrop_path":"/t18ocAG0cpgC1AP288SseqmXqB5.jpg","original_title":"The Babadook","original_language":"en"},{"id":133805,"adult":false,"title":"Carrie","video":false,"overview":"An awkward, telekinetic teenage girl is the object of relentless bullying at school and an oppressively religious mother at home.","genre_ids":[18,27],"media_type":"movie","popularity":3.0899,"vote_count":4666,"poster_path":"/kloXz9qwO23z9Kbt3z3MgnjF4xO.jpg","release_date":"2013-10-16","vote_average":6.044,"backdrop_path":"/zTwuMSZ8Tsf9k6r2lslemPs4m1H.jpg","original_title":"Carrie","original_language":"en"},{"id":270303,"adult":false,"title":"It Follows","video":false,"overview":"A young woman is followed by an unknown supernatural force after a sexual encounter.","genre_ids":[27,9648],"media_type":"movie","popularity":8.058,"vote_count":6805,"poster_path":"/iwnQ1JH1wdWrGYkgWySptJ5284A.jpg","release_date":"2015-02-04","vote_average":6.587,"backdrop_path":"/ikaRI4yMxKOje5SmOlAhOBUnicL.jpg","original_title":"It Follows","original_language":"en"},{"id":602223,"adult":false,"title":"The Forever Purge","video":false,"overview":"All the rules are broken as a sect of lawless marauders decides that the annual Purge does not stop at daybreak and instead should never end as they chase a group of immigrants who they wan