idth":1539,"height":2170,"file_path":"/x7mQZfRVfbOhwuAeqwZNPLrf6mz.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.709,"vote_average":0},{"width":2000,"height":3000,"file_path":"/m466EostHuG7kb33jQZ16bttCNs.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/rIhSO9etaUfD1X2bDLMpaJgJ0ri.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1434,"height":2048,"file_path":"/zw6soUnobYd1cEt7ye05DZ5fz07.jpg","iso_639_1":"nl","iso_3166_1":"NL","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":1365,"height":2048,"file_path":"/6oRzUZ4PJCok4KrWyCRpe5dlYrO.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/vOl7bPpWxyETFbJpo9nliDSRuP1.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/2CkeSYrDuYITmNiKkbqcipcnJHT.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/kWoAdQQglE0OPnoG8E3MxUmZOYu.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1433,"height":2048,"file_path":"/z39w2BJHo9hnQlaRqATbcTnAht2.jpg","iso_639_1":"lt","iso_3166_1":"LT","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":509,"height":755,"file_path":"/1admodFaG5OKYwVtPTAq86d2CMJ.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.674,"vote_average":0},{"width":509,"height":755,"file_path":"/pUW2JtHvV3Xvk7AvPjNwHHEmY8W.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.674,"vote_average":0},{"width":1084,"height":1500,"file_path":"/2X91RuoP0MA446IYnRFPwbvmIKu.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.723,"vote_average":0},{"width":1000,"height":1500,"file_path":"/5