9:{"metadata":[["$","title","0",{"children":"A Working Man | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Levon Cade left behind a decorated military career in the black ops to live a simple life working construction. But when his boss's daughter, who is like family to him, is taken by human traffickers, his search to bring her home uncovers a world of corruption far greater than he ever could have imagined."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/108805/a-working-man"}],["$","meta","5",{"property":"og:title","content":"A Working Man"}],["$","meta","6",{"property":"og:description","content":"Levon Cade left behind a decorated military career in the black ops to live a simple life working construction. But when his boss's daughter, who is like family to him, is taken by human traffickers, his search to bring her home uncovers a world of corruption far greater than he ever could have imagined."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/108805/a-working-man"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/6FRFIogh3zFnVWn7Z6zcYnIbRcX.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"A Working Man"}],["$","meta","12",{"name":"twitter:description","content":"Levon Cade left behind a decorated military career in the black ops to live a simple life working construction. But when his boss's daughter, who is like family to him, is taken by human traffickers, his search to bring her home uncovers a world of corruption far greater than he ever could have imagined."}],["$","meta","13",{"name":"twitter:image","c