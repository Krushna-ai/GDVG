:"he","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/crthB4cSlnfE4ryDrDpT5elQz8y.jpg","iso_639_1":"ro","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/30lfpMY2sK6uU4GYmlXTFcUmiPd.jpg","iso_639_1":"tr","vote_average":3.334}],"backdrops":[{"width":3840,"height":2160,"file_path":"/fTrQsdMS2MUw00RnzH0r3JWHhts.jpg","iso_639_1":null,"vote_average":7.05},{"width":3840,"height":2160,"file_path":"/xBrx6O1RIhjtWmVthZIANuQz7Z2.jpg","iso_639_1":null,"vote_average":5.25},{"width":3840,"height":2160,"file_path":"/mQ6lIqblLT1uXunxLRZ0BIcPN3g.jpg","iso_639_1":"en","vote_average":3.334},{"width":3840,"height":2160,"file_path":"/uz3PYuJFmLn01uVaIlWdzk6sWtC.jpg","iso_639_1":"es","vote_average":3.334},{"width":3840,"height":2160,"file_path":"/xmCqmUk8b0Wt2d58vHaTZBTjAYn.jpg","iso_639_1":null,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/5dRQd041lUSupX1aunzhGx8kd8h.jpg","iso_639_1":null,"vote_average":2.066},{"width":3840,"height":2160,"file_path":"/ykqxDnRquOZI4wBFfbcPgNyz3ys.jpg","iso_639_1":"en","vote_average":1.75},{"width":3840,"height":2160,"file_path":"/fKueuPnozJnMYyzp6zFfI4SZ9ht.jpg","iso_639_1":null,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/pAB7bpX0H2A7xZTgP4PQAlVuFgo.jpg","iso_639_1":"en","vote_average":1.75},{"width":3840,"height":2160,"file_path":"/6hcdOo39P3O3huiPrl34iRlhY9A.jpg","iso_639_1":null,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/s4UihKnLx5ACClZzKea8XYZ0HnN.jpg","iso_639_1":null,"vote_average":1.444},{"width":3840,"height":2160,"file_path":"/e8Tk6FK6Es4bhkXQnUKUUQyjan6.jpg","iso_639_1":null,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/kl2XZ2ksz4zFc88tX5HFqbt0wpD.jpg","iso_639_1":null,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/79lV1TdqD7YxLhdZ4DbvmnFOLWw.jpg","iso_639_1":"en","vote_average":0.166},{"width":3840,"height":2160,"file_path":"/gPidEkpPZqH5OZIvrHiSnEvii2L.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-02-21T10:36:33.344+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":116,"tagline":"Human traffickers beware.","homepage":"https://www.amazon.com/salp/aworkingman?hhf","overview":"Levon Cade left behind a decorated military career in the black ops to live a simple life working construction. But when his boss's daughter, who is like family to him, is taken by human traffickers, his search to bring her home uncovers a world of corruption far greater than he ever could have imagined."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"워킹맨","runtime":0,"tagline":"그가 돌아왔다","homepage":"","overview":"전직 블랙 옵스 요원이었던 레본 케이드(제이슨 스타뎀)는 평범한 건설 노동자로 살아가며 딸과 함께 조용한 삶을 추구하고 있었으나 그의 상사의 딸이 인신매매 조직에 의해 납치되면서, 다시 과거의 전투 기술을 사용해 그녀를 구하기 위해 나서게 된다. 이 과정에서 시카고의 범죄 조직과 러시아 마피아와 얽히며, 부패와 폭력으로 가득 찬 어두운 세계를 마주하게 되는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Мастер","runtime":116,"tagline":"«В своём деле он — лучший»","homepage":"","overview":"Левон Кейд — рабочий на стройке, но когда дочь директора стройки похищают неизвестные, он обращается за помощью именно к Левону. Пришло время сбросить маски и проявить свои истинные навыки."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":116,"tagline":"Statham revient pour casser des bouches.","homepage":"","overview":"Levon Cade a quitté une carrière militaire prestigieuse dans les forces spéciales pour mener une vie simple dans la construction. Cependant, lorsque la fille de son patron, qu'il considère comme sa propre famille, est enlevée par des trafiquants d'êtres humains, sa quête pour la ramener chez elle le plonge dans un monde de corruption bien plus vaste qu'il n'aurait jamais pu imaginer."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Rescate implacable","runtime":0,"tagline":"Traficantes de personas, están advertidos.","homepage":"https://www.warnerbroslatino.com/es-mx/peliculas/rescate-implacable","overview":"Levon Cade dejó atrás una distinguida carrera militar en operaciones encubiertas para llevar una vida sencilla trabajando en la construcción. Pero cuando la hija de su jefe, quien es como familia para él, es capturada por traficantes de personas, su búsqueda para traerla de regreso revela un mundo de corrupción mucho mayor de lo que jamás pudo imaginar."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"制暴：无限杀机","runtime":0,"tagline":"","homepage":"","overview":"影片改编自查克·迪克逊所著同名系列小说，主人公莱文·凯德（杰森·斯坦森 Jason Statham 饰）是黑色行动界的传奇人物，他放弃职业从事建筑工作，想过简单的生活，做女儿的好父亲，而当他老板的十几岁女儿珍妮突然消失后，莱文被召回要求重操旧业。在追踪过程中，莱文卷入到 一个邪恶的犯罪阴谋的中心，产生了连锁反应，将威胁到他的新生活方式。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Профі","runtime":0,"tagline":"На торговців людьми чекає розплата","homepage":"","overview":"Левон Кейд – звичайний роботяга в будівельній компанії, але за його мовчазним характером приховане темне минуле. Коли доньку його друга викрадають, Левон змушений згадати навички, завдяки яким він став легендою і які так довго намагався приховати. На кону – життя невинних. Його вороги – великий синдикат, що займається торгівлею людьми. Але він – справжній профі, який ніколи не відступить від своєї мети: врятувати близьких і позбавити світ від справжніх негідників."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"重裝制裁","runtime":0,"tagline":"上下勾結的犯罪結構，就由他來打掉重練","homepage":"","overview":"妻子過世之後，萊文凱德（傑森史塔森 飾）離開了皇家海軍陸戰隊，轉當建築工人。某天，萊文的老闆女兒離奇失蹤，於是拜託萊文運用他過去的技能幫忙找人，結果意外揭發了一個涉及政府與犯罪集團的龐大犯罪陰謀……。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"رجل عامل","runtime":118,"tagline":"","homepage":"","overview":"تخلى \"ليفون كايد\" عن مسيرة عسكرية لامعة في سلاح العمليات السوداء ليعيش حياة بسيطة كعامل بناء، لكن عندما يختطف تجار البشر ابنة رئيسه التي يعدّها من أهله، فإن رحلة البحث عنها لإعادتها إلى بيتها تكشف عالماً من الفساد الذي ما كان ليتصور هوله قط."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"סוגר פינות","runtime":0,"tagline":"","homepage":"","overview":"לבון קייד הותיר אחריו קריירה צבאית מעוטרת ביחידת מבצעים חשאיים כדי לחיות חיים פשוטים כפועל בניין מן המניין. אך כאשר בתו של הבוס, אותה הוא רואה כבת משפחה, נחטפת ע\"י ארגון פשע אכזרי בסחר בבני אדם, קייד יוצא למירוץ נגד הזמן להצילה ובדרך חושף עולם תחתון אפל ומושחת בהרבה ממה שיכול היה לדמיין."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Opaki radnik","runtime":0,"tagline":"Trgovci ljudima pazite se!","homepage":"","overview":"Levon Cade okrenuo je leđa svojoj opasnoj prošlosti i pronašao mir u građevinskom poslu. Dok se trudi biti dobar otac i napokon živjeti jednostavnim životom, njegov svijet okrene se naglavačke kada mu šefova kći netragom nestane. U pokušaju da je pronađe, Levon se mora vratiti vještinama koje su ga nekad činile legendom u tajnom svijetu specijalnih operacija. No, što se dublje upušta u istragu, sve više otkriva mračnu urotu koja prijeti uništiti ne samo njegov teško stečeni mir, već i živote onih koje najviše voli."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"","runtime":0,"tagline":"Traficantes de personas, cuidado.","homepage":"https://www.warnerbros.es/peliculas/working-man","overview":"Levon Cade dejó atrás una condecorada carrera militar en las operaciones encubiertas para vivir una vida sencilla trabajando en la construcción. Pero cuando la hija de su jefe, que para él es como de la familia, es secuestrada por traficantes de personas, su búsqueda para traerla a casa descubre un mundo de corrupción mucho mayor de lo que jamás podría haber imaginado."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Resgate Implacável","runtime":116,"tagline":"Traficantes de pessoas, cuidado.","homepage":"","overview":"Ele quer viver uma vida simples e ser um bom pai para sua filha. Mas quando a filha adolescente de seu chefe, Jenny, desaparece, ele é chamado para reempregar as habilidades que o tornaram uma figura lendária nas operações secretas."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Darbininkas","runtime":116,"tagline":"Prekeiviai žmonėmis turėtų bijoti","homepage":"","overview":"Didesnę dalį gyvenimo Levonas Keidas praleido specialiosiose pajėgose. Visgi prieš keletą metų, išsiilgęs ramesnio gyvenimo, vyras nutarė mesti tarnybą ir įsidarbino paprastu darbininku. Puikiai sutardamas tiek su kolegomis, tiek su viršininkais, Levonas mėgaujasi sąžiningu darbu ir paprastais gyvenimo malonumais, o per tuos kelerius metus kolegos jam jau spėjo tapti naująja šeima.\r Tad kai vieną dieną paslaptingai dingsta jo viršininko (kurį vaidina Michaelas Peña) duktė Dženė, Levonas jaučiasi, tarsi kažkas būtų pagrobęs jo paties dukrą. Vyras puikiai žino, kad policija panašioms byloms neturi nei laiko, tad nutaria tyrimo imtis pats.\r Jam teks panaudoti visus ankstesniame gyvenime išmoktus triukus ir patirtį, kad saugiai pargabentų Dženę namo."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Fachowiec","runtime":116,"tagline":"Handlarze ludźmi, strzeżcie się.","homepage":"","overview":"Levon Cade zostawił za sobą utytułowaną karierę wojskową w operacjach specjalnych, aby wieść proste życie pracując w budownictwie. Ale kiedy córka jego szefa, która jest dla niego jak rodzina, zostaje porwana przez handlarzy ludźmi, jego poszukiwania, aby ją sprowadzić do domu, odkrywają świat korupcji o wiele większy, niż kiedykolwiek mógł sobie wyobrazić."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":116,"tagline":"Trafficanti di uomini fate attenzione","homepage":"","overview":"Levon Cade ha lasciato una carriera militare decorata nelle operazioni segrete per vivere una vita semplice lavorando nell’edilizia. Ma quando la figlia del suo capo, che per lui è come una famiglia, viene rapita dai trafficanti di esseri umani, la sua ricerca per riportarla a casa scopre un mondo di corruzione molto più grande di quanto avrebbe mai potuto immaginare."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":117,"tagline":"Menschenhändler seid gewarnt.","homepage":"https://www.warnerbros.de/de-at/filme/working-man","overview":"Levon Cade hat eine erfolgreiche Militärkarriere im Bereich Geheimoperationen hinter sich gelassen, um ein einfaches Leben als Arbeiter auf dem Bau zu führen. Als jedoch die Tochter seines Vorgesetzten, die für ihn wie eine Tochter ist, von einem Menschenhändlerring entführt wird, zieht er noch einmal in den Kampf. Bei seiner Suche stößt er auf eine Welt voller Korruption, die selbst seine schlimmsten Vorstellungen übertrifft."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Levon Cade opustil svoju úspešnú vojenskú kariéru v tajných operáciách, aby začal viesť pokojný život ako stavebný robotník. Keď však unesú dcéru jeho šéfa, ktorú považuje za vlastnú rodinu, vydá sa ju zachrániť. Pátranie ho zavedie do temného sveta obchodovania s ľuďmi a rozsiahlej korupcie, ktorá siaha oveľa hlbšie, než si kedy dokázal predstaviť."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"یک کارگر","runtime":0,"tagline":"","homepage":"","overview":"لوون کید یک نظامی کارکشته ی سایق ارتش را رها میکند تا زندگی ساده ای را در کار ساخت و ساز داشته باشد. اما وقتی دختر رئیسش که برای او مانند خانواده است توسط قاچاقچیان انسان ربوده میشود، جستجوی او برای بازگرداندن او به خانه دنیایی از فساد را آشکار می کند که بسیار بزرگتر از آن چیزی است که او تصور می کرد."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Ağır İşçi","runtime":118,"tagline":"İnsan tacirlerine karşı sessiz bir isyan!","homepage":"","overview":"Levon Cade, eski bir Kraliyet Deniz Komandosu'dur ve artık inşaat işçisi olarak sakin bir yaşam sürmektedir. Ancak patronunun genç kızı Jenny'nin insan kaçakçıları tarafından kaçırılmasıyla birlikte, Levon eski yeteneklerini kullanmak zorunda kalır. Jenny'yi bulmak için çıktığı bu yolculuk, onu büyük bir yolsuzluk ve hükümet ajanlarının insan kaçakçılığına karıştığı bir komploya götürür."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":116,"tagline":"Yhden miehen taistelu ihmiskauppaa vastaan","homepage":"","overview":"Levon Cade on jättänyt taakseen komean uran armeijan erikoisjoukoissa elääkseen yksinkertaista elämää raksamiehenä. Kaikki kuitenkin muuttuu, kun ihmiskauppiaat vievät hänen pomonsa tyttären, joka on Levonille kuin omaa perhettä. Levonin taistelu tytön puolesta paljastaa suuremman korruptioverkoston kuin kukaan olisi voinut uskoa."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"A melós","runtime":116,"tagline":"Emberkereskedők, vigyázat!","homepage":"","overview":"Levon Cade egy kitüntetésekkel díjazott katonai karriert hagyott ott a titkosszolgálatnál, hogy egyszerű életet éljen, és az építőiparban dolgozzon. Amikor azonban emberkereskedők elrabolják a főnöke lányát, aki számára olyan, mintha a családtagja lenne, megígéri, hogy hazaviszi a lányt. Kutatásai során egy olyan romlott világot tár fel, amely sokkal hatalmasabb, mint azt valaha gondolta volna."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"นรกหยุดนรก","runtime":0,"tagline":"","homepage":"","overview":"เลวอน เคด ได้ละทิ้งอาชีพเดิมของเขาเพื่อเริ่มต้นชีวิตใหม่อย่างสุจริตด้วยการทำงานก่อสร้าง เขาต้องการที่จะใช้ชีวิตอย่างเรียบง่ายและเป็นพ่อที่ดีให้กับลูกสาวของเขา แต่เมื่อ เจนนี่ ลูกสาววัยรุ่นของเจ้านายเขาหายตัวไป เขาจึงจำเป็นที่จะต้องนำเอาทักษะที่ทำให้เขาเป็นตำนานในโลกแห่งปฏิบัติการลับกลับมาใช้อีกครั้ง โดยการตามหานักศึกษาสาวที่หายตัวไปได้นำเขาไปสู่ใจกลางของแผนการอาชญากรรมอันชั่วร้าย ที่พร้อมจะสร้างผลกระทบเป็นลูกโซ่ ซึ่งจะคุกคามวิถีชีวิตใหม่ที่เขาพยายามสร้างขึ้นมา"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Mật Vụ Phụ Hồ","runtime":116,"tagline":"Tao tới nơi, tụi mày tới số.","homepage":"","overview":"Levon Cade - cựu biệt kích tinh nhuệ thuộc lực lượng Thủy quân Lục chiến Hoàng gia Anh. Sau khi nghỉ hưu, anh sống cuộc đời yên bình là một công nhân xây dựng tại Chicago (Mỹ). Levon có mối quan hệ rất tốt với gia đình ông chủ Joe Garcia (Michael Peña). Một ngày nọ, cô con gái tuổi teen Jenny (Arianna Rivas) của Joe bị bắt cóc khiến chàng cựu quân nhân phải sử dụng lại các kỹ năng giết chóc của mình để giúp đỡ."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Levon Cade har lämnat en militär karriär inom specialoperationer för att leva ett enkelt liv som byggarbetare. När hans chefs dotter, som är som familj för honom, blir bortförd av människohandlare, avslöjar hans sökande efter henne en värld av korruption som är mycket större än han någonsin hade kunnat föreställa sig."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":116,"tagline":"","homepage":"","overview":"Levon Cade  was een onderscheiden militair betrokken bij geheime operaties, maar heeft die carrière opgegeven voor een eenvoudig leven als bouwvakker. Als de dochter van zijn baas, die hij als familie beschouwt, ontvoerd wordt door mensenhandelaars, gaat hij naar haar op zoek en stuit hij op een onvoorstelbaar grote wereld vol corruptie."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Ένας Απλός Άνθρωπος","runtime":0,"tagline":"","homepage":"","overview":"Ο Λέβον Κέιντ άφησε πίσω τους μια επιτυχημένη καριέρα στις μυστικές επιχειρήσεις των ειδικών δυνάμεων για να ζήσει μια απλή ζωή δουλεύοντας στην οικοδομή. Όμως, όταν η κόρη του αφεντικού του, που είναι σαν οικογένεια για εκείνον, πέφτει θύμα εμπόρων ανθρώπων, η αναζήτησή του για να τη φέρει πίσω αποκαλύπτει έναν κόσμο διαφθοράς πολύ μεγαλύτερο από ό,τι θα μπορούσε ποτέ να φανταστεί."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Работникът","runtime":0,"tagline":"","homepage":"","overview":"Левон Кейд оставя зад гърба си бляскава военна кариера в черните операции, за да води прост живот като строителен работник. Но когато дъщерята на шефа му, която е като семейство за него, е отвлечена от трафиканти на хора, търсенето му, за да я върне у дома, разкрива свят на корупция, далеч по-мащабен, отколкото някога е можел да си представи."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Um Trabalhador Implacável","runtime":0,"tagline":"","homepage":"","overview":"Levon Cade deixou para trás uma carreira militar condecorada nas operações secretas para viver uma vida simples na construção civil. Mas quando a filha do seu patrão, que é como se fosse da sua família, é levada por traficantes de seres humanos, a sua busca para a trazer de volta a casa revela um mundo de corrupção muito maior do que ele alguma vez poderia ter imaginado."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Nevarni gradbinec","runtime":0,"tagline":"Trgovci z ljudmi, pazite se!","homepage":"","overview":"Levon Cade je za seboj pustil odlikovano vojaško kariero v tajnih operacijah, da bi živel preprosto življenje kot gradbeni delavec. Toda ko trgovci z ljudmi ugrabijo hčer njegovega šefa, ki sta mu kot družina, njegovo iskanje razkrije temno zaroto in svet korupcije, ki je veliko večji, kot si je kdaj koli predstavljal. Ta ogroža ne le njegov težko pridobljeni mir, temveč tudi življenja vseh tistih, ki jih ima najraje."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Töömees","runtime":0,"tagline":"Inimkaubitsejad, olge hoiatatud","homepage":"","overview":"Levon Cade vahetas tunnustatud sõjaväekarjääri lihtsa ehitustöölise elu vastu. Kuid kui inimkaubitsejad röövivad ta ülemuse tütre, kes on talle pereliikme eest, paljastab ta tüdrukut otsides arvatust palju üüratuma korruptiivse maailma."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"Working Man","runtime":118,"tagline":"Obchodníci s lidmi dejte si pozor","homepage":"","overview":"Levon Cade opustil svou úspěšnou vojenskou kariéru v tajných operacích, aby začal vést klidný život jako stavební dělník. Když je však unesena dcera jeho šéfa, kterou považuje za vlastní rodinu, vydá se ji zachránit. Pátrání ho zavede do temného světa obchodování s lidmi a rozsáhlé korupce, která sahá mnohem hlouběji, než si kdy dokázal představit."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"La parole d'un homme","runtime":116,"tagline":"Les trafiquants d'être humains sont prévenus","homepage":"https://www.warnerbroscanada.com/fr/films/la-parole-dun-homme","overview":"Un ex-Marine de l'armée royale britannique vole au secours de la fille de son patron, enlevée par un réseau de traite de personnes."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Darba rūķis","runtime":0,"tagline":"","homepage":"","overview":"Levons Keids pameta godalgotu militāro karjeru slepenajās operācijās, lai dzīvotu vienkāršu dzīvi, strādājot celtniecībā. Bet, kad viņa priekšnieka meitu, kas viņam ir kā radiniece, nolaupa cilvēku tirgotāji, cenšoties viņu atvest mājās, viņš atklāj korupcijas pasauli, kas ir daudz lielāka, nekā viņš varēja iedomāties."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Опаки радник","runtime":0,"tagline":"","homepage":"","overview":"Левон Кејд, бивши командос Краљевских маринаца, води миран живот као радник на градилишту у Чикагу. Међутим, Левон је приморан да искористи своје старе вештине како би пронашао своју шефову ћерку, тинејџерку Џени, коју су отели трговци људима, и ускоро открива заверу о корупцији и укључености владиних агената у трговину људима."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"","runtime":118,"tagline":"","homepage":"","overview":"Levon Cade forlod en dekoreret militærkarriere som agent for at leve et enkelt liv som bygningsarbejder. Men da hans chefs datter, der er som familie for ham, bortføres til menneskehandel, afdækker hans jagt på at få hende hjem en verden af korruption meget større, end han kunne have forestillet sig."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Un bărbat de onoare","runtime":118,"tagline":"","homepage":"","overview":"Levon Cade a lăsat în urmă o carieră militară decorată la operații speciale pentru a duce o viață simplă lucrând în construcții. Dar, când fiica șefului său, care este ca o rudă pentru el, e răpită de traficanții de persoane, misiunea lui de a o aduce acasă scoate la iveală o lume a corupției mult mai mare decât și-ar fi putut imagina vreodată."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"პროფესიონალი","runtime":0,"tagline":"","homepage":"","overview":"ამ ფილმის სახელია \"მშრომელი კაცი\" და რომელმა სულელმა თარგმნა ასე? რა შუაშია ნამდვილ სახელთან \"პროფესიონალი\" ?  ლევონ კეიდმა დატოვა თავისი საიდუმლო სამასახურის აგენტის პროფესია, რათა გამხდარიყო მუშა და ემუშავა მშენებლობაზე. მას სურს იცხოვროს უბრალო ცხოვრებით და იყოს კარგი მამა. მაგრამ როდესაც მისი უფროსის თინეიჯერი ქალიშვილი - ჯენი დაიკარგება, მან უნდა გამოიყენოს ის უნარები, რამაც იგი ლეგენდარულ ფიგურად აქცია საიდუმლო ოპერაციების ბნელ სამყაროში. მის ნადირობას დაკარგულ კოლეჯის სტუდენტზე მთავარი გმირი მიჰყავს ბოროტი დანაშაულებრივი შეთქმულების წიაღში, რაც ქმნის ჯაჭვურ რეაქციას, რომელიც საფრთხეს შეუქმნის მის ახალ ცხოვრებას...."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"ワーキングマン","runtime":118,"tagline":"","homepage":"","overview":"レヴォン・ケイドは、受勲もした軍歴を持つ極秘任務隊員だが、そのキャリアを封印し、建設業で質素な生活を送っていた。しかし、彼にとって家族同然である上司の娘が人身売買集団に連れ去られてしまう。彼女を連れ戻そうとするレヴォンは、捜索の過程で想像をはるかに上回る腐敗社会を目の当たりにするのだった。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"重裝制裁","runtime":116,"tagline":"","homepage":"","overview":"妻子過世之後，萊文凱德（傑森史塔森 飾）離開了皇家海軍陸戰隊，轉當建築工人。某天，萊文的老闆女兒離奇失蹤，於是拜託萊文運用他過去的技能幫忙找人，結果意外揭發了一個涉及政府與犯罪集團的龐大犯罪陰謀……。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"رجل عامل","runtime":118,"tagline":"","homepage":"","overview":"تخلى \"ليفون كايد\" عن مسيرة عسكرية لامعة في سلاح العمليات السوداء ليعيش حياة بسيطة كعامل بناء، لكن عندما يختطف تجار البشر ابنة رئيسه التي يعدّها من أهله، فإن رحلة البحث عنها لإعادتها إلى بيتها تكشف عالماً من الفساد الذي ما كان ليتصور هوله قط."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"Un home treballador","runtime":0,"tagline":"","homepage":"","overview":"En Levon Cade va deixar enrere una condecorada carrera militar com a agent d'operacions encobertes per emprendre una vida més senzilla com a treballador de la construcció. Però quan la filla del seu cap, a qui ell considera de la família, és segrestada per uns traficants de persones, la seva cerca per portar-la a casa destapa un món de corrupció d'abast molt superior al que hauria imaginat."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"","runtime":118,"tagline":"","homepage":"","overview":"Levon Cade meninggalkan karier militernya yang gemilang yang berfokus pada operasi rahasia untuk menjalani kehidupan sederhana sebagai pekerja konstruksi. Namun, ketika putri atasannya yang sudah seperti keluarganya sendiri diculik para pedagang manusia, Levon mendapati upayanya dalam menyelamatkan gadis itu telah mengungkap dunia korupsi yang jauh lebih besar dari yang dia pernah bayangkan."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"","runtime":118,"tagline":"","homepage":"","overview":"Levon Cade tinggalkan kerjaya ketenteraan yang cemerlang dalam operasi sulit demi menjalani kehidupan sederhana sebagai pekerja binaan. Namun apabila anak perempuan majikannya, yang dianggap seperti keluarganya sendiri, diculik oleh sindiket pemerdagangan manusia, usaha Levon untuk membawanya pulang telah mendedahkan sebuah dunia penuh korupsi yang jauh lebih besar daripada apa yang dia bayangkan."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"","runtime":118,"tagline":"","homepage":"","overview":"Levon Cade tinggalkan kerjaya ketenteraan yang cemerlang dalam operasi sulit demi menjalani kehidupan sederhana sebagai pekerja binaan. Namun apabila anak perempuan majikannya, yang dianggap seperti keluarganya sendiri, diculik oleh sindiket pemerdagangan manusia, usaha Levon untuk membawanya pulang telah mendedahkan sebuah dunia penuh korupsi yang jauh lebih besar daripada apa yang dia bayangkan."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"SG","english_name":"Malay"},{"data":{"title":"","runtime":118,"tagline":"Menschenhändler seid gewarnt.","homepage":"","overview":"Levon Cade hat eine dekorierte Militärkarriere bei den Black Ops hinter sich gelassen, um ein einfaches Leben als Bauarbeiter zu führen. Doch als die Tochter seines Chefs, die für ihn wie eine Familie ist, von Menschenhändlern entführt wird, stößt er bei seiner Suche nach ihr auf eine Welt der Korruption, die viel größer ist, als er es sich je hätte vorstellen können."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"","runtime":118,"tagline":"Menschenhändler seid gewarnt.","homepage":"","overview":"Levon Cade hat eine dekorierte Militärkarriere bei den Black Ops hinter sich gelassen, um ein einfaches Leben als Bauarbeiter zu führen. Doch als die Tochter seines Chefs, die für ihn wie eine Familie ist, von Menschenhändlern entführt wird, stößt er bei seiner Suche nach ihr auf eine Welt der Korruption, die viel größer ist, als er es sich je hätte vorstellen können."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"CH","english_name":"German"},{"data":{"title":"","runtime":118,"tagline":"","homepage":"","overview":"Levon Cade verruilde een militaire carrière van speciale operaties en hoge onderscheidingen voor een eenvoudiger bestaan als bouwvakker. Maar wanneer de dochter van zijn baas, die hij als familie beschouwt, wordt ontvoerd door mensenhandelaars onthult zijn zoektocht naar haar een wereld van corruptie die verdergaat dan hij ooit had kunnen denken."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"","runtime":118,"tagline":"","homepage":"","overview":"Levon Cade har lagt bak seg en dekorert militærkarriere i spesialstyrkene for å leve et enkelt liv som bygningsarbeider. Men når datteren til sjefen – som er som familie for ham – blir bortført av menneskehandlere, starter han en intens jakt som avdekker et nettverk av korrupsjon langt større enn han noensinne kunne ha forestilt seg."},"name":"Bokmål","iso_639_1":"nb","iso_3166_1":"NO","english_name":"Norwegian Bokmål"},{"data":{"title":"","runtime":118,"tagline":"","homepage":"","overview":"Levon Cade har lagt bak seg en dekorert militærkarriere i spesialstyrkene for å leve et enkelt liv som bygningsarbeider. Men når datteren til sjefen – som er som familie for ham – blir bortført av menneskehandlere, starter han en intens jakt som avdekker et nettverk av korrupsjon langt større enn han noensinne kunne ha forestilt seg."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"}],"reviews_tmdb":[{"id":"67e559a75e8e5c9bacba471a","url":"https://www.themoviedb.org/review/67e559a75e8e5c9bacba471a","author":"Manuel São Bento","content":"FULL SPOILER-FREE REVIEW @ https://fandomwire.com/a-working-man-review/\r\n\r\n\"A Working Man is a textbook example of a movie that fails in every fundamental aspect of its own genre.\r\n\r\nWithout impactful action sequences, engaging characters, or any valid attempt at innovation or narrative depth, David Ayer delivers a frustratingly generic, utterly forgettable experience.\r\n\r\nJason Statham does his best to elevate a project doomed from the first draft of the script, but not even his charismatic presence can save a film that will inevitably end as one of the worst of the year.\"\r\n\r\nRating: D","created_at":"2025-03-27T13:59:03.871Z","updated_at":"2025-03-27T13:59:03.956Z","author_details":{"name":"Manuel São Bento","rating":3,"username":"msbreviews","avatar_path":null}},{"id":"67e559a85f3e0ac1880027b0","url":"https://www.themoviedb.org/review/67e559a85f3e0ac1880027b0","author":"Manuel São Bento","content":"FULL SPOILER-FREE REVIEW @ https://fandomwire.com/a-working-man-review/\r\n\r\n\"A Working Man is a textbook example of a movie that fails in every fundamental aspect of its own genre.\r\n\r\nWithout impactful action sequences, engaging characters, or any valid attempt at innovation or narrative depth, David Ayer delivers a frustratingly generic, utterly forgettable experience.\r\n\r\nJason Statham does his best to elevate a project doomed from the first draft of the script, but not even his charismatic presence can save a film that will inevitably end as one of the worst of the year.\"\r\n\r\nRating: D","created_at":"2025-03-27T13:59:04.209Z","updated_at":"2025-03-27T13:59:04.303Z","author_details":{"name":"Manuel São Bento","rating":3,"username":"msbreviews","avatar_path":null}},{"id":"67e6fc6cfa4b524e047680c5","url":"https://www.themoviedb.org/review/67e6fc6cfa4b524e047680c5","author":"r96sk","content":"$11","created_at":"2025-03-28T19:45:48.271Z","updated_at":"2025-03-28T19:45:48.358Z","author_details":{"name":"","rating":8,"username":"r96sk","avatar_path":"/mwR7rFHoDcobAx1i61I3skzMW3U.jpg"}},{"id":"67eb57fad9981fda187aa48d","url":"https://www.themoviedb.org/review/67eb57fad9981fda187aa48d","author":"MovieGuys","content":"$12","created_at":"2025-04-01T03:05:30.293Z","updated_at":"2026-01-04T01:02:02.949Z","author_details":{"name":"","rating":3,"username":"MovieGuys","avatar_path":null}},{"id":"67ef8874ede8d82f3bad0b34","url":"https://www.themoviedb.org/review/67ef8874ede8d82f3bad0b34","author":"Louisa Moore - Screen Zealots","content":"$13","created_at":"2025-04-04T07:21:24.492Z","updated_at":"2025-04-04T07:21:24.557Z","author_details":{"name":"Louisa Moore - Screen Zealots","rating":5,"username":"screenzealots","avatar_path":null}},{"id":"67f17796a7336870ee994c8b","url":"https://www.themoviedb.org/review/67f17796a7336870ee994c8b","author":"CinemaSerf","content":"$14","created_at":"2025-04-05T18:33:58.624Z","updated_at":"2025-04-05T18:35:38.418Z","author_details":{"name":"CinemaSerf","rating":6,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}},{"id":"6856e3b8fc794f584853c8a3","url":"https://www.themoviedb.org/review/6856e3b8fc794f584853c8a3","author":"Dean","content":"Was really good. Jason's movies never disappoint.","created_at":"2025-06-21T16:54:16.391Z","updated_at":"2025-06-21T16:54:16.464Z","author_details":{"name":"Dean","rating":8,"username":"Ditendra","avatar_path":"/pbZ9zJZEVYmtmjOZHPRvnnYxqYt.png"}}],"recommendations":[{"id":668489,"adult":false,"title":"Havoc","video":false,"overview":"When a drug heist swerves lethally out of control, a jaded cop fights his way through a corrupt city's criminal underworld to save a politician's son.","genre