9:{"metadata":[["$","title","0",{"children":"Sidewalls | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Martin is a neurotic web designer taking baby steps out of the isolation of his one-room apartment and his virtual reality. Mariana is an artist fresh out of a a long relationship. They are perfect for each other, live on the same street, in opposite buildings, but they never meet. Can the movement of a modern city of three million people bring them together?"}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148397/sidewalls"}],["$","meta","5",{"property":"og:title","content":"Sidewalls"}],["$","meta","6",{"property":"og:description","content":"Martin is a neurotic web designer taking baby steps out of the isolation of his one-room apartment and his virtual reality. Mariana is an artist fresh out of a a long relationship. They are perfect for each other, live on the same street, in opposite buildings, but they never meet. Can the movement of a modern city of three million people bring them together?"}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148397/sidewalls"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/4LkufGzat0GMRDEr88w0oHQM2CD.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Sidewalls"}],["$","meta","12",{"name":"twitter:description","content":"Martin is a neurotic web designer taking baby steps out of the isolation of his one-room apartment and his virtual reality. Mariana is an artist fresh out of a a long relationship. They are perfect for each other, live on the same street, in opposite buildings, but they never meet. Can the movement of a modern city of three million people bring them together?"}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/4LkufGzat0GMRDEr88w0oHQM2CD.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
