"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":720,"height":1080,"file_path":"/pWPUzV9arFeyJoH0wO2cxuGWT9U.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/nbY7wxLTEwjgrg4MSXBKiHIRDgh.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/xv9XGs20dEaefw4zXRfK2tT5qeb.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/WvmISrOwFPf1pG9rEgYYmBmkb2.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/gq7PzTbvlMEyfK7WVVXYMTFIsoi.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/llMbp3RzOCljNwbTA5SRY12HytE.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1179,"height":1756,"file_path":"/pjxHHFYwymvWy1c5kxCvXdKJzNE.jpg","iso_639_1":"ja","iso_3166_1":"JP","vote_count":0,"aspect_ratio":0.671,"vote_average":0},{"width":667,"height":1000,"file_path":"/eZgSmCFcUt3sY64Yn147TtNiJBM.jpg","iso_639_1":"pl","iso_3166_1":"PL","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":715,"height":1000,"file_path":"/2qIp1MPGqyHgQV4bkpzwHuU1Ccp.jpg","iso_639_1":"pl","iso_3166_1":"PL","vote_count":0,"aspect_ratio":0.715,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/r8xotdjJLzZpdbj3Iz636bUi3oR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/yHm2UbcaDMk80EWLEoOKapPZNmO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":2560,"height":1440,"file_path":"/l6gTVFAGr4JRQ5gRIQCV6zr9kkf.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1512,"height":850,"file_path":"/dBDhCYgyxsHsJuY6s1qbqwEAmQE.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":1920,"height":1080,"file_path":"/yki6wBPJjywtup9UwT1Bj8jK6WX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/H2GrWAyvyvyGwk3zg8GdmSiYiS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/fW8ha4PZ5c5pmFqpnr5ZYpej2fG.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/kuFgoLbRArdwsIEMfW75PpG5dhs.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/8aUCIfgJn42Z5mZkQATYBbwBFHp.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/9aC42aNqtiJrHCFNdWqIDXS7k00.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/6Ako3KE0661dE7jJCNea7aeqArq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/vPz6DkJPc1K6vKaW4QFM7pwBMC3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/1zFfXWYCyZp1JE3xHTxvOWWSEWv.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/gPbBrWA9Un6w6WUeAYayWJIA069.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2398,"height":1348,"file_path":"/zqUipwRvKZGTALw4Gz9wzkfKC0g.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":1920,"height":1080,"file_path":"/ft5b40h2uSjhkyRucIGmHH9Gaos.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T03:30:43.003+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":93,"tagline":"A Tsunami Just Flipped The Foodchain.","homepage":"","overview":"A freak tsunami traps shoppers at a coastal Australian supermarket inside the building ... along with a 12-foot great white shark."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":93,"tagline":"","homepage":"","overview":"Vi har alle sammen prøvet det! Man er ude at handle, og pludselig er supermarkedet fyldt med vand og kæmpehajer! Det er præcist, hvad der sker for en håndfuld indbyggere i en lille ferieby. Da en tsunami rammer byen er de pludselig fanget i et oversvømmet supermarket! Men ikke nok med det, vandet har bragt nogle meget sulte kæmpehajer med sig og snart begynder den lille gruppe handlende at blive spist en efter en. De overlevende må nu arbejde sammen for at komme hjem med alle deres varer og i et stykke."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Shark","runtime":91,"tagline":"Il terrore scorre in profondità","homepage":"","overview":"Uno strano tsunami intrappola i clienti di un supermarket di una località balneare australiana all'interno del negozio ... insieme con un gruppo di squali tigre."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":0,"tagline":"Um tsunami acabou de virar a cadeia alimentar.","homepage":"","overview":"Este filme é sobre um grupo de pessoas que ficam presas em um supermercado depois de um tsunami atingir a costa de Queensland, na Austrália. Mas eles logo descobrem que eles têm mais que se preocupar do que estar em um supermercado inundado, há um tubarão nadando 12 metros ao redor deles, e que está com fome."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":93,"tagline":"","homepage":"","overview":"In een slaperig kustresort wordt het winkelend publiek geterroriseerd door een dwaze crimineel in een plaatselijke supermarkt. Dan gebeurt het ondenkbare. Een enorme tsunami treft het stadje. Gevangen in een overstroomde supermarkt met een gewapende maniak en het gevaar om te verdrinken, ontdekken ze dat ze niet alleen zijn."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Vad är värre än att drabbas av en tsunami? Det är att bli drabbad av en tsunami full med hungriga hajar när man storhandlar en lördag i köpcentret. Det är den legendariske regissören bakom Highlander-filmerna och Resident Evil som står bakom denna groteska och ruggiga rysare där ett australiensiskt köpcenter förvandlas till en makaber version av Sea World – med dig som bete!"},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Цунами 3D","runtime":0,"tagline":"Цунами 3D","homepage":"","overview":"Чудовищное цунами обрушивается на курортный город. Из морских глубин на затопленные улицы вырываются голодные и жаждущие крови акулы. Начинается охота. Оказавшись в ловушке стихии, чудом уцелевшие люди пытаются выжить. Сможет ли Джош спасти жизнь девушки, которую он всегда любил, но однажды уже потерял?"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":93,"tagline":"","homepage":"","overview":"Σε μια παραλία της Αυστραλίας, ένα τσουνάμι στο πέρασμα του παρασύρει τα πάντα. Ένα κατάστημα γεμάτο από πολίτες και υπαλλήλους πλημμυρίζει. Οι επιζώντες ενωμένοι προσπαθούν να απεγκλωβιστούν από τα ερείπια του καταστήματος και κάνουν τα πάντα για να επιβιώσουν. Όμως, δεν είναι μόνοι, ακόμα ένας κίνδυνος καραδοκεί, που είναι πιο επικίνδυνος. Οι λευκοί καρχαρίες, που τους έχει παρασύρει το τσουνάμι και βρίσκονται στο πλημμυρισμένο κατάστημα."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"","runtime":94,"tagline":"Un violent tsunami s'est abattu sur leur ville. Ils pensaient avoir survécu au pire… Ils avaient tort.","homepage":"","overview":"Alors qu'un tsunami vient de frapper une ville balnéaire, un groupe d'individus se retrouve piégé dans un supermarché inondé, devenu également le refuge et le terrain de chasse du plus dangereux des prédateurs !"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Bait - Haie im Supermarkt","runtime":90,"tagline":"Jetzt sind wir das Schnäppchen!","homepage":"","overview":"Genau ein Jahr, nachdem der Rettungsschwimmer Josh seinen besten Freund durch einen Haiangriff sterben sah und aus Trauer die Verlobung mit Tina auflöste, überschwemmt eine Tsunami-Welle den Strand einer australischen Kleinstadt und schließt die beiden in einem Supermarkt ein, der obendrein gerade überfallen wird. Nun sitzen die Überlebenden, darunter ein verletzter Polizist und diverse Angestellte, auf den Regalen der überfluteten Mall und stehen auf dem Speiseplan eines von der Riesenwelle eingespülten, gefräßigen weißen Hais."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Bait (Carnada)","runtime":93,"tagline":"Limpieza en pasillo 7.","homepage":"","overview":"Un monstruoso tsunami, en la costa australiana, atrapa a los compradores de un supermercado en el interior del edificio junto con un gran tiburón blanco. Ahora ellos deberán luchar por sus vidas."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"大海啸之鲨口逃生","runtime":0,"tagline":"","homepage":"","overview":"　　宁静的澳洲海滩上，宿醉的救生员乔许（泽维尔·塞缪尔 Xavier Samuel 饰）让女友蒂娜（沙妮·文森 Sharni Vinson 饰）的哥哥罗利替他去海上例行检查防鲨网的设置，结果罗利遭到了鲨鱼的袭击，罗利的死对乔许和蒂娜造成了很大的心理阴影，乔许为此对女友充满了歉疚，乔许为此放弃了救生员的工作去超市做了理货员，蒂娜也远赴中国学习舞蹈。一年后，当蒂娜重新返回澳洲后，和乔许在超市不期而遇，与此同时，超市里风起云涌，偷窃、抢劫……就在这起突发事件白炽化的时候，地动天摇，海啸铺天盖地而来，超市立刻沦为孤岛，大鲨鱼随之而来，一场人鲨大战瞬间展开……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Csalétek","runtime":93,"tagline":"","homepage":"","overview":"Egy álmos kisváros szupermarketébe egy csapat fegyveres tör be, ám a rablást nem sikerült befejezniük, mivel éppen akkor egy hatalmas cunami söpör végig a városon, ami csapdába ejti az összes bent tartózkodót. A túlélők egyre kétségbeesettebben keresik kiutat, ráadásul észreveszik, hogy a szökőár további kéretlen látogatókat hozott az áruházba: borotvaéles fogakkal felszerelkezett, éhes cápákat…"},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"W szczękach rekina","runtime":0,"tagline":"","homepage":"","overview":"Twórcy \"Matriksa Reaktywacji\" i \"Piekielnej głębi\" połączyli siły, tworząc thriller dla widzów o naprawdę mocnych nerwach! Może się wydawać, że tylko kąpiel w oceanie naraża na rozszarpanie przez rekina. Nic bardziej mylnego. Grupa ludzi po przejściu fali tsunami zostaje uwięziona w zalanym supermarkecie. Szybko okazuje się, że nie są tam sami...  \"W szczękach rekina 3D\" to film dla wszystkich kochających ekstremalne przeżycia w kinie! Efekt 3D sprawi, że otrzesz się o śmierć..."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Žraločí invaze","runtime":92,"tagline":"","homepage":"","overview":"Tina a Josh jsou mladý šťastný pár. Jejich spokojený život ovšem přeruší tragická smrt Tinina bratra, kterého napadne a zabije velký bílý žralok. Josh si jako záchranář vyčítá jeho smrt a jejich vztah se rozpadne. Po roce na sebe ti dva narazí v supermarketu, kde Josh začal po tragédii pracovat. Jejich náhlou konfrontaci ovšem přeruší zloděj, který přišel supermarket vykrást. Nikdo v obchodě ovšem netuší, že už se blíží obrovská vlna Tsunami, která je všechny společně v obchodě uvězní a nepřinese sebou pouze ničivou vodní sílu, ale i dva krvelačné bílé žraloky."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"פיתיון","runtime":0,"tagline":"","homepage":"","overview":"לאחר פגיעה של צונמי, הפוגע בקהילה שקטה שנמצאת ליד הים, קבוצה של ניצולים בודדים מוצאים את עצמם לכודים בתוך חנות-קניות מוצף במים. כאשר הם מנסים לברוח הם מגלים שמסביבם מחכים עמלצים לבנים שפיתחו תיאבון לבשר אדם."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Captivi fără scăpare","runtime":0,"tagline":"","homepage":"","overview":"Un tsunami teribil de puternic izolează un grup de clienți într-un supermarket din zona de coastă a Australiei. Valul aduce, însă, cu el, și o \"haită\" de rechini-tigru..."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Yem","runtime":0,"tagline":"","homepage":"","overview":"Köpekbalığı saldırılarıyla ilgili yepyeni bir gerilim filmi... Depremin sarsıcı etkilerinden Tsunami hakkında enteresan bir senaryoya sahip olan ‘Bait 3D’ Avustralya yapımı. 3 boyutlu olarak çekilen film, bir grup insanın Tsunami sonrasında sular altında kalan bir markette mahsur kalmalarını ve okyanus sularıyla birlikte gelen davetsiz misafirlerle olan mücadelelerini anlatıyor. Kaplan köpekbalığı türündeki vahşi hayvanlar ve bir grup soyguncu markette kısılı kalan ahaliye zor anlar yaşatıyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Стръв 3D","runtime":0,"tagline":"История с акули.","homepage":"","overview":"В малко крайбрежно градче посетителите в подземен супермаркет са тероризирани от обезумял престъпник, който заплашва, че ще ги убие. Но това е само началото на проблемите - малко след нападението на престъпника изненадващо и огромно цунами връхлита града и помита хиляди жители и туристи. Попаднали в капан и застрашени от прииждащата вода оцелелите в супермаркета са на път да открият, че истинския ужас тепърва предстои. Заедно с водата в града са се появили и голям брой кръвожадни акули, които атакуват всяко едно живо същество което им се изпречи на пътя."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"베이트","runtime":0,"tagline":"폐허 속에 들이닥친 또 다른 공포! 놈들에게서 살아남아야 한다!","homepage":"","overview":"평화로운 오후, 순식간에 불어 닥친 끔찍한 쓰나미는 아름다운 해변 도시를 휩쓸어 버린다. 폐허가 된 대형 마트에서 생존자는 단 13명. 이미 헤어졌던 연인과 현재의 연인, 그리고 사이가 좋지 않은 부녀, 마트에 침입했던 강도와 경찰까지, 저마다의 사연이 있는 그들을 미끼로 노리는 포식자의 공격이 시작된다!"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Hirvittävä tsunami iskee Australian rannikkokaupunkiin ja upottaa suuren osan alueesta veden alle. Ryhmä toisilleen vieraita ihmisiä jää loukkuun veden saartamaan maanalaiseen supermarkettiin ja sen parkkihalliin.\r Pian selviytyjät huomaavat, että nouseva vesi ja sähköiskujen vaara eivät ole heidän ainoat ongelmansa. Tulva on tuonut mukanaan valtamerestä nälkäisiä valkohaita, jotka partioivat kaupan hyllyjen välissä. Loukussa olevien on tehtävä yhteistyötä ja löydettävä keino päästä ulos ennen kuin hait poimivat heidät yksi kerrallaan tai ennen kuin happi loppuu upoksissa olevasta rakennuksesta."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"โคตรฉลามคลั่ง","runtime":0,"tagline":"โคตรฉลามคลั่ง","homepage":"","overview":"ชุมชนเล็กๆริมหาดแสนสงบ แม่บ้านนักช๊อปกำลังจับจ่ายซื้อของในซูเปอร์มาร์เก็ตชั้นใต้ดินต้องตกอยู่ใน ความตระหนกเมื่อมีโจรบุกเข้าปล้น ฉับพลันคลื่นทรึนามิก็พัดถล่มให้ทั้งเมืองพังพาบ ทว่าผู้คนที่ยังติดอยู่ใต้ดินไม่สามารถออกมาได้ขณะที่ปริมาณน้ำค่อยๆซึมและ เริ่มเพิ่มระดับ กลุ่มคนคลั่งติดอาวุธครบมือ มันเหมือนสุสานใต้บาดาล ความกดอากาศ อุหภูมิ ทุกอย่างคือบททดสอบว่าใครจะสามารถเอาตัวรอดในสถานการณ์ขับขันนี้ได้ พวกเขาต้องการมีชีวิตไม่ว่าจะแลกด้วยอะไร แต่มันก็ไม่ง่ายเมื่อกลุ่มผู้รอดจะต้องถูกโจมตีด้วยเพชรฆาตแห่งท้องทะเลลึก ซึ่งคลื่นทรึนามินำมันติดมาด้วย ยิ่งน้ำที่ทะลักเข้ามาเพิ่มระดับ ฝูงฉลามเสือกระหายเลือดที่กำลังหิวก็พร้อมที่จะแหวกว่ายไปทุกซอกมุม"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Цунамі","runtime":0,"tagline":"Полювання розпочалось","homepage":"","overview":"Жахливе цунамі обрушується на курортне місто. З морських глибин на затоплені вулиці вириваються голодні і спраглі крові акули. Починається полювання. Опинившись у пастці стихії, дивом уцілілі люди намагаються вижити. Чи зможе Джош врятувати життя дівчини, яку він завжди кохав, але одного разу вже втратив?"},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Carnada","runtime":93,"tagline":"","homepage":"","overview":"Un gran tsunami atrapa a un grupo de personas en una tienda de abarrotes sumergible. Mientras ellos intentan escapar, ellos son atacados por unos tiburones blancos que están hambrientos de carne."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"A Isca","runtime":0,"tagline":"Prenda seu fôlego... Você vai precisar muito dele!","homepage":"","overview":"Numa comunidade costeira tranquila, os vendedores de um supermercado subterrâneo encontram-se aterrorizados quando um bandido invade o local. Ao mesmo tempo, um assustador tsunami atinge a cidade, prendendo-os no estabelecimento praticamente submerso, enquanto tentam se esquivar do maníaco armado. No entanto, o problema maior ainda está por vir: o tsunami trouxe para o local visitantes do lado profundo das águas. Com o medo de morrer afogado ou assassinado, o grupo ainda precisa sobreviver a essa outra e mais poderosa ameaça: tubarões tigres famintos!"},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"تنظيف الممر 7.","homepage":"","overview":"تسونامي غريب يحبس المتسوقين في سوبر ماركت أسترالي ساحلي داخل المبنى ... إلى جانب سمكة قرش بيضاء ضخمة يبلغ ارتفاعها 12 قدمًا."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Mamac","runtime":0,"tagline":"Čišćenje u prolazu 7.","homepage":"","overview":"Ovo je film o grupi ljudi koji su zatočeni u supermarketu nakon što tsunami udari u obalu Queenslanda u Australiji. Uskoro otkrivaju da im poplava u trgovini nije jedina briga: u vodi koja je došla s poplavom pliva gladni morski pas od 3,5 m."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"ცუნამი","runtime":0,"tagline":"","homepage":"","overview":"საზარელი ცუნამი დაატყდება თავს კურორტულ ქალაქს. ზღვის სიღრმეებიდან დატბორილ ქუჩებში გამოდიან მშიერი და სისხლის მსმელი ზვიგენები. ნადირობა იწყება. სტიქიის ხაფანგში სასწაულად გადარჩენილი ადამიანები ცდილობენ გადარჩენას."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Bẫy Cá Mập","runtime":0,"tagline":"Món khoái khẩu nay là thịt người.","homepage":"","overview":"Bait xoay quanh câu chuyện về một hung thần trắng dưới đại dương, đã tấn công và tàn sát mọi khách du lịch tại bờ biển Coolangatta ở Australia. Khi mọi người vẫn đang vui vẻ nghĩ dưỡng và tận hưởng kỳ nghỉ thì, tai họa ập đến, dần dần mọi người đều bị bỏ mạng dưới hàm răng kinh hoàng của cá mập. Một số người may mắn sống sót hiện đáng trốn trong những tòa nhà, thế nhưng mực nước ngày càng dân cao hơn khiến cá thành phố dần ngập trong biển nước và cá mập có thể di chuyển vào trong những căn nhà và tiếp tục tàn sát từng người. Vì thế những người còn sống tìm cách chiến đấu và sinh tồn để giữ gìn tính mạng và chờ người tới giúp đỡ."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"パニック・マーケット3D","runtime":0,"tagline":"","homepage":"","overview":"外界から隔絶されてしまったスーパーマーケットで、次々と絶体絶命の危機に襲われる人々の姿を3Dで描いたサバイバルパニック。大洪水にのみこまれ、一軒のスーパーマーケットに閉じ込められた13人の生存者たち。水浸しの店内には高圧電線が垂れ下がり、水中からは巨大な人食いザメが襲いかかるなど、次々とピンチが訪れる。さらに、13人の中には強盗殺人犯が紛れ込んでいることがわかり……。出演は「エクリプス　トワイライト・サーガ」「ドリフト」のゼイビア・サミュエル、「ステップ・アップ3」のシャーニ・ビンソンほか。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Cunami","runtime":91,"tagline":"","homepage":"","overview":"Tina a Josh sú mladý šťastný pár. Ich šťastný život však preruší tragická smrť Tininho brata, ktorého napadol a zabil veľký biely žralok. Josh si ako záchranca dáva jeho smrť za vinu a ich vzťah sa rozpadá. O rok neskôr na seba obaja narazia v supermarkete, kde Josh po tragédii začal pracovať. Ich náhlu konfrontáciu však preruší zlodej, ktorý prišiel vykradnúť supermarket. Nikto v obchode však netuší, že sa blíži obrovská vlna cunami, ktorá ich všetkých spoločne uväzní v obchode a prinesie so sebou nielen ničivú silu vody, ale aj dvoch krvilačných bielych žralokov."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Masalas","runtime":93,"tagline":"","homepage":"https://www.visifilmai.lt/filmas/masalas-2012/","overview":"Australijoje netikėtai smogė cunamio banga ir užtvindė pakrantėje esanti prekybos centrą. Apsemtame prekybos centre žmonės stengiasi išgyventi ir padėti sužeistiesiems. Potvynis turėtų juos mažiausiai jaudinti, nes po prekybos centrą plaukioja du išalkę didieji baltieji rykliai. Įkalinti mirties spąstuose jie susivienija ir stengiasi išgyventi."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"大海嘯之鯊口逃生","runtime":0,"tagline":"","homepage":"","overview":"寧靜的澳洲海灘上，宿醉的救生員喬許（澤維爾·塞繆爾 Xavier Samuel 飾）讓女友蒂娜（沙妮·文森 Sharni Vinson 飾）的哥哥羅利替他去海上例行檢查防鯊網的設置，結果羅利遭到了鯊魚的襲擊，羅利的死對喬許和蒂娜造成了很大的心理陰影，喬許為此對女友充滿了歉疚，喬許為此拋棄了救生員的工作去超市做了理貨員，蒂娜也遠赴中國學習舞蹈。一年後，當蒂娜重新返回澳洲後，和喬許在超市不期而遇，與此同時，超市裏風起雲湧，偷竊、搶劫……就在這起突發事件白熾化的時候，地動天搖，海嘯鋪天蓋地而來，超市立刻淪為孤島，大鯊魚隨之而來，一場人鯊大戰瞬間展開……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[{"id":"561cb053c3a368225800351f","url":"https://www.themoviedb.org/review/561cb053c3a368225800351f","author":"John Chard","content":"Sharkunami Gone Barmy!\r\n\r\nWhen a tsunami traps shoppers inside a coastal Australian supermarket, their survival prospects are reduced even further when Great White Sharks find their way into the area.\r\n\r\nIt's as nutty as it sounds, a bonkers but wonderfully genius premise is played out with \"B\" movie heart and a smile on its face. Standard rules apply, there's a myriad of characters who are in need of redemption or reconciliations, and of course it's a time for heroes and villains to thrust themselves forward. Action and suspense is never far away, and neither is blood! There's even some humour to be found, especially with a bickering couple of teenage lovers.\r\n\r\nSome of the CGI is poor and as is the norm with this type of film, there's daft scenes that ask you to just roll with it. If you can do that then there's a good time to be had here. 6/10","created_at":"2015-10-13T07:18:43.668Z","updated_at":"2024-05-16T15:22:11.920Z","author_details":{"name":"","rating":6,"username":"John Chard","avatar_path":"/utEXl2EDiXBK6f41wCLsvprvMg4.jpg"}},{"id":"5ec0fba79979d2001f2dc31b","url":"https://www.themoviedb.org/review/5ec0fba79979d2001f2dc31b","author":"Peter89Spencer","content":"Not a bad Shark horror film, since Jaws.\r\nThe Aussies never disappoint.","created_at":"2020-05-17T08:53:59.011Z","updated_at":"2021-06-23T15:58:38.154Z","author_details":{"name":"","rating":7,"username":"Peter89Spencer","avatar_path":null}},{"id":"6352fcc19369a20079d156d7","url":"https://www.themoviedb.org/review/6352fcc19369a20079d156d7","author":"The Movie Mob","content":"**Bait isn't groundbreaking or particularly impressive but slightly edges out typical low-budget shark flicks with a creative setting.**\r\n\r\nBait's concept and setting bear similarities to 2019's alligator thriller Crawl. A tsunami traps a small band of survivors in a flooded underground supermarket with hungry man-eating great whites. The quality doesn't rise to the level of The Shallows or Crawl, but it's pretty solid for a non-Hollywood 3D low-budget film. I was expecting a goofy shark film with dreadful performances (which I love) and was surprised by something a little better. Don't get me wrong, it isn't a gold standard for anything, but in a subgenre built on low-budget cheesiness, Bait shows a little more effort than most.","created_at":"2022-10-21T20:10:41.088Z","updated_at":"2022-10-21T20:33:42.265Z","author_details":{"name":"The Movie Mob","rating":6,"username":"mooney240","avatar_path":"/blEC280vq31MVaDcsWBXuGOsYnB.jpg"}},{"id":"63e6a3e49512e1007f176396","url":"https://www.themoviedb.org/review/63e6a3e49512e1007f176396","author":"CinemaSerf","content":"$11","created_at":"2023-02-10T20:07:00.105Z","updated_at":"2023-02-10T20:07:00.188Z","author_details":{"name":"CinemaSerf","rating":5,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":77883,"adult":false,"title":"The Possession","video":false,"overview":"A young girl buys an antique box at a yard sale, unaware that inside the collectible lives a malicious ancient spirit. The girl's father teams with his ex-wife to find a way to end the curse upon their child.","genre_ids":[27,53],"media_type":"movie","popularity":1.952,"vote_count":1682,"poster_path":"/4VxIbGO5A9HRlkAPMi70zimosDY.jpg","release_date":"2012-08-30","vote_average":6.036,"backdrop_path":"/A83Y5I16txh9lZGlhHP37PhBh33.jpg","original_title":"The Possession","original_language":"en"},{"id":786064,"adult":false,"title":"The Great Indian Kitchen","video":false,"overview":"After marriage, a woman struggles to be the submissive wife that her husband and his family expect her to be.","genre_ids":[18],"media_type":"movie","popularity":0.4166,"vote_count":48,"poster_path":"/f6SDfxoU3l8hpe9tzzf8MyjOPHL.jpg","release_date":"2021-01-15","vote_average":7.6,"backdrop_path":"/pyYcByKY5HyRsYdhTyIwFOnO6jT.jpg","original_title":"മഹത്തായ ഭാരതീയ അടുക്കള","original_language":"ml"},{"id":41240,"adult":false,"title":"Bastard Out of Carolina","video":false,"overview":"A poor, struggling South Carolinian mother and daughter face painful choices with their resolve and pride. Bone, the eldest daughter, and Anney her tired mother, grow both closer and farther apart: Anney sees Glen as her last chance.","genre_ids":[18],"media_type":"movie","popularity":0.9048,"vote_count":80,"poster_path":"/jYFwFOkHwWxaStR21UIgdb96Gzh.jpg","release_date":"1996-12-15","vote_average":7.1,"backdrop_path":"/qL5Njffzz9kzq17nx2UHIPhauFk.jpg","original_title":"Bastard Out of Carolina","original_language":"en"},{"id":412678,"adult":false,"title":"Killing Salazar","video":false,"overview":"An elite team of DEA agents are assigned to protect a dangerous drug lord and take refuge in a luxury hotel while they await extraction. They soon find themselves at the center of an ambush as the drug lord's former associates launch an explosive assault on the hotel.","genre_ids":[80,28,12,53],"media_type":"movie","popularity":0.4487,"vote_count":62,"poster_path":"/2J7jc9VZroyf4rFlyWJ0mIreu2A.jpg","release_date":"2017-01-23","vote_average":4.9,"backdrop_path":"/op8VP5bKaRSKO7MxDi4BKOuAeKL.jpg","original_title":"Killing Salazar","original_language":"en"},{"id":537347,"adult":false,"title":"Viking Destiny","video":false,"overview":"A Viking Princess is forced to flee her kingdom after being framed for the murder of her father, the King. Under the guidance of the God Odin, she travels the world gaining wisdom and building the army she needs to win back her throne.","genre_ids":[12,28,14],"media_type":"movie","popularity":1.4844,"vote_count":51,"poster_path":"/oHPPUlwR4UNOGe1ne68kawiGOed.jpg","release_date":"2018-07-26","vote_average":5.2,"backdrop_path":"/gt4W35yrQTeJbMwT2PVGF33c2eF.jpg","original_title":"Viking Destiny","original_language":"en"},{"id":115724,"adult":false,"title":"Do You Know Me","video":false,"overview":"Ellie Carter is recently graduated and has it all. While celebrating with friend and boyfriend, she comes across a milk carton with a picture of a missing child that looks a lot like her. As a prank, they call the toll free number and she realizes that this person could be her. The more she finds out, the closer she gets to getting herself and beloved ones killed.","genre_ids":[80,9648,53],"media_type":"movie","popularity":1.1132,"vote_count":14,"poster_path":"/uY2yDcBvTl86RJ6Qg3sBsrYBMBi.jpg","release_date":"2009-05-17","vote_average":4.857,"backdrop_path":"/aXDiN09MD3XXCRI0rhJcxtL4s69.jpg","original_title":"Do You Know Me","original_language":"en"},{"id":60264,"adult":false,"title":"Urgency","video":false,"overview":"Returning home after difficult negotiations with potential customers, an employee of the Los Angeles-based pharmaceutical company, Tony West realizes that his wife is captured, while its unit and return home unscathed criminals require $ 50,000 in the next half hour. Doomed to hear Tony goes in search of money, but soon realizes that the kidnapping was not connected with the money …","genre_ids":[28,12,53],"media_type":"movie","popularity":0.646,"vote_count":7,"poster_path":"/yKdixnjoIERqodxXkfy0t3EhT2V.jpg","release_date":"2010-01-01","vote_average":2.9,"backdrop_path":"/vgFrze0B3SRjJtoaxm0YRaXsGKK.jpg","original_title":"Urgency","original_language":"en"},{"id":149906,"adult":false,"title":"Bryan Adams: So Far So Good","video":false,"overview":"So Far So Good is a compilation album by Bryan Adams, released by A&amp;M Records in November 1993. The album reached number six on The Billboard 200 charts in 1993. The album was number one hit in UK and many other countries.  The album contains hits from between \"Cuts Like a Knife\" (1983) and Waking Up the Neighbours (1991), and a new single, \"Please Forgive Me\", although all cuts appear in their album versions. Originally the song \"So Far So Good\" was going to be included on the album so the album started and finished with a new song but it was dropped. The song was included on disc two of Anthology.","genre_ids":[10402],"media_type":"movie","popularity":0.0487,"vote_count":9,"poster_path":"/lpv7NmPKlE5lTPkoihdTIliMoqr.jpg","release_date":"2002-04-01","vote_average":8.7,"backdrop_path":"/me1iTuCC9unKImMq7KqL10exw6c.jpg","original_title":"Bryan Adams: So Far So Good","original_language":"en"},{"id":1025838,"adult":false,"title":"Cold Case Detective","video":true,"overview":"A strange case happened in Haifuxiang Hospital! Ruan Yannian, the eunuch who was favored by Puyi in the Manchu state, woke up from a severe coma, smashed his head in an incredible way, and dug his own brain to eat. The abbot of the dojo was convinced that it was harmed by the \"Three Corpse Insects\", the resident deity responsible for monitoring, informing and sabotage. Song Mei and Wan Guobao, who were in charge of the investigation, originally laughed at these things, but Geng Shen day and night, the three corpse bugs ran out of the patient's eyes in front of them... Seeing is proof? wrong! What amazing secrets and conspiracies are behind this bizarre, they are determined to reveal!","genre_ids":[],"media_type":"movie","popularity":0.0261,"vote_count":1,"poster_path":"/s6w7KdXL9cIs4gEsp3cQchiS25x.jpg","release_date":"2018-06-20","vote_average":5,"backdrop_path":"/3SqR3frkN9dS8s9sytMnDwNI6es.jpg","original_title":"悬案委托行","original_language":"zh"},{"id":406859,"adult":false,"title":"This Time Tomorrow","video":false,"overview":"Bright and beautiful, 17-year-old Adelaida enjoys a comfortable family life with her parents in an apartment in Bogotá. But soon the cracks begin to show through the veneer of this picture perfect family.","genre_ids":[18],"media_type":"movie","popularity":0.0448,"vote_count":8,"poster_path":"/v0Ko4ZENxPzlzcG6LmvD6EWAAlu.jpg","release_date":"2016-10-07","vote_average":6.1,"backdrop_path":"/a819asED7n8v1okKldhkFAtAAlO.jpg","original_title":"Mañana a esta hora","original_language":"es"},{"id":650055,"adult":false,"title":"A Nossa Bandeira Jamais Será Vermelha","video":false,"overview":"A documentary about the current political state of Brazil.","genre_ids":[99],"media_type":"movie","popularity":0.0495,"vote_count":11,"poster_path":"/x5z8fjpbk75u2YGLiBioybXyKSz.jpg","release_date":"2019-12-09","vote_average":6.4,"backdrop_path":"/uO4bXckZVcHHazl9e5ta04BCtPU.jpg","original_title":"A Nossa Bandeira Jamais Será Vermelha","original_language":"pt"},{"id":325986,"adult":false,"title":"Amnesty International's Big 30","video":false,"overview":"In the tradition of the acclaimed series of British concerts known as The Secret Policemen's Ball, Amnesty International celebrates its 50th Anniversary live at Radio City Music Hall.","genre_ids":[99,35],"media_type":"movie","popularity":0.3824,"vote_count":1,"poster_path":"/kossqJ1d4xxf4ynQOHvxN9U8cj3.jpg","release_date":"1991-12-28","vote_average":4,"backdrop_path":null,"original_title":"Amnesty International's Big 30","original_language":"en"},{"id":265019,"adult":false,"title":"Preservation","video":false,"overview":"Three family members head deep into the woods for a hunting trip that doubles as a distraction from their troubles at home. When all of their gear is stolen, they turn on each other, but soon realize there are much more treacherous forces at work.","genre_ids":[53,27],"media_type":"movie","popularity":0.5373,"vote_count":193,"poster_path":"/ppoOXtJZBPXq9Qf2v9pxaa8UeQg.jpg","release_date":"2014-08-22","vote_average":4.87,"backdrop_path":"/yZHzTJDP9gWDNfcXNiogxgL7rzn.jpg","original_title":"Preservation","original_language":"en"},{"id":1317887,"adult":false,"title":"Lolo and the Kid","video":false,"overview":"A hustler and the child he took in routinely con the wealthy — but a life-changing opportunity could end their inseparable bond.","genre_ids":[18,10751],"media_type":"movie","popularity":0.3274,"vote_count":33,"poster_path":"/a1Eubtd5zCISRsGxpd3CiAYkBao.jpg","release_date":"2024-08-07","vote_average":7.667,"backdrop_path":"/fzj8QCwi9zZBO7pi81bfbTa5fak.jpg","original_title":"Lolo and the Kid","original_language":"tl"},{"id":1319895,"adult":false,"title":"Hostile Takeover","video":false,"overview":"Follows Pete, a professional hitman, as he faces a group of assassins after the boss of a crime syndicate suspects disloyalty due to his attendance at Workaholics Anonymous meetings.","genre_ids":[28,35,53],"media_type":"movie","popularity":6.5007,"vote_count":65,"poster_path":"/AvAgo0AHVAFAPr0vZLAzHPq0ftL.jpg","release_date":"2025-08-08","vote_average":6.923,"backdrop_path":"/tIfLu82gSgcgsXS6jvNFjwMqcKp.jpg","original_title":"Hostile Takeover","original_language":"en"},{"id":84226,"adult":false,"title":"The Day","video":false,"overview":"Open war against humanity rages. For five survivors – lost and on the run – the pursuit is relentless, the bullets are dwindling and the battle is everywhere. This is a 24-hour look into their lives.","genre_ids":[28,18,27,878],"media_type":"movie","popularity":1.2657,"vote_count":275,"poster_path":"/zNFCkFmgI4Dnv3UpC0lLM7jWhYU.jpg","release_date":"2011-09-15","vote_average":5.131,"backdrop_path":"/6axH52yRnDuj3ToK68tes9aDx3a.jpg","original_title":"The Day","original_language":"en"},{"id":7182,"adult":false,"title":"Venom","video":false,"overview":"A group of teenagers fear for their lives in the swamps of Louisiana, chased by Mr. Jangles, a man possessed by 13 evil souls, and now relentless in his pursuit of new victims.","genre_ids":[27,53],"media_type":"movie","popularity":1.3054,"vote_count":362,"poster_path":"/z1oor8urdFc0w2mhYMdzryojMH.jpg","release_date":"2005-09-16","vote_average":5.4,"backdrop_path":"/haP0jnAmZ6AbpGeBlPZForH8GCb.jpg","original_title":"Venom","original_language":"en"},{"id":885121,"adult":false,"title":"Room 203","video":false,"overview":"Two female roommates were tormented by the vengeful spirits dwelling in their gothic-style, rented apartment, which contains an ornate centerpiece.","genre_ids":[27],"media_type":"movie","popularity":0.5003,"vote_count":93,"poster_path":"/t4M0n5kfToiU9TIf22bccSbNu