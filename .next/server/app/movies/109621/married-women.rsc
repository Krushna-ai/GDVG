5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Married Women\",\"description\":\"We are in a fling!  They know men better than men and they don't even need to play hard to get!  Some female owners of a salon, DVD room and beer pub are out looking for some fresh meat other than their husbands. From a building owner to a part-time officer and even guests, these women have what it takes to have them eating out of their hands.\",\"image\":\"https://image.tmdb.org/t/p/w500/3MGoNQQpwHqPW0YhBaCGsOc4h9A.jpg\",\"datePublished\":\"2015-10-14\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"erotic film\",\"Drama\",\"Romance\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7,\"bestRating\":10,\"ratingCount\":2}}"}}],["$","$L10",null,{"initialDrama":{"id":"785b1e98-d736-4ff1-9c80-368f54ad248f","tmdb_id":387834,"imdb_id":null,"content_type":"movie","title":"Married Women","original_title":"유부녀들","overview":"We are in a fling!  They know men better than men and they don't even need to play hard to get!  Some female owners of a salon, DVD room and beer pub are out looking for some fresh meat other than their husbands. From a building owner to a part-time officer and even guests, these women have what it takes to have them eating out of their hands.","poster_path":"/3MGoNQQpwHqPW0YhBaCGsOc4h9A.jpg","backdrop_path":"/sIIY2tluMkFtfL5jARS0l1ubNEo.jpg","release_date":"2015-10-14","first_air_date":null,"status":"published","original_language":"ko","origin_country":["KR"],"genres":[{"name":"erotic film"},{"id":18,"name":"Drama"},{"id":10749,"name":"Romance"},"erotic film"],"popularity":4.4281,"vote_average":7,"vote_count":2,"runtime":0,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-04T22:07:06.118116+00:00","updated_at":"2026-02-23T12:33:34.923+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":136876,"name":"늘푸른시네마","logo_path":null,"origin_country":"KR"}],"production_countries":[{"name":"South Korea","iso_3166_1":"KR"}],"spoken_languages":[{"name":"한국어/조선말","iso_639_1":"ko","english_name":"Korean"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[{"id":155477,"name":"softcore"}],"alternative_titles":[],"videos":[{"id":"5eb27b67caab6d001ddbd889","key":"Avwjqld2o_0","name":"유부녀들 ~ Married Women 2015 trailer","site":"YouTube","size":720,"type":"Trailer","official":false,"iso_639_1":"en","iso_3166_1":"US","published_at":"2017-01-08T13:13:44.000Z"}],"watch_providers":{"results":{}},"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"KR","main_poster":"/3MGoNQQpwHqPW0YhBaCGsOc4h9A.jpg","images":{"logos":[],"posters":[{"width":740,"height":1110,"file_path":"/3MGoNQQpwHqPW0YhBaCGsOc4h9A.jpg","iso_639_1":null,"vote_average":0}],"backdrops":[{"width":1600,"height":900,"file_path":"/sIIY2tluMkFtfL5jARS0l1ubNEo.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T03:50:44.233+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"유부녀들","runtime":90,"tagline":"우리 지금 바람 났어요!","homepage":"","overview":"남자 보다 남자를 더 잘 알고, 밀당 같은 것도 필요 없다!  한 상가 안에 모여 있는 미용실, DVD방, 호프집 여사장들이 지긋지긋한 남편을 벗어나 신선한 남자를 찾아나섰다. 건물주부터 아르바이트생 그리고 손님들까지 모두를 사로잡는 마성의 유부녀들이 지금 매력 발산을 시작한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Married Women","runtime":0,"tagline":"","homepage":"","overview":"We are in a fling!  They know men better than men and they don't even need to play hard to get!  Some female owners of a salon, DVD room and beer pub are out looking for some fresh meat other than their husbands. From a building owner to a part-time officer and even guests, these women have what it takes to have them eating out of their hands."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"有夫之妇","runtime":0,"tagline":"","homepage":"","overview":"　　2015韩国电影《有夫之妇》讲述的是聚集的商场里有美容院、DVD、店张女士的丈夫寻回了新鲜人找我。建筑物周开始兼职和客人都吸引到了有夫之妇们正在散发的魅力。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"有夫之婦","runtime":0,"tagline":"","homepage":"","overview":"2015 韓國電影《有夫之婦》講述的是聚集的商場裏有美容院、DVD、店張女士的丈夫尋回了新鮮人找我。建築物周開始兼職和客人都吸引到了有夫之婦們正在散發的魅力。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":73108,"adult":false,"title":"Teen Spirit","video":false,"overview":"Amber, a mean popular girl who gets electrocuted and dies, is not allowed to enter into heaven unless she helps the least popular girl in school become Prom Queen within a week, but things do not go as planned.","genre_ids":[18,14,35,10770],"media_type":"movie","popularity":3.3321,"vote_count":298,"poster_path":"/8mmxoEBzTMX4ziYgveeEx35ltNY.jpg","release_date":"2011-08-07","vote_average":5.94,"backdrop_path":"/s75xYQOo4Hy2fy229CEfj5jgC2B.jpg","original_title":"Teen Spirit","original_language":"en"},{"id":359983,"adult":false,"title":"The Lion Guard: Return of the Roar","video":false,"overview":"Set in the African savannah, the film follows Kion as he assembles the members of the 'Lion Guard'. Throughout the film, the diverse team of young animals will learn how to utilize each of their unique abilities to solve problems and accomplish tasks to maintain balance within the Circle of Life, while also introducing viewers to the vast array of animals that populate the prodigious African landscape.","genre_ids":[10751,10770,16,12],"media_type":"movie","popularity":1.4165,"vote_count":1219,"poster_path":"/pzcQ7cQBHIdsKLN4exd7bCyy1pk.jpg","release_date":"2016-01-25","vote_average":6.7,"backdrop_path":"/sYbdAWcTqcdLtpAnwIWjrIw6t0r.jpg","original_title":"The Lion Guard: Return of the Roar","original_language":"en"},{"id":463520,"adult":false,"title":"The Return","video":false,"overview":"The Return is a 2016 documentary directed by Emmy Award winning director Erich Joiner chronicling Ford GT's return to 24 Hours of Le Mans after their 1966 1-2-3 victory.","genre_ids":[99,28],"media_type":"movie","popularity":0.1957,"vote_count":93,"poster_path":"/ROvTxTwcCN8CyxrV4Rhun9MhYD.jpg","release_date":"2017-06-15","vote_average":6.6,"backdrop_path":"/bOTts5qHl3qiRUpsGYcwVYuOQ1H.jpg","original_title":"The Return","original_language":"en"},{"id":715892,"adult":false,"title":"I Want to Return Return Return","video":false,"overview":"A depiction of the Wrangelkiez neighbourhood in Berlin. The people portrayed tell their life stories. One woman came to the neighbourhood a decade ago to work in Berlin’s still unfinished Brandenburger Airport, one man reminisces his childhood on a Tobacco farm in Kentucky, another speaks of an exceptional day in an otherwise monotonous workplace. These portraits are interwoven with the story of Elpi, a Greek woman who is waiting for the long overdue visit of an old important friend. The outcome of this mixture is a film which captures the lives and perspectives of some of Wrangelkiez’s most commanding citizens, while at the same time evoking the loss that change and time passing means for places and for people.","genre_ids":[99],"media_type":"movie","popularity":0.0628,"vote_count":80,"poster_path":"/goHjKTGvOR2MTgv9PAvltaXxsNY.jpg","release_date":"2020-09-19","vote_average":6.7,"backdrop_path":null,"original_title":"I Want to Return Return Return","original_language":"en"},{"id":495193,"adult":false,"title":"Benji","video":false,"overview":"Two school kids strike up a friendship with an orphaned puppy named Benji. When danger befalls them and they end up kidnapped by robbers who are in over their heads, Benji and his scruffy sidekick come to the rescue.","genre_ids":[18,10751,12,80],"media_type":"movie","popularity":3.074,"vote_count":317,"poster_path":"/79pacM3h5FoETnfuRC6O2qPfzn4.jpg","release_date":"2018-03-16","vote_average":6.9,"backdrop_path":"/eOkbeZ658RHVt7ULoFBqmesxEYX.jpg","original_title":"Benji","original_language":"en"},{"id":172386,"adult":false,"title":"Return to Nim's Island","video":false,"overview":"Fourteen year old Nim, more determined than ever to protect her island and all the wildlife that call it home, faces off against resort developers and animal poachers. Soon she realizes she can’t depend on her animal cohorts alone and must make her first human friend – Edmund, who’s run away to the island from the mainland – to save her home.","genre_ids":[10751,12],"media_type":"movie","popularity":0.4688,"vote_count":642,"poster_path":"/9LPDKDZQyGlQQphTna5kRHe4nrE.jpg","release_date":"2013-03-15","vote_average":6.5,"backdrop_path":"/auLEgC09Pvwkzul8lwEkcWnlSC2.jpg","original_title":"Return to Nim's Island","original_language":"en"},{"id":150273,"adult":false,"title":"The Return","video":false,"overview":"Two young children and an adult in a small town have an encounter with an alien spaceship. 25 years later the children are reunited as adults in the same town which is now beset by strange cattle mutilations. Matters become worse when the cattle mutilations are joined by human murders and mutilations.","genre_ids":[9648,53,878],"media_type":"movie","popularity":0.532,"vote_count":129,"poster_path":"/oyRNMNZMFdGKe0S3cuVELIutWPp.jpg","release_date":"1980-03-31","vote_average":5.9,"backdrop_path":"/dyolD5LM5OkQsf59VFNj1P8XuLQ.jpg","original_title":"The Return","original_language":"en"},{"id":8965,"adult":false,"title":"Atlantis: Milo's Return","video":false,"overview":"Milo and Kida reunite with their friends to investigate strange occurances around the world that seem to have links to the secrets of Atlantis.","genre_ids":[14,16,878,10751,28],"media_type":"movie","popularity":1.9955,"vote_count":3887,"poster_path":"/hyAbWGld5WLdrmUB9OHyewcJQGL.jpg","release_date":"2003-02-25","vote_average":6.3,"backdrop_path":"/GDTwA5FBvVUOjCGKoNDMflbs3Z.jpg","original_title":"Atlantis: Milo's Return","original_language":"en"},{"id":615774,"adult":false,"title":"Scooby-Doo! Return to Zombie Island","video":false,"overview":"Scooby-Doo and his pals win an all-expense paid vacation and embark on a trip of a lifetime to a tropical paradise. Their destination however, turns out to be Zombie Island. As soon as they arrive, they realize the place looks strangely familiar and is reminiscent of a trip they took years ago, in which they became wrapped up in a mystery involving zombies. The gang soon learns that their trip to paradise comes with a price when the zombies re-emerge and attack their hotel. Will Scooby-Doo and the Mystery Inc. gang finally solve the mystery behind Zombie Island?","genre_ids":[14,16,10751,12,35,9648,27],"media_type":"movie","popularity":1.2436,"vote_count":951,"poster_path":"/vd0oIoWhEm8o7EpS0kV7RaV0Flf.jpg","release_date":"2019-09-03","vote_average":6.984,"backdrop_path":"/cVqwzMSNPS4vgUDlXlSYoWOmGsI.jpg","original_title":"Scooby-Doo! Return to Zombie Island","original_language":"en"},{"id":352492,"adult":false,"title":"XOXO","video":false,"overview":"XOXO follows six strangers whose lives collide in one frenetic, dream-chasing, hopelessly romantic night.","genre_ids":[10402,18],"media_type":"movie","popularity":0.654,"vote_count":597,"poster_path":"/5hbTuc8Lbw7N8RwMOc9bjAcSjuw.jpg","release_date":"2016-08-26","vote_average":5.955,"backdrop_path":"/8veRW9Hb3cQZgAy28gqvJVo34O1.jpg","original_title":"XOXO","original_language":"en"},{"id":283564,"adult":false,"title":"SlugTerra: Return of the Elementals","video":false,"overview":"A new member has joined Eli and the Shane Gang! Junjie, once the protector of the Eastern Caverns, is a master of the slugslinging art of Slug Fu! But even with the power of five slingers, the Shane Gang find themselves in over their heads as they race across The 99 Caverns in search of the Legendary Elemental Slugs. The five Elementals are ancient slugs of great power, and the forbearers of all slugs found in SlugTerra today. In the wrong hands, they could bring Slugterra to the brink of destruction. So when an evil alliance starts hunting down the Elementals, Eli and his friends — old and new — take off in pursuit of the greatest threat their world has ever faced!","genre_ids":[10751,16,12],"media_type":"movie","popularity":0.851,"vote_count":348,"poster_path":"/ApN2lteDsoIU5dDHJXeqVD13vpd.jpg","release_date":"2014-08-02","vote_average":6.974,"backdrop_path":"/6jnSkRFKkcyKyQJGO5eVfFeXFGF.jpg","original_title":"SlugTerra: Return of the Elementals","original_language":"en"},{"id":365756,"adult":false,"title":"A Dogwalker's Christmas Tale","video":false,"overview":"Spoiled 21-year-old Luce Lockhart faces a tough decision when a handsome new friend asks her to help protect a dog park from her wealthy employer.","genre_ids":[35,10770,10749],"media_type":"movie","popularity":0.324,"vote_count":55,"poster_path":"/cInkAcLdI4dWYqL9IQ7tmMmg9yC.jpg","release_date":"2015-11-15","vote_average":5.864,"backdrop_path":"/frJzRmqrtaakV7Hq0tIDglzQ2gL.jpg","original_title":"A Dogwalker's Christmas Tale","original_language":"en"},{"id":207680,"adult":false,"title":"Return to... Return to Nuke 'Em High aka Vol. 2","video":false,"overview":"Following the events of Volume 1,  the mutated glee club continue their violent rampage in Tromaville. Chrissy and Lauren, two innocent lesbian lovers, must fight not only the Cretins, mutants, and monsters but also the evil Tromorganic Foodstuffs Conglomerate. Can they, and Kevin the Wonder Duck, save Tromaville High School and the world?","genre_ids":[35,27,878],"media_type":"movie","popularity":0.4774,"vote_count":178,"poster_path":"/2YC1JNgGGHrCXDT83UCpdcWLFmV.jpg","release_date":"2017-01-15","vote_average":6.458,"backdrop_path":"/u4vzkyQFGuTJ1l2SS9jZmYZG4fr.jpg","original_title":"Return to... Return to Nuke 'Em High aka Vol. 2","original_langua