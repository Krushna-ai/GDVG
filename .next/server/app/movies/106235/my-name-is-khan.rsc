9:{"metadata":[["$","title","0",{"children":"My Name Is Khan | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Rizwan Khan, a Muslim from the Borivali section of Mumbai, has Asperger's syndrome. He marries a Hindu single mother, Mandira, in San Francisco. After 9/11, Rizwan is detained by authorities at LAX who treat him as a terrorist because of his condition and his race."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/106235/my-name-is-khan"}],["$","meta","5",{"property":"og:title","content":"My Name Is Khan"}],["$","meta","6",{"property":"og:description","content":"Rizwan Khan, a Muslim from the Borivali section of Mumbai, has Asperger's syndrome. He marries a Hindu single mother, Mandira, in San Francisco. After 9/11, Rizwan is detained by authorities at LAX who treat him as a terrorist because of his condition and his race."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/106235/my-name-is-khan"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/5Y36lCiNyyV71mjq6LavgiggbhT.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"My Name Is Khan"}],["$","meta","12",{"name":"twitter:description","content":"Rizwan Khan, a Muslim from the Borivali section of Mumbai, has Asperger's syndrome. He marries a Hindu single mother, Mandira, in San Francisco. After 9/11, Rizwan is detained by authorities at LAX who treat him as a terrorist because of his condition and his race."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/5Y36lCiNyyV71mjq6LavgiggbhT.jpg"}],["$","link","14",{"rel":"icon","hr