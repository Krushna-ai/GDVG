5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Momo\",\"description\":\"Momo is a young orphan girl who lives in the ruins of an old Roman amphitheater and becomes friends with everybody in the neighborhood. But when a powerful international corporation starts stealing everybody’s time, nobody has any time left for her, let alone their friends or families. Momo, together with Master Hora, the custodian of time, are the only ones who can go up against the time thieves before all is lost forever.\",\"image\":\"https://image.tmdb.org/t/p/w500/t3igABxx2wkslwdlTBDYHzyNfL6.jpg\",\"datePublished\":\"2025-10-02\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"DE\",\"inLanguage\":\"de\",\"genre\":[\"Family\",\"Fantasy\",\"Adventure\",\"Drama\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.292,\"bestRating\":10,\"ratingCount\":24}}"}}],["$","$L10",null,{"initialDrama":{"id":"636ed84d-0c91-46cf-9fc9-f93b0b57df73","tmdb_id":1175842,"imdb_id":"tt26325131","content_type":"movie","title":"Momo","original_title":"Momo","overview":"Momo is a young orphan girl who lives in the ruins of an old Roman amphitheater and becomes friends with everybody in the neighborhood. But when a powerful international corporation starts stealing everybody’s time, nobody has any time left for her, let alone their friends or families. Momo, together with Master Hora, the custodian of time, are the only ones who can go up against the time thieves before all is lost forever.","poster_path":"/t3igABxx2wkslwdlTBDYHzyNfL6.jpg","backdrop_path":"/yxcbiZEaVzQqWSRWVIa4OzSK0Ug.jpg","release_date":"2025-10-02","first_air_date":null,"status":"published","original_language":"de","origin_country":["DE"],"genres":[{"id":10751,"name":"Family"},{"id":14,"name":"Fantasy"},{"id":12,"name":"Adventure"},{"id":18,"name":"Drama"}],"popularity":6.3359,"vote_average":7.292,"vote_count":24,"runtim