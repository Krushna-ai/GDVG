":3840,"height":2160,"file_path":"/u6vgNGgAy8VjEGZHYbr4bdl5AOH.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/xRq2S58GArXEYn2CjofqTz4CyNO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/9YDCDgjbUtXuqLiNFx4lIRGuCHy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/5UH9ylNzGHWwBLS0mfyGYvZnCsc.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1772,"height":997,"file_path":"/aWAWLdmCkqoPxx6AgTnozvm0QP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3840,"height":2160,"file_path":"/7jnt2tStbzdmfwZW21UQAFKgfBQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:15:04.819+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":91,"tagline":"","homepage":"","overview":"Im Mittelpunkt  steht ein junges Waisenmädchen, das in den Ruinen eines alten römischen Amphitheaters lebt und sich mit jedem in der Nachbarschaft anfreundet. Doch als ein mächtiger internationaler Konzern beginnt, die Zeit aller zu stehlen, hat niemand mehr Zeit für sie, geschweige denn für ihre Freunde oder Familien – und Momo ist zusammen mit Meister Hora, dem Hüter der Zeit, die Einzige, die es mit den Zeitdieben aufnehmen kann, bevor alles für immer verloren ist."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":93,"tagline":"","homepage":"","overview":"Momo is a young orphan girl who lives in the ruins of an old Roman amphitheater and becomes friends with everybody in the neighborhood. But when a powerful international corporation starts stealing everybody’s time, nobody has any time left for her, let alone their friends or families. Momo, together with Master Hora, the custodian of time, are the only ones who can go up against the time thieves before all is lost forever."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Momo is een jong weesmeisje dat in de ruïnes van een oud Romeins amfitheater woont en vrienden wordt met iedereen in de buurt. Maar wanneer een machtige internationale onderneming ieders tijd begint te stelen, heeft niemand meer tijd voor haar, laat staan ​​voor hun vrienden of familie. Momo is samen met meester Hora, de bewaarder van de tijd, de enigen die het tegen de tijddieven kunnen opnemen voordat alles voor altijd verloren is.  naar de gelijknamige roman van Michael Ende"},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Момо","runtime":91,"tagline":"","homepage":"","overview":"У сироты Момо дар вдохновлять людей и пробуждать в них все самое лучшее. Однажды девочка замечает, что в ее городе появились странные «серые господа», которые учат эффективно тратить свое время. Вот только люди от этого становятся все более несчастными, ведь в погоне за продуктивностью они растрачивают свои жизни. Момо объединяется с Хранителем времени и черепашкой-предсказательницей, чтобы понять, как избавить город от этих похитителей времени и вернуть его жителям потерянную радость."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Momo to młoda, osierocona dziewczynka, która mieszka w ruinach starego rzymskiego amfiteatru i zaprzyjaźnia się ze wszystkimi w okolicy. Jednak gdy potężna międzynarodowa korporacja zaczyna kraść ludziom czas, nikt nie ma go już ani dla niej, ani nawet dla swoich przyjaciół czy rodzin. Momo, razem z Mistrzem Horą – strażnikiem czasu – są jedynymi, którzy mogą stanąć do walki z złodziejami czasu, zanim wszystko zostanie stracone na zawsze."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Momo ir laiko paslaptis","runtime":91,"tagline":"","homepage":"","overview":"Seno romėnų amfiteatro griuvėsiuose gyvena mergaitė, tačiau niekas iš aplinkinių nežino, iš kur ji atsirado. Žinomas tik jos vardas – Momo. Kai paslaptingi pilkieji ponai ima iš žmonių vogti laiką, Momo pajunta, kaip pasikeičia gyvenimas: niekas nebendrauja tarpusavyje, žmonės atsisako draugų ir šeimos, nes... jiems tiesiog nebeturi laiko.\r Vieną dieną Momo, vedama paslaptingos vėžlės Kasiopėjos, patenka pas Sekundijų Minutijų Horą – laiko saugotoją. Paaiškėja, kad jo padedama, stipri ir ryžtinga Momo gali nugalėti paslaptinguosius laiko vagis ir išlaisvinti žmones, sugrąžindama jiems iš jų pavogtą laiką, o tuo pačiu – ir gyvenimo džiaugsmą."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"","runtime":0,"tagline":"Zamanı çalanlara karşı, kalbin gücüyle savaş!","homepage":"","overview":"Michael Ende’nin klasik romanından uyarlanan Momo, izleyiciyi zamanın değerini sorgulatan büyüleyici bir yolculuğa çıkarıyor. Eski bir Roma amfitiyatrosunun harabelerinde yaşayan küçük yetim kız Momo, mahalledeki herkesin sevgisini kazanır. Ancak güçlü bir uluslararası şirket insanların zamanını çalmaya başladığında, dostluklar ve aile bağları kopar. İnsanların birbirine ayıracak vakti kalmaz. Momo, zamanın koruyucusu Master Hora ile birlikte bu “zaman hırsızlarına” karşı mücadeleye girişir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":91,"tagline":"","homepage":"","overview":"Momo ir maza bārene, kas dzīvo veca romiešu amfiteātra drupās un sadraudzējas ar visiem savā apkaimē. Bet, kad ietekmīga, starptautiska korporācija sāk zagt visiem laiku, nevienam vairs nav laika viņai, nemaz nerunājot par viņu draugiem un ģimenēm. Momo kopā ar meistaru Horu, laika sargātāju, ir vienīgie, kas spēj stāties pretī laika zagļiem, pirms viss zudis uz visiem laikiem."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Dívka Momo a zloději času","runtime":0,"tagline":"","homepage":"","overview":"Momo je mladá velice přátelská osiřelá dívka, která žije v troskách starého římského amfiteátru. Jednoho dne zjistí, že mocná mezinárodní korporace začne pomocí bezduchých šedých mužů krást čas. Aby ochránila svoje přátele, nezbývá Momo nic jiného, než se vydat na boj s nezvaným nepřítelem."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Момо","runtime":0,"tagline":"","homepage":"","overview":"Момо е младо сираче, което живее сред руините на стар римски амфитеатър и е приятелка с всички в квартала. Но когато могъща международна корпорация започва да краде времето на хората, никой вече няма време за нея, камо ли за приятелите или семейството си. Момо, заедно с майстор Хора – пазителя на времето, са единствените, които могат да се изправят срещу крадците на време, преди всичко да бъде изгубено завинаги."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Momo je mlada sirota, ki živi v ruševinah starega rimskega amfiteatra in se spoprijatelji z vsemi v soseski. A ko močna mednarodna korporacija začne krasti čas vsem, nihče nima več časa zanjo, kaj šele za prijatelje ali družine. Momo skupaj z mojstrom Horo, varuhom časa, sta edina, ki se lahko spopadeta s tatovi časa, preden je vse za vedno izgubljeno."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Dievča Momo a zlodeji času","runtime":0,"tagline":"Od autora Nekonečného príbehu","homepage":"","overview":"Momo žije v ruinách starého amfiteátra. Nie je však obyčajné dievča – jej darom je pozorne načúvať každému vo svojom okolí a každému, koho stretne, sa vďaka nej začne zázračne dariť. Jedného dňa ju navštívi veľmi zvláštna korytnačka, s ktorou musí Momo spojiť sily, aby zabránila zlodejom času ukradnúť všetok čas na zemi. Ale bude ich plán fungovať? Začína sa napínavý závod."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"}],"reviews_tmdb":[],"recommendations":[{"id":747305,"adult":false,"title":"PorNO","video":false,"overview":"Max films his friends having lecherous fun at his own birthday party; unaware of how it will change his life. Just out of high school, by haphazard, he becomes a big porno producer. His father, a principled police major, chases porno makers, not suspecting that one of them lives in his own apartment. Hoodlums and girls from good families, corrupted policemen, petty dealers find themselves in a luring and scary world of porno.","genre_ids":[18],"media_type":"movie","popularity":1.3017,"vote_count":6,"poster_path":"/ca4IeFe4C7Hfco2TSUDKbUoSOFT.jpg","release_date":"2010-02-01","vote_average":4.5,"backdrop_path":"/hBwyI8ppriwL9teR27JZYyvEngN.jpg","original_title":"Бес Пор No","original_language":"uk"},{"id":289100,"adult":false,"title":"Girls Fight Club","video":false,"overview":"The best women's wrestling competition of all time...and if you think it's fake you're in for a big surprise See LEGENDARY Mixed Martial Arts fighters coach their teams to victory in the cage! aka Chuck Lidell's Girl's Fight Club","genre_ids":[],"media_type":"movie","popularity":0.0505,"vote_count":13,"poster_path":null,"release_date":"2009-06-18","vote_average":7.5,"backdrop_path":null,"original_title":"Girls Fight Club","original_language":"en"},{"id":477295,"adult":false,"title":"Men","video":false,"overview":"Men will be men.","genre_ids":[35],"media_type":"movie","popularity":1.9722,"vote_count":1,"poster_path":"/jMlSkJuJx8zHhFRsIDh0VIikw3j.jpg","release_date":"2017-06-23","vote_average":6,"backdrop_path":"/nuuim1TXDvv20kQS7h0HaMSKAay.jpg","original_title":"Men","original_language":"en"},{"id":77982,"adult":false,"title":"Wizards of Waverly Place: Wizard School","video":true,"overview":"When Alex is caught using magic to clean her room she is forced to go to wizard school with Justin. Max and Jerry camp out on the terrace to prove their manhood.","genre_ids":[10751,35,14,10770],"media_type":"movie","popularity":0.646,"vote_count":245,"poster_path":"/bdc2L2xnH55chbam8bOvxuSDYst.jpg","release_date":"2008-04-06","vote_average":8.955,"backdrop_path":"/j3jPLQ7HVSFoO32MPUPI2Xe04Vx.jpg","original_title":"Wizards of Waverly Place: Wizard School","original_language":"en"},{"id":532155,"adult":false,"title":"Musangwe: Fight Club","video":false,"overview":"The first rule is that there are no rules. For the bare-knuckle combatants competing in Musangwe fights, anything goes - you can even put a curse on him. The sport, which dates back centuries, has become a South African institution. Any male from the age of nine to ninety can compete. We follow a group of fighters as they slug it out in the ring. Who will be this year's champion?","genre_ids":[99],"media_type":"movie","popularity":0.1533,"vote_count":16,"poster_path":"/tZDxttt0LfgAKwvLIWyOO3fr01c.jpg","release_date":"2007-10-01","vote_average":7.7,"backdrop_path":null,"original_title":"Musangwe: Fight Club","original_language":"en"},{"id":64610,"adult":false,"title":"Free Hands","video":false,"overview":"Barbara is a filmmaker who has been working in the prison environment for a few years now. She is preparing a film written and directed by long-term inmates in a prison in the projects around Paris. Twice a week, Barbara goes to the prison where she shoots interviews with the inmates which will serve as a basis for the writing of their screenplay.","genre_ids":[18],"media_type":"movie","popularity":0.4544,"vote_count":5,"poster_path":"/ii1YDxbnylQvNPbk4lqGTpFd7lN.jpg","release_date":"2010-06-16","vote_average":5.5,"backdrop_path":null,"original_title":"Les Mains Libres","original_language":"fr"},{"id":969532,"adult":false,"title":"GCW: Fight Club Houston","video":true,"overview":"On July 9th GCW presents Fight Club Houston straight from Premier Arena in Houston, Texas. The lineup is almost completed, check it below:  AJ Gray vs Bryan Keith  Nick Gage vs Sadika  Joey Janela vs Dante  Ninja Mack vs Jack Cartwheel  Effy vs Gino  Jimmy Lloyd vs Carter  Lucha Scramble  .... more to be added soon!","genre_ids":[],"media_type":"movie","popularity":0.0719,"vote_count":12,"poster_path":"/353CATo61TQERENVF6AqIqhUD51.jpg","release_date":"2021-07-09","vote_average":7.5,"backdrop_path":null,"original_title":"GCW: Fight Club Houston","original_language":"en"},{"id":603663,"adult":false,"title":"Cherrie - ut ur mörkret","video":false,"overview":"","genre_ids":[99,10770],"media_type":"movie","popularity":0.1782,"vote_count":34,"poster_path":null,"release_date":"2018-05-30","vote_average":6,"backdrop_path":"/2oIcobdYUubpYD5pksFrbeL7BTz.jpg","original_title":"Cherrie - ut ur mörkret","original_language":"sv"},{"id":937020,"adult":false,"title":"Jailer","video":false,"overview":"Muthuvel Pandian, a retired, stern yet compassionate jailer lives a peaceful life with his family, but trouble knocks his door when his cop son’s tryst with an antique mafia gang goes awry and forces Muthu to step back into a dark world he had voluntarily took a break from.","genre_ids":[28,80,53,35,12],"media_type":"movie","popularity":0.9757,"vote_count":105,"poster_path":"/pTmMxAHqX4vsIDE6HPPxOR0Q6TN.jpg","release_date":"2023-08-10","vote_average":6.624,"backdrop_path":"/ownDZBS9ecoPbWjW5V5L8jknGF.jpg","original_title":"ஜெயிலர்","original_language":"ta"},{"id":1245774,"adult":false,"title":"Bird Thongchai Concert #1/1988 Kaolao ThongChai (Mai-Ngok)","video":false,"overview":"Relive the magic of Thongchai \"Bird\" McIntyre's captivating performance at Bangkok Youth Center in 1988","genre_ids":[10402],"media_type":"movie","popularity":0.0785,"vote_count":16,"poster_path":"/lF70yd1kLsTw3tXINjvcyds7S9A.jpg","release_date":"1988-04-22","vote_average":6.2,"backdrop_path":null,"original_title":"เบิร์ด ธงไชย คอนเสิร์ต #1/2531 เกาเหลาธงไชย (ไม่งอก)","original_language":"th"},{"id":772689,"adult":false,"title":"Re-Cycling","video":false,"overview":"This direct-to-draw animated film on 35 mm film features the imagery of 10 European directors in a collective project. Each produced 1 minute of animation on film, drawing directly onto it in his or her own style.","genre_ids":[16],"media_type":"movie","popularity":0.3855,"vote_count":48,"poster_path":"/35QidLwL1EPLsOvItBKoc3tSzqM.jpg","release_date":"2014-12-08","vote_average":7.6,"backdrop_path":"/kViPszuWdfeNSSvDZOHch1nU0NO.jpg","original_title":"Re-Cycling","original_language":"en"},{"id":389556,"adult":false,"title":"Gunpowder","video":false,"overview":"At the end of September 1941, Soviet artillery troops in besieged Leningrad realize that pretty soon they will fire their last shot, and after that the defense of the city will be doomed. The film is based on a true event: a small group of fearless soldiers transported a large supply of gunpowder through enemy lines to Leningrad.","genre_ids":[18,10752],"media_type":"movie","popularity":0.4816,"vote_count":11,"poster_path":"/5KtOwT8ovaiJYksiDM14AlW0cul.jpg","release_date":"1985-03-25","vote_average":5.9,"backdrop_path":"/jiqBxxcuHiBSwDhYrTGPCE6xrvA.jpg","original_title":"Порох","original_language":"ru"},{"id":604461,"adult":false,"title":"Cut: Exposing FGM Worldwide","video":false,"overview":"Taking more than six years to complete, The Cut is a feature-length documentary that conclusively proves that female genital mutilation or cutting (FGM) can be found as a native practice on all inhabitable continents. From war zones in the Middle-East to bucolic Middle America, the film visits 14 countries and features key interviews with FGM survivors, activists, cutters, doctors and researchers to uncover an often secret practice shrouded in centuries of traditions, mysticisms and irrationalities.","genre_ids":[99],"media_type":"movie","popularity":0.0899,"vote_count":25,"poster_path":"/h6z0AgbLYe6Xl4DWcV7As4PZbXt.jpg","release_date":"2017-12-31","vote_average":5.9,"backdrop_path":"/ebRHuCyprRZWIoacf7txU21TE1i.jpg","original_title":"Cut: Exposing FGM Worldwide","original_language":"en"},{"id":14818,"adult":false,"title":"Dynamite Warrior","video":false,"overview":"The story is set in 1890s Siam. Siang is a young Muay Thai warrior and rocketry expert who steals back water buffalo taken from poor Isan farmers by unscrupulous cattle raiders. He is searching for a man with a tattoo who killed his parents.","genre_ids":[28],"media_type":"movie","popularity":2.2931,"vote_count":51,"poster_path":"/7yRZYBeYJgM49MGWEX1LQNgzqza.jpg","release_date":"2006-12-21","vote_average":6.3,"backdrop_path":"/4aqCW6eXcRXovWJc8yNNbB3rXYr.jpg","original_title":"ฅนไฟบิน","original_language":"th"},{"id":1077600,"adult":false,"title":"Baby Assassins: 2 Babies","video":false,"overview":"Chisato and Mahiro must pay four years of overdue fees or lose their membership in their assassin guild. They take part-time jobs, but find themselves in the middle of an armed robbery and being hunted by other assassins.","genre_ids":[28,35,80,18],"media_type":"movie","popularity":1.6875,"vote_count":50,"poster_path":"/hP4xasBknL8LCUjuDUoSr6V6Kpd.jpg","release_date":"2023-03-24","vote_average":6.62,"backdrop_path":"/33ayowCajE7A3bdIcGUCEYDpe0.jpg","original_title":"ベイビーわるきゅーれ2ベイビー","original_language":"ja"},{"id":37932,"adult":false,"title":"Flicka 2","video":false,"overview":"Carrie is a big-city teenager whose life is turned upside down when she moves to a horse ranch in Wyoming to live with her father. But everything changes when Carrie meets Flicka, a wild, jet-black mustang who's just as free-spirited and strong-willed as Carrie. The two form a special bond and Carrie opens her heart to her father and a handsome, local boy, but when a jealous rival puts Flicka's life in jeopardy, Carrie must do whatever it takes to save her best friend.","genre_ids":[10751,18],"media_type":"movie","popularity":0.5055,"vote_count":131,"poster_path":"/9fon68TdGTlcgVmHe0arPLnEvc6.jpg","release_date":"2010-05-04","vote_average":6.737,"backdrop_path":"/qJ1TKRNpajzufU7nXNcaSAnR6aC.jpg","original_title":"Flicka 2","original_language":"en"},{"id":926946,"adult":false,"title":"School of Magical Animals 2","video":false,"overview":"The students of the School of Magical Animals want to perform a musical for the school's anniversary. Will rehearsals end in chaos or will the class pull together? And what's up with the strange holes on the school grounds?","genre_ids":[10751,12,14],"media_type":"movie","popularity":1.0282,"vote_count":44,"poster_path":"/wRXzkXnniE4NijTHVmqohCZrUQB.jpg","release_date":"2022-09-29","vote_average":6.5,"backdrop_path":"/qGPLVKo4Iz0qBNJRFXKTpPGeXGt.jpg","original_title":"Die Schule der magischen Tiere 2","original_language":"de"},{"id":920258,"adult":false,"title":"The Immortal Wars: Rebirth","video":false,"overview":"Rebirth takes place during the early brutal stages of Dominion Industries. In this story watch Olive and other deviants undergo a series of deadly experiments lead by Laurie Harvey and her team.","genre_ids":[878],"media_type":"movie","popularity":0.8328,"vote_count":49,"poster_path":"/ofTnrgEwtPILNfjwk0FAx3bfwZ6.jpg","release_date":"2021-11-02","vote_average":6.6,"backdrop_path":"/wurJckmxIzn2GrJcPDuNFFy1gWx.jpg","original_title":"The Immortal Wars: Rebirth","original_language":"en"},{"id":300693,"adult":false,"title":"Truth","video":false,"overview":"As a renowned producer and close associate of Dan Rather, Mary Mapes believes she’s broken the biggest story of the 2004 election: revelations of a sitting U.S. President’s military service. But when allegations come pouring in, sources change their stories, document authenticity is questioned, and the casualties begin to mount.","genre_ids":[18],"media_type":"movie","popularity":1.2414,"vote_count":516,"poster_path":"/qmpMRABYbQjgtxwJ6xMPc8KskzA.jpg","release_date":"2015-10-16","vote_average":6.534,"backdrop_path":"/3jEuzzKf95v5e4GdTouBpyl6Dc9.jpg","original_title":"Truth","original_language":"en"},{"id":1023915,"adult":false,"title":"2073","video":false,"overview":"Inspired by Chris Marker's iconic 1962 featurette La Jetée; the year is 2073—a not-so-distant dystopian future—and the setting is New San Francisco, the scorched-earth tech-dominant police state where democracy and personal freedom have been well and truly obliterated.","genre_ids":[53,878],"media_type":"movie","popularity":1.5005,"vote_count":93,"poster_path":"/l67ir3kU53FYd6Vjwhqrkih1H1P.jpg","release_date":"2024-12-27","vote_average":6.677,"backdrop_path":"/721p2lNSGp2iSlUUukZwCzEKrnn.jpg","original_title":"2073","original_language":"en"}],"similar_content":[{"id":62,"adult":false,"title":"2001: A Space Odyssey","video":false,"overview":"Humanity finds a mysterious object buried beneath the lunar surface and sets off to find its origins with the help of HAL 9000, the world's most advanced super computer.","genre_ids":[878,9648,12],"popularity":13.0323,"vote_count":12364,"poster_path":"/ve72VxNqjGM69Uky4WTo2bK6rfq.jpg","release_date":"1968-04-02","vote_average":8.056,"backdrop_path":"/w5IDXtifKntw0ajv2co7jFlTQDM.jpg","original_title":"2001: A Space Odyssey","original_language":"en"},{"id":66,"adult":false,"title":"Absolute Power","video":false,"overview":"A master thief coincidentally is robbing a house where a murder—in which the President of the United States is involved—occurs in front of his eyes. He is forced to run, while holding evidence that could convict the President.","genre_ids":[80,18,28],"popularity":2.2658,"vote_count":1203,"poster_path":"/izvyt3cxlilhbYwybTOteDWqf99.jpg","release_date":"1997-02-14","vote_average":6.658,"backdrop_path":"/cLftTzGw40BlLw8IggKSWDjKOQo.jpg","original_title":"Absolute Power","original_language":"en"},{"id":854356,"