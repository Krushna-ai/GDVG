media_type":"movie","popularity":1.9351,"vote_count":23,"poster_path":"/4r5Kne06Q20OuzEzV1oGlVv8mEv.jpg","release_date":"2002-08-15","vote_average":6.261,"backdrop_path":"/cfvIbVDiI3tkKNaBwcJJeWWo4wt.jpg","original_title":"பாபா","original_language":"ta"},{"id":369823,"adult":false,"title":"Hello Naan Pei Pesuren","video":false,"overview":"A thief steals the mobile phone of an accident victim not realising that her ghost now resides in the device.","genre_ids":[18,35,27,10749],"media_type":"movie","popularity":0.1854,"vote_count":11,"poster_path":"/sMD1QZEKDwDSGyxZSGIeR6eBZhV.jpg","release_date":"2016-04-01","vote_average":4.545,"backdrop_path":null,"original_title":"ஹலோ நான் பேய் பேசறேன்","original_language":"ta"},{"id":773,"adult":false,"title":"Little Miss Sunshine","video":false,"overview":"A family loaded with quirky, colorful characters piles into an old van and road trips to California for little Olive to compete in a beauty pageant.","genre_ids":[35,18],"media_type":"movie","popularity":4.593,"vote_count":7674,"poster_path":"/niNdhTpPHSgw22tK0PLjQMV640v.jpg","release_date":"2006-07-26","vote_average":7.69,"backdrop_path":"/fs6p6TfZgblhmTk0hCeEINdeCAl.jpg","original_title":"Little Miss Sunshine","original_language":"en"},{"id":530915,"adult":false,"title":"1917","video":false,"overview":"At the height of the First World War, two young British soldiers must cross enemy territory and deliver a message that will stop a deadly attack on hundreds of soldiers.","genre_ids":[10752,36,18,28,12],"media_type":"movie","popularity":9.447,"vote_count":13298,"poster_path":"/iZf0KyrE25z1sage4SYFLCCrMi9.jpg","release_date":"2019-12-25","vote_average":7.985,"backdrop_path":"/2lBOQK06tltt8SQaswgb8d657Mv.jpg","original_title":"1917","original_language":"en"},{"id":238,"adult":false,"title":"The Godfather","video":false,"overview":"Spanning the years 1945 to 1955, a chronicle of the fictional Italian-American Corleone crime family. When organized crime family patriarch, Vito Corleone barely survives an attempt on his life, his youngest son, Michael steps in to take care of the would-be killers, launching a campaign of bloody revenge.","genre_ids":[18,80],"media_type":"movie","popularity":41.7683,"vote_count":22487,"poster_path":"/3bhkrj58Vtu7enYsRolD1fZdja1.jpg","release_date":"1972-03-14","vote_average":8.687,"backdrop_path":"/tSPT36ZKlP2WVHJLM4cQPLSzv3b.jpg","original_title":"The Godfather","original_language":"en"},{"id":496243,"adult":false,"title":"Parasite","video":false,"overview":"All unemployed, Ki-taek's family takes peculiar interest in the wealthy and glamorous Parks for their livelihood until they get entangled in an unexpected incident.","genre_ids":[35,53,18],"media_type":"movie","popularity":33.5167,"vote_count":20171,"poster_path":"/7IiTTgloJzvGI1TAYymCfbfl3vT.jpg","release_date":"2019-05-30","vote_average":8.493,"backdrop_path":"/hiKmpZMGZsrkA3cdce8a7Dpos1j.jpg","original_title":"기생충","original_language":"ko"},{"id":475557,"adult":false,"title":"Joker","video":false,"overview":"During the 1980s, a failed stand-up comedian is driven insane and turns to a life of crime and chaos in Gotham City while becoming an infamous psychopathic crime figure.","genre_ids":[80,53,18],"media_type":"movie","popularity":20.2185,"vote_count":27326,"poster_path":"/udDclJoHjfjb8Ekgsd4FDteOkCU.jpg","release_date":"2019-10-01","vote_average":8.128,"backdrop_path":"/hO7KbdvGOtDdeg0W4Y5nKEHeDDh.jpg","original_title":"Joker","original_language":"en"},{"id":278,"adult":false,"title":"The Shawshank Redemption","video":false,"overview":"Imprisoned in the 1940s for the double murder of his wife and her lover, upstanding banker Andy Dufresne begins a new life at the Shawshank prison, where he puts his accounting skills to work for an amoral warden. During his long stretch in prison, Dufresne comes to be admired by the other inmates -- including an older prisoner named Red -- for his integrity and unquenchable sense of hope.","genre_ids":[18,80],"media_type":"movie","popularity":38.9881,"vote_count":29778,"poster_path":"/9cqNxx0GxF0bflZmeSMuL5tnGzr.jpg","release_date":"1994-09-23","vote_average":8.715,"backdrop_path":"/zfbjgQE1uSd9wiPTX4VzsLi0rGG.jpg","original_title":"The Shawshank Redemption","original_language":"en"},{"id":490132,"adult":false,"title":"Green Book","video":false,"overview":"Tony Lip, a bouncer in 1962, is hired to drive pianist Don Shirley on a tour through the Deep South in the days when African Americans, forced to find alternate accommodations and services due to segregation laws below the Mason-Dixon Line, relied on a guide called The Negro Motorist Green Book.","genre_ids":[18,35,36],"media_type":"movie","popularity":11.1917,"vote_count":12602,"poster_path":"/7BsvSuDQuoqhWmU2fL7W2GOcZHU.jpg","release_date":"2018-11-16","vote_average":8.222,"backdrop_path":"/5En0fmDagt3Pk8d7P3uTwfeQceg.jpg","original_title":"Green Book","original_language":"en"},{"id":284052,"adult":false,"title":"Doctor Strange","video":false,"overview":"After his career is destroyed, a brilliant but arrogant surgeon gets a new lease on life when a sorcerer takes him under her wing and trains him to defend the world against evil.","genre_ids":[14,12,28],"media_type":"movie","popularity":11.9177,"vote_count":23174,"poster_path":"/xf8PbyQcR5ucXErmZNzdKR0s8ya.jpg","release_date":"2016-10-25","vote_average":7.417,"backdrop_path":"/3zvZ699gMW2RhWc0GisIukzq0Ls.jpg","original_title":"Doctor Strange","original_language":"en"},{"id":396461,"adult":false,"title":"Under the Silver Lake","video":false,"overview":"Young and disenchanted Sam meets a mysterious and beautiful woman who's swimming in his building's pool one night. When she suddenly vanishes the next morning, Sam embarks on a surreal quest across Los Angeles to decode the secret behind her disappearance, leading him into the murkiest depths of mystery, scandal and conspiracy.","genre_ids":[80,18,9648],"media_type":"movie","popularity":2.7304,"vote_count":1556,"poster_path":"/771Ey73LqsE9ORJhQCI25rgMXS2.jpg","release_date":"2018-08-08","vote_average":6.352,"backdrop_path":"/r2z8ceIsg9ON8DIHTf6cMqnK3CL.jpg","original_title":"Under the Silver Lake","original_language":"en"},{"id":293660,"adult":false,"title":"Deadpool","video":false,"overview":"The origin story of former Special Forces operative turned mercenary Wade Wilson, who, after being subjected to a rogue experiment that leaves him with accelerated healing powers, adopts the alter ego Deadpool. Armed with his new abilities and a dark, twisted sense of humor, Deadpool hunts down the man who nearly destroyed his life.","genre_ids":[28,12,35],"media_type":"movie","popularity":14.8702,"vote_count":32382,"poster_path":"/3E53WEZJqP6aM84D8CckXx4pIHw.jpg","release_date":"2016-02-09","vote_average":7.622,"backdrop_path":"/en971MEXui9diirXlogOrPKmsEn.jpg","original_title":"Deadpool","original_language":"en"},{"id":299536,"adult":false,"title":"Avengers: Infinity War","video":false,"overview":"As the Avengers and their allies have continued to protect the world from threats too large for any one hero to handle, a new danger has emerged from the cosmic shadows: Thanos. A despot of intergalactic infamy, his goal is to collect all six Infinity Stones, artifacts of unimaginable power, and use them to inflict his twisted will on all of reality. Everything the Avengers have fought for has led up to this moment - the fate of Earth and existence itself has never been more uncertain.","genre_ids":[12,28,878],"media_type":"movie","popularity":31.8302,"vote_count":31507,"poster_path":"/7WsyChQLEftFiDOVTGkv3hFpyyt.jpg","release_date":"2018-04-25","vote_average":8.234,"backdrop_path":"/mDfJG3LC3Dqb67AZ52x3Z0jU0uB.jpg","original_title":"Avengers: Infinity War","original_language":"en"},{"id":551332,"adult":false,"title":"The Two Popes","video":false,"overview":"Frustrated with the direction of the church, Cardinal Bergoglio requests permission to retire in 2012 from Pope Benedict. Instead, facing scandal and self-doubt, the introspective Pope Benedict summons his harshest critic and future successor to Rome to reveal a secret that would shake the foundations of the Catholic Church.","genre_ids":[18,36],"media_type":"movie","popularity":2.6515,"vote_count":3096,"poster_path":"/4d4mTSfDIFIbUbMLUfaKodvxYXA.jpg","release_date":"2019-11-27","vote_average":7.491,"backdrop_path":"/bOPessdyd0dChHy70FM8Om7CgDg.jpg","original_title":"The Two Popes","original_language":"en"},{"id":503919,"adult":false,"title":"The Lighthouse","video":false,"overview":"Two lighthouse keepers try to maintain their sanity while living on a remote and mysterious New England island in the 1890s.","genre_ids":[18,14,53],"media_type":"movie","popularity":5.8462,"vote_count":5408,"poster_path":"/f1tIYarTbkBdIT1aW0gzelDwknv.jpg","release_date":"2019-10-18","vote_average":7.484,"backdrop_path":"/sYLzRuEcwSz0L1Z92wQNrETHU9O.jpg","original_title":"The Lighthouse","original_language":"en"},{"id":565310,"adult":false,"title":"The Farewell","video":false,"overview":"A headstrong Chinese-American woman returns to China when her beloved grandmother is given a terminal diagnosis. Billi struggles with her family's decision to keep grandma in the dark about her own illness as they all stage an impromptu wedding to see grandma one last time.","genre_ids":[35,18],"media_type":"movie","popularity":2.5437,"vote_count":1515,"poster_path":"/7ht2IMGynDSVQGvAXhAb83DLET8.jpg","release_date":"2019-07-12","vote_average":7.418,"backdrop_path":"/5INPBiKVRsyp9kgHfsC0cTfvKFH.jpg","original_title":"The Farewell","original_language":"en"},{"id":361743,"adult":false,"title":"Top Gun: Maverick","video":false,"overview":"After more than thirty years of service as one of the Navy’s top aviators, and dodging the advancement in rank that would ground him, Pete “Maverick” Mitchell finds himself training a detachment of TOP GUN graduates for a specialized mission the likes of which no living pilot has ever seen.","genre_ids":[28,18],"media_type":"movie","popularity":21.4957,"vote_count":10602,"poster_path":"/62HCnUTziyWcpDaBO2i1DX17ljH.jpg","release_date":"2022-05-21","vote_average":8.156,"backdrop_path":"/AaV1YIdWKnjAIAOe8UUKBFm327v.jpg","original_title":"Top Gun: Maverick","original_language":"en"},{"id":643532,"adult":false,"title":"The Card Counter","video":false,"overview":"William Tell just wants to play cards. His spartan existence on the casino trail is shattered when he is approached by Cirk, a vulnerable and angry young man seeking help to execute his plan for revenge on a military colonel. Tell sees a chance at redemption through his relationship with Cirk. But keeping Cirk on the straight-and-narrow proves impossible, dragging Tell back into the darkness of his past.","genre_ids":[18,53,80],"media_type":"movie","popularity":1.3168,"vote_count":1059,"poster_path":"/y5DNLVg0gPiGSkuK4yFc4fjQ42Q.jpg","release_date":"2021-09-03","vote_average":6.122,"backdrop_path":"/mE0sGZ4CyzibmBG7FYan5CIKuag.jpg","original_title":"The Card Counter","original_language":"en"}],"similar_content":[],"external_ids":{"imdb_id":"tt0139861","twitter_id":null,"facebook_id":null,"wikidata_id":"Q3418065","instagram_id":null,"mydramalist_id":"212760","rotten_tomatoes_id":"m/arunachalam"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":108103,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"IN","release_dates":[{"note":"","type":3,"iso_639_1":"ta","descriptors":[],"release_date":"1997-04-10T00:00:00.000Z","certification":"U"}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":"Chennai","review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikidata_metadata":{},"mood_tags":null,"