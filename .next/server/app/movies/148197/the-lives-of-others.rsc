9:{"metadata":[["$","title","0",{"children":"The Lives of Others | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"In 1984 East Berlin, dedicated Stasi officer Gerd Wiesler begins spying on a famous playwright and his actress-lover Christa-Maria. Wiesler becomes unexpectedly sympathetic to the couple, and faces conflicting loyalties when his superior takes a liking to Christa-Maria."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148197/the-lives-of-others"}],["$","meta","5",{"property":"og:title","content":"The Lives of Others"}],["$","meta","6",{"property":"og:description","content":"In 1984 East Berlin, dedicated Stasi officer Gerd Wiesler begins spying on a famous playwright and his actress-lover Christa-Maria. Wiesler becomes unexpectedly sympathetic to the couple, and faces conflicting loyalties when his superior takes a liking to Christa-Maria."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148197/the-lives-of-others"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/cVUDMnskSc01rdbyH0tLATTJUdP.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"The Lives of Others"}],["$","meta","12",{"name":"twitter:description","content":"In 1984 East Berlin, dedicated Stasi officer Gerd Wiesler begins spying on a famous playwright and his actress-lover Christa-Maria. Wiesler becomes unexpectedly sympathetic to the couple, and faces conflicting loyalties when his superior takes a liking to Christa-Maria."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/cVUDMnskSc01rdbyH0tLATTJUdP.jpg"}]