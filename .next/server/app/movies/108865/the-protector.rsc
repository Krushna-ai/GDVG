_639_1":"es","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/6CHTuyaGmLzQHdHLawAxJdtOQax.jpg","iso_639_1":"th","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/sGOZQVnuVpa39DUnDXzi1FO3gmP.jpg","iso_639_1":"de","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/fcVFC02Q0mQ31Dq0LZVAm9yflWP.jpg","iso_639_1":"fr","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/r4hEsdJXX2XYeEq55QK2iEAt3iS.jpg","iso_639_1":"pt","vote_average":3.334},{"width":1400,"height":2100,"file_path":"/A4HRER2Xtr0FAEGGmcexdYlqqiG.jpg","iso_639_1":"hu","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/uKE9BxgtT5g2pE3ZKC7MnzsAbTZ.jpg","iso_639_1":"en","vote_average":2.278},{"width":1000,"height":1500,"file_path":"/mGN5lxyM2zIjWXglRUTrtEd2qDs.jpg","iso_639_1":"pt","vote_average":1.75},{"width":1000,"height":1500,"file_path":"/gWNHpDS4dTNHgYNhbxmwzmDsQrV.jpg","iso_639_1":"en","vote_average":1.75},{"width":500,"height":750,"file_path":"/o7HQCaXLkqKTRD9pAy4hWLZWQ1x.jpg","iso_639_1":"en","vote_average":1.75},{"width":1000,"height":1426,"file_path":"/gkMXWScxAifuJfaVo9zYw8iOLcf.jpg","iso_639_1":"fr","vote_average":1.75},{"width":1000,"height":1500,"file_path":"/pHVN2LyIhpQ6D4UvZPLNRklRFI5.jpg","iso_639_1":"fr","vote_average":1.75},{"width":2000,"height":3000,"file_path":"/opXeqf4547X5gGIH0NTW4ZcieDG.jpg","iso_639_1":"en","vote_average":1.75},{"width":854,"height":1280,"file_path":"/een3Wqnvlpw0MEx8wxm9itWwU4t.jpg","iso_639_1":"en","vote_average":1.75}],"backdrops":[{"width":3840,"height":2160,"file_path":"/b2NxliGN77rdu78HQv5peZBmkw4.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/jRQC2lvzQlZBONYrmdyFGqMWGrp.jpg","iso_639_1":null,"vote_average":2.542},{"width":1280,"height":720,"file_path":"/1wzVEuaWFfk4GcPIwaefTMq4ir9.jpg","iso_639_1":null,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/zKwoRzIyTRoettyqy7KAfiYG58j.jpg","iso_639_1":null,"vote_average":0.166},{"width":1985,"height":1115,"file_path":"/fd0Tjk1TUC0idBcVsaBrvMj1ItJ.jpg","iso_639_1":null,"vote_average":0.166}]},"enriched_at":"2026-02-21T13:06:19.221+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Protector","runtime":105,"tagline":"Vengeance Knows No Mercy.","homepage":"","overview":"A young fighter named Kham must go to Australia to retrieve his stolen elephant. With the help of a Thai-born Australian detective, Kham must take on all comers, including a gang led by an evil woman and her two deadly bodyguards."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Revenge of the Warrior","runtime":108,"tagline":"","homepage":"","overview":"Tierhändler haben Khams Familie zwei Elefanten gestohlen. Um den Ruhm seiner Familie aufrecht zu erhalten, reist er den rücksichtslosen Tierhändlern bis nach Australien hinterher, wo er mächtig und stark versucht auf die Fährte der Bande zu kommen, obwohl ihm das fremde Land große Schwierigkeiten bereitet."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"A Honra do Dragão","runtime":108,"tagline":"A vingança não conhece perdão.","homepage":"","overview":"O melhor filme de ação de todos os tempos... Kham, um jovem lutador, precisa ir para a Austrália recuperar seu elefante roubado. Com a ajuda de um detetive, Khan tem que lutar contra todos, incluindo uma gang liderada por uma mulher maligna e seus dois guarda-costas mortais."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"The Protector - La legge del Muay Thai","runtime":108,"tagline":"","homepage":"","overview":"Il padre di un giovane tailandese cresciuto sin da piccolo a stretto contatto con gli elefanti voleva partecipare ad un concorso per l'elefante dell'imperatore. Ma il concorso si rivela tutta una trappola dei bracconieri, per catturare l'elefante. Il giovane tailandese sarà costretto a partire per l'Australia per riprendere i suoi 2 fratellini (i due elefanti)."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Thai Dragon: El Protector","runtime":109,"tagline":"","homepage":"","overview":"Kham es un joven que vive apaciblemente en su aldea de la Tailandia rural. Pero esta tranquila vida dará un vuelco cuando una banda mafiosa con base en Australia roba sus elefantes trasladándolos a Sidney. Los dos elefantes son más que unos simples animales para Kham y su padre; son dos miembros más de la familia que han sido preparados durante años para regalárselos como signo de devoción al rey de Tailandia. La única posibilidad de recuperar a los animales será adentrarse en una tierra desconocida y luchar contra la banda mafiosa."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"L'Honneur du Dragon","runtime":94,"tagline":"La vengeance ne connaît pas la pitié.","homepage":"","overview":"Quand il était petit, Kham n'avait que son père et ses éléphants pour toute famille. À l'approche du Festival de l'eau de Songkran, le père de Kahm est convaincu que son éléphant bien-aimé est suffisamment princier pour déambuler dans les jardins du roi. Il rend visite au chef du village qui le persuade de faire examiner soigneusement son éléphant afin de vérifier s'il satisfait à l'ensemble des critères. Il s'agit en réalité d'une ruse destinée à subtiliser l'éléphant... Une bagarre s'engage alors au cours de laquelle Kham apprend que ses chers éléphants sont voués à être envoyés en... Australie. Voyageant hors de son pays pour la première fois de sa vie, Kham se rend à Sydney à la recherche des éléphants, désormais aux mains de Madame Rose, une impitoyable chef de gang particulièrement férue de créatures en voie de disparition..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Честь дракона","runtime":81,"tagline":"","homepage":"","overview":"В основе сюжета лежит история о том, как у одной крестьянской семьи из Таиланда перекупщики похитили слона и слоненка, которые были затем нелегально переправлены в Сидней. Молодой парень отправляется в Австралию, где вступает в схватку с преступным синдикатом."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Obrońca","runtime":108,"tagline":"Zemsta nie zna litości...","homepage":"","overview":"Gdy zabrali mu to co kochał najbardziej zostało mu tylko jedno - krwawa zemsta! Młody wojownik Kham (Tony Jaa) wyrusza do Sydney aby pomścić ojca oraz odnaleźć młode słoniątko - dziedzictwo jednego z tajskich plemion. Jedyną jego bronią jest Muay Thai - tajska, brutalna sztuka walki. Czy jednak ona wystarczy, gdy okaże się, że spisek sięga o wiele wyższych kręgów niż mogłoby się to wydawać na samym początku?  [opis dystrybutora dvd]"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Tom Yum Goong","runtime":108,"tagline":"","homepage":"","overview":"De jonge krijger Kham wordt door de dorpsoudste naar Australië gestuurd om een gestolen olifant terug te vinden. Samen met een Australische politieagent bindt Kham de strijd aan met iedereen die hem in de weg staat."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Koruyucu","runtime":0,"tagline":"","homepage":"","overview":"Bruce Lee ve Jet Li'den sonra kendi dövüş sanatı Muay Thai'yı geliştiren yeni efsane Tony Jaa ve aksiyon filmlerinin yönetmeni Prachya Pinkaew \"Koruyucu\"da yeniden buluştular.  Kham filler ile birlikte büyümüştür. Filler görkemli yaratıklardır. Barış içindedirler, ama savaşa da hazırlardır. Bir festival esnasında şeytani bir Asyalı çete yetişkin bir fille birlikte yavru bir fili kaçırır. Onları Avustralya'da Sidney'e götürür. Kham da fillerin peşinden Avustralya'ya, hiç bilmediği bu yabancı ülkeye gider ve her şeye rağmen filleri kurtarmaya çalışır. Elinde olan tek Muay Thai adlı dövüş stilindeki yeteneği ve ona yardım eden Tayland kökenli gözden düşmüş bir polistir. Ancak başarması gereken şey imkansızdır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Tom Yum Goong","runtime":0,"tagline":"","homepage":"","overview":"Mlady Thajcan Kam sa vydava na cestu do Australie, aby ziskal naspat svojho ukradnuteho slona. S pomocou prefikaneho policajneho detektiva coskoro zistuje, ze pachatelom je tajomna zena vlastniaca obchod pomenovany Tom Yum Goong. V nerovnom merani sil s mnohymi protivnikmi sa Kamovi hodia jeho vynikajuce bojove schopnosti."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Tom Yum Goong","runtime":106,"tagline":"","homepage":"","overview":"I generationer har Khams släkt varit beskyddare av ett heligt djur som enligt legenden besitter magiska krafter. När en mystisk organisation ledd av den iskalla Madame Rose stjäl dyrgripen tvingas Kham att starta ett enmanskrig mot maffian. Ställd mot hundratals hantlangare som attackerar från BMX, rollerblades och knivbepansrade motorcyklar, avancerar han med armbågar och knän allt närmare maffians kärna och en spektakulär slutfight."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"The Protector","runtime":0,"tagline":"Hævn kender ingen nåde","homepage":"","overview":"Den unge kampsportsentusiast Kham, der må begive sig ud på en farefuld færd, da hans to elskede elefanter bliver indfanget af et internationalt mafiasyndikat og smuglet til Sydney. Under sin mission finder han dog allierede i sin kamp i form af en thailandsk politibetjent og en ung thailandsk slavepige, men Khams mange modstandere er sværere at få bugt med end som så. Kham sætter efter skurkene med bagagen fuld af cirkelspark og knogleknusertricks."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"ต้มยำกุ้ง","runtime":0,"tagline":"ตำนานบทใหม่ การต่อสู้ครั้งยิ่งใหญ่ กำลังจะเริ่มต้น","homepage":"","overview":"เรื่องราวของ ขาม (จา พนม ยีรัมย์) เด็กหนุ่มบ้านป่าที่ชีวิตต้องพลิกผันข้ามน้ำข้ามทะเลไปยังออสเตรเลียเพื่อช่วยพ่อใหญ่ และ ขอน ช้างพลายสองพ่อลูกที่ถูกลักพาไปขายในต่างแดน ด้วยความช่วยเหลือจาก จ่ามาร์ค (หม่ำ จ๊กมก) และ ปลา (ตั๊ก บงกช คงมาลัย) ทำให้พบเบาะแสที่ร้าน \"ต้มยำกุ้ง\" ที่เบื้องหลังคือธุรกิจค้าสัตว์ผิดกฎหมาย เมื่อชีวิตสัตว์มากมายต้องถูกพรากอย่างทารุณ กระตุ้นแรงโกรธแค้นของเขาให้ลุกโชนดั่งเปลวเพลิง ถึงเวลาที่เลือดเข้าตาต้องเดินหน้าสู้ตาย ด้วยวิถีการต่อสู้ที่ถูกฝังอยู่ในสายเลือด \"มวยคชสาร\" การต่อสู้มือเปล่าแบบโบราณ ที่จะกลายเป็นตำนานตราบเท่าปัจจุบัน!!"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"A sárkány bosszúja","runtime":0,"tagline":"","homepage":"","overview":"Bangkokban a fiatal Kham apjával a dzsungel egyik kis falujában nevelkedett, elefántok között. A falu lakói az elefántokat a legjobb barátjuknak tekintik. Amikor a legöregebb elefántot és annak gyermekét elrabolják a faluból Kham bosszút esküszik és elindul, hogy megkeresse legféltettebb barátját. A nyomok Ausztráliába vezetnek, ahol Kham rájön, hogy az elefántot az ott uralkodó thai maffia klán vezérének, Madame Rose-nak rabolták el. Kham minden kung-fu tudását beveti, hogy kiszabadíthassa az állatot."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"冬荫功","runtime":0,"tagline":"","homepage":"","overview":"纯朴善良的青年阿锦（托尼·贾 Tony Jaa 饰）自幼生长在泰国一个原始丛林中，村民们日出而作，日落而息，过着平和安静的生活。他们以大象作为交通工具和助手，人与动物间建立了深厚的友情。阿锦的父亲曾是一名皇家护卫，他在闲暇之余教儿子学习泰拳，好有朝一日进宫保卫国王。\r 　　父亲精心饲养大象，在泼水节当天拜托村长将大象献给国王。谁知村长图谋不轨，将大象转手卖给黑帮，企图销往澳洲牟取暴利。他们不择手段，还打伤了阿锦的父亲。愤怒的年轻人只身闯入黑帮老巢，与这群不法之徒展开大战。当得知大象正被送往悉尼，阿锦毫不犹豫，只身前往，由此踏上一条充满死亡危险的道路…… ©豆瓣"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"המגן","runtime":0,"tagline":"","homepage":"","overview":"קאם ואביו גידלו שני פילים כחלק ממשפחתם, חיות שנועדו למתנה למלך תאילנד. התוכניות משתבשות כשהפילים נחטפים על ידי כנופיית גנגסטרים, ונמכרים באוסטרליה. לראשונה בחייו נאלץ קאם (טוני ג'ה) לצאת את המדינה כדי להחזיר את ששייך לו. מצטרפים אליו שוטר תאילנדי ונערה שנמכרה לזנות. אקשן מטורף ווירטואוזי לחלוטין של אומנויות לחימה, סרטו השני של פראצ'יה פינקאוו, לאחר \"אונג באק\" פורץ הדרך."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Tom yum goong - El drac de Tailàndia","runtime":0,"tagline":"","homepage":"","overview":"Kham és un jove que viu feliç a la Tailàndia rural. Però aquesta tranquil·la vida donarà un tomb radical quan una banda mafiosa amb base a Austràlia roba els seus elefants traslladant-los a Sidney. Els dos elefants són més que uns simples animals per en Kham i el seu pare; són dos membres més de la família que han estat preparats durant anys per regalar-los-hi com a signe de devoció al rei de Tailàndia. L'única possibilitat de recuperar als animals serà endinsar-se en una terra desconeguda i lluitar contra la banda mafiosa."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"The Protector","runtime":0,"tagline":"","homepage":"","overview":"Ο νεαρός Kham μεγαλώνει στην Μπανγκόγκ,παρέα με ελέφαντες. Όταν του κλέβουν τον αγαπημένο του ελέφαντα, ταξιδεύει ως την Αυστραλία για να τον βρει."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"O Protetor","runtime":110,"tagline":"A vingança não conhece perdão.","homepage":"","overview":"Kham, um jovem lutador, precisa ir para a Austrália recuperar seu elefante roubado. Com a ajuda de um detetive, Khan tem que lutar contra todos, incluindo uma gang liderada por uma mulher maligna e seus dois guarda-costas mortais."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Tom yum goong","runtime":109,"tagline":"","homepage":"","overview":"Mladý Thajec Kam se vydává na cestu do Austrálie, aby získal nazpět svého ukradeného slona. S pomocí vychytralého policejního detektiva brzy zjišťuje, že pachatelem je tajemná žena vlastnící obchod pojmenovaný Tom Yum Goong. V nerovném měření sil s mnoha protivníky se Kamovi hodí jeho vynikající bojové schopnosti."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Честь дракона","runtime":0,"tagline":"","homepage":"","overview":"В основі сюжету – історія про те, як в однієї селянської родини з Таїланду перекупники викрали слона й слоненя, яких потім нелегально переправили у Сідней. Юнак, чийого батька убили від час викрадення, вирушає в Австралію, де починає битву зі злочинним синдикатом..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"옹박: 두번째 미션","runtime":0,"tagline":"","homepage":"","overview":"‘자투렁카바트’라고 불리운 근위대 조상을 둔 청년 캄은 과거 선친들이 살던 깊은 산골에서 코끼리를 키우며 살고 있는 평범한 청년이다. 그에겐 포야이와 콘이라는 귀중한 혈통의 코끼리가 있는데 그 중 포야이는 전설로만 내려오던 완벽한 혈통의 코끼리로 캄과 그의 아버지는 포야이를 곧 왕에게 하사할 예정이었다.  그러던 어느 날, 태국의 갱 조직에 의해 코끼리가 도난 당하고 우여곡절 끝에 그 코끼리는 국제 범죄조직에 의해 호주 시드니로 밀매가 되어버린다. 그에게 있어 코끼리는 가족과도 같이 소중한 것이었기에 캄은 부족들의 대표로 코끼리들을 되 찾아 오기 위해 호주로 떠난다.  호주에 도착한 캄은 그곳의 경찰관인 마크와 릭을 만나 그들이 조사중인 사건에 도움을 주며 협조를 받게 되고 캄이 상대해야 할 범죄조직이 엄청난 영향력을 행사하고 있는 마피아 조직임을 알게 되는데...  마피아들은 태국에서 온 골칫덩어리 캄을 제거하려 악명 높은 킬러들을 보내기 시작한다. 이에 캄은 조상 대대로 전수 받은 고대 무에타이 ‘무에타이보란’을 사용하여 적들에게 조금씩 다가가는데... 그곳엔 상상을 초월하는 강력한 적들에 의한 예상치 못한 위험이 그를 기다리고 있었다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Тайландски дракон","runtime":109,"tagline":"Отмъщението не познава милост!","homepage":"","overview":"Тайландски дракон разказва историята на Кам (Тони Джаа), обикновено селско момче, което е изправено пред предизвикателствата на живота. Кам и баща му притежават два слона, които мечтаят да представят на краля на Тайланд. Когато ценните слонове са откраднати и продадени в Австралия от тайландска банда, Кам разбира, че единственият начин да спаси животните, е като се справи с престъпниците. С помощта на тайландския полицай Марк (Мум Джокмок) и живеещата в Сидни тайландска девойка Пла (Бонкох Конмалай), Кам се изправя пред тежка битка срещу боса на бандата Мадам Роуз и нейните свирепи подчинени Джони и Ти Кей."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"محافظ 1","runtime":0,"tagline":"","homepage":"","overview":"جنگجوی جوانی به نام خام ، باید به استرالیا برود تا فیل دزدیده شده اش را پیدا کند. اما…"},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"拳霸2","runtime":0,"tagline":"","homepage":"","overview":"「象拳」的絕世傳人東尼嘉從小與父親相依為命，他們飼養了一對具有皇族血統的大象，大象父子和他們父子的感情非常深厚。東尼嘉一心想將自己最美好的財富－這兩隻皇族大象，獻給泰皇蒲美蓬。沒想到，這兩隻皇族大象受到澳洲黑幫幫主「玫瑰夫人」的覬覦，砸下了重金指名非買到手不可。泰國黑幫份子在重賞之下全數傾巢而出，兩隻皇族大象於是被奪，並被連夜裝載送往澳洲。東尼嘉眼見自己心愛的大象遭人奪走，決定遠渡重洋到澳洲單挑黑幫幫主，並奪回這對大象父子…。東尼嘉究竟能不能達成援救任務？而這對大象父子是否能順利平安歸來？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"El Protector","runtime":0,"tagline":"","homepage":"","overview":"Kham es un joven que vive apaciblemente en su aldea de la Tailandia rural. Pero esta tranquila vida dará un vuelco cuando una banda mafiosa con base en Australia roba sus elefantes trasladándolos a Sidney. Los dos elefantes son más que unos simples animales para Kham y su padre; son dos miembros más de la familia que han sido preparados durante años para regalárselos como signo de devoción al rey de Tailandia. La única posibilidad de recuperar a los animales será adentrarse en una tierra desconocida y luchar contra la banda mafiosa."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"トム・ヤム・クン!","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"The Protector","runtime":0,"tagline":"","homepage":"","overview":"Norsujen parissa kasvanut kamppailulajien mestari Kham lähtee Australiaan etsimään rikollisjengin sieppaamia norsuystäviään. Matkasta tulee varsinainen yhden miehen sota, kun Kham käy taistoon roistojoukkiota vastaan. Kaiken ratkaiseva lopullinen taistelu on käsillä..."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Người Bảo Vệ","runtime":0,"tagline":"","homepage":"","overview":"Tại Bangkok, cậu bé Kham được cha nuôi dưỡng trong rừng cùng những chú voi như một thành viên trong gia đình. Khi con voi già của mình và con Kern con bị bọn tội phạm đánh cắp, Kham phát hiện ra rằng những con vật đó đã được gửi đến Sidney. Anh ta đi đến Úc, nơi anh ta tìm thấy chú voi con trong một nhà hàng thuộc sở hữu của Madame Rose độc ác, thủ lĩnh của một tổ chức mafia Thái quốc tế. Với sự hỗ trợ của trung sĩ Thái Lan hiệu quả Mark, người đã tham gia vào một âm mưu, Kham chiến đấu để giải cứu con vật khỏi đám đông."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"冬蔭功","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Revenge of the Warrior","runtime":111,"tagline":"","homepage":"","overview":"Tierhändler haben Khams Familie zwei Elefanten gestohlen. Um den Ruhm seiner Familie aufrecht zu erhalten, reist er den rücksichtslosen Tierhändlern bis nach Australien hinterher, wo er mächtig und stark versucht auf die Fährte der Bande zu kommen, obwohl ihm das fremde Land große Schwierigkeiten bereitet."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"}],"reviews_tmdb":[],"recommendations":[{"id":110552,"adult":false,"title":"The Protector 2","video":false,"overview":"Kham finds himself in trouble when he is accused of killing a trader. While on the run from the trader's nieces who are martial artists, Kham meets a friend who warns him of a terrorist plot.","genre_ids":[28],"media_type":"movie","popularity":1.4697,"vote_count":299,"poster_path":"/hYTnLRJcIbYZEN9vfYN93fm8l5R.jpg","release_date":"2013-10-23","vote_average":6.156,"backdrop_path":"/aqjiiYkvt9dNfvnyIx1IxUtBRrb.jpg","original_title":"ต้มยำกุ้ง 2","original_language":"th"},{"id":9316,"adult":false,"title":"Ong-Bak","video":false,"overview":"When the head of a statue sacred to a village is stolen, a young martial artist goes to the big city and finds himself taking on the underworld to retrieve it.","genre_ids":[28,80],"media_type":"movie","popularity":4.8387,"vote_count":1829,"poster_path":"/oagqAwp48dMPoCT94yDJUDOCVPi.jpg","release_date":"2003-01-31","vote_average":7.13,"backdrop_path":"/wdHIYawEp7lnf1XNzp6rWxLYgUG.jpg","original_title":"องค์บาก","original_language":"th"},{"id":43209,"adult":false,"title":"Ong Bak 3","video":false,"overview":"Tien is captured and almost beaten to death before he is saved and brought back to the Kana Khone villagers. There he is taught meditation and how to deal with his Karma, but very soon his arch rival returns challenging Tien for a final duel.","genre_ids":[28,12,36],"media_type":"movie","popularity":1.7445,"vote_count":479,"poster_path":"/sIVrOJVeLqPz9NwNa0e4FpqJCWK.jpg","release_date":"2010-05-05","vote_average":6.072,"backdrop_path":"/rtScIZjSyI0oV7YFCtUUthFNvqj.jpg","original_title":"องค์บาก 3","original_language":"th"},{"id":16353,"adult":false,"title":"Ong Bak 2","video":false,"overview":"Tien, the son of Lord Sihadecho — a murdered nobleman — is taken under the wing of Chernang, a renowned warrior and leader of the Pha Beek Krut.","genre_ids":[12,28,53],"media_type":"movie","popularity":2.6321,"vote_count":696,"poster_path":"/5Iue46Q6d1EGMPl7XraeRAMdMoY.jpg","release_date":"2008-12-04","vote_average":6.451,"backdrop_path":"/3ZH69oLWaAmnR0WNGnTQkituwSF.jpg","original_title":"องค์บาก 2","original_language":"th"},{"id":30718,"adult":false,"title":"Last of the Dogmen","video":false,"overview":"A Montana bounty hunter is sent into the wilderness to track three escaped prisoners. Instead he sees something that puzzles him. Later with a female Native Indian history professor, he returns to find some answers.","genre_ids":[12,9648,53,37],"media_type":"movie","popularity":1.6969,"vote_count":100,"poster_path":"/7GkP9w87TAFSXLzJdqxTt0ymbJE.jpg","release_date":"1995-09-08","vote_average":6.7,"backdrop_path":"/eSjyfYgT9GOoeTEj20ByCgj84Ms.jpg","original_title":"Last of the Dogmen","original_language":"en"},{"id":570508,"adult":false,"title":"Innocent Witness","video":false,"overview":"An old man is found dead, and his housekeeper is charged with the murder. Her defense attorney is surprised to learn the only witness to the crime is a teenage girl with autism.","genre_ids":[18],"media_type":"movie","popularity":0.9624,"vote_count":83,"poster_path":"/rLfGdUJ4Rp1FTWKOvaZlMqHXb4i.jpg","release_date":"2019-02-13","vote_average":7.759,"backdrop_path":"/iJtsrvr9fWPpx9QO3PwuqMz58wy.jpg","original_title":"증인","original_language":"ko"},{"id":8268,"adult":false,"title":"Surviving with Wolves","video":false,"overview":"In 1942, the young Jewish girl Misha, her Russian mother Gerusha and her German father Reuven hide from the Germans in a small house in Ardennes, Belgium. Misha is very connected to her mother that advises her that if one day a person comes to her saying \"love of my life\", she would follow him or her without any question. When her parents are captured by the Nazis, Misha is delivered to a German family and the abusive matriarch gives a bad treatment to the girl. However, she finds support in the family of Ernest and his deranged wife Marthe that supplies groceries to foster family. Misha loves Ernest's dogs and the old man gives a compass to her and tells that her parents have been sent to East to forced labor. When the old couple is denounced for sheltering the girl and arrested by the Germans, Misha flees through the woods heading east. Along her journey seeking out her parents...","genre_ids":[18],"media_type":"movie","popularity":0.762,"vote_count":80,"poster_path":"/vlcyVOnKEMzMMoTg8oAcPCyoiSg.jpg","release_date":"2007-11-21","vote_average":6.238,"backdrop_path":"/2v7CE53X4aXdtiU22SgSdq0Oha.jpg","original_title":"Survivre avec les loups","original_language":"fr"},{"id":10104,"adult":false,"title":"Dorm Daze 2","video":false,"overview":"The gang from Dorm Daze is back, but this time they're on a cruise ship on a tropical voyage through the high seas. The cruise makes an educational stop at the island of San Paradiso, where the students are supposed to explore an important archaeological site. Things go from normal to crazy as their visit coincides with every other college's spring break. The moment the boat docks, classes are over! For these Billingsley students, their Semester at Sea will be an adventure no one will ever forget.","genre_ids":[35],"media_type":"movie","popularity":0.6635,"vote_count":95,"poster_path":"/6H4osjA6mFDBPMRKHkuoDrF4sXm.jpg","release_date":"2006-09-05","vote_average":4.6,"backdrop_path":"/igVGnlYpHXg9Z0UZDuCegOpSVKn.jpg","original_title":"Dorm Daze 2","original_language":"en"},{"id":64205,"adult":false,"title":"BKO: Bangkok Knockout","video":false,"overview":"A group of martial arts students are enjoying a reunion party when a bomb goes off in the building. When they wake up, some of their friends have been kidnapped and they soon find a group of assassins coming after them. The only way to survive is to fight their way out.","genre_ids":[28],"media_type":"movie","popularity":0.4385,"vote_count":74,"poster_path":"/GcXOHBEHqfaT3bYTb56Vd4zbEP.jpg","release_date":"2010-12-16","vote_average":5.723,"backdrop_path":"/ocgfe17YJhIMk5991yTMydTxxXn.jpg","original_title":"โคตรสู้ โคตรโส","original_language":"th"},{"id":56519,"adult":false,"title":"El Sicario, Room 164","video":false,"overview":"The story of a hitman for the drug cartels in Ciudad Juarez, Mexico.","genre_ids":[99],"media_type":"movie","popularity":0.1542,"vote_count":54,"poster_path":"/mHE3Ym8Ci84X2ggvNnC7gX8fZV4.jpg","release_date":"2010-11-03","vote_average":6.8,"backdrop_path":"/znXBkOdG8vWjd0C6rOuQso1z4L4.jpg","original_title":"El Sicario, Room 164","original_language":"es"},{"id":31378,"adult":false,"title":"Samurai III: Duel at Ganryu Island","video":false,"overview":"A humble and simple Takezo abandons his life as a knight errant. He's sought as a teacher and vassal by Shogun, Japan's most powerful clan leader. He's also challenged to fight by the supremely confident and skillful Sasaki Kojiro. Takezo agrees to fight Kojiro in a year's time but rejects Shogun's patronage, choosing instead to live on the edge of a village, raising vegetables. He's followed there by Otsu and later by Akemi, both in love with him. The year ends as Takezo assists the villagers against a band of brigands. He seeks Otsu's forgiveness and accepts her love, then sets off across the water to Ganryu Island for his final contest.","genre_ids":[28,12,18,10749,36],"media_type":"movie","popularity":1.3141,"vote_count":133,"poster_path":"/oVGMAef2EGjeXc4rJTTqTJq1ib4.jpg","release_date":"1956-01-03","vote_average":7.2,"backdrop_path":"/sL1Jv69vMefWm0BeowsETS07ALm.jpg","original_title":"宮本武蔵完結編　決闘巌流島","original_language":"ja"},{"id":82783,"adult":false,"title":"Entrega Inmediata","video":false,"overview":"Immediate delivery recounts the misadventures of Feliciano Callosum (Cantinflas), a postman who is recruited by the secret counterintelligence service (called XU-777 secret agency), and must uncover an international conspiracy.","genre_ids":[35],"media_type":"movie","popularity":0.43,"vote_count":53,"poster_path":"/17EOPEXYgzmTcVQyYRH9xPq836w.jpg","release_date":"1963-12-25","vote_average":7.198,"backdrop_path":"/q47t31ayeHvQMsZwshvLrf5Rf3s.jpg","original_title":"Entrega Inmediata","original_language":"es"},{"id":74842,"adult":false,"title":"Legend of the Millennium Dragon","video":false,"overview":"A spectacular journey of an unwilling young hero thrust into a mysterious past full of monsters, dragons, and strange hidden powers. Through a series of out of this world battles and adventures, Jun, a shy middle school boy, is transformed into a hero destined to battle evil and ensure harmony and tranquility in the world.","genre_ids":[16,12,14],"media_type":"movie","popularity":1.0337,"vote_count":61,"poster_path":"/thIp92OiHGCl8CB8CmbwfgSQfmF.jpg","release_date":"2011-04-29","vote_average":6.041,"backdrop_path":"/7aWPhsfiiEFIIojF1UndzfGYni5.jpg","original_title":"鬼神伝","original_language":"ja"},{"id":58648,"adult":false,"title":"Closet Land","video":false,"overview":"A young writer is interrogated by a sadistic secret policeman. She is accused of embedding political messages in her children's stories. The entire movie takes place in one room, with only the two actors. The movie is set in an unidentified, modern police state.","genre_ids":[18,53],"media_type":"movie","popularity":0.6519,"vote_count":45,"poster_path":"/6EsCDiddM1zAFehNIcYx2uRujn1.jpg","release_date":"1991-03-06","vote_average":6.611,"backdrop_path":"/mBwWJgiF8kCNSjCdFY3aWl3SZA.jpg","original_title":"Closet Land","original_language":"en"},{"id":13280,"adult":false,"title":"Kickin' It Old Skool","video":false,"overview":"In 1986, a young breakdancer falls into a coma after hitting his head in a talent show. 20 years later, he awakens and attempts to revive his dance team's short-lived career in order to support his parents' failing yogurt shop.","genre_ids":[35],"media_type":"movie","popularity":0.6271,"vote_count":98,"poster_path":"/yigEC20RnNqaXPeItmEO3RpdFdB.jpg","release_date":"2007-04-27","vote_average":4.73,"backdrop_path":"/y84fjbAiQh0idmMOrliNmWd2N7K.jpg","original_title":"Kickin' It Old Skool","original_language":"en"},{"id":30942,"adult":false,"title":"Fatal Contact","video":false,"overview":"A young man learns the fighting techniques of Sanda from a coach. The two become best friends as the young man prepares to enter an underground tournament, competing against some of the top fighters of the world.","genre_ids":[28,53,80],"media_type":"movie","popularity":0.9375,"vote_count":52,"poster_path":"/koUrJtsoeKH5z63554SXWCl2b1t.jpg","release_date":"2006-10-05","vote_average":6.5,"backdrop_path":"/t1mHDnHW8yzHA2qUMO38xV9uR1e.jpg","original_title":"黑拳","original_language":"zh"},{"id":184219,"adult":false,"title":"Pee Mak","video":false,"overview":"Mak's friends just want to protect him, but his wife Nak won't let a small thing like her own death get in the way of true love.","genre_ids":[35,10749,27],"media_type":"movie","popularity":1.1693,"vote_count":135,"poster_path":"/5gY0EPvTdeGjEEIQ7337ZxHXV55.jpg","release_date":"2013-03-28","vote_average":7.163,"backdrop_path":"/miFiBFHoWBi9wMg527arqhFAOlK.jpg","original_title":"พี่มาก..พระโขนง","original_language":"th"},{"id":45408,"adult":false,"title":"The Protector","video":false,"overview":"Billy Wong is a New York City cop whose partner is gunned down during a robbery. Billy and his new partner, Danny Garoni, are working security at a fashion show when a wealthy man's daughter, Laura Shapiro, is kidnapped. The Federal authorities suspect that Laura's father is involved with Mr. Ko, a Hong Kong drug kingpin, so the NYC police commissioner sends the two cops to Hong Kong to investigate.","genre_ids":[28,80,53],"media_type":"movie","popularity":1.2733,"vote_count":196,"poster_path":"/ri2yctGQr4DPLBODZZ2Ky2yqBoL.jpg","release_date":"1985-06-15","vote_average":6,"backdrop_path":"/pXx9LJ40uM7keWCDn0izV5FwkOd.jpg","original_title":"The Protector","original_language":"en"},{"id":391629,"adult":false,"title":"Baaghi","video":false,"overview":"Ronny is a rebellious man, who falls in love with Sia but circumstances separate them. Years later, Ronny learns that Sia is abducted by a martial arts champion, Raghav.","genre_ids":[28,53,10749,12],"media_type":"movie","popularity":1.0747,"vote_count":140,"poster_path":"/4IEqNeF3PzL06Y2YKsvi4uMGJ1q.jpg","release_date":"2016-04-29","vote_average":6.4,"backdrop_path":"/sM6P9HR36glkzk02A9vGfr3x1Qs.jpg","original_title":"बाघी","original_language":"hi"},{"id":329004,"adult":false,"title":"The Survivalist","video":false,"overview":"In a time of starvation, a survivalist lives off a small plot of land hidden deep in forest. When two women seeking food and shelter discover his farm, he finds his existence threatened.","genre_ids":[18,878,53],"media_type":"movie","popularity":1.4212,"vote_count":369,"poster_path":"/hd491WgKPxeQus2LnvFbYmyUFmt.jpg","release_date":"2015-04-15","vote_average":6.222,"backdrop_path":"/9uNxv66tEPnzsKCDPzcIK0ZIgVB.jpg","original_title":"The Survivalist","original_language":"en"}],"similar_content":[{"id":746,"adult":false,"title":"The Last Emperor","video":false,"overview":"A dramatic history of Pu Yi, the last of the Emperors of China, from his lofty birth and brief reign in the Forbidden City, the object of worship by half a billion people; through his abdication, his decline and dissolute lifestyle; his exploitation by the invading Japanese, and finally to his obscure existence as just another peasant worker in the People's Republic.","genre_ids":[18,36],"popularity":4.9386,"vote_count":1868,"poster_path":"/7TILJhdeJAaEyDiwvJZMo9SQBoe.jpg","release_date":"1987-10-04","vote_average":7.582,"backdrop_path":"/k29qVmwWwR0i5A1UMIws1Vmv6hV.jpg","original_title":"The Last Emperor","original_language":"en"},{"id":1966,"adult":false,"title":"Alexander","video":false,"overview":"Alexander, the King of Macedonia, leads his legions against the giant Persian Empire. After defeating the Persians, he leads his army across the then known world, venturing farther than any westerner had ever gone, all the way to India.","genre_ids":[10752,36,28,12,18,10749],"popularity":4.7502,"vote_count":3451,"poster_path":"/jrwQu72sGwGqwE8Ijne89PSIvhp.jpg","release_date":"2004-11-21","vote_average":5.95,"backdrop_path":"/h21dxRjtR7xOhyZljtSYeTETCht.jpg","original_title":"Alexander","original_language":"en"},{"id":420539,"adult":false,"title":"Honeygiver Among the Dogs","video":false,"overview":"In the remote Bhutan, an undercover detective investigates the case of a missing Buddhist nun and falls into a risky alliance with his only suspect, an alluring young woman known as the village \"demoness\".","genre_ids":[9648,80],"popularity":0.2463,"vote_count":5,"poster_path":"/jata2zud0wIwogw2xVPMlCLKC7k.jpg","release_date":"2018-02-16","vote_average":7,"backdrop_path":null,"original_title":"མོན་མོ་བཀྲིས་ཁྱེའུ་འདྲེན།","original_language":"dz"},{"id":942,"adult":false,"title":"Lethal Weapon 2","video":false,"overview":"Riggs and Murtaugh are on the trail of South African diplomats using their immunity to engage in criminal activities.","genre_ids":[28,12,35,80,53],"popularity":4.4713,"vote_count":3655,"poster_path":"/ZsUGxTnZ4TzTrHSAfUPJcliL1K.jpg","release_date":"1989-07-07","vote_average":7.026,"backdrop_path":"/zjRkl5PZvFujbRndrNbf4ZKbeNC.jpg","original_title":"Lethal Weapon 2","original_language":"en"},{"id":949,"adult":false,"title":"Heat","video":false,"overview":"Obsessive master thief Neil McCauley leads a top-notch crew on various daring heists throughout Los Angeles while determined detective Vincent Hanna pursues him without rest. Each man recognizes and respects the ability and the dedication of the other even though they are aware their cat-and-mouse game may end in violence.","genre_ids":[80,18,28],"popularity":14.6479,"vote_count":8089,"poster_path":"/e09dLw1Ljtccd2P4NsuUvVtS5du.jpg","release_date":"1995-12-15","vote_average":7.928,"backdrop_path":"/5JaR6UEoCJJLtLpqFOVMY4O4R7P.jpg","original_title":"Heat","original_language":"en"},{"id":978,"adult":false,"title":"Seven Years in Tibet","video":false,"overview":"Austrian mountaineer Heinrich Harrer journeys to the Himalayas without his family to head an expedition in 1939. But when World War II breaks out, the arrogant Harrer falls into Allied forces' hands as a prisoner of war. He escapes with a fellow detainee and makes his way to Lhasa, Tibet, where he meets the 14-year-old Dalai Lama, whose friendship ultimately transforms his outlook on life.","genre_ids":[12,18,36],"popularity":3.4644,"vote_count":3049,"poster_path":"/5euQXAgJ34TdUFl1t3O6Jw2lJAs.jpg","release_date":"1997-09-12","vote_average":7.16,"backdrop_path":"/athnSvS41TEHOSK2Ax0LAM0ulDp.jpg","original_title":"Seven Years in Tibet","original_language":"en"},{"id":868,"adult":false,"title":"Tsotsi","video":false,"overview":"A young South African boy from the Johannesburg ghetto named Tsotsi, meaning Gangster, leaves home as a child to get away from his helpless parents. Now a teenage thug, Tsotsi finds a baby in the back seat of a car he's just stolen. He decides that it is his responsibility to care for the infant and in the process learns that maybe the criminal life isn’t the best way.","genre_ids":[80,18],"popularity":0.6634,"vote_count":338,"poster_path":"/r3ebTJFcDZ35GaKcuUQQe243z4f.jpg","release_date":"2005-12-23","vote_average":6.95,"backdrop_path":"/gLxgqHpJcMvB6cMTA4hUBxoOMJ1.jpg","original_title":"Tsotsi","original_language":"tn"},{"id":500,"adult":false,"title":"Reservoir Dogs","video":false,"overview":"A botched robbery indicates a police informant, and the pressure mounts in the aftermath at a warehouse. Crime begets violence as the survivors -- veteran Mr. White, newcomer Mr. Orange, psychopathic parolee Mr. Blonde, bickering weasel Mr. Pink and Nice Guy Eddie -- unravel.","genre_ids":[80,53],"popularity":9.2336,"vote_count":15163,"poster_path":"/xi8Iu6qyTfyZVDVy60raIOYJJmk.jpg","release_date":"1992-09-02","vote_average":8.117,"backdrop_path":"/jwt159hXWA9Q5xpBo8hWb3zwLi7.jpg","original_title":"Reservoir Dogs","original_language":"en"},{"id":419307,"adult":false,"title":"The Samurai in Autumn","video":false,"overview":"Vladica lost the only thing that mattered to him - an amateur karate championship. Now he's back in his home town looking for a job, love and redemption.","genre_ids":[28,35,18],"popularity":0.1852,"vote_count":7,"poster_path":"/mWzbh1wCr59JSpT25e1mcnOYn0r.jpg","release_date":"2016-10-01","vote_average":6.9,"backdrop_path":"/2dg38HDyw47LlM03VKpBYHdAxAe.jpg","original_title":"Јесен самураја","original_language":"sr"},{"id":1472572,"adult":false,"title":"Elephant from \"Zoo Story\"","video":false,"overview":"The fifth film in the Toho Diamond series, following \"The Hateful Thing.\" Based on the true story of \"Zoo Story\" by author Fukuda Saburo.  During the Tokyo air raids of World War II, Zen-san, an elephant keeper at Ueno Zoo, is faced with the heartbreaking task of euthanizing Tonki, a beloved elephant, due to food shortages and wartime pressures. Unable to carry out the order, Zen-san secretly feeds Tonki, but the elephant is ultimately shot by the military police. The film poignantly captures Zen-san’s despair and the devastation of war, as he reflects on his powerlessness amid the chaos.","genre_ids":[18],"popularity":0.2478,"vote_count":0,"poster_path":"/4B8xd62PsDRyoUQzVx6zQ7jMZNQ.jpg","release_date":"1957-04-09","vote_average":0,"backdrop_path":null,"original_title":"「動物園物語」より 象","original_language":"ja"},{"id":249469,"adult":false,"title":"Loft","video":false,"overview":"In an apocalyptic future world, a young upper class couple is visiting an exhibition of surrealistic paintings, presented by a group of young anarchists in their loft flat where they trap and torture their high society guests.","genre_ids":[18,53,27],"popularity":0.1469,"vote_count":8,"poster_path":"/r5gQdFKlbZRaQvvSm9gZHbCxQpu.jpg","release_date":"1985-06-28","vote_average":3.625,"backdrop_path":"/kxl14WPBxnySeiIplk9Ovl9lgPK.jpg","original_title":"Loft","original_language":"de"},{"id":17317,"adult":false,"title":"Urban Justice","video":false,"overview":"Seagal plays a man with a dark and violent past, who seeks revenge for the murder of his son.","genre_ids":[80,28,53],"popularity":0.6535,"vote_count":123,"poster_path":"/owBmON7qbru3VvV6AaorgtXhMmF.jpg","release_date":"2007-10-21","vote_average":5.07,"backdrop_path":"/wNnrNmZe3GBmZnCIroFXPWOMhL4.jpg","original_title":"Urban Justice","original_language":"en"},{"id":17381,"adult":false,"title":"BMX Bandits","video":false,"overview":"Teens P.J. and Goose get their thrills on BMX bikes, performing hair-raising tricks all across Sydney, Australia. Along with their new friend Judy, they discover a box of walkie-talkies -- and find out that a gang of criminals intends to use them to monitor police signals during a bank robbery. When the young trio snatches the devices, it propels them on a hair-raising adventure in which their pedaling skills might just save their necks.","genre_ids":[12,80,18],"popularity":1.0814,"vote_count":156,"poster_path":"/e9yUSie4WBQzVDSaHx17x0RtDHy.jpg","release_date":"1983-12-29","vote_average":5.5,"backdrop_path":"/ePJKdYRLH7QiAX994POl78U3Rv3.jpg","original_title":"BMX Bandits","original_language":"en"},{"id":17386,"adult":false,"title":"Revenge of the Ninja","video":false,"overview":"A peaceful ex-ninja's life shatters when his son's kidnapping forces him back into violence amid an American-Japanese criminal drug war.","genre_ids":[28,80,18,53],"popularity":1.4346,"vote_count":162,"poster_path":"/qEZ0Av3VvJvIs0zeqntNVUY9n48.jpg","release_date":"1983-09-07","vote_average":6.2,"backdrop_path":"/1Zo7iLqs0ugLK1JgeeDpMpT0uqo.jpg","original_title":"Revenge of the Ninja","original_language":"en"},{"id":15699,"adult":false,"title":"Opal Dream","video":false,"overview":"Pobby & Dingan are invisible. They live in an opal town in Australia and are friends with Kellyanne, the 9 year-old daughter of an opal miner. The film tells the story of the bizarre and inexplicable disappearance of Pobby & Dingan, Kellyanne's imaginary friends, and the impact this has on her family and the whole town. The story is told through the eyes of Kellyanne's 11 years old brother Ashmol.","genre_ids":[18,10751],"popularity":0.4121,"vote_count":26,"poster_path":"/3CNwFxtb