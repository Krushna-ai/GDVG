vote_average":1.75},{"width":3817,"height":2147,"file_path":"/pLsPfMhBSBM2knfVwlDQnDF7cvN.jpg","iso_639_1":null,"vote_average":1.75},{"width":3058,"height":1720,"file_path":"/u2uR5j390MrmVUctoKIGEL5yEiO.jpg","iso_639_1":null,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/vfJzPTYVW2Wd0xb1CYYqlIuC5r8.jpg","iso_639_1":null,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/gRYOy6ZCMR0zq28xdJOokiPauyl.jpg","iso_639_1":null,"vote_average":1.75},{"width":1338,"height":752,"file_path":"/qaxJ1N0uzsyiPGQX9r3Y8O1GNGF.jpg","iso_639_1":null,"vote_average":1.222}]},"enriched_at":"2026-02-21T10:05:24.637+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":144,"tagline":"","homepage":"","overview":"天劫之后，哪吒、敖丙的灵魂虽保住了，但肉身很快会魂飞魄散。太乙真人打算用七色宝莲给二人重塑肉身。但是在重塑肉身的过程中却遇到重重困难，哪吒、敖丙的命运将走向何方？ 申公豹放出被囚的四龙王，东海龙王敖光表示“我若出战，就让陈塘关鸡犬不留”，哪吒为了守卫陈塘关将与四海龙王大打出手。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Ne Zha 2","runtime":144,"tagline":"Witness a hero reborn.","homepage":"https://a24films.com/films/ne-zha-2","overview":"After a catastrophic event leaves their bodies destroyed, Ne Zha and Ao Bing are granted a fragile second chance at life. As tensions rise between the dragon clans and celestial forces, the two must undergo a series of perilous trials that will test their bond, challenge their identities, and decide the fate of both mortals and immortals."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Ne Zha 2","runtime":144,"tagline":"Sé testigo del renacimiento de un héroe.","homepage":"","overview":"Cuando los cuerpos de los dos amigos, Aobing y Nezha, están a punto de ser destruidos, se les permite que sus almas sigan existiendo. Su maestro, Taiyi Zhenren, restaura sus cuerpos con la ayuda de una flor de loto. Después de esto, Nezha parte en busca de enfrentar al Rey Dragón del Mar del Este, Ao Guang."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Ne Zha 2","runtime":144,"tagline":"","homepage":"","overview":"Após a Tribulação, embora as almas de Ne Zha e Ao Bing tenham sido preservadas, os seus corpos físicos seriam em breve completamente destruídos. Tai Yi Zhen Ren planeia utilizar o Lótus de Sete Cores para remodelar as suas formas físicas. Mas no processo de remodelação, encontram inúmeras dificuldades. Para onde irá o destino de Ne Zha e Ao Bing?"},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Нэчжа побеждает Царя драконов","runtime":143,"tagline":"","homepage":"","overview":"После катастрофы, хотя души Нечжи и Аобина были спасены, их тела вскоре были разрушены. Тайи Чжэньжэнь планировал использовать семицветный лотос для восстановления своих тел."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Na Tra 2: Ma Đồng Náo Hải","runtime":143,"tagline":"","homepage":"","overview":"Sau kiếp nạn, mặc dù linh hồn của Na Tra và Ngao Bính được bảo toàn, nhưng thân xác của họ sẽ sớm bị hủy hoại hoàn toàn. Thái Ất Chân Nhân dự định sử dụng Bảy Đóa Sen Sắc Màu để tái tạo thân xác cho họ. Tuy nhiên, trong quá trình tái tạo, họ đã gặp phải vô vàn khó khăn. Số phận của Na Tra và Ngao Bính sẽ đi về đâu?"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Ne Zha 2: El Renacer del Alma","runtime":143,"tagline":"","homepage":"","overview":"Después de la catástrofe, aunque las almas de Nezha y Aobing fueron salvadas, sus cuerpos pronto serían destrozados. Taiyi Zhenren planeaba usar el loto de siete colores para reconstruir sus cuerpos."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Ne Zha 2: O Renascer da Alma","runtime":144,"tagline":"A maior animação de todos os tempos.","homepage":"https://a2filmes.com.br/details/3462","overview":"Após uma grande catástrofe, as almas de Ne Zha e Ao Bing são salvas, mas seus corpos enfrentam a ruína. Para lhes dar uma nova vida, Taiyi Zhenren recorre à mística lótus de sete cores em uma ousada tentativa de reconstruí-los e mudar seus destinos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"นาจา 2","runtime":0,"tagline":"","homepage":"","overview":"หลังจากรับอสนีบาต แม้นาจากับอ๋าวปิ่งจะรอดมาได้ด้วยการกลายเป็นวิญญาณ แต่ในไม่ช้าพวกเขาก็จะต้องสลายหายไป ไท่หยี่จึงวางแผนที่จะสร้างร่างของนาจาและอ๋าวปิ่งขึ้นมาใหม่ด้วยดอกบัววิเศษเจ็ดสี ทว่าระหว่างการสร้างร่างก็ได้เกิดอุปสรรคขึ้นมากมาย มาลุ้นกันว่าชะตากรรมของนาจาและอ๋าวปิ่งจะเป็นอย่างไรต่อไป"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"哪吒之魔童鬧海","runtime":0,"tagline":"","homepage":"","overview":"天劫之後，哪吒、敖丙的靈魂雖保住了，但靈魂很快會魂飛魄散。太乙真人打算用七色寶蓮給二人重塑肉身。但是在重塑肉身的過程中卻遇到重重困難，哪吒、敖丙的命運將走向何方？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"哪吒之魔童鬧海","runtime":0,"tagline":"","homepage":"","overview":"天劫之後，哪吒、敖丙的靈魂雖然保住了，但肉身很快會魂飛魄散。太乙真人只能使用七色寶蓮給二人重塑肉身。但是在重塑肉身的過程中卻遭遇重重困難，哪吒、敖丙的命運將走向何方？申公豹放出被囚禁深海的四龍王，東海龍王敖光表示「我若出戰，就讓陳塘關雞犬不留」，哪吒為了守衛陳塘關將與四海龍王大打出手。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"Нечжа 2","runtime":0,"tagline":"Стань свідком відродження героя.","homepage":"","overview":"Хоча душі Нечжі та Аобіна були врятовані, їх фізичні втілення невдовзі мають зникнути. Тайї Чженьжень вирішує використати семикольоровий лотос, щоб відновити їх тіла."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Ne Zha 2: W krainie potworów","runtime":0,"tagline":"","homepage":"","overview":"Historia zbuntowanego młodego chłopca o imieniu Ne Zha, który budzi strach wśród bogów, choć urodził się jako dziecko śmiertelników. Posiada dzikie i niekontrolowane moce. Gdy przebudzona zostaje starożytna siła, która zamierza zniszczyć ludzkość, chłopiec musi szybko dorosnąć, aby stać się bohaterem, którego świat potrzebuje.  Jest to uniwersalna, klasyczna opowieść o walce między dobrem, a złem."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Ne Zha - L'ascesa del guerriero di fuoco","runtime":0,"tagline":"Il film d'animazione con il maggior incasso nella storia del cinema","homepage":"","overview":"Ne Zha, un giovane ribelle dai poteri sovrannaturali, stringe un’alleanza instabile con il principe dei draghi, Ao Bing, in una battaglia epica per proteggere i loro rispettivi clan. Ma dopo lo scontro, i loro corpi sono sull’orlo della distruzione. Ne Zha deve così intraprendere una pericolosa missione alla ricerca di un elisir capace di salvare il corpo di Ao Bing. Durante questo viaggio tra mostri epici e leggende, Ne Zha scoprirà una cospirazione che minaccia di scatenare una guerra devastante tra il bene e il male — e dovrà affrontare forze oscure e inganni per proteggere ciò che ha di più caro."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Ne Zha 2","runtime":0,"tagline":"Je suivrai mon propre chemin","homepage":"","overview":"Après la catastrophe, bien que les âmes de Ne Zha et d'Ao Bing aient été sauvées, leurs corps sont menacés de destruction. Pour leur redonner vie, Taiyi Zhenren se tourne vers le lotus mystique aux sept couleurs dans une tentative audacieuse de les reconstruire et de changer leur destin."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"","iso_639_1":"tl","iso_3166_1":"PH","english_name":"Tagalog"},{"data":{"title":"نژا ۲","runtime":0,"tagline":"","homepage":"","overview":"پس از یک نبرد بزرگ، اگرچه روح نژا و آئوبینگ نجات یافت، اما بدن فیزیکی آن‌ها به زودی به طور کامل نابود خواهد شد. حال استاد تای‌یی‌ژن‌رن قصد دارد از نیلوفر آبی هفت رنگ برای بازسازی بدن‌های آن‌ها استفاده کند، اما در فرآیند بازسازی، با مشکلات متعددی روبرو می‌شود. در نهایت باید دید سرنوشت نژا و آئوبینگ چگونه رقم خواهد خورد؟"},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Ne Zha 2","runtime":0,"tagline":"","homepage":"","overview":"După tribulație, deși sufletele lui Ne Zha și Ao Bing au fost păstrate, corpurile lor fizice erau pe cale să fie complet distruse. Tai Yi Zhen Ren plănuiește să folosească Lotusul cu Șapte Culori pentru a le reconstrui trupurile. Însă, în timpul acestui proces, apar numeroase obstacole neașteptate. Încotro va merge soarta lui Ne Zha și Ao Bing?"},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"너자 2","runtime":0,"tagline":"세상을 뒤흔들 엄청난 녀석 등장!","homepage":"","overview":"신·인간·요괴가 뒤섞여 사는 세상, 조금 다르게 태어났다는 이유로 말썽쟁이로 불리는 팬더 눈 너자. 엄청난 파워의 너자는 스승과 함께 수련에만 열심히인데… 문제의 시작은 삼계의 균형을 흔드는 위험한 힘의 흔적. 가만히 두면 세상이 통째로 뒤집힐 판이라, 우리의 주인공 너자가 나선다. 소동의 근원을 찾아 나선 너자 일행, 그러나 길은 순탄치 않고 싸움은 점점 그 규모가 커져 가는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"ナタ 魔童の大暴れ","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Ne Zha 2","runtime":143,"tagline":"","homepage":"","overview":"Nach den Ereignissen des ersten Films werden die Seelen von Ne Zha und Ao Bing zwar bewahrt, ihre physischen Körper jedoch bald zerstört. Tai Yi Zhen Ren plant, ihre Körper mithilfe des Siebenfarbigen Lotus neu zu gestalten, stößt dabei jedoch auf zahlreiche Schwierigkeiten. Was wird aus Ne Zha und Ao Bing?"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"ناچا ٢","runtime":144,"tagline":"","homepage":"https://a24films.com/films/ne-zha-2","overview":"بعد تعرض ناچا (Nezha) وآوْبِينْغ (Ao Bing) لصاعقة سماوية، تحوَّلت أجسادهما إلى أرواح معرضة للزوال. يخطط المعلم تَايِي (Taiyi) لإعادة بناء أجسادهما باستخدام زهرة اللوتس المقدسة، إلا أنَّ العملية تواجه عقبات عديدة. فما مصيرُ نِيْتْشَا وآوْبِينْغ في ظلِّ هذه التحديات؟"},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Не Жа 2","runtime":0,"tagline":"","homepage":"","overview":"След скръбта, въпреки че душите на Не Жа и Ао Бинг бяха запазени, физическите им тела скоро ще бъдат унищожени. Тай Йи Джен Рен планира да използва седемте цветни лотоси, за да прекрои физическите си форми, но среща множество трудности. Какво ще стане с Не Жа и Ао Бинг?"},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Ne Zha 2","runtime":0,"tagline":"","homepage":"","overview":"Seqüela de la pel·lícula animada 'Ne Zha', basada en una novel·la xinesa del segle XVI. Després d’una batalla èpica, les ànimes de Nezha i Ao Bing sobreviuen, però els seus cossos resten destruïts. Amb l’ajuda d’una flor de lotus màgica, el mestre Taiyi els retorna la vida. Llavors Nezha emprèn una nova missió per vèncer el Rei Drac i evitar una guerra entre el bé i el mal."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Ne Zha 2","runtime":143,"tagline":"","homepage":"","overview":"Musibet sonrası Ne Zha ve Ao Bing'in ruhları korunmuş olsa da, fiziksel bedenleri yok olmak üzeredir. Tai Yi Zhen Ren, onların fiziksel formlarını Yedi Renkli Lotus ile yeniden şekillendirmeyi planlar, ancak sayısız zorlukla karşılaşır. Peki, Ne Zha ve Ao Bing'in akıbeti ne olacak?"},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Po zničení svých těl nebeskými blesky se dětský démon Ne Zha a syn dračího krále Ao Bing snaží obnovit svá fyzická těla pomocí síly posvátného lotosu. Jejich rituál však přeruší invaze démonického Šen Gongbaoa, který se spojí s draky vyhnanými z nebeského království. Ne Zha, jenž v tuto chvíli sdílí tělo s Ao Bingem, se vydává do paláce Yuxu, aby požádal o pomoc nesmrtelného mistra Wulianga, který je jejich poslední nadějí na záchranu a obnovu jejich těl."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"ნე ჯა ამარცხებს დრაკონების მეფეს","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Неза 2","runtime":0,"tagline":"","homepage":"","overview":"Након што катастрофалан догађај уништи њихова тела, Неза и Ао Бинг добијају крхку другу шансу за живот. Како расту тензије између змајевих кланова и небеских сила, њих двоје морају да прођу кроз низ опасних искушења која ће тестирати њихову везу, довести у питање њихове идентитете и одлучити о судбини и смртника и бесмртника."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Radnja prati dječaka imena Ne Zha, demonsko dijete koje su odgojili ljudi, a koji mora krenuti u opasnu misiju kako bi došao do eliksira koji može zaliječiti tijelo njegovog saveznika, zmajskog princa Ao Binga. Tijekom teškog putovanja Ne Zha će otkriti i veliku zavjeru koja bi mogla pokrenuti veliki rat između dobra i zla."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Ne Zha 2: The Demon Boy Churns the Sea","runtime":0,"tagline":"","homepage":"","overview":"Efter en stor katastrof räddas Nezhas och Aobings själar, men deras kroppar är förstörda. För att ge dem nytt liv vänder sig Taiyi Zhenren till den mystiska sju-färgade lotusen i ett djärvt försök att återskapa dem och förändra deras öde."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Ne Zha 2","runtime":0,"tagline":"","homepage":"","overview":"A megpróbáltatások után Nezha és Aobing azzal szembesül, hogy fizikai formájuk hamarosan elveszik. Taiyi Zhenren egy merész tervet eszel ki, hogy a misztikus Hétszínű Lótusz segítségével helyreállítsa őket. Ez a küldetés azonban komoly akadályokba ütközik...  (Gergo Horvath)R3"},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"ناچا ٢","runtime":144,"tagline":"","homepage":"https://a24films.com/films/ne-zha-2","overview":"بعد تعرض ناچا (Nezha) وآوْبِينْغ (Ao Bing) لصاعقة سماوية، تحوَّلت أجسادهما إلى أرواح معرضة للزوال. يخطط المعلم تَايِي (Taiyi) لإعادة بناء أجسادهما باستخدام زهرة اللوتس المقدسة، إلا أنَّ العملية تواجه عقبات عديدة. فما مصيرُ نِيْتْشَا وآوْبِينْغ في ظلِّ هذه التحديات؟"},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"Ne Zha 2","runtime":0,"tagline":"Je suivrai mon propre chemin","homepage":"","overview":"Après la catastrophe, bien que les âmes de Ne Zha et d'Ao Bing aient été sauvées, leurs corps sont menacés de destruction. Pour leur redonner vie, Taiyi Zhenren se tourne vers le lotus mystique aux sept couleurs dans une tentative audacieuse de les reconstruire et de changer leur destin."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Ne Zha 2","runtime":0,"tagline":"","homepage":"","overview":"Ο Νεζά, ένα δαιμονικό παιδί που ανατράφηκε από ανθρώπους, σχηματίζει μια εύθραυστη συμμαχία με τον πρίγκιπα των Δράκων, Άο Μπινγκ, σε μια επική μάχη για την προστασία των φυλών τους. Μετά τη σύγκρουση, τα σώματά τους βρίσκονται στο χείλος της καταστροφής. Ο Νεζά πρέπει τώρα να ξεκινήσει μια επικίνδυνη αποστολή για να αποκτήσει ένα ελιξίριο που θα επαναφέρει το σώμα του Άο Μπινγκ.\r Κατά τη διάρκεια αυτής της αποστολής εξόντωσης δαιμόνων, ο Νεζά αποκαλύπτει μια συνωμοσία που θα πυροδοτήσει έναν καταστροφικό πόλεμο ανάμεσα στο καλό και το κακό - και θα χρειαστεί να αντισταθεί σε προδοτικές δυνάμεις για να προστατεύσει ό,τι αγαπά."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"}],"reviews_tmdb":[{"id":"67d7d3a131678cc3f8019b3d","url":"https://www.themoviedb.org/review/67d7d3a131678cc3f8019b3d","author":"CinemaSerf","content":"$11","created_at":"2025-03-17T07:47:45.478Z","updated_at":"2025-03-17T07:51:36.504Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}},{"id":"68b827474acfe14e8e1baf96","url":"https://www.themoviedb.org/review/68b827474acfe14e8e1baf96","author":"wu66chen","content":"$12","created_at":"2025-09-03T11:32:23.524Z","updated_at":"2025-09-12T16:13:49.574Z","author_details":{"name":"","rating":null,"username":"wu66chen","avatar_path":null}},{"id":"68be843a1cc83836311bc96f","url":"https://www.themoviedb.org/review/68be843a1cc83836311bc96f","author":"tmdb90329212","content":"Bro, Nezha 2 completely misses the point of the first movie. In the first one, the dragons weren’t enemies they were tricked by The Supreme Lords into doing their dirty work, capturing monsters, and ended up also being trapped in the underwater purgatory. But in the second movie, the story feels totally disconnected from that and somehow leaving doesn't matter nor some of the problems caused. Like It honestly seems like the producers didn’t even try, since some scenes look copied and pasted from the original and the movie in general don't make sense in many parts nor what the actual \r\nSubject for the movie was, I feel so disappointed in this since I was so excited to see the movie to end up feeling dissatisfied and definitely disappointed😕","created_at":"2025-09-08T07:22:34.053Z","updated_at":"2025-09-12T16:08:37.599Z","author_details":{"name":"","rating":null,"username":"tmdb90329212","avatar_path":null}}],"recommendations":[{"id":615453,"adult":false,"title":"Ne Zha","video":false,"overview":"A young boy is born as the reincarnation of a demonic power, into a society that hates and fears him. Destined by prophecy to bring destruction to the world, Nezha must choose between good and evil to see if he can change his fate.","genre_ids":[16,14,12],"media_type":"movie","popularity":8.5545,"vote_count":801,"poster_path":"/phM9bb6s9c60LA8qwsdk7U1N2cS.jpg","release_date":"2019-07-26","vote_average":7.896,"backdrop_path":"/k1pJslKr4aDayw9kWwWnlC3MIP3.jpg","original_title":"哪吒之魔童降世","original_language":"zh"},{"id":1500536,"adult":false,"title":"Dead to Rights","video":false,"overview":"During the 1937 Nanjing Massacre, a postman poses as a photo developer, helping Japanese forces while secretly sheltering Chinese refugees. He later risks his life evacuating them and revealing evidence of the atrocities.","genre_ids":[18,10752,36],"media_type":"movie","popularity":3.1035,"vote_count":67,"poster_path":"/rx9xTly73NssFHPg9gKrX9tJdDI.jpg","release_date":"2025-07-19","vote_average":8,"backdrop_path":"/ngLgoY3MTfLANqv9cpXr96saaFV.jpg","original_title":"南京照相馆","original_language":"zh"},{"id":1155281,"adult":false,"title":"Creation of the Gods II: Demon Force","video":false,"overview":"Taishi Wen Zhong led the army of Shang Dynasty including Deng Chanyu and four generals of the Mo Family to Xiqi. With the help of Kunlun immortals such as Jiang Ziya, Ji Fa led the army and civilians of Xiqi to defend their homeland.","genre_ids":[28,14,10752],"media_type":"movie","popularity":9.2246,"vote_count":128,"poster_path":"/dfUCs5HNtGu4fofh83uiE2Qcy3v.jpg","release_date":"2025-01-29","vote_average":6.371,"backdrop_path":"/yujcZMkNKtNXPvRGyTA3e3VCrbx.jpg","original_title":"封神第二部：战火西岐","original_language":"zh"},{"id":1357305,"adult":false,"title":"Detective Chinatown 1900","video":false,"overview":"In 1900, a white woman was murdered in Chinatown in San Francisco, and the suspect was a Chinese man. The murder caused social shock, and people demanded the closure of Chinatown.","genre_ids":[35,9648,28],"media_type":"movie","popularity":2.3961,"vote_count":95,"poster_path":"/g3GsgIlH3fA4RxhNOAMvSbVWyfW.jpg","release_date":"2025-01-29","vote_average":6.316,"backdrop_path":"/ux9bsXuwkhlSHwcnmKa8hzTOadO.jpg","original_title":"唐探1900","original_language":"zh"},{"id":1338799,"adult":false,"title":"JUJUTSU KAISEN: Hidden Inventory / Premature Death - The Movie","video":false,"overview":"Pursued by a religious cult and other curse users, former friends Satoru Gojo and Suguru Geto are the only sorcerers capable of carrying the difficult task of protecting Riko Amanai, a student who has been designated to be sacrificed as the Star Plasma Vessel, until she can fulfill her duty.","genre_ids":[16,28,14],"media_type":"movie","popularity":8.2651,"vote_count":57,"poster_path":"/kZkyr1sRzarENrxjtltPvmHRrTk.jpg","release_date":"2025-05-30","vote_average":8.211,"backdrop_path":"/w8j0HVX7xasNVGAva2T3W4ncoN4.jpg","original_title":"劇場版総集編 呪術廻戦 懐玉・玉折","original_language":"ja"},{"id":1280444,"adult":false,"title":"The Occupant","video":false,"overview":"Desperate to save her sister, Abby takes a dangerous job in the remote Georgian wilderness. Stranded in the mountains after her helicopter crashes, she finds hope through John, a mysterious helper radioing from nearby. As he guides her through the harsh conditions, Abby struggles to survive, and her grip on reality falters until she is faced with an impossible choice.","genre_ids":[878,18,53],"media_type":"movie","popularity":1.4087,"vote_count":57,"poster_path":"/aRWeT2UIkaWolqQ6fYeHOB1D6vA.jpg","release_date":"2025-08-07","vote_average":5.8,"backdrop_path":"/hltwDG1SWl1BqjORA619hIJb4Ui.jpg","original_title":"The Occupant","original_language":"en"},{"id":1291594,"adult":false,"title":"Beezel","video":false,"overview":"Over six tumultuous decades, three unwitting guests of a cursed New England home stumble upon a sinister secret dwelling beneath its floors - an eternal witch with an insatiable thirst for the flesh of the living.","genre_ids":[27,53],"media_type":"movie","popularity":2.0932,"vote_count":58,"poster_path":"/a9gZxhG98LATZJGy1vWssyjVkk.jpg","release_date":"2024-09-20","vote_average":5.552,"backdrop_path":"/1NIAoD8mWBfmqRpZiXVrxcAH873.jpg","original_title":"Beezel","original_language":"en"},{"id":1429739,"adult":false,"title":"Gold Rush Gang","video":false,"overview":"At the tail end of World War II, a bandit leader and his crew go up against his sworn enemy and the Japanese army to rob a train full of gold.","genre_ids":[28,35,18,37],"media_type":"movie","popularity":2.2363,"vote_count":31,"poster_path":"/7j6jZNhCTnsZy5QItpruDwyBWoo.jpg","release_date":"2025-08-19","vote_average":6.887,"backdrop_path":"/kYsU56QEcwEr8jAQ6Vm3M8bXTWz.jpg","original_title":"เขาชุมทอง คะนองชุมโจร","original_language":"th"},{"id":1454800,"adult":false,"title":"Trapped","video":false,"overview":"In 1995, the year before the comprehensive gun ban policy was implemented, the tranquility of Mangya Town was shattered. A notorious bandit leader, who had hidden a massive treasure, broke out of prison. Forty-three ruthless outlaws gathered from all directions, joining their leader, Beishan, in blockading Mangya by force. The entire town was plunged into a desperate crisis—cut off from fuel and communication!\r The bandits wanted both money and lives. Gunfire erupted across Mangya as a massive sandstorm loomed on the horizon. Facing impossible odds—one gun against eighty-eight—the gang also turned on each other in a brutal \"dog-eat-dog\" power struggle. Surrounded by enemies, with sandstorms blotting out the sun and death hanging by a thread—how can they turn the tide?","genre_ids":[18,80,9648],"media_type":"movie","popularity":2.6051,"vote_count":16,"poster_path":"/mmIqkyXhlgcaSb1S8zJsLQwGBls.jpg","release_date":"2025-04-29","vote_average":7.313,"backdrop_path":"/mINSxREmed7uTom1HiradrnwYoP.jpg","original_title":"Trapped","original_language":"zh"},{"id":1305653,"adult":false,"title":"Dongji Rescue","video":false,"overview":"Inspired by the real life rescue of over 300 British soldiers in 1942, Dongji Rescue is a rousing, action-packed story of heroism on the high seas. When the Japanese warship Lisbon Maru is torpedoed off the coast of Dongji Island, the lives of over 300 British POWs on board are at risk of being claimed by the sea. Their only hope is a small group of defiant Chinese fisherman who will do anything to rescue and protect them from their captors.","genre_ids":[18,36,10752],"media_type":"movie","popularity":2.7701,"vote_count":19,"poster_path":"/1eb3YebyscUmXmrrC2ZDDVR0w0P.jpg","release_date":"2025-08-08","vote_average":6.9,"backdrop_path":"/k42B99QoaXB9u8H4TeyT7dU1bdD.jpg","original_title":"东极岛","original_language":"zh"},{"id":291692,"adult":false,"title":"Brotherhood of Blades","video":false,"overview":"In the late Ming Dynasty, three sworn brothers who serve as the imperial secret police are dispatched to hunt down Wei Zhongxian, a eunuch politician who had been forced to resign from his influential post and exiled from Beijing. The brothers return successfully from their quest, only to find that their task was but the beginning of a strange conspiracy.","genre_ids":[10749,28,18],"media_type":"movie","popularity":2.3153,"vote_count":181,"poster_path":"/d2mXV6VXqpxxv5Zet9xc2rKVpJz.jpg","release_date":"2014-08-07","vote_average":6.738,"backdrop_path":"/hnVbBBQMztst5gbmXsp7oyQTCaY.jpg","original_title":"绣春刀","original_language":"zh"},{"id":1056444,"adult":false,"title":"The Colors Within","video":false,"overview":"Totsuko is a high school student with the ability to see the 'colors' of others. Colors of bliss, excitement, and serenity, plus a color she treasures as her favorite. Kimi, a classmate at her school, gives off the most beautiful color of all. Although she doesn't play an instrument, Totsuko forms a band with Kimi and Rui, a quiet music enthusiast they meet at a used bookstore in a far corner of town. As they practice at an old church on a remote island, music brings them together, forming friendships and stirring affections.","genre_ids":[16,18,10402],"media_type":"movie","popularity":1.9248,"vote_count":55,"poster_path":"/gOWDvzglcQZOQPqGfVF6hfOhMNT.jpg","release_date":"2024-08-30","vote_average":6.927,"backdrop_path":"/vmSyIJSc8froKqFEZHnsZGzdYCb.jpg","original_title":"きみの色","original_language":"ja"},{"id":31850,"adult":false,"title":"Breathless","video":false,"overview":"Sang-hoon is a lowlife gangster, a debt collector exercising thuggish ways to collect his money. The recipient of nothing but anger since his childhood, he expresses himself through violence. When he finally encounters someone who can stand up to him, feisty school-girl Yoon-hee they become unlikely friends.","genre_ids":[80,18],"media_type":"movie","popularity":1.0608,"vote_count":134,"poster_path":"/9ZPPjSoPWN4BPea2h8sd6L7skSI.jpg","release_date":"2009-04-16","vote_average":7.112,"backdrop_path":"/nMxucwkm4dAT7kfxV98dXqs6P0w.jpg","original_title":"똥파리","original_language":"ko"},{"id":1205892,"adult":false,"title":"Behind the Shadows","video":false,"overview":"Au Yeung Wai Yip is a private detective who has been focusing on missing persons and adultery investigations for many years. One day, he received a \"special\" commission: the owner of the travel agency had asked him to investigate his girlfriend, who happened to be Au Yeung Wai Yip’s wife.Being a private detective, he is used to looking for the truth with cold eyes for his clients, but he finds it difficult to face the truth about their own marriage. Unable to withstand his inner torment, Au Yeung Wai Yip gave up on another ongoing case - a client's search for his missing fiancée - and went to the hotel to catch the adulterer. Unfortunately, the marriage could not be saved in the end, and the client's fiancée was killed after he left. A seemingly ordinary affair turned into a murderous incident!","genre_ids":[18,80,9648],"media_type":"movie","popularity":0.9469,"vote_count":12,"poster_path":"/tM7TDlKcnARVeIvGcQ4Nj46h0VY.jpg","release_date":"2025-05-31","vote_average":6.333,"backdrop_path":"/pZ9BsPVRDz004TDF3ij5t3P3Uts.jpg","original_title":"私家偵探","original_language":"cn"},{"id":1273472,"adult":false,"title":"Honey Money Phony","video":false,"overview":"A working girl accidentally incurs a massive debt. She crosses paths with a con man. Amidst lies and deceit, they navigate a tumultuous journey, questioning their paths in life.","genre_ids":[35,10749],"media_type":"movie","popularity":0.9967,"vote_count":18,"poster_path":"/8Fe3E8qkL0oru2B8Z8ll2de3pOY.jpg","release_date":"2024-12-20","vote_average":5.944,"backdrop_path":"/mugCe3BRjMqNdS9YdKXLuJW9iRR.jpg","original_title":"“骗骗”喜欢你","original_language":"zh"},{"id":1083420,"adult":false,"title":"Adulthood","video":false,"overview":"The lives of two siblings are completely upended when they discover a dead body, long buried in their parent’s basement, sending them down a rabbit hole of crime and murder.","genre_ids":[35,80,18,9648],"media_type":"movie","popularity":3.2886,"vote_count":75,"poster_path":"/a40Gi0Zq4Ecqu3obmOp6TSgEne1.jpg","release_date":"2025-09-19","vote_average":5.94,"backdrop_path":"/7MEi8dOoQKz6no668dZDQgotOPD.jpg","original_title":"Adulthood","original_language":"en"},{"id":1181125,"adult":false,"title":"The Day Iceland Stood Still","video":false,"overview":"When 90% of Iceland’s women walked off the job and out of their homes one morning in 1975, they brought their country to its knees and catapulted Iceland to the forefront of today's global fight for gender equality. Unexpectedly funny, laced with evocative animation and powerfully told by the women who lived it – this is the true story of 12 hours that launched a revolution.","genre_ids":[99],"media_type":"movie","popularity":0.193,"vote_count":6,"poster_path":"/2335e2qPPBzsYAbjc8rWut0ad9R.jpg","release_date":"2025-01-25","vote_average":8.7,"backdrop_path":"/2rcFEp1DL6wcLdeKRgtxBcgNR2Y.jpg","original_title":"The Day Iceland Stood Still","original_language":"en"},{"id":895435,"adult":false,"title":"Be Somebody","video":false,"overview":"During the Republican era, a group of frustrated people from the movie industry is invited in a luxurious mansion to make a movie out of a gruesome case that has recently rattled the city of Shanghai, in the hopes that it would turn into a huge sensation and make them famous. However, they never expected that the murderer would be in their midst and that the truth behind the case would be far more bizarre than their fictional movie plot.","genre_ids":[35,9648,18],"media_type":"movie","popularity":0.7225,"vote_count":57,"poster_path":"/8z7IptdlKjox7BIiwNwSdSV68HP.jpg","release_date":"2021-11-11","vote_average":7.404,"backdrop_path":"/56RNLigrw1qPtxiohkFkXPRKrJO.jpg","original_title":"扬名立万","original_language":"zh"},{"id":41387,"adult":false,"title":"From Beijing with Love","video":false,"overview":"A Chinese secret agent travels to Hong Kong to reclaim a dinosaur fossil but experiences hilarious incidents because of his incompetence.","genre_ids":[28,35],"media_type":"movie","popularity":2.3132,"vote_count":217,"poster_path":"/xUAVVRNxbbI3XcwKdFTRAryQAk8.jpg","release_date":"1994-10-13","vote_average":7,"backdrop_path":"/doddmaUMZuWr6NhiPzQwjIs0MXD.jpg","original_title":"國產凌凌漆","original_language":"cn"},{"id":11378,"adult":false,"title":"Trafic","video":false,"overview":"Mr. Hulot is the head designer of the Altra Automotive Co. His latest invention is a newfangled camper car loaded with outrageous extra features. Along with the company's manager and publicity model, Hulot sets out from Paris with the intention of debuting the car at the annual auto show in Amsterdam. The going isn't easy, however, and the group encounters an increasingly bizarre series of hurdles and setbacks en route.","genre_ids":[35],"media_type":"movie","popularity":1.022,"vote_count":206,"poster_path":"/i68ups46J9bIb1Xnq0f6nxNXBYZ.jpg","release_date":"1971-04-16","vote_average":7.109,"backdrop_path":"/bRb9uhqaXm82Ioi6WUGLABikUCw.jpg","original_title":"Trafic","original_language":"fr"}],"similar_content":[{"id":247049,"adult":false,"title":"Lion and Bull","video":false,"overview":"Award winning animated short film by Fyodor Khitruk.","genre_ids":[16],"popularity":0.1903,"vote_count":13,"poster_path":"/jtC6rIr56z7FqTLcZll4iSyp7wo.jpg","release_date":"1984-08-01","vote_average":6,"backdrop_path":"/yfvYL86XorzivhyrHNJwnJhdrc6.jpg","original_title":"Лев и Бык","original_language":"ru"},{"id":590252,"adult":false,"title":"The Gingerbread House","video":false,"overview":"Even children in an over-technified civilization need fairy tales, and Mrs. Fairy Tale invites them into her world. The woodcutter goes to the forest with his children, Hansel and Gretel. While their father works, the children pick strawberries. However, they get lost deep into the forest and lose their way back. After a sinister night, they find themselves in front of a honey gingerbread house. While peeling gingerbread, the witch catches them: she locks the skinny Hansel in a cage to fatten him up, and makes the plump Gretel her helper. However, benevolent angels watch over both children, appearing to them in their dreams and giving them hope for salvation.","genre_ids":[10751,14],"popularity":0.1786,"vote_count":1,"poster_path":null,"release_date":"1933-12-22","vote_average":2,"backdrop_path":null,"original_title":"Perníková chaloupka","original_language":"cs"},{"id":763577,"adult":false,"title":"Spiritpact","video":false,"overview":"Yang Jinghua, a young heir to a family of exorcists, is left struggling alone after his parents’ deaths. Barely surviving, he encounters the wealthy and skilled exorcist Duanmu Xi while trying to fend off a spirit. After a fatal accident, Yang awakens to find himself in a contract with Duanmu Xi, marking the start of his new life.","genre_ids":[14],"popularity":0.2472,"vote_count":3,"poster_path":"/gQfa44P8piUHJ8A7bP6j0PXBNEy.jpg","release_date":"2018-03-11","vote_average":2.7,"backdrop_path":"/6P5Y2u2HrnOrTVQXTNDUNsJpSiS.jpg","original_title":"灵契","original_language":"zh"},{"id":247504,"adult":false,"title":"Veeram","video":false,"overview":"A straightforward man, who uses violence to settle disputes, decides to mend his ways for the sake of his lover, but when he learns that her family is in danger, he decides to save them at all cost.","genre_ids":[28,35],"popularity":0.4478,"vote_count":42,"poster_path":"/tLeL3TODjce9mC6KxpP45EPxZjm.jpg","release_date":"2014-01-10","vote_average":5.3,"backdrop_path":"/4wTcPRyHlWdpCpIUmfPDrMvMBZ6.jpg","original_title":"வீரம்","original_language":"ta"},{"id":671,"adult":false,"title":"Harry Potter and the Philosopher's Stone","video":false,"overview":"Harry Potter has lived under the stairs at his aunt and uncle's house his whole life. But on his 11th birthday, he learns he's a powerful wizard—with a place waiting for him at the Hogwarts School of Witchcraft and Wizardry. As he learns to harness his newfound powers with the help of the school's kindly headmaster, Harry uncovers the truth about his parents' deaths—and about the villain who's to blame.","genre_ids":[12,14],"popularity":22.7137,"vote_count":29166,"poster_path":"/wuMc08IPKEatf9rnMNXvIDxqP4W.jpg","release_date":"2001-11-16","vote_average":7.9,"backdrop_path":"/1XAC6RPT01UX9EQGy2JVn5c8pgy.jpg","original_title":"Harry Potter and the Philosopher's Stone","original_language":"en"},{"id":672,"adult":false,"title":"Harry Potter and the Chamber of Secrets","video":false,"overview":"Cars fly, trees fight back, and a mysterious house-elf comes to warn Harry Potter at the start of his second year at Hogwarts. Adventure and danger await when bloody writing on a wall announces: The Chamber Of Secrets Has Been Opened. To save Hogwarts will require all of Harry, Ron and Hermione's magical abilities and courage.","genre_ids":[12,14],"popularity":16.148,"vote_count":23265,"poster_path":"/sdEOH0992YZ0QSxgXNIGLq1ToUi.jpg","release_date":"2002-11-13","vote_average":7.704,"backdrop_path":"/1stUIsjawROZxjiCMtqqXqgfZWC.jpg","original_title":"Harry Potter and the Chamber of Secrets","original_language":"en"},{"id":673,"adult":false,"title":"Harry Potter and the Prisoner of Azkaban","video":false,"overview":"Year three at Hogwarts means new fun and challenges as Harry learns the delicate art of approaching a Hippogriff, transforming shape-shifting Boggarts into hilarity and even turning back time. But the term also brings danger: soul-sucking Dementors hover over the school, an ally of the accursed He-Who-Cannot-Be-Named lurks within the castle walls, and fearsome wizard Sirius Black escapes Azkaban. And Harry will confront them all.","genre_ids":[12,14],"popularity":15.6854,"vote_count":22845,"poster_path":"/aWxwnYoe8p2d2fcxOqtvAtJ72Rw.jpg","release_date":"2004-05-31","vote_average":8.009,"backdrop_path":"/vbk5CfaAHOjQPSAcYm6AoRRz2Af.jpg","original_title":"Harry Potter and the Prisoner of Azkaban","original_language":"en"},{"id":674,"adult":false,"title":"Harry Potter and the Goblet of Fire","video":false,"overview":"When Harry Potter's name emerges from the Goblet of Fire, he becomes a competitor in a grueling battle for glory among three wizarding schools—the Triwizard Tournament. But since Harry never submitted his name for the Tournament, who did? Now Harry must confront a deadly dragon, fierce water demons and an enchanted maze only to find himself in the cruel grasp of He Who Must Not Be Named.","genre_ids":[12,14],"popularity":17.271,"vote_count":21865,"poster_path":"/fECBtHlr0RB3foNHDiCBXeg9Bv9.jpg","release_date":"2005-11-16","vote_average":7.801,"backdrop_path":"/8f9dnOtpArDrOMEylpSN9Sc6fuz.jpg","original_title":"Harry Potter and the Goblet of Fire","original_language":"en"},{"id":675,"adult":false,"title":"Harry Potter and the Order of the Phoenix","video":false,"overview":"Returning for his fifth year at Hogwarts, Harry is stunned to find that his warnings about the return of Lord Voldemort have been ignored. Left with no choice, Harry takes matters into his own hands, training a small group of motivated students to defend themselves against the Dark Arts.","genre_ids":[12,14],"popularity":14.5713,"vote_count":20531,"poster_path":"/5aOyriWkPec0zUDxmHFP9qMmBaj.jpg","release_date":"2007-07-08","vote_average":7.672,"backdrop_path":"/pkxPkHOPJjOvzfQOclANEBT8OfK.jpg","original_title":"Harry Potter and the Order of the Phoenix","original_language":"en"},{"id":681,"adult":false,"title":"Diamonds Are Forever","video":false,"overview":"Diamonds are stolen only to be sold again in the international market. James Bond infiltrates a smuggling mission to find out who's guilty. The mission takes him to Las Vegas where Bond meets his archenemy Blofeld.","genre_ids":[28,53],"popularity":6.3489,"vote_count":2305,"poster_path":"/uajiHcFX5sOhYB2tBuWkmizbtuU.jpg","release_date":"1971-12-14","vote_average":6.404,"backdrop_path":"/pyTDtQCn5sG8gi2zkM5ZylSNmtJ.jpg","original_title":"Diamonds Are Forever","original_language":"en"},{"id":767,"adult":false,"title":"Harry Potter and the Half-Blood Prince","video":false,"overview":"As Lord Voldemort tightens his grip on both the Muggle and wizarding worlds, Hogwarts is no longer a safe haven. Harry suspects perils may even lie within the castle, but Dumbledore is more intent upon preparing him for the final battle fast approaching. Together they work to find the key to unlock Voldemorts defenses and to this end, Dumbledore recruits his old friend and colleague Horace Slughorn, whom he believes holds crucial information. Even as the decisive showdown looms, romance blossoms for Harry, Ron, Hermione and their classmates. Love is in the air, but danger lies ahead and Hogwarts may never be the same again.","genre_ids":[12,14],"popularity":13.7456,"vote_count":20501,"poster_path":"/z7uo9zmQdQwU5ZJHFpv2Upl30i1.jpg","release_date":"2009-07-15","vote_average":7.7,"backdrop_path":"/ze6Mx4QE5mQVXRYmG2flncqqle4.jpg","original_title":"Harry Potter and the Half-Blood Prince","original_language":"en"},{"id":2059,"adult":false,"title":"National Treasure","video":false,"overview":"Modern treasure hunters, led by archaeologist Ben Gates, search for a chest of riches rumored to have been stashed away by George Washington, Thomas Jefferson and Benjamin Franklin during the Revolutionary War. The chest's whereabouts may lie in secret clues embedded in the Constitution and the Declaration of Independence, and Gates is in a race to find the gold before his enemies do.","genre_ids":[12,28,53,9648],"popularity":5.7201,"vote_count":6727,"poster_path":"/pxL6E4GBOPUG6CdkO9cUQN5VMwI.jpg","release_date":"2004-11-19","vote_average":6.648,"backdrop_path":"/xXWT0je8dTFFNBq6P2CeTZkPUu2.jpg","original_title":"National Treasure","original_language":"en"},{"id":2062,"adult":false,"title":"Ratatouille","video":false,"overview":"Remy, a resident of Paris, possesses a palate far more refined than that of his fellow comrades. He dreams of becoming a chef, determined to create culinary masterpieces rather than scavenge for scraps. There’s just one small problem: Remy is a rat. When fate deposits him in the sewers beneath one of Paris’s most famous restaurants, he finds himself ideally placed to fulfill his dream. Forming an unusual alliance with a bumbling young kitchen worker, Remy begins a daring culinary double life. Together, they must outwit the scheming Head Chef Skinner, evade Remy’s disapproving colony, and impress renowned food critic Anton Ego, who strikes fear in the hearts of chefs all throughout France.","genre_ids":[16,35,10751,14],"popularity":13.5564,"vote_count":18193,"poster_path":"/t3vaWRPSf6WjDSamIkKDs1iQWna.jpg","release_date":"2007-06-28","vote_average":7.836,"backdrop_path":"/xgDj56UWyeWQcxQ44f5A3RTWuSs.jpg","original_title":"Ratatouille","original_language":"en"},{"id":949190,"adult":false,"title":"Berona","video":false,"overview":"","genre_ids":[35,10751,14],"popularity":1.9266,"vote_count":0,"poster_path":null,"release_date":"1967-01-01","vote_average":0,"backdrop_path":null,"original_title":"Berona","original_language":"sk"},{"id":1126128,"adult":false,"title":"13 Bombs","video":false,"overview":"An organization races against time to uncover the mastermind behind the placement of 13 bombs in Jakarta before the city falls into chaos.","genre_ids":[28,80,53],"popularity":0.6176,"vote_count":29,"poster_path":"/7vSfQ5nIjA5c2TB0EMTXCBRwvJG.jpg","release_date":"2023-12-28","vote_average":6.9,"backdrop_path":"/bB8av9j4BideDSLuDeAreqMJJil.jpg","original_title":"13 Bom di Jakarta","original_language":"id"},{"id":953,"adult":false,"title":"Madagascar","video":false,"overview":"Four animal friends get a taste of the wild life when they break out of captivity at the Central Park Zoo and wash ashore on the island of Madagascar.","genre_ids":[10751,16,12,35],"popularity":8.9954,"vote_count":11528,"poster_path":"/zMpJY5CJKUufG9OTw0In4eAFqPX.jpg","release_date":"2005-05-25","vote_average":6.921,"backdrop_path":"/tPaurpIUskVji5vwV0dhy9pq4Vs.jpg","original_title":"Madagascar","original_language":"en"},{"id":2120,"adult":false,"title":"Cedric","video":false,"overview":"Death as a global service provider? Unthinkable! So far Death has thought that too. But then his nephew Cedric had the crazy idea of founding the company AFTER LIFE while his uncle was away. This company takes over the craft of death with the latest technology and markets it worldwide.","genre_ids":[16,10751],"popularity":0.1481,"vote_count":0,"poster_path":"/v158R46vHrjpKQqP1bwVni2RGxJ.jpg","release_date":"2006-01-01","vote_average":0,"backdrop_path":"/m1CSCeQtLN5bHrclX8JtADzXBlH.jpg","original_title":"Cedric","original_language":"de"},{"id":808,"adult":false,"title":"Shrek","video":false,"overview":"It ain't easy bein' green -- especially if you're a likable (albeit smelly) ogre named Shrek. On a mission to retrieve a gorgeous princess from the clutches of a fire-breathing dragon, Shrek teams up with an unlikely compatriot -- a wisecracking donkey.","genre_ids":[16,35,14,12,10751],"popularity":21.571,"vote_count":18414,"poster_path":"/iB64vpL3dIObOtMZgX3RqdVdQDc.jpg","release_date":"2001-05-18","vote_average":7.757,"backdrop_path":"/sRvXNDItGlWCqtO3j6wks52FmbD.jpg","original_title":"Shrek","original_language":"en"},{"id":812,"adult":false,"title":"Aladdin","video":false,"overview":"In the boorish city of Agrabah, kind-hearted street urchin Aladdin and Princess Jasmine fall in love, although she can only marry a prince. He and power-hungry Grand Vizier Jafar vie for a magic lamp that can fulfill their wishes.","genre_ids":[16,10751,12,14,10749],"popularity":11.0202,"vote_count":11847,"poster_path":"/eLFfl7vS8dkeG1hKp5mwbm37V83.jpg","release_date":"1992-11-25","vote_average":7.654,"backdrop_path":"/nenJjvfe2Eq8uBMXFJnWj5mw4bi.jpg","original_title":"Aladdin","original_language":"en"},{"id":847,"adult":false,"title":"Willow","video":false,"overview":"The evil Queen Bavmorda hunts the newborn princess Elora Danan, a child prophesied to bring about her downfall. When the royal infant is found by Willow, a timid farmer and aspiring sorcerer, he's entrusted with delivering her from evil.","genre_ids":[14,12,28],"popularity":3.4489,"vote_count":2106,"poster_path":"/pAIRGMIdN7ZdZhflazdV2ezuJ9f.jpg","release_date":"1988-05-20","vote_average":7.005,"backdrop_path":"/3sF6AibdbTTkswfSRxXEGCt5w6s.jpg","original_title":"Willow","original_language":"en"}],"external_ids":{"imdb_id":"tt34956443","twitter_id":null,"facebook_id":null,"wikidata_id":"Q131937861","instagram_id":null,"rotten_tomatoes_id":"m/ne_zha_ii"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":103322,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast