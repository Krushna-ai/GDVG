O4uW6eqbv5Juoohz91UxGQXz0O.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2000,"height":1125,"file_path":"/vBkvjpM1Xd1Wmd0j3S74emtAT6V.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T06:12:04.694+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"Saara and Robert are living a love that is free from traditional conventions and role models. They set off to an extensive summer holiday on a lonely island in the Finnish archipelago where the tension between them escalates and becomes a fight for survival."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Villi leikki","runtime":0,"tagline":"","homepage":"","overview":"Saara ja Robert elävät parisuhteessa, joka on heille harkittu mutta kiehtova valtapeli.  He ovat kumpikin akateemisesti kunnianhimoisia omilla aloillaan. Saaran ura on valtavassa nosteessa. Hän on mukana tutkimusryhmässä ja saamassa nimensä merkittävään lääketieteelliseen julkaisuun ja sitä myötä ehkä oman tutkimusryhmänsä. Saksasta Suomeen Saaran perässä muuttaneen Robertin on liki mahdoton saada apurahaa oman tohtorinväitöskirjan tekemiseen. Niinpä lähes ummikkona Robert asuu rahattomana Saaran luona. Myös hänen sosiaaliset kontaktinsa ovat täysin Saaran ystäväpiirin varassa.\r Saaran aloitteesta pariskunta harrastaa roolileikkejä niin yksityisesti kuin hieman julkisemminkin. Robert ei aina hirveästi haluaisi näitä leikkejä leikkiä, mutta riippuvuus Saarasta saa hänet heittäytymään mukaan niihin parhaan kykyjensä mukaan. Kun Saaran kesäloma alkaa, he päättävät aloittaa villin leikin, jonka Saara päättää viedä äärirajoille muuttaen sen lopulta henkiinjäämistaisteluksi."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":"Saara und Robert sind glücklich verliebt. Erst kürzlich ist Robert von Berlin nach Helsinki gezogen, um ihrer Beziehung eine echte Perspektive zu geben. Ihr Alltag ist geprägt vom Spiel mit Geschlechterrollenklischees und Machtverhältnissen, doch hinter der unkonventionellen Fassade kämpfen beide mit Ängsten und Unsicherheiten. Voller Vorfreude auf eine Auszeit brechen sie zu einem ausgedehnten Sommerurlaub auf einer einsamen Insel im finnischen Archipel auf. Von der rauen Natur aufgewühlt, fällt das Paar in archaische Muster zurück, die es verzweifelt zu überwinden versucht."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"파워 오브 러브","runtime":0,"tagline":"거침없는 육체의 탐닉을 엿본다!","homepage":"","overview":"끝없는 욕망의 탐구! 연상연하 커플이 미친 격정에 빠져든다. 그들의 대화는 정사로만 이루어진다. 깊어진 관계만큼 더 서로를 탐하지만, 사랑은 구속의 욕망을 불러오고, 마침내 예측불허의 사건으로 이어지는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Jogos de Sedução","runtime":0,"tagline":"","homepage":"","overview":"Saara e Robert nos levam na intensa jornada emocional de um casal que tenta redefinir o relacionamento além do papel usual dos chlichés, imerso no grande cenário da natureza rude da Finlândia."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"}],"reviews_tmdb":[],"recommendations":[{"id":718314,"adult":false,"title":"FILM","video":false,"overview":"A boy walks through an abandoned building and films the interior. Suddenly his camera disappears.","genre_ids":[],"media_type":"movie","popularity":0.1785,"vote_count":11,"poster_path":"/pMjTLiyPKs0kPlG8S3LS2zySqrp.jpg","release_date":"2020-04-18","vote_average":7.2,"backdrop_path":"/iiwWSq6pQmaEnIX5FYGg2uWe5qH.jpg","original_title":"FILM","original_language":"en"},{"id":638566,"adult":false,"title":"Naruto to Boruto: The Live 2019","video":false,"overview":"“NARUTO to BORUTO THE LIVE 2019”, a special event for the 20th anniversary of the first publication of “NARUTO” series in Weekly Shonen Jump!! Featuring live performances by artists performing the theme songs of both “NARUTO” and “BORUTO: NARUTO NEXT GENERATIONS”, anime cast members reading original story episodes, and more.","genre_ids":[16],"media_type":"movie","popularity":0.3303,"vote_count":81,"poster_path":"/8OkxtHotJnegiBbWQSz8fD60NEc.jpg","release_date":"2019-10-05","vote_average":7.444,"backdrop_path":"/kfLlBmKDLAdTZSpj8bzFEnnVh1c.jpg","original_title":"Naruto to Boruto: The Live 2019","original_language":"ja"},{"id":531166,"adult":false,"title":"A Maine Movie","video":false,"overview":"A group of mismatched friends spend a weekend together in Maine.","genre_ids":[35],"media_type":"movie","popularity":0.1849,"vote_count":2,"poster_path":"/4KYjbDH1SeLB4c51bhAxyRBv9n.jpg","release_date":"2018-06-11","vote_average":7,"backdrop_path":null,"original_title":"A Maine Movie","original_language":"en"},{"id":699254,"adult":false,"title":"Naruto OVA 10: Uchiha Madara vs Senju Hashirama","video":false,"overview":"Naruto Shippūden Ultimate Ninja Storm Generations OVA Madara vs Hashirama is the tenth Naruto OVA. It is distributed as part of Naruto Shippūden: Ultimate Ninja Storm Generations.","genre_ids":[16],"media_type":"movie","popularity":0.7612,"vote_count":55,"poster_path":"/3AwkYyiwl02CMELo2oj88x2bEtu.jpg","release_date":"2012-02-23","vote_average":6.5,"backdrop_path":"/8VI7ItY7u3WL5i1PQlTdUprZMXT.jpg","original_title":"NARUTO−ナルト− 疾風伝 OVA マダラ vs 柱間","original_language":"ja"},{"id":689500,"adult":false,"title":"Six Hours: Surviving Typhoon Yolanda","video":false,"overview":"In the middle of a broadcast about Typhoon Yolanda's initial impact, reporter Jiggy Manicad was faced with the reality that he no longer had communication with his station. They were, for all intents and purposes, stranded in Tacloban. With little option, and his crew started the six hour walk to Alto, where the closest broadcast antenna was to be found. Letting the world know what was happening to was a priority, but they were driven by the need to let their families and friends know they were all still alive. Along the way, they encountered residents and victims of the massive typhoon, and with each step it became increasingly clear just how devastating this storm was. This was a storm that was going to change lives.","genre_ids":[99,18,36],"media_type":"movie","popularity":0.4105,"vote_count":1,"poster_path":"/eeSbsZDvYHugxL08YRrWNF1FpwV.jpg","release_date":"2014-12-23","vote_average":8.5,"backdrop_path":"/MmJlXi6qI0xQ1wGLwED2rB28qt.jpg","original_title":"Six Hours: Surviving Typhoon Yolanda","original_language":"en"},{"id":1058261,"adult":false,"title":"Box","video":false,"overview":"8mm film by Swiss artist Roman Signer.","genre_ids":[],"media_type":"movie","popularity":0.1557,"vote_count":30,"poster_path":"/djVHmYwGekG3RCLKWKXLnoeQt8U.jpg","release_date":"1975-01-01","vote_average":4.5,"backdrop_path":null,"original_title":"Box","original_language":"en"},{"id":868848,"adult":false,"title":"13","video":false,"overview":"The film is a continuous time-lapse with multiple exposures of the sunset from the same angle and position on 16mm film. The shoot was done in a span of 5 years. The title 13 is because the time-lapse has a 13-second interval per frame.","genre_ids":[],"media_type":"movie","popularity":0.2157,"vote_count":2,"poster_path":null,"release_date":"2021-12-04","vote_average":10,"backdrop_path":null,"original_title":"13","original_language":"ja"},{"id":855777,"adult":false,"title":"ŽŽŽ: Journal About Želimir Žilnik","video":false,"overview":"Road movie documentary through half a century of filmography by Želimir Žilnik. But also a journey through the history of Yugoslavia, a country that no longer exists. With the specific style of docudrama that he built over the years, Zilnik managed to stay engaged and brave, but above all free, by making low-budget films for decades. We follow the efforts of his team to finish the film \"Freedom or Comics\", which was seized by censorship 50 years ago, and which was recently accidentally found. The story of an uninterrupted struggle for disenfranchised social and minority groups who are constantly the main heroes of Žilnik's films.","genre_ids":[99],"media_type":"movie","popularity":0.0811,"vote_count":2,"poster_path":"/9IkC2D1EPUuhK1tjznyGEQXdasP.jpg","release_date":"2021-11-16","vote_average":8.5,"backdrop_path":null,"original_title":"ŽŽŽ: Žurnal o Želimiru Žilniku","original_language":"sr"},{"id":614840,"adult":false,"title":"Box","video":false,"overview":"A group of friends try to defeat an evil king, and meet some quirky characters along the way.","genre_ids":[],"media_type":"movie","popularity":0.1575,"vote_count":44,"poster_path":null,"release_date":"","vote_average":5,"backdrop_path":null,"original_title":"Box","original_language":"en"},{"id":1440684,"adult":false,"title":"Tu Quoque","video":false,"overview":"Maximus's life has officially come to a standstill, on the brink of a precipice. However, he is magically transported to ancient Rome. There, using his connections, Maximus saves Julius Caesar's life, foiling the assassination attempt that would have killed him and becoming his most trusted advisor.","genre_ids":[35,36],"media_type":"movie","popularity":0.2107,"vote_count":10,"poster_path":"/kqQSNsWoQqg4WkmBzmv3NtbDOgk.jpg","release_date":"2025-04-03","vote_average":5.9,"backdrop_path":"/igAL3bgdpQeaw51eHIwmtFQ2Vzi.jpg","original_title":"Tu Quoque","original_language":"it"},{"id":336108,"adult":false,"title":"The Decline","video":false,"overview":"A weak before her lady-killer lover, a blond diva breaks up with the arrogant libertine to be with a kind friend. His ego demands appeasement, but the lethal revolver in her hand thirsts for retribution. Who is to blame for her downfall?","genre_ids":[18],"media_type":"movie","popularity":0.3543,"vote_count":11,"poster_path":"/pq9wh4SzA2qJyW2q4w3cYWdnkmx.jpg","release_date":"1961-12-02","vote_average":5.6,"backdrop_path":"/eSU1MRZ9a3jBq96qpJb681kU5ua.jpg","original_title":"Ο Κατήφορος","original_language":"el"},{"id":405029,"adult":false,"title":"3D Saamri","video":false,"overview":"In a small town a wealthy aged male named Dharmesh Saxena, known for his worship of Devi Maa Kaali, and magic, is called \"Saamri\". Dharmesh knows that his end is near, he summons his lawyer and wills his entire estate to his niece, Anju Trivedi. But when Mama Taklifchand, Dharmesh's step-brother, finds this out, he, together with a gorgeous young woman, Maria, a hotel owner, Khanna, professor Chatterjee, and others, kill Dharmesh, throw his body in the river, and when the body is found, inform the police and the public that Dharmesh killed himself. With the case closed, Taklifchand & the others must find ways and means to kill Anju and keep the wealth and estate for themselves. Before they could carry out their plan - one by one they start dying horrible deaths. Looks like Saamri has arisen from the grave to hunt down his killers, and there is no one who can even dare to even think of stopping him.","genre_ids":[10402,9648,27,14,10749],"media_type":"movie","popularity":0.3814,"vote_count":1,"poster_path":"/h11Nl2Jn99NNNDdvGdXq7g5ZpL4.jpg","release_date":"1985-01-01","vote_average":5,"backdrop_path":null,"original_title":"थ्री डी सामरी","original_language":"hi"},{"id":918428,"adult":false,"title":"The Legend of the Galactic Heroes: Die Neue These Collision 2","video":false,"overview":"","genre_ids":[16],"media_type":"movie","popularity":0.6207,"vote_count":5,"poster_path":"/lugVjhv7axiZxnSlrfXyogVf0Hl.jpg","release_date":"2022-04-01","vote_average":9,"backdrop_path":"/9npMbBg3W4l6NT0qjqBGALw8KT5.jpg","original_title":"銀河英雄伝説 Die Neue These 激突 第二章","original_language":"ja"},{"id":383104,"adult":false,"title":"Stangenfieber","video":false,"overview":"","genre_ids":[],"media_type":"movie","popularity":0.6865,"vote_count":1,"poster_path":null,"release_date":"1987-06-09","vote_average":8,"backdrop_path":null,"original_title":"Stangenfieber","original_language":"de"},{"id":1150865,"adult":false,"title":"Soc filla de ma mare","video":false,"overview":"","genre_ids":[99,10751],"media_type":"movie","popularity":0.0143,"vote_count":1,"poster_path":"/1G6JGje7QpAjiL6xL3s48vdJYtd.jpg","release_date":"2023-06-25","vote_average":9,"backdrop_path":"/wnkGO9p93c4ZLcNVrTnOkfcUTJI.jpg","original_title":"Soc filla de ma mare","original_language":"es"},{"id":69572,"adult":false,"title":"Mumbai Xpress","video":false,"overview":"A young man's journey in Mumbai as a kidnapper.","genre_ids":[28,35],"media_type":"movie","popularity":0.3784,"vote_count":13,"poster_path":"/iRoC6isEOUBr8VEeSrKG2ZtRkih.jpg","release_date":"2005-04-15","vote_average":5.8,"backdrop_path":null,"original_title":"Mumbai Xpress","original_language":"ta"},{"id":620004,"adult":false,"title":"Anime","video":false,"overview":"Two hardy orphans survive upon the remains of a humanity that has left them behind.","genre_ids":[18],"media_type":"movie","popularity":0.8468,"vote_count":22,"poster_path":"/7qig1q8F6ejuPdSjMR8TBa0rDOz.jpg","release_date":"2017-03-16","vote_average":7.1,"backdrop_path":"/f6SlOYpzsZjDGtMUNEQ7T50Qo7Y.jpg","original_title":"Anime","original_language":"fr"},{"id":315829,"adult":false,"title":"Gentle Annie","video":false,"overview":"The Goss family live on a farm they call the dust bowl where the wind blows during the day and the coyotes howl at night. When the train is robbed, everyone thinks that Cotton and Violet were the ones that did the job, but no one has any proof. US Marshal Lloyd Richland comes into town in disguise to find the truth and he finds that the sheriff is corrupt and that the Goss family is gosh darn nice. They take in Richland and a stranded woman named Mary without any questions. Cotton believes that Sheriff Tatum shot their pa in the back, and the sheriff is now trying to plug the boys. Richland is looking for the train robbers, and at the same time is keeping an eye on Tatum and the lovely young Mary.","genre_ids":[37,10749],"media_type":"movie","popularity":0.2978,"vote_count":8,"poster_path":"/3QIfgyVpqZBX2qC8zqJYsf9D0I6.jpg","release_date":"1944-12-05","vote_average":5.2,"backdrop_path":"/hPHwUbVBBWKrlD8FV0yTejIQDaC.jpg","original_title":"Gentle Annie","original_language":"en"},{"id":740025,"adult":false,"title":"Dropout - Die Doku mit Eric Stehfest","video":false,"overview":"","genre_ids":[],"media_type":"movie","popularity":0.0168,"vote_count":1,"poster_path":"/lSdpaA699ScyImLc2W3qOzSQUGX.jpg","release_date":"","vote_average":8,"backdrop_path":"/95KyyimYUOczHf6IDjzLPWcdIFU.jpg","original_title":"Dropout - Die Doku mit Eric Stehfest","original_language":"de"}],"similar_content":[],"external_ids":{"imdb_id":"tt11086338","twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148388,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"DE","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":["Sexualized Violence","Sexuality"],"release_date":"2024-10-03T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"FI","release_dates":[{"note":"Helsinki International Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2023-09-19T00:00:00.000Z","certification":""},{"note":"","type":3,"iso_639_1":"","descriptors":["sexual content","contains violence"],"release_date":"2023-10-20T00:00:00.000Z","certification":"K-16"}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikidata_metadata":{},"mood_tags":null,"trope_tags":null,"vibe_description":null,"ai_en