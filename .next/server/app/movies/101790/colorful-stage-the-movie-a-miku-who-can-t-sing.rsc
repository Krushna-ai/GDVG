5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"COLORFUL STAGE! The Movie: A Miku Who Can't Sing\",\"description\":\"Ichika is a high school musician who can enter a mysterious place called “SEKAI,” where she and her friends express their innermost emotions through music alongside Hatsune Miku. One day after giving a live performance, Ichika meets a new Miku that she has never seen before. No matter how hard this new Miku tries to sing, she struggles connecting with the hearts of her listeners. Miku must rely on the help of others to find a way to sing again.\",\"image\":\"https://image.tmdb.org/t/p/w500/uiQ6wj8TPYHueuIJRsNlPruzogT.jpg\",\"datePublished\":\"2025-01-17\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"musical film\",\"Animation\",\"Music\",\"Drama\",\"Science Fiction\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.6,\"bestRating\":10,\"ratingCount\":35}}"}}],["$","$L10",null,{"initialDrama":{"id":"adc2baca-d194-428b-a80f-28558951885f","tmdb_id":1322752,"imdb_id":"tt33050528","content_type":"movie","title":"COLORFUL STAGE! The Movie: A Miku Who Can't Sing","original_title":"劇場版プロジェクトセカイ 壊れたセカイと歌えないミク","overview":"Ichika is a high school musician who can enter a mysterious place called “SEKAI,” where she and her friends express their innermost emotions through music alongside Hatsune Miku. One day after giving a live performance, Ichika meets a new Miku that she has never seen before. No matter how hard this new Miku tries to sing, she struggles connecting with the hearts of her listeners. Miku must rely on the help of others to find a way to sing again.","poster_path":"/uiQ6wj8TPYHueuIJRsNlPruzogT.jpg","backdrop_path":"/kLpIAD9WWku0VhGNWJ7bjUilPjK.jpg","release_date":"2025-01-17","first_air_date":null,"status":"published","original_language":"ja","origin_country":["JP"],"genres":[{