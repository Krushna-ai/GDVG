9:{"metadata":[["$","title","0",{"children":"COLORFUL STAGE! The Movie: A Miku Who Can't Sing | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Ichika is a high school musician who can enter a mysterious place called “SEKAI,” where she and her friends express their innermost emotions through music alongside Hatsune Miku. One day after giving a live performance, Ichika meets a new Miku that she has never seen before. No matter how hard this new Miku tries to sing, she struggles connecting with the hearts of her listeners. Miku must rely on the help of others to find a way to sing again."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/101790/colorful-stage-the-movie-a-miku-who-can-t-sing"}],["$","meta","5",{"property":"og:title","content":"COLORFUL STAGE! The Movie: A Miku Who Can't Sing"}],["$","meta","6",{"property":"og:description","content":"Ichika is a high school musician who can enter a mysterious place called “SEKAI,” where she and her friends express their innermost emotions through music alongside Hatsune Miku. One day after giving a live performance, Ichika meets a new Miku that she has never seen before. No matter how hard this new Miku tries to sing, she struggles connecting with the hearts of her listeners. Miku must rely on the help of others to find a way to sing again."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/101790/colorful-stage-the-movie-a-miku-who-can-t-sing"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/uiQ6wj8TPYHueuIJRsNlPruzogT.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"COLOR