_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/b0nmXbLJBVv6L72VUdZKILjQP83.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/cA4LH5mM3QWrvxdiBsr1sw1HWL1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/eJDCCevx5dE1LZ42G73v7JLOaWl.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T05:56:43.189+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":93,"tagline":"","homepage":"http://www.samuelgoldwynfilms.com/oscar-shaw/","overview":"After retiring from the police force, a relentless detective haunted by the tragic loss of his closest friend sets out on a perilous quest for vengeance, seeking redemption and fighting to restore justice to the streets he once swore to protect."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Après avoir pris sa retraite de la police, un détective implacable hanté par la perte tragique de son ami le plus proche se lance dans une périlleuse quête de vengeance, cherchant la rédemption et luttant pour rendre justice aux rues qu'il avait autrefois juré de protéger."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Po przejściu na emeryturę z policji, nieustępliwy detektyw, prześladowany przez tragiczną stratę najbliższego przyjaciela, wyrusza na niebezpieczną wyprawę w poszukiwaniu zemsty, odkupienia win i walki o przywrócenie sprawiedliwości na ulicach, które kiedyś przysięgał chronić."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Na zijn pensionering bij de politie maakt een vastberaden rechercheur er zijn persoonlijke missie van om de dood van zijn beste vriend te wreken. Hij neemt de ontmoedigende taak op zich om recht te doen op straat. Iets wat hem tijdens zijn diensttijd niet is gelukt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"Оскар Шоу","runtime":0,"tagline":"","homepage":"","overview":"После ухода из полиции решительный детектив берет на себя личную миссию отомстить за смерть своего лучшего друга. Он берется за сложную задачу восстановления справедливости на улицах, чего ему не удалось достичь во время службы.."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"孤警追凶","runtime":0,"tagline":"","homepage":"","overview":"一名退休警察为他最好的朋友的死报仇，在警察生涯中未能实现正义后，他将正义掌握在自己手中。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Tras retirarse de la policía, un implacable detective atormentado por la trágica pérdida de su mejor amigo emprende una peligrosa búsqueda de venganza, buscando la redención y luchando también por devolver la justicia a las calles que una vez juró proteger."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Tras retirarse de la policía, un implacable detective atormentado por la trágica pérdida de su mejor amigo emprende una peligrosa búsqueda de venganza, buscando la redención y luchando también por devolver la justicia a las calles que una vez juró proteger."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Depois de se aposentar da polícia, um detetive decide vingar a morte de seu melhor amigo, fazendo justiça com as próprias mãos nas ruas, algo que ele não conseguiu durante seu serviço."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Un polițist pensionat caută să se răzbune pentru moartea celui mai bun prieten al său, luând lucrurile în propriile mâini după ce nu a reușit să o obțină în timpul carierei sale de polițist."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Polisten emekli olan bu kararlı dedektif, en yakın arkadaşının trajik kaybıyla sarsılmış bir halde, intikam peşinde tehlikeli bir yola çıkar. Hem kendini affettirmek hem de korumaya yemin ettiği sokaklarda adaleti yeniden tesis etmek için mücadele eder."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[],"external_ids":{"imdb_id":"tt27674706","twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148456,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"US","release_dates":[{"note":"","type":2,"iso_639_1":"","descriptors":[],"release_date":"2026-01-09T00:00:00.000Z","certification":"NR"},{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-01-09T00:00:00.000Z","certification":"NR"}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikidata_metadata":{},"mood_tags":null,"trope_tags":null,"vibe_description":null,"ai_enriched_at":null,"ai_enrichment_version":0}}]]
