8,"vote_average":0},{"width":1920,"height":1080,"file_path":"/tIK8Y8hKVyFevnzcHI3xFfDUXoV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/rEouC4x6IQ2cE7q71Nak95fXkKK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/A0xLp9t6sVulxDGesmXPNXxD1wC.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/cPtbG0H9DF7dI9dgERb9JPpAHW2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/cbeeWosRJ1B2VcHiddGrG59JNAG.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/zmcymHqInLqawzd0l6s6FC0zQwd.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/iyI3IGiNINl0bb2zqzzRJj638lA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/3Fslt9Q1R1PSoEHcWnDR4tsV10l.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/382NaW9M2jg14m5XNSWYkCQKHUZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2560,"height":1440,"file_path":"/AmipZsHMkhetnDpRNENfKM6plmK.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/aMEeYFfDBoL4jsA0CaBHXVPjsov.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/x9bY4OzjffTMG2RXIeg20ySZjn2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/g6RmABFoAiO4z9thL80drIjHF2a.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/tzPOlRpKN66veV5Hf6MOy9bH3Mg.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/gwVDBwYDoRfanknNd3b499aDrXp.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/3HAHmBVWXiTPIPYYi98zhdFlMiz.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/6Ok9UP7mVdWrHPtUJZjIgsY5Ajp.jpg","iso_639_1":"ca","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/3JkjAz82a0oydYzZnCDhCAhy0cY.jpg","iso_639_1":"da","iso_3166_1":"DK","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/aYuX3WzVxyNfmB9eEtLmsZFmdCu.jpg","iso_639_1":"da","iso_3166_1":"DK","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:41:12.208+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Asterix at the Olympic Games","runtime":116,"tagline":"","homepage":"http://www.asterixauxjeuxolympiques.com/index.php","overview":"Astérix and Obélix have to win the Olympic Games in order to help their friend Alafolix marry Princess Irina. Brutus uses every trick in the book to have his own team win the game, and get rid of his father Julius Caesar in the process."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Asterix bei den Olympischen Spielen","runtime":116,"tagline":"","homepage":"http://www.asterixauxjeuxolympiques.com/index.php","overview":"Die Abenteuer des blitzschnellen Asterix und seines zaubertrankgestärkten Gefährten Obelix führen diesmal ins ferne Griechenland. Dort wollen sie dem jungen und wagemutigen Gallier Alafolix helfen, die Olympischen Spiele und gleichzeitig das Herz der wunderschönen griechischen Prinzessin Irina zu gewinnen. Wäre da nur nicht der tückische Brutus, der alles daran setzt, die Olympiade zu beherrschen und außerdem seinen Vater Julius Caesar aus dem Weg zu räumen..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Asterix og de olympiske lege","runtime":113,"tagline":"","homepage":"","overview":"Den unge galler Romantix er dybt forelsket i prinsesse Irina, men Irina skal mod sin vilje giftes med Cæsar's søn Brutus. I forsøget på at redde sig ud af giftermålet udfordrer hun Brutus og Romantix. Den, der vinder De Olympiske Lege, får lov til at gifte sig med hende. Nu får Romantix for alvor brug for hjælp, men heldigvis springer Asterix og Obelix til med en hel masse trylledrik i bagagen."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":113,"tagline":"","homepage":"","overview":"Astérix et Obélix, dans de nouvelles aventures où ils devront remporter les Jeux olympiques, permettre au jeune Gaulois, Alafolix, d’épouser la Princesse Irina et lutter contre le terrible Brutus, prêt à tous les stratagèmes, pour lui aussi gagner les Jeux olympiques et se débarrasser de son père : Jules César."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Астерикс на Олимпийских играх","runtime":113,"tagline":"","homepage":"","overview":"Астерикс и Обеликс берутся помочь своему другу Полюбвиксу добиться руки его возлюбленной, прекрасной Ирины, дочери правителя Греции. В то же время, той же самой руки пытается добиться и сын великого Цезаря, Брут."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Asterix alle olimpiadi","runtime":116,"tagline":"","homepage":"","overview":"Il giovane gallo Alafolix è innamorato della principessa greca Irina che però è stata promessa in sposa al figlio di Cesare, Bruto. Decisa a non unirsi in matrimonio con un buzzurro e colpita nel profondo dalle romantiche lettere d'amore del gallo, Irina propone di sposare colui che vincerà le Olimpiadi. La missione di Asterix e Obelix sarà quella di portare Alafolix sul podio e smascherare lo sleale Bruto, che giocherà sporco pur di ottenere la vittoria e la mano della principessa."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Asteriks Olimpiyat Oyunları'nda","runtime":116,"tagline":"","homepage":"","overview":"Genç ve korkusuz Galyalı Mecnuniks, Yunan prensesi Irina’ya aşık olur. Asteriks ve Oburiks’in yardımıyla, olimpiyat oyunlarını kazanıp Irina ile evlenmek için Yunanistan’a giderler."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Asterix på olympiaden","runtime":0,"tagline":"","homepage":"","overview":"Asterix och Obelix deltar, i den här filmen, i OS för att hjälpa sin vän Alafolix, som med deras vinst kommer att tillåtas att gifta sig med prinsessan Irina. Som främste motståndare har de Brutus, som är ett starkt motstånd då han tar till alla medel för att vinna spelen för att kunna stjälpa sin egen far, Julius Caesar."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Asteriks na olimpiadzie","runtime":116,"tagline":"","homepage":"","overview":"Zbliżają się pierwsze w historii igrzyska olimpijskie, w których pozwolono wystartować Rzymianom. Galowie stwierdzili, że od podbicia ich kraju przez Juliusza Cezara oni też w jakiejś części są Rzymianami. Postanowili, więc także wystartować. Kiedy ta wiadomość dotarła do obozu Rzymian zaprzestali treningów. Wiedzą przecież od dawna, że z magicznym napojem Galów nikt nie ma szans. Niektórzy jednak wcale nie chcą tak szybko zrezygnować."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Asterix a Olympijské hry","runtime":118,"tagline":"Největší sportovní klání všech dob!","homepage":"","overview":"Asterix a Obelix jsou zpět! A tentokrát vás čeká příběh plný sportovního zápolení mezi Galy a jejich soupeři z celého světa. A při tom všem se odvážný mladý Gal Alafolix vášnivě zamiluje do řeské princezny Iriny. Spolu s Asterixem a Obelixem a za pomoci jejich čarovného elixíru se vydá do Řecka s cílem vyhrát nejen Olympijské hry, ale i srdce princezny Iriny. Střetává se tu však se zlomyslným Brutem, synem Césara, a jeho týmem, který je, zdá se, silným soupeřem. Jak je všeobecně známo, čarovné elixíry jsou na Olympijských hrách zakázané, ale Asterix už má plán, jak opět zvítězit..."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Astérix nos Jogos Olímpicos","runtime":116,"tagline":"","homepage":"","overview":"Astérix e Obélix embarcam numa nova e hilariante aventura onde terão que vencer os Jogos Olímpicos para que o jovem gaulês, Apaixonadix, possa casar com a Princesa Irina e derrotar o terrível Brutus que está, ele também, pronto a usar todos os estratagemas para ganhar os Jogos Olímpicos e livrar-se do seu pai: Júlio César."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Astérix en los Juegos Olímpicos","runtime":116,"tagline":"","homepage":"","overview":"En el pequeño pueblo de los irreductibles galos no sólo se persigue a los romanos y a los jabalíes, también se persigue el amor. Alafólix, joven guerrero intrépido y romántico, enamorado de la sublime princesa griega Irina, osa desafiar a Brutus, un soldado romano que también aspira a conquistarla. Ambos se enfrentarán en los Juegos Olímpicos por la mano de Irina. Astérix, Obélix y Alafólix, gracias a la poción mágica de Panorámix, van superando todas las pruebas con la intención de darle una buena lección a César."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Asterix en de Olympische Spelen","runtime":116,"tagline":"","homepage":"","overview":"De beeldschone prinses Irina heeft haar hart verloren aan de Galliër Hartstochtelix, maar Caesars zoon Brutus heeft zijn oog op haar laten vallen. Prinses Irina rest niets anders dan te verklaren dat ze zal trouwen met de winnaar van de Olympische Spelen. Asterix en Obelix worden uitgekozen om als afgevaardigden van de Galliërs deel te nemen aan de Spelen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Asterix a Olympijské hry","runtime":115,"tagline":"","homepage":"http://www.asterixauxjeuxolympiques.com/index.php","overview":"Príbeh plný športového napätia medzi Galmi a ich súpermi z celého sveta. A pri tom všetkom sa odvážny mladý Gal Alafolix vášnivo zamiluje do gréckej princeznej Iriny. Spolu s Asterixom a Obelixom a pomocou ich čarovného elixíru sa vydáva do Grécka s cieľom vyhrať nielen Olympijské hry, ale aj srdce princeznej Iriny. Stretáva sa tu však so zlomyseľným Brutom, synom Cézara, a jeho tímom, ktorý je, zdá sa, silným súperom. Ako je všeobecne známe, čarovné elixíry sú na Olympijských hrách zakázané, ale Asterix už má plán, ako opäť zvíťaziť."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Asterix az Olimpián","runtime":0,"tagline":"","homepage":"","overview":"Asterix és jó barátja, Obelix az ókori olimpiai játékokra mennek, hogy megküzdjenek a rómaiakkal. Mindezt azért teszik, mert a gall Alafolix herceg szerelmes lesz a gyönyörű görög hercegnőbe, és elkél neki a segítség, hogy felkészülhessen az Olimpiai megmérettetésekre. Csakhogy ugyanebbe a hercegnőbe szerelmes Cézár fia, Brutus is. Kettőjük között olyan versengés alakul ki, amely nem feltétlen a fair-play elemeit hordozza magában. Vajon ki nyeri el végül a hercegnő kezét?"},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Астерикс на Олимпийските игри","runtime":116,"tagline":"","homepage":"","overview":"Астерикс, Обеликс и техните приятели се включват във великите Олимпийски игри в Атина. Те са решени да вкусят победата, но срещат голяма съпротива от страна на гърците и римляните. Дали Астерикс ще заслужи златен медал? Или ще страда от унижението на загубата?"},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Asterix og de olympiske leker","runtime":0,"tagline":"","homepage":"","overview":"Galleren Heltpåtuppix er stormforelsket i den greske prinsessen Irina. For å erobre hjertet hennes, må han vinne de olympiske leker. Da trenger han kløkten til Asterix og styrken til Obelix. Men de tapre gallerne har ikke regnet med Brutus. Han tar i bruk alle midler for å vinne lekene og Irina."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Ο Αστερίξ στους Ολυμπιακούς Αγώνες","runtime":0,"tagline":"","homepage":"","overview":"Ο Αστερίξ, ο Οβελίξ, ο Ιντεφίξ, όλο το γαλατικό χωριό αλλά και πολλοί άλλοι θα μετακομίσουν στην αρχαία Ολυμπία, προκειμένου να συμμετάσχουν στο μεγαλύτερο αθλητικό γεγονός όλων των εποχών, τους Ολυμπιακούς Αγώνες. Εκεί, θα βρεθούν αντιμέτωποι με τα πανούργα σχέδια του γιου του Καίσαρα, Βρούτου, ο οποίος είναι αποφασισμένος να κερδίσει τη διοργάνωση...Το έπαθλο άλλωστε των αγώνων, είναι η καρδιά της πανέμορφης πριγκίπισσας της Ελλάδας Ειρήνης…"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"אסטריקס באולימפיאדה","runtime":0,"tagline":"","homepage":"","overview":"אסטריקס וחברו הטוב אובליקס עושים את דרכם לרומא כדי לעזור לחברם גאול אלפואה לזכות במשחקים האולימפיים ובכך גם לזכות בליבה של הנסיכה אירינה. הם מוצאים את עצמם מתחרים בברוטוס, בנו של יוליוס קיסר, המתכנן בקדחתנות את נפילתו של אביו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Asterix la Jocurile Olimpice","runtime":116,"tagline":"","homepage":"","overview":"Asterix (Clovis Cornillac), Obelix (Gerard Depardieu) și credinciosul Dogmatix călătoresc în Grecia pentru a veni în ajutorul prietenului lor, Alafolix, bolnav de chinurile dragostei. În paralel, galii aud că romanii plănuiesc să-l trimită pe legionarul Gluteus Maximus să reprezinte Roma la Jocurile Olimpice, și își trimit proprii campioni, Asterix și Obelix, la marele eveniment sportiv. Oficialii greci au interzis Poțiunea Magică pe motiv că este un stimulant artificial, astfel că galii sunt acum pe cont propriu. Alafolix (Stephane Rousseau) este îndrăgostit lulea de prințesa Irina (Vanessa Hessler), la mâna căreia râvnește și Brutus (Benoit Poelvoorde). Pentru că în dragoste și război este permis orice, Brutus intenționează să joace murdar, astfel că i-a angajat pe Doctormabus, \"magicianul mistic\", și pe Scapus, \"inventatorul nebun\", pentru a crește performanțele echipei romanilor la Jocurile Olimpice. Miza este mare: învingătorul câștigă și mâna prințesei Irina!"},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"아스테릭스 : 미션 올림픽게임","runtime":0,"tagline":"그리스의 사랑스러운 이리나 공주와 결혼하려면?  올림픽 게임에서 우승할 것! 참~쉽죠잉~?","homepage":"","overview":"어딘가 2% 부족하지만 훈남 로맨티스트인 ‘러브식스’는 그리스의 ‘이리나’ 공주와 사랑에 빠진다. 하지만 그들의 달콤한 미래를 방해하는 이가 등장했으니, 바로 로마제국의 황제 ‘시저’의 양아들이며 만년 2인자인 찌질이 ‘브루투스’! 거대한 로마 제국의 힘 앞에 그리스의 왕은 어쩔 수 없이 브루투스와 이리나를 정략 결혼시키겠다고 약속해버린 것! 이리나 공주는 그들 앞에 닥친 위기에서 빠져나가기 위해 올림픽 게임의 우승자와 결혼하겠다고 선언한다!  최강로마 브루투스 군단 VS 무한마법 러브식스 골족  브루투스는 막강한 부와 권력으로 심판 매수는 물론 마법사들까지 동원해 마법의 물약으로 강력한 힘과 스피드까지 겸비한 최강의 올림픽 선수단을 구성한다. 그에 비해 가진 거라고는 건강한 신체뿐인 ‘러브식스’는 신비한 힘의 만능해결사 ‘아스테릭스’와 가공할 파워의 천하무적 ‘오벨릭스’에게 도움을 청한다. 이로써 막강 찌질이 브루투스에 맞선 훈남 러브식스의 놀랍고 흥미진진한 상상초월 올림픽 게임이 시작되는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Asterix nos Jogos Olímpicos","runtime":116,"tagline":"","homepage":"","overview":"Astérix e Obélix precisam vencer os Jogos Olímpicos para ajudar seu amigo Alafolix a se casar com a Princesa Irina. Brutus usa todos os truques possíveis para fazer com que seu próprio time vença o jogo e, no processo, se livrar de seu pai, Júlio César."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Astèrix als Jocs Olímpics","runtime":0,"tagline":"","homepage":"","overview":"Al petit poble dels irreductibles gals no només es persegueix als romans i als senglars, també es persegueix l'amor. Alafólix, jove guerrer intrèpid i romàntic, enamorat de la sublim princesa grega Irina, gosa desafiar a Brutus, un soldat romà que també aspira a conquistar-la. Tots dos s'enfrontaran en els Jocs Olímpics per la mà d'Irina. Astérix, Obélix i Alafólix, gràcies a la poció màgica de Panorámix, van superant totes les proves amb la intenció de donar-li una bona lliçó a César."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"高卢英雄大战凯撒王子","runtime":116,"tagline":"","homepage":"","overview":"高卢人沃夫希克斯爱上了美丽的埃及公主艾瑞娜，并通过鸿雁传书的方式打动了她。终于有一天，正当他千里迢迢来向公主表白时，却发现罗马执政官凯撒（阿兰•德龙 Alain Delon 饰）的儿子布鲁特斯也来提亲。双方产生争执。公主倾向于高卢人，但是国王慑于凯撒的淫威，决定以奥运会冠军决定公主的婚事。高卢人在奥贝里克斯（杰拉尔•德帕迪约 Gérard Depardieu 饰）等人的帮助下为爱而战，然而布鲁特斯也在处心积虑地想尽一切歪门邪道，骗取比赛胜利，一切的结果都将在奥运会比赛的最后时刻揭开……  　　本片是导演弗雷德里克•佛瑞斯提亚继《美丽新世界》、《埃及公主的任务》之后推出的又一部作品，世界足球先生齐达内、一级方程式车王舒马赫和NBA球星帕克的加盟令本片星光熠熠。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Astérix aux jeux olympiques","runtime":112,"tagline":"Il va y avoir du sport !","homepage":"","overview":"Astérix et Obélix, dans de nouvelles aventures où ils devront remporter les Jeux Olympiques, permettre au jeune Gaulois, Alafolix, d’épouser la Princesse Irina et lutter contre le terrible Brutus, prêt à tous les stratagèmes, pour lui aussi gagner les Jeux Olympiques et se débarrasser de son père : Jules César."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Астерікс на Олімпійських іграх","runtime":117,"tagline":"","homepage":"","overview":"Практично вже все знаходиться під владою Римської Імперії, крім маленького галльського села, яке ніяк не хоче підкорюватися римлянам. А весь секрет їх могутності це чарівник, та його зілля, що робить галлів неймовірно сильними. В цей же час син Юлія Цезаря Брут хоче одружитися з грецькою принцесою Іриною, в яку також закоханий галл Коханікс. Щоб дати галлу шанс, Ірина оголошує, що вийде заміж за переможця Олімпійських ігор. Дізнавшись про це, Астерікс і Обелікс вирішують допомогти другу завоювати серце принцеси і виграти Ігри..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Asterix olympialaisissa","runtime":0,"tagline":"","homepage":"","overview":""},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Asteriksas olimpinėse žaidynėse","runtime":0,"tagline":"","homepage":"","overview":"Šįkart Asteriksas ir Obeliksas dalyvaus Olimpinėse žaidynėse ir susirungs su romėnų stipruoliu gladiatoriumi Maksimu. Olimpinėje arenoje taip pat galinėsis ir graikai, ir egiptiečiai. Žaidynių teisėjai turės būti budrūs ir stebėti, kad galai nepiknaudžiautų magiškuoju gėrimu. Todėl Asteriksas ir Obeliksas, norėdami laimėti auksą, privalės pademonstruotų savo išradingumą."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Asterix na olimpijskih igrah","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Asterix Olinpiar Jokoetan","runtime":0,"tagline":"","homepage":"","overview":"Lunatix gerlari gazte ausart eta erromantikoak Irina printzesa greziarra maite du. Horregatik, Brutusi erronka botako dio eta, Irinarekin ezkontzeko asmotan, bere aurka lehiatuko da Olinpiar Jokoetan. Asterixek, Obelixek eta Lunatixek probak gainditu beharko dituzte Panoramixen edabe magikoak lagunduta, eta Cesarri irakatsia eman."},"name":"euskera","iso_639_1":"eu","iso_3166_1":"ES","english_name":"Basque"},{"data":{"title":"เปิดเกมส์โอลิมปิกสะท้านโลก","runtime":0,"tagline":"","homepage":"","overview":"เมื่อ 50 ปีก่อนคริสตกาล พระราชาเมืองโกลอยู่ในความปกครองของโรมัน อยากให้ อิลินา (วาเนสซา เฮสส์เลอร์) ธิดาของตนมีคู่ครอง อิลินา ชอบพอกับ อลาโฟลิกซ์ (สเตฟาน รูสโซ) แต่หนึ่งในชายหนุ่มที่เดินทางมาให้เจ้าหญิงดูตัวอย่าง บรูตัส (เบนวา โพเอลวัวด์) ไม่ยอมแพ้ง่ายๆ พระราชาจึงจัดการแข่งขันกีฬาโอลิมปิกขึ้นมา เพื่อใช้เป็นเครื่องตัดสิน บรูตัส ทำทุกวิถีทางเพื่อให้ตัวเองชนะ พร้อมทั้งวางแผนสังหาร จูเลียส ซีซาร์ (อแลง เดอลอง) บิดาของตัวเองไปในตัว ส่วน แอสเตริกซ์ (โคลวิส คอร์นิลแลก) และ โอเบลิกซ์ (เจราร์ด เดอพาร์ดิว) ก็พยายามอย่างยิ่งที่จะชนะเช่นกัน เพื่อช่วยให้เพื่อนของพวกเขา อลาโฟลิกซ์ ได้แต่งงานกับ อิลินา สมดังหวัง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Asterix na Olimpijskim igrama","runtime":0,"tagline":"Kad se Rimljani i Gali sretnu na Olimpijskim igrama, pravila ne vrijede! Pripremite se za urnebesnu borbu za pobjedu.","homepage":"","overview":"Asterix i Obelix kreću na Olimpijske igre kako bi pomogli svom prijatelju Ljubomiru da osvoji srce princeze Irine. Međutim, situacija se komplicira kada Brut, Julije Cezarov sin, također želi pobjedu na igrama i Irininu ruku. Asterix i Obelix moraju se suočiti s Brutovim lukavim trikovima i rimskim atletičarima kako bi osigurali pobjedu svog prijatelja i pošteno natjecanje. Koristeći svoj čarobni napitak, Asterix i Obelix nadjačavaju svoje protivnike, no suočavaju se i s moralnim dilemama o korištenju čarolije u sportu. Na kraju, prijateljstvo i poštenje pobjeđuju, a Ljubomir osvaja Irinino srce."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"高盧英雄大戰凱撒王子","runtime":0,"tagline":"","homepage":"","overview":"高盧人沃夫希克斯愛上了美麗的埃及公主艾瑞娜，並通過鴻雁傳書的方式打動了她。終於有一天，正當他千裏迢迢來向公主表白時，卻發現羅馬執政官凱撒（阿蘭•德龍 Alain Delon 飾）的兒子布魯特斯也來提親。雙方產生爭執。公主傾向於高盧人，但是國王懾於凱撒的淫威，決定以奧運會冠軍決定公主的婚事。高盧人在奧貝里克斯（傑拉爾•德帕迪約 Gérard Depardieu 飾）等人的幫助下為愛而戰，然而布魯特斯也在處心積慮地想盡一切歪門邪道，騙取比賽勝利，一切的結果都將在奧運會比賽的最後時刻揭開…… 本片是導演弗雷德里克•佛瑞斯提亞繼《美麗新世界》、《埃及公主的任務》之後推出的又一部作品，世界足球先生齊達內、一級方程式車王舒馬赫和 NBA 球星帕克的加盟令本片星光熠熠。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Ástríkur á Ólympíuleikunum","runtime":116,"tagline":"","homepage":"","overview":"Ungi og fífldjarfi Gaulverjinn Ofurheitríkur verður ástfanginn af grísku prinsessunni Irina. Með hjálp Ástríks, Steinríks og töfraseyðis Sjóðríks ferðast hann til Grikklands til að vinna Ólympíuleikana og með því hjarta Irinu. Þegar þangað er komið þarf hann að keppa við hinn sviksama son Sesars, Brútus, sem er áfjáður í að koma föður sínum frá. Eins og allir vita eru töfraseyði bönnuð á Ólympíuleikunum en Ástríkur deyr ekki ráðalaus."},"name":"Íslenska","iso_639_1":"is","iso_3166_1":"IS","english_name":"Icelandic"}],"reviews_tmdb":[],"recommendations":[{"id":99770,"adult":false,"title":"Asterix & Obelix: God Save Britannia","video":false,"overview":"Asterix crosses the channel to help second-cousin Anticlimax face down Julius Caesar and invading Romans.","genre_ids":[10751,12,35],"media_type":"movie","popularity":1.7171,"vote_count":1380,"poster_path":"/rbdGCkvLPxuSvfVwHDK4PmOqmIm.jpg","release_date":"2012-10-17","vote_average":5.107,"backdrop_path":"/wVyHzMadmXs5FsQWnRjg3oGTIjY.jpg","original_title":"Astérix & Obélix : Au service de Sa Majesté","original_language":"fr"},{"id":9564,"adult":false,"title":"Asterix and Obelix vs. Caesar","video":false,"overview":"Set in 50 B.C., Asterix and Obelix are living in a small but well-protected village in Gaul, where a magic potion concocted by Druids turns the townsfolk into mighty soldiers. When Roman troops carve a path through Gaul to reach the English Channel, Caesar and his aide de camp Detritus discover the secret elixir and capture the Druid leader who knows its formula, and Asterix and Obelix are sent off to rescue them.","genre_ids":[10751,12,35,14],"media_type":"movie","popularity":2.4576,"vote_count":2012,"poster_path":"/sJ4zNakOuWcsW6ssH1qk80JehQ2.jpg","release_date":"1999-02-03","vote_average":6.012,"backdrop_path":"/1FxwuCdaMmCEsl3hSlafKRHR8Th.jpg","original_title":"Astérix & Obélix contre César","original_language":"fr"},{"id":2899,"adult":false,"title":"Asterix & Obelix: Mission Cleopatra","video":false,"overview":"History's favorite Gauls assist Queen Cleopatra when she wagers that the Egyptian people can build a palace for Julius Caesar in just three months.","genre_ids":[10751,14,35,12],"media_type":"movie","popularity":4.2455,"vote_count":3724,"poster_path":"/5gMmVSkY7RAxb5xRk7ej7JVhXyl.jpg","release_date":"2002-01-30","vote_average":7.374,"backdrop_path":"/1Cuaush5VwesuZJzJRy2ptfalCh.jpg","original_title":"Astérix & Obélix : Mission Cléopâtre","original_language":"fr"},{"id":9929,"adult":false,"title":"Asterix and Cleopatra","video":false,"overview":"Popular animated hero Asterix and his faithful sidekick Obelix travel to ancient Egypt to help Cleopatra build a new summer home. Cleopatra and Julius Caesar have made a bet, with Caesar wagering the project cannot be completed in a few weeks time. With the help of a magic potion, Asterix comes to the rescue of the Queen of the Nile as Caesar and an angry architect plot against them.","genre_ids":[10751,16,12,35],"media_type":"movie","popularity":1.1984,"vote_count":1010,"poster_path":"/gNpKAmWFsCiWKKx39Ap8pF7EWQg.jpg","release_date":"1968-12-19","vote_average":6.9,"backdrop_path":"/ort14Ott2BvpfmTuhsMUVnSEsWd.jpg","original_title":"Astérix et Cléopâtre","original_language":"fr"},{"id":9642,"adult":false,"title":"Asterix and the Vikings","video":false,"overview":"Asterix and Obelix have been given a tough mission: Transform the chief's lazy nephew Justforkix into a warrior. When the Vikings abduct him and bring him back to their homeland, Asterix and Obelix must travel to Norway to rescue Justforkix.","genre_ids":[10751,16,35,12],"media_type":"movie","popularity":0.8353,"vote_count":744,"poster_path":"/dW9h1Ez6PRx8PnZUVT27MnG8Wu5.jpg","release_date":"2006-04-12","vote_average":6.1,"backdrop_path":"/yBdtVoQe010z8PRJBPaun0iCKso.jpg","original_title":"Astérix et les Vikings","original_language":"fr"},{"id":527729,"adult":false,"title":"Asterix: The Secret of the Magic Potion","video":false,"overview":"Following a fall during mistletoe picking, Druid Getafix decides that it is time to secure the future of the village. Accompanied by Asterix and Obelix, he undertakes to travel the Gallic world in search of a talented young druid to transmit the Secret of the Magic Potion.","genre_ids":[10751,16,35,12],"media_type":"movie","popularity":1.5073,"vote_count":1305,"poster_path":"/5OvHpzWXBzOvgZwOoUsqNSouSwy.jpg","release_date":"2018-05-12","vote_average":6.848,"backdrop_path":"/9cPMIuB2tv4IP0LbeNhrK5OyDy5.jpg","original_title":"Astérix: Le Secret de la potion magique","original_language":"fr"},{"id":13727,"adult":false,"title":"Disco","video":false,"overview":"Didier Travolta is a 40-year-old disco music fan who has no job, lives with his mother, and has a son he hasn't seen for a while. The mother of his son refuses to send him their son for the holidays unless he can offer him a real vacation, not just going to bars of the French port city of Le Havre. Penniless, the only way he can see his son is by winning a dance contest organized by his friend Jackson, with the prize of a vacation to Australia for two.","genre_ids":[10402,35],"media_type":"movie","popularity":0.7269,"vote_count":357,"poster_path":"/6P7UjF09cp9r13sh6OA6FbiAcsr.jpg","release_date":"2008-04-02","vote_average":4.385,"backdrop_path":"/gT9a1REH37HNRuDF1WsD1VAMg2z.jpg","original_title":"Disco","original_language":"fr"},{"id":9385,"adult":false,"title":"The Twelve Tasks of Asterix","video":false,"overview":"Asterix and Obelix depart on an adventure to complete twelve impossible tasks to prove to Caesar that they are as strong as the Gods. You'll roar with laughter as they outwit, outrun, and generally outrage the very people who are trying to prove them \"only human\".","genre_ids":[10751,16,35,12],"media_type":"movie","popularity":1.356,"vote_count":1322,"poster_path":"/7cZQZOYZFJcLjZnxWjO5PcUtmDZ.jpg","release_date":"1976-06-26","vote_average":7.3,"backdrop_path":"/lyQSifurKvWmqWzouVe50JFoI35.jpg","original_title":"Les 12 travaux d'Astérix","original_language":"fr"},{"id":11047,"adult":false,"title":"Asterix the Gaul","video":false,"overview":"In the year 50 BC, Gaul is occupied by the Romans - nearly. But the small village of Asterix and his friends still resists the Roman legions with the aid of their druid's magic potion, which gives superhuman strength. Learning of this potion, a Roman centurion kidnaps the druid to get the secret formula out of him.","genre_ids":[10751,16,12,35],"media_type":"movie","popularity":2.2983,"vote_count":788,"poster_path":"/A2dlVs5WRmAwIPVS5vODhAOkNy7.jpg","release_date":"1967-12-20","vote_average":6.5,"backdrop_path":"/1ljIHeb8SFJVaXNAZfncSZvcHPx.jpg","original_title":"Astérix le Gaulois","original_language":"fr"},{"id":58858,"adult":false,"title":"The Marquis","video":false,"overview":"Thomas Gardesse, a traveling alarm systems salesman, is arrested for a minor offense and sentenced to six months imprisonment. To win the respect of his fellow inmates, he claims he is \"The Marquis,\" a brilliant robber whose identity has remained a mystery. Two weeks before his release, an armed robber named Quentin Tasseau helps him escape and takes him to Manila so he can take part in a robbery whose mastermind requires the talents of the Marquis.","genre_ids":[35],"media_type":"movie","popularity":0.4111,"vote_count":185,"poster_path":"/uHXiv8lsH2PtYGp8ua1ldRtaEHn.jpg","release_date":"2011-03-09","vote_average":5.2,"backdrop_path":"/oLKXaPsCjHl6hDAmiToNRlp7aAc.jpg","original_title":"Le Marquis","original_language":"fr"},{"id":9318,"adult":false,"title":"Asterix in Britain","video":false,"overview":"One little ancient British village still holds out against the Roman invaders. Asterix and Obelix are invited to help. They must face fog, rain, warm beer and boiled boar with mint sauce, but they soon have Governor Encyclopaedius Britannicus's Romans declining and falling. Until a wild race for a barrel of magic potion lands them in the drink.","genre_ids":[10751,16,12,35],"media_type":"movie","popularity":0.9457,"vote_count":711,"poster_path":"/10L5R1l03MqDx36e0LJ99NKLGD3.jpg","release_date":"1986-12-03","vote_average":6.768,"backdrop_path":"/cNwnAack1iyaLoWqGyTGocMOarg.jpg","original_title":"Astérix chez les Bretons","original_language":"fr"},{"id":624091,"adult":false,"title":"Sri Asih","video":false,"overview":"Alana discover the truth about her origin: she’s not an ordinary human being. She may be the gift for humanity and become its protector as Sri Asih. Or a destruction, if she can’t control her anger.","genre_ids":[28,12,878],"media_type":"movie","popularity":1.7221,"vote_count":155,"poster_path":"/wShcJSKMFg1Dy1yq7kEZuay6pLS.jpg","release_date":"2022-11-17","vote_average":6.49,"backdrop_path":"/atn3cbaqNJl7mw7p9QDiMIfHAK2.jpg","original_title":"Sri Asih","original_language":"id"},{"id":170522,"adult":false,"title":"Asterix: The Mansions of the Gods","video":false,"overview":"In order to wipe out the Gaulish village by any means necessary, Caesar plans to absorb the villagers into Roman culture by having an estate built next to the village to start a new Roman colony.","genre_ids":[16,35,12,10751],"media_type":"movie","popularity":1.4015,"vote_count":1450,"poster_path":"/oppvIr8jmTXEVkzRHtipxcmvdQ5.jpg","release_date":"2014-11-26","vote_average":6.791,"backdrop_path":"/bJcsrbkhzJvT1plcHv5rtyKiUny.jpg","original_title":"Astérix : Le Domaine des dieux","original_language":"fr"},{"id":643215,"adult":false,"title":"Asterix & Obelix: The Middle Kingdom","video":false,"overview":"Gallic heroes and forever friends Asterix and Obelix journey to China to help Princess Sa See save the Empress and her land from a nefarious prince.","genre_ids":[10751,35,12],"media_type":"movie","popularity":3.726,"vote_count":1147,"poster_path":"/ifOqT5SmA4ANjmyEacLw3KAFKUd.jpg","release_date":"2023-02-01","vote_average":4.827,"backdrop_path":"/n9wlAmb4vEgZHghtqsXXj95PocJ.jpg","original_title":"Astérix & Obélix : L'Empire du Milieu","original_language":"fr"},{"id":21788,"adult":false,"title":"Trouble at Timpetill","video":false,"overview":"The children of a small European mountain village end up being its only residents, soon after the adults cannot take their behavior any longer.","genre_ids":[14,12,10751],"media_type":"movie","popularity":0.6468,"vote_count":389,"poster_path":"/fpM57XnYSWwUk4Xvkx8KLBJ0ESR.jpg","release_date":"2008-12-17","vote_average":6.104,"backdrop_path":"/jE6zByZk2XohEUDi6GW6zHJB5k2.jpg","original_title":"Les Enfants de Timpelbach","original_language":"fr"},{"id":9369,"adult":false,"title":"Asterix Conquers America","video":false,"overview":"When marauding Romans capture - and catapult - their pal Getafix into lands unknown, the shrewd and cunning Asterix and his able sidekick Obelix spring into action! But their journey leads them to a strange and dangerous new world, where they must face a tribe of Indians, a stampeding herd of buffalo and a medicine man with designs on their magic potion!","genre_ids":[10751,16,12,35],"media_type":"movie","popularity":1.0318,"vote_count":631,"poster_path":"/lKSunt7dnbITSopaEeeR7KfeSHb.jpg","release_date":"1994-09-29","vote_average":6.209,"backdrop_path":"/XBY0iPOFVghrFPT5I3heiToGca.jpg","original_title":"Asterix in Amerika","original_language":"de"},{"id":2731,"adult":false,"title":"Indochine","video":false,"overview":"In colonial Vietnam, dashing French naval captain Jean-Baptiste, wealthy plantation owner Éliane Devries, and her adopted Vietnamese daughter Camillevare the three points of a cross-cultural romantic triangle. As the struggle against European imperialism sweeps Indochina, Jean-Baptiste and Camille have to choose sides and Éliane faces the emotionally difficult challenge of raising the child of her daughter and ex-lover.","genre_ids":[18,10749],"media_type":"movie","popularity":4.0375,"vote_count":232,"poster_path":"/sAemRfr6mOSwtQ76e4yUQVImo8B.jpg","release_date":"1992-04-15","vote_average":6.991,"backdrop_path":"/sk5YqvIl4jd7xgw7lcoUMYOLjKt.jpg","original_title":"Indochine","original_language":"fr"},{"id":8980,"adult":false,"title":"Mortadelo & Filemon: The Big Adventure","video":false,"overview":"In the Headquarters of the T.I.A. (Terminal Intelligence Agency), someone has stolen Professor Bacterio's most dangerous invention, the D.O.T. (Demoralizer of Troops), an artifact that ends up in the hands of a very short, wacky dictator who is ready to use it for criminal purposes. The T.I.A Chief, though, is firm in his resolve: if he wants to get the D.O.T. back, he must NOT count on his agents Mortadelo & Filemon. But when the crime fighting duo discover that the T.I.A. has engaged a cocky and slimy detective from outside the agency, they decide to act at their own risk, even if that risk involves all of Humanity.","genre_ids":[28,35],"media_type":"movie","popularity":0.5571,"vote_count":138,"poster_path":"/tiP17WpKYLotQwg4EUs0UfmQq24.jpg","release_date":"2003-02-07","vote_average":5.638,"backdrop_path":"/gLIDdvf3vmYmZ9RPzEfGUKQqbDO.jpg","original_title":"La gran aventura de Mortadelo y Filemón","original_language":"es"},{"id":77728,"adult":false,"title":"Giorgino","video":false,"overview":"October 1918: After returning to the civil life, the young Doctor Giorgino Volli searches for a group of children, which he had been the care-taker of before the first world war began. However, soon the searching becomes a part of hide-and-seek with death. Giorgino finds a village bordered with a treacherous marsh and rumours of wolves. There he also meets the mysterious Catherine....","genre_ids":[18,27,12],"media_type":"movie","popularity":3.1344,"vote_count":45,"poster_path":"/j87ucqJHsg8W8QMa38oAQzi3hKH.jpg","release_date":"1994-10-05","vote_average":6.4,"backdrop_path":"/jd7UaFVw75WM0qNWmAC0ExpbpJb.jpg","original_title":"Giorgino","original_language":"fr"},{"id":40415,"adult":false,"title":"Ghislain Lambert's Bicycle","video":false,"overview":"In the 70s, there was Merckx and there were the others. Ghislain Lambert was one of the others. This is his story, a quite simple one. The story of a modest Belgian bike racer. His greatest ambition in life? To become a champion. His greatest tragedy? Not having the legs his heart deserves.","genre_ids":[35],"media_type":"movie","popularity":0.1533,"vote_count":139,"poster_path":"/lIYWYhFxWaDK3ECxWRRnUxpRs0B.jpg","release_date":"2001-09-14","vote_average":5.96,"backdrop_path":"/gYUGMcsoHdaZh4n2Kj8CgG3dopv.jpg","original_title":"Le Vélo de Ghislain Lambert","original_language":"fr"}],"similar_content":[{"id":48646,"adult":false,"title":"Androcles and the Lion","video":false,"overview":"George Bernard Shaw’s breezy, delightful dramatization of this classic fable—about a Christian slave who pulls a thorn from a lion’s paw and is spared from death in the Colosseum as a result of his kind act—was written as a meditation on modern Christian values. Pascal’s final Shaw production is played broadly, with comic character actor Alan Young as the titular naïf. He’s ably supported by Jean Simmons, Victor Mature, Robert Newton, and Elsa Lanchester.","genre_ids":[35],"popularity":2.0109,"vote_count":15,"poster_path":"/16XZFR47rhHcyh8Jh4FYpmQ7dYc.jpg","release_date":"1952-12-01","vote_average":5.8,"backdrop_path":"/gpGI4siIbpYTBk4m5KV4g3iv0KR.jpg","original_title":"Androcles and the Lion","original_language":"en"},{"id":313095,"adult":false,"title":"The Magic Bubble","video":false,"overview":"A middle-aged woman frees herself from the spirit-crushing influence of her husband by refusing to remember what her age is.","genre_ids":[35,18,14],"popularity":0.4864,"vote_count":7,"poster_path":"/mnhLvu4WE6TirfmFTe03EpfCBrm.jpg","release_date":"1993-03-26","vote_average":2.214,"backdrop_path":"/4mpSv5QTlM965fxi7O1TSdhIOCS.jpg","original_title":"The Magic Bubble","original_language":"en"},{"id":313297,"adult":false,"title":"Kubo and the Two Strings","video":false,"overview":"Kubo mesmerizes the people in his village with his magical gift for spinning wild tales with origami. When he accidentally summons an evil spirit seeking vengeance, Kubo is forced to go on a quest to solve the mystery of his fallen samurai father and his mystical weaponry, as well as discover his own magical powers.","genre_ids":[16,12,10751],"popularity":4.0113,"vote_count":3754,"poster_path":"/aZJ6KK1Wt7YB4dgZ0qlpaX3PwNV.jpg","release_date":"2016-08-18","vote_average":7.632,"backdrop_path":"/bhspYsRMHgMqzUlxiVpIY8OrqMt.jpg","original_title":"Kubo and the Two Strings","original_language":"en"},{"id":49051,"adult":false,"title":"The Hobbit: An Unexpected Journey","video":false,"overview":"Bilbo Baggins, a hobbit enjoying his quiet life, is swept into an epic quest by Gandalf the Grey and thirteen dwarves who seek to reclaim their mountain home from Smaug, the dragon.","genre_ids":[12,14,28],"popularity":27.9919,"vote_count":19333,"poster_path":"/yHA9Fc37VmpUA5UncTxxo3rTGVA.jpg","release_date":"2012-12-12","vote_average":7.367,"backdrop_path":"/xyXmtuvsoM5J3yNad0nvcetpBdY.jpg","original_title":"The Hobbit: An Unexpected Journey","original_language":"en"},{"id":313371,"adult":false,"title":"All She Wishes","video":false,"overview":"When her birthday wish magically summons wacky Hollywood actor Drake to her small Midwestern town, Sophie has to figure out how to help him fit in until she can get him back home. But Drake is more interested in helping Sophie stand out.","genre_ids":[35,14,10770],"popularity":0.2449,"vote_count":12,"poster_path":"/uwyvClqccWsilxCMbH3TDfAGPxJ.jpg","release_date":"2015-01-15","vote_average":6.9,"backdrop_path":"/80VAmXBbeTqsRJ56ecKzYfouq66.jpg","original_title":"All She Wishes","original_language":"en"},{"id":48832,"adult":false,"title":"Scott Pilgrim vs. the Animation","video":false,"overview":"Scott Pilgrim vs. The Animation is an animated short based on Bryan Lee O'Malley's \"Scott Pilgrim\" franchise.","genre_ids":[16,28,35,10749],"popularity":0.4482,"vote_count":88,"poster_path":"/od3W75dkIqhQjVEz1D6calCNgGR.jpg","release_date":"2010-08-10","vote_average":7.045,"backdrop_path":"/E3oRaNXvPqHuTd7yvL8cLVi47F.jpg","original_title":"Scott Pilgrim vs. the Animation","original_language":"en"},{"id":313657,"adult":false,"title":"Pekka Puupää","video":false,"overview":"Pete and Runt set up a kindergarten at their home, and unknowingly end up taking care of a kidnapped baby.","genre_ids":[35],"popularity":0.1368,"vote_count":9,"poster_path":"/j0gaI0v1tm91lXYvAB48meuyxsF.jpg","release_date":"1953-04-30","vote_average":4.9,"backdrop_path":"/tccBfU7VVuHq8YGjSwLQ73FEOCZ.jpg","original_title":"Pekka Puupää","original_language":"fi"},{"id":49076,"adult":false,"title":"Superman: The Last Son of Krypton","video":true,"overview":"Clark Kent, the last survivor of the dead planet Krypton, uses his amazing powers to defend people of his adopted world, Earth, and become Superman.","genre_ids":[16,10751,14,28,12,878,10770],"popularity":0.506,"vote_count":75,"poster_path":"/2g5o7gVeSn0HTtmZapL2pY1u1xR.jpg","release_date":"1996-09-10","vote_average":7.073,"backdrop_path":"/dOjWpQ7evwJXfFzxQjUv3sWIHB6.jpg","original_title":"Superman: The Last Son of Krypton","original_language":"en"},{"id":313884,"adult":false,"title":"Wedding night","video":false,"overview":"As fate would have it, four newly-weds who aren't quite total strangers unknowingly reunite at a sea-side resort, eager to experience a hot wedding night. However, love isn't always a bed of roses. Will their first night be unforgettable?","genre_ids":[35],"popularity":0.878,"vote_count":18,"poster_path":"/rX8D9GAjCYhvqPvgIGAagGJDfbE.jpg","release_date":"1967-12-11","vote_average":6.611,"backdrop_path":"/syzMpdXuhoZYyqP2rgtceFR6Udx.jpg","original_title":"Νύχτα γάμου","original_language":"el"},{"id":313954,"adult":false,"title":"When Hell Freezes Over","video":false,"overview":"This Mutt and Jeff cartoon was directed by Charley Bowers. It shows his typical care, both in the drawings of the characters and a surprisingly elaborate back ground. Mutt and Jeff are out looking for fire wood during a cold snap; the Devil appears and takes them to the Hot Place, where they are put in charge of making sure that the last fire there doesn't go out. Their job is complicated by the imps and demons, as well as the fire insisting on wandering around.","genre_ids":[27,16,35],"popularity":0.2152,"vote_count":2,"poster_path":null,"release_date":"1926-03-06","vote_average":5,"backdrop_path":null,"original_title":"When Hell Freezes Over","original_language":"en"},{"id":313995,"adult":false,"title":"Little Houdini","video":false,"overview":"Appleton, Wisconsin, 1886. Harry, 12 years old, has lived and breathed magic since his early childhood. But the small village Appleton is not the best spot for his natural talent to blossom. Although he rehearses endlessly in his parent’s barn he does realize that his dream is far stretched out. One day Harry catches the glimpse of a chance: the New York mayor has called out for a large contest in view of  the Statue of Liberty’s official opening. However one must be tutored by a «real» magician and he doesn’t have the slightest idea of how to contact one… until his father tells him that the great Tesla is in town! Despite the young boys’ lack of knowledge Tesla spots talent, creativity and boldness in Harry. He decides to give him a chance and invites him to his own home, accompagnied by his niece Beth and his robot assistant Amrold.","genre_ids":[16,10751,36,12],"popularity":0.8217,"vote_count":7,"poster_path":"/wbdOFLbnc07iRl5E0tdrqlwK8M4.jpg","release_date":"2014-12-27","vote_average":8.4,"backdrop_path":"/1jkWRBkB9PgsqeEiUWgR6YnLenQ.jpg","original_title":"Houdini - Le Film","original_language":"fr"},{"id":49432,"adult":false,"title":"Where Is Winky's Horse?","video":false,"overview":"In the sequel to \"Winky's Horse\", 8-year old Winky looks after the horse of St Nicholas. Then one day the horse runs away.","genre_ids":[10751],"popularity":0.9384,"vote_count":15,"poster_path":"/ldidzQHEyCWDfoURPBH4vpimZIo.jpg","release_date":"2007-10-10","vote_average":6.7,"backdrop_path":"/luMX3R8TbdH4rvv00ERQvVTrtkR.jpg","original_title":"Waar is het paard van Sinterklaas?","original_language":"nl"},{"id":706663,"adult":false,"title":"Nahuel and the Magic Book","video":false,"overview":"Nahuel lives with his father in a fishing town, yet he has a deep fear of the sea. One day, he finds a magical book that seems to be the solution to this problem, but a dark sorcerer is after it and captures Nahuel's father. This is where his journey to rescue his father and overcome his fears begins.","genre_ids":[16,14],"popularity":0.1939,"vote_count":31,"poster_path":"/vwWz3biJXjhJmn5WCjocGCVG3k2.jpg","release_date":"2021-04-20","vote_average":7.9,"backdrop_path":"/ikiUz57XNzYO0pNeOuJOLjwchlb.jpg","original_title":"Nahuel y el libro mágico","original_language":"es"},{"id":49521,"adult":false,"title":"Man of Steel","video":false,"overview":"A young boy learns that he has extraordinary powers and is not of this earth. As a young man, he journeys to discover where he came from and what he was sent here to do. But the hero in him must emerge if he is to save the world from annihilation and become the symbol of hope for all mankind.","genre_ids":[28,12,878],"popularity":9.7733,"vote_count":15956,"poster_path":"/8GFtkImmK0K1VaUChR0n9O61CFU.jpg","release_date":"2013-06-12","vote_average":6.639,"backdrop_path":"/69EFgWWPFWbRNHmQgYdSnyJ94Ge.jpg","original_title":"Man of Steel","original_language":"en"},{"id":706860,"adult":false,"title":"Out","video":false,"overview":"On an average day, Greg's life is filled with family, love and a rambunctious little dog - but despite all of this, Greg has a secret. Today is different, though. With some help from his precocious pup, and a little bit of magic, Greg might learn that he has nothing to hide.","genre_ids":[16,35,18,14,10751,10749],"popularity":0.3673,"vote_count":208,"poster_path":"/dCmtnJqu4Lk4yzEPoLZkHYrpwaP.jpg","release_date":"2020-05-22","vote_average":7.245,"backdrop_path":"/knLH3cYsDt7jO6uSMrc0PXfimra.jpg","original_title":"Out","original_language":"en"},{"id":49524,"adult":false,"title":"R.I.P.D.","video":false,"overview":"A recently slain cop joins a team of undead police officers working for the Rest in Peace Department and tries to find the man who murdered him.","genre_ids":[14,28,35],"popularity":3.8323,"vote_count":4226,"poster_path":"/rS0kByPD4YF8pQ85KjzMdGiu7Xf.jpg","release_date":"2013-07-18","vote_average":5.9,"backdrop_path":"/6KJcFFE1iBPC0Xj0iPCcmMvS5WK.jpg","original_title":"R.I.P.D.","original_language":"en"},{"id":49538,"adult":false,"title":"X-Men: First Class","video":false,"overview":"Before Charles Xavier and Erik Lensherr took the names Professor X and Magneto, they were two young men discovering their powers for the first time. Before they were arch-enemies, they were closest of friends, working together with other mutants (some familiar, some new), to stop the greatest threat the world has ever known.","genre_ids":[28,878,12],"popularity":0.3788,"vote_count":13373,"poster_path":"/hNEokmUke0dazoBhttFN0o3L7Xv.jpg","release_date":"2011-06-01","vote_average":7.3,"backdrop_path":"/mCinjxmq2tRDzSgc8QcuRkV8yTo.jpg","original_title":"X-Men: First Class","original_language":"en"},{"id":33176,"adult":false,"title":"Lupin the Third: Return of Pycal","video":false,"overview":"Lupin steals an extraordinary gem from a Mediterranean party, only to be interrupted by Pycal, the trickster \"magician\" who had apparently died fighting Lupin early in his career. Pycal, now armed with real magical abilities, is determined to take revenge.","genre_ids":[16,28,35,80],"popularity":0.6083,"vote_count":65,"poster_path":"/zUyLw8LTjH0U8WqeVzGjzfnkptf.jpg","release_date":"2002-04-03","vote_average":6.1,"backdrop_path":"/2gE6TveWJ8D6qiX1D5h4pS8YkZu.jpg","original_title":"ルパン三世 生きていた魔術師","original_language":"ja"},{"id":33081,"adult":false,"title":"Paheli","video":false,"overview":"Kishanlal marries the beautiful Lachchi, but the day after the wedding, he leaves on business for five years. When Kishanlal reappears only a few days later, Lachchi is delighted, but this new Kishanlal is in fact a spirit who has taken the form of Lachchi's husband, after having seen her by chance and fallen in love with her. Four years later, the real Kishanlal returns and the townsfolk must determine who is who.","genre_ids":[10749,18,14],"popularity":0.5805,"vote_count":100,"poster_path":"/1oQ8mBfBKcVT758y1949ULkSXER.jpg","release_date":"2005-06-24","vote_average":6.145,"backdrop_path":"/7WoyOMp0wORdgYJimHeg0XuNaTM.jpg","original_title":"पहेली","original_language":"hi"},{"id":33358,"adult":false,"title":"The Mostly Unfabulous Social Life of Ethan Green","video":false,"overview":"Ethan Green (Daniel Letterle) has no problem finding guys who want to sleep with him or even date him, but finding someone to settle down with is a different story. Given three choices -- a sexy teenager, a hunky jock, or his ex-boyfriend who is about to get married -- will he find a Mr. Right, or is he destined to an unfabulous existence. Based on a popular gay-themed comic strip.","genre_ids":[35,10749],"popularity":0.4513,"vote_count":38,"poster_path":"/pbZx18g9NlDzvsCCkajRbZu16cJ.jpg","release_date":"2005-04-29","vote_average":5.3,"backdrop_path":"/ArIoeXp9mIxPJHqOvehURsqIcrZ.jpg","original_title":"The Mostly Unfabulous Social Life of Ethan Green","original_language":"en"}],"external_ids":{"imdb_id":"tt0463872","twitter_id":null,"facebook_id":null,"wikidata_id":"Q273676","instagram_id":null,"mydramalist_id":"140194","rotten_tomatoes_id":"m/asterix_at_the_olympic_games"},"social_ids"