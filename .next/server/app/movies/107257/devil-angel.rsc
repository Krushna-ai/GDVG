5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Devil Angel\",\"description\":\"Chi Kit worked in a stock company. One day, the stock market crashed and Chi Kit ran into bankruptcy. He called his girlfriend Siu Suen and told her everything. Siu Suen loved Chi Kit so much that she took all her savings and ran away with him to Singapore to hide away from their debts. Unfortunately, Chi Kit met a wealthy woman with an interesting proposal, and it changed everything.\",\"image\":\"https://image.tmdb.org/t/p/w500/4OZV7CAHuiIkBmM0wCVeHtWZULY.jpg\",\"datePublished\":\"1995-11-09\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"TW\",\"inLanguage\":\"cn\",\"genre\":[\"Drama\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.1,\"bestRating\":10,\"ratingCount\":11}}"}}],["$","$L10",null,{"initialDrama":{"id":"ddfe803b-6651-4e6c-a81e-4ea0360ff9b8","tmdb_id":271116,"imdb_id":"tt0320109","content_type":"movie","title":"Devil Angel","original_title":"Devil Angel","overview":"Chi Kit worked in a stock company. One day, the stock market crashed and Chi Kit ran into bankruptcy. He called his girlfriend Siu Suen and told her everything. Siu Suen loved Chi Kit so much that she took all her savings and ran away with him to Singapore to hide away from their debts. Unfortunately, Chi Kit met a wealthy woman with an interesting proposal, and it changed everything.","poster_path":"/4OZV7CAHuiIkBmM0wCVeHtWZULY.jpg","backdrop_path":"/x5QV9uKKcwKb3ImcYPDGdKWaIJw.jpg","release_date":"1995-11-09","first_air_date":null,"status":"published","original_language":"cn","origin_country":["TW","HK"],"genres":[{"id":18,"name":"Drama"}],"popularity":3.3974,"vote_average":4.1,"vote_count":11,"runtime":95,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-03T22:55:32.356212+00:00","updated_at":"2026-02-03T22:55:32.356212+00:00","tagline":"Rich woman, poor m