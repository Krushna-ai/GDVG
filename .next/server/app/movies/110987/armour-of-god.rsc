r_name":"Rakuten TV","display_priority":13},{"logo_path":"/auWzottqpExOHUlJwDZ4DvdHGoL.jpg","provider_id":423,"provider_name":"Blockbuster","display_priority":14},{"logo_path":"/sNmIwrniZZORvNJOmEuWGhwBJNf.jpg","provider_id":426,"provider_name":"SF Anytime","display_priority":15},{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":39}],"free":[{"logo_path":"/w1V9hzBaRlkpISBWhCv676kI8Mp.jpg","provider_id":496,"provider_name":"Cineasterna","display_priority":22}],"link":"https://www.themoviedb.org/movie/10974/watch?locale=SE","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":4},{"logo_path":"/bnoTnLzz2MAhK3Yc6P9KXe5drIz.jpg","provider_id":76,"provider_name":"Viaplay","display_priority":6},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":8},{"logo_path":"/bZvc9dXrXNly7cA0V4D9pR8yJwm.jpg","provider_id":35,"provider_name":"Rakuten TV","display_priority":13},{"logo_path":"/auWzottqpExOHUlJwDZ4DvdHGoL.jpg","provider_id":423,"provider_name":"Blockbuster","display_priority":14},{"logo_path":"/sNmIwrniZZORvNJOmEuWGhwBJNf.jpg","provider_id":426,"provider_name":"SF Anytime","display_priority":15},{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":39}]},"SG":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":6},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":7}],"link":"https://www.themoviedb.org/movie/10974/watch?locale=SG","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":6},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":7}],"flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"SV":{"ads":[{"logo_path":"/dB8G41Q6tSL5NBisrIeqByfepBc.jpg","provider_id":300,"provider_name":"Pluto TV","display_priority":18}],"link":"https://www.themoviedb.org/movie/10974/watch?locale=SV"},"TH":{"link":"https://www.themoviedb.org/movie/10974/watch?locale=TH","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":1}]},"TW":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":6}],"link":"https://www.themoviedb.org/movie/10974/watch?locale=TW","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":6}],"flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"US":{"ads":[{"logo_path":"/zLYr7OPvpskMA4S79E3vlCi71iC.jpg","provider_id":73,"provider_name":"Tubi TV","display_priority":361}],"link":"https://www.themoviedb.org/movie/10974/watch?locale=US","flatrate":[{"logo_path":"/8G7qvHF7hdmXpfxxqtF1WT9ib68.jpg","provider_id":2308,"provider_name":"Darkroom","display_priority":138}]},"UY":{"ads":[{"logo_path":"/dB8G41Q6tSL5NBisrIeqByfepBc.jpg","provider_id":300,"provider_name":"Pluto TV","display_priority":21}],"link":"https://www.themoviedb.org/movie/10974/watch?locale=UY"},"VE":{"ads":[{"logo_path":"/dB8G41Q6tSL5NBisrIeqByfepBc.jpg","provider_id":300,"provider_name":"Pluto TV","display_priority":18}],"link":"https://www.themoviedb.org/movie/10974/watch?locale=VE"}}},"wikidata_id":"Q1199513","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-20T21:54:59.900198+00:00","region":null,"main_poster":null,"images":null,"enriched_at":"2026-04-21T07:29:48.254+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Armour of God","runtime":97,"tagline":"Jackie Chan in his greatest adventure ever!","homepage":"","overview":"Jackie Chan stars as Asian Hawk, an Indiana Jones-style adventurer looking to make a fortune in exotic antiquities. After Hawk discovers a mysterious sword in Africa, a band of Satan-worshipping monks kidnap his ex-girlfriend Lorelei, demanding the sword as ransom as well as other pieces of the legendary Armour of God - a magical outfit dating back to the Crusades."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Der rechte Arm der Götter","runtime":87,"tagline":"","homepage":"","overview":"Der Abenteurer Jackie stiehlt im finsteren Afrika das Schwert einer mittelalterlichen Rüstung. Als ihm einige Zeit später das Geld ausgeht, bietet er das Stück auf einer Versteigerung an, wo sich eine mysteriöse Schönheit ganz besonders dafür interessiert. Jackie weiß nicht, daß das Schwert zum obersten Heiligtum einer kriminellen Sekte gehört, zu der legendären fünfteiligen “Rüstung Gottes”. Und um in den Besitz der noch fehlenden drei Teile zu gelangen, schrecken die Verbrecher vor nichts zurück – auch nicht vor der Entführung von Jackies Freundin."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Armour of God","runtime":88,"tagline":"","homepage":"","overview":"Jackie Condor, cacciatore di tesori e reliquie, in compagnia di un imbranato amico/aiutante, cercherà di salvare la sua ex-fidanzata rapita da una congrega di oscuri e invasati monaci. Durante le ricerche la sgangherata coppia scoprirà che gli stessi monaci sono entrati in possesso di una preziosissima reliquia chiamata \"corazza di Dio\" (Armour of God), rubata a un ricco antiquario durante un'asta. I Nostri si prodigheranno così tra mille disavventure e indagini per salvare ragazza e armatura."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Mister Dynamite","runtime":94,"tagline":"Jackie Chan dans sa plus grande aventure !","homepage":"","overview":"Jackie, un grand aventurier, est désigné par Bannon, millionnaire collectionneur d'antiquités, pour retrouver les pièces manquantes d'un ancien artefact religieux, \"L'Armure de Dieu\". Parallèlement, les fidèles de cette religion veulent récupérer leur \"trésor\" et kidnappent la meilleure amie de Jackie, Lorelei, pour s'en servir comme monnaie d'échange."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Доспехи Бога","runtime":88,"tagline":"","homepage":"","overview":"«Азиатский ястреб» — так назвали героя Джеки в Европе. Когда он похитил в Африке ритуальный меч, то не предполагал, что это начало опасных приключений. Оказывается, что меч — часть древних доспехов Бога, и если их уничтожить, то в мире будут править силы Ужаса и Зла. Силы Зла, которые укрылись в неприступном монастыре, узнают, что у Джеки есть доступ к остальным доспехам. Они похищают девушку, которую любит Ястреб, и требуют выкупа. Понимая, что одной ловкостью ему не справиться с полчищами бандитов, Джеки добровольно становится человеком — бомбой. Но этот козырь он приберег на самый крайний случай…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Istenek fegyverzete","runtime":88,"tagline":"","homepage":"","overview":"A kalandor és kincsvadász Jackie veszélyt nem ismerve megszerzi az istenek fegyverzetének egy darabját a sivatag ősi városából. A fegyverek őrei azonban nem adják könnyen a misztikus kincset. A szekta követői elrabolják Jackie barátnőjét, Loreleit, hogy ezzel kényszerítsék a férfit a szent fegyverzetek összes darabjának átadására. A lány kiszabadítása nem tűnik könnyű feladatnak, ugyanis titkos csapdák, amazonok, és egy dühös varázsló keresztezik Jackie útját."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"La armadura de Dios","runtime":88,"tagline":"¡Jackie Chan en su mayor aventura!","homepage":"","overview":"Nadie sabe como es exactamente la Armadura de Dios ni que forma tiene. Según la Biblia, la Armadura de Dios encarna el poder de la justicia que combate el siniestro espíritu del hombre. Diferentes armaduras han aparecido por todo el mundo y todos sus coleccionistas reclaman su autenticidad. Jackie Chan ha estado ayudando a Duke en su continua búsqueda de la armadura: en su última aventura consiguió hacerse con la Espada Sagrada, originaria de los aborígenes africanos. Duke está dispuesto a pagar cualquier precio por ella. Mientras, una banda de terroristas he secuestrado a la novia de Alan y exige la Espada Sagrada como rescate. La hija de Duke, Jackie y Alan se embarcan en un viaje para combatir a los terroristas. La acción está asegurada."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Long Hing Foo Dai","runtime":94,"tagline":"","homepage":"","overview":"Asian Hawk is een avonturier, schatgraver en een geduchte verchtersbaas. Hawk krijgt het aan de stok met een orde van satanistische monniken die zijn voormalige vriendin Laura hebben gekidnapt. De monniken proberen zo Lauras nieuwe vriend Alan te dwingen één van de vijf delen van The Armour of God te overhandigen, een magisch harnas waarvan de drager onoverwinnelijk is."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Božská relikvie","runtime":0,"tagline":"Jackie Chan ve svém největším dobrodružství všech dob!","homepage":"","overview":"Dobrodruh a hledač pokladů Jackie odvážně získá v jednom starobylém městě v poušti zbraň patřící k výzbroji bohů. Ovšem strážci zbraní nejsou ochotni vzdát se svého pokladu. Členové kmenu unesou Jackieho přítelkyni Loreleii, aby ho tím přinutili k vydání všech zbraní patřících k výzbroji bohů. Vysvobození dívky není snadným úkolem, jelikož na cestě jsou uložené různé nástrahy, číhají na něj odvážné amazonky a zlostný čaroděj. Jméno Jackie Chan je už dobře známo nejen mezi milovníky bojových umění, kteří se kochají pohledem na jeho bravurní kung-fung scény, ale okouzlují nás i jeho komedie. Samozřejmě i v tomto filmu se setkáme se spoustou humoru, který je pro něj tak charakteristický a na konci se zasmějeme nad kopancemi při natáčení scének."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"龙兄虎弟","runtime":0,"tagline":"","homepage":"","overview":"基督教《圣经》中记载上帝曾利用五件“上帝武装”打败邪魔，但而后来散失在世界各地。伯爵（Bozidar Smiljanic 饰）得到了其中的三件，而邪魔的传人得到了两件。\r 艾伦（谭咏麟 饰）的女友罗娜（关之琳 饰）在时装表演时，被信奉邪魔的恶僧侣掳走，赎回条件就是用伯爵的三件上帝武装交换人质。艾伦只得找兄弟亚洲飞鹰（成龙 饰）帮忙，此时飞鹰的三件上帝武装已经卖给了伯爵，他们不得不去伯爵府借。\r 伯爵最初不愿借出上帝武装，因此艾伦潜入伯爵府以试图偷出，但被抓获。飞鹰和伯爵说人情，向伯爵借用三件上帝武装的同时，愿意将邪魔阵营的另外两件上帝武装无偿献给伯爵，伯爵最终才同意。\r 伯爵的女儿阿美（罗拉·芳娜 饰）坚持要监视飞鹰和艾伦以上帝武装营救人质的行动，因此也加入了营救罗娜的队伍。于是，飞鹰、艾伦和阿美一起组队西行欧洲，参与救人和夺宝的行动。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Доспехите на Бога","runtime":97,"tagline":"","homepage":"","overview":"Джеки Чан играе отказал се певец, чиято бивша приятелка е отвлечена от сатанинска секта. Единствената надежда на момичето остава екс-приятелят ѝ, който е готов на всичко, за да я спаси."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Обладунки Бога","runtime":88,"tagline":"","homepage":"","overview":"\"Азійський яструб\" - так звали героя в Європі. Коли він викрав в Африці ритуальний меч, то не уявляв собі, що це був початок небезпечних пригод. Виявляється, що меч - частина стародавніх обладунків Бога, і якщо їх знищити, то у світ прийдуть сили Зла."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"サンダーアーム 龍兄虎弟","runtime":0,"tagline":"","homepage":"","overview":"“アジアの鷹”の異名を取る探検家のジャッキーは、親友のアランから、かつて自分が思いを寄せていた女性ロー ラが謎の邪教集団に誘拐されたことを知らされる。教団 の目的は、世界に散らばる5つの秘宝“神の武具”を ジャッキーに集めさせ、強大なパワーを手中に収めること だった。ジャッキーは悪の使徒たちの恐るべき野望を阻止 すべく、大量のダイナマイトを武器に、敵の砦である洞窟 へと乗り込む。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Armadura de Deus","runtime":0,"tagline":"Armadura, deus","homepage":"","overview":"Vilões sequestram a ex-namorada de Jackie e atual namorada do seu amigo cantor, que não hesita em pedir sua ajuda para resgatá-la. Porém, eles devem primeiro encontrar a lendária Armadura de Deus, que torna invencível quem a usa. Jackie e o roteirista, Edward, sempre foram fãs de Steven Spielberg. Por isso fizeram essa “homenagem” ao Indiana Jones, na qual nosso ator faz Asian Hawk, um caçador de tesouros e aventuras. Na cena onde Jackie teve que pular de um muro para uma árvore, ele errou, caiu de uma altura de 3 andares, bateu com a cabeça numa pedra e quase morreu. Ficou surdo de um ouvido e teve traumatismo craniano e foram aplicadas placas de titânio em sua cabeça. Foi premiado em seu lançamento em Hong Kong, com “Melhor Fotografia” e “Melhor Cena de Ação”. Um filme de ação fantástico!"},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Fandens til våben","runtime":0,"tagline":"","homepage":"","overview":"Jackie Chan er eventyrer med stort E, på jagt efter skjulte skatte og velbevarede hemmeligheder. Da han finder et magisk sværd, kidnapper en gruppe satanistiske munke Jackies eks-kæreste og kræver våbenet som løsepenge. Mens de venter, hjernevasker de pigen og Jackie må snart kæmpe mod virkeligt hårde odds. Jackie Chan har oven i købet selv instrueret filmen! Armour of God er også kendt under titlen Operation Condor 2."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Zbroja Boga","runtime":0,"tagline":"","homepage":"","overview":"Najlepszy film przygodowy z udziałem Jackie Chana kręcony na Bałkanach. Historia awanturnika, poszukiwacza przygód oraz reliktów starych kultur. Bohater filmu po odnalezieniu miecza Boga, udaje się na kolejną wyprawę, aby odnaleźć zbroję. Wszystkie trudne sceny, kręcone były bez pomocy kaskaderów. W trakcie kręcenia jednej z niebezpiecznych scen aktor uległ nieomal śmiertelnemu wypadkowi.  [opis dystrybutora dvd]"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"נשק האלים","runtime":0,"tagline":"","homepage":"","overview":"כת שטנית חושקת לנעוץ ציפורניה בשריון מיוחד בבעלותו של ג'קי. על מנת לעשות זאת, חוטפים חברי הכת את חברתו של חברו הטוב. עכשיו יוצאים השניים להציל אותה ובו בזמן עליהם להשגיח לא להיפרד מהאוצר יקר הערך."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Armadura de Deus","runtime":98,"tagline":"Jackie Chan em sua maior aventura de todos os tempos!","homepage":"","overview":"Vilões sequestraram a ex-namorada de Jackie e atual do seu amigo cantor, que não hesita em pedir sua ajuda para resgatá-la. Porém, eles devem primeiro encontrar a lendária Armadura de Deus, que torna invencível quem a usa."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"용형호제","runtime":0,"tagline":"그녀를 되찾기 위한 고난과 역경의 탈출기!","homepage":"","overview":"재키는 알란과 로라와 함께 그룹 활동을 하다 로라를 사이에 두고 알란과 충돌이 일자 그룹을 떠나 보물 사냥꾼 '날으는 매'로 명성을 떨친다. 재키가 5개의 상제무장검들 중 3개를 찾아내자, 교의 번영을 위해 상제무장을 모두 찾아 없애야 하는 사이비 종교인 만물교의 교주가 로라를 납치해 그가 찾은 3개의 상제무장을 갖고 오라 협박한다. 이미 경매를 통해 백작에게 넘어간 상제무장검들을 되돌려 받아 로라를 구하기 위해 재키는 만물교의 교주가 가진 나머지 2개의 검과 함께 세트로 돌려주는 조건과 백작의 딸 '미미'를 동행시키는 조건으로 상제무장검을 빌리는 데 성공한다. 검은 옷을 입은 만물교의 신도들과 쫓고 쫓기는 추적을 반복하던 세 사람은 마침내 그들의 아지트에 잠복하여 로라를 구하러 가는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Opération Condor 2 : Le bouclier des Dieux","runtime":89,"tagline":"Jackie Chan dans sa plus grande aventure !","homepage":"","overview":"Jackie, un grand aventurier, est désigné par Bannon, millionnaire collectionneur d'antiquités, pour retrouver les pièces manquantes d'un ancien artefact religieux, \"L'Armure de Dieu\". Parallèlement, les fidèles de cette religion veulent récupérer leur \"trésor\" et kidnappent la meilleure amie de Jackie, Lorelei, pour s'en servir comme monnaie d'échange."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Tanrının Zırhı","runtime":0,"tagline":"Jackie Chan şimdiye kadarki en büyük macerasında!","homepage":"","overview":"Tanrının zırhı denen beş kutsal silahı ele geçirmeye çalışan gizemli bir tarikat, paralı askerlik yapan Asian’ın peşine düşer. Çünkü beş zırhtan biri olan Tanrının kılıcını Asian bir Afrika kabilesinden çalmıştır. Tarikatın liderleri genç dövüşçünün eskiden beri ilgi duyduğu güzel Lorelei’yi kaçırıp koz kullanarak Asian’dan diğer parçaları da bulmasını isterler."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"L’armadura de Déu","runtime":0,"tagline":"Jackie Chan en la seva aventura més gran!","homepage":"","overview":"Lorelei, companya d'Alan i amiga de Jackie, ha estat segrestada. Els raptors, que posseeixen dues peces de l'\"armadura de Déu\", volen tenir les altres tres, que estan en poder del col·leccionista d'art Bannon. Bannon accepta deixar les peces a Jackie i Alan perquè les utilitzin com a esquer per aconseguir l'armadura completa. En companyia de May, filla de Bannon, tots dos companys s'introdueixen en una secta que trafica amb drogues. Un cop hagin alliberat Lorelei, serà el moment d'enfrontar-se amb les forces del mal."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"龍兄虎弟","runtime":97,"tagline":"","homepage":"","overview":"基督教《聖經》中記載上帝曾利用五件「上帝武裝」打敗邪魔，但後來散失在世界各地。伯爵（Bozidar Smiljanic 飾）得到了其中的三件，而邪魔的傳人得到了兩件。\r 艾倫（譚詠麟 飾）的女友羅娜（關之琳 飾）在時裝表演時，被信奉邪魔的惡僧侶擄走，贖回條件就是用伯爵的三件上帝武裝交換人質。艾倫只得找兄弟亞洲飛鷹（成龍 飾）幫忙，此時飛鷹的三件上帝武裝已經賣給了伯爵，他們不得不去伯爵府借。\r 伯爵最初不願借出上帝武裝，因此艾倫潛入伯爵府試圖偷出，但被抓獲。飛鷹向伯爵說人情，表示借用三件上帝武裝的同時，願意將邪魔陣營的另外兩件上帝武裝無償獻給伯爵，伯爵最終才同意。\r 伯爵的女兒阿美（羅拉·芳娜 飾）堅持要監視飛鷹和艾倫以上帝武裝營救人質的行動，因此也加入了營救羅娜的隊伍。於是，飛鷹、艾倫和阿美一起組隊西行歐洲，參與救人和奪寶的行動。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Ο Κεραυνός του Θεού","runtime":0,"tagline":"Τζάκι Τσαν: Ο Κεραυνός του Θεού","homepage":"","overview":"Ένας απλός και καθημερινός άνθρωπος μπλέκεται σε μια απίστευτη περιπέτεια, όταν η κοπέλα του καλύτερού του φίλου απάγεται. Προκειμένου να την εντοπίσει, ο Άζιαν Χοκ θα αναγκαστεί να εμπλακεί στην επιχείρηση εντοπισμού ενός μυστήριου και μυθικού αντικειμένου γνωστού ως «Κεραυνός του Θεού». Η συναρπαστική του αναζήτηση θα τον οδηγήσει στα πλοκάμια μιας σκοτεινής αίρεσης στην Ευρώπη που αποτελείται από έναν κύκλο τρομοκρατών κι εμπόρων ναρκωτικών μεταμφιεσμένων σε καλόγερους!"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Božská relikvia","runtime":88,"tagline":"Jackie Chan vo svojom najväčšom dobrodružstve všetkých čias!","homepage":"","overview":"Vyznávači satanovho kultu unesú Lorelei, bývalú priateľku lovca relikvií Jackieho za to, že im ukradol vzácny artefakt. Jej súčasný priateľ Alan sa naňho obráti s prosbou o pomoc pri jej záchrane. Obaja sa snažia unesenú modelku zachrániť. Napriek ich vôli im asistuje vnučka obchodníka so starožitnosťami May, od ktorej si Jackie musí vypožičať už predané kusy relikvie."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Jumalan aseet","runtime":0,"tagline":"","homepage":"","overview":"Asian Hawk on huoleton onnensoturi, joka muun muassa tekee antiikkikauppoja nopean voiton toivossa. Sattuma tuo Hawkin käsiin ikivanhan muinaisjäännöksen. Hän muuttaa hankintansa nopeasti voitoksi ja myy uskonnollisen kulttiesineen antiikkikauppias Bannonilla. Muinaisesine, nimeltään Armour of God, on kuitenkin tärkeä epäjumala eräälle suljetulle lahkolle. Ja sen fanaattiset jäsenet ovat päättäneet saada esineen itselleen... hintaan mihin hyvänsä. Siitä alkaa Hawkin loputon painajainen."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"La armadura de Dios","runtime":0,"tagline":"","homepage":"","overview":"Alan acude a su viejo amigo Jackie cuando una secta de monjes malignos secuestra a su novia. Sólo podrán salvarla encontrando la Armadura de Dios antes que los monjes y Jackie conoce el paradero de dos piezas. Investigando, acaban en la mansión de un noble que posee otra pieza, pues la ha adquirido recientemente en una subasta. Encontrar la pieza más preciada, la espada, será la tarea más ardua, pues los dos amigos y luchadores deberán superar a enemigos altamente entrenados en el combate, y cargar con la caprichosa hija de un conde no formaba parte de sus planes."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Dievo šarvai","runtime":0,"tagline":"","homepage":"","overview":"Ritualinį kardą, kuriame sukoncentruota Dievo galia, užvaldo Azijos Vanagu pramintas kovotojas. Jei jis nesugebės išlaikyti kardo, žemę užvaldys siaubas ir pyktis. Pykčio jėgos susivienija, kad perimtų iš Vanago paslaptingąjį ginklą. Jie pagrobia Vanago mylimąją ir reikalauja išpirkos. Vaikinas pasiryžta kovai."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"ใหญ่สั่งมาเกิด","runtime":0,"tagline":"","homepage":"","overview":"นักล่าขุมทรัพย์จอมผจญภัยที่มีนามว่าแจ็คกี้ เจ้าของฉายาเหยี่ยวเอเชีย แจ็คกี้ได้ช่วยท่านดยุคค้นหาอาวุธเทพเจ้า ซึ่งในการค้นหาครั้งล่าสุด แจ็คกี้ได้ดาบศักดิ์สิทธิ์มาไว้ในครอบครอง ท่านดยุครู้สึกปลาบปลื้มเป็นอย่างมากและพร้อมที่จะจ่ายไม่อั้นเพื่อให้ได้ ดาบศักดิ์สิทธิ์ชิ้นนี้มาเป็นของตน แต่เมื่อผู้ก่อการร้ายจอมโหดได้ทราบข่าวเรื่องดาบก็ได้ส่งคนมาจับตัวแฟนสาวของอลันไป ซึ่งในอดีตเธอเคยเป็นแฟนกับแจ็คกี้มาก่อน เพื่อนำมาเป็นเงื่อนไขแลกเปลี่ยนกับดาบ ท่านดยุคได้ให้แจ็คกี้ยืมดาบไป โดยมีข้อแม้ว่าเขาต้องนำอาวุธเทพเจ้าที่เหลือกลับมาให้ได้ แจ็คกี้และอลันจึงออกเดินทางไปยังยุโรป เพื่อชิงตัวหญิงสาวและนำอาวุธเทพเจ้าที่อยู่ในการครอบครองของผู้ก่อการร้ายกลับมาด้วย"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Božji oklop","runtime":0,"tagline":"","homepage":"","overview":"Jackie je bivši popularni pjevač koji je postao lovac na blago. Njegovu nekadašnju djevojku Lorelei otela je zločinačka sekta koja se želi domoći tzv. Božjeg oklopa, po predaji oklopne opreme koje su koristile snage dobra u borbi protiv snaga zla. Božji oklop sastoji se od pet dijelova, od kojih su dva u rukama sekte, a ostala tri u posjedu bogatog kolekcionara Bannona. Vođe sekte traže od Jackieja da im pribave ostala tri dijela, a on to čini na zamolbu sadašnjeg Loreleina zaručnika i svog bivšeg prijatelja Alana. Jackie i Alan nagovore Bannona da im posudi svoja tri dijela Božjeg oklopa kako bi spasili Lorelei, obećavajući da će ih vratiti neoštećene, a u akciji im se pridružuje Bannonova kćerka May."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"龍兄虎弟","runtime":0,"tagline":"","homepage":"","overview":"基督教《聖經》中記載上帝曾利用五件「上帝武裝」打敗邪魔，但後來散失在世界各地。伯爵（Bozidar Smiljanic 飾）得到了其中的三件，而邪魔的傳人得到了兩件。\r 艾倫（譚詠麟 飾）的女友羅娜（關之琳 飾）在時裝表演時，被信奉邪魔的惡僧侶擄走，贖回條件就是用伯爵的三件上帝武裝交換人質。艾倫只得找兄弟亞洲飛鷹（成龍 飾）幫忙，此時飛鷹的三件上帝武裝已經賣給了伯爵，他們不得不去伯爵府借。\r 伯爵最初不願借出上帝武裝，因此艾倫潛入伯爵府試圖偷出，但被抓獲。飛鷹向伯爵説人情，表示借用三件上帝武裝的同時，願意將邪魔陣營的另外兩件上帝武裝無償獻給伯爵，伯爵最終才同意。\r 伯爵的女兒阿美（羅拉·芳娜 飾）堅持要監視飛鷹和艾倫以上帝武裝營救人質的行動，因此也加入了營救羅娜的隊伍。於是，飛鷹、艾倫和阿美一起組隊西行歐洲，參與救人和奪寶的行動。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Áo Giáp Thượng Đế","runtime":0,"tagline":"","homepage":"","overview":"Jackie (do Thành Long thủ vai), một nhà thám hiểm và cựu ca sĩ nhạc rock nổi tiếng, được biết đến với biệt danh \"Kền kền châu Á\" (Asian Condor). Anh chuyên đi khắp thế giới để tìm kiếm và bán những cổ vật quý hiếm. Một ngày nọ, bạn gái cũ của Jackie là Laura (Rosamund Kwan) bị một giáo phái bí ẩn bắt cóc. Giáo phái này yêu cầu Jackie phải giao nộp \"Áo Giáp Thượng Đế\" - một bộ giáp cổ xưa được cho là có sức mạnh thần bí, nằm trong truyền thuyết. Thực chất, Áo Giáp Thượng Đế là một bộ sưu tập gồm nhiều mảnh giáp được cất giữ ở những nơi khác nhau trên thế giới."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"}],"reviews_tmdb":[],"recommendations":[{"id":10975,"adult":false,"title":"Operation Condor","video":false,"overview":"Hired by a Spanish baron, Hong Kong treasure hunter Jackie, a.k.a. \"Asian Hawk\" and his entourage seek WWII Nazi gold buried in the Sahara Desert.","genre_ids":[28,12,80,53],"media_type":"movie","popularity":3.1848,"vote_count":622,"poster_path":"/q6NAwJlPFb9u0G0AjMJLn0SWaLy.jpg","release_date":"1991-02-07","vote_average":7.331,"backdrop_path":"/leHpAsKAJGnNuv5EPAUZUbqrRxq.jpg","original_title":"飛鷹計劃","original_language":"cn"},{"id":21521,"adult":false,"title":"Project A Part II","video":false,"overview":"Dragon is now transferred to be the police head of Sai Wan district, and has to contend with a gangster kingpin, anti-Manchu revolutionaries, some runaway pirates, Manchu Loyalists and a corrupt police superintendent.","genre_ids":[28,35],"media_type":"movie","popularity":2.0324,"vote_count":322,"poster_path":"/oY6wOuPmeeDoKjPdPlMwwmDCYmA.jpg","release_date":"1987-07-25","vote_average":7.152,"backdrop_path":"/w46M9qW9KqOrhZPydTch6ta1RIH.jpg","original_title":"A計劃續集","original_language":"cn"},{"id":11205,"adult":false,"title":"Wheels on Meals","video":false,"overview":"Cousins Thomas and David, owners of a mobile restaurant, team up with their friend Moby, a bumbling private detective, to save the beautiful Sylvia, a pickpocket.","genre_ids":[10749,28,35,80],"media_type":"movie","popularity":2.4416,"vote_count":427,"poster_path":"/zCii0fXuI7xzroEEG1KBJDlqu0O.jpg","release_date":"1984-08-17","vote_average":6.893,"backdrop_path":"/bhJwUazhSk735vkZLkmrBeqDxSH.jpg","original_title":"快餐車","original_language":"cn"},{"id":133459,"adult":false,"title":"The Anderssons in Greece: All Inclusive","video":false,"overview":"A penny-pinching dad springs for an all-inclusive Greek vacation with his wife and three kids, who get up to plenty of antics of their own. What fun is a family vacation if you actually have to hang out with your parents the whole time?","genre_ids":[35,10751],"media_type":"movie","popularity":0.3033,"vote_count":36,"poster_path":"/aym1nUcs16ti6sZlBs3cZVQgs7L.jpg","release_date":"2012-12-25","vote_average":4.9,"backdrop_path":"/5bmbMBoVJByokQpglOZGBHyNDh9.jpg","original_title":"Sune i Grekland - all inclusive","original_language":"sv"},{"id":18632,"adult":false,"title":"A Dog's Breakfast","video":false,"overview":"If you've never been good at anything in your life, why would murder be any different? Patrick has always had a somewhat combative relationship with his little sister Marilyn, but when she brings home her new sci-fi soap star fiancé Ryan, it's all out war. When Patrick fails to drive a wedge between the happy couple, he reaches for sharper instruments.","genre_ids":[35,27],"media_type":"movie","popularity":0.4705,"vote_count":55,"poster_path":"/w1Fgu2GxGTy4I5zQN3lkMNu4z6e.jpg","release_date":"2007-03-03","vote_average":6.3,"backdrop_path":"/vnuUCpMswBNviOGbBq4QZ260Mai.jpg","original_title":"A Dog's Breakfast","original_language":"en"},{"id":377004,"adult":false,"title":"Treasure Island: Part I – Captain Flint's Map","video":false,"overview":"A Soviet Ukrainian made violent farcical yet quite faithful adaptation of the famous Robert Louis Stevenson's book that combines animated sequences with live action parts. This movie covers the first half of the book.","genre_ids":[16,12,10770,10751,10402],"media_type":"movie","popularity":0.2773,"vote_count":23,"poster_path":"/898uPP5WAhtvtl2bD6FPf8oP3Jb.jpg","release_date":"1987-10-13","vote_average":7.761,"backdrop_path":"/6ZhhKCjwixpSFiQ7VcRWBpMvW3r.jpg","original_title":"Остров сокровищ. Карта капитана Флинта","original_language":"ru"},{"id":53117,"adult":false,"title":"Don't Tell Anyone","video":false,"overview":"Based on the alleged autobiography of gay peruvian talk show host Jaime Bailey. Joaquin, a young man from the high class of Lima, deals with problems concerning his sexual identity as a child, then as a teenager pressured by his macho snobbish father, then as an independent lazy pot-smoking college student, and later as a cocaine addict in Lima and Miami.","genre_ids":[35,18],"media_type":"movie","popularity":0.4557,"vote_count":24,"poster_path":"/93fjWBuwimIffPpDQH8cbA38Gy3.jpg","release_date":"1998-07-16","vote_average":5.8,"backdrop_path":"/aAa9Cr0YkdisVbHi0O7Z5SIOwYp.jpg","original_title":"No se lo digas a nadie","original_language":"es"},{"id":12901,"adult":false,"title":"No End in Sight","video":false,"overview":"Chronological look at the fiasco in Iraq, especially decisions made in the spring of 2003 - and the backgrounds of those making decisions - immediately following the overthrow of Saddam: no occupation plan, an inadequate team to run the country, insufficient troops to keep order, and three edicts from the White House announced by Bremmer when he took over.","genre_ids":[99],"media_type":"movie","popularity":0.4585,"vote_count":90,"poster_path":"/vNLK1fRPHTHFfWfy63NJFDwX7MQ.jpg","release_date":"2007-07-27","vote_average":7.756,"backdrop_path":"/xFZT3PycLvZMM5tOLam4eMQeCy1.jpg","original_title":"No End in Sight","original_language":"en"},{"id":477016,"adult":false,"title":"Out of Blue","video":false,"overview":"Mike Hoolihan is an unconventional New Orleans cop investigating the murder of renowned astrophysicist Jennifer Rockwell, a black hole expert found shot to death in her observatory.  As Mike tumbles down the rabbit hole of the disturbing, labyrinthine case, she finds herself grappling with increasingly existential questions of quantum mechanics, parallel universes, and exploding stars. The hunt for a killer draws a detective into an even larger mystery: the nature of the universe itself.","genre_ids":[18,80,9648],"media_type":"movie","popularity":0.6395,"vote_count":84,"poster_path":"/k74DaMtAhnjeOGX6LIXsvwMStfK.jpg","release_date":"2019-03-22","vote_average":5.2,"backdrop_path":"/8nsk04y7BH6cvft5UPjbjEu8MAw.jpg","original_title":"Out of Blue","original_language":"en"},{"id":41263,"adult":false,"title":"The Brotherhood of Justice","video":false,"overview":"High-school students start a vigilante group in their neighbourhood but, as their power increases, they become more abusive and dangerous.","genre_ids":[53,28,18,80,10770],"media_type":"movie","popularity":0.9532,"vote_count":72,"poster_path":"/xXh7NVsOIIn5c4FE6apl5ToXgr0.jpg","release_date":"1986-05-18","vote_average":5.8,"backdrop_path":"/3PaRgQQiCseq7p9Fyacj2QsvPyf.jpg","original_title":"The Brotherhood of Justice","original_language":"en"},{"id":12476,"adult":false,"title":"The Hidden","video":false,"overview":"When average, law-abiding citizens suddenly turn to a life of hedonistic behavior and violent crime, Detective Tom Beck is tasked with helping young FBI agent Lloyd Gallagher determine the cause.","genre_ids":[878,28,27],"media_type":"movie","popularity":2.0023,"vote_count":468,"poster_path":"/tImKQZsw5rx5jyr70Uc3Pxym0LJ.jpg","release_date":"1987-10-30","vote_average":6.884,"backdrop_path":"/3n1iVAd7uulpQfYH5UJplzbOL8a.jpg","original_title":"The Hidden","original_language":"en"},{"id":18767,"adult":false,"title":"Island of Fire","video":false,"overview":"Someone in a prison run by a corrupt warden fakes the deaths of convicts to later use them as expendable assassins. A police officer is sent into the prison to gather evidence of the corruption.","genre_ids":[28,80,18],"media_type":"movie","popularity":2.017,"vote_count":139,"poster_path":"/1sGDNO8HlpcVmXpBxOAKEV270cI.jpg","release_date":"1990-03-28","vote_average":6.194,"backdrop_path":"/sO9PmCQtZeq7Trqxeuj5mGXXgdl.jpg","original_title":"火燒島","original_language":"cn"},{"id":12485,"adult":false,"title":"Candyman: Day of the Dead","video":false,"overview":"As the Day of the Dead celebration approaches the barrio of East Los Angeles, Caroline is challenged to control the horrifying legend of her ancestor, the \"Candyman\".","genre_ids":[27,53],"media_type":"movie","popularity":1.0788,"vote_count":266,"poster_path":"/tBhkCLtcgfccZhPU1RlyzmKVTH6.jpg","release_date":"1999-07-09","vote_average":4.549,"backdrop_path":"/5QUQvk4wfJnnR5wc4T61X2wvzwA.jpg","original_title":"Candyman: Day of the Dead","original_language":"en"},{"id":18867,"adult":false,"title":"Half a Loaf of Kung Fu","video":false,"overview":"A young daydreamer  assumes the identity of a dead martial arts hero and quickly finds himself caught up in a plot by several clans to steal famous martial arts artifacts being transported by an escort company.","genre_ids":[35,28],"media_type":"movie","popularity":1.1644,"vote_count":87,"poster_path":"/lH11m3LC8itFSTWzkS4xVYL6nB.jpg","release_date":"1978-06-30","vote_average":6.2,"backdrop_path":"/9LhDEiMxCsuJe2zGsd3l0yuUJwd.jpg","original_title":"招半式闖江湖","original_language":"zh"},{"id":98567,"adult":false,"title":"Armour of God 3: Chinese Zodiac","video":false,"overview":"Asian Hawk leads a mercenary team to recover several lost artifacts from the Old Summer Palace, the bronze heads of the twelve Chinese Zodiac animals which were sacked by the French and British armies from the imperial Summer Palace in Beijing in 1860. Assisted by a Chinese student and a Parisian woman, Hawk stops at nothing to accomplish the mission.","genre_ids":[28,12],"media_type":"movie","popularity":3.8207,"vote_count":868,"poster_path":"/rT3NsV3bgOZ1DtyVAM1GgmKtIf8.jpg","release_date":"2012-12-20","vote_average":6.2,"backdrop_path":"/xuLVW4mWU12CUtewcizdmgOQZp1.jpg","original_title":"十二生肖","original_language":"cn"},{"id":11198,"adult":false,"title":"City Hunter","video":false,"overview":"A self-indulgent private investigator winds up on a cruise ship full of rich patrons, gorgeous women, murderous terrorists, and scarce food.","genre_ids":[28,12,35,10749],"media_type":"movie","popularity":2.8883,"vote_count":444,"poster_path":"/aGJZv8h0cJWkZB1N8P2TXJycPgN.jpg","release_date":"1993-01-14","vote_average":6.6,"backdrop_path":"/fyx4nXXGsOwoHOwzfcReaTxhCB0.jpg","original_title":"城市獵人","original_language":"cn"},{"id":18764,"adult":false,"title":"Twin Dragons","video":false,"overview":"Identical twins are separated at birth, one becoming a streetwise mechanic, and the other an acclaimed classical concert conductor. Finally meeting in adulthood, they're mistaken for the other and entangled in each other's worlds.","genre_ids":[28,35,80],"media_type":"movie","popularity":2.6645,"vote_count":417,"poster_path":"/tm153lMrHy6HykEYwoP0EI3dQ8k.jpg","release_date":"1992-01-15","vote_average":6.7,"backdrop_path":"/h3vctOuLlF0V3liuTfaWVC9utKG.jpg","original_title":"双龙会","original_language":"cn"},{"id":10753,"adult":false,"title":"Police Story 2","video":false,"overview":"The Hong Kong super-cop must stop a group of blackmailing bombers at the same time that the villains of the first Police Story are out for revenge.","genre_ids":[28,80,53],"media_type":"movie","popularity":2.5097,"vote_count":605,"poster_path":"/kjq1FXtHh9i2sIuM0JaoYf43FDU.jpg","release_date":"1988-08-13","vote_average":7.078,"backdrop_path":"/f8ag2cxqaQGqvqMvThtu73pPnEM.jpg","original_title":"警察故事續集","original_language":"cn"},{"id":45408,"adult":false,"title":"The Protector","video":false,"overview":"Billy Wong is a New York City cop whose partner is gunned down during a robbery. Billy and his new partner, Danny Garoni, are working security at a fashion show when a wealthy man's daughter, Laura Shapiro, is kidnapped. The Federal authorities suspect that Laura's father is involved with Mr. Ko, a Hong Kong drug kingpin, so the NYC police commissioner sends the two cops to Hong Kong to investigate.","genre_ids":[28,80,53],"media_type":"movie","popularity":1.6754,"vote_count":196,"poster_path":"/ri2yctGQr4DPLBODZZ2Ky2yqBoL.jpg","release_date":"1985-06-15","vote_average":6,"backdrop_path":"/pXx9LJ40uM7keWCDn0izV5FwkOd.jpg","original_title":"The Protector","original_language":"en"},{"id":18707,"adult":false,"title":"Twinkle, Twinkle Lucky Stars","video":false,"overview":"The third installment in the Lucky Stars series, following Winners and Sinners and My Lucky Stars. The team are released from prison to play detective in order to stop a ruthless gang from ruining their reputations, taking their lives, and that of a key witness in an upcoming trial. They must battle their way through and with the help of Muscles, take down the bad guys.","genre_ids":[28,35],"media_type":"movie","popularity":2.8485,"vote_count":160,"poster_path":"/ojeCl4Qw4CmMP7jjpiJU4ZlbsV.jpg","release_date":"1985-08-15","vote_average":6.5,"backdrop_path":"/c09plj5Bzro6rl3FttRxcmr2oEB.jpg","original_title":"夏日福星","original_language":"cn"}],"similar_content":[{"id":672,"adult":false,"title":"Harry Potter and the Chamber of Secrets","video":false,"overview":"Cars fly, trees fight back, and a mysterious house-elf comes to warn Harry Potter at the start of his second year at Hogwarts. Adventure and danger await when bloody writing on a wall announces: The Chamber Of Secrets Has Been Opened. To save Hogwarts will require all of Harry, Ron and Hermione's magical abilities and courage.","genre_ids":[12,14],"popularity":17.7305,"vote_count":23264,"poster_path":"/sdEOH0992YZ0QSxgXNIGLq1ToUi.jpg","release_date":"2002-11-13","vote_average":7.704,"backdrop_path":"/1stUIsjawROZxjiCMtqqXqgfZWC.jpg","original_title":"Harry Potter and the Chamber of Secrets","original_language":"en"},{"id":879,"adult":false,"title":"Hook","video":false,"overview":"The boy who wasn't supposed to grow up—Peter Pan—does just that, becoming a soulless corporate lawyer whose workaholism could cost him his wife and kids. During his trip to see Granny Wendy in London, the vengeful Capt. Hook kidnaps Peter's kids and forces Peter to return to Neverland.","genre_ids":[12,14,