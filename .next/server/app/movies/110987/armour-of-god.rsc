9:{"metadata":[["$","title","0",{"children":"Armour of God | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Jackie Chan stars as Asian Hawk, an Indiana Jones-style adventurer looking to make a fortune in exotic antiquities. After Hawk discovers a mysterious sword in Africa, a band of Satan-worshipping monks kidnap his ex-girlfriend Lorelei, demanding the sword as ransom as well as other pieces of the legendary Armour of God - a magical outfit dating back to the Crusades."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/110987/armour-of-god"}],["$","meta","5",{"property":"og:title","content":"Armour of God"}],["$","meta","6",{"property":"og:description","content":"Jackie Chan stars as Asian Hawk, an Indiana Jones-style adventurer looking to make a fortune in exotic antiquities. After Hawk discovers a mysterious sword in Africa, a band of Satan-worshipping monks kidnap his ex-girlfriend Lorelei, demanding the sword as ransom as well as other pieces of the legendary Armour of God - a magical outfit dating back to the Crusades."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/110987/armour-of-god"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/7H0Qp0EqFdBIChuXrR4kEyKZyzk.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Armour of God"}],["$","meta","12",{"name":"twitter:description","content":"Jackie Chan stars as Asian Hawk, an Indiana Jones-style adventurer looking to make a fortune in exotic antiquities. After Hawk discovers a mysterious sword in Africa, a band of Satan-worshipping monks kidnap his ex-girlfriend Lorelei, demanding the sword as ransom as well as other pieces of the legendary Armour of God - a magical outfit dating back to the Crusades."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/7H0Qp0EqFdBIChuXrR4kEyKZyzk.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
