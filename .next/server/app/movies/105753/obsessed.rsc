"height":3000,"file_path":"/fYrFH2WlCEUNuR85JturV77uOBU.jpg","iso_639_1":"ko","vote_average":3.334},{"width":719,"height":1024,"file_path":"/g9qQumF9vF2aFsEv1ubxWOsvSWh.jpg","iso_639_1":"en","vote_average":1.75},{"width":2000,"height":3000,"file_path":"/6eiXKviztlWmXOHQbAQNx3cLD1k.jpg","iso_639_1":"zh","vote_average":1.75},{"width":840,"height":1200,"file_path":"/fJLe351zFTy8627K4qC32aYSrqp.jpg","iso_639_1":"zh","vote_average":0.166},{"width":1000,"height":1500,"file_path":"/AeqTU6Q6GLKkWFzRt3WbZpvLcH8.jpg","iso_639_1":"de","vote_average":0.166},{"width":1416,"height":2000,"file_path":"/zbHvt4UAuBtcRRbcx0PAw0PDKFr.jpg","iso_639_1":"zh","vote_average":0.166},{"width":640,"height":912,"file_path":"/2vzxYGRlcogOgo0kOj7gVSIbMA2.jpg","iso_639_1":"en","vote_average":0},{"width":967,"height":1378,"file_path":"/zMCeJiRbV7Z5TFA8JpALExAQra.jpg","iso_639_1":"ko","vote_average":0},{"width":919,"height":1378,"file_path":"/jBczgCbxSGbUSSN3oBTCUBtYMFo.jpg","iso_639_1":"ko","vote_average":0},{"width":1913,"height":2870,"file_path":"/8diIar2Jq23Fbvkwg0Skbo2nVD5.jpg","iso_639_1":"ko","vote_average":0},{"width":1913,"height":2870,"file_path":"/bSmy7nHcrvutVh4Bj7w0gTawRhH.jpg","iso_639_1":"ko","vote_average":0},{"width":500,"height":750,"file_path":"/txhS0ppvnqjLqvPIDySwb7vG44E.jpg","iso_639_1":"ja","vote_average":0}],"backdrops":[{"width":2033,"height":1143,"file_path":"/iGBbWXmAIgpiWg9Mx2D2gLzbg4n.jpg","iso_639_1":null,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/ty4DZapNvdFXxNd466etlk50Ubk.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/7LFB3Llb1tX2G6x6XnWlmEyE0Nh.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/helUOWdfQKwSGNOYy4S3JlFT27B.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/zvuGQQqi5SlbkUFYRLl6b5Ekg5V.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/sK8VHSRNujXpsr784Ij2J1VVfKA.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/8Z52pZTZsClkVNrgTqXzobQjwye.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/zR7TxlmEHQM2Z6z9960tKDbt8e.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/sPMIZlHeEtsEM9RZCbZ7bmaMP5N.jpg","iso_639_1":"ru","vote_average":0},{"width":3840,"height":2160,"file_path":"/kBUYw8P4L878EiGiQFDDOHXCAhI.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/1DC3F2hxAK8L9aSEm4BdqAvqG5f.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/nJEvRlhSAyisEqoiZbu65Z24oWC.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/5tdjiSgvpYUcpoLe8LuGpCgzsm7.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/aQzXICKh3oaJanWSsSRJ2epB9Z5.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/6mwOuuXhEkKibGwfRbq4OJ4NkSi.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-02-21T11:21:29.425+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Obsessed","runtime":132,"tagline":"If i cannot see you, i can't even breathe…","homepage":"http://www.obsessed.co.kr/","overview":"A secret, passionate affair happens in the summer of 1969 between Colonel Jin Pyeong, trapped in a loveless marriage with Soo Jin, and Jong Ga Heun, the Chinese-Korean wife of Captain Kyung Woo Jin."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"인간중독","runtime":132,"tagline":"누가 보면 어때요? 다 남인데...","homepage":"","overview":"베트남전이 막바지로 치달아가던 1969년, 엄격한 위계질서와 상하관계로 지배되는 군관사. 모두의 신임을 받으며 승승장구 중인 교육대장 김진평과 남편을 장군으로 만들려는 야망을 가진 진평의 아내 이숙진. 어느 날, 김진평의 부하로 충성을 맹세하는 경우진과 그의 아내 종가흔이 이사를 온다. 진평은 우진의 아내 가흔에게 첫 만남부터 강렬한 떨림을 느끼는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"人间中毒","runtime":0,"tagline":"","homepage":"","overview":"越战英雄军官金镇平（宋承宪 饰）新接收了一个部下荆宇真大卫（温朱万 饰），荆大卫的妻子钟佳欣（林智妍 饰）也随丈夫一同住进了军队官邸。镇平为佳欣的魅力所吸引无法自拔，以致发展出一段军中不伦之恋。该影片由执导过《方子传》、《淫乱书生》等影片的导演金大宇导演执导。一直以偶像形象示人的宋承宪首度挑战大尺度裸露戏份。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"1969.  Ο Συνταγματάρχης Κιμ Τζιν Πιονγκ γυρίζει σαν ήρωας πολέμου από το Βιετνάμ και ζει μια βαρετή ζωή με την σύζυγο του, ως Διοικητής εκπαίδευσης στην Κορέα.  Η βαρετή ζωή του σύντομα θα αλλάξει όταν δίπλα στο σπίτι τους μετακομίζει ο νέος λοχαγός Κιονγκ με την σύζυγο του, την Γκα Χουν.  Γρήγορα ανάμεσα τους αναπτύσσεται μια δυνατή έλξη που φτάνει στην εμμονή και που σύντομα θα φέρει καταστροφικά αποτελέσματα…"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"In-gan-jung-dok","runtime":0,"tagline":"","homepage":"","overview":"A 1969 nyarán, Kim Jin Pyeong ezredes visszatér Dél-Koreába miután Vietnamban szolgált.  Poszttraumás szindrómában szenved és csapdába esett egy szeretetlen házasságban Soo Jin-el, aki kétségbeesetten vágyik egy gyermekre. Egy éjszaka, találkozik az új szomszéddal Jong Ga Heun-el, Kyung Jin Woo kapitány kínai-koreai feleségével,aki a közelmúltban helyeztek át a katonai táborba. A katonai tábor fojtogató légkörében,a két ember titkos, szenvedélyes viszonyba keveredik egymással."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Peligrosa obsesión","runtime":90,"tagline":"","homepage":"","overview":"En el verano de 1969, el coronel Kim Jin-pyeong, atrapado en un matrimonio sin amor con Lee Suk-jin, y Jong Ga-heun, la esposa chino-coreana del capitán Kyung Woo-jin, mantienen un apasionado romance secreto."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Obsessed","runtime":132,"tagline":"","homepage":"","overview":"En traumatiserad hjälte från kriget i Vietnam tröttnar på sin barnlösa fru och inleder på basen hemma i Korea en passionerad kärleksaffär med sin servile underordnades burfågelälskande fru."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"人間中毒","runtime":132,"tagline":"每個女人，都渴望擁有個為她犧牲一切的男人","homepage":"","overview":"本片是擅長拍攝情色、電影《情慾對決》金大佑最新執導的作品，宋承憲、 趙如晶、劉海鎮、林智妍主演，這也是宋承憲第一次嘗試19禁激情裸露的電影，片中有多場露骨的床戲。1969年代，上校金鎮平（宋承憲飾演）以越戰英雄之姿重返南韓。他一直是被眾人忌妒的男人──即將榮升、擁有美麗的妻子，還有身為陸軍司令官的岳父；但事實上，他對妻子的熱情卻逐漸消褪，甚至受困於戰後創傷症候群當中。某日，金鎮平接收一位轉調而來的部下；同時，更遇見部下的妻子鐘佳欣（林智妍飾演）。這個與他同月同日生的女子，魔性魅力讓他深深著迷；在森嚴的軍隊當中，他是否願意為了這段不倫之戀放棄一切，甚至賭上性命？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Obsessed","runtime":0,"tagline":"","homepage":"","overview":"Em um acampamento militar coreano em 1969, um coronel casado se apaixona loucamente pela bela esposa de seu novo oficial subordinado."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Ám Ảnh Dục Vọng","runtime":0,"tagline":"","homepage":"","overview":"Bối cảnh của phim được lấy vào năm 1969, nội dung xoay quanh đại tá Kim Jin-Pyeong, người mới trở về Hàn Quốc sau khi đi đánh thuê cho quân đội Mỹ trong Chiến tranh Việt Nam. Anh được chỉ huy quân đội cũng là cha vợ của mình và hầu hết mọi người trong căn cứ quân sự kính trọng. Tuy nhiên, Kim Jin-Pyeong cũng gặp phải những tổn thương bên trong do hậu quả của chiến tranh.  Một ngày nọ, Kyung Woo-Jin được chuyển sang làm việc cho Kim Jin-Pyeong. Kyung Woo-Jin là kiểu người sẽ nói hoặc làm bất cứ điều gì để làm hài lòng cấp trên của mình. Chẳng bao lâu, đại tá Kim Jin-Pyeong gặp Jong Ga-Heun, vợ của cấp dưới mới của anh. Hai vợ chồng cấp dưới cũng mới chuyển đến ngôi nhà bên kia đường của nhà đại tá Kim Jin-Pyeong và vợ. Vào một buổi tối định mệnh, đại tá Kim Jin-Pyeong chơi đùa với một con chim nhốt trên hiên nhà của hàng xóm, đó cũng là khoảnh khắc mà anh và Jong Ga-Heun trao trái tim cho nhau ngay từ cái nhìn đầu tiên, để rồi phát triển một mối quan hệ vụng trộm không đúng đắn…"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Obsessed - Im Feuer der Lust","runtime":0,"tagline":"","homepage":"","overview":"Im Sommer 1969 kehrt Oberst Kim Jin Pyeong (Song Seung-heon) nach seinem Dienst in Vietnam nach Südkorea zurück. Er leidet unter einer posttraumatischen Störung und ist in einer lieblosen Ehe mit Soo Jin (Yeo-jeong Cho) gefangen, die sich verzweifelt ein Kind wünscht. Eines Abends lernt er seine neue Nachbarin Jong Ga Heun (Ji-Yeon Lim) kennen, die chinesisch-koreanische Frau von Hauptmann Kyung Woo Jin (Joo-Wan On), der vor kurzem in das Armeelager versetzt wurde. In der erdrückenden Atmosphäre des Armeelagers beginnen die beiden eine heimliche und leidenschaftliche Affäre."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Perigosa Obsessão","runtime":0,"tagline":"","homepage":"","overview":"No verão de 1969, o Coronel Jin Pyeong, preso em um casamento sem amor com Soo Jin, e Jong Ga Heun, a esposa sino-coreana do Capitão Kyung Woo Jin, têm um caso secreto e apaixonado."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"情愛中毒","runtime":0,"tagline":"","homepage":"","overview":"ベトナム戦争が終盤に差し掛かった1969年、軍の教育隊長キム・ジンピョン（ソン・スンホン）と夫を将軍にさせようという野望を持った妻イ・スクチン（チョ・ヨジョン）。ある日、キム・ジンピョンの部下として忠誠を誓うキョン・ウジン（オン・ジュワン）と彼の妻チョン・ガフン（イム・ジヨン）が引っ越してくる。ジンピョンはウジンの妻ガフンに激しく惹かれていく…。誰にも言えない秘密を抱える女性ガフンと彼女に夢中になるジンピョン。出会ってはいけなかった2人。最上流階級の軍の官舎で、誰にも言えない危険で破滅的なスキャンダルが始まる―。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"人間中毒","runtime":0,"tagline":"","homepage":"","overview":"本片是擅長拍攝情色、電影《方子傳》金大佑最新執導的作品，宋承憲、 趙如晶、劉海鎮、林智妍主演，這也是宋承憲第一次嘗試 19 禁激情裸露的電影，片中有多場露骨的床戲。1969 年代，上校金鎮平（宋承憲飾演）以越戰英雄之姿重返南韓。他一直是被眾人忌妒的男人──即將榮升、擁有美麗的妻子，還有身為陸軍司令官的嶽父；但事實上，他對妻子的熱情卻逐漸消褪，甚至受困於戰後創傷症候群當中。某日，金鎮平接收一位轉調而來的部下；同時，更遇見部下的妻子鐘佳欣（林智妍飾演）。這個與他同月同日生的女子，魔性魅力讓他深深著迷；在森嚴的軍隊當中，他是否願意為了這段不倫之戀拋棄一切，甚至賭上性命？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Obsessed","runtime":0,"tagline":"","homepage":"","overview":"En 1969. Kim Jin Pyeong est un officier ayant combattu à la guerre du Vietnam. Il revient en Corée du Sud changé. Les traumatismes de la guerre sont encore en lui et il se désintéresse de sa femme Lee Suk Jin qu'il trouve trop calculatrice et manipulatrice.\r Gyeong Wu Jin est transféré dans sa base et devient son subordonné. Lui et sa femme ont emménagé en face de chez Jin Pyeong et Suk Jin et ils deviennent donc voisins. Jin Pyeong rencontre Jong Ga Heun et tombe amoureux d'elle, seulement Ga Heun n'est d'autre que la femme de Wu Jin.\r Une liaison secrète et obsessionnelle va alors commencer entre eux."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Одержимость","runtime":132,"tagline":"","homepage":"","overview":"1969 год, война во Вьетнаме подходит к концу, офицер и герой войны полковник Ким Джин-пхён готовится получить звание генерала. Успехи на службе, счастливый брак, красивая жена — всё это не может оставить равнодушным завистников. Но на самом деле его привязанность к жене ослабла, а из-за войны он страдает от посттравматического синдрома. Однажды Джин-пхён сталкивается с женой своего капитана и влюбляется настолько сильно, что готов пожертвовать ради неё всем — и карьерой, и браком."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"In 1969. Kim Jin Pyeong is een officier die vocht in de oorlog in Vietnam. Hij keert veranderd terug naar Zuid-Korea. De trauma's van de oorlog zitten nog steeds in hem en hij verliest de interesse in zijn vrouw Lee Suk Jin, die hij te berekenend en manipulatief vindt.  Gyeong Wu Jin wordt overgebracht naar zijn basis en wordt zijn ondergeschikte. Hij en zijn vrouw gingen aan de overkant van Jin Pyeong en Suk Jin wonen, zodat ze buren werden. Jin Pyeong ontmoet Jong Ga Heun en wordt verliefd op haar, alleen Ga Heun is niemand minder dan de vrouw van Wu Jin.  Er ontstaat dan een geheime en obsessieve affaire tussen hen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Peligrosa Obsesión","runtime":132,"tagline":"","homepage":"","overview":"En el verano de 1969, el coronel Kim Jin Pyung luchó con valentía en la guerra de Vietnam. Sin embargo, vive atrapado en un matrimonio sin amor con Soo Jin. En un complejo de viviendas de la familia militar, el coronel se enamora de Jong Ga Heun, la esposa de su subordinado, y mantienen un apasionado romance secreto."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"}],"reviews_tmdb":[],"recommendations":[{"id":338803,"adult":false,"title":"The Treacherous","video":false,"overview":"The story of Joseon's tyrant king Yeonsan who exploits the populace for his own carnal pleasures, his seemingly loyal retainer who controls him and all court dealings, and a woman who seeks vengeance.","genre_ids":[18,36,80],"media_type":"movie","popularity":7.6911,"vote_count":88,"poster_path":"/1YpS9sXZ8bRrmPwULftGbfwImnR.jpg","release_date":"2015-05-21","vote_average":6.1,"backdrop_path":"/qFq2Ixo3XApoTp1H7JCTgLfGwVk.jpg","original_title":"간신","original_language":"ko"},{"id":294682,"adult":false,"title":"Little Forest: Summer/Autumn","video":false,"overview":"Fleeing heartbreak in the big city, Ichiko returns to Komori, her rural hometown. She battles summer's rain and humidity, bakes her own bread, grows hothouse tomatoes and tills the fields. During autumn, the time for pickling and preserving fish and sweet potatoes, Ichiko begins reaping rice and recalls her departure five years before.","genre_ids":[18],"media_type":"movie","popularity":1.4745,"vote_count":117,"poster_path":"/8O5h2aSJsJCLeHM6O8jZYGvzdHd.jpg","release_date":"2014-08-30","vote_average":7.744,"backdrop_path":"/1bAE9YexmEfAanXKaO1d9Ms4qKm.jpg","original_title":"リトル・フォレスト 夏・秋","original_language":"ja"},{"id":122126,"adult":false,"title":"The Concubine","video":false,"overview":"Living a torturous life of poverty and barely able to survive, Hwa-yeon decides to offer herself as one of the king’s concubines. Once inside the royal palace, two men are immediately seized by the woman - the Grand Prince Seong-won, a megalomaniacal ruler drunk with power and lust, and Kwon-yoo, who has everything to lose if his desire for Hwa-yeon is exposed.","genre_ids":[18],"media_type":"movie","popularity":5.7806,"vote_count":108,"poster_path":"/cLT2eYXoDSXWkqJQcDqVinxIkf0.jpg","release_date":"2012-06-06","vote_average":5.833,"backdrop_path":"/zgx6bBaVLAsFO5ip7gwndOjhE7U.jpg","original_title":"후궁: 제왕의 첩","original_language":"ko"},{"id":1089223,"adult":false,"title":"Revolver","video":false,"overview":"Su-young, a police detective who went to prison for someone else, is surprised when a mysterious woman named Yoon-sun arrives to collect her on her day of release. As she discovers that the promised compensation for her time behind bars has vanished, Su-young embarks on a mission to reclaim what rightfully belongs to her.","genre_ids":[80,53],"media_type":"movie","popularity":1.4037,"vote_count":37,"poster_path":"/hOYoIVY2DQdOkcLw0sEt9jFLvUj.jpg","release_date":"2024-08-07","vote_average":5.5,"backdrop_path":"/iBrvaJcVNc3boMqKGr4gyYAwemW.jpg","original_title":"리볼버","original_language":"ko"},{"id":442014,"adult":false,"title":"One-Line","video":false,"overview":"A group of professional con artists scam poor, unsuspecting citizens with fraudulent bank loans. The scams go well for a while, but then they begin to distrust each other.","genre_ids":[80,53],"media_type":"movie","popularity":1.1126,"vote_count":36,"poster_path":"/qcWnGBLJwQeSKAxAINmtDHf6WNG.jpg","release_date":"2017-03-29","vote_average":6.6,"backdrop_path":"/z0TF6eijRsu22EdamavqAzeRfIN.jpg","original_title":"원라인","original_language":"ko"},{"id":347642,"adult":false,"title":"Bite","video":false,"overview":"While on her bachelorette party getaway, Casey, the bride to be, gets a seemingly harmless bite from an unknown insect. After returning home with cold feet, Casey tries to call off her wedding but before she's able to, she starts exhibiting insect like traits. Between her physical transformation and her wedding anxiety, Casey succumbs to her new instincts and begins creating a hive that not only houses her translucent eggs, but feeds on the flesh of others. As her transformation becomes complete, Casey discovers that everything can change with a single bite.","genre_ids":[27],"media_type":"movie","popularity":0.5598,"vote_count":187,"poster_path":"/oHoqxVKgXUiz0gGQ23AZPPLgUXd.jpg","release_date":"2015-07-29","vote_average":5.537,"backdrop_path":"/qhrGfvWueot3aI3yV2pK824hMub.jpg","original_title":"Bite","original_language":"en"},{"id":52418,"adult":false,"title":"Fate","video":false,"overview":"Four friends bound by destiny and unbeatable in the dark world. When a casino attack goes wrong as a result of betrayal, fate turns them into enemies. Now, forced to aim the gun at each other's hearts, their unavoidable battle begins.","genre_ids":[28,53,80],"media_type":"movie","popularity":0.71,"vote_count":30,"poster_path":"/k8vW7jMXak5tfoD02jOrmVmB7Hz.jpg","release_date":"2008-03-20","vote_average":5.717,"backdrop_path":"/vMVa0M12i61w7PB9nyr6eOa7tn7.jpg","original_title":"숙명","original_language":"ko"},{"id":999127,"adult":false,"title":"Broad Peak","video":false,"overview":"After climbing Broad Peak mountain, Maciej Berbeka learns his journey to the summit is incomplete. 25 years later, he sets out to finish what he started.","genre_ids":[18,36],"media_type":"movie","popularity":0.4649,"vote_count":60,"poster_path":"/n7eiUpUb27Vpd3MBfLro9rkUo0F.jpg","release_date":"2022-09-09","vote_average":5.825,"backdrop_path":"/mssCqICnOv70yv0JHsCgaFvMAMe.jpg","original_title":"Broad Peak","original_language":"pl"},{"id":248360,"adult":false,"title":"Under the Rose","video":false,"overview":"James Wong and his female assistant visited various kinds of pleasure-houses, including invisible dens, high-tech private dens, smuggling blackpoints and famouse tryst places, both large and small ones, throughout Hong Kong. They also looked back to the Scientific Beauty in Lai Chi Kok Amusement Park, striptease in the Kowloon Walled City and the old stories in fish-ball stalls. There are also interviews of call-girls and grooms.","genre_ids":[99],"media_type":"movie","popularity":0.3528,"vote_count":4,"poster_path":"/agkHHwwfSF3ny8BCyDh9c1plYRX.jpg","release_date":"1992-06-17","vote_average":6.5,"backdrop_path":"/hEtkuYa387cJrDMgFjQwjm0uosB.jpg","original_title":"大咸濕","original_language":"cn"},{"id":64222,"adult":false,"title":"Marriage Is a Crazy Thing","video":false,"overview":"Joon-yeong is a Korean professor of English literature and confirmed bachelor. But when he meets Yeon-hee on a blind date, his days of bachelorhood seem numbered.","genre_ids":[18,10749],"media_type":"movie","popularity":1.3765,"vote_count":37,"poster_path":"/tQG2mfXzKfn5vdEwx5iVh3jGiGG.jpg","release_date":"2002-04-26","vote_average":6.473,"backdrop_path":"/5f6BvtEnpee3cA0WAkZj65gfP8v.jpg","original_title":"결혼은, 미친 짓이다","original_language":"ko"},{"id":1327683,"adult":false,"title":"Not Like Dad 2: Granddad","video":false,"overview":"On the verge of divorce, Max comes to his ex Irina's to pick up his son Dima for the autumn holidays, but then it turns out that the child has run away from home. The worried parents set off in search in the car of family psychologist/Irina's part-time boyfriend Vlad. Learning that Dima ran away to the village to Max's father, Bata, Max recalls, on the drive, how his parents, during their divorce, sent him to the village, about their life together, his first love and childhood friends.","genre_ids":[35,18],"media_type":"movie","popularity":0.325,"vote_count":9,"poster_path":"/nJXVFPNVnWKqPWBzbAgO8UZaLdk.jpg","release_date":"2025-04-03","vote_average":6.222,"backdrop_path":"/9NrMvX4nC5Mu0huvOFZRo4TpFwu.jpg","original_title":"Батя 2: Дед","original_language":"ru"},{"id":30471,"adult":false,"title":"Spiderbabe","video":false,"overview":"A socially awkward young woman gets bitten by a radioactive spider and becomes a crime-fighting superhero and tries to defeat a nefarious super villain while going after any man (or woman) she wants to bed down with.","genre_ids":[28,35,878],"media_type":"movie","popularity":0.687,"vote_count":37,"poster_path":"/mh7oL7A43NvNy1o5O2CouyoQTKl.jpg","release_date":"2003-10-14","vote_average":4.432,"backdrop_path":"/z9aMQn1ciokeMvY2gVBgtZ8gu2.jpg","original_title":"Spiderbabe","original_language":"en"},{"id":220265,"adult":false,"title":"Horny Family","video":false,"overview":"From the outside, the Suhs seem like a loving, cookie-cutter, middle-class family with their lives in perfect order. In reality, everyone is hiding some secrets. The father has the hots for a young grad student. The mother is flirting around with a photographer she's posing for. The daughter is engaged but has a sex partner on the side. The son has a girlfriend, but he's been stalking the same student his father likes! What will happen to this perfect family when the secrets spill?","genre_ids":[10749,35],"media_type":"movie","popularity":0.9716,"vote_count":8,"poster_path":"/yNEmnoMj8hOPtPoXghy9KQtsiZe.jpg","release_date":"2013-01-17","vote_average":4.4,"backdrop_path":"/vGpU5qHz6wlvYqJhfS7wheKg7dc.jpg","original_title":"배꼽","original_language":"ko"},{"id":472516,"adult":false,"title":"The Moment You Fall in Love","video":false,"overview":"Following Natsuki Enomoto's confession rehearsals with Yuu Setoguchi, their younger siblings Kotarou and Hina struggle to confess their own love. Despite a disastrous first meeting in middle school with her upperclassman Koyuki Ayase, Hina’s heart is captured by his warm smile. Initially confused by these newfound feelings, Hina soon realizes that she has fallen in love for the very first time.  Chasing after her brother Yuu and her crush Koyuki, Hina also enrolls in Sakuragaoka High School; but the threads of love are far-reaching, and they entangle Hina and her friends. Boisterous but sensitive, Hina hopes to confess her feelings to the tender-hearted Koyuki. Meanwhile, Kotarou, oblivious to his own feelings for her, is determined to always keep Hina smiling.  This movie follows Hina, Kotarou, and Koyuki in high school. Their youthful love forges new relationships, but also threatens to break others.","genre_ids":[18,16,10749,35],"media_type":"movie","popularity":1.117,"vote_count":137,"poster_path":"/b3NQEmgAYKTDuAXSE0f294lrE4Q.jpg","release_date":"2016-12-17","vote_average":7.5,"backdrop_path":"/lTbYegQ35QRWlWvDqYwS0okFiY4.jpg","original_title":"好きになるその瞬間を。～告白実行委員会～","original_language":"ja"},{"id":165213,"adult":false,"title":"New World","video":false,"overview":"An undercover cop has his loyalties tested when the boss of the corporate gang he's spent years infiltrating dies.","genre_ids":[53,80,18],"media_type":"movie","popularity":5.7353,"vote_count":520,"poster_path":"/5Ai3BMJlDGOlZXbcDv3vnOM1CSp.jpg","release_date":"2013-02-21","vote_average":7.426,"backdrop_path":"/6UnVwCA6F29erZK29PKqRyHqFA.jpg","original_title":"신세계","original_language":"ko"},{"id":4588,"adult":false,"title":"Lust, Caution","video":false,"overview":"During World War II, a secret agent must seduce and assassinate an official who works for the Japanese puppet government in Shanghai.","genre_ids":[28,18,10749,53],"media_type":"movie","popularity":7.5379,"vote_count":775,"poster_path":"/6c1tqfJEBuIyhQC19SLlLQAUAvJ.jpg","release_date":"2007-09-24","vote_average":7.25,"backdrop_path":"/lU1fQews2gye23PocVE48CsTmOQ.jpg","original_title":"色‧戒","original_language":"zh"},{"id":462919,"adult":false,"title":"Sierra Burgess Is a Loser","video":false,"overview":"A case of mistaken identity results in unexpected romance when the most popular girl in high school and the biggest loser must come together to win over their crushes.","genre_ids":[35,18,10749],"media_type":"movie","popularity":1.1314,"vote_count":3452,"poster_path":"/vjnHRySiVM4YcBYzjCxw344y9g.jpg","release_date":"2018-09-07","vote_average":6.288,"backdrop_path":"/fdFIVBpq57ZbHok07SI3gNLWUbO.jpg","original_title":"Sierra Burgess Is a Loser","original_language":"en"},{"id":695721,"adult":false,"title":"The Hunger Games: The Ballad of Songbirds & Snakes","video":false,"overview":"64 years before he becomes the tyrannical president of Panem, Coriolanus Snow sees a chance for a change in fortunes when he mentors Lucy Gray Baird, the female tribute from District 12.","genre_ids":[878,28],"media_type":"movie","popularity":7.6668,"vote_count":3385,"poster_path":"/lrkOYL5GBTFW9cgs9RlojxAcZZF.jpg","release_date":"2023-11-15","vote_average":6.992,"backdrop_path":"/8GnWDLn2AhnmkQ7hlQ9NJUYobSS.jpg","original_title":"The Hunger Games: The Ballad of Songbirds & Snakes","original_language":"en"},{"id":785084,"adult":false,"title":"The Whale","video":false,"overview":"A reclusive English teacher suffering from severe obesity attempts to reconnect with his estranged teenage daughter for one last chance at redemption.","genre_ids":[18],"media_type":"movie","popularity":5.1849,"vote_count":4499,"poster_path":"/jQ0gylJMxWSL490sy0RrPj1Lj7e.jpg","release_date":"2022-12-09","vote_average":7.779,"backdrop_path":"/46FRuCeAn6TrS4F1P4F9zhyCpyo.jpg","original_title":"The Whale","original_language":"en"},{"id":156022,"adult":false,"title":"The Equalizer","video":false,"overview":"McCall believes he has put his mysterious past behind him and dedicated himself to beginning a new, quiet life. But when he meets Teri, a young girl under the control of ultra-violent Russian gangsters, he can’t stand idly by – he has to help her. Armed with hidden skills that allow him to serve vengeance against anyone who would brutalize the helpless, McCall comes out of his self-imposed retirement and finds his desire for justice reawakened. If someone has a problem, if the odds are stacked against them, if they have nowhere else to turn, McCall will help. He is The Equalizer.","genre_ids":[53,28,80],"media_type":"movie","popularity":16.5484,"vote_count":9748,"poster_path":"/9u4yW7yPA0BQ2pv9XwiNzItwvp8.jpg","release_date":"2014-09-24","vote_average":7.281,"backdrop_path":"/wNAfVj1ObGNye5fQM4tJXJGtU0.jpg","original_title":"The Equalizer","original_language":"en"}],"similar_content":[{"id":2054,"adult":false,"title":"Mr. Holland's Opus","video":false,"overview":"In 1965, passionate musician Glenn Holland takes a day job as a high school music teacher, convinced it's just a small obstacle on the road to his true calling: writing a historic opus. As the decades roll by with the composition unwritten but generations of students inspired through his teaching, Holland must redefine his life's purpose.","genre_ids":[18,10402],"popularity":1.1019,"vote_count":441,"poster_path":"/kBmwWeSN3ajnYHZ3dSybEobxEPI.jpg","release_date":"1995-12-29","vote_average":6.954,"backdrop_path":"/oUptKQLatCgywVDx0ETVhq7knHt.jpg","original_title":"Mr. Holland's Opus","original_language":"en"},{"id":1293968,"adult":false,"title":"Hero's Island","video":false,"overview":"Set in post-war Okinawa, Japan, Gusuku had 3 close childhood friends: On, Yamako and On's younger brother Rei. On was the oldest of the group and he was like a leader to everybody else. He was also a heroic figure to them. On led his friends into the U.S. military base and they stole supplies to give away to the local residents. Everybody in the neighborhood praised On. One night, they entered the U.S. military based to steal supplies. During their raid, On was chased by U.S. soldiers and went missing. Years later, Gusuku now works as a police officer. Yamako is an elementary school teacher. Rei is a member of the yakuza. These three people are still unable to get over the disappearance of On. They chase after the truth behind On's disappearance and uncover a shocking answer.","genre_ids":[18],"popularity":1.0103,"vote_count":5,"poster_path":"/aX5G8rimkQmnDkNP3IGBI4bqTNk.jpg","release_date":"2025-09-19","vote_average":9.4,"backdrop_path":"/6Nx5e2gW12LKnTdRBv0xl4Qd6eo.jpg","original_title":"宝島","original_language":"ja"},{"id":881,"adult":false,"title":"A Few Good Men","video":false,"overview":"When cocky military lawyer Lt. Daniel Kaffee and his co-counsel, Lt. Cmdr. JoAnne Galloway, are assigned to a murder case, they uncover a hazing ritual that could implicate high-ranking officials such as shady Col. Nathan Jessep.","genre_ids":[18],"popularity":5.176,"vote_count":4028,"poster_path":"/rLOk4z9zL1tTukIYV56P94aZXKk.jpg","release_date":"1992-12-11","vote_average":7.542,"backdrop_path":"/H40nWdJngUc6gtytMAbElm9HOu.jpg","original_title":"A Few Good Men","original_language":"en"},{"id":792,"adult":false,"title":"Platoon","video":false,"overview":"As a young and naive recruit in Vietnam, Chris Taylor faces a moral crisis when confronted with the horrors of war and the duality of man.","genre_ids":[18,10752,28],"popularity":7.8196,"vote_count":4968,"poster_path":"/m3mmFkPQKvPZq5exmh0bDuXlD9T.jpg","release_date":"1986-12-19","vote_average":7.743,"backdrop_path":"/xywFHPls3rMTiRtZUhrCghMCsMe.jpg","original_title":"Platoon","original_language":"en"},{"id":801,"adult":false,"title":"Good Morning, Vietnam","video":false,"overview":"A disk jockey goes to Vietnam to work for the Armed Forces Radio Service. While he becomes popular among the troops, his superiors disapprove of his humor.","genre_ids":[35,18,10752],"popularity":3.2434,"vote_count":2935,"poster_path":"/sreISlFUn5TyR41QNjlfAdX5SEW.jpg","release_date":"1987-12-23","vote_average":7.305,"backdrop_path":"/mbgJEkrJ0uBOakLwpufdmW4K8Im.jpg","original_title":"Good Morning, Vietnam","original_language":"en"},{"id":820,"adult":false,"title":"JFK","video":false,"overview":"Follows the investigation into the assassination of President John F. Kennedy led by New Orleans district attorney Jim Garrison.","genre_ids":[18,53,36],"popularity":4.3598,"vote_count":2339,"poster_path":"/r0VWVTYlqdRCK5ZoOdNnHdqM2gt.jpg","release_date":"1991-12-20","vote_average":7.602,"backdrop_path":"/lGJxJQCiEeaoXAoQUvBcv6lRa7U.jpg","original_title":"JFK","original_language":"en"},{"id":838,"adult":false,"title":"American Graffiti","video":false,"overview":"A couple of high school graduates spend one final night cruising the strip with their buddies before they go off to college.","genre_ids":[35,18],"popularity":2.9161,"vote_count":1545,"poster_path":"/1tjLivPad2PX8FAzWko7FPIb8d2.jpg","release_date":"1973-08-11","vote_average":7.033,"backdrop_path":"/xdofxnT2FADbSFOJflOTLnCoZe9.jpg","original_title":"American Graffiti","original_language":"en"},{"id":842,"adult":false,"title":"The Assassination of Richard Nixon","video":false,"overview":"It’s 1974 and Sam Bicke has lost everything. His wife leaves him with his three kids, his boss fires him, his brother turns away from him, and the bank won’t give him any money to start anew. He tries to find someone to blame for his misfortunes and comes up with the President of the United States who he plans to murder.","genre_ids":[18,36,53,80],"popularity":0.7546,"vote_count":299,"poster_path":"/5jOOvAVvP0XtwC5yYQpQCy4cjq1.jpg","release_date":"2004-05-17","vote_average":6.498,"backdrop_path":"/mhMBrMEzG7eMVmOeBSmZUjH5Yu0.jpg","original_title":"The Assassination of Richard Nixon","original_language":"en"},{"id":843,"adult":false,"title":"In the Mood for Love","video":false,"overview":"Two neighbors form a strong bond after both suspect extramarital activities of their spouses. However, they agree to keep their bond platonic so as not to commit similar wrongs.","genre_ids":[18,10749],"popularity":6.7222,"vote_count":3158,"poster_path":"/iYypPT4bhqXfq1b6EnmxvRt6b2Y.jpg","release_date":"2000-09-29","vote_average":8.092,"backdrop_path":"/ffQFnAUm2Uu4RU0nijpjPRf9TBT.jpg","original_title":"花樣年華","original_language":"cn"},{"id":851,"adult":false,"title":"Brief Encounter","video":false,"overview":"Returning home from a shopping trip to a nearby town, bored suburban housewife Laura Jesson is thrown by happenstance into an acquaintance with virtuous doctor Alec Harvey. Their casual friendship soon develops during their weekly visits into something more emotionally fulfilling than either expected, and they must wrestle with the potential havoc their deepening relationship would have on their lives and the lives of those they love.","genre_ids":[18,10749],"popularity":3.8208,"vote_count":691,"poster_path":"/jC9EwLJcGhYMSQAHu2LxkKN5v7O.jpg","release_date":"1945-11-24","vote_average":7.698,"backdrop_path":"/vKvoOlhhaZCsiGQDvaZQqyGq1oA.jpg","original_title":"Brief Encounter","original_language":"en"},{"id":403,"adult":false,"title":"Driving Miss Daisy","video":false,"overview":"The story of an old Jewish widow named Daisy Werthan and her relationship with her black chauffeur, Hoke. From an initial mere work relationship grew in 25 years a strong friendship between the two very different characters, in a time when those types of relationships were shunned.","genre_ids":[18],"popularity":2.0411,"vote_count":1732,"poster_path":"/iaCzvcY42HihFxQBTZCTKMpsI0P.jpg","release_date":"1989-12-13","vote_average":7.235,"backdrop_path":"/4XC0HwRNOvub6xksENsOl68zHOn.jpg","original_title":"Driving Miss Daisy","original_language":"en"},{"id":284,"adult":false,"title":"The Apartment","video":false,"overview":"Bud Baxter is a minor clerk in a huge New York insurance company, until he discovers a quick way to climb the corporate ladder. He lends out his apartment to the executives as a place to take their mistresses. Although he often has to deal with the aftermath of their visits, one night he's left with a major problem to solve.","genre_ids":[35,18,10749],"popularity":4.285,"vote_count":2578,"poster_path":"/hhSRt1KKfRT0yEhEtRW3qp31JFU.jpg","release_date":"1960-06-21","vote_average":8.19,"backdrop_path":"/2L8U8rUyWeFTb6n1egTNeJsEsvj.jpg","original_title":"The Apartment","original_language":"en"},{"id":311,"adult":false,"title":"Once Upon a Time in America","video":false,"overview":"A former Prohibition-era Jewish gangster returns to the Lower East Side of Manhattan over thirty years later, where he once again must confront the ghosts and regrets of his old life.","genre_ids":[18,80],"popularity":9.7373,"vote_count":5901,"poster_path":"/i0enkzsL5dPeneWnjl1fCWm6L7k.jpg","release_date":"1984-05-23","vote_average":8.387,"backdrop_path":"/xlDUjb0Q5Dv6jPQRF5VE4IMjIy.jpg","original_title":"Once Upon a Time in America","original_language":"en"},{"id":337,"adult":false,"title":"Monsieur Ibrahim","video":false,"overview":"Paris, 1960s. Momo, a resolute and independent Jewish teenager who lives with his father, a sullen and depressed man, in a working-class neighborhood, develops a close friendship with Monsieur Ibrahim, an elderly Muslim who owns a small grocery store.","genre_ids":[18],"popularity":0.8715,"vote_count":159,"poster_path":"/lS4hx9X5v6cpoCzzQohZs7zD881.jpg","release_date":"2003-09-17","vote_average":7.013,"backdrop_path":"/56uYFEyonCvjlM3lpPchy1LRruH.jpg","original_title":"Monsieur Ibrahim et les Fleurs du Coran","original_language":"fr"},{"id":434973,"adult":false,"title":"Blindfolded","video":false,"overview":"Two 9-year-old boys, Jontti and Länki, grow up in a Finnish seaside town in the 1960s. Länki's biggest dream is to run away on a ship to the sea where his father is rumoured to have died. Jontti too must discover that his father is not what he appears to be. When his dad moves away with another woman, Jontti is determined to win him back.","genre_ids":[18,35],"popularity":0.5257,"vote_count":