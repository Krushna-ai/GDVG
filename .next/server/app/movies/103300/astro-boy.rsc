9:{"metadata":[["$","title","0",{"children":"Astro Boy | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Set in the futuristic Metro City, Astro Boy (Atom) is a young robot with incredible powers created by a brilliant scientist in the image of the son he had lost. Unable to fulfill his creator's expectations, Astro embarks on a journey in search of acceptance, experiencing betrayal and a netherworld of robot gladiators, before returning to save Metro City and reconcile with the father who rejected him."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/103300/astro-boy"}],["$","meta","5",{"property":"og:title","content":"Astro Boy"}],["$","meta","6",{"property":"og:description","content":"Set in the futuristic Metro City, Astro Boy (Atom) is a young robot with incredible powers created by a brilliant scientist in the image of the son he had lost. Unable to fulfill his creator's expectations, Astro embarks on a journey in search of acceptance, experiencing betrayal and a netherworld of robot gladiators, before returning to save Metro City and reconcile with the father who rejected him."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/103300/astro-boy"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/6AK3uOHaIbl6EDaytHYe4FinZMu.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Astro Boy"}],["$","meta","12",{"name":"twitter:description","content":"Set in the futuristic Metro City, Astro Boy (Atom) is a young robot with incredible powers created by a brilliant scientist in the image of the son he had lost. Unable to fulfill his creator's expectations, Astro embarks on a journey in search of acceptance, experiencing betrayal and a netherworld of robot gladiators, before returning to save Metro City and reconcile with the father who rejected him."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/6AK3uOHaIbl6EDaytHYe4FinZMu.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
