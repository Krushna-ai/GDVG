5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Astro Boy\",\"description\":\"Set in the futuristic Metro City, Astro Boy (Atom) is a young robot with incredible powers created by a brilliant scientist in the image of the son he had lost. Unable to fulfill his creator's expectations, Astro embarks on a journey in search of acceptance, experiencing betrayal and a netherworld of robot gladiators, before returning to save Metro City and reconcile with the father who rejected him.\",\"image\":\"https://image.tmdb.org/t/p/w500/6AK3uOHaIbl6EDaytHYe4FinZMu.jpg\",\"datePublished\":\"2009-10-15\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"US\",\"inLanguage\":\"en\",\"genre\":[\"adventure film\",\"science fiction film\",\"action film\",\"children's film\",\"Animation\",\"Action\",\"Family\",\"Science Fiction\",null,null,null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.33,\"bestRating\":10,\"ratingCount\":1608}}"}}],["$","$L10",null,{"initialDrama":{"id":"c4c2f5a5-3c04-472b-8c05-f4c9052d3c3c","tmdb_id":16577,"imdb_id":"tt0375568","content_type":"movie","title":"Astro Boy","original_title":"Astro Boy","overview":"Set in the futuristic Metro City, Astro Boy (Atom) is a young robot with incredible powers created by a brilliant scientist in the image of the son he had lost. Unable to fulfill his creator's expectations, Astro embarks on a journey in search of acceptance, experiencing betrayal and a netherworld of robot gladiators, before returning to save Metro City and reconcile with the father who rejected him.","poster_path":"/6AK3uOHaIbl6EDaytHYe4FinZMu.jpg","backdrop_path":"/t39jaNSYMVNecNPQSVVlW6I4opm.jpg","release_date":"2009-10-15","first_air_date":null,"status":"published","original_language":"en","origin_country":["US","HK"],"genres":[{"name":"adventure film"},{"name":"science fiction film"},{"name":"action film"},{"name":"childr