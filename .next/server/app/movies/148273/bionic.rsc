ount":10,"aspect_ratio":1.778,"vote_average":0.5},{"width":3840,"height":2160,"file_path":"/8jFJ43oCs8wYuOS6pXXNmsN0qQP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":10,"aspect_ratio":1.778,"vote_average":0.5},{"width":3840,"height":2160,"file_path":"/4AGJXTU1eDK5uWsLYIX6bxK8l4C.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":10,"aspect_ratio":1.778,"vote_average":0.5},{"width":3840,"height":2160,"file_path":"/3F6AvM9WIMxK9TjzfOF0ES0wR2t.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":10,"aspect_ratio":1.778,"vote_average":0.5},{"width":3840,"height":2160,"file_path":"/8rCmqMiwUBBhiIt4qxb3DUDbr9y.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":10,"aspect_ratio":1.778,"vote_average":0.5},{"width":3840,"height":2160,"file_path":"/iYImUVT13zJpNBHkAB848sRZCWS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":10,"aspect_ratio":1.778,"vote_average":0.5},{"width":2048,"height":1152,"file_path":"/ziFmBrdEkzhxIluwGoPixZqxYiw.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:01:12.748+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Bionic","runtime":110,"tagline":"","homepage":"https://www.netflix.com/title/81406459","overview":"When the progress of robotics makes Paralympic athletes the new sports stars, Maria dreams of competing against her sister. For that, she will have to enter a world of crime and violence."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":110,"tagline":"O ano é 2035 e o mundo mudou.","homepage":"https://www.netflix.com/title/81406459","overview":"Em um futuro distópico em que as próteses robóticas dominam os esportes, duas irmãs competem no salto em distância. Só que essa rivalidade leva a um caminho sinistro."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"바이오닉","runtime":0,"tagline":"","homepage":"https://www.netflix.com/kr/title/81406459","overview":"로봇 보철물의 발전으로 스포츠 혁명이 일어난 미래의 디스토피아 세계. 멀리뛰기 종목에서 라이벌 관계인 두 자매가 과도한 경쟁심으로 인해 불길한 상황으로 내몰린다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Bionic: เหนือมนุษย์","runtime":110,"tagline":"","homepage":"","overview":"ในโลกอนาคตอันเสื่อมทราม ซึ่งแวดวงกีฬาเปลี่ยนแปลงไปเพราะการใช้อวัยวะกล พี่น้องคู่หนึ่งลงแข่งขันกระโดดไกล แต่การขับเคี่ยวครั้งนี้อาจนำทั้งคู่ไปสู่เส้นทางหายนะ"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"仿生超極限","runtime":0,"tagline":"","homepage":"","overview":"在反烏托邦的未來世界，機械義肢讓體育界重新洗牌，兩姊妹參與跳遠比賽，卻因相互競爭而走上惡途。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Bionic","runtime":0,"tagline":"","homepage":"","overview":"V dystopické budoucnosti převrátí robotické protézy svět sportu naruby. Dvě soutěživé sestry se utkají ve skoku dalekém, ale vzájemná rivalita je svede na scestí."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Képességeink határa","runtime":110,"tagline":"","homepage":"https://www.netflix.com/hu/title/81406459","overview":"A sivár jövőben, ahol a sporteredményeket már bionikus végtagok határozzák meg, egy testvérpár távolugrásban versenyez, ám rivalizálásuk sötét fordulatot hoz."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Sinh Hóa","runtime":0,"tagline":"","homepage":"","overview":"Bộ phim lấy bối cảnh tương lai, khi công nghệ robot đã làm thay đổi hoàn toàn thể thao, biến các vận động viên Paralympic trở thành những siêu sao mới.Hai chị em Gabi và Maria, những người cạnh tranh trong môn nhảy xa với sự hỗ trợ của các cấy ghép sinh hóa. Tuy nhiên, sự cạnh tranh này không chỉ dừng lại ở sân thi đấu mà còn lan sang thế giới tội phạm và bạo lực, đưa ra nhiều câu hỏi về đạo đức và tác động của công nghệ đối với thể thao và cuộc sống"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"仿生超极限","runtime":110,"tagline":"","homepage":"","overview":"在机器人假肢重新定义体育运动的反乌托邦的未来，两姐妹参加跳远比赛，但相互之间的较量却使她们走上险恶的道路。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Bionički ljudi","runtime":0,"tagline":"","homepage":"","overview":"U distopijskoj budućnosti u kojoj je robotska protetika potpuno preobrazila sportove, dvije sestre natječu se u skoku u dalj. No zbog tog suparništva pođu mračnim putem."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Biónicos","runtime":110,"tagline":"","homepage":"https://www.netflix.com/es/title/81406459","overview":"Dos hermanas compiten en salto de longitud en un futuro distópico en el que las prótesis robóticas han redefinido el deporte. Su rivalidad las lleva por un siniestro camino."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"仿生超極限","runtime":0,"tagline":"","homepage":"","overview":"跳遠選手瑪莉亞憎恨妹妹在運動場上成就過人，當一個幫派領袖對她提出危險邀約，瑪莉亞的世界從此天翻地覆。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Bionic","runtime":0,"tagline":"","homepage":"https://www.netflix.com/title/81406459","overview":"Dans un futur dystopique où les prothèses robotiques ont redéfini le sport, deux sœurs s'affrontent au saut en longueur. Mais leur rivalité les conduit sur un chemin dangereux."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Bionic","runtime":0,"tagline":"","homepage":"","overview":"W dystopijnej przyszłości, w której oblicze sportu zmieniają protezy upodabniające ludzi do robotów, rywalizacja dwóch sióstr w skoku w dal prowadzi je na złą drogę."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Bionische Schwestern","runtime":110,"tagline":"","homepage":"","overview":"In einer dystopischen Zukunft, in der bionische Prothesen den Sport bestimmen, führt die Rivalität zweier Schwestern im Weitsprung die beiden auf einen unheilvollen Weg."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Biyonik","runtime":110,"tagline":"","homepage":"","overview":"Robot protez uzuvların sporu yeniden tanımladığı distopik bir gelecekte uzun atlama dalında birbirleriyle yarışan iki kız kardeşin rekabeti, onları uğursuz bir yola sevk eder."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Bionici","runtime":0,"tagline":"","homepage":"","overview":"Într-un viitor distopic în care protezele robotice redefinesc sportul, două surori concurează la săritura în lungime, dar rivalitatea lor le conduce pe o cale sinistră."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"ביוניים","runtime":0,"tagline":"","homepage":"","overview":"בעתיד דיסטופי שבו פרוטזות רובוטיות מגדירות מחדש את עולם הספורט, שתי אחיות מתחרות בקפיצה לרוחק – אבל היריבות ביניהן עלולה לעלות להן ביוקר."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Біоніка","runtime":0,"tagline":"","homepage":"","overview":"В антиутопічному майбутньому, де роботизовані протези кардинально змінюють спорт, дві сестри змагаються в стрибках у довжину. Але суперництво веде їх небезпечним шляхом."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Bionic","runtime":110,"tagline":"","homepage":"https://www.netflix.com/it/title/81406459","overview":"La storia è ambientata in un futuro dove gli avanzamenti tecnologici e scientifici hanno portato grandi innovazioni nel campo della robotica e tra i tanti upgrade, le protesi sono ormai incredibilmente sofisticate, al punto da portare gli atleti disabili a essere delle vere e proprie star.  Maria, disabile e atleta, vuole competere contro sua sorella, ma per farlo si ritroverà ad entrare in un mondo di crimine e violenza."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"バイオニック","runtime":110,"tagline":"","homepage":"https://www.netflix.com/jp/title/81406459","overview":"ロボット義肢によりスポーツのあり方が大きく塗り替えられた暗黒の近未来。走り幅跳びの選手として競い合う2人の姉妹は、ライバル心に翻弄され、不穏な世界に足を踏み入れていく。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Wanneer de vooruitgang van de robotica van paralympische atleten de nieuwe sportsterren maakt, droomt Maria ervan om tegen haar zus te strijden. Daarvoor zal ze een wereld van misdaad en geweld moeten betreden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Biónicos","runtime":110,"tagline":"","homepage":"https://www.netflix.com/mx/title/81406459","overview":"En un futuro distópico en el que las prótesis robóticas redefinen el deporte, dos hermanas compiten en salto en largo, pero su rivalidad toma un rumbo siniestro."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":110,"tagline":"","homepage":"https://www.netflix.com/pt/title/81406459","overview":"Num futuro distópico em que as próteses robóticas redefinem o desporto, duas irmãs competem no salto em comprimento, mas a sua rivalidade leva-as por um caminho sinistro."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Расширяя возможности","runtime":0,"tagline":"","homepage":"","overview":"Антиутопия о том, как спорт становится другим из-за роботизированных протезов. Две сестры соревнуются в прыжках в длину, однако соперничество ведет их по зловещему пути."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"}],"reviews_tmdb":[],"recommendations":[{"id":437342,"adult":false,"title":"The First Omen","video":false,"overview":"When a young American woman is sent to Rome to begin a life of service to the church, she encounters a darkness that causes her to question her own faith and uncovers a terrifying conspiracy that hopes to bring about the birth of evil incarnate.","genre_ids":[27],"media_type":"movie","popularity":3.6512,"vote_count":1243,"poster_path":"/cIzk6GhxEZuweekGFXWEoAyuaMX.jpg","release_date":"2024-04-03","vote_average":6.826,"backdrop_path":"/aBoo55Vl58NCo8D8BPykolQ8y86.jpg","original_title":"The First Omen","original_language":"en"},{"id":1123278,"adult":false,"title":"Lazareth","video":false,"overview":"Lee is an aunt whose life mission is to protect her orphaned nieces, Imogen and Maeve, from a self-destructing world, raising them in isolation until an outsider threatens their peaceful existence.","genre_ids":[53],"media_type":"movie","popularity":2.1293,"vote_count":48,"poster_path":"/36o8ancoKDKW1sstzMi0YYkQkpU.jpg","release_date":"2024-05-10","vote_average":6.063,"backdrop_path":"/5yZIKAPCjqm8t2r19vlzuasxbOP.jpg","original_title":"Lazareth","original_language":"en"},{"id":1060385,"adult":false,"title":"Cat","video":false,"overview":"8mm film by Swiss artist Roman Signer.","genre_ids":[],"media_type":"movie","popularity":0.0698,"vote_count":12,"poster_path":"/3OW0ytR9Xbf4bpCFj24y1rHHva.jpg","release_date":"1979-01-01","vote_average":6.708,"backdrop_path":null,"original_title":"Cat","original_language":"en"},{"id":1081680,"adult":false,"title":"Jackdaw","video":false,"overview":"A former motocross champion and army veteran, now caring for his younger brother. Broke, he agrees to do an open water pick up of a mysterious illegal package in the North Sea. A resulting double cross and his brother’s disappearance set him and his old bike on a violent nocturnal odyssey through England’s northern rust belt.","genre_ids":[28,18,80,53],"media_type":"movie","popularity":4.6352,"vote_count":30,"poster_path":"/m3OwT2vQ468E6b05pNCcCKY0Q7u.jpg","release_date":"2024-01-26","vote_average":4.683,"backdrop_path":"/5GPPGvLJmOg18TOPhQj8YK6P