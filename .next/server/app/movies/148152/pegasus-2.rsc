_3166_1":"CN","vote_count":0,"aspect_ratio":1.78,"vote_average":0},{"width":2500,"height":1406,"file_path":"/3xYZUhC2Nhq91tFHB3RhCp5cAxz.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/nV3v5V3ez2PMIsTCa5pan2nqXTO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:56:03.138+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"飞驰人生2","runtime":121,"tagline":"","homepage":"","overview":"昔日冠军车手张驰沦为落魄驾校教练，过着靠脸吃饭勉强度日的生活。不料天上掉馅饼，濒临停产的老头乐车厂厂长主动提出赞助张驰组建车队再闯最后一届巴音布鲁克拉力赛。面对这泼天的富贵，张驰蠢蠢欲动，而厂长背后真实的目的无人知晓……带资进队的车手厉小海，看似单纯善良却为何有着与之身份毫不相符的超强天赋？张驰召集老朋友孙宇强和记星，与天才车手厉小海和总是考不过科目二的菜鸟驾校学员刘显德组成了一个苦中作乐、鸡飞狗跳的草台班子，克服重重困难，笑料百出地奔赴赛场。这一次他将超越无数次出现在梦中的终点线……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Pegasus 2","runtime":121,"tagline":"","homepage":"","overview":"The former champion driver Zhang Chi became a driving school instructor in troubled times, living a life of relying on his reputation to make ends meet. Unexpectedly, pie in the sky falls, and the director of Laotoule Automobile Factor, who is on the verge of suspending production, offers to sponsor Zhang Chi to form a team to compete in the last Bayinbrook Rally."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"비치인생 2","runtime":121,"tagline":"","homepage":"","overview":"은퇴한 레이싱 챔피언이 운전학원 강사로 근근히 생활을 이어가던 중,  국제레이싱 경기에 출전하자는 지인의 제안을 받고,  유망한 신인레이서, 운전학원 수강생, 예전 동료들과 함께 팀을 꾸려  레이싱챔피언에 도전하는 스토리"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"飛馳人生2","runtime":121,"tagline":"","homepage":"","overview":"五年前巴音布魯克的悲壯一搏，傳奇車手張馳（沈騰 飾）贏得了比賽，卻輸掉了一切。因鉛封始終未能找到，他的成績被組委會取消，為了謀生開辦駕校又遭到網絡惡意中傷，窮困潦倒，不聞一名。偶然的一天，一通電話讓他重燃賽車手的熱情。瀕臨停産的老頭樂車廠廠長（賈冰 飾）是張馳的粉絲，他 主動提出贊助讓張馳的車隊去拼搏最後一屆巴音布魯克。老頭樂的員工厲小海（範丞丞 飾）天賦出衆，在張馳、孫宇強（尹正 飾）、記星（張本煜 飾）和萬年不及格的菜鳥駕校學員劉顯德（孫藝洲 飾）聯合訓練下，小海成長迅速。\r 　　只是通往勝利的道路充滿艱辛與磨難，有的人過于理想，有的人太過現實……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"飛馳人生 2","runtime":0,"tagline":"","homepage":"","overview":"五年前巴音布魯克的悲壯一搏，傳奇車手張馳（沈騰 飾）贏得了比賽，卻輸掉了一切。因鉛封始終未能找到，他的成績被組委會取消，為了謀生開辦駕校又遭到網絡惡意中傷，窮困潦倒，不聞一名。偶然的一天，一通電話讓他重燃賽車手的熱情。瀕臨停產的老頭樂車廠廠長（賈冰 飾）是張馳的粉絲，他 主動提出贊助讓張馳的車隊去拼搏最後一屆巴音布魯克。老頭樂的員工厲小海（範丞丞 飾）天賦出眾，在張馳、孫宇強（尹正 飾）、記星（張本煜 飾）和萬年不及格的菜鳥駕校學員劉顯德（孫藝洲 飾）聯合訓練下，小海成長迅速。\r 只是通往勝利的道路充滿艱辛與磨難，有的人過於理想，有的人太過現實……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Пегас 2","runtime":121,"tagline":"","homepage":"","overview":"Бывший чемпион по ралли, оказавшийся в непростой жизненной ситуации, находит новых партнеров, чтобы вновь принять участие в знаменитой раллийной гонке."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"პეგასი 2","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Pegasus 2","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"தமிழ்","iso_639_1":"ta","iso_3166_1":"IN","english_name":"Tamil"}],"reviews_tmdb":[],"recommendations":[{"id":1229349,"adult":false,"title":"Yolo","video":false,"overview":"After an argument with her younger sister, Le Ying moves out on her own. She meets a boxing trainer and starts boxing.","genre_ids":[18,35,28],"media_type":"movie","popularity":1.0309,"vote_count":107,"poster_path":"/eD1mfjEeDUOAAsptZjQA6skrdJy.jpg","release_date":"2024-02-10","vote_average":6.7,"backdrop_path":"/9IEYCg2Sxk72QdNNcvbbCMelalu.jpg","original_title":"热辣滚烫","original_language":"zh"},{"id":1147596,"adult":false,"title":"Article 20","video":false,"overview":"Tells the story of prosecutor Han Ming who is involved in a difficult case where the intentional injury of people is turned into a legitimate defense.","genre_ids":[18,35],"media_type":"movie","popularity":0.8776,"vote_count":53,"poster_path":"/atUfcWtxyILttah3ItN329ouAU.jpg","release_date":"2024-02-10","vote_average":6.962,"backdrop_path":"/PsyMMWKOyMVjTZBiyhNebyHDsQ.jpg","original_title":"第二十条","original_language":"zh"},{"id":1136557,"adult":false,"title":"Day Dreaming","video":false,"overview":"Zhu Tong is at the bottom of his class and is mischievous. Ten thousand fantasies appear in his little head every day. However, one day, he found that his head teacher was chasing aliens in the corridor, the flowers in the lawn could talk.","genre_ids":[35,14],"media_type":"movie","popularity":0.4347,"vote_count":20,"poster_path":"/bRCkkj31Oa5ISxzPi7KiTgeTEnI.jpg","release_date":"2024-05-25","vote_average":6.526,"backdrop_path":"/opfM09SFPVizLtsPsfLuI8vSlJ6.jpg","original_title":"朱同在三年级丢失了超能力","original_language":"zh"},{"id":1089654,"adult":false,"title":"Chang'an","video":false,"overview":"A few years after the Anshi Rebellion, Tang dynasty military commander Gao Shi suffers a defeat in a battle threatening Chang'an. Trapped in the besieged city, he recalls his lifelong friendship with the acclaimed poet Li Bai.","genre_ids":[16,36],"media_type":"movie","popularity":1.4665,"vote_count":62,"poster_path":"/ltWuj0bEhITpiNYaTmpc2lUKy90.jpg","release_date":"2023-07-02","vote_average":7.581,"backdrop_path":"/m4sS3YPOu6OPHzwJcPKjMH1TyRA.jpg","original_title":"长安三万里","original_language":"zh"},{"id":479306,"adult":false,"title":"Never Say Die","video":false,"overview":"A boxer and a journalist accidentally exchange bodies after they are struck by current, embarking a series of adventures.","genre_ids":[35,14],"media_type":"movie","popularity":0.7214,"vote_count":81,"poster_path":"/i7lhHL8puIpgxtxBhFj8mKVeB9k.jpg","release_date":"2017-09-30","vote_average":5.988,"backdrop_path":"/lyGuft4aGUrCTvsOBNlvb6YcRCE.jpg","original_title":"羞羞的铁拳","original_language":"zh"},{"id":412092,"adult":false,"title":"Mom's Friend 2","video":false,"overview":"An art student named Gwang-ho gets dumped by his girlfriend because she was only his source of comfort, and that he's a Mama's boy and a premature ejaculator. He tries to avoid seeing her by going to a different academy and that's when his mother introduces him to her friend Soo-yeon, a sophisticated and intelligent looking woman. Gwang-ho falls for her.  Gwang-ho's mother suddenly leaves for Australia because his father is sick and Gwang-ho gets to stay in Soo-yeon's house for a few days. Looking at her, he thinks of all the things he would like to do with her and Soo-yeon's niece Ha-kyeong stimulates him to do something about his feelings.","genre_ids":[10749],"media_type":"movie","popularity":5.5653,"vote_count":15,"poster_path":"/mLlke4cd9R65FYqtMVUZ3h3Z2z9.jpg","release_date":"2016-09-01","vote_average":6.1,"backdrop_path":"/dhaHfxS7AVNG53xdHOfJO5hRQbW.jpg","original_title":"엄마친구 2","original_language":"ko"},{"id":1077295,"adult":false,"title":"Godspeed","video":false,"overview":"A family of four people experience a laughable and touching journey. Truck driver Zhou Donghai doesn't think Wan Yi Fan is good enough as his son-in-law-to-be. In order to make his future father-in-law happy, Wan Yifan has been trying hard but keeps doing wrong things.","genre_ids":[35],"media_type":"movie","popularity":0.555,"vote_count":26,"poster_path":"/iddfS5fGtMeI2oexwCl7xPhBuhS.jpg","release_date":"2023-04-28","vote_average":5.346,"backdrop_path":"/mvyh8tXxuuaAFGR6QGQEbxfsd1s.jpg","original_title":"人生路不熟","original_language":"zh"},{"id":209032,"adult":false,"title":"The Floating Castle","video":false,"overview":"In the year 1590, the mighty warlord Toyotomi Hideyoshi is close to fulfilling his ambition of unifying all of Japan under his banner when he comes across unexpected resistance in the form of a floating fortress known as Oshi Castle. Narita Nagachika, a frivolous hedonistic fellow and unlikely candidate for the position of rebel general, finds himself in charge of defending the castle. His odds? An army of 500 men to combat Toyotomi Hideyoshi's army of 20,000.","genre_ids":[36,35,18],"media_type":"movie","popularity":1.0023,"vote_count":30,"poster_path":"/zpZOUmSR7Kq29efyWLYKkylsPoB.jpg","release_date":"2012-11-02","vote_average":7.417,"backdrop_path":"/beb6Ai7Gww2z71a7a6Mn9hm5LDo.jpg","original_title":"のぼうの城","original_language":"ja"},{"id":408620,"adult":false,"title":"Asura: The City of Madness","video":false,"overview":"A shady cop finds himself in over his head when he gets caught between Internal Affairs and the city’s corrupt mayor.","genre_ids":[28,80,53],"media_type":"movie","popularity":1.977,"vote_count":118,"poster_path":"/vJmSw2QFvX5vqdGQSBGe1x7HEcJ.jpg","release_date":"2016-09-28","vote_average":6.805,"backdrop_path":"/1Q9xEpkSTBgJISMZFLiPt96Jlhs.jpg","original_title":"아수라","original_language":"ko"},{"id":999056,"adult":false,"title":"I Did It My Way","video":false,"overview":"Ho Sau, an undercover agent, has been working with Yau, a drug lord, for years, but his job and family are in trouble.","genre_ids":[28,80,18],"media_type":"movie","popularity":1.0057,"vote_count":18,"poster_path":"/tisEbLoPUUFbhiVY4yFaEDnYfW0.jpg","release_date":"2023-12-29","vote_average":5.056,"backdrop_path":"/oIAR486U0QGyMp3dkQXdI4J9RIk.jpg","original_title":"潛行","original_language":"cn"},{"id":498419,"adult":false,"title":"Keep Calm and Be a Superstar","video":false,"overview":"Tiezhu (Li) is a private eye recruited by the police to investigate the criminal activities surrounding action icon Yuen Bao (Chan). A long-time fan of Bao’s, the asthma patient Tiezhu can hardly believe his luck when he saves his idol’s life during a set accident. But as the two become friends and Tiezhu is brought in to reshape the sci-fi action film that Bao is working on, Bao’s sneaky manager, Tai (Danny Chan Kwok-kwan), is determined to turn his action crew into drug traffickers.","genre_ids":[28,35],"media_type":"movie","popularity":0.4429,"vote_count":9,"poster_path":"/eFVaLgwXb9rZRhR7ecXXLmqSq2G.jpg","release_date":"2018-01-12","vote_average":5.8,"backdrop_path":"/8CJypIEFZ9ldtg6y6JXzeeoL8D9.jpg","original_title":"臥底巨星","original_language":"cn"},{"id":1241217,"adult":false,"title":"All In","video":false,"overview":"Cheng Jialang and Wei Yifu are the contemporary poker twin stars, and they are about to have their first face-to-face confrontation. However, at this moment, Cheng Jialang accidentally transferred his poker talent to a small-time crook named Huang Xiaoqi, who had no previous experience. The two of them went through a wonderful journey and decided to join forces to challenge Wei Yifu.","genre_ids":[35],"media_type":"movie","popularity":0.509,"vote_count":4,"poster_path":"/8hITxjYexJpCGjYV1omFy9d8dQr.jpg","release_date":"2024-02-08","vote_average":5.2,"backdrop_path":"/sDAZxpZo85zyo7GHNcfhMWmm5nU.jpg","original_title":"扑克王者","original_language":"zh"},{"id":937895,"adult":false,"title":"Obsessed","video":false,"overview":"An attractive young coroner involves herself in a strange relationship with s.e.x, desires, and deaths. The phantasmagoria filled with gore, e.r.o.t.i.c, and mystery unfolds during the serial killer search. The viewer has to guess, who the main protagonist is, and what part is she playing - a victim, a killer, or a mere witness?","genre_ids":[53,18],"media_type":"movie","popularity":0.6697,"vote_count":34,"poster_path":"/rHaOJitZOP9oJyIzdOvsiEUbjUV.jpg","release_date":"2022-07-14","vote_average":3.824,"backdrop_path":"/34Yp8fVMDqUyXz6zFw6F9B03YB9.jpg","original_title":"Одержимая","original_language":"ru"},{"id":1159242,"adult":false,"title":"The Invisible Guest","video":false,"overview":"A greedy police chief learns that a wealthy businesswoman has been wrongly accused of murder and strikes a deal with her – her freedom for a large sum of money. As the case progresses, a revelation that a sadistic politician and the businesswoman have a long standing relationship, the details of which will uncover the truth about the murder.","genre_ids":[9648,18,80],"media_type":"movie","popularity":1.169,"vote_count":15,"poster_path":"/dpnXb8wQNTQzbWkMPOiEMITN5vB.jpg","release_date":"2023-12-08","vote_average":6.133,"backdrop_path":"/2S1yCTJVTtexZ2NB2A2hUdSkp7S.jpg","original_title":"瞒天过海","original_language":"zh"},{"id":566397,"adult":false,"title":"The Man Standing Next","video":false,"overview":"When the investigation of 'Koreagate' takes place, Park Yong-gak, a former KCIA director who knows everything about the government's operations, heads to the United States in exile.","genre_ids":[18,53],"media_type":"movie","popularity":2.0851,"vote_count":148,"poster_path":"/iWavVXt7U20Vu2v5jX5ABE3e6gV.jpg","release_date":"2020-01-22","vote_average":7.095,"backdrop_path":"/m0Zp6dlmjfpolhMWx6KHJvmFlOk.jpg","original_title":"남산의 부장들","original_language":"ko"},{"id":20342,"adult":false,"title":"Secret","video":false,"overview":"Ye Xiang Lun, a talented piano player is a new student at the prestigious Tamkang School. On his first day, he meets Lu Xiao Yu, a pretty girl playing a mysterious piece of music.","genre_ids":[14,18,53],"media_type":"movie","popularity":1.6215,"vote_count":203,"poster_path":"/pOqdX6e4y2F9JTyoe4qorBtXVaR.jpg","release_date":"2007-07-27","vote_average":7.6,"backdrop_path":"/gm9REvuEjb3p2gylDsAzoT1G0r7.jpg","original_title":"不能說的秘密","original_language":"zh"},{"id":758891,"adult":false,"title":"Hi, Mom","video":false,"overview":"Devastated after her mom's serious accident and grief-stricken because she hasn't become the daughter she wanted to be for her mother, Jia Xiaoling finds herself transported back in time to the year 1981, where she meets her young mother before she was her mom.","genre_ids":[18,35,14],"media_type":"movie","popularity":1.3801,"vote_count":164,"poster_path":"/31W7qLEMqQKgdCeCtV9EbVi3bwG.jpg","release_date":"2021-02-12","vote_average":7.027,"backdrop_path":"/cTD9U4QLJHEL75ee1NoqIIeBc1y.jpg","original_title":"你好，李焕英","original_language":"zh"},{"id":1173076,"adult":false,"title":"Johnny Keep Walking!","video":false,"overview":"Fitter Hu Jianlin was transferred to the headquarters by accident when the group was laying off employees. He is full of jokes because he is incompatible with the environment of the big factory. Human resources manager Ma Jie, who was caught up in the \"wrong adjustment\" incident, was forced to go around hiding it in order to keep his job. Is he able to keep his job after this mistake?","genre_ids":[18,35],"media_type":"movie","popularity":0.822,"vote_count":96,"poster_path":"/8055dyA5XJbEcN9JjECZ1WsR62o.jpg","release_date":"2023-12-29","vote_average":7.438,"backdrop_path":"/f4OCzvS3HvisHEkxq5596jg21UJ.jpg","original_title":"年会不能停！","original_language":"zh"},{"id":453191,"adult":false,"title":"The Big Bad Fox and Other Tales","video":false,"overview":"The countryside isn't always as calm and peaceful as it's made out to be, and the animals on this farm are particularly agitated: a fox who mothers a family of chicks, a rabbit who plays the stork, and a duck who wants to be Santa Claus.","genre_ids":[10751,16,35],"media_type":"movie","popularity":0.8472,"vote_count":311,"poster_path":"/3Nib5a3p2O7yPFSTTNwChp0cnsh.jpg","release_date":"2017-06-21","vote_average":7.71,"backdrop_path":"/dh1FefCVNJtRLJoD13Xyt1MOk6d.jpg","original_title":"Le Grand Méchant Renard et autres contes...","original_language":"fr"},{"id":1061990,"adult":false,"title":"City Hunter","video":false,"overview":"An exceptional marksman and hopeless playboy, private eye Ryo Saeba reluctantly forms an alliance with his late partner's sister to investigate his death.","genre_ids":[28],"media_type":"movie","popularity":3.5384,"vote_count":245,"poster_path":"/cjQzJ9xFdaN9KAwu7HUImIgbc2Y.