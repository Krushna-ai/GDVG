5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Pegasus 2\",\"description\":\"The former champion driver Zhang Chi became a driving school instructor in troubled times, living a life of relying on his reputation to make ends meet. Unexpectedly, pie in the sky falls, and the director of Laotoule Automobile Factor, who is on the verge of suspending production, offers to sponsor Zhang Chi to form a team to compete in the last Bayinbrook Rally.\",\"image\":\"https://image.tmdb.org/t/p/w500/wGPHkBmLYtdjJpPW6ewxtejLrbd.jpg\",\"datePublished\":\"2024-02-10\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Drama\",\"Comedy\",\"Adventure\",null,null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.2,\"bestRating\":10,\"ratingCount\":84}}"}}],["$","$L10",null,{"initialDrama":{"id":"46fd2bf6-7177-4ed1-a94e-ed8a566abbf9","tmdb_id":1228891,"imdb_id":"tt30829309","content_type":"movie","title":"Pegasus 2","original_title":"飞驰人生2","overview":"The former champion driver Zhang Chi became a driving school instructor in troubled times, living a life of relying on his reputation to make ends meet. Unexpectedly, pie in the sky falls, and the director of Laotoule Automobile Factor, who is on the verge of suspending production, offers to sponsor Zhang Chi to form a team to compete in the last Bayinbrook Rally.","poster_path":"/wGPHkBmLYtdjJpPW6ewxtejLrbd.jpg","backdrop_path":"/ch8rKF1a5WXFDcxi2AKfmnaMBk7.jpg","release_date":"2024-02-10","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":18,"name":"Drama"},{"id":35,"name":"Comedy"},{"id":12,"name":"Adventure"},"sport film","comedy film","drama film"],"popularity":4.4459,"vote_average":7.2,"vote_count":84,"runtime":121,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-24T22:19:47.746892+00: