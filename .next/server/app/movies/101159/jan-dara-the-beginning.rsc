5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Jan Dara: The Beginning\",\"description\":\"Jan, a young boy, grows up without a mother and is often insulted by his father. He struggles with his life as he longs to be with several women, even Madame Boonleung, his father's lover.\",\"image\":\"https://image.tmdb.org/t/p/w500/6JXtCgm8ygSJRKGSl3GvOzRjGBM.jpg\",\"datePublished\":\"2012-09-06\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"TH\",\"inLanguage\":\"th\",\"genre\":[\"erotic film\",\"Drama\",\"Romance\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.8,\"bestRating\":10,\"ratingCount\":38}}"}}],["$","$L10",null,{"initialDrama":{"id":"21490440-c577-40f6-83c1-e7f4feb317da","tmdb_id":151512,"imdb_id":"tt2599106","content_type":"movie","title":"Jan Dara: The Beginning","original_title":"จันดารา ปฐมบท","overview":"Jan, a young boy, grows up without a mother and is often insulted by his father. He struggles with his life as he longs to be with several women, even Madame Boonleung, his father's lover.","poster_path":"/6JXtCgm8ygSJRKGSl3GvOzRjGBM.jpg","backdrop_path":"/wzdcUQFlbl5POvJbzYSYrsLS3Ss.jpg","release_date":"2012-09-06","first_air_date":null,"status":"published","original_language":"th","origin_country":["TH"],"genres":[{"name":"erotic film"},{"id":18,"name":"Drama"},{"id":10749,"name":"Romance"}],"popularity":2.8207,"vote_average":5.8,"vote_count":38,"runtime":136,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:53:09.563926+00:00","updated_at":"2026-02-21T14:53:59.849+00:00","tagline":"A tragedy of lust, love and revenge…","homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":4207,"name":"Sahamongkolfilm","logo_path":"/v5BSFwIXQmZEO16bClILNrbv4Kl.png","origin_country":"TH"}],"production_countries":[{"name":"Thailand","iso_3166_1":"TH"}],"spoken_languages":[{"name":"ภาษาไทย","iso_63