vote_average":0},{"width":500,"height":750,"file_path":"/sSMds3WqGQND2NykvzKx8KtLim8.jpg","iso_639_1":"zh","vote_average":0},{"width":1103,"height":1654,"file_path":"/r7ddaFpwM9NpEVTEYnOF0TykazI.jpg","iso_639_1":"en","vote_average":0},{"width":1985,"height":2836,"file_path":"/bE1FebYrjmZosO9WN5KwhwZRPl2.jpg","iso_639_1":"zh","vote_average":0},{"width":1433,"height":2048,"file_path":"/2aBSxzOkm0YoPYkjR23uJEtvFBW.jpg","iso_639_1":"th","vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/3G7k1Fg89FYblmB9OXOjXMAi8MH.jpg","iso_639_1":"en","vote_average":0},{"width":1280,"height":720,"file_path":"/wzdcUQFlbl5POvJbzYSYrsLS3Ss.jpg","iso_639_1":null,"vote_average":0},{"width":1600,"height":899,"file_path":"/eqBYAc4jRyfumVlqA9YZXSNeN0v.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-02-21T14:54:16.056+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":119,"tagline":"","homepage":"","overview":"จัน ดารา เป็นภาพยนตร์ไทย ดัดแปลงจาก นิยายเรื่อง 'เรื่องของจัน ดารา' ซึ่ง อุษณา เพลิงธรรม เขียนลงพิมพ์ เป็นตอนๆ ในหนังสือพิมพ์ ตั้งแต่ปี 2507 ถึงปี 2509 มีหม่อมหลวง พันธุ์เทวนพ เทวกุล เป็นผู้เขียนบท และกำกับ และสหมงคลฟิล์ม สร้างเป็นทวิภาค ต่อเนื่องกัน คือ จัน ดารา ปฐมบท เผยแพร่ ตั้งแต่ วันที่ 6 กันยายน 2555[1] และ จัน ดารา ปัจฉิมบท เผยแพร่ ในปี 2556 มีเนื้อหา ทำนองนาฎกรรม เชิงสังวาส ว่าด้วย ความสัมพันธ์ ของครอบครัวหนึ่ง ทั้งที่เป็น ความรักฉันญาติ ความรักฉันชู้สาว และความเคียดแค้น ชิงชัง ชนิดที่ตัวละคร แต่ละตัวล้วน เป็นกระจกสะท้อน พฤติกรรม ของกันและกัน"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Jan Dara: The Beginning","runtime":136,"tagline":"A tragedy of lust, love and revenge…","homepage":"","overview":"Jan, a young boy, grows up without a mother and is often insulted by his father. He struggles with his life as he longs to be with several women, even Madame Boonleung, his father's lover."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"晚娘上部：恋欲","runtime":0,"tagline":"一场欲望、爱情和复仇的悲剧……","homepage":"","overview":"《晚娘上部：恋欲》是一个充满性爱与沉沦的故事，将于2012年11月30日在台上映。故事叙述真达拉(马力欧莫瑞  晚娘上部：恋欲(4张)尔饰演)一出生，他的母亲便因难产而死，他父亲相信这个孩子害死了他深爱的妻子，誓言要以严酷的极端手段惩罚他。“真”这个名字就是“人渣”的意思，这个孩子的一生也将受到罪孽的诅咒…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Ян Дара: Начало","runtime":0,"tagline":"","homepage":"","overview":"Таиланд, столица страны Бангкок. Здесь в 1915 году в сезон дождей родился мальчик в семье респектабельного торгового клана из провинции и переехавшей в столицу. Семья обладала богатством и высоким социальным положением. Но судьба по отношению к мальчику была жестокой. Родители его матери внезапно скончались, а при его рождении умирает его мама. Для мальчишки наступают страшные дни его детства проклятого родным отцом."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Jan Dara: The Beginning","runtime":136,"tagline":"","homepage":"","overview":"1915 wird ein Junge in einem aristokratischen Anwesen in Bangkok geboren. Dabei stirbt jedoch seine Mutter, was den Vater Luang Wisnan dazu bewegt, das Baby zu verfluchen und auf den Namen Janrai zu taufen - Abschaum. Tante Wad, eine Cousine der verstorbenen Mutter, übernimmt die Pflege des Kindes, während die mächtige Grossmutter für seinen Schutz sorgt. Doch als sie nach Amerika reist, beginnt Vater Luang eine Intrige. Er bringt alle Angestellten des Anwesens mit seiner Überzeugungskraft und seiner Virilität auf seine Seite, so dass er sich ungestört Tante Wad annehmen kann. Die beiden heiraten. Jan wächst gepeinigt auf. Auch als Teenager muss Jan die Beleidigungen seines Vaters und seiner Halbschwester Kaew erdulden. Nur Tante Wad und der Bediensteten-Sohn Ken halten zu ihm. Letzterer ist es auch, der Jan in die Freuden der Sexualität einführt. Bevor Jan diese bei dem Schulmädchen Hyacinth anwenden kann, taucht die vornehme Lady Boonleung, die Geliebte des Vaters, im Haus auf."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"잔다라 더 비기닝","runtime":0,"tagline":"에로티시즘의 결정판! 더 자극적이고, 아름다워졌다!","homepage":"","overview":"태어날 때부터 시작된 가혹한 운명의 주인공, ‘잔다라’ 어머니가 그를 낳다 죽자, ‘잔다라’의 아버지는 그를 ‘인간 쓰레기’ 취급하며 학대한다. 욕정에 사로잡힌 아버지는 집안의 하녀들을 탐하고, ‘잔다라’를 돌보기 위해 찾아 온 ‘잔다라’의 이모까지 자신의 여자로 만든다. 아버지에 대한 트라우마에 시달리던 ‘잔다라’ 역시 욕망의 노예가 되어 가고, 아버지의 새로운 여자 ‘분링 부인’에게 점차 빠져들고 마는데… 욕망의 늪에 빠진 한 남자의 가혹한 운명, 그 서막이 펼쳐진다!"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Annesi doğum yaparken ölen fakat kendisi yaşayan Jan Dara bu olaydan sonra lanetlenmiştir ve henüz on üç yaşındayken yapmadığı bir suçla, tecavüzle, onu suçlar ve o dakikadan itibaren hayatı çok kötü bir yön alır. Evi terk eder ve tek başına büyük sıkıntılar atlatır"},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"晚孃上部：戀慾","runtime":0,"tagline":"","homepage":"","overview":"這是一個充滿性愛與沈淪的故事，真達拉(馬力歐莫瑞爾飾)一生的悲劇從他出生的那一刻開始。他的母親Dara便難產而死，傳說他的一生從此受到詛咒！  1915年，曼谷的一個暴風雨夜晚的大宅院中，一位母親因難產而死，他的父親相信是因為這個孩子而害死了他深愛的妻子，於是他詛咒這個兒子並誓言要以嚴酷的極端手段懲罰他。這個男孩是真達拉，「真」這個名字就是「人渣」的意思。真在大宅院庭園裡的一間小房舍長大，由繼母華姨照顧。最好的朋友是家中傭人的兒子肯。華姨成為老爺的新任妻子後生了一名女兒喬(西野翔飾)，是老爺疼愛的掌上明珠，喬也被父親教導著必須仇恨真。  但這間大宅院卻深藏不欲人知的醜陋祕密，男主人老爺沉溺於肉體上的歡愉，各種性愛體位和變態虐待遊戲，他日以繼夜在宅院跟各式各樣的女人性交，家中年幼的孩子真、肯和喬就是在這樣的情色慾海中長大，他們也開始尋求自己的色慾歡愉，恣意悠遊在這個縱慾樂園之中。  肯引領真進入縱慾的漩渦，大多跟家中的女傭交合，不過命運讓真邂逅人生摯愛，來自英語學校的迷人女孩荷欣。當老爺將舉止優雅但思想奔放的舊愛晚孃(牙牙茵飾)帶回家中時，情況卻變得複雜。她很快就迷戀上年輕的真，在心裡和身體都依戀著他，兩人發展出複雜糾葛的關係。  然而黑暗的祕密卻等著這個受詛咒的家族，真一時衝動，背負強暴同父異母妹妹(西野翔飾)的不實指控而被父親趕出家門，因而逃離大宅院回到母親的故鄉。這場交織著情慾和復仇的愛恨輪迴將緊緊纏繞真的一生……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Jan Dara pathommabot","runtime":137,"tagline":"","homepage":"","overview":""},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"晚孃：風月豪門","runtime":0,"tagline":"","homepage":"","overview":"1915 年，真達拉（Jan Dara）在曼谷一所富貴大宅出生，因為母親難產而死，真達拉自幼被父親視為剋星，終日承受咒罵、虐打；幸好繼母華姨（Aunt Wad）對他寵愛有加，真達拉的僕人兼好友阿基（Ken）亦非常關照。華姨後來誕下女兒喬（Kaew），但在父親的耳濡目染下，喬對真達拉充滿不屑和恨意。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"}],"reviews_tmdb":[],"recommendations":[{"id":48340,"adult":false,"title":"Sanctum","video":false,"overview":"Master diver Frank McGuire has explored the South Pacific's Esa-ala Caves for months.  But when his exit is cut off in a flash flood, Frank's team—including 17-year-old son Josh and financier Carl Hurley are forced to radically alter plans.  With dwindling supplies, the crew must navigate an underwater labyrinth to make it out.","genre_ids":[28,53],"media_type":"movie","popularity":2.6355,"vote_count":1137,"poster_path":"/zRUNv1CbeVtmTCNr6RLHnxV2QYm.jpg","release_date":"2011-02-03","vote_average":6.042,"backdrop_path":"/AfJdtxxhbA0E6vlzRRcXDUNdBEB.jpg","original_title":"Sanctum","original_language":"en"},{"id":447458,"adult":false,"title":"Dwaraka","video":false,"overview":"A petty thief gains great wealth by pretending to be a baba. However, he has a change of heart after falling in love but finds himself getting pushed deep into the world of crime.","genre_ids":[18],"media_type":"movie","popularity":0.1801,"vote_count":9,"poster_path":"/8g6lfCRbQxw3GgOP7SVatamq38A.jpg","release_date":"2017-03-03","vote_average":5.6,"backdrop_path":"/rdTeTbWWgnrvn7LFq7qUTHEWCF.jpg","original_title":"ద్వారక","original_language":"te"},{"id":392008,"adult":false,"title":"Carl","video":false,"overview":"Based on a true story, a young Carl Denaro is shot but survives the 1976 Son of Sam killings, leading him to reflect on what the future now holds for him.","genre_ids":[],"media_type":"movie","popularity":0.0475,"vote_count":1,"poster_path":null,"release_date":"2016-12-01","vote_average":8,"backdrop_path":null,"original_title":"Carl","original_language":"en"},{"id":152760,"adult":false,"title":"The Monuments Men","video":false,"overview":"Based on the true story of the greatest treasure hunt in history, The Monuments Men is an action drama focusing on seven over-the-hill, out-of-shape museum directors, artists, architects, curators, and art historians who went to the front lines of WWII to rescue the world’s artistic masterpieces from Nazi thieves and return them to their rightful owners.  With the art hidden behind enemy lines, how could these guys hope to succeed?","genre_ids":[10752,18,36,28],"media_type":"movie","popularity":3.2762,"vote_count":3761,"poster_path":"/wiWAg4mKV2S4vImPxsPRIdj2R2B.jpg","release_date":"2014-01-24","vote_average":6.1,"backdrop_path":"/uLBJtONQwHoGc61vbIfoC6a9gUp.jpg","original_title":"The Monuments Men","original_language":"en"},{"id":398818,"adult":false,"title":"Call Me by Your Name","video":false,"overview":"In the summer of 1983, a 17-year-old Elio spends his days in his family's villa in Italy. One day Oliver, a graduate student, arrives to assist Elio's father, a professor of Greco-Roman culture. Soon, Elio and Oliver discover a summer that will alter their lives forever.","genre_ids":[10749,18],"media_type":"movie","popularity":9.4697,"vote_count":12596,"poster_path":"/mZ4gBdfkhP9tvLH1DO4m4HYtiyi.jpg","release_date":"2017-10-01","vote_average":8.096,"backdrop_path":"/fwf4L3r2ZU9ptOB9nOo5nuVLo1i.jpg","original_title":"Call Me by Your Name","original_language":"en"},{"id":14,"adult":false,"title":"American Beauty","video":false,"overview":"Lester Burnham, a depressed suburban father in a mid-life crisis, decides to turn his hectic life around after developing an infatuation with his daughter's attractive friend.","genre_ids":[18],"media_type":"movie","popularity":11.4797,"vote_count":12811,"poster_path":"/wby9315QzVKdW9BonAefg8jGTTb.jpg","release_date":"1999-09-15","vote_average":8.002,"backdrop_path":"/2ndw55F40IkALzWyjCCza3M6nqM.jpg","original_title":"American Beauty","original_language":"en"},{"id":150540,"adult":false,"title":"Inside Out","video":false,"overview":"When 11-year-old Riley moves to a new city, her Emotions team up to help her through the transition. Joy, Fear, Anger, Disgust and Sadness work together, but when Joy and Sadness get lost, they must journey through unfamiliar places to get back home.","genre_ids":[16,10751,12,18,35],"media_type":"movie","popularity":14.8246,"vote_count":23174,"poster_path":"/2H1TmgdfNtsKlU9jKdeNyYL5y8T.jpg","release_date":"2015-06-17","vote_average":7.909,"backdrop_path":"/jJKZaTBNenlFclQyjrnvzkRmvWE.jpg","original_title":"Inside Out","original_language":"en"},{"id":157336,"adult":false,"title":"Interstellar","video":false,"overview":"The adventures of a group of explorers who make use of a newly discovered wormhole to surpass the limitations on human space travel and conquer the vast distances involved in an interstellar voyage.","genre_ids":[12,18,878],"media_type":"movie","popularity":47.1397,"vote_count":38915,"poster_path":"/gEU2QniE6E77NI6lCU6MxlNBvIx.jpg","release_date":"2014-11-05","vote_average":8.467,"backdrop_path":"/2ssWTSVklAEc98frZUQhgtGHx7s.jpg","original_title":"Interstellar","original_language":"en"},{"id":382591,"adult":false,"title":"Two Is a Family","video":false,"overview":"A man without attachments or responsibilities suddenly finds himself with an abandoned baby and leaves for London to try and find the mother. Eight years later after he and his daughter become inseparable Gloria's mother reappears.","genre_ids":[18,35],"media_type":"movie","popularity":2.4208,"vote_count":3039,"poster_path":"/aFgtdhuzgI2eqnIVWtRB03x3pnt.jpg","release_date":"2016-12-07","vote_average":7.726,"backdrop_path":"/fO0qXJnBJYuWJ5dvWWGXfRF8MXA.jpg","original_title":"Demain tout commence","original_language":"fr"},{"id":11324,"adult":false,"title":"Shutter Island","video":false,"overview":"World War II soldier-turned-U.S. Marshal Teddy Daniels investigates the disappearance o