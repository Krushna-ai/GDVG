9:{"metadata":[["$","title","0",{"children":"Spider-Man: Across the Spider-Verse | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"After reuniting with Gwen Stacy, Brooklyn’s full-time, friendly neighborhood Spider-Man is catapulted across the Multiverse, where he encounters the Spider Society, a team of Spider-People charged with protecting the Multiverse's very existence. But when the heroes clash on how to handle a new threat, Miles finds himself pitted against the other Spiders and must set out on his own to save those he loves most."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/100121/spider-man-across-the-spider-verse"}],["$","meta","5",{"property":"og:title","content":"Spider-Man: Across the Spider-Verse"}],["$","meta","6",{"property":"og:description","content":"After reuniting with Gwen Stacy, Brooklyn’s full-time, friendly neighborhood Spider-Man is catapulted across the Multiverse, where he encounters the Spider Society, a team of Spider-People charged with protecting the Multiverse's very existence. But when the heroes clash on how to handle a new threat, Miles finds himself pitted against the other Spiders and must set out on his own to save those he loves most."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/100121/spider-man-across-the-spider-verse"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/8Vt6mWEReuy4Of61Lnj5Xj704m8.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Spider-Man: Across the Spider-Verse"}],["$","meta","12",{"name":"twitter:description","content":"After reuniting with Gwen Stac