e_average":0},{"width":1920,"height":1080,"file_path":"/6PY8bYphbgdbNgZN7bamNBx0CNo.jpg","iso_639_1":"tl","iso_3166_1":"PH","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/eDWgjlLVkzueIAbLDvXkRtiFQ5f.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/qHpxu4Frbffxi1mBtnBl6dbyQoS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/q6CuQhZKuLWK9hN0qgPK4hyvvT6.jpg","iso_639_1":"tl","iso_3166_1":"PH","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T06:55:22.489+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":114,"tagline":"","homepage":"","overview":"Melaine finds herself torn between two passionate relationships, unable to resist the pull of desire. When a third man enters her life, temptation takes over, leading her into a whirlwind of love, lust, and complicated choices."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"现在不行","runtime":0,"tagline":"","homepage":"","overview":"万众瞩目的Vivamax的女王安吉丽·康（Angeli Khang），被一个、两个，不是，是三个性感男主角分享。梅兰妮（Melaine）对生活中的两个男人感到厌倦。当一个新男人出现时，她屈服于诱惑。  导演：杰弗瑞·荷迪乐  演员：安吉丽·康、阿尔比·卡森诺、希拉·雪、范·奥伦治、伊坦·罗萨勒斯"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"언페이스풀 2","runtime":0,"tagline":"","homepage":"","overview":""},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Stalker - Du gehörst mir","runtime":0,"tagline":"","homepage":"","overview":"Die hübsche Melanie führte einst ein ausschweifendes Leben voller Sex und Partys. Doch als ihr Freund Martin ihr einen Antrag macht, gelobt sie ihm ewige Treue. Diese hält nicht lange, als Martins heißer Bruder Leo aufkreuzt. Zudem wird sie von einem geheimnisvollen Stalker heimgesucht. Ein verschmähter Liebhaber? Melanie verliert sich mehr und mehr in einem Strudel aus Lust, Sex und Eifersucht."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"}],"reviews_tmdb":[],"recommendations":[{"id":1421198,"adult":false,"title":"Sponsor","video":false,"overview":"A movie about sisters who use their bodies to survive. To support her family, Jasmine becomes a sugar baby to a businessman. She regrets her choice as she learns that that it would put her and her sister's life in danger.","genre_ids":[18],"media_type":"movie","popularity":2.6571,"vote_count":6,"poster_path":"/7Opn9aPs8UCBJQ6lqou3i8f9omC.jpg","release_date":"2025-01-31","vote_average":7.3,"backdrop_path":"/dJLxORMnuJLprSAMQ9dFIiyWR4l.jpg","original_title":"Sponsor","original_language":"tl"},{"id":689500,"adult":false,"title":"Six Hours: Surviving Typhoon Yolanda","video":false,"overview":"In the middle of a broadcast about Typhoon Yolanda's initial impact, reporter Jiggy Manicad was faced with the reality that he no longer had communication with his station. They were, for all intents and purposes, stranded in Tacloban. With little option, and his crew started the six hour walk to Alto, where the closest broadcast antenna was to be found. Letting the world know what was happening to was a priority, but they were driven by the need to let their families and friends know they were all still alive. Along the way, they encountered residents and victims of the massive typhoon, and with each step it became increasingly clear just how devastating this storm was. This was a storm that was going to change lives.","genre_ids":[99,18,36],"media_type":"movie","popularity":0.4105,"vote_count":1,"poster_path":"/eeSbsZDvYHugxL08YRrWNF1FpwV.jpg","release_date":"2014-12-23","vote_average":8.5,"backdrop_path":"/MmJlXi6qI0xQ1wGLwED2rB28qt.jpg","original_title":"Six Hours: Surviving Typhoon Yolanda","original_language":"en"},{"id":1323046,"adult":false,"title":"Dharmaveer 2","video":false,"overview":"Explores Anand Dighe's life, tracing his political journey and capturing the essence of his impactful legacy as a prominent figure.","genre_ids":[18],"media_type":"movie","popularity":0.2742,"vote_count":2,"poster_path":"/m4SHtLoSfatigDMZxpsX8E7NuVH.jpg","release_date":"2024-08-09","vote_average":6,"backdrop_path":"/fF1FKpw9xtixmMIoNNbNeyxP5TE.jpg","original_title":"धर्मवीर २","original_language":"mr"},{"id":789070,"adult":false,"title":"Kevin","video":false,"overview":"It is the first time that Joana, a Brazilian, has visited her friend Kevin in her country, Uganda.  They met 20 years ago when they studied together in Germany and have not seen each other for a long time.  Now they are close to turning 40 and life is more complex than in youth.  This is a film about a friendship between women.","genre_ids":[99],"media_type":"movie","popularity":0.2426,"vote_count":1,"poster_path":"/1oP6wJyEBFHgRcd1A5oJChS3Puq.jpg","release_date":"2022-11-03","vote_average":7,"backdrop_path":"/hzlRwK1efkNHz2TVGOPpwo3kw42.jpg","original_title":"Kevin","original_language":"pt"},{"id":420092,"adult":false,"title":"The Signal Fire","video":false,"overview":"A short romantic drama in which a captain and his wife are separated by a shipwreck. The woman ends up on a desert island with another man, and they have a relationship. When they are saved by the captain, he decides to stay behind on the island, alone.","genre_ids":[37],"media_type":"movie","popularity":0.115,"vote_count":2,"poster_path":"/wu97CzkGbGhwe1QNYlwYRtmxCzM.jpg","release_date":"1912-09-25","vote_average":4,"backdrop_path":null,"original_title":"The Signal Fire","original_language":"en"},{"id":731789,"adult":false,"title":"# 3_2","video":false,"overview":"One day, there was a problem while rendering the edited image. Usually, even though the video is not played back, Split frame and green flicker(R:1 G:137 B:1) occurred on the screen. This work is similar to a stuffing that sampled the errors of digital algorithms.","genre_ids":[],"media_type":"movie","popularity":0.0389,"vote_count":1,"poster_path":"/s9WuzU6GaGX8LrHAmwFEpmt4uNx.jpg","release_date":"2018-01-01","vote_average":6,"backdrop_path":null,"original_title":"# 3_2","original_language":"en"},{"id":1423978,"adult":false,"title":"小米SU7出战日本筑波赛车场","video":true,"overview":"","genre_ids":[99],"media_type":"movie","popularity":0.097,"vote_count":1,"poster_path":"/6qqTvB82k1GM2fUBCoCS9J1WWOU.jpg","release_date":"2024-10-01","vote_average":8,"backdrop_path":"/jCf8101fpBq8h8PEW5IrO1duImv.jpg","original_title":"小米SU7出战日本筑波赛车场","original_language":"zh"},{"id":95341,"adult":false,"title":"Crazy to Act","video":false,"overview":"Millionaire film producer Gordon Bagley wants to marry Ethel St. John, the leading lady in his latest film. Ethel is in love with Arthur Young, the hero of Bagley's lastest movie. Work on the film starts, and at the preview screening is shown to be disasterous. Ethel then goes away with Arthur, while Gordon runs on a rotating movie set.","genre_ids":[35],"media_type":"movie","popularity":0.1372,"vote_count":2,"poster_path":"/iS2t14AkPiP2sHKXaioRTZPFbxk.jpg","release_date":"1927-05-15","vote_average":5.5,"backdrop_path":null,"original_title":"Crazy to Act","original_language":"en"},{"id":237007,"adult":false,"title":"The Johnstown Flood","video":false,"overview":"Re-enactment of the famous May 31, 1889 Johnstown, Pennsylvania flood where the dam broke and flooded out an entire town! In this version, the town is occupied by mice and dogs. But Mighty Mouse comes to the rescue after drinking a bottle of \"Atomic Energy.\" He reverses the flood waters and puts everything back where it was. And in this cartoon, he uses magic lightning bolts coming off his hands like Merlin the Magician!","genre_ids":[16,35],"media_type":"movie","popularity":0.0645,"vote_count":5,"poster_path":"/pxxLqI3WWO724KzH8DwmAW4jceS.jpg","release_date":"1946-06-27","vote_average":4,"backdrop_path":null,"original_title":"The Johnstown Flood","original_language":"en"},{"id":1227308,"adult":false,"title":"Dodger Special: Christmas","video":false,"overview":"A kind-hearted deed for an old friend leads Dodger to break into 10 Downing Street.","genre_ids":[10770,35,18,10751,36],"media_type":"movie","popularity":0.2516,"vote_count":0,"poster_path":"/18zLMiJWXPWGnMQiWvgfFI3UCOi.jpg","release_date":"2022-12-04","vote_average":0,"backdrop_path":"/5AkAhtTkjUg1WJkh5S7gyNO4qEX.jpg","original_title":"Dodger Special: Christmas","original_language":"en"},{"id":1267175,"adult":false,"title":"NO STEP","video":true,"overview":"A group of students are preparing works for an art exhibition, they belittle a myth that \"Any inanimate object that resembles a living thing, is not just a dead-object\"","genre_ids":[27,53],"media_type":"movie","popularity":0.0626,"vote_count":2,"poster_path":"/nJgHE4uOVa8SvIAje00cwUeyeSi.jpg","release_date":"2020-12-21","vote_average":6.5,"backdrop_path":"/68Zjt9bTcjLatjVwAUF1L0e4BZn.jpg","original_title":"NO STEP","original_language":"id"},{"id":325619,"adult":false,"title":"Johan Falk: Silent Diplomacy","video":false,"overview":"When Johan and his colleagues are watching Seth and his gang member Jack, they stumble on a larger case than they expected. Seth is selling arms to terrorists, but without Jack's knowledge, in a car where Johan's old colleague Pernilla mysterious appears. While Johan begin researching what Pernilla and SÄPO is doing, Jack suspects that everything is not right with Seth and that he's working with the police.","genre_ids":[80,53,28],"media_type":"movie","popularity":0.319,"vote_count":28,"poster_path":"/lof0RkJwXCbsjNwMmnbo3lOZAjQ.jpg","release_date":"2015-07-13","vote_average":6.25,"backdrop_path":"/aKfNpPlxYwsqCOAX9jsEzortQF6.jpg","original_title":"Johan Falk: Tyst diplomati","original_language":"sv"},{"id":315029,"adult":false,"title":"At the Waterfront After the Social: The Legacy of Sleepaway Camp","video":false,"overview":"A documentary about the making of Sleepaway Camp","genre_ids":[9