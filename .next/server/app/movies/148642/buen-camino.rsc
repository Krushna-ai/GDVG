10:T508,{"@context":"https://schema.org","@type":"Movie","name":"Buen Camino","description":"Checco's life is a comfortable and luxurious one, and it couldn't be otherwise, considering he's the only son of Eugenio Zalone, a wealthy sofa manufacturer. Stranded by the pool in his luxurious villas, with an unspecified number of Filipinos serving him, a very young Mexican model as a girlfriend, and vacationing on his yacht with friends who share his passion for not wanting to work; it seems like a truly enviable life, considering he lacks nothing, absolutely nothing. Actually, no. Something is missing. It's his underage daughter, Cristal, named after the famous French sparkling wine, who has suddenly disappeared without a trace. Urgently summoned to Rome by his ex-wife, Linda, he finds himself facing the responsibilities of fatherhood for the first time, trying to find the girl—a very complicated task, considering he knows absolutely nothing about Cristal and her life.","image":"https://image.tmdb.org/t/p/w500/3rlO9DkQQaKbRkAZVXcUED3DFrE.jpg","datePublished":"2025-12-25","numberOfEpisodes":null,"countryOfOrigin":"IT","inLanguage":"it","genre":["Comedy","Family","Adventure",null],"aggregateRating":{"@type":"AggregateRating","ratingValue":6.397,"bestRating":10,"ratingCount":379}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"a2ee9236-62eb-475a-81f6-657b35dee0ac","tmdb_id":1472638,"imdb_id":"tt38350059","content_type":"movie","title":"Buen Camino","original_title":"Buen Camino","overview":"Checco's life is a comfortable and luxurious one, and it couldn't be otherwise, considering he's the only son of Eugenio Zalone, a wealthy sofa manufacturer. Stranded by the pool in his luxurious villas, with an unspecified number of Filipinos serving him, a very young Mexican model as a girlfriend, and vacationing on his yacht with friends who share his passion for not wanting to work; it seems like a truly enviable life, considering he lacks nothing, absolutely nothing. Actually, no. Something is missing. It's his underage daughter, Cristal, named after the famous French sparkling wine, who has suddenly disappeared without a trace. Urgently summoned to Rome by his ex-wife, Linda, he finds himself facing the responsibilities of fatherhood for the first time, trying to find the girl—a very complicated task, considering he knows absolutely nothing about Cristal and her life.","poster_path":"/3rlO9DkQQaKbRkAZVXcUED3DFrE.jpg","backdrop_path":"/qo2VoL7vyDWKvUejikxrdIFUDIa.jpg","release_date":"2025-12-25","first_air_date":null,"status":"published","original_language":"it","origin_country":["IT"],"genres":[{"id":35,"name":"Comedy"},{"id":10751,"name":"Family"},{"id":12,"name":"Adventure"},"comedy film"],"popularity":2.931,"vote_average":6.397,"vote_count":379,"runtime":90,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-26T00:40:31.679442+00:00","updated_at":"2026-02-26T00:40:31.532+00:00","tagline":null,"homepage":null,"budget":28100000,"revenue":73797878,"production_companies":[{"id":18156,"name":"Indiana Production","logo_path":"/3nAuYcaWdpW0ULMvMz6V5HIJmCO.png","origin_country":"IT"},{"id":6246,"name":"Medusa Film","logo_path":"/7X6pfxldTiOD7MLo2EQqUQlmOUw.png","origin_country":"IT"}],"production_countries":[{"name":"Italy","iso_3166_1":"IT"}],"spoken_languages":[{"name":"Français","iso_639_1":"fr","english_name":"French"},{"name":"Italiano","iso_639_1":"it","english_name":"Italian"},{"name":"Español","iso_639_1":"es","english_name":"Spanish"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[],"alternative_titles":[{"type":"","title":"Good Road","iso_3166_1":"US"}],"videos":[],"watch_providers":{"results":{}},"wikidata_id":"Q137211198","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-26T00:40:31.679442+00:00","region":null,"main_poster":null,"images":{"logos":[{"width":1996,"height":488,"file_path":"/2R8BiFswmXVMmoOqp62dsJFQJpA.png","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":4.09,"vote_average":0}],"posters":[{"width":1024,"height":1536,"file_path":"/1Yn8kGIieRTQ3EgrN6DeXLeQxb8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":0.667,"vote_average":2.278},{"width":1417,"height":2025,"file_path":"/3rlO9DkQQaKbRkAZVXcUED3DFrE.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":3,"aspect_ratio":0.7,"vote_average":2.278},{"width":500,"height":750,"file_path":"/5sHyD2AEaaX9tzRkBdWM5G9NeJ8.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":5,"aspect_ratio":0.667,"vote_average":1.434},{"width":900,"height":1350,"file_path":"/s3JRivAeNyMoTBt8IsQKKGecZYZ.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":3,"aspect_ratio":0.667,"vote_average":1.222},{"width":1365,"height":2048,"file_path":"/3duYKU5fnPygOmEzN0PRgxNkf2U.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":3,"aspect_ratio":0.667,"vote_average":0.166},{"width":800,"height":1143,"file_path":"/gCuF7a7961xiK0IzCYqfzDUUuqr.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":2,"aspect_ratio":0.7,"vote_average":0.166},{"width":1417,"height":2025,"file_path":"/qr73U8ni6NXuEc0xmh49vmjRMow.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.7,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/qo2VoL7vyDWKvUejikxrdIFUDIa.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/t5rM9EEjJlLuq5mcn80cDHH1XeC.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1313,"height":739,"file_path":"/bUQyIVW6CP8edu6wSN4DvSLvZXU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1536,"height":864,"file_path":"/8kqkr70SZynNCuGTNyPLk3F7RvC.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1426,"height":802,"file_path":"/wNEBSu1iDDcgXEjf8YGOD0XUWX5.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:32:07.465+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":90,"tagline":"","homepage":"https://www.medusa.it/movie/buen-camino/","overview":"Checco, erede ricchissimo e viziato è costretto a lasciare la sua vita dorata per mettersi sulle tracce della figlia adolescente. È così che finisce, suo malgrado, sul Cammino di Santiago: un’occasione per conoscersi davvero."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Checco's life is a comfortable and luxurious one, and it couldn't be otherwise, considering he's the only son of Eugenio Zalone, a wealthy sofa manufacturer. Stranded by the pool in his luxurious villas, with an unspecified number of Filipinos serving him, a very young Mexican model as a girlfriend, and vacationing on his yacht with friends who share his passion for not wanting to work; it seems like a truly enviable life, considering he lacks nothing, absolutely nothing. Actually, no. Something is missing. It's his underage daughter, Cristal, named after the famous French sparkling wine, who has suddenly disappeared without a trace. Urgently summoned to Rome by his ex-wife, Linda, he finds himself facing the responsibilities of fatherhood for the first time, trying to find the girl—a very complicated task, considering he knows absolutely nothing about Cristal and her life."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":90,"tagline":"","homepage":"","overview":"Checco, reicher und verwöhnter Erbe, muss seine luxuriöse Lebenswelt hinter sich lassen, um seine jugendliche Tochter zu finden. Widerwillig begibt er sich auf den Jakobsweg, wo er Schritt für Schritt auf neue Herausforderungen stösst. Die Reise wird zu einer unerwarteten Chance, sich selbst und seine Tochter wirklich kennenzulernen und wichtige Werte zu entdecken."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Buen Camino","runtime":90,"tagline":"","homepage":"","overview":"Checco, bogaty i rozpieszczony dziedzic, zmuszony jest porzucić swoje luksusowe życie, by pójść w ślady swojej nastoletniej córki. W ten sposób nieświadomie trafia na Camino de Santiago: okazję, by naprawdę się poznać."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":90,"tagline":"","homepage":"","overview":"Checco, riche héritier gâté, doit abandonner son train de vie luxueux pour retrouver sa fille adolescente. À contrecœur, il se lance sur le chemin de Compostelle, où il rencontre de nouveaux défis à chaque étape. Ce voyage devient une occasion inattendue de vraiment apprendre à se connaître, lui et sa fille, et de découvrir des valeurs importantes."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[],"external_ids":{"imdb_id":"tt38350059","twitter_id":null,"facebook_id":null,"wikidata_id":"Q137211198","instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148642,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"CH","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-12-25T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"IT","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-12-25T00:00:00.000Z","certification":"T"}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikidata_metadata":{},"mood_tags":null,"trope_tags":null,"vibe_description":null,"ai_enriched_at":null,"ai_enrichment_version":0}}]]
