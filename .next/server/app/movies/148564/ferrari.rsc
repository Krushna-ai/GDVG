.778,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/roWRsvjwXNm4IcunugC0MopCexE.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/hT2pXnpEnS5hUKtab2nx09X4kJy.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/lubGDoivW1SVU5zMciIphmqu5lm.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/lYxm1pKaXEcyrxmF6fDb2QqLgxM.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/ccsvC5OtyMhypOoBqEeWmoMqZMv.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/ltdGjE8TR3O8DBoK90s5Ex8VrQd.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/6uPcwsbklviJZqhdN90cJYf2VPF.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/2NtRfiQAyMluGisxS6ReUFyNjVJ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1480,"height":832,"file_path":"/77KQYNDqKb0Paus2iLZFETxVJmN.jpg","iso_639_1":"he","iso_3166_1":"IL","vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":1920,"height":1080,"file_path":"/cWJ56tVWcCaHF1oG5FUshlKZIdz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/hVGly9hUHwSxfeL8OIlDrJXTbMc.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/pdgiaiViwfP4l4pKQJzkfqNPU0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2000,"height":1125,"file_path":"/emVTTfyVtqkRSuvWfBq8NCMrPpA.jpg","iso_639_1":"ja","iso_3166_1":"JP","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1454,"height":818,"file_path":"/13PfMb7ncrXa37z79A00ZSOu2GF.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/aF7I15IM8OY1pt6hPSLLcPdSmKV.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/w3VFdRdvwKr9NNQsU7laLi7Dvtx.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2519,"height":1417,"file_path":"/hFRPrNeGQMqSqNx9DioT7WaouHI.jpg","iso_639_1":"zh","iso_3166_1":"TW","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T04:53:07.133+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":131,"tagline":"","homepage":"https://neonrated.com/films/ferrari","overview":"Set during the summer of 1957. Ex-racecar driver, Enzo Ferrari, is in crisis. Bankruptcy stalks the company he and his wife, Laura, built from nothing ten years earlier. Their tempestuous marriage struggles with the mourning for one son and the acknowledgement of another."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":130,"tagline":"","homepage":"","overview":"Au cours de l'été 1957, Enzo Ferrari, ancien pilote automobile, est en crise. La faillite guette l'entreprise que lui et sa femme, Laura, ont créée à partir de rien dix ans plus tôt. Leur mariage tumultueux doit faire face au deuil d'un fils et à la reconnaissance d'un autre. Pour tenter d'assurer leur survie, il jette les dés sur une course — 1 000 miles à travers l'Italie, l'emblématique Mille Miglia."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"法拉利","runtime":0,"tagline":"","homepage":"","overview":"1957年，法拉利的公司面临破产，和妻子的婚姻摇摇欲坠，他和车手团队决定在一场比赛中孤注一掷，参与横跨意大利的开放公路耐力赛。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Феррарі","runtime":0,"tagline":"","homepage":"","overview":"Літо 1957 року. Колишній автогонщик Енцо Феррарі переживає кризу. Банкрутство переслідує компанію, яку вони з дружиною Лаурою започаткували десять років тому. Їхній шлюб отримує одне випробування за іншим: спочатку – втрату єдиного сина і законного спадкоємця, після – визнання та прийняття сина, народженого Енцо поза шлюбом. Щоб врятувати сімейний бізнес, Феррарі вирішує ризикнути та поставити усе на Мілле Мілья – культову гонку довжиною 1000 миль Італією."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"페라리","runtime":140,"tagline":"페라리가 던진 마지막 승부수","homepage":"","overview":"파산 위기에 놓인 엔초 페라리. 회사 존폐의 기로에서 사사건건 충돌하는 아내 라우라. 아들 피에로를 페라리 가로 인정하라고 압박하는 또다른 여인 리나. 평생 쌓아온 모든 것이 무너지기 직전인 1957년 여름, 이탈리아 전역 공도를 가로지르는 광기의 1,000마일 레이스 밀레 밀리아에서 엔초 페라리는 판도를 뒤집을 마지막 승부수를 던지는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"O ex-piloto de corrida, Enzo Ferrari está em crise. A falência assombra a empresa que ele e sua mulher, Laura, construíram do nada 10 anos atrás. O casamento tempestuoso dos dois sofre com o luto pela morte de um filho e a dificuldade de reconhecer outro. Ele decide contrapor essas perdas apostando tudo em uma corrida - a icônica Mille Miglia, na Itália."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":130,"tagline":"","homepage":"","overview":"È l’estate del 1957. Dietro lo spettacolo della Formula 1, l’ex pilota Enzo Ferrari è in crisi. Il fallimento incombe sull’azienda che lui e sua moglie Laura hanno costruito da zero dieci anni prima. Il loro matrimonio si incrina con la perdita del loro unico figlio Dino. Ferrari lotta per riconoscerne un altro, avuto con Lina Lardi. Nel frattempo la passione dei suoi piloti per la vittoria li spinge al limite quando si lanciano nella pericolosa corsa che attraversa tutta l’Italia: la Mille Miglia."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":0,"tagline":"Nie można opisać pasji, można ją tylko przeżyć.","homepage":"","overview":"Były kierowca rajdowy Enzo Ferrari jest w najtrudniejszym momencie swojego życia. Firma, którą od 10 lat buduje wraz z piękną żoną Laurą, stoi u progu bankructwa."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Una película biográfica del magnate automovilístico Enzo Ferrari, cuya familia redefinió la idea del deportivo italiano de alta potencia y prácticamente generó el concepto de las carreras de Fórmula Uno."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Феррари","runtime":0,"tagline":"","homepage":"","overview":"Об автомобилях Ferrari мечтают миллионы, а имеют единицы. Это символ роскошной жизни, известный во всём мире. Но блестящий фасад скрывает трагическую историю основателя компании Энцо Феррари. Семейные проблемы, финансовый кризис, ужасные аварии и даже гнев Ватикана – всё это в своё время преодолел гениальный конструктор и бизнесмен, чтобы вписать своё имя в историю автопрома навсегда..."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Huyền Thoại Ferrari","runtime":0,"tagline":"","homepage":"","overview":"Bộ phim lấy bối cảnh nước Ý vào năm 1957, mười năm sau khi Enzo Ferrari thành lập hãng xe hơi với biểu tượng ngựa chồm được yêu thích của mình. Tuy nhiên, tình hình kinh doanh lúc đó gặp khủng hoảng giữa bối cảnh cuộc hôn nhân với người vợ Laura bế tắc sau khi con trai cả của ông là Alfredo Ferrari qua đời dù mới 26 tuổi. Những xung đột này đã khiến cho vị doanh nhân quyết định tài trợ một cuộc đua đầy mạo hiểm thuộc khuôn khổ giải Mille Miglia."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":130,"tagline":"Una Película de Michael Mann","homepage":"","overview":"Verano de 1957. El expiloto de carreras Enzo Ferrari está en crisis. La bancarrota acecha a la empresa que él y su esposa, Laura, construyeron de la nada diez años atrás. Su tormentoso matrimonio se encuentra en medio de una gran crisis, mientras lidian con la muerte de su hijo. En esta crucial etapa, Ferrari tomará decisiones arriesgadas apostándolo todo en una única carrera que atraviesa 1.000 millas a lo largo de toda Italia: la Mille Miglia."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"يتناول العمل السيرة الذاتية لمتسابق السيارات والمستثمر الإيطالي الشهير اينزو فيراري، والذي اشتهر في حلبات السباقات وامتلك علامته التجارية الشهيرة حتى وقتنا هذا (فيراري)."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Durante o verão de 1957, o ex-piloto de automóveis Enzo Ferrari vive uma crise pessoal e profissional. A empresa que construiu 10 anos antes com a sua esposa Laura enfrenta a falência. O seu turbulento casamento é ameaçado pela perda de um filho e o reconhecimento legal de outro. Na tentativa de garantir a sua sobrevivência, Enzo Ferrari aposta tudo numa corrida: a icónica Mille Miglia - 1000 milhas por Itália."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"A szenvedélyt nem lehet leírni, csak átélni.","homepage":"","overview":"1957 nyara. A Formula 1 látványosan pörög, ám az egykori versenyző, Enzo Ferrari válságos időket él meg. Csőd fenyegeti a gyárat, amit feleségével, Laurával a semmiből hoztak létre tíz évvel korábban. Vehemens házasságukra rányomta a bélyegét fiuk, Dino közelmúltban bekövetkezett halála is. Ráadásul Ferrarinak nehezére esik elismernie Lina Larditól született gyermekét, Pierót is. A versenyzés – és győzelem – iránti szenvedélye közben egyre-másra próbára teszi mindannyiukat, amikor elindulnak az Olaszország ezer mérföldnyi területén átívelő Mille Miglián."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"法拉利","runtime":0,"tagline":"","homepage":"","overview":"1957年夏天，前職業車手恩佐法拉利（亞當崔佛 飾）的人生陷入空前危機，他和妻子蘿拉（潘妮洛普克魯茲 飾）十年前創立的法拉利車廠​面臨破產，兩人的婚姻也因為兒子的過世而岌岌可危，他決定把一切都賭在一場比賽上，那就是賽程長達一千英里的「Mille Miglia千里賽」。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":131,"tagline":"","homepage":"","overview":"De zomer van 1957 verloopt moeizaam voor ex-autocoureur Enzo Ferrari: zijn autobedrijf dreigt failliet te gaan en het huwelijk met zijn vrouw Laura lijdt zwaar onder het gemis van hun overleden zoon Dino. Enzo zet zijn laatste hoop op één racewedstrijd: de Mille Miglia door Italië."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"פרארי","runtime":0,"tagline":"","homepage":"","overview":"זהו קיץ  של שנת 1957 ומאחורי העולם הנוצץ והמסוכן של פורמולה 1, נהג המרוצים לשעבר אנזו פרארי נמצא במשבר. החברה אותה הקים עם אשתו לאורה, לפני עשר שנים, נמצאת על סף פשיטת רגל. חיי הנישואים המעורערים שלהם חווים טלטלה נוספת עם הצער על אובדן בנם היחיד. במשך כל התקופה המורכבת הזו פרארי מסתיר מאשתו ניהול חיים כפולים עם אישה אחרת, לינה לארדי אתה הוא חובק בן נוסף, אבל הוא מתקשה להכיר בו כבנו החוקי.  אבל פרארי דוהר קדימה. זאת תשוקת הנהיגה שלו והרצון לנצח בכל מחיר שתביא אותו ואת קרוביו לקצה. כל הגורלות שלהם מתכנסים למרוץ אחד, מרוץ 1,000 המייל הבוגדני ברחבי איטליה והידוע כמרוץ האייקוני  'מילה מילייה'."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"法拉利 FERRARI","runtime":131,"tagline":"","homepage":"","overview":"1957 年盛夏，前一級方程式賽車手安素法拉利陷入了家庭與事業的危機：與妻子勞拉的婚姻因為兒子意外去世及婚外情而存在隔閡，而兩人共同建立的公司也面臨破產，為了拯救一切，他把所有人生賭注都壓在一場橫跨義大利的千裏賽上. . . . . ."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Ljeto je 1957. Nakon spektakla Formule 1, bivši je vozač Enzo Ferrari u krizi. Bankrot prijeti tvornici koju su on i njegova supruga Laura od temelja izgradili prije deset godina. Njihov nestalan brak razoren je gubitkom sina Dina godinu dana ranije. Ferrari se bori i na privatnom planu oko priznanja sina Piera kojeg je dobio s Linom Lardi. Osim toga, tu je i pritisak da se poveća proizvodnja automobila iako su u tijeku pripreme za opasnu kultnu utrku Mille Miglia koja se vozila od Brescie do Rima i natrag."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"L'histoire incroyable de l'entrepreneur italien de voitures Enzo Ferrari."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Ferrari","runtime":0,"tagline":"","homepage":"","overview":"Turbūt nėra pasaulyje bent kiek automobiliais besidominčio žmogaus, kuris nežinotų Ferrari vardo. Režisieriaus Michaelo Manno biografinis filmas pasakoja apie bene juodžiausią automobilių legendos Enzo Ferrario gyvenimo laikotarpį.  1957-ieji. E. Ferraris gedi prieš metus mirusio vienintelio sūnaus Alfredo. Jo santuokai su žmona Laura taip pat iškilusi grėsmė. Prieš dešimtmetį sutuoktinių įkurta automobilių gamybos kompanija – ant bankroto slenksčio.  Gyvenimui dūžtant į šipulius, vienintelė sritis, kurioje Enzo jaučiasi galintis bent kažką pakeisti, yra jo kompanija. Desperatiškai ieškodamas galimybės ją išgelbėti, E. Ferraris nusprendžia, kad jo komanda dalyvaus pragarui prilyginamose „Mille Miglia“ – žiauriose, bekompromisėse ir velniškai pavojingose tūkstančio mylių (1600 kilometrų) atviro kelio ištvermės lenktynėse Italijoje."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Poletje, leta 1957. Nekdanji voznik in ustanovitelj najbolj znane avtomobilske in dirkalne znamke na svetu Enzo Ferrari, je v krizi. Tovarni, ki sta jo z ženo Lauro pred desetimi leti zgradila iz nič, grozi stečaj. Njun buren zakon se spopada z žalovanjem za enim sinom in priznanjem za drugega. Medtem jih strast do zmage njegovih voznikov potisne na rob, ko se podajo na nevarno kultno vzdržljivostno dirko Mille Miglia, ki poteka od Brescie do Rima in nazaj."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"","runtime":130,"tagline":"","homepage":"","overview":"Το καλοκαίρι του 1967, ο πρώην οδηγός αγώνων αυτοκινήτων, Έντσο Φεράρι βρίσκεται σε κρίση. Με την εταιρεία του στα πρόθυρα της πτώχευσης και τον γάμο του να βιώνει την τραυματική απώλεια του ενός γιου, ο Φερράρι εναποθέτει την ελπίδα για την σωτηρία τους σε έναν αγώνα δρόμου 1000 μιλίων στην Ιταλία, τον εμβληματικό Mille Miglia."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Děj filmu se odehrává v létě roku 1957. V roce, kdy se bývalý automobilový závodník Ferrari (Adam Driver) ocitá ve velké krizi. Řeší problémy v manželství, smrt syna, ale také bankrot společnosti, jíž věřil. Příběh zachycuje nejen hlavního hrdinu, ale také další členy jeho rodiny, která definovala myšlenku výkonného italského sportovního vozu a prakticky stála u zrodu závodů formule 1 a také u legendární automobilové značky."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Lüks spor otomobil şirketi Ferrari'nin kurucusu Enzo Ferrari'nin hikayesini anlatacak olan film, 1957'de Ferrari'nin Mille Miglia yarışına katıldığı dönemi merkezine alıyor. Eşi Laura ile birlikte sıfırdan inşa ettikleri şirketin iflasla karşı karşıya olması, fırtınalı bir evlilik, bir oğullarının yası ve diğerinin tanınmasıyla mücadele eden Ferrari'nin sonunda ikonik yarış Mille Miglia'ya katılmaya karar vererek kayıplara karşı koymaya çalışmasının hikayesinin anlatıldığı filmin senaryosu Brock Yates'in \"Enzo Ferrari - The Man and the Machine\" adlı kitabından Troy Kennedy Martin tarafından uyarlandı."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Udspillet i løbet af sommeren 1957. Den tidligere racerkører, Enzo Ferrari, er i krise. Konkurs forfølger det firma, han og hans kone, Laura, byggede fra ingenting ti år tidligere. Deres stormfulde ægteskab kæmper med sorgen over en søn og anerkendelsen af en anden."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Im Sommer des Jahres 1957 steht der legendäre italienische Rennwagenbauer Ferrari kurz vor dem Bankrott. Kaum jemand will die sündhaft teuren Luxusautos kaufen und auch im Rennsport hat die Konkurrenz von Maserati die Nase vorn. Im Privaten sieht es nicht besser aus: Enzo Ferrari und seine Frau Laura, die das Unternehmen vor zehn Jahren aus dem Nichts aufgebaut haben, haben sich über den tragischen Tod ihres gemeinsamen Sohnes völlig auseinandergelebt. Als Laura dann auch noch von Enzos langjähriger Liebschaft mit Lina Lardi erfährt, mit der er sogar ein Kind gezeugt hat, entfacht sie einen Krieg um die Firma. Mit dem Rücken zur Wand entscheidet sich Enzo dazu, sein Rennteam am berüchtigten Mille Miglia-Langstrecken-Straßenrennen teilnehmen zu lassen, mit katastrophalen Folgen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"ფერარი","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Ферари","runtime":0,"tagline":"","homepage":"","overview":"Радња се одвија у лето 1957. Бивши возач тркачких аутомобила Енцо Ферари је у кризи. Банкрот прати компанију коју су он и његова супруга Лаура изградили из ничега десет година раније. Њихов буран брак бори се са тугом за једним сином и признањем другог."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"فراری","runtime":124,"tagline":"","homepage":"https://www.ferrari-film.com/","overview":"داستان زندگی انزو فراری، سازنده ایتالیایی خودروهای اسپرت و موسس شرکت فراری، که با وجود مشکلات بسیار در خانواده، برای برنده شدن در یک مسابقه معروف اتومبیل رانی همه چیز را به خطر انداخت و..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Kesällä 1957 entinen Formula 1 -kilpa-autoilija, ikoninen Enzo Ferrari on kriisin partaalla: konkurssi uhkaa autotehdasta, jonka hän ja hänen vaimonsa Laura rakensivat tyhjästä kymmenen vuotta aiemmin. Samalla heidän intohimoista, mutta myrskyisää avioliittoaan varjostaa heidän poikansa Dinon menetys vuotta aiemmin. Ferrari myös kamppailee toisen, avioliiton ulkopuolella syntyneen poikansa Pieron virallisen tunnustamisen kanssa. Samaan aikaan kiihkeä intohimo kilpa-ajamista kohtaan ajaa Enzo Ferraria äärirajoille, kun hän suuntaa kohti Mille Migliaa, vaarallista liki 1 000 mailin kilpailua Italian halki."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Ферари","runtime":0,"tagline":"","homepage":"","overview":"Базиран на книгата Ферари – мъжът, автомобилите, състезанията, машината на Брок Йейтс, Ferrari ни отвежда през лятото на 1957 г. На фона на грандиозния спектакъл Формула 1 бившият състезател Енцо Ферари преживява истинска криза. Фалит заплашва фабриката, която той и съпругата му Лаура са изградили от нищото десет години по-рано. Нестабилният им брак е разтърсен и разбит от загубата на сина им Дино година преди това. Ферари трудно намира сили да приеме другия си син – Пиеро, от любовницата си Лина Ларди. Междувременно жаждата за победа на пилотите му ги тласка до ръба, когато те се впускат в емблематичното, но коварно състезание Миле Миля – 1 000 мили през Италия."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Estiu del 1957. L'expilot de carreres, Ferrari, està en crisi. La fallida aguaita l'empresa que ell i la seva dona, Laura, van construir del no-res deu anys abans. El seu tempestuós matrimoni es troba enmig d'una gran crisi, mentre lidien amb la mort del seu fill. En aquesta crucial etapa, Ferrari prendrà decisions arriscades, i ho aposta tot en una única carrera que travessa 1.000 milles al llarg de tot Itàlia, la Mille Miglia."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"フェラーリ","runtime":0,"tagline":"魂が、高鳴る。","homepage":"https://www.ferrari-movie.jp/","overview":"1957年。イタリアの自動車メーカー「フェラーリ」の創始者エンツォ・フェラーリは激動の渦中にいた。妻ラウラとともに設立した会社は経営の危機に瀕し、1年前の息子ディーノの死により家庭は破綻。その一方で、愛するパートナー、リナ・ラルディとの間に生まれた息子ピエロを認知することは叶わない。再起を誓ったエンツォは、イタリア全土1000マイルを走る過酷なロードレース“ミッレミリア”にすべてを賭けて挑む——。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Det utspelar sig 1957 och det krisar på Enzo Ferraris bilimperium. Den före detta racerföraren som blev entreprenör pressar sig själv och sina förare till bristningsgränsen när de sätter fart mot Mille Miglia, ett förrädiskt lopp på 1 600 kilometer genom Italien."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"فيراري","runtime":0,"tagline":"","homepage":"","overview":"صيف عام 1957. يمر سائق السباق السابق إنزو فيراري بأزمة. يطارد الإفلاس الشركة التي بدأها هو وزوجته لورا قبل عشر سنوات. يواجه زواجهما تجربة تلو الأخرى: أولًا فقدان ابنهما الوحيد ووريثهما الشرعي، ثم الاعتراف وقبول ابن إنزو خارج إطار الزواج. لإنقاذ شركة العائلة، تقرر فيراري المخاطرة والمراهنة بكل شيء على سباق ميلي ميليا، وهو السباق الشهير الذي يبلغ طوله 1000 ميل عبر إيطاليا."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Este vara anului 1957. Dincolo de spectacolul de Formula 1, fostul pilot, Enzo Ferrari, este în plină criză. Acum zece ani, împreună cu soția sa, Laura, a construit o fabrică de la zero, aflată la momentul actual în pragul falimentului. Căsnicia lor volatilă a fost afectată de moartea unuia dintre fii, Dino, cu un an mai devreme, și de acceptarea relației celui de-al doilea fiu, Piero, cu Lina Lardi. Între timp, pasiunea sa pentru victorie îl determină să mizeze pe o singură cursă periculoasă de 1.000 de mile prin Italia, Mille Miglia."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"สปีดทวงบัลลังก์","runtime":0,"tagline":"","homepage":"","overview":"เบื้องหลังความยิ่งใหญ่ของตำนานแห่งวงการฟอร์มูล่าวัน คือชีวิตสุดกดดันที่ชายหนึ่งคนต้องแบบรับ กลางฤดูร้อนของปี 1957 เอนโซ เฟอร์รารี อดีตนักแข่งที่ผันตัวมาเป็นผู้ผลิตกำลังเผชิญวิกฤตชีวิต บริษัทที่เขาและภรรยา ลอร่า ปั้นมากับมือเมื่อ 10 ปีก่อนกำลังจะล้มละลาย ชีวิตคู่ก็สั่นคลอนหลังจากเสีย ดิโน ลูกชายไปเมื่อปีก่อน เฟอร์รารีพบว่าตัวเองต้องกลั้นใจยอมรับ ปิเอโร ลูกชายนอกสมรสของเขากับ ลีน่า ลาร์ดี เป็นลูกตัวเอง ในขณะเดียวกัน แพชชันอันแรงกล้าในการแข่งขันของเขา บีบทุกคนให้เผชิญหน้ากับขีดจำกัด เมื่อเอนโซตัดสินใจพาทีมลงแข่งขันสุดทรหด Mille Miglia ที่กินระยะทางกว่า 1,000 ไมล์ทั่วอิตาลี ซึ่งเป็นความหวังสุดท้ายให้บริษัทของเขายังเดินหน้าต่อไปได้"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Ir 1957. gada vasara. 20. gadsimta 50. gadu Pirmās Formulas spozmes un adrenalīna fonā tās bijušais autobraucējs Enco Ferrari nonācis krīzē. Uzņēmumam, ko viņi ar sievu Lauru izveidojuši pirms desmit gadiem, draud bankrots. Vētrainā laulība cietusi no sērām par dēla Dino nāvi. Ferrari rodas grūtības atzīt savu otru, ārlaulības dēlu. Viņa sacīkšu braucēja kāre uzvarēt noved viņu līdz riska robežai. Viņš liek uz spēles visus kauliņus, piesakoties viltīgajās tūkstoš jūdžu sacīkstēs „Mille Miglia”."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Suvel 1957 aastal valitseb Enzo Ferrari autoimpeeriumis kriis. Endisest võidusõitjast ettevõtja paneb end ja oma sõitjaid proovile. Üheskoos võtavad nad ette 1609 kilomeetri pikkuse ohtliku Mille Miglia võidusõidu."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Film Ferrari je pôsobivou filmovou kronikou jednej z najikonickejších postáv automobilového sveta – Enza Ferrariho. Tento životopisný, dramatický a zároveň akčný športový film ponúka fascinujúci pohľad do zákulisia života muža, ktorého meno sa stalo synonymom rýchlosti, vášne a nekompromisného perfekcionizmu. Príbeh sa sústreďuje na kľúčové obdobie v roku 1957, kedy Ferrari čelí existenčnej kríze – ako vo svojej osobnej rovine, tak aj v rámci svojej automobilky. Film sleduje Enza v momente, keď sa jeho manželstvo s Laurou zmieta v napätí spôsobenom tragickou smrťou ich syna Dina, zatiaľ čo jeho firma čelí finančnému kolapsu. Enzo zároveň bojuje s požiadavkami pretekárskeho sveta, v ktorom ho každé rozhodnutie môže stáť život."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"}],"reviews_tmdb":[{"id":"64f1e1d8e0ca7f00ec875dd0","url":"https://www.themoviedb.org/review/64f1e1d8e0ca7f00ec875dd0","author":"Manuel São Bento","content":"FULL SPOILER-FREE REVIEW @ https://fandomwire.com/ferrari-venice-film-festival-review-penelope-cruz-drives-an-uneven-biopic/\r\n\r\n\"Ferrari has the potential to be a memorable biopic but lacks a more thoughtful emotional focus in its performance-driven character study. Adam Driver is excellent, but Penélope Cruz clearly stands out with an emotionally devastating performance.\r\n\r\nThe dialogues between the main couple are the highlights of a globally abrupt film that deals with the deaths of people outside the family nucleus in a manner that is too fleeting and insignificant, in addition to overdramatizing a particular subplot.\r\n\r\nCompetent racing sequences. It fulfills the basic purpose of telling the story of a complex man whose life is much sadder than one can imagine.\"\r\n\r\nRating: B-","created_at":"2023-09-01T13:06:32.783Z","updated_at":"2023-09-01T13:06:32.874Z","author_details":{"name":"Manuel São Bento","rating":6,"username":"msbreviews","avatar_path":null}},{"id":"6590032041a56166da04744b","url":"https://www.themoviedb.org/review/6590032041a56166da04744b","author":"CinemaSerf","content":"$11","created_at":"2023-12-30T11:46:41.023Z","updated_at":"2023-12-30T11:46:41.131Z","author_details":{"name":"CinemaSerf","rating":6,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":1128668,"adult":false,"title":"Santocielo","video":false,"overview":"In paradise, a group gathers to discuss why people still act selfishly, even though Jesus sacrificed himself for them 2,000 years ago. As a result, a new Messiah is sent to Earth to address the issue.","genre_ids":[35,14],"media_type":"movie","popularity":0.6489,"vote_count":171,"poster_path":"/dLDyJunOnqwCdQesG6mvCWCWCEs.jpg","release_date":"2023-12-14","vote_average":5.918,"backdrop_path":"/8mXqTjyxfC9iA5KEkwU0Aq6DCtx.jpg","original_title":"Santocielo","original_language":"it"},{"id":823452,"adult":false,"title":"The Boys in the Boat","video":false,"overview":"The triumphant underdog story of the University of Washington men's rowing team, who stunned the world by competing at the 1936 Berlin Olympics.","genre_ids":[18,36],"media_type":"movie","popularity":1.6749,"vote_count":332,"poster_path":"/ncJMztHprw3gLRAnDjNnnT23CIt.jpg","release_date":"2023-12-25","vote_average":7.231,"backdrop_path":"/gub9e0qRZWmmzTV77A6T95HELIF.jpg","original_title":"The Boys in the Boat","original_language":"en"},{"id":1013221,"adult":false,"title":"100 Sundays","video":false,"overview":"Antonio, a former shipyard worker, leads a mild and peaceful life: he plays bowls with friends, takes care of his elderly mother, has an ex-wife with whom he is on excellent terms and Emilia, his only and beloved daughter When Emilia announces to him one day that she has decided to get married, Antonio is filled with joy, he can finally fulfill his dream by giving her the reception they have always dreamed of together being able to count on the savings of a lifetime.However, the bank of which he has always been a client seems to be hiding something, the employees are suddenly elusive and the director inexplicably changes constantly.The task of paying for his daughter's wedding will prove increasingly difficult and Antonio will discover, against his will, that those who keep our treasures don't always keep our dreams as well.","genre_ids":[18],"media_type":"movie","popularity":2.6163,"vote_count":176,"poster_path":"/yVYTR3TA8c3eoHPAg2lwt3UBWmK.jpg","release_date":"2023-11-23","vote_average":6.722,"backdrop_path":"/aWLkVSdeTpO3OXkP1qNCnqaV51L.jpg","original_title":"Cento domeniche","original_language":"it"},{"id":440626,"adult":false,"title":"Sobibor","video":false,"overview":"The film is based on a real story that happened in 1943 in the Sobibor concentration camp in German-occupied Poland. The main character of the movie is the Soviet-Jewish soldier Alexander Pechersky, who at that time was serving in the Red Army as a lieutenant. In October 1943, he was captured by the Nazis and deported to the Sobibor concentration camp, where Jews were being exterminated in gas chambers. But, in just 3 weeks, Alexander was able to plan an international uprising of prisoners from Poland and Western Europe. This uprising resulted in being the only successful one throughout the war, which led to the largest escape of prisoners from a Nazi concentration camp.","genre_ids":[10752,18],"media_type":"movie","popularity":1.5513,"vote_count":327,"poster_path":"/dnexT2if0lRTp8jsGSOY4JVAnnj.jpg","release_date":"2018-05-03","vote_average":6.6,"backdrop_path":"/zjVz2XCXKwb0FX8qge1LbTd80H.jpg","original_title":"Собибор","original_language":"ru"},{"id":972433,"adult":false,"title":"Race for Glory: Audi vs. Lancia","video":false,"overview":"Inspired by true events that occurred during the fierce rivalry between Germany (Audi) and Italy (Lancia) at the 1983 Rally World Championships.","genre_ids":[18,36],"media_type":"movie","popularity":1.0272,"vote_count":242,"poster_path":"/ovoybG8mCn6nQ6i5WoC8DdR08c2.jpg","release_date":"2024-01-05","vote_average":6.041,"backdrop_path":"/1aL5xmJJKxur5GJ1glJSOLK3xnG.jpg","original_title":"Race for Glory: Audi vs. Lancia","original_language":"en"},{"id":792307,"adult":false,"title":"Poor Things","video":false,"overview":"Brought back to life by an unorthodox scientist, a young woman runs off with a lawyer on a whirlwind adventure across the continents. Free from the prejudices of her times, she grows steadfast in her purpose to stand for equality and liberation.","genre_ids":[878,10749,35],"media_type":"movie","popularity":12.0713,"vote_count":5311,"poster_path":"/kCGlIMHnOm8JPXq3rXM6c5wMxcT.jpg","release_date":"2023-12-07","vote_average":7.655,"backdrop_path":"/zh6IdheEYinU4TPtorWsjx6qPQE.jpg","original_title":"Poor Things","original_language":"en"},{"id":855262,"adult":false,"title":"Pinball: The Man Who Saved the Game","video":false,"overview":"The dramatic comedy is based on the true story of writer and pinball wizard Roger Sharpe, chronicling his journey to overturn New York City’s 35-year ban on pinball.","genre_ids":[35,18,36,10749],"media_type":"movie","popularity":0.6667,"vote_count":91,"poster_path":"/gjGphbx4ZDwAYYWImpY427KGw7B.jpg","release_date":"2023-03-17","vote_average":7,"backdrop_path":"/iDTcJtM7MTRxkOpy1h7FuoS4t7i.jpg","original_title":"Pinball: The Man Who Saved the Game","original_language":"en"},{"id":1214020,"adult":false,"title":"WAR IS OVER! Inspired by the Music of John & Yoko","video":false,"overview":"Set in an alternate WWI reality where a senseless war rages on, two soldiers on opposite sides of the conflict play a joyful game of chess. A heroic carrier pigeon delivers the soldiers' chess moves over the battlefield as the fighting escalates. Neither soldier knows his opponent as the game and the war builds to its climatic final move. Whoever wins the game, one thing is for certain: there are no winners in war.","genre_ids":[16,10402,10752],"media_type":"movie","popularity":0.63,"vote_count":41,"poster_path":"/c8HG8jpjVa44hgMkVN91ZQ0Iw5B.jpg","release_date":"2023-12-05","vote_average":6.3,"backdrop_path":"/ulKRqaetuOTOLeQu9zj1FLhSoF9.jpg","original_title":"WAR IS OVER! Inspired by the Music of John & Yoko","original_language":"en"},{"id":766931,"adult":false,"title":"Born a Champion","video":false,"overview":"After a blood- soaked jujitsu match in Dubai, fighting legend Mickey Kelley falls to superstar Blaine. But years later, an online video proves that Blaine cheated, and the world demands a rematch. Can the aging underdog get back into shape in time to vanquish his foe, get revenge, and claim his prize?","genre_ids":[28,18],"media_type":"movie","popularity":0.7899,"vote_count":136,"poster_path":"/ijizwYu2B04gVkrbGlclAAfdN3p.jpg","release_date":"2021-01-22","vote_average":6.989,"backdrop_path":"/3EwbyRUmZNnkTEkYE1QQy9WwNbK.jpg","original_title":"Born a Champion","original_language":"en"},{"id":927594,"adult":false,"title":"Love Life","video":false,"overview":"Taeko and her husband, Jirō, are living a peaceful existence with her young son, Keita, when a tragic accident brings the boy's long-lost father, Park, back into her life. To cope with the pain and guilt, Taeko throws herself into helping this deaf and homeless man.","genre_ids":[18],"media_type":"movie","popularity":0.7242,"vote_count":101,"poster_path":"/5OSTURpAJCFsUydL6w4JPx48SSQ.jpg","release_date":"2022-09-09","vote_average":7.228,"backdrop_path":"/8FgFpyqpm5XZ8JpYXv6iHyQ7lKa.jpg","original_title":"LOVE LIFE","original_language":"ja"},{"id":1018494,"adult":false,"title":"Operation Seawolf","video":false,"overview":"During the last days of World War II, Germany, desperate for any last grasp to defeat the allied powers, looked to their last remaining weapons and soldiers. The German Navy and the last remaining U-Boats were formed together for one desperate last mission – a mission to attack the United States Homeland, known as Operation Seawolf. Captain Hans Kessler, a grizzled submarine commander from both World Wars, is called into service to make one mission a success and help turn the tide of the war.","genre_ids":[10752,53,28,12],"media_type":"movie","popularity":1.3478,"vote_count":113,"poster_path":"/eqm5EAyC9hJCN5qutuW4Ka1xYbU.jpg","release_date":"2022-10-07","vote_average":5.633,"backdrop_path":"/6fYTLy4QE55BgMiHF3Co7bErjry.jpg","original_title":"Operation Seawolf","original_language":"en"},{"id":843394,"adult":false,"title":"Cat Person","video":false,"overview":"When Margot, a college sophomore, goes on a date with the older Robert, she finds that IRL Robert doesn’t live up to the Robert she has been flirting with over texts.","genre_ids":[53,35],"media_type":"movie","popularity":2.7406,"vote_count":101,"poster_path":"/atrfmVWmw9NPrpFSfgUE2XG7eF9.jpg","release_date":"2023-10-06","vote_average":5.693,"backdrop_path":"/fJGjHVvlaUecsRJ4nnDr6SPyt3x.jpg","original_title":"Cat Person","original_language":"en"},{"id":1066575,"adult":false,"title":"Winter Lemons","video":false,"overview":"Pietro and Eleonora, both avid gardeners, are strangers who only meet because their two terraces are close to each other. The relationship that grows between them helps them to alleviate the pain each feels over something secret and very serious, a pain both try to hide from themselves and those around them. In this limbo they inhabit, the two make a stab at finding happiness together, until their paths diverge once more.","genre_ids":[10749],"media_type":"movie","popularity":0.3491,"vote_count":39,"poster_path":"/32jzdFfVwzHGwjqNWnfnUzF6iAC.jpg","release_date":"2023-11-30","vote_average":6.372,"backdrop_path":"/klw6b8aNAcdGqsb7kmkUo3QOBny.jpg","original_title":"I limoni d'inverno","original_language":"it"},{"id":937220,"adult":false,"title":"Bank of Dave","video":false,"overview":"The true story of how Dave Fishwick, a working class man and self-made millionaire, fought to set up a community bank so that he could help the local businesses of Burnley not only survive, but thrive. In his bid to help his beloved community, he has to take on the elitist financial institutions of London and fight to receive the first, new banking license to be issued in over 100 years.","genre_ids":[35,18],"media_type":"movie","popularity":0.7071,"vote_count":121,"poster_path":"/pKZ8nURAqNmuSpKVTYGko7SD1GP.jpg","release_date":"2023-03-10","vote_average":6.88,"backdrop_path":"/wcka0WH6otb1xueWk62Rpxqh3nm.jpg","original_title":"Bank of Dave","original_language":"en"},{"id":17606,"adult":false,"title":"The Other Man","video":false,"overview":"The story of a husband who suspects his wife of adultery, and sets out to track down the other man in her life.","genre_ids":[18,53,9648,10749],"media_type":"movie","popularity":0.9885,"vote_count":238,"poster_path":"/qtHxTrhdLjToXz1nR0lTYf75t5k.jpg","release_date":"2008-12-25","vote_average":5.357,"backdrop_path":"/fY0oDU9Tq9U2gROvwqIRFgiPDGJ.jpg","original_title":"The Other Man","original_language":"en"},{"id":1069185,"adult":false,"title":"Inshallah a Boy","video":false,"overview":"After the sudden death of her husband, working mother Nawal has to fight for her inheritance in order to save her daughter and home in a society where having a son would be a game changer.","genre_ids":[18],"media_type":"movie","popularity":0.2303,"vote_count":23,"poster_path":"/7nQgIXi8BQSFASb15fWVQBTthgW.jpg","release_date":"2024-01-12","vote_average":7.087,"backdrop_path":"/9rUN2bgCsnIvACLPWQXi2YbgxHM.jpg","original_title":"إن شاء الله ولد","original_language":"ar"},{"id":1008048,"adult":false,"title":"How to Blow Up a Pipeline","video":false,"overview":"A crew of young environmental activists execute a daring mission to sabotage an oil pipeline.","genre_ids":[80,18,53],"media_type":"movie","popularity":0.8412,"vote_count":179,"poster_path":"/5HJF47ywTuxxouVdAHAZ7iPzB4T.jpg","release_date":"2023-04-07","vote_average":6.371,"backdrop_path":"/2QUrL1jVuTe2eRuyDmHlLwDdAM1.jpg","original_title":"How to Blow Up a Pipeline","original_language":"en"},{"id":1032795,"adult":false,"title":"The Hijacking of Flight 375","video":false,"overview":"Brazil, 1988. An unemployed tractor driver hijacks VASP flight 375 and orders commander Murilo to crash the plane on the Planalto Palace to kill the president - whom he considers guilty for the country's devastating economic crisis.","genre_ids":[53,18],"media_type":"movie","popularity":0.4911,"vote_count":53,"poster_path":"/xhZXZRMXzJlMpMuibmJx4By1iIb.jpg","release_date":"2023-12-07","vote_average":7.84,"backdrop_path":"/mQWZ1IgBqv3bcQtc6OwlcvtvYmH.jpg","original_title":"O Sequestro do Voo 375","original_language":"pt"},{"id":1113505,"adult":false,"title":"Family Matters","video":false,"overview":"Marco, Guido, Leo, Luisa, Gaelle and Mattia have different mothers, they are not all biological children of the same father but they have a single true father figure of reference: Manfredi Alicante. When the latter passes away, they all find themselves together for the first time in their father's house in Bordeaux, living the illusion of being able to become a united family. But now each of them brings with them a story, an identity and going back won't be easy.","genre_ids":[35],"media_type":"movie","popularity":0.1509,"vote_count":40,"poster_path":"/s0dOH8kGNnFvuklzKqBdmFD1VRj.jpg","release_date":"2024-05-01","vote_average":6,"backdrop_path":"/8tRMWphlmPWNRN6zvD5xBxbhoDb.jpg","original_title":"Sei fratelli","original_language":"it"},{"id":852758,"adult":false,"title":"I Am the Abyss","video":false,"overview":"The Man Who Cleans knows you can find a lot of secrets in trash. People tend to lie but their trash never does. The Man Who Cleans thought he was invisible, until he met the Girl with the Purple Hair Lock. Girl with the Purple Hair Lock breaks into his tidy life because only an evil angel can save her now. Meanwhile, the Huntress knows somebody is killing blonds out there. Nobody believes her, but she knows. What she doesn't know, though, is that evil is hiding behind the green door. The truth lies at the bottom of a dark, deep abyss.","genre_ids":[53,80],"media_type":"movie","popularity":0.276,"vote_count":114,"poster_path":"/grarRx57AFkQGuyY856Ex8RMkQp.jpg","release_date":"2022-10-27","vote_average":5.715,"backdrop_path":"/s5MVkbChPVrTKlJmZlh6dN3T7Hb.jpg","original_title":"Io sono l'abisso","original_language":"it"}],"similar_content":[{"id":1058435,"adult":false,"title":"The Blue Whale","video":false,"overview":"The film revolves around the \"Blue Whale Challenge\" game used by many young people and adolescents, after the spread of technology and the parents are too busy to look after their children which might lead to their exposure to great risks.","genre_ids":[18,53,27],"popularity":0.3732,"vote_count":0,"poster_path":"/pZEeURRtkuUTVe5mevPzLbugGRF.jpg","release_date":"2020-08-26","vote_average":0,"backdrop_path":"/e15IvvWX3dl8zTYiaK535ylCz7Q.jpg","original_title":"الحوت الأزرق","original_language":"ar"},{"id":462824,"adult":false,"title":"Jack Kerouac's Road: A Franco-American Odyssey","video":false,"overview":"Part documentary, part drama, this film presents the life and work of Jack Kerouac, an American writer with Québec roots who became one of the most important spokesmen for his generation. Intercut with archival footage, photographs and interviews, this film takes apart the heroic myth and even returns to the childhood of the author whose life and work contributed greatly to the cultural, sexual and social revolution of the 1960s.","genre_ids":[18,99],"popularity":0.136,"vote_count":1,"poster_path":"/8j5ATlmngqvYwJla20vzUDB7hhw.jpg","release_date":"1987-03-01","vote_average":8,"backdrop_path":"/hsQ4QbsXgANCTOCypKWJHpvNYb.jpg","original_title":"Le Grand Jack","original_language":"fr"},{"id":854239,"adult":false,"title":"Till","video":false,"overview":"The true story of Mamie Till Mobley’s relentless pursuit of justice for her 14 year old son, Emmett Till, who, in 1955, was lynched while visiting his cousins in Mississippi.","genre_ids":[18,36],"popularity":2.7651,"vote_count":322,"poster_path":"/cmDs0CYlgioyP2AQQTTmavt3uoO.jpg","release_date":"2022-10-14","vote_average":7.29,"backdrop_path":"/xFKjWcxEumvwEhovqTDzoDCmD45.jpg","original_title":"Till","original_language":"en"},{"id":274428,"adult":false,"title":"Moment of Truth: A Child Too Many","video":false,"overview":"Patty Nowakowski already has three children, but decides to be a surrogate mother. Fully confident of being able to give up her baby, she is nonetheless stunned when she discovers that she is expecting twins, and the couple for whom she is pregnant will only accept one child, provided it is female.","genre_ids":[18,10770],"popularity":0.1467,"vote_count":7,"poster_path":null,"release_date":"1993-10-11","vote_average":5.6,"backdrop_path":null,"original_title":"Moment of Truth: A Child Too Many","original_language":"en"},{"id":3111,"adult":false,"title":"A Star Is Born","video":false,"overview":"A movie star helps a young singer-actress find fame, even as age and alcoholism send his own career into a downward spiral.","genre_ids":[18,10402,10749],"popularity":1.1728,"vote_count":325,"poster_path":"/zpg2SzpYhZk1D1seDfIIlwaqAxT.jpg","release_date":"1954-10-01","vote_average":7.143,"backdrop_path":"/5wOyvfih0eVK3MIxI8TK8hSCJlM.jpg","original_title":"A Star Is Born","original_language":"en"},{"id":3133,"adult":false,"title":"Badlands","video":false,"overview":"An impressionable teenage girl from a dead-end town and her older greaser boyfriend embark on a killing spree in the South Dakota badlands.","genre_ids":[80,18,10749],"popularity":3.4184,"vote_count":1308,"poster_path":"/z81rBzHNgiNLean2JTGHgxjJ8nq.jpg","release_date":"1974-01-05","vote_average":7.471,"backdrop_path":"/5rp9Jydh9RxrvVBW2lr27B8NYiT.jpg","original_title":"Badlands","original_language":"en"},{"id":3033,"adult":false,"title":"Gods and Monsters","video":false,"overview":"It's 1957, and James Whale's heyday as the director of \"Frankenstein,\" \"Bride of Frankenstein\" and \"The Invisible Man\" is long behind him. Retired and a semi-recluse, he lives his days accompanied only by images from his past. When his dour housekeeper, Hannah, hires a handsome young gardener, the flamboyant director and simple yard man develop an unlikely friendship, which will change them forever.","genre_ids":[18],"popularity":0.955,"vote_count":382,"poster_path":"/awvJH3NtXoStsjAtXKr99hfuVaG.jpg","release_date":"1998-09-12","vote_average":6.933,"backdrop_path":"/v1HOjtXoGwQz26fT4elHeNT0JnW.jpg","original_title":"Gods and Monsters","original_language":"en"},{"id":3037,"adult":false,"title":"Yella","video":false,"overview":"A young East German woman leaves her husband and business partner and relocates to a West German city to start anew as an accountant, but he soon catches up with her.","genre_ids":[18,53,27],"popularity":0.3806,"vote_count":106,"poster_path":"/axC6pBrFc7Y2I6pFzvvte9uRf9x.jpg","release_date":"2007-09-13","vote_average":6.2,"backdrop_path":"/4GeaiLZkVtCDMoPHPsDEXVQSGjB.jpg","original_title":"Yella","original_language":"de"},{"id":274411,"adult":false,"title":"The Prime Minister","video":false,"overview":"A biopic of the legendary Benjamin Disraeli, his rise from a foppish young novelist to the Prime Minister of the United Kingdom and confidante of Queen Victoria.","genre_ids":[18,36,10749,10752],"popularity":0.3859,"vote_count":1,"poster_path":"/6wBKYVdX9sloBky3cmIfLw6XKqo.jpg","release_date":"1941-03-04","vote_average":6,"backdrop_path":null,"original_title":"The Prime Minister","original_language":"en"},{"id":3418,"adult":false,"title":"Death Watch","video":false,"overview":"In a future world where the disease has been finally defeated and everything can be sold, even the crude spectacle of death, the rare case of a dying woman becomes the morbid theme of a revolutionary reality show, broadcast through the curious eyes of a peculiar camera.","genre_ids":[18,878],"popularity":0.5695,"vote_count":111,"poster_path":"/wSuvftmbs0fInDe69u8yDUtElsp.jpg","release_date":"1980-01-23","vote_average":6.3,"backdrop_path":"/hjqOmIZVSZLqqUkTuzZmTUUmoQP.jpg","original_title":"La Mort en direct","original_language":"fr"},{"id":2977,"adult":false,"title":"Becoming Jane","video":false,"overview":"Though young Jane Austen's financially strapped parents expect her to marry the nephew of wealthy Lady Gresham, Jane herself knows that such a union will destroy her creativity and sense of self-worth. Instead, she becomes involved with Tom Lefroy, a charming but penniless apprentice lawyer who gives her the knowledge of the heart she needs for her future career as a novelist.","genre_ids":[10749,18],"popularity":1.7105,"vote_count":1238,"poster_path":"/9v2hp5qrhx8JpodGPVYfRrSAxuv.jpg","release_date":"2007-03-02","vote_average":7.311,"backdrop_path":"/r95IP56O3j8fz9a09x55lymr9uJ.jpg","original_title":"Becoming Jane","original_language":"en"},{"id":3291,"adult":false,"title":"Good Night, and Good Luck.","video":false,"overview":"The story of journalist Ed