":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/cPy57o3A8luUbdPP0EpHCPbHs7B.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/aB2XutxybOIDpqXWd8Jef9CAIaZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/6oZIj1kAiVWiTEmqWQmAJXVmU28.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/mr5N3nWVIzWYHmHIpeoPY9FKIGn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1450,"height":816,"file_path":"/7NSYeNaW04e5sgrR1qjTArvgE9q.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1920,"height":1080,"file_path":"/yrFECPsaW0QemCv31YsOtSWF8Lu.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/b5AKAxgVLWQiZdimPHkzGMgVV2x.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/611FKzey5Ms2uRuC4hXczj7RORn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/lcP1ZLJe0lUuJvqegj7p8gl2hZu.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/qCdeFYX6omsSzlbI7sDDecUbZWl.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":0},{"width":1451,"height":816,"file_path":"/f4R9K10s5u9k1uys62JQTx7HoV7.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1451,"height":816,"file_path":"/ocnZvifvrVQ32fLPwX39rtTSqYv.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/9RkcoSk0ILUrKU480DqGo1kWSz6.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1892,"height":1064,"file_path":"/zA672Rv8HlUBMvG8s76JAgyW8ej.jpg","iso_639_1":"el","iso_3166_1":"GR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/rRe2PLXdt5QpFjZ68Me1bvsdUaO.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/dh4QuvcvLrbxUoiAF5eMMieAWqA.jpg","iso_639_1":"hi","iso_3166_1":"IN","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/p6zYo5m1qgM0hjJxaQhsW6VCjUf.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/dx1YiKtZ1T79xq1h4ReGe5HX31J.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:55:54.449+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Malena","runtime":108,"tagline":"Too young to be a widow, too beautiful to be alone.","homepage":"","overview":"During WWII, a teenage boy discovering himself becomes love-stricken by Malèna, a sensual woman living in a small, narrow-minded Italian town."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Der Zauber von Malèna","runtime":109,"tagline":"","homepage":"","overview":"Malèna ist die schönste Frau in dem kleinen sizilianischen Dorf. Als ihr Mann in den Krieg eingezogen wird, wenden sich alle Männer des Dorfes ihr zu, die Frauen stricken aus Eifersucht ein Netz der Intrigen. Renato ist noch ein Junge aber schon besessen von Malèna ..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Малена","runtime":100,"tagline":"«Она была слишком красива, а он был слишком молод, чтобы защитить её»","homepage":"","overview":"Малена - красавица-вдова, наваждение мужчин и предмет зависти женщин. Жены распускают о ней грязные сплетни. Мужья преследуют ее по пятам и грезят о ней. «Мне было 13, когда я увидел ее впервые. Прошло время, я любил многих женщин, и когда мы были близки, они спрашивали: буду ли я помнить их? И я говорил: да, я буду помнить вас. Но единственная, кого я никогда не забуду - та, которая никогда не спрашивала. Малена»."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Malena","runtime":0,"tagline":"","homepage":"","overview":"Dünya, ülkelerin arasındaki politik çıkmazlar sebebiyle büyük bir savaşın gölgesindedir. Bu dünyada gençliğine ulaşmaya çabalayan bir çocuk ise kasabalarına gelen, güzeller güzeli bir genç kadın olan Malena'nın etkisiyle kendi erkek kimliğini bulmak üzeredir. Malena, tüm güzelliğiyle faşist bir İtalyan kasabasını derinden etkilemektedir. Bütün kasabayı birbirine düşürecek olan genç, seksi ve dul kadın, bu kasabanın hem başlangıcı hem de sonu olmak üzeredir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":109,"tagline":"Trop jeune pour être veuve, trop belle pour être seule.","homepage":"","overview":"Au printemps 1940, Mussolini a déclaré la guerre à la France et à la Grande‐Bretagne. La ville sicilienne de Castelcuto est en liesse. Renato Amoroso, un garçon de treize ans, est heureux pour d’autres raisons. Il vient de recevoir sa première bicyclette et de tomber sous le charme de Malèna, une ravissante veuve de guerre qui fait tourner la tête à tous les hommes du village et attise la haine des épouses jalouses. Renato, littéralement envoûté, la suit partout avec son vélo. Mais Malèna est victime des refoulements et des convoitises des habitants de Castelcuto. Le petit garçon va trouver le moyen de l’aider, et grâce à elle, il apprendra les leçons de la vie."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":109,"tagline":"Demasiado joven para ser viuda, demasiado hermosa para estar sola.","homepage":"","overview":"Malena es la belleza más encantadora e irresistible de Castelcuto, un aburrido pueblo de la soleada costa siciliana. Es nueva en la población y estando su marido en la guerra, cada paseo que da por el pueblo se convierte en un espectáculo, acompañado por las lujuriosas miradas de los hombres de la localidad y de los resentidos cotilleos de sus envidiosas esposas. Un ejército de flacos adolescentes en bicicleta la sigue allí donde vaya, con la única intención de observar su exquisita y arquetípica belleza. Entre ellos se encuentra Renato Amoroso, un chico de trece años con mucha imaginación que lleva su deseo a unos límites inesperados de obsesiva fantasía."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":108,"tagline":"","homepage":"","overview":"Ambientato in Sicilia negli anni della II Guerra Mondiale, è la storia della folle passione che un ragazzino, Renato Amoroso, nutre per la donna più bella e desiderata del paese: Malèna. Mentre Renato scopre la sessualità immaginando Malèna, di volta in volta, come la Jane di Tarzan, Cleopatra, la pupa del gangster o la bella dei calendarietti per barbieri, Malèna vive la sua parabola da giovane moglie, poi vedova, a prostituta."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"西西里的美丽传说","runtime":109,"tagline":"她太年轻了，不能当寡妇，太漂亮了，不能独自一人。每个男人都想拥有她。一个男孩冒着一切危险保护她。","homepage":"","overview":"二战时期西西里岛上宁静的小镇，美艳动人的妇人玛莲娜，撩着波浪长发，穿着时髦的短裙丝袜，踏着诱惑的高跟鞋，烟视媚行，征服了镇上所有男人，也包括年仅13岁的维利图，他悄悄地成为她的小跟班，如影随形地跟踪、窥视她的生活。她摇曳的倩影、她聆听的和音乐、她贴身的衣物…都成为这个被荷尔蒙淹没的少年，最真实、最美好的情欲幻想…"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Malena","runtime":109,"tagline":"","homepage":"","overview":"Jest rok 1941. Do sennego sycylijskiego miasteczka przyjeżdża przepiękna kobieta, Malena. Przyjeżdża sama, bo mąż walczy na froncie. Każde publiczne pojawienie się Maleny zamienia się w spektakl. Wszędzie towarzyszą jej pożądliwe spojrzenia mężczyzn i złośliwe plotki ich zazdrosnych żon. Za Maleną podąża też armia kościstych wyrostków na rowerach. Jeden z nich, 13-latek Renato Amoroso, popada w prawdziwą obsesję na jej punkcie. Kiedy mąż Maleny ginie na froncie, pęka bariera tłumionych żądzy, zazdrości i gniewu."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"ผู้หญิงสะกดโลก","runtime":0,"tagline":"","homepage":"","overview":"Malena (เมลีน่า) คือหนังที่อื้อฉาวที่สุดของ โมนิก้า เบลลุชชี่ หากนึกไม่ออกว่าเธอเป็นใคร เธอก็คือดาราที่แสดงในเรื่อง The Matrix เรื่องราวในหนังเกิดขึ้นช่วงสงครามโลกครั้งที่ 2 ประเทศอิตาลี่ ประกาศสงครามกับพันธมิตร เมลีน่า (โมนิก้า เบลลุชชี่) แม่บ้านที่เฝ้ารอการกลับมาของสามีที่ไปรบ ไม่รู้ว่าเป็นโชคดีหรือโชคร้ายของเธอที่ เธอเป็นผู้หญิงที่สวยที่สุดในเมือง ถึงเธอจะแต่งงานแล้ว แต่เธอก็ยังเป็นที่หมายตาของหนุ่มๆ ทั้งเมือง บรรดาภรรยาของผู้ชายเหล่านั้นต่างก็นินทาเธออย่างเสียๆหายๆ เมื่อสงครามใกล้เข้ามา ความอดอยากก็ทำให้เธอต้องเอาตัวรอด เพราะในตอนนี้เธอได้รับรู้ข่าวว่าสามีของเธอได้ตายในสนามรบ หนังเรื่องนี้จะเล่าเรื่องราวผ่านเด็กที่กำลังจะเป็นหนุ่ม ด้วยสายตาที่หลงไหลและเฝ้ามองเธออยู่ทุกฝีก้าว ทำให้เขาเป็นคนเดียวเท่านั้นที่รู้ความจริงของเมลีน่า"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Maléna","runtime":109,"tagline":"","homepage":"","overview":"Maléna a napsütötte, álmos szicíliai kisváros szépe, igéző és ellenállhatatlanul vonzó fiatal nő. Nemrég költözött ide, a férje a fronton van, és amikor csak végigmegy az utcán, férfiak vágyakozó tekintete és feleségek irigy pletykái kísérik minden lépését. Vézna, tizenéves srácok követik biciklijükön mindenhová, hogy lélegzetelállító szépségét minél tovább csodálhassák. A fiúk között van az élénk fantáziájú Renato, akit vágyai a fantázia világának váratlan magasságába röpítenek. Ám ahogy az évek telnek, Malénának - és az őt titkon csodáló Renatónak is - szembesülnie kell a könyörtelen valósággal."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":109,"tagline":"","homepage":"","overview":"Sicilië, 1941. De Tweede Wereldoorlog is in volle gang. Toch hebben de mannen iets heel anders aan hun hoofd. Een groep 13-jarige jongens is verliefd op de mooie Malèna, de vrouw van een plaatselijke soldaat. Eén van de jongens, Renato, volgt haar constant en bespioneert haar bij haar meest intieme momenten. Malèna heeft een betoverend effect op het mannelijke deel van de bevolking in het dorpje waar ze woont, maar de vrouwen hebben hun oordeel over de buitenstaander snel klaar."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"En bitterljuv berättelse om Malèna, som väljer att gå sin egen väg och utmana bygemenskapen i den lilla Italienska staden Castelcuto. Malèna är oerhört vacker och när hennes man rapporteras saknad i strid kastar byns män, gamla som unga, lystna blickar efter henne. För den 13-årige Renato, sprängfylld av alla romantiska filmer han sett, blir Malèna den sinnliga kärleken personifierad. Han följer henne överallt och bli allt mer besatt av tanken att äga henne. Snart börjar rykten florera om Malènas påstådda sexuella lössläppthet och hon finner sig utstött från bygemenskapen."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Malèna","runtime":108,"tagline":"Um mundo em guerra. Um jovem chegando à maioridade e a mulher que mudou a sua vida para sempre","homepage":"","overview":"Em 1941, no meio de clima de guerra e numa pequena vila localizada na Sicília, um grupo de garotos de 13 anos de idade descobrindo-se a si mesmos nutrem uma profunda paixão por Malèna (Monica Bellucci), uma mulher sensual que vive numa pequena cidade italiana de pobres de espírito, Malèna  é a viúva de um soldado local, despertando assim uma história de amor, perda e coragem."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Malena","runtime":0,"tagline":"Příběh o nezávislosti, intrikách, odvaze a přítomnosti opravdové lásky.","homepage":"","overview":"V roce 1941 bylo Renatovi 13 let a ačkoliv probíhala druhá světová válka, v jeho ospalé vesničce se prakticky nic nedělo. Dokud se však jednoho dne neobjevilo něco, co jednou provždy změnilo jeho život: Malena, krásná mladá údajná válečná vdova, jež se stala obsesí každého muže a objektem nenávisti každé ženy. Díky ní začne Renato získávat mnoho životních zkušeností a dostane se do míst, která by si nedokázal ani představit.  Film od režiséra oceněného Oscarem za film BIO RÁJ vypráví intimní portrét a epický příběh o nezávislosti, intrikách, odvaze a nezapomenutelné přítomnosti opravdové lásky.(oficiální text distributora)"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Μαλένα","runtime":109,"tagline":"Ήταν πολύ νέα για να είναι χήρα και πολύ όμορφη για να είναι μόνη. Κάθε άντρας ήθελε να την έχει. Ένα αγόρι ρίσκαρε τα πάντα για να την προστατέψει.","homepage":"","overview":"Σε μια μικρή παραθαλάσσια πόλη της Σικελίας, το 1940, μια ομάδα εφήβων, ανάμεσά τους και ο Ρενάτο, περνούν την ώρα τους περιμένοντας να περάσει η όμορφη Μαλένα Η Μαλένα, επίκεντρο των φαντασιώσεων των ανδρών της πόλης, είναι μια γοητευτική, αλλά αφελής δασκάλα που δεν δείχνει να καταλαβαίνει το ρόλο που παίζει η παρουσία της στον ανδρικό πληθυσμό της πόλης. Όταν όμως ο άνδρας της σκοτώνεται στον πόλεμο, η χήρα πια Μαλένα γίνεται το αντικείμενο μιας απωθημένης λαγνείας των ανδρών, προκαλώντας σκάνδαλο όταν αρχίζει να βγαίνει με Γερμανούς στρατιώτες για να επιζήσει..."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"말레나","runtime":0,"tagline":"그녀에게 죄가 있다면 그건 단지 아름답다는 것이다","homepage":"","overview":"무솔리니 정권의 이탈리아, 한 시골마을에 사는 주인공 소년 레나토(주세페 술파로)는 마을에서 가장 아름다운 여인 말레나(모니카 벨루치)에 한눈에 반한다. 레나토의 라틴어 선생(피에트로 노타리안니)의 딸인 말레나는 전쟁으로 남편을 잃고 혼자 살고 있었다. 레나토는 빼어난 미모 때문에 온 마을 사내들의 정욕에 찬 시선과 아낙네들의 따돌림을 감내해야 하는 말레나를 늘 안타깝게 지켜본다.  어느 날 말레나의 남편 스코르디아(가에타노 아로니카)의 전사소식이 전해지고, 독일군이 점령한 마을에서 생계를 잃은 말레나는 창녀가 된다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"מלנה","runtime":0,"tagline":"עולם במלחמה. נער מתבגר ואשה שמשנה את חייו לתמיד.","homepage":"","overview":"ג'וזפה טורנאטורה האיטלקי, שארג למעננו אגדות קולנועיות קסומות כ\"סינמה פרדיסו\" ו\"מוכר החלומות\" מחזיר אותנו לכפר בחופי סיציליה שטופת השמש.הסרט חושף בפנינו את אורחותיו של הכפר הקטן, כאשר צעיר בן הכפר מתגייס לצבא לאחר הכרזת מוסוליני על הצטרפות איטליה למלחמה, ומותיר בדד מאחוריו את רעייתו הטרייה והיפהפייה, מלנה (מוניקה בלוצ'י). דמותה של מלנה מהווה תשתית לפנטזיות המיניות של גברי הכפר, הלוטשים בה עיניים חומדות, כמו גם רכילות ושמועות זדוניות אשר נשות הכפרהמרשעות והקנאיות מפיצות אודותיה. היחיד המגן עליה הוא הנער החולמני והמאוהב, רנאטו (ג'וזפה סולפארו), העוקב אחריה בסתר, ואשר לסיפורה הכאוב הוא שותף סמוי ונסתר מהעין.הסרט הפיוטי והציורי מובא מנקודת מבטו של הנער המתבגר, כאשר מוניקה בלוצ'י (כל כך יפה...), כמעט ולא פוצה פה במהלך הסרט - משחקה מתמקד בשתיקתה המיוסרת, מה שבעצם מעצים את המיסתורין סביב דמותה האמיתית: ההיתה היא כה נשגבה?"},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":0,"tagline":"Prea tânără ca să fie văduvă, prea frumoasă ca să fie singură.","homepage":"","overview":"În timpul celui de-al Doilea Război Mondial, un adolescent care se descoperă pe el însuși, devine îndrăgostit de Malèna, o femeie senzuală care trăiește într-un mic oraș italian, cu mintea îngustă."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Малена","runtime":109,"tagline":"","homepage":"","overview":"Малена — красуня-вдова, мана чоловіків і предмет заздрості жінок. Дружини розпускають про неї брудні плітки, чоловіки переслідують її по п'ятах і марять про неї. «Мені було 13, коли я побачив її вперше. Минув час, я любив багатьох жінок, і коли ми були близькі, вони запитували: чи буду я пам'ятати їх? І я говорив: так, я буду пам'ятати вас. Але єдина, кого я ніколи не забуду - та, яка ніколи не питала. Малена»"},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"","runtime":109,"tagline":"","homepage":"","overview":"Em 1941, numa pequena vila localizada na Sicília, um grupo de garotos de 13 anos de idade nutre uma profunda paixão por Malena (Monica Bellucci), a viúva de um soldado local, despertando uma história de amor, perda e coragem."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Малена","runtime":109,"tagline":"","homepage":"","overview":"През 1940 г., когато Италия се присъединява към войната, две неща се случват на 12-годишния Ренато: той получава първото си колело и за пръв път вижда Малена. Тя е красива, тиха жена, която се е преместила в това малко сицилианско градче заедно със съпруга си Нико. Когато Нико отива на фронта, Малена остава сама. Тя посреща похотливите погледи на мъжете и клюките на завистливите жени в продължение на няколко години. Докато Ренато преминава от юношеството към зрелостта, той е свидетел на страданията на Малена. Вижда как трябва да се унижава, след като Нико е обявен за мъртъв, а тя търси работа в градчето. Дали Ренато ще се научи да бъде смел като Малена и ще й подаде ли ръка, когато има нужда от това?"},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Малена","runtime":0,"tagline":"","homepage":"","overview":"Ренато Аморозо (Ђ. Сулфаро), тринаестогодишњак који открива свет сексуалних фантазија, заљубљен је у прелепу мештанку, Малену (М. Белучи). Малена је удата, муж јој је на фронту, а њена изузетна лепота и привлачност изазивају злобу и пакост мештана који распредају злобне трачеве. Њена ћутња и индиферентност, невољност да ишта каже у своју одбрану потиче провинцијални миље на најгору осуду. Ренато посматра, саосећа и прати Малену, сва понижења, муку и неправду кроз коју пролази..."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"真愛伴我行","runtime":0,"tagline":"","homepage":"","overview":"影片背景是1940年的西西里島的寧靜小鎮，當時義大利剛剛宣布參戰。女主角瑪蓮娜的丈夫Nino Scordia參軍未歸，被認定為死亡。瑪蓮娜離開家鄉，來到了這個海邊小鎮，在這裡，她吸引了所有男人的目光，包括12歲的雷納托。儘管八卦不斷，瑪蓮娜一直忠於自己的丈夫。而雷納托悄悄地迷戀上這個女人，跟蹤、窺視她的生活，陷入了情慾幻想。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"西西裏的美麗傳説","runtime":0,"tagline":"","homepage":"","overview":"影片背景是 1940 年的西西裏島的寧靜小鎮，當時義大利剛剛宣佈參戰。女主角瑪蓮娜的丈夫 Nino Scordia 參軍未歸，被認定為死亡。瑪蓮娜離開家鄉，來到了這個海邊小鎮，在這裏，她吸引了所有男人的目光，包括 12 歲的雷納託。儘管八卦不斷，瑪蓮娜一直忠於自己的丈夫。而雷納託悄悄地迷戀上這個女人，跟蹤、窺視她的生活，陷入了情慾幻想。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"マレーナ","runtime":0,"tagline":"あの頃、あなたが世界のすべてだった。","homepage":"","overview":"第2次世界大戦中のイタリア。シチリア島の漁村で暮らす12歳の少年レナートは、美しい年上の女性マレーナに魅せられる。彼女は結婚して2週間で戦地に送られた夫の帰りを待ち続け、レナートはそんな彼女の姿を見守っては想いを募らせていた。戦局の移り変わりで島はナチス、次いで米軍の支配下となり、戦争未亡人となったマレーナは自分を庇護してくれる愛人の間を渡り歩く。だがそんな彼女の行動は島の人々の反感を買う。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Malena","runtime":88,"tagline":"Bola príliš mladá na vdovu a príliš krásna na to, aby bola sama. Túžil po nej každý. Jeden chlapec riskoval všetko, aby ju ochránil.","homepage":"","overview":"V roku 1941 mal Renato 13 rokov a aj napriek tomu, že zúrila 2. svetová vojna, sa v jeho ospalej dedine prakticky nič nedialo. Až kým sa jedného dňa neobjavilo niečo, čo zmenilo jeho život – Maléna, krásna údajná vojnová vdova, ktorá sa stala posadnutosťou každého muža a objektom nenávisti každej ženy. Vďaka nej začne Renato získavať veľa životných skúseností a dostane sa na miesta, ktoré by si nikdy nedokázal ani predstaviť."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Malena","runtime":100,"tagline":"Drama. Romance. Comedia | Años 40. II Guerra Mundial. Adolescencia. Celos. Vida rural. Prostitución. Drama romántico","homepage":"","overview":"Malena es la belleza más encantadora e irresistible de Castelcuto, un tranquilo pueblo de la soleada costa siciliana. Es nueva en el pueblo y, estando su marido en la guerra, cada paseo que da se convierte en un espectáculo que va acompañado de las lujuriosas miradas de los hombres y de los resentidos cotilleos de sus envidiosas esposas. Un ejército de flacos adolescentes en bicicleta la sigue allí donde vaya, con la única intención de observar su exquisita y arquetípica belleza. Pero entre ellos se encuentra Renato, un chico de trece años con mucha imaginación que lleva su deseo a unos límites de obsesiva fantasía."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Malena","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ozbek","iso_639_1":"uz","iso_3166_1":"UZ","english_name":"Uzbek"},{"data":{"title":"مالنا","runtime":0,"tagline":"","homepage":"","overview":"مالنا روایت جوزپه تورناتوره است از عشق و شهوت یک نوبالغ 12 ساله به زنی زیبا . و درعین حال طعنه ای است به موقعیت زنان در جوامع عقب افتاده. موقعیتی که به آنها  هرگز اجازه توامان زیبابودن و تنها بودن را نمی دهد. ـ داستان: سال 1940 در شهرک کوچکی از توابع سیسیل، خبر درگیری ایتالیا در جنگ جهانی دوم به گوش مردم می رسد.  نینو (آرونیکا) همسر مالنا (مونیکا بلوچی) که از شهری دیگر به آنجا آمده اند راهی جبهه جنگ موسولینی می شود. مالنا که زن فوق العاده زیبایی است در شهرک غریب مانده و  مورد حسد زنان دیگر قرار می گیرد. از طرفی رناتو (سولفارو) پسرکی تازه بالغ شیفته و عاشق مالنا می شود بطوریکه در خواب و بیداری خود را با او و هم آغوش او تصور می کند. رناتو لحظه لحظه زندگی مالنا را زیر نظر دارد و تمامی رویاهایش را در او خلاصه می کند...."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"","runtime":0,"tagline":"كانت أصغر من أن تكون أرملة ، وجميلة من أن تكون وحيدة. كل رجل يريد أن يكون لها. خاطر صبي واحد بكل شيء لحمايتها.","homepage":"","overview":"في اليوم الذي دخلت فيه إيطاليا الحرب من عام 1940 ، حدث شيئان لريناتو البالغ من العمر 12 عامًا: حصل على دراجته الأولى ، وألقى أول نظرة على مالينا. إنها غريبة جميلة وصامتة انتقلت إلى هذه المدينة الصقلية لتكون مع زوجها نيكو. سرعان ما خرج إلى الحرب ، تاركًا إياها في عيون الرجال الشهوانية وألسنة النساء الحادة. خلال السنوات القليلة التالية ، مع تقدم ريناتو نحو الرجولة ، شاهد مالينا وهي تعاني وتثبت قوتها. إنه يرى وحدتها ، ثم حزنها عند الإبلاغ عن وفاة نيكو ، وآثار الافتراء على علاقتها مع والدها ، وفقرها وبحثها عن عمل ، والإذلال الأخير. هل سيتعلم ريناتو الشجاعة من مالينا ويدافع عنها؟"},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Malena","runtime":0,"tagline":"","homepage":"","overview":"1940 m. Sicilijos miestelis Castelcuta. Rūpintis sunkiai sergančiu tėvu čia atvyksta mergina vardu Malena. Kai tik ji išeina į gatvę, kiekvienas miestelio vyras nebegali atitraukti akių nuo nuostabaus grožio, o visos moterys paleidžia liežuvius ir skleidžia paskalas. Vos tik pamatęs Maleną, berniukas Renato pirmą kartą gyvenime nesugeba išsiginti nuo užplūdusių keistų jausmų. Jis pradeda sekti savo svajonių merginą, norėdamas išsiaiškinti, kokia yra tikroji Malena, kurios vyras tragiškai žuvo kare."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Tình Yêu Đầu Đời","runtime":0,"tagline":"","homepage":"","overview":"Vào ngày nước Ý tham chiến năm 1940, có hai điều xảy ra với cậu bé 12 tuổi Renato: cậu bé có được chiếc xe đạp đầu tiên và cậu bé có cái nhìn đầu tiên về Malèna. Cô ấy là một người ngoài xinh đẹp, thầm lặng, đã chuyển đến thị trấn Sicilia này để ở với chồng của cô ấy, Nico. Anh ta nhanh chóng ra trận, để lại cô trước ánh mắt thèm muốn của những người đàn ông và những chiếc lưỡi sắc bén của phụ nữ. Trong vài năm tiếp theo, khi Renato dần trưởng thành, anh chứng kiến Malèna đau khổ và chứng tỏ dũng khí của cô. Anh nhìn thấy sự cô đơn của cô, sau đó đau buồn khi Nico được thông báo đã chết, ảnh hưởng của sự vu khống lên mối quan hệ của cô với cha mình, sự nghèo khó và tìm kiếm việc làm của cô, và sự sỉ nhục cuối cùng. Liệu Renato có học được lòng dũng cảm từ Malèna và đứng lên vì cô ấy?"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"მალენა","runtime":0,"tagline":"","homepage":"","overview":"მალენა - ულამაზესი ქვრივია, კაცებისთვის საოცნებო ხილვაა და ქალებისთვის კი შურის საგანი. ცოლები მასზე ბინძურ ჭორებს ავრცელებენ, ქმრები კი მას კვალ და კვალ დასდევენ და ოცნებობენ მასზე. \"მე ვიყავი 13 წლის, როდესაც მე ის პირველად ვნახე. გავიდა დრო, მე უამრავი ქალი მყავდა, და სიახლოვის დროს, ისინი კითხულობდნენ: მემახსოვრება მე თუ არა ისინი? მე დადებითად ვპასუხობდი... მაგრამ ერთადერთი, ვინც მე არასოდეს დამავიწყდება – ის რომელსაც ეს არასოდეს უკითხავს. მალენაა.\""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"၁၉၄၁ ခုနှစ်က စစ္စလီကျွန်းပေါ်မှာနေတဲ့ အသက် ၁၃ နှစ်သား ကောင်လေးတစ်ယောက် လမ်းခဲ့ရတဲ့ မာလိနာဆိုတဲ့ မိန်းမတစ်ယောက်အကြောင်း ဒုတိယ ကမ္ဘာစစ်ကြောင့် ခိုကိုးရာမဲ့သွားတဲ့မိန်းမတစ်ယောက်၊ လှပလွန်းသောကြောင့် ယောက်ကျားတိုင်းက စိတ်ဝင်စားပြီးတစ်ခြားမိန်းမတွေက မနာလိုဖြစ်ခြင်းခံနေရတဲ့ မိန်းမတစ်ယောက်၊  ကံဆိုးမှု တွေကြောင့် ဖခင်ဖြစ်သူရဲ့ အထင်လွဲမှုကို ခံရပြီးစားဝတ်နေရေးအတွက် ရုန်းကန်ခဲ့ရတဲ့ မိန်းမတစ်ယောက်၊ အရာရာကို ခွင့်လွှတ်သည်းခံပြီး ချစ်သူခင်ပွန်းရဲ့ဖေးမမှုနဲ့ ဘဝကိုတည်ငြိမ်စွာပြန်လည်လျှောက်လှမ်းနိုင်ခဲ့တဲ့ မိန်းမတစ်ယောက်ရဲ့ အကြောင်း။ ဒီဇာတ်ကားထဲမှာ လူတွေရဲ့ မနာလိုစိတ်တွေ၊ အချောင်ရလိုမှုတွေ၊အားနည်းသူကို ပျက်စီးစေချင်ကြတဲ့စိတ်တွေနဲ့ ယောင်္ကျားတွေရဲ့ စိတ်ကို ကွက်ကွက် ကွင်းကွင်းမြင်အောင် ပြထားပါတယ်။ကြီးကောင်ဝင်စ လူငယ်လေးတစ်ယောက်ရဲ့ စိတ်နေစိတ်ထားနဲ့ လူတွေအကြောင်း သင်ယူခဲ့မှုတွေကိုလည်း အထင်အရှားမြင်ရမှာ ဖြစ်ပါတယ်။"},"name":"","iso_639_1":"my","iso_3166_1":"MY","english_name":"Burmese"},{"data":{"title":"","runtime":0,"tagline":"Massa jove per ser vídua, massa bonica per estar sola.","homepage":"","overview":"Malena és la bellesa més encantadora i irresistible de Castelcuto, un avorrit poble de la assolellada costa siciliana. És nova a la població i estant el seu marit a la guerra, cada passeig que fa pel poble es converteix en un espectacle, acompanyat per les luxurioses mirades dels homes de la localitat i de les ressentides xafarderies de les seves envejoses esposes. Un exèrcit de dèbils adolescents amb bicicleta la segueix allà on vagi, amb l'única intenció d'observar la seva bellesa exquisida i arquetípica. Entre ells hi ha Renato Amoroso, un noi de tretze anys amb molta imaginació que porta el desig a uns límits inesperats d'obsessiva fantasia."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Malena","runtime":0,"tagline":"Romantična priča o odrastanju, sazrijevanju, o provincijalizmu i licemjerju.","homepage":"","overview":"„Malena“ je nezaboravna priča o putovanju jednog dječaka do zrelosti usred kaosa i netrpeljivosti Drugog svjetskog rata. U uspavanom talijanskom selu Malena, najljepša žena u mjestu, postaje tema sve brojnijih zlobnih ogovaranja među pohotnim mještanima i njihovim ljubomornim suprugama. Ali samo će njezin najvatreniji obožavatelj, mladi Renato Amoroso, saznati njezinu zagonetnu neispričanu priču."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"}],"reviews_tmdb":[{"id":"64aee6b4cddbbc0105643687","url":"https://www.themoviedb.org/review/64aee6b4cddbbc0105643687","author":"TheRealMina","content":"$11","created_at":"2023-07-12T17:45:24.926Z","updated_at":"2023-07-14T15:09:16.919Z","author_details":{"name":"TheRealMina","rating":10,"username":"minymina","avatar_path":null}}],"recommendations":[{"id":25846,"adult":false,"title":"Baaria","video":false,"overview":"Giuseppe Tornatore traces three generations of a Sicilian family in in the Sicilian town of Bagheria (known as Baarìa in the local Sicilian dialect), from the 1930s to the 1980s, to tell the story of the loves, dreams and delusions of an unusual community.","genre_ids":[18,35,10749],"media_type":"movie","popularity":3.0715,"vote_count":662,"poster_path":"/8gMju8daHITnaqjJFQfxJbVVtPJ.jpg","release_date":"2009-09-25","vote_average":7.205,"backdrop_path":"/lzSEhkipvwLLmL3PUIDreQCJdqs.jpg","original_title":"Baarìa","original_language":"it"},{"id":41585,"adult":false,"title":"Mary Forever","video":false,"overview":"A teacher discovers his calling. Marco relocates to Palermo from Milan and takes a job teaching in a reform school while he waits for a high school position. He tries to understand and motivate his handful of students, reading them colloquial poetry, encouraging them to stand up for their rights, finding out about their histories. Natale, in for murder, enamoured of the Mafia, the King Rat within the group; Mery, a drag queen, arrested for assault when defending himself, in love with Mario and, in daylight, rejected by all; Pietro, illiterate, muscular, believing his destiny is set; the callow Claudio, vulnerable, learning to harden himself. What can Mario learn and do in such a short time?","genre_ids":[80,18],"media_type":"movie","popularity":0.6829,"vote_count":237,"poster_path":"/iGgJH7580UkEaqrwxMolpqQ7a1X.jpg","release_date":"1989-05-04","vote_average":7.437,"backdrop_path":"/5y98LdgXJPSo2n4vLJhTLCN78PS.jpg","original_title":"Mery per sempre","original_language":"it"},{"id":19223,"adult":false,"title":"A Pure Formality","video":false,"overview":"Onoff is a famous writer, now a recluse. The Inspector is suspicious when Onoff is brought into the station one night, disoriented and suffering a kind of amnesia. In an isolated, rural police station, the Inspector tries to establish the events surrounding a killing, to reach a startling resolution.","genre_ids":[9648,53,80,18],"media_type":"movie","popularity":0.7349,"vote_count":381,"poster_path":"/bAd56dYln4cgoJBa1r60cb9S5xR.jpg","release_date":"1994-05-15","vote_average":7.42,"backdrop_path":"/88FnsK3iF9rWdR36N3anp1oYVYJ.jpg","original_title":"Una pura formalità","original_language":"it"},{"id":44741,"adult":false,"title":"Malicious","video":false,"overview":"A widower and two of his sons become infatuated by their beautiful housekeeper, and all three set out to seduce her using their own unique methods.","genre_ids":[35],"media_type":"movie","popularity":6.1302,"vote_count":344,"poster_path":"/s1ioOR6IZ6pRN59wEIYCPcY6vW8.jpg","release_date":"1973-03-29","vote_average":7.3,"backdrop_path":"/eGqZyH83bQ1x5MKD5SggEfarPa.jpg","original_title":"Malizia","original_language":"it"},{"id":152742,"adult":false,"title":"The Best Offer","video":false,"overview":"Virgil Oldman is a world renowned antiques expert and auctioneer. An eccentric genius, he leads a solitary life, going to extreme lengths to keep his distance from the messiness of human relationships. When appointed by the beautiful but emotionally damaged Claire to oversee the valuation and sale of her family’s priceless art collection, Virgil allows himself to form an attachment to her – and soon he is engulfed by a passion which will rock his bland existence to the core.","genre_ids":[18,10749,80],"media_type":"movie","popularity":2.5835,"vote_count":3003,"poster_path":"/ibDGPgUZn6vxHiSgt2xeQyFp8Np.jpg","release_date":"2013-01-01","vote_average":7.8,"backdrop_path":"/4EdN5rIT43xcqi4IVRrhxiDOz6z.jpg","original_title":"La migliore offerta","original_language":"it"},{"id":11216,"adult":false,"title":"Cinema Paradiso","video":false,"overview":"A filmmaker recalls his childhood, when he fell in love with the movies at his village's theater and formed a deep friendship with the theater's projectionist.","genre_ids":[18,10749],"media_type":"movie","popularity":5.3166,"vote_count":4735,"poster_path":"/gCI2AeMV4IHSewhJkzsur5MEp6R.jpg","release_date":"1988-11-17","vote_average":8.424,"backdrop_path":"/zoVeIgKzGJzpdG6Gwnr7iOYfIMU.jpg","original_title":"Nuovo Cinema Paradiso","original_language":"it"},{"id":203,"adult":false,"title":"Mean Streets","video":false,"overview":"A small-time hood must choose from among love, friendship and the chance to rise within the mob.","genre_ids":[18,80],"media_type":"movie","popularity":2.355,"vote_count":2254,"poster_path":"/9msfwOeGc9uL1iRRTBdEf15XonC.jpg","release_date":"1973-10-14","vote_average":7.057,"backdrop_path":"/qdecDSIVoqctIoYoOhLH3TgSYLD.jpg","original_title":"Mean Streets","original_language":"en"},{"id":1278,"adult":false,"title":"The Dreamers","video":false,"overview":"When Isabelle and Theo invite Matthew to stay with them, what begins as a casual friendship ripens into a sensual voyage of discovery and desire in which nothing is off limits and everything is possible.","genre_ids":[18,10749],"media_type":"movie","popularity":5.9085,"vote_count":3037,"poster_path":"/gBb7GGaFYPu7nEUYvC8G4LaJJN1.jpg","release_date":"2003-10-10","vote_average":7.182,"backdrop_path":"/vaRCS4CCFXcWz1j9GKd6rGLsQQ2.jpg","original_title":"The Dreamers","original_language":"en"},{"id":10376,"adult":false,"title":"The Legend of 1900","video":false,"overview":"The story of a virtuoso piano player who lives his entire life aboard an ocean liner. Born and raised on the ship, 1900 learned about the outside world through interactions with passengers, never setting foot on land, even for the love of his life. Years later, the ship may be destroyed, and a former band member fears that 1900 may still be aboard, willing to go down with the ship.","genre_ids":[18,10402],"media_type":"movie","popularity":3.3553,"vote_count":2404,"poster_path":"/iOcbJ5pxokOPDRgieVDbsFMrCc6.jpg","release_date":"1998-10-28","vote_average":8.245,"backdrop_path":"/muSeX7fnNw0pv4zHK7RSwZln6Hk.jpg","original_title":"La leggenda del pianista sull'oceano","original_language":"it"},{"id":57157,"adult":false,"title":"Young Adult","video":false,"overview":"A divorced writer from the Midwest returns to her hometown to reconnect with an old flame, who's now married with a family.","genre_ids":[35,18],"media_type":"movie","popularity":2.1371,"vote_count":1333,"poster_path":"/4tGMz5xUs9sk8X9B28G6UalHK1d.jpg","release_date":"2011-11-11","vote_average":5.815,"backdrop_path":"/wwcsaGDLBoYbPk5mBCaTIljLiCs.jpg","original_title":"Young Adult","original_language":"en"},{"id":13386,"adult":false,"title":"I'm Starting from Three","video":false,"overview":"Gaetano, a young Neapolitan, decides to leave home, work and friends, to look for other moments of life and meet other people.","genre_ids":[35],"media_type":"movie","popularity":0.3823,"vote_count":695,"poster_path":"/lS0X9KScgkUbhiu6lOHBya8z9R2.jpg","release_date":"1981-03-05","vote_average":7.616,"backdrop_path":"/gL8WqjpbkoOdo1y3qkt4GUkdDhV.jpg","original_title":"Ricomincio da tre","original_language":"it"},{"id":49009,"adult":false,"title":"The Way Back","video":false,"overview":"A small band of multicultural convicts stages a daring escape from a WWII-era Siberian gulag, and embarks on a treacherous journey across five countries in a desperate race for freedom and survival.","genre_ids":[18,12,36],"media_type":"movie","popularity":2.5382,"vote_count":1716,"poster_path":"/xQ6hxfpD5XQGJz0ekVle5zegam7.jpg","release_date":"2010-11-22","vote_average":7,"backdrop_path":"/jcQfgcq1j7Vit4wQ54niXiLfvE8.jpg","original_title":"The Way Back","original_language":"en"},{"id":58925,"adult":false,"title":"Mr. Klein","video":false,"overview":"Paris, France, 1942, during the Nazi occupation. Robert Klein, a successful art dealer who benefits from the misfortunes of those who are ruthlessly persecuted, discovers by chance that there is another Robert Klein, apparently a Jewish man; someone with whom he could be mistakenly identified, something dangerous in such harsh times.","genre_ids":[9648,18,53],"media_type":"movie","popularity":3.1615,"vote_count":279,"poster_path":"/oa4MzaXlXJSMvcHhJ9FbBLwbuQb.jpg","release_date":"1976-09-23","vote_average":7.194,"backdrop_path":"/d6ELJEiJDoOZhoGe48o4L7qTQKa.jpg","original_title":"Mr. Klein","original_language":"fr"},{"id":79178,"adult":false,"title":"Savages","video":false,"overview":"A group of Italian tourists on a Caribbean holiday finds itself stranded on a deserted island after a plane crash.","genre_ids":[35],"media_type":"movie","popularity":0.2099,"vote_count":274,"poster_path":"/75cmp0XY6NzH4aC6JUfw5CrBcFS.jpg","release_date":"1995-12-15","vote_average":5.568,"backdrop_path":"/oRoKX0t0MJumeroTK3wsEntZ7rE.jpg","original_title":"Selvaggi","original_language":"it"},{"id":10886,"adult":false,"title":"The Unknown Woman","video":false,"overview":"Irena, a Ukrainian woman, comes to Italy looking for a job as a maid. She does everything she can to become a beloved nanny for an adorable little girl, Thea. However, that is just the very beginning of her unknown journey.","genre_ids":[53,18,9648],"media_type":"movie","popularity":0.7555,"vote_count":367,"poster_path":"/piBn5ydvdfCHSfys6N1A7LNwQft.jpg","release_date":"2006-10-09","vote_average":7.18,"backdrop_path":"/ckkDsME8QIqBDp1wO0PvJ2q5ACU.jpg","original_title":"La sconosciuta","original_language":"it"},{"id":20069,"adult":false,"title":"Manuale d'amore 2 (capitoli successivi)","video":false,"overview":"Paralyzed from a crash, Nicola falls for his physiotherapist Lucia. Franco and Manuela seek fertility treatment in Barcelona. Filippo and Fosco, a gay couple, plan their wedding. Ernesto, a waiter, has an affair with Spanish cook Cecilia.","genre_ids":[10749,35,18],"media_type":"movie","popularity":0.82,"vote_count":289,"poster_path":"/2mDPqJ8HQNs9oyziI88EelJCzoO.jpg","release_date":"2007-01-19","vote_average":5.372,"backdrop_path":"/asFQViBQ0LraXtFZOI1TwTCkSPB.jpg","original_title":"Manuale d'amore 2 (capitoli successivi)","original_language":"it"},{"id":9261,"adult":false,"title":"The Wedding Banquet","video":false,"overview":"A Taiwanese-American man is happily settled in New York with his American boyfriend. He plans a marriage of convenience to a Chinese woman in order to keep his parents off his back and to get the woman a green card. Chaos follows when his parents arrive in New York for the wedding.","genre_ids":[35,18,10749],"media_type":"movie","popularity":1.2124,"vote_count":280,"poster_path":"/arWCA8lg0rbdlwHUMvI46LNDhnL.jpg","release_date":"1993-03-01","vote_average":7.193,"backdrop_path":"/d2Zz6EyYESWtKUYXDy6qccOcBA5.jpg","original_title":"囍宴","original_language":"zh"},{"id":38961,"adult":false,"title":"Tamara Drewe","video":false,"overview":"A young newspaper writer returns to her hometown in the English countryside, where her childhood home is being prepped for sale.","genre_ids":[35,10749],"media_type":"movie","popularity":1.0652,"vote_count":473,"poster_path":"/z7EOfHUR95rEFMQmvhxLyuUdaRD.jpg","release_date":"2010-07-14","vote_average":5.876,"backdrop_path":"/n4rEE6PiYG57qAQYmZpmsy5SuJ2.jpg","original_title":"Tamara Drewe","original_language":"en"},{"id":9424,"adult":false,"title":"Disturbing Behavior","video":false,"overview":"Steve Clark is a newcomer in the town of Cradle Bay, and he quickly realizes that there's something odd about his high school classmates. The clique known as the \"Blue Ribbons\" are the eerie embodiment of academic excellence and clean living. But, like the rest of the town, they're a little too perfect. When Steve's rebellious friend Gavin mysteriously joins their ranks, Steve searches for the truth with fellow misfit Rachel.","genre_ids":[9648,27,878],"media_type":"movie","popularity":1.202,"vote_count":408,"poster_path":"/uAhvaueOUUQ6ORCRdsJr1WXz1w0.jpg","release_date":"1998-07-24","vote_average":5.775,"backdrop_path":"/9bMAhzkuvwSXdxUIoFrYuAvkxDU.jpg","original_title":"Disturbing Behavior","original_language":"en"},{"id":421471,"adult":false,"title":"Flower","video":false,"overview":"Rebellious, quick-witted Erica Vandross is a 17-year-old firecracker living with her single mom, Laurie, and her mom's new boyfriend, Bob, in L.A.'s San Fernando Valley. When Bob's mentally unbalanced son, Luke, arrives from rehab to live with the family, Erica finds her domestic and personal life overwhelmed. With Luke and her sidekicks Kala and Claudine in tow, Erica acts out by exposing a high school teacher's dark secret.","genre_ids":[35,18],"media_type":"movie","popularity":0.7409,"vote_count":277,"poster_path":"/xYTI11qFnmx39LRhDOsGEabfqtp.jpg","release_date":"2017-03-16","vote_average":6.3,"backdrop_path":"/lcgaDmokrKltbgwQu9Wf6X0qPTE.jpg","original_title":"Flower","original_language":"en"}],"similar_content":[{"id":653768,"adult":false,"title":"Neporažení","video":false,"overview":"As Nazi troops prepare to occupy the already truncated Czechoslovak Republic, a small military garrison made up of communists defies orders to abandon their post.","genre_ids":[18,10752],"popularity":0.1807,"vote_count":1,"poster_path":"/nIEMDcMIQFCYvZ8RjnBJdaAFoZz.jpg","release_date":"1956-11-16","vote_average":7,"backdrop_path":null,"original_title":"Neporažení","original_language":"cs"},{"id":93,"adult":false,"title":"Anatomy of a Murder","video":false,"overview":"Semi-retired Michigan lawyer Paul Biegler takes the case of Army Lt. Manion, who murdered a local innkeeper after his wife claimed that he raped her. Over the course of an extensive trial, Biegler parries with District Attorney Lodwick and out-of-town prosecutor Claude Dancer to set his client free, but his case rests on the victim's mysterious business partner, who's hiding a dark secret.","genre_ids":[80,18,9648],"popularity":2.1998,"vote_count":1125,"poster_path":"/b2G1QSAwtBv9luhEwErIgSRaU92.jpg","release_date":"1959-07-01","vote_average":7.836,"backdrop_path":"/xfEU7DOlQPwz8Y0TBhKmpETuNIc.jpg","original_title":"Anatomy of a Murder","original_language":"en"},{"id":38,"adult":false,"title":"Eternal Sunshine of the Spotless Mind","video":false,"overview":"Joel Barish, heartbroken that his girlfriend underwent a procedure to erase him from her memory, decides to do the same. However, as he watches his memories of her fade away, he realises that he still loves her, and may be too late to correct his mistake.","genre_ids":[878,18,10749],"popularity":11.4839,"vote_count":16050,"poster_path":"/5MwkWH9tYHv3mV9OdYTMR5qreIz.jpg","release_date":"2004-03-19","vote_average":8.091,"backdrop_path":"/jzZcW65MZQfAgvbEoX8EWCvlxpk.jpg","original_title":"Eternal Sunshine of the Spotless Mind","original_language":"en"},{"id":79,"adult":false,"title":"Hero","video":false,"overview":"During China's Warring States period, a district prefect arrives at the palace of Qin Shi Huang, claiming to have killed the three assassins who had made an attempt on the king's life three years ago.","genre_ids":[18,12,28,36],"popularity":5.4979,"vote_count":2436,"poster_path":"/vxgZto2Cz7ILHAlmRXt50I2brB2.jpg","release_date":"2002-12-19","vote_average":7.508,"backdrop_path":"/jDz6RYN3nKYtlo7J9IMvGoJit7B.jpg","original_title":"英雄","original_language":"zh"},{"id":1252037,"adult":false,"title":"The Tank","video":false,"overview":"A German Tiger tank crew is sent on a dangerous mission to rescue the missing officer Paul von Hardenburg from a top-secret bunker behind enemy lines. As they make their way through the lethal no-man's land, they must confront not only the enemy, but also their own fears and inner demons. Fueled by the Wehrmacht's methamphetamine, their mission increasingly becomes a journey into the heart of darkness.","genre_ids":[10752,28,18],"popularity":48.0637,"vote_count":351,"poster_path":"/65Jr1JAgWlu9em8zHhAfrNJJQBt.jpg","release_date":"2025-09-18","vote_average":7.08,"backdrop_path":"/vMxOmgmBGegjVObjlb8ugsjGgkD.jpg","original_title":"Der Tiger","original_language":"de"},{"id":1058032,"adult":false,"title":"Here","video":false,"overview":"In Brussels, a construction worker crosses paths with a bryologist.","genre_ids":[18,10749],"popularity":1.565,"vote_count":25,"poster_path":"/pIDQ7miG72FEVIiRgGPdxCGv3tW.jpg","release_date":"2024-01-17","vote_average":5.9,"backdrop_path":"/fEw9lVTbDH92W9JFNx1l6XOw6Go.jpg","original_title":"Here","original_language":"fr"},{"id":1587,"adult":false,"title":"What's Eating Gilbert Grape","video":false,"overview":"Gilbert Grape is a small-town young man with a lot of responsibility. Chief among his concerns are his mother, who is so overweight that she can't leave the house, and his mentally impaired younger brother, Arnie, who has a knack for finding trouble. Settled into a job at a grocery store and an ongoing affair with local woman Betty Carver, Gilbert finally has his life shaken up by the free-spirited Becky.","genre_ids":[10749,18],"popularity":4.457,"vote_count":4198,"poster_path":"/8FxWgsfDNosewo7H65oE4QkOb7g.jpg","release_date":"1993-12-17","vote_average":7.662,"backdrop_path":"/fHuKwcrwltGlWn3510N1YO7vJ4I.jpg","original_title":"What's Eating Gilbert Grape","original_language":"en"},{"id":1591,"adult":false,"title":"Nowhere in Africa","video":false,"overview":"A Jewish woman named Jettel Redlich flees Nazi Germany with her daughter Regina, to join her husband, Walter, on a farm in Kenya. At first, Jettel refuses to adjust to her new circumstances, bringing with her a set of china dishes and an evening gown. While Regina adapts readily to this new world, forming a strong bond with her father's cook, an African named Owuor.","genre_ids":[18],"popularity":0.7076,"vote_count":177,"poster_path":"/2ED1GaTKhHielGYa1giBsxfoacp.jpg","release_date":"2001-12-11","vote_average":7.1,"backdrop_path":"/7WcWTWOmCNLFnazUmIY64eSvMMz.jpg","original_title":"Nirgendwo in Afrika","original_language":"de"},{"id":465240,"adult":false,"title":"Birds Are Singing in Kigali","video":false,"overview":"We meet ornithologist Anna in 1994 just as genocide is raging in Rwanda, perpetrated by the majority Hutus against the Tutsis. Anna manages to save the daughter of a colleague whose family has been murdered, and she takes her to Poland. But the woman returns to Rwanda to visit the graves of her loved ones. The director originally worked on the movie with her husband Krzysztof Krauze (My Nikifor – Crystal Globe, KVIFF 2005), but after his death in 2014 she eventually finished this challenging picture alone.","genre_ids":[18,36],"popularity":0.1819,"vote_count":20,"poster_path":"/su4ZKk5ZUbtyvTV9QXgVd7nI7U6.jpg","release_date":"2017-09-22","vote_average":5.2,"backdrop_path":"/6Yzuuk2Has10jRhIY5W0Gi3jy6z.jpg","original_title":"Ptaki śpiewają w Kigali","original_language":"pl"},{"id":1060904,"adult":false,"title":"Rytíř","video":false,"overview":"","genre_ids":[18],"popularity":0.1943,"vote_count":0,"poster_path":null,"release_date":"1975-10-30","vote_average":0,"backdrop_path":"/2IDwtTT4BHYRKrV1uRobOjTQYn4.jpg","original_title":"Rytíř","original_language":"cs"},{"id":1578,"adult":false,"title":"Raging Bull","video":false,"overview":"The life of boxer Jake LaMotta, whose violence and temper that led him to the top in the ring destroyed his life outside of it.","genre_ids":[18],"popularity":4.6734,"vote_count":4664,"poster_path":"/1WV7WlTS8LI1L5NkCgjWT9GSW3O.jpg","release_date":"1980-11-14","vote_average":7.908,"backdrop_path":"/tvNuhRlpRozDgsX1zR9gQ2aHv1X.jpg","original_title":"Raging Bull","original_language":"en"},{"id":1628,"adult":false,"title":"Jules and Jim","video":false,"overview":"In the carefree days before World War I, introverted Austrian author Jules strikes up a friendship with the exuberant Frenchman Jim and both men fall for the impulsive and beautiful Catherine.","genre_ids":[18,10749],"popularity":1.2286,"vote_count":1040,"poster_path":"/kuFjZlcZhQFDtIjuI3GQJjsQG03.jpg","release_date":"1962-01-23","vote_average":7.546,"backdrop_path":"/o3GSSYr7AzrdcukNpQrqFEJNOjk.jpg","original_title":"Jules et Jim","original_language":"fr"},{"id":1651,"adult":false,"title":"Mississippi Mermaid","video":false,"overview":"A tobacco planter on Réunion island in the Indian Ocean becomes engaged through correspondence to a French woman he does not know. The woman that arrives does not look like the picture he received, but he marries her anyway.","genre_ids":[10749,18,80,53],"popularity":0.849,"vote_count":214,"poster_path":"/l2jsT4bWzGZry34x4k5eNiSquhv.jpg","release_date":"1969-06-18","vote_average":6.61,"backdrop_path":"/bEe4xvjFr9kObNeBCw8kce3o047.jpg","original_title":"La Sirène du Mississipi","original_language":"fr"},{"id":273404,"adult":false,"title":"I'll Follow You Down","video":false,"overview":"After the disappearance of a young scientist on a business trip, his son and wife struggle to cope, only to make a bizarre discovery years later - one that may bring him home.","genre_ids":[878,18,9648],"popularity":0.7079,"vote_count":190,"poster_path":"/3osrKXIz5OkSrpnEt1hqHAAyvbd.jpg","release_date":"2013-07-28","vote_average":6,"backdrop_path":"/hBaZ0cXy2gOwOvsywez8MHWgAjO.jpg","original_title":"I'll Follow You Down","original_language":"en"},{"id":1712,"adult":false,"title":"Giant","video":false,"overview":"Wealthy rancher Bick Benedict and dirt-poor cowboy Jett Rink both woo Leslie Lynnton, a beautiful young woman from Maryland who is new to Texas. She marries Benedict, but she is shocked by the racial bigotry of the White Texans against the local people of Mexican descent. Rink discovers oil on a small plot of land, and while he uses his vast, new wealth to buy all the land surrounding the Benedict ranch, the Benedict's disagreement over prejudice fuels conflict that runs across generations.","genre_ids":[18,37,10749],"popularity":4.1768,"vote_count":737,"poster_path":"/wXGmfJkU83daBsqp9R8LeWguIZd.jpg","release_date":"1956-11-08","vote_average":7.6,"backdrop_path":"/sm3ErHMXQLaNdo74vbIa1JRXIXS.jpg","original_title":"Giant","original_language":"en"},{"id":1783,"adult":false,"title":"To End All Wars","video":false,"overview":"Based on a real-life story, this drama focuses on a small group of Allied soldiers in Burma who are held captive by the Japanese. Capt. Ernest Gordon, Lt. Jim Reardon and Maj. Ian Campbell are among the military officers kept imprisoned and routinely beaten and deprived of food. While Campbell wants to rebel and attempt an escape, Gordon tries to take a more stoic approach, an attitude that proves to be surprisingly resonant.","genre_ids":[18,10752,28],"popularity":0.6122,"vote_count":177,"poster_path":"/4fXRE02M2EckpGPZNbuZIo05dmL.jpg","release_date":"2001-09-02","vote_average":6.415,"backdrop_path":"/7ew2soLD1RY0PbHwhReqNUv08Wa.jpg","original_title":"To End All Wars","original_language":"en"},{"id":1863,"adult":false,"title":"Sunflower","video":false,"overview":"After World War II, a woman refuses to believe her husband, missing on the Russian front, is dead. Flashbacks reveal their brief courtship and marriage. Years later, she travels to Russia with his photo, determined to find him. What will she discover?","genre_ids":[18,10752],"popularity":4.0493,"vote_count":174,"poster_path":"/eVxcQRc3xfA2IOOzXHT0ML1CjzS.jpg","release_date":"1970-03-14","vote_average":7.5,"backdrop_path":"/qdsZrnGu2YQSIJIaCHt88ASMHVh.jpg","original_title":"I girasoli","original_language":"it"},{"id":1887,"adult":false,"title":"Marie Antoinette","video":false,"overview":"A retelling of the story of France’s iconic but ill-fated queen, Marie Antoinette - from her betrothal and marriage to Louis XVI at fifteen to her reign as queen at nineteen and ultimately the fall of Versailles.","genre_ids":[18,36],"popularity":3.6401,"vote_count":2905,"poster_path":"/cybXGmv8Rjd5Os8Xml6YxMBQ0Zt.jpg","release_date":"2006-05-24","vote_average":6.7,"backdrop_path":"/9hxBNoRjEDZGjyR1JpmmtxJWmVU.jpg","original_title":"Marie Antoinette","original_language":"en"},{"id":1904,"adult":false,"title":"Memoirs of a Geisha","video":false,"overview":"In the years before World War II, a penniless Japanese child is torn from he