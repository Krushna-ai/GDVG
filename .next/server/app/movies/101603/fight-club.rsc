9:{"metadata":[["$","title","0",{"children":"Fight Club | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"A ticking-time-bomb insomniac and a slippery soap salesman channel primal male aggression into a shocking new form of therapy. Their concept catches on, with underground \"fight clubs\" forming in every town, until an eccentric gets in the way and ignites an out-of-control spiral toward oblivion."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/101603/fight-club"}],["$","meta","5",{"property":"og:title","content":"Fight Club"}],["$","meta","6",{"property":"og:description","content":"A ticking-time-bomb insomniac and a slippery soap salesman channel primal male aggression into a shocking new form of therapy. Their concept catches on, with underground \"fight clubs\" forming in every town, until an eccentric gets in the way and ignites an out-of-control spiral toward oblivion."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/101603/fight-club"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/pB8BM7pdSp6B6Ih7QZ4DrQ3PmJK.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Fight Club"}],["$","meta","12",{"name":"twitter:description","content":"A ticking-time-bomb insomniac and a slippery soap salesman channel primal male aggression into a shocking new form of therapy. Their concept catches on, with underground \"fight clubs\" forming in every town, until an eccentric gets in the way and ignites an out-of-control spiral toward oblivion."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w50