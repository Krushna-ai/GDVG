5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Big Boss\",\"description\":\"Cheng is a young Chinese mainlander who moves in with his expatriate cousins to work at an ice factory in Thailand. He does this with a family promise never to get involved in any fights. However, when members of his family begin disappearing after meeting the management of the factory, the resulting mystery and pressures force him to break that vow and take on the villainy of the Big Boss.\",\"image\":\"https://image.tmdb.org/t/p/w500/9VFYDWYnAhXAgyqgs94lwNmMBbk.jpg\",\"datePublished\":\"1971-10-23\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"zh\",\"genre\":[\"action film\",\"martial arts film\",\"Action\",null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.069,\"bestRating\":10,\"ratingCount\":809}}"}}],["$","$L10",null,{"initialDrama":{"id":"cce5e157-dca7-4caf-b26b-86efaf357dd7","tmdb_id":12481,"imdb_id":"tt0067824","content_type":"movie","title":"The Big Boss","original_title":"唐山大兄","overview":"Cheng is a young Chinese mainlander who moves in with his expatriate cousins to work at an ice factory in Thailand. He does this with a family promise never to get involved in any fights. However, when members of his family begin disappearing after meeting the management of the factory, the resulting mystery and pressures force him to break that vow and take on the villainy of the Big Boss.","poster_path":"/9VFYDWYnAhXAgyqgs94lwNmMBbk.jpg","backdrop_path":"/993ZXFkyHGltND6AvlrVlVsveyM.jpg","release_date":"1971-10-23","first_air_date":null,"status":"published","original_language":"zh","origin_country":["HK"],"genres":[{"name":"action film"},{"name":"martial arts film"},{"id":28,"name":"Action"},"action film","martial arts film"],"popularity":3.5627,"vote_average":7.069,"vote_count":809,"runtime":99,"number_of_seasons":null,"number_