:3000,"file_path":"/onO2RDp8klrwFI7675KHOu3Gjjd.jpg","iso_639_1":"sv","vote_average":8.034},{"width":800,"height":1200,"file_path":"/8eGwqgR54xVwpeHSW0HhzXkftT.jpg","iso_639_1":"sr","vote_average":6.2},{"width":1000,"height":1500,"file_path":"/6XcehjQ6eEABIM3vBQ83cMFB04X.jpg","iso_639_1":"eo","vote_average":6.042},{"width":1434,"height":2151,"file_path":"/sBpxTGLzKnvPSVtL5yQYpSxvKEb.jpg","iso_639_1":"en","vote_average":5.87},{"width":1382,"height":2048,"file_path":"/m9vMKZObkQPzc9OmIi2QNqSC0MR.jpg","iso_639_1":"fi","vote_average":5.786},{"width":1275,"height":1913,"file_path":"/s4NKFXA6NlYIbNodRjNYLRcDo8a.jpg","iso_639_1":"is","vote_average":5.682},{"width":2000,"height":2963,"file_path":"/9sSO6rwmhzDQLCO3Tq91d7nCAxf.jpg","iso_639_1":"en","vote_average":5.404},{"width":1100,"height":1650,"file_path":"/i38zFYpbBnWbqcRayu9F1n71yVT.jpg","iso_639_1":"en","vote_average":5.024},{"width":2000,"height":3000,"file_path":"/vc2S0dvgpsM0XfSiXZDMVkRCSSU.jpg","iso_639_1":"en","vote_average":5},{"width":2000,"height":3000,"file_path":"/zqxc2O6eOcPdkcmvem9kgGHvkmM.jpg","iso_639_1":"en","vote_average":4.934},{"width":1065,"height":1600,"file_path":"/fyWxxdiSavcckiQtXeZ50jkJLei.jpg","iso_639_1":"en","vote_average":4},{"width":1382,"height":2048,"file_path":"/qCF8Es9yNBFVKSk3SJklRZ1L1AT.jpg","iso_639_1":"en","vote_average":3.954},{"width":2000,"height":3000,"file_path":"/2xDrjSftMphjtStYjKO3NrZBMWz.jpg","iso_639_1":"en","vote_average":3.804},{"width":2000,"height":2857,"file_path":"/47hsouV25AjycfuTDghyQqUm8IH.jpg","iso_639_1":"ar","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/9w7WGjQes0Cs0s4U3Qr09Tg1Sra.jpg","iso_639_1":"ko","vote_average":3.334}],"backdrops":[{"width":3200,"height":1800,"file_path":"/s6aB9kjxNg0mu2361IkCUSpyHJV.jpg","iso_639_1":null,"vote_average":5.778},{"width":3200,"height":1800,"file_path":"/1Z3YaryoYAaMoE1Js3L1HDw4xvc.jpg","iso_639_1":null,"vote_average":5.778},{"width":3840,"height":2160,"file_path":"/4g4bFrZayZoEMH4vr2fNF8ObPzU.jpg","iso_639_1":null,"vote_average":5.778},{"width":3200,"height":1800,"file_path":"/1ktHy4yBupG3JzYoFsQ8DFoqZh4.jpg","iso_639_1":null,"vote_average":5.682},{"width":3200,"height":1800,"file_path":"/uarnMfwwUUkFXjvwKumtjj8TkMY.jpg","iso_639_1":null,"vote_average":5.53},{"width":2752,"height":1548,"file_path":"/wGPAegoJ7ZLatvvtWKrHvd38qsu.jpg","iso_639_1":null,"vote_average":5.25},{"width":3200,"height":1800,"file_path":"/sz2Nx3ekF7WHAU6PSjgzTZlDqLQ.jpg","iso_639_1":null,"vote_average":4.97},{"width":3200,"height":1800,"file_path":"/eU3Dgc4Zumx2JGPVGgktzGqjXHU.jpg","iso_639_1":null,"vote_average":4.934},{"width":3200,"height":1800,"file_path":"/ZoMFyB1ohKHJMCjwlAeqHdHof9.jpg","iso_639_1":null,"vote_average":4.934},{"width":3200,"height":1800,"file_path":"/eh7MaJgdcHw2svMkSWRorg8zgs5.jpg","iso_639_1":null,"vote_average":4.934},{"width":3840,"height":2160,"file_path":"/wPkU44Zirk9RizHGyK54vpd13MT.jpg","iso_639_1":null,"vote_average":4.722},{"width":3200,"height":1800,"file_path":"/zK3QUsV2Zb0TVx0tSEfa0RDHz6f.jpg","iso_639_1":null,"vote_average":4.572},{"width":3200,"height":1800,"file_path":"/qhuf26nq3wP0MVst1CyIAW2DI9k.jpg","iso_639_1":null,"vote_average":4.572},{"width":3200,"height":1800,"file_path":"/ml9GzM50zG3uMiHXtCIAF0UmTQl.jpg","iso_639_1":null,"vote_average":4.572},{"width":3200,"height":1800,"file_path":"/jmwALbsG6YkvlFfh87tAwnUdqmG.jpg","iso_639_1":null,"vote_average":4.458}]},"enriched_at":"2026-04-21T06:02:19.413+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"No Other Choice","runtime":139,"tagline":"Would you kill for a job?","homepage":"https://www.neonrated.com/film/no-other-choice","overview":"After being laid off and humiliated by a ruthless job market, a veteran paper mill manager descends into violence in a desperate bid to reclaim his dignity."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":139,"tagline":"사람은 넷, 자리는 하나","homepage":"","overview":"다 이루었다는 생각이 들 만큼 삶에 만족하던 25년 경력의 제지 전문가 만수. 아내 미리, 두 아이, 반려견들과 함께 행복한 일상을 보내던 만수는 회사로부터 돌연 해고 통보를 받는다. 목이 잘려 나가는 듯한 충격에 괴로워하던 만수는, 가족을 위해 석 달 안에 반드시 재취업하겠다고 다짐한다. 그 다짐이 무색하게도, 그는 1년 넘게 마트에서 일하며 면접장을 전전하고, 급기야 어렵게 장만한 집마저 빼앗길 위기에 처한다. 무작정 문 제지를 찾아가 필사적으로 이력서를 내밀지만, 선출 반장 앞에서 굴욕만 당한다. 문 제지의 자리는 누구보다 자신이 제격이라고 확신한 만수는 모종의 결심을 한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"无可奈何","runtime":0,"tagline":"","homepage":"","overview":"一名男子失业数年后，为获得新工作灵光一现想出独特计划：消灭自己的竞争对手。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Aucun autre choix","runtime":139,"tagline":"","homepage":"https://www.arpselection.com/film/aucun-autre-choix/","overview":"Cadre dans une usine de papier You Man-su est un homme heureux, il aime sa femme, ses enfants, ses chiens, sa maison.  Lorsqu’il est licencié, sa vie bascule, il ne supporte pas l’idée de perdre son statut social et la vie qui va avec.  Pour retrouver son bonheur perdu, il n’ a aucun  autre choix que d’éliminer tous ses concurrents…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"No Other Choice","runtime":0,"tagline":"Skulle du döda för ett jobb?","homepage":"","overview":"Man-soo har äntligen allt han vill ha: ett fint hus, en kärleksfull hustru, två barn och två väluppfostrade hundar. Men en dag kommer beskedet som ingen hade förutsett - han har fått sparken. Efter misslyckande på misslyckande i jakten på ett nytt jobb inser han att han inte har något annat val. Han måste eliminera sina konkurrenter."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"No Other Choice - Non c'è altra scelta","runtime":0,"tagline":"","homepage":"","overview":"Man-su, specialista nella produzione di carta con venticinque anni di esperienza, è così soddisfatto della vita da potersi dire sinceramente: “Ho tutto”. Finché un giorno viene improvvisamente informato dalla sua azienda di essere stato licenziato. Sentendosi come se gli avessero reciso la testa con un’ascia, Man-su giura di trovare un nuovo lavoro entro i successivi tre mesi per il bene della famiglia. Nonostante la sua ferma determinazione, trascorre oltre un anno passando da un colloquio all’altro, finendo per lavorare in un negozio al dettaglio. Si ritrova a rischio di perdere quella stessa casa che ha faticato così tanto per comprare. Disperato, si presenta senza preavviso alla Moon Paper per consegnare il curriculum, ma viene umiliato dal responsabile di linea Sun-chul. Sapendo di essere più qualificato di chiunque altro per lavorare lì, prende una decisione: se non c’è un posto vacante per me, dovrò farmi assumere creandone uno."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Жодного вибору","runtime":0,"tagline":"","homepage":"","overview":"Ман Су раптово звільняють зі стабільної роботи. Після кількох років безробіття, відчайдушно намагаючись зберегти власний будинок та забезпечити сім’ю, чоловік розробляє унікальний план, щоб отримати нову роботу: “просто” позбутися конкурентів."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"La única opción","runtime":140,"tagline":"","homepage":"","overview":"Después de estar desempleado durante varios años, un hombre idea un plan único para conseguir un nuevo trabajo: eliminar a su competencia."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"No Other Choice","runtime":139,"tagline":"","homepage":"","overview":"Man-su hat sich mit viel Fleiß und harter Arbeit ein perfektes Leben geschaffen: Haus mit Garten, harmonische Ehe, talentierte Kinder und genug Zeit für sein geliebtes Bonsai-Hobby. Doch als KI plötzlich seinen Job ersetzt, müssen er und seine Familie auf allerlei Annehmlichkeiten verzichten: die Tennisstunden der Gattin, das Netflix-Abo der Kinder und selbst die zwei treuen Golden Retriever können sie sich nicht mehr leisten. Und je länger Man-su vergeblich Bewerbungen schreibt, desto näher rückt auch der Verlust des geliebten Hauses. Schließlich begreift er: Nicht der Mangel an Jobs ist das Problem, sondern die Menge an Mitbewerbern. Man-su bleibt keine andere Wahl als sich – auf sehr kreative Art und Weise – seiner Konkurrenten zu entledigen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"選擇有罪","runtime":0,"tagline":"","homepage":"","overview":"資深紙廠管理層萬洙（李炳憲 飾）25年來營營役役地工作，與妻子美莉（孫藝珍 飾）一家四口過著人生勝利組般的美滿生活。直至一天，公司向他提出「對不起，我們別無選擇。」的解僱通知。為了維持其幸福家庭，萬洙高呼：「我唯一的訴求就是要返工！」下定決心要3個月內找到新工作，但他先接二連三敗走面試，再因只有微薄收入的工作令他面臨痛失安樂小屋的危機......當世界沒有為他預留位置，務求「殺」出一條生路，而返工這些機會…..是否屬於他的？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Метод исключения","runtime":139,"tagline":"","homepage":"","overview":"Четверть века проработав в бумажной промышленности, Ю Ман-су стал высококлассным специалистом. Он выкупил и отремонтировал принадлежавший отцу загородный дом и считает себя счастливым семьянином и состоявшимся человеком, поэтому сильным шоком для мужчины становится внезапное увольнение. За несколько месяцев так и не найдя работу по специальности, Ман-су сталкивается с перспективой потери дома и от отчаяния решает физически устранить конкурентов на должность в компании мечты — таких же безработных бедолаг с блестящими резюме."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"No Other Choice","runtime":139,"tagline":"","homepage":"","overview":"Na 25 trouwe dienstjaren verliest Man-su zijn goede baan als opzichter van de papierfabriek wanneer deze in buitenlandse handen komt. Als blijkt dat het vinden van een nieuwe baan lastiger is dan gedacht, moeten Man-su en zijn gezin hun levensstijl drastisch aanpassen. In een wanhopige poging bij de volgende sollicitatie als beste uit de bus te komen, besluit Man-su de concurrentie uit te schakelen. Hoe ver ga je als er geen andere keuze meer is?"},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"徵人啟弒","runtime":0,"tagline":"別無選擇","homepage":"","overview":"擁有25年造紙經驗的資深技師萬洙（李炳憲 飾），一直以來對自己的人生感到十分滿意，甚至能發自內心地說：「我已經擁有一切了。」他與妻子美莉（孫藝珍 飾）、兩個孩子和兩隻狗過著平凡幸福的日子。然而某天，公司卻突然通知他被解雇。\r 「很抱歉，我們別無選擇。」"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Citas izvēles nav","runtime":139,"tagline":"","homepage":"","overview":"Darba tirgus ir nežēlīgs, bet kapitālisms ir ļaunāks par čūskas kodiena agoniju. Mansu pēc 25 pašatdeves pilniem gadiem tiek atlaists no darba papīra ražotnē. Darba devējiem nebija citas izvēles. Iepriekš viņš varēja apskaut ģimeni un pateikt, ka dzīvē ir ieguvis visu, ko vēlējies. Pēc neveiksmīgiem darba meklējumiem Mansu ir spiests atteikties no vidusšķiras labklājības: pārdot bērnības māju, atteikties no meitas čella nodarbībām, bet sievai ir jāagriežas darbā. Viņš nevēlas būt ģimenes galva, kas, atsaucoties uz korejiešu sakāmvārdu, paliek bez galvas – Mansu ir pārdrošs plāns, kā tikt pie darba un atgriezt savu pašcieņu."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Başka Yolu Yok","runtime":139,"tagline":"","homepage":"","overview":"Deneyimli bir kağıt fabrikası yöneticisi, acımasız iş piyasası tarafından işten çıkarılıp aşağılandıktan sonra çaresiz kalır ve onurunu geri kazanmak adına şiddete başvurur."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Bez wyjścia","runtime":139,"tagline":"","homepage":"","overview":"Oddany człowiek rodziny i doświadczony kierownik papierni You Man-su pogrąża się w chaosie po zwolnieniu i odrzuceniu przez bezwzględny rynek pracy. Upokorzony nieudanymi rozmowami kwalifikacyjnymi i wyśmiany przez korporacyjnych strażników, postanawia odzyskać godność za wszelką cenę – decyzja ta pcha go na ścieżkę przemocy, z której nie ma już odwrotu."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"لا خيار آخر","runtime":0,"tagline":"","homepage":"","overview":"بعد فصله وإذلاله من قبل سوق عمل قاسٍ لا يرحم، ينحدر مدير مصنع ورق مخضرم نحو العنف في محاولة يائسة لاستعادة كرامته"},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"אין ברירה אחרת","runtime":139,"tagline":"","homepage":"","overview":"מאן-סו תמיד הרגיש שיש לו הכול: אישה אוהבת, שני ילדים מוצלחים ושני כלבים. הוא אפילו קנה את הבית היפה שבו גדל. ואז, אחרי 25 שנות עבודה מסורה במפעל לייצור נייר, הוא לפתע מפוטר. עד מהרה הוא מתקשה לשלם את המשכנתה, ואשתו רוצה למכור את הבית. אבל כשמאן-סו שומע על משרה נחשקת, יש לו תוכנית איך להשיג אותה: לחסל את המתחרים."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"A Única Saída","runtime":139,"tagline":"","homepage":"https://mubi.com/pt/br/films/no-other-choice","overview":"Um homem é demitido da empresa de papel onde trabalhou por 25 anos. Algum tempo depois, ainda desempregado, encontra uma solução: eliminar literalmente sua concorrência."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"งานนี้.. ฆ่าเอา","runtime":0,"tagline":"","homepage":"","overview":"มันซู ชายผู้เชี่ยวชาญด้านการผลิตกระดาษมากว่า 25 ปี ใช้ชีวิตอย่างมีความสุขกับภรรยา มีริ ลูกสอง และสุนัขสองตัว จนกระทั่งวันหนึ่ง เขาได้รับข่าวช็อกจากบริษัทว่า—เขาถูกเลิกจ้าง เหมือนถูกฟันหัวด้วยขวาน มันซูให้สัญญากับตัวเองว่าจะหางานใหม่ให้ได้ภายในสามเดือน เพื่อครอบครัวที่เขารัก ทว่าความพยายามของเขากลับยืดยาวกว่าหนึ่งปี ทั้งการสัมภาษณ์งานซ้ำแล้วซ้ำเล่าและการทำงานพาร์ทไทม์ในร้านค้าปลีก จนในที่สุดเขากำลังจะสูญเสียบ้านที่กู้เงินมาซื้อด้วยน้ำพักน้ำแรง ในภาวะสิ้นหวัง มันซูตัดสินใจไปที่บริษัท \"มูน เปเปอร” โดยไม่ได้นัดหมาย เพื่อยื่นใบสมัครงาน แต่กลับถูกหัวหน้างานอย่าง ซอนชอล ดูถูกและไล่ออกมา มันซูซึ่งรู้ดีว่าตัวเองมีความสามารถมากกว่าใครในสายงานนี้ จึงตัดสินใจบางอย่าง— ถ้าไม่มีตำแหน่งให้เรา... เราก็จะสร้างมันขึ้นมาเอง!"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Ainus valik","runtime":0,"tagline":"","homepage":"","overview":"You Man-su (Lee Byung-hun) on pika kogemusega paberitootmise spetsialist, kes on oma eluga ülimalt rahul ning saab öelda, et tal on kõik olemas – armastav naine, lapsed, lemmikloomad ja vaevaga üles ehitatud kodu. Seda kuni päevani, kui saab ootamatult töö juurest sõnumi, et neil on kahju, kuid ta on vallandatud ja see oli nende ainus võimalik valik. Uue töökoha leidmine osutub aga raskeks. Kui hakkab tekkima oht, et ta võib kaotada oma kalli kodu ning satub järjekordse võimaliku töökoha otsingul liinitöölise pilke ohvriks, siis on jäänud ka mehel vaid üks valik – kui talle sobivat töökohta ei ole vaba, siis tuleb tema teel olevatest inimestest vabaneda ja endale vaba töökoht luua."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"No Other Choice","runtime":139,"tagline":"","homepage":"","overview":"Man-soon elämässä on vihdoin kaikki hyvin: upea talo, rakastava vaimo, kaksi lasta ja kaksi hyvin käyttäytyvää koiraa. Kunnes eräänä kauniina päivänä tapahtuu odottamaton – Man-soon saa potkut asiantuntijatehtävästään paperitehtaalla. Uuden työpaikan haku etenee nihkeästi, kunnes Man-soon tajuaa, että on vain yksi vaihtoehto: kilpakumppanit on eliminoitava."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Καμιά Άλλη Επιλογή","runtime":0,"tagline":"","homepage":"","overview":"Ένας σκληρά εργαζόμενος οικογενειάρχης βλέπει να γκρεμίζεται το όνειρο της γεμάτης προνόμια ζωής του όταν η εταιρεία στην οποία δούλευε επί 25 χρόνια αποφασίζει να τον απολύσει. Μέσα στην απελπισία του, και θέλοντας να μη στερηθεί τις πολυτέλειες που μέχρι πρότινος απολάμβανε μαζί με τη σύζυγο, τα δύο τους παιδιά και δυο αξιαγάπητα τετράποδα, ο ήρωας αποφασίζει να βγάλει από τη μέση κάθε άλλο υποψήφιο που σκοπεύει να διεκδικήσει με εκείνον την ίδια θέση σε μια καινούργια δουλειά, ώστε να είναι σίγουρη η δική του πρόσληψη."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"چاره ای نیست","runtime":0,"tagline":"","homepage":"","overview":"یو من‌سو، کارمندی باتجربه در صنعت کاغذ، بعد از اخراج ناگهانی زندگی‌اش از هم می‌پاشد. او در حس ناامیدی و ترس از آینده، نقشه‌ای تاریک برای حذف رقبایش ترتیب می‌دهد تا بتواند دوباره شغلش را به دست آورد. اما اقدامات او به زودی پیامدهایی جدی و خونین پیدا می‌کند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Không Còn Lựa Chọn","runtime":0,"tagline":"","homepage":"","overview":"Man Soo (Lee Byung Hun), một nhân viên văn phòng bỗng chốc bị sa thải khỏi một công ty mà anh đã gắn bó 25 năm, cuộc sống êm ấm vừa mới có được lại bị đảo ngược. Để chu toàn cho gia đình là vợ Mi Ri (Son Ye Jin) và hai con, người đàn ông này nhất quyết phải sinh tồn đến cùng, bao gồm cả việc nhận những nghề cực đoan nhất."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Sem Alternativa","runtime":139,"tagline":"","homepage":"https://medeiafilmes.com/filmes/sem-alternativa-2025","overview":"You Man-su, gerente de uma fábrica de papel, é um homem feliz. Adora a sua mulher, os seus filhos, os seus cães e a sua casa. Quando é despedido, a sua vida é profundamente abalada. Não suporta a ideia de perder o seu estatuto social e o estilo de vida que o acompanha. Para recuperar a felicidade perdida, não lhe resta alternativa senão eliminar todos os seus concorrentes."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Není jiná možnost","runtime":0,"tagline":"","homepage":"","overview":"Man-su má všechno, o čem snil: stabilní práci v prestižní papírenské firmě, respekt, šťastnou rodinu a velký dům se skleníkem plným bonsají. Když ale papírnu koupí Američané a Man-su přijde o místo, začne se jeho dokonalý svět rozpadat. Jediná možnost, jak vše v korporátním světě získat zpět? Odstranit konkurenci."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Nincs más választás","runtime":0,"tagline":"","homepage":"","overview":"Man-su évtizedek óta a helyi papírgyár megbecsült dolgozója. A koreai álmot éli: feleségével, két gyerekükkel és két kutyájukkal tágas családi házban élnek, ahol a bonsai fák csinosítgatása tölti ki a szabadidejét. A gyár új tulajdonosa azonban a modernizáció jegyében leépítésbe kezd, és kisvártatva Man-su is az utcán találja magát. A kezdeti eltökélt munkakeresést kétségbeesés váltja fel: egy idő után már a háziállatok fenntartása is éppúgy problémát jelent, mint a jelzáloghitel rendszeres törlesztése. Megalázó helyzetek sorozata végül Man-su-t minden határt áthágó lépésekre készteti."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"CH","english_name":"German"},{"data":{"title":"No hay otra opción","runtime":0,"tagline":"","homepage":"","overview":"La historia sigue a un hombre de mediana edad llamado Man-su que se embarca decidido en una búsqueda de trabajo tras ser despedido inesperadamente de la compañía de papel en la que trabajó durante 25 años. \"Si no hay una vacante para mí, tendré que crear una para que me contraten. No hay otra opción\". Adaptación de la novela \"The Ax\" de Donald E. Westlake, que ya fue llevada al cine en la película \"Arcadia\", dirigida por Costa-Gavras en 2005."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Setelah dipecat dan dipermalukan oleh pasar kerja yang kejam, seorang manajer pabrik kertas veteran terjerumus ke dalam kekerasan dalam upaya putus asa untuk mendapatkan kembali martabatnya."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"Без конкуренция","runtime":0,"tagline":"","homepage":"","overview":"Търсите работа? Когато щастлив семеен човек бъде уволнен след двадесет и пет години вярна служба в хартиена компания, той намира перфектното решение да получи следващата си роля: наистина да елиминира конкуренцията."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"არჩევანის გარეშე","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"N-am avut de ales","runtime":0,"tagline":"","homepage":"","overview":"După 25 de ani în care munca a fost pasiunea lui, Man-su este concediat. Simțindu-se ca și cum cineva i-a tăiat capul, jură să-și găsească un nou job în următoarele trei luni, de dragul familiei sale. După mai bine de un an tot nu reușește să treacă de interviuri, așa că nu are de ales: trebuie să-i elimine pe cei mai buni ca el."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Nie je iná možnosť","runtime":0,"tagline":"Zabíjal by si pre prácu?","homepage":"","overview":"Man-su má všetko, o čom sníval: stabilnú prácu v prestížnej papierenskej firme, rešpekt, šťastnú rodinu a veľký dom so skleníkom plným bonsajov. Keď ale papiereň kúpia Američania a Man-su príde o miesto, začne sa jeho dokonalý svet rozpadať. Jediná možnosť, ako všetko v korporátnom svete získať späť? Odstrániť konkurenciu. Bizarne temný príbeh ukazuje, kam až môže slušný človek zájsť, keď mu dôjde trpezlivosť a naozaj... Nie je iná možnosť.  Majster réžie Park Chan-wook (Old Boy, Komorná) prichádza s čiernou komédiou, v hlavnej úlohe s Lee Byung-hunom (Hra na kalmáre), ktorá svojou podvratnosťou a vizuálnou precíznosťou zasiahla publikum hlavnej súťaže na benátskom festivale."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Без другог избора","runtime":0,"tagline":"","homepage":"","overview":"Након што је отпуштен и понижен од стране немилосрдног тржишта рада, ветеран-менаџер фабрике папира прибегава насиљу у очајничком покушају да поврати своје достојанство."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"}],"reviews_tmdb":[{"id":"68f0d53a46b728c533a82ddc","url":"https://www.themoviedb.org/review/68f0d53a46b728c533a82ddc","author":"Manuel São Bento","content":"FULL SPOILER-FREE REVIEW @ https://fandomwire.com/no-other-choice-review/\r\n\r\n\"No Other Choice proves to be a fantastic piece of art with superb tonal control and dedicated performances that solidify Park Chan-wook's return to the style that defines him.\r\n\r\nIt's a painfully entertaining analysis of a man driven to madness by corporate greed and social pressure, and a courageous, violent, hysterical look at how dysfunctional our world has become.\r\n\r\nIn the end, the film isn't just about a man who lost his job but a voracious critique of the madness of a system that teaches us to kill the rivalry, literally or figuratively, and the human cost of that survival game.\"\r\n\r\nRating: A-","created_at":"2025-10-16T11:21:30.880Z","updated_at":"2025-10-16T11:21:30.936Z","author_details":{"name":"Manuel São Bento","rating":8,"username":"msbreviews","avatar_path":null}},{"id":"6949b20878d30669621557c0","url":"https://www.themoviedb.org/review/6949b20878d30669621557c0","author":"Brent Marchant","content":"$11","created_at":"2025-12-22T21:03:04.730Z","updated_at":"2025-12-22T21:03:04.752Z","author_details":{"name":"Brent Marchant","rating":3,"username":"Brent_Marchant","avatar_path":null}},{"id":"697124dc3224724dea54665e","url":"https://www.themoviedb.org/review/697124dc3224724dea54665e","author":"CinemaSerf","content":"$12","created_at":"2026-01-21T19:11:24.080Z","updated_at":"2026-02-13T21:12:40.543Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":993708,"adult":false,"title":"The Threesome","video":false,"overview":"Connor and his long-time crush Olivia engage in a threesome with a sweet, alluring stranger named Jenny. This encounter sparks a relationship between Connor and Olivia, leading them to plan a life together. However, their romance faces challenges when Jenny reappears, thrusting all three into a difficult journey toward true accountability and adulthood.","genre_ids":[35,10749,18],"media_type":"movie","popularity":6.6854,"vote_count":68,"poster_path":"/7vQUAw3CX60dhzgzC7BQZFN7Y31.jpg","release_date":"2025-09-04","vote_average":6.125,"backdrop_path":"/vXYRqIySwaa56quJGRKxXfSaTh0.jpg","original_title":"The Threesome","original_language":"en"},{"id":1062722,"adult":false,"title":"Frankenstein","video":false,"overview":"Dr. Victor Frankenstein, a brilliant but egotistical scientist, brings a creature to life in a monstrous experiment that ultimately leads to the undoing of both the creator and his tragic creation.","genre_ids":[18,14,27],"media_type":"movie","popularity":32.8311,"vote_count":2945,"poster_path":"/g4JtvGlQO7DByTI6frUobqvSL3R.jpg","release_date":"2025-10-17","vote_average":7.676,"backdrop_path":"/ceyakefyCRAgyeFhefa2bz6d9QO.jpg","original_title":"Frankenstein","original_language":"en"},{"id":1135286,"adult":false,"title":"We Have Never Been Modern","video":false,"overview":"Helena, is about to give birth and face a rosy future in a modern city, as the pregnant wife of an important factory manager. However, all her illusions soon perish, as the dead body of a newborn intersex baby is found in the middle of their factory. Helena needs to find out what happened here for the safety of her own child, but she runs into her own prejudices.","genre_ids":[80,18],"media_type":"movie","popularity":0.3864,"vote_count":19,"poster_path":"/yTSLzDuCiyBmdaS6834gtQ1BcB2.jpg","release_date":"2023-10-05","vote_average":6.684,"backdrop_path":"/gCjg7vE2eGAcm3gG52VeGIlkDOz.jpg","original_title":"Úsvit","original_language":"cs"},{"id":59143,"adult":false,"title":"Mikey and Nicky","video":false,"overview":"Nick is desperate, holed up in a cheap hotel, suffering from an ulcer and convinced that a local mob boss wants him killed. Desperate and terrified, he calls Mikey, his friend since childhood and a fellow gangster. So begins a long night…","genre_ids":[80,18],"media_type":"movie","popularity":1.1515,"vote_count":190,"poster_path":"/fnHC1OJ1EbdOX97nmXVYrXFgiQT.jpg","release_date":"1976-12-21","vote_average":6.9,"backdrop_path":"/pzST8cae4CTsfj0nPP63YOdPLiO.jpg","original_title":"Mikey and Nicky","original_language":"en"},{"id":86267,"adult":false,"title":"The Day a Pig Fell Into the Well","video":false,"overview":"The lives of 4 interconnected South Koreans - a married couple, a novelist the wife is having an affair with, and a second woman the novelist is simultaneously involved with.","genre_ids":[18],"media_type":"movie","popularity":0.6592,"vote_count":58,"poster_path":"/7uTymGOa8kHPf0tJkJY2o0HUrIU.jpg","release_date":"1996-05-04","vote_average":6.31,"backdrop_path":"/zaWCHa0EXs9uMPZxmjFZ6D1dXp7.jpg","original_title":"돼지가 우물에 빠진 날","original_language":"ko"},{"id":1296742,"adult":false,"title":"Rangga & Cinta","video":false,"overview":"Jakarta, 2001. Cinta seems to have it all—close friends, a loving family, and the title of the most popular girl in school. But her perfect world starts to shift when she unexpectedly loses a poetry contest to Rangga, a quiet and mysterious boy who prefers books to people. Annoyed yet intrigued, Cinta finds herself drawn into his world, so different from her own. As emotions grow and loyalties are tested, she must choose between the friends who’ve always stood by her or the first love she never saw coming.","genre_ids":[18,10402,10749],"media_type":"movie","popularity":1.0503,"vote_count":6,"poster_path":"/iutKnkc5dPHVxwrCB5ri26r86PF.jpg","release_date":"2025-10-02","vote_average":6.8,"backdrop_path":"/aDdeZLOvl8GctncFlFUBsW31g9E.jpg","original_title":"Rangga & Cinta","original_language":"id"},{"id":516716,"adult":false,"title":"Milly & Mamet","video":false,"overview":"After two lovebirds make some sacrifices to build their nest, new opportunities to spread their wings put their union to the test.","genre_ids":[35,18,10749],"media_type":"movie","popularity":0.1737,"vote_count":15,"poster_path":"/1QrmAZsnbAZPNRkK2XBV3ZCMhtv.jpg","release_date":"2018-12-20","vote_average":7.6,"backdrop_path":"/swRvr9iQ7qfmq5Xls4CKhzaERo3.jpg","original_title":"Milly & Mamet","original_language":"id"},{"id":1159206,"adult":false,"title":"Father Mother Sister Brother","video":false,"overview":"Three stories concerning the relationships between adult children, their somewhat distant parent (or parents), and each other: a reclusive father visited by his grown children in the US, sisters visiting their novelist mother in Dublin, and adult twins called back to their Paris apartment to address a family tragedy.","genre_ids":[35,18],"media_type":"movie","popularity":4.6197,"vote_count":143,"poster_path":"/zewZA6sL52YSH8xIH4wbG5GadjV.jpg","release_date":"2025-12-01","vote_average":6.552,"backdrop_path":"/xxFH8OgUVw5LyJmqBaXeV97mfri.jpg","original_title":"Father Mother Sister Brother","original_language":"en"},{"id":351962,"adult":false,"title":"Love Letter in the Sand","video":false,"overview":"During a month of unusually heavy rain in Tokyo, a mystery assailant has been brutally assaulting and killing people with a metal bat. When a handsome young man with amnesia is found outside an area hospital, the nurse who discovered him begins to suspect that he may in fact be the assailant. But her own strange erotic fixations with him, and the questionable involvement of the doctor tasked with the amnesia victim, lead them all down an increasingly twisted path of deeply-rooted trauma and violence.","genre_ids":[9648,18,27],"media_type":"movie","popularity":0.485,"vote_count":10,"poster_path":"/cY38TTfxY2I2GFJDmQDmrXypYun.jpg","release_date":"1988-07-28","vote_average":5.3,"backdrop_path":"/zUR2dq7Awt8T5f8Mneott8qZTsR.jpg","original_title":"変態病棟 白衣責め","original_language":"ja"},{"id":431412,"adult":false,"title":"The Hell (Two Kinds of Life)","video":false,"overview":"Jae-young, an ordinary woman in her mid-20s is sentenced to death by an angel, and ascends to Heaven. Going to Heaven means nothing to her because she assumes Heaven is devoid of reason and humanity. But she accepts her fate and proceeds to bid farewell to her mother and friend. During her farewells, the desire for life starts to torture her.","genre_ids":[16,14,27],"media_type":"movie","popularity":0.2926,"vote_count":1,"poster_path":"/sZYbh7pAKiyjmKIgDqeCgFMZH6y.jpg","release_date":"2025-09-17","vote_average":6,"backdrop_path":"/tFNvJ5Iy72zcGlw7r6pdUsNfUGu.jpg","original_title":"지옥: 두개의 삶","original_language":"ko"},{"id":729854,"adult":false,"title":"Concrete Utopia","video":false,"overview":"The world has been reduced to rubble by a massive earthquake. While no one knows for sure how far the ruins stretch, or what the cause of the earthquake may be, in the heart of Seoul there is only one apartment building left standing. It is called Hwang Gung Apartments. As time passes, outsiders start coming in to Hwang Gung Apartments trying to escape the extreme cold. Before long, the apartment residents are unable to cope with the increasing numbers. Feeling a threat to their very survival, the residents enact a special measure.","genre_ids":[53,28],"media_type":"movie","popularity":2.7916,"vote_count":281,"poster_path":"/4l68KHxnPSow8MvnGUpjqLzJtLJ.jpg","release_date":"2023-08-09","vote_average":6.938,"backdrop_path":"/57Nn5HRpMiDY2ODKSI4VAOiuyJg.jpg","original_title":"콘크리트 유토피아","original_language":"ko"},{"id":1054867,"adult":false,"title":"One Battle After Another","video":false,"overview":"Washed-up revolutionary Bob exists in a state of stoned paranoia, surviving off-grid with his spirited, self-reliant daughter, Willa. When his evil nemesis resurfaces after 16 years and she goes missing, the former radical scrambles to find her, father and daughter both battling the consequences of his past.","genre_ids":[53,80,28],"media_type":"movie","popularity":38.5086,"vote_count":2848,"poster_path":"/lbBWwxBht4JFP5PsuJ5onpMqugW.jpg","release_date":"2025-09-23","vote_average":7.421,"backdrop_path":"/gre7gyocZSuwd7M51CGlqsJqBmB.jpg","original_title":"One Battle After Another","original_language":"en"},{"id":1007734,"adult":false,"title":"Nobody 2","video":false,"overview":"Former assassin Hutch Mansell takes his family on a nostalgic vacation to a small-town theme park, only to be pulled back into violence when they clash with a corrupt operator, a crooked sheriff, and a ruthless crime boss.","genre_ids":[28,53],"media_type":"movie","popularity":17.543,"vote_count":1262,"poster_path":"/iyxwxDZCpIm0vIORaHpmgJv2BGF.jpg","release_date":"2025-08-13","vote_average":6.987,"backdrop_path":"/82C04rTiXYZ7c8XZv91Nu53w82Y.jpg","original_title":"Nobody 2","original_language":"en"},{"id":1140817,"adult":false,"title":"As","video":false,"overview":"Three years after the death of her beloved child, Elouise, Mara still feels her presence when she sits on the butterfly bedding in front of the jar with her ashes in it. Mara arranges a twelfth birthday party for Elouise, further alienating her from her husband, Richter, and remaining daughter, Hannah. Although Mara eventually vacates Elouise's room at the insistence of her husband, she does find a way to stay close to Elouise. Before long, however, Hannah discovers her mother's secret.","genre_ids":[],"media_type":"movie","popularity":0.2508,"vote_count":185,"poster_path":null,"release_date":"2023-01-01","vote_average":7.054,"backdrop_path":null,"original_title":"As","original_language":"en"},{"id":533535,"adult":false,"title":"Deadpool & Wolverine","video":false,"overview":"A listless Wade Wilson toils away in civilian life with his days as the morally flexible mercenary, Deadpool, behind him. But when his homeworld faces an existential threat, Wade must reluctantly suit-up again with an even more reluctant Wolverine.","genre_ids":[28,35,878],"media_type":"movie","popularity":24.5553,"vote_count":8279,"poster_path":"/8cdWjvZQUExUUTzyp4t6EDMubfO.jpg","release_date":"2024-07-24","vote_average":7.559,"backdrop_path":"/ufpeVEM64uZHPpzzeiDNIAdaeOD.jpg","original_title":"Deadpool & Wolverine","original_language":"en"},{"id":823491,"adult":false,"title":"Out of Darkness","video":false,"overview":"In the Old Stone Age, a disparate gang of early humans band together in search of a new land. But when they suspect a malevolent, mystical, being is hunting them down, the clan are forced to confront a danger they never envisaged.","genre_ids":[12,27,53],"media_type":"movie","popularity":0.7152,"vote_count":119,"poster_path":"/9tG77VE7bP8ve79X86ABwHzDqbb.jpg","release_date":"2024-02-09","vote_average":5.7,"backdrop_path":"/hGDNYyED9uJVtROtp2K7ukF0jTz.jpg","original_title":"Out of Darkness","original_language":"en"},{"id":308259,"adult":false,"title":"RE","video":false,"overview":"Emma returns to her childhood home only to find her past catching up with her.","genre_ids":[18,27],"media_type":"movie","popularity":0.4093,"vote_count":77,"poster_path":"/jii5C9iGtY0a1YDHblnPFUzu0Vw.jpg","release_date":"2014-01-01","vote_average":6.4,"backdrop_path":null,"original_title":"RE","original_language":"en"},{"id":889737,"adult":false,"title":"Joker: Folie à Deux","video":false,"overview":"While struggling with his dual identity, Arthur Fleck not only stumbles upon true love, but also finds the music that's always been inside him.","genre_ids":[18,80,53],"media_type":"movie","popularity":8.4043,"vote_count":2789,"poster_path":"/if8QiqCI7WAGImKcJCfzp6VTyKA.