ea9fI.jpg","iso_639_1":null,"vote_average":0.166}],"backdrops":[{"width":1920,"height":1080,"file_path":"/pAyImoslSnpMgjRwhaS5ZEdl8UI.jpg","iso_639_1":null,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/4kjPMklaHZCklHumSLmJld2GgXW.jpg","iso_639_1":null,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/w9D45Y8WkmeGmuExerGNq3Owy8U.jpg","iso_639_1":null,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/rXFLeEPgrrV5PT1LoXgzSoGvQ8c.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/nv6VRUyrLavYhMhDJ8RWy6Ds2my.jpg","iso_639_1":"en","vote_average":0}]},"enriched_at":"2026-04-21T06:08:39.311+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":99,"tagline":"","homepage":"","overview":"An ex-black ops team reunite to pull off a desperate heist in order to save the life of their leader’s eight-year-old daughter."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Une ancienne équipe d'opérations spéciales se réunit pour réaliser un braquage afin de sauver la vie de la fille de leur chef."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Instinto salvaje","runtime":0,"tagline":"","homepage":"","overview":"Wildcat sigue a un exequipo de operaciones negras que se reúne para llevar a cabo un arriesgado atraco con el fin de salvar la vida de una niña de ocho años. En doce horas deben navegar por las calles letales en medio de un motín en la ciudad, pagar un rescate elevado y acusar a una peligrosa organización criminal, en una misión cargada de acción, traiciones y sacrificios"},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"限時營救","runtime":0,"tagline":"","homepage":"","overview":"艾達的八歲女兒遭到綁架，她過去率領的特種部隊成員們因此再度聚首，為了在十二小時內籌措到高額贖金，他們決定把倫敦變成戰場……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Lwica","runtime":99,"tagline":"","homepage":"","overview":"Opowiada historię byłego oddziału tajnych operacji, który ponownie łączy siły, by dokonać ryzykownego napadu i uratować życie ośmioletniej dziewczynki. W ciągu dwunastu godzin muszą przemierzać niebezpieczne ulice miasta w trakcie zamieszek, zapłacić wysoki okup i wrobić niebezpieczną organizację przestępczą w misję pełnej akcji, zdrady i poświęcenia."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"ไวลด์แคท สวยต้องปล้น","runtime":0,"tagline":"","homepage":"","overview":"การกลับมารวมตัวกันอีกครั้งของอดีตหน่วยปฏิบัติการลับ (Black Ops)  เพื่อทำภารกิจเสี่ยงชีวิต ช่วยเหลือเด็กหญิงอายุ 8 ขวบ ซึ่งเป็นลูกของหัวหน้าทีมด้วยการปล้น กับเวลาเพียง 12 ชั่วโมงท่ามกลางเมืองที่เกิดจลาจล"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Дивата котка","runtime":0,"tagline":"","homepage":"","overview":"Бивш екип от тайни операции се събира отново, за да осъществи отчаян обир и да спаси живота на осемгодишната дъщеря на своя лидер."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"限时营救","runtime":0,"tagline":"","homepage":"","overview":"讲述了一支前秘密行动小组重聚，实施一场孤注一掷的抢劫行动，以拯救一名八岁女孩的生命。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Un antiguo escuadrón de operaciones especiales se reúne para una última misión: un robo de alto riesgo para rescatar a la hija pequeña de su comandante."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Идеальная афера","runtime":89,"tagline":"","homepage":"","overview":"Брат Эйды задолжал мафии крупную сумму. Взамен преступники взяли в заложники ее маленькую дочь. У Эйды есть двенадцать часов, чтобы собрать команду и украсть для них крупную партию бриллиантов, а заодно разработать план побега — ведь владельцы бриллиантов не привыкли прощать тех, кто их обокрал."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":99,"tagline":"","homepage":"","overview":"Eski bir “black-ops” ekibi, sekiz yaşındaki bir kızı kurtarmak için son ve umutsuz bir soygun planı doğrultusunda yeniden bir araya gelir. Ancak görev yalnızca bir kurtarma değil: şehir çapında bir isyanın ortasında, kendilerine dayatılan 12 saatlik süre içinde büyük bir fidye ödenmeli, tehlikeli suç örgütü suçlanmalı ve kaosun içinden sağ çıkılmalıdır. Kaçınılmaz çatışmalar, yüksek gerilim ve moral ikilemler eşliğinde ekip, hem zamanla hem de geçmişin gölgeleriyle hesaplaşacaktır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"قط بري","runtime":0,"tagline":"","homepage":"","overview":"يتحد فريق سابق من العمليات السوداء لتنفيذ عملية سرقة يائسة من أجل إنقاذ حياة ابنة زعيمهم البالغة من العمر ثماني سنوات."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Una ex squadra delle operazioni speciali si riunisce per un'ultima missione: una rapina ad alto rischio per salvare la giovane figlia del loro comandante."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Divja mačka","runtime":0,"tagline":"","homepage":"","overview":"Nekdanji pripadniki elitne enote za črne operacije se znova združijo, da bi izvedli drzen rop in rešili življenje osemletni hčerki njihovega vodje."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"O fostă echipă de operațiuni speciale se reunește pentru o ultimă misiune - un jaf cu miză mare în urma căruia ar trebui s - o salveze pe tânăra fiica a comandantului lor."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"限時營救","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"گربه وحشی","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"","runtime":99,"tagline":"","homepage":"","overview":"Ada's wereld stort in wanneer haar jonge dochter ontvoerd wordt. Om haar te redden moet ze tegen de volgende dag een grote som geld bijeenschrapen. Ada behoorde vroeger tot de speciale eenheden en samen met enkele medestrijders beraamt ze een overval. Tegelijk vechten twee criminele bendes voor de heerschappij in Londen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Ein ehemaliges Spezialeinheit-Team findet sich für eine letzte Mission zusammen - einen riskanten Raubüberfall, um die kleine Tochter ihres Kommandanten zu retten."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":99,"tagline":"","homepage":"","overview":"Ada, uma ex-agente de operações especiais de elite, é forçada a sair da aposentadoria quando sua filha de oito anos é sequestrada por uma organização criminosa. Para salvar a menina, ela precisa reunir sua antiga equipe e realizar um assalto de alto risco em apenas 12 horas. A missão se torna ainda mais perigosa quando eles precisam atravessar a cidade, que está mergulhada no caos absoluto devido a um motim violento e a uma guerra entre facções rivais."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Mèo Rừng","runtime":0,"tagline":"","homepage":"","overview":"Một cựu đội đặc nhiệm bí mật buộc phải tái hợp trong phi vụ cuối cùng mang tính sống còn – một vụ cướp táo bạo nhằm giải cứu con gái 8 tuổi của chỉ huy cũ, khi thời gian cạn dần và quá khứ bạo lực trỗi dậy, họ phải đối mặt với những kẻ thù nguy hiểm, lựa chọn khắc nghiệt và cái giá phải trả cho lòng trung thành."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"לביאה","runtime":0,"tagline":"","homepage":"","overview":"כשהעסקים המפוקפקים של אחיה מובילים לחטיפת בתה שארלוט, אדה וויליאמס, סוכנת כוחות מיוחדים לשעבר, נאלצת לתעל את כישוריה מהחיים שהשאירה מאחור כדי להשיב אותה. בעזרת צוותה הוותיק שמתאחד למשימה אחת אחרונה, היא יוצאת למרוץ נגד הזמן לחלץ את שארלוט מהעולם התחתון, לפני שיהיה מאוחר מדי."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Laukinė katė","runtime":0,"tagline":"","homepage":"","overview":"Buvęs specialiųjų operacijų būrys susivienija paskutinei misijai – aukšto rizikos apiplėšimui, siekiant išgelbėti savo vadės jaunąją dukrą. Įtampa auga, kai komanda susiduria su pavojingais priešais ir sudėtingais moraliniais pasirinkimais, o kiekviena akimirka gali tapti lemiama. Ši istorija alsuoja adrenalino kupina veiksmo dinamika ir giliu vienybės jausmu, vedančiu herojus per neįveikiamas kliūtis."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"","runtime":96,"tagline":"","homepage":"","overview":"Når hendes bror, Edward, roder sig ud i lyssky affærer, og datteren Charlotte bliver kidnappet som følge deraf, må den tidligere elitesoldat Ada Williams bruge alle sine færdigheder for at få hende tilbage. Hun samler sit gamle hold til én sidste mission – et desperat kapløb mod tiden og en by på randen af kaos – før det er for sent, og Charlotte forsvinder for altid ned i underverdenen."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Divoká kočka","runtime":0,"tagline":"","homepage":"","overview":"Když pochybné kšefty jejího bratra Edwarda vedou k únosu její dcery Charlotte, je bývalá členka speciálních jednotek Ada Williamsová nucena využít všechny své schopnosti, aby ji získala zpět. Dává znovu dohromady svůj starý tým na poslední akci a musí závodit s časem – i s městem propadajícím se do chaosu – dřív, než bude pozdě a Charlotte se navždy ztratí v temném podsvětí."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"När Ada Williams bror Edwards skumma affärer leder till att hennes dotter Charlotte blir kidnappad, tvingas den före detta specialstyrkesoldaten Ada att använda alla sina färdigheter för att få sin dotter tillbaka. Med desperationen som drivkraft samlar Ada sitt gamla team för ett sista, livsfarligt uppdrag - där ingenting är som det verkar och varje misstag kan bli ödesdigert."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Ada Williams on eliittitason \"black ops\" -erikoisjoukkojen agentti, joka on jättänyt vaarallisen menneisyytensä taakseen ja asuuu nyt Itä-Lontoossa 8-vuotiaan kuuron tyttärensä Charlotten kanssa. Adan elämä suistuu raiteiltaan, kun hänen veljensä Edward joutuu vaikeuksiin Lontoon alamaailmassa ja  Charlotte kidnapataan lunnaita varten.  Pelastaakseen tyttärensä Adan on koottava vanha erikoisryhmänsä, johon kuuluu muun muassa hänen entinen rakastettunsa Roman. Ryhmän on suoritettava epätoivoinen ja monimutkainen timanttiryöstö keskellä kaupungin levottomuuksia ja jengi-sotaa. Aikaa on vain 12 tuntia navigoida läpi vaarallisten katujen, maksaa lunnasrahat ja selviytyä kilpailevien rikollispomojen välienselvittelystä."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Egy volt titkos ügynökökből álló csapat újra összeáll, hogy végrehajtson egy kétségbeesett rablást és megmentse egy nyolcéves kislány életét."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"}],"reviews_tmdb":[{"id":"692a718c8969e54eab3ce488","url":"https://www.themoviedb.org/review/692a718c8969e54eab3ce488","author":"MovieGuys","content":"Kate Beckinsale's lead character, Ada is about as intimidating as a bag of spinach, in this truly awful, tough girl action flick. \r\n\r\nThere is little to like here. An unoriginal story with a dash of casual misandry, meets what could best be described, as an unintentional satire of \"Lock, Stock and Two Smoking Barrels\". \r\n\r\nPerhaps the only upside, is the actions not wholly bad but it doesn't really make up, for this films deficits, in most other respects.\r\n\r\nIn summary, yet another hammy girl boss action flick, no one asked for, much less wanted.","created_at":"2025-11-29T04:07:40.359Z","updated_at":"2025-12-05T22:25:17.498Z","author_details":{"name":"","rating":4,"username":"MovieGuys","avatar_path":null}},{"id":"692b31a78bff3b1818080951","url":"https://www.themoviedb.org/review/692b31a78bff3b1818080951","author":"AbsoluteTube","content":"Every character in this was brilliant, it could've been a good film if Kate wasn't walking about looking like a duck begging for bread in a park. Really offputting","created_at":"2025-11-29T17:47:19.378Z","updated_at":"2025-11-30T18:01:27.966Z","author_details":{"name":"","rating":null,"username":"AbsoluteTube","avatar_path":null}}],"recommendations":[],"similar_content":[{"id":379,"adult":false,"title":"Miller's Crossing","video":false,"overview":"Set in 1929, a political boss and his advisor have a parting of the ways when they both fall for the same woman.","genre_ids":[18,53,80],"popularity":2.7216,"vote_count":1804,"poster_path":"/i83gYdglRCjCRLSsmCk5nRWRmDM.jpg","release_date":"1990-09-21","vote_average":7.45,"backdrop_path":"/cEsnLkTCJ4jh9Oym7nPAPGnOMm3.jpg","original_title":"Miller's Crossing","original_language":"en"},{"id":285,"adult":false,"title":"Pirates of the Caribbean: At World's End","video":false,"overview":"Captain Jack Sparrow, that wily charmer of a pirate, is trapped in Davy Jones' Locker when his pirate brethren begin a desperate quest to locate and rescue him. Follow their wild seafaring adventures from exotic Singapore to World's End and beyond.","genre_ids":[12,14,28],"popularity":14.9147,"vote_count":15229,"poster_path":"/jGWpG4YhpQwVmjyHEGkxEkeRf0S.jpg","release_date":"2007-05-19","vote_average":7.267,"backdrop_path":"/1jHxkVXMI5s3vRiyiZooUy1shB5.jpg","original_title":"Pirates of the Caribbean: At World's End","original_language":"en"},{"id":1452198,"adult":false,"title":"Hamburg","video":false,"overview":"Germán is a driver and transports women who work as slaves in brothels on the Costa del Sol. Broke and lost, he tries to get by working for his friend Cacho, who manages several of these clubs for a local mafia. One night he is presented with what seems like a chance to change his life, but this decision will put him in more danger than ever. He has only one option left, the same one Alina thinks of every night: to escape.","genre_ids":[53],"popularity":0.2426,"vote_count":0,"poster_path":"/aWghdaaHi1TKab5Esf25XhxnxcN.jpg","release_date":"2025-05-30","vote_average":0,"backdrop_path":null,"original_title":"Hamburgo","original_language":"es"},{"id":9539,"adult":false,"title":"Martyrs","video":false,"overview":"A young woman’s quest for revenge against the people who kidnapped and tortured her as a child leads her and her best friend, also a victim of child abuse, on a terrifying journey into a living hell of depravity.","genre_ids":[27,18,53],"popularity":4.3002,"vote_count":2957,"poster_path":"/2zj5JHihR3Bih8vZROJK9LOWsZO.jpg","release_date":"2008-06-12","vote_average":7.304,"backdrop_path":"/fO1hwjlUqDe1ixO7eMfxTby62Ut.jpg","original_title":"Martyrs","original_language":"fr"},{"id":11653,"adult":false,"title":"The Myth","video":false,"overview":"When a fellow scientist asks for Jack's help in locating the mausoleum of China's first emperor, the past collides violently with the present as Jack discovers his amazing visions are based in fact.","genre_ids":[28,12,35,18,14],"popularity":2.7976,"vote_count":410,"poster_path":"/iBDFnLkTZZxQlbb6IIeYkufnPCY.jpg","release_date":"2005-05-11","vote_average":6.418,"backdrop_path":"/xChyWmjDeEH8zOVi9dwVrtIJEfd.jpg","original_title":"神話","original_language":"zh"},{"id":1461443,"adult":false,"title":"Nothing Goes","video":false,"overview":"A university student’s life begins to spiral out of control after reluctantly being involved in a robbery, leading to a road trip which will change his life forever.","genre_ids":[80,53,18],"popularity":0.3541,"vote_count":1,"poster_path":"/8DjbNl8dkyRPK6mN6mp71nqSnVd.jpg","release_date":"2023-10-22","vote_average":10,"backdrop_path":"/ypov7OuU4wQXMFvLvfwaRv9HcIs.jpg","original_title":"Nothing Goes","original_language":"en"},{"id":14164,"adult":false,"title":"Dragonball Evolution","video":false,"overview":"On his 18th birthday, Goku receives a mystical Dragonball as a gift from his grandfather. There are only six others like it in the whole world, and legend has it that whoever possesses all seven will be granted one perfect wish. When the arrival of a dark force triggers a tragedy, Goku and his companions are propelled into an epic quest to collect the seven Dragonballs and save the Earth from destruction.","genre_ids":[28,12,14,878,53],"popularity":2.4817,"vote_count":2169,"poster_path":"/sunS9xhPnFNP5wlOWrvbpBteAB.jpg","release_date":"2009-03-12","vote_average":2.936,"backdrop_path":"/19ChHftp06sllxdgINPSTDIyKHw.jpg","original_title":"Dragonball Evolution","original_language":"en"},{"id":7446,"adult":false,"title":"Tropic Thunder","video":false,"overview":"A group of self-absorbed actors set out to make the most expensive war film ever. After ballooning costs force the studio to cancel the movie, the frustrated director 