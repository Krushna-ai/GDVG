9:{"metadata":[["$","title","0",{"children":"Deathstalker | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"A powerful swordsman known as Deathstalker recovers a cursed amulet from a corpse-strewn battlefield. Marked by dark magic and hunted by monstrous assassins, he must face the rising evil and break the curse."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148741/deathstalker"}],["$","meta","5",{"property":"og:title","content":"Deathstalker"}],["$","meta","6",{"property":"og:description","content":"A powerful swordsman known as Deathstalker recovers a cursed amulet from a corpse-strewn battlefield. Marked by dark magic and hunted by monstrous assassins, he must face the rising evil and break the curse."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148741/deathstalker"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/nEI3DnzQC1afAjJOAizx6UX27pL.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Deathstalker"}],["$","meta","12",{"name":"twitter:description","content":"A powerful swordsman known as Deathstalker recovers a cursed amulet from a corpse-strewn battlefield. Marked by dark magic and hunted by monstrous assassins, he must face the rising evil and break the curse."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/nEI3DnzQC1afAjJOAizx6UX27pL.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L12","15",{}]],"error":null,"digest":"$undefined"}
