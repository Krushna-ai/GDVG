6_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":506,"height":759,"file_path":"/kT0gv7s2lQQbIdMMr16wCCineM3.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/cugd16e3WbCG3Zogb8N7lwUnVXH.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/vtqKDMdRySkV4GSM5F6AKyZO8aJ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/bAAbHQF97RJRsRzbA10XlBQqniW.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/zsY9AYfKqDdZ2ujy7desOTheiLb.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T04:40:06.359+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":103,"tagline":"Evil has many names. Adventure has only one...","homepage":"https://www.shoutstudios.com/deathstalker","overview":"A powerful swordsman known as Deathstalker recovers a cursed amulet from a corpse-strewn battlefield. Marked by dark magic and hunted by monstrous assassins, he must face the rising evil and break the curse."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Un guerrier affronte un sorcier maléfique et autres créatures..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Ловчий смерти","runtime":0,"tagline":"«У зла много имён»","homepage":"","overview":"Ловчий смерти, легендарный воин и бывший рыцарь, однажды среди трупов на поле боя находит таинственный амулет и становится жертвой древнего проклятия. Теперь ему предстоит найти способ снять проклятие и спасти королевство Абраксеон от зла."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"圣剑屠魔","runtime":0,"tagline":"","homepage":"","overview":"一位被称为死亡追踪者的强大剑客从尸体遍布的战场上找回了一个被诅咒的护身符。他以黑魔法为标志，被可怕的刺客追捕，他必须面对不断上升的邪恶，打破诅咒。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Regatul Abraxeon este asediat de Dreadites, mesagerii vrăjitorului Nekromemnon, mort de mult timp. Când Deathstalker recuperează o amuletă blestemată de pe un câmp de luptă presărat cu cadavre, el devine ținta magiei negre și este vânat de asasini monstruoși. Pentru a supraviețui, trebuie să rupă blestemul și să înfrunte răul care se ridică. Moartea este doar începutul... unei mari aventuri!"},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"聖劍屠魔","runtime":0,"tagline":"","homepage":"","overview":"亡靈巫師涅克羅姆農的恐怖軍團\"懼亡者\"圍攻阿布拉西昂王國。當\"死亡潛行者\"尋獲受詛咒的護符，黑暗魔法烙印使其淪為怪物刺客的獵殺目標。為求生存，他必須破除詛咒——或死於嘗試。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Преследвач на смъртта","runtime":0,"tagline":"","homepage":"","overview":"Воинът Deathstalker получава мисия от стара вещица да открие и обедини трите сили на сътворението – чаша, амулет и меч – преди те да попаднат в ръцете на злия магьосник Мункар, който би ги използвал за престъпни цели. След като се сдобива с меча, той се присъединява към група пътешественици, отправили се към Големия турнир с цел да определят най-силния воин. Междувременно фалшивият крал държи истинската принцеса в плен и планира да убие Deathstalker, който трябва да се бори, за да я освободи."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":102,"tagline":"","homepage":"","overview":"El reino de Abraxeon está siendo asediado por los Dreadites, heraldos del hechicero Nekromemnon, muerto hace mucho tiempo. Cuando Deathstalker recupera un amuleto maldito de un campo de batalla sembrado de cadáveres, queda marcado por la magia negra y es perseguido por monstruosos asesinos de todo tipo. Para sobrevivir, debe romper la maldición y enfrentarse al mal naciente."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":102,"tagline":"","homepage":"","overview":"El reino de Abraxeon está siendo asediado por los Dreadites, heraldos del hechicero Nekromemnon, muerto hace mucho tiempo. Cuando Deathstalker recupera un amuleto maldito de un campo de batalla sembrado de cadáveres, queda marcado por la magia negra y es perseguido por monstruosos asesinos de todo tipo. Para sobrevivir, debe romper la maldición y enfrentarse al mal naciente."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"W królestwie Abraxeon narasta mrok, gdy pradawne zło powraca, by pogrążyć świat w chaosie. Samotny wojownik, znany jako Deathstalker, natrafia na przeklęty amulet – źródło potężnej, ale zatrutej mocy. Od tej chwili staje się celem dla potworów i magów żądnych władzy. By przetrwać, musi zmierzyć się z ciemnością, która ogarnęła nie tylko królestwo, ale i jego własne serce."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Het koninkrijk Abraxeon wordt belegerd door de Dreadites, een mysterieuze horde krijgers. Hun plotselinge verschijning voorspelt volgens geruchten de terugkeer van Nekromemnon, een oude tovenaar die al lang dood gewaand was. Voor iemand als Deathstalker, die zijn brood verdient met het aanvallen van de Dreadites, kan het niet beter. Maar wanneer hij onbewust een betoverd amulet vindt op een slagveld vol lijken, merkt Deathstalker dat hij vervloekt is door geheimzinnige magie. Nu hij wordt achtervolgd door een monsterlijke clan van moordenaars, wordt Deathstalker gedwongen om een gevaarlijke zoektocht te ondernemen om de vloek ongedaan te maken en het rijk van het kwaad te bevrijden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Ein mächtiger Schwertkämpfer namens Deathstalker birgt ein verfluchtes Amulett von einem mit Leichen übersäten Schlachtfeld. Gezeichnet von dunkler Magie und gejagt von monströsen Attentätern, muss er sich dem aufsteigenden Bösen stellen und den Fluch brechen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"Zlo ima veliko imen. Pustolovščina ima samo eno...","homepage":"","overview":"Mogočen mečevalec, znan kot Deathstalker, pridobi prekleti amulet s trupla na bojišču. Ker ga lovijo pošastni morilci in označen s temno magijo, se mora soočiti z naraščajočim zlom in zlomiti prekletstvo."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"مُطارد الموت","runtime":103,"tagline":"","homepage":"","overview":"يستعيد مقاتل ماهر بالسيف يُعرف باسم \"مُطارد الموت\" تميمة ملعونة من ساحة معركة مليئة بالجثث. بعد أن أصبح هدفًا للسحر الأسود ومطاردة قتلة وحوش، عليه أن يواجه الشر المتصاعد ويكسر اللعنة."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Um poderoso espadachim conhecido como Deathstalker recupera um amuleto amaldiçoado em um campo de batalha repleto de cadáveres. Marcado por magia negra e caçado por assassinos monstruosos, ele precisa enfrentar o mal crescente e quebrar a maldição."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Mocný bojovník s mečem známý jako Deathstalker najde na bojišti posetém mrtvolami prokletý amulet. Označen temnou magií a pronásledován monstrózními asasíny musí čelit rostoucímu zlu a zlomit kletbu."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"}],"reviews_tmdb":[{"id":"698dea76d1757f62e7dcdceb","url":"https://www.themoviedb.org/review/698dea76d1757f62e7dcdceb","author":"Chandler Danier","content":"Holy shit. The perfect Deathstalker film. I am just amazed by how well the lead handles the situations. I must say, they should hire my buddy to make them some silicon masks because the foam sure seems lifeless on a lead. Some pretty weak little dude effects all around. The thing about practical effects is even if they're bad you get to see the creative decisions they had to make based on budget. If the CGI is bad...you just feel disappointed.\r\n\r\nNice to see practical effects. Nice to hear squealing guitars. Nice to see the perfect sword. I find the perfect sword to be the best joke in this film. It's hilarious. Good god, I loved Deathstalker. I can no longer see any of its flaws and I hope they make more of this bullshit.","created_at":"2026-02-12T14:57:58.636Z","updated_at":"2026-02-12T14:57:58.650Z","author_details":{"name":"Chandler Danier","rating":10,"username":"chandlerdanier","avatar_path":null}},{"id":"69980fc4f25704bf8eab908e","url":"https://www.themoviedb.org/review/69980fc4f25704bf8eab908e","author":"graeaehorror","content":"$11","created_at":"2026-02-20T07:39:48.705Z","updated_at":"2026-02-20T07:39:48.714Z","author_details":{"name":"","rating":10,"username":"graeaehorror","avatar_path":"/5NFe3m6dyXiY3WAgfdMIRsQtYy3.jpg"}}],"recommendations":[{"id":766,"adult":false,"title":"Army of Darkness","video":false,"overview":"Ash, a handsome, shotgun-toting, chainsaw-armed department store clerk, is time warped backwards into England's Dark Ages, where he romances a beauty and faces legions of the undead.","genre_ids":[14,27,35],"media_type":"movie","popularity":5.7743,"vote_count":3440,"poster_path":"/xsgTuAtR2zSH8Umg3jWZcZjlDpe.jpg","release_date":"1992-10-31","vote_average":7.261,"backdrop_path":"/5RPXs9g0sZ9Woo4pNLxdXdge7tc.jpg","original_title":"Army of Darkness","original_language":"en"},{"id":4108,"adult":false,"title":"The Transporter","video":false,"overview":"Former Special Forces officer Frank Martin will deliver anything to anyone for the right price, and his no-questions-asked policy puts him in high demand. But when he realizes his latest cargo is alive, it sets in motion a dangerous chain of events. The bound and gagged Lai is being smuggled to France by a shady American businessman, and Frank works to save her as his own illegal activities are uncovered by a French detective.","genre_ids":[28,80,53],"media_type":"movie","popularity":6.3513,"vote_count":5703,"poster_path":"/dncJ81z1BahrT3ogLvlxOUC5n4u.jpg","release_date":"2002-10-02","vote_average":6.718,"backdrop_path":"/8dXR9R0NUo4eyS4hnYOsCywmo16.jpg","original_title":"The Transporter","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":28.4976,"vote_count":26828,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.903,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":11324,"adult":false,"title":"Shutter Island","video":false,"overview":"World War II soldier-turned-U.S. Marshal Teddy Daniels investigates the disappearance of a patient from a hospital for the criminally insane, but his efforts are compromised by troubling visions and a mysterious doctor.","genre_ids":[18,53,9648],"media_type":"movie","popularity":14.6244,"vote_count":25460,"poster_path":"/nrmXQ0zcZUL8jFLrakWc90IR8z9.jpg","release_date":"2010-02-14","vote_average":8.2,"backdrop_path":"/8xt8AMb1OKC63AdhNSaYBWxB4Iq.jpg","original_title":"Shutter Island","original_language":"en"},{"id":12230,"adult":false,"title":"One Hundred and One Dalmatians","video":false,"overview":"When a litter of dalmatian puppies are abducted by the minions of Cruella De Vil, the parents must find them before she uses them for a diabolical fashion statement.","genre_ids":[12,16,35,10751],"media_type":"movie","popularity":6.6608,"vote_count":6591,"poster_path":"/kSlYq6FrBUviGSEh8v4L9nrSnBT.jpg","release_date":"1961-01-25","vote_average":7.173,"backdrop_path":"/cZgUATpU4NDlsfGj7sRriKJEiLB.jpg","original_title":"One Hundred and One Dalmatians","original_language":"en"},{"id":10193,"adult":false,"title":"Toy Story 3","video":false,"overview":"Woody, Buzz, and the rest of Andy's toys haven't been played with in years. With Andy about to go to college, the gang find themselves accidentally left at a nefarious day care center. The toys must band together to escape and return home to Andy.","genre_ids":[16,10751,35],"media_type":"movie","popularity":14.7591,"vote_count":15489,"poster_path":"/AbbXspMOwdvwWZgVN0nabZq03Ec.jpg","release_date":"2010-06-16","vote_average":7.804,"backdrop_path":"/9w40MpsvyxMdtnwu1R4tPVW8Gmb.jpg","original_title":"Toy Story 3","original_language":"en"},{"id":105,"adult":false,"title":"Back to the Future","video":false,"overview":"Eighties teenager Marty McFly is accidentally sent back in time to 1955, inadvertently disrupting his parents' first meeting and attracting his mother's romantic interest. Marty must repair the damage to history by rekindling his parents' romance and - with the help of his eccentric inventor friend Doc Brown - return to 1985.","genre_ids":[12,35,878],"media_type":"movie","popularity":18.5525,"vote_count":21421,"poster_path":"/vN5B5WgYscRGcQpVhHl6p9DDTP0.jpg","release_date":"1985-07-03","vote_average":8.324,"backdrop_path":"/qskzmLTbarKnXDbo2HRj4NJ3vcW.jpg","original_title":"Back to the Future","original_language":"en"},{"id":98,"adult":false,"title":"Gladiator","video":false,"overview":"After the death of Emperor Marcus Aurelius, his devious son takes power and demotes Maximus, one of Rome's most capable generals who Marcus preferred. Eventually, Maximus is forced to become a gladiator and battle to the death against other men for the amusement of paying audiences.","genre_ids":[28,18,12],"media_type":"movie","popularity":16.5057,"vote_count":20542,"poster_path":"/ty8TGRuvJLPUmAR1H1nRIsgwvim.jpg","release_date":"2000-05-04","vote_average":8.222,"backdrop_path":"/jhk6D8pim3yaByu1801kMoxXFaX.jpg","original_title":"Gladiator","original_language":"en"},{"id":62,"adult":false,"title":"2001: A Space Odyssey","video":false,"overview":"Humanity finds a mysterious object buried beneath the lunar surface and sets off to find its origins with the help of HAL 9000, the world's most advanced super computer.","genre_ids":[878,9648,12],"media_type":"movie","popularity":13.0323,"vote_count":12364,"poster_path":"/ve72VxNqjGM69Uky4WTo2bK6rfq.jpg","release_date":"1968-04-02","vote_average":8.056,"backdrop_path":"/w5IDXtifKntw0ajv2co7jFlTQDM.jpg","original_title":"2001: A Space Odyssey","original_language":"en"},{"id":37165,"adult":false,"title":"The Truman Show","video":false,"overview":"An insurance salesman begins to suspect that his whole life is actually some sort of reality TV show.","genre_ids":[35,18],"media_type":"movie","popularity":16.282,"vote_count":19833,"poster_path":"/vuza0WqY239yBXOadKlGwJsZJFE.jpg","release_date":"1998-06-04","vote_average":8.151,"backdrop_path":"/aCHn2TXYJfzPXQKA6r9mKPbMlUB.jpg","original_title":"The Truman Show","original_language":"en"},{"id":14,"adult":false,"title":"American Beauty","video":false,"overview":"Lester Burnham, a depressed suburban father in a mid-life crisis, decides to turn his hectic life around after developing an infatuation with his daughter's attractive friend.","genre_ids":[18],"media_type":"movie","popularity":10.4774,"vote_count":12827,"poster_path":"/wby9315QzVKdW9BonAefg8jGTTb.jpg","release_date":"1999-09-15","vote_average":8.002,"backdrop_path":"/2ndw55F40IkALzWyjCCza3M6nqM.jpg","original_title":"American Beauty","original_language":"en"},{"id":854,"adult":false,"title":"The Mask","video":false,"overview":"Stanley Ipkiss, an insecure banker who has lost his zest for life stumbles upon an ancient mask, that turns him into a confident suave cartoon-like character who upsets his ordinary life.","genre_ids":[10749,35,80,14],"media_type":"movie","popularity":11.6934,"vote_count":11034,"poster_path":"/jPC2eYub74zwf2tPGVtzSlBW6Oy.jpg","release_date":"1994-07-29","vote_average":6.975,"backdrop_path":"/bQlw59HncOXX9alFlOYKHAvSnm.jpg","original_title":"The Mask","original_language":"en"},{"id":150540,"adult":false,"title":"Inside Out","video":false,"overview":"When 11-year-old Riley moves to a new city, her Emotions team up to help her through the transition. Joy, Fear, Anger, Disgust and Sadness work together, but when Joy and Sadness get lost, they must journey through unfamiliar places to get back home.","genre_ids":[16,10751,12,18,35],"media_type":"movie","popularity":16.5969,"vote_count":23190,"poster_path":"/2H1TmgdfNtsKlU9jKdeNyYL5y8T.jpg","release_date":"2015-06-17","vote_average":7.909,"backdrop_path":"/o3i6AfTcWAuNvzAUV3q5lOmi6Gx.jpg","original_title":"Inside Out","original_language":"en"},{"id":272,"adult":false,"title":"Batman Begins","video":false,"overview":"Driven by tragedy, billionaire Bruce Wayne dedicates his life to uncovering and defeating the corruption that plagues his home, Gotham City.  Unable to work within the system, he instead creates a new identity, a symbol of fear for the criminal underworld - The Batman.","genre_ids":[18,80,28],"media_type":"movie","popularity":12.5976,"vote_count":22282,"poster_path":"/sPX89Td70IDDjVr85jdSBb4rWGr.jpg","release_date":"2005-06-10","vote_average":7.721,"backdrop_path":"/9IIBboV7MCT0bTxzXHmWK1Hq558.jpg","original_title":"Batman Begins","original_language":"en"},{"id":359940,"adult":false,"title":"Three Billboards Outside Ebbing, Missouri","video":false,"overview":"After seven months have passed without a culprit in her daughter's murder case, Mildred Hayes makes a bold move, painting three signs leading into her town with a controversial message directed at Bill Willoughby, the town's revered chief of police. When his second-in-command Officer Jason Dixon, an immature mother's boy with a penchant for violence, gets involved, the battle between Mildred and Ebbing's law enforcement is only exacerbated.","genre_ids":[80,18],"media_type":"movie","popularity":5.294,"vote_count":10716,"poster_path":"/bRYLt8fV82tdVoDppSFTZIcJiLN.jpg","release_date":"2017-12-01","vote_average":8.061,"backdrop_path":"/bioYaOXZS2nXLiLVf5mDOgXpCd8.jpg","original_title":"Three Billboards Outside Ebbing, Missouri","original_language":"en"},{"id":9502,"adult":false,"title":"Kung Fu Panda","video":false,"overview":"Chosen by prophecy but doubted by all, Po is an unlikely Dragon Warrior—a clumsy panda thrust into the world of kung fu as a deadly enemy threatens the Valley of Peace. Guided by Master Shifu and the Furious Five, Po must embrace who he is to unlock the power that no scroll can teach.","genre_ids":[16,10751,35,28],"media_type":"movie","popularity":13.7983,"vote_count":12410,"poster_path":"/wWt4JYXTg5Wr3xBW2phBrMKgp3x.jpg","release_date":"2008-06-04","vote_average":7.315,"backdrop_path":"/qdthf9WrRDSaIkGVQGhhJ9pz1hn.jpg","original_title":"Kung Fu Panda","original_language":"en"},{"id":59436,"adult":false,"title":"Midnight in Paris","video":false,"overview":"While on a trip to Paris with his fiancée's family, a nostalgic screenwriter finds himself mysteriously going back to the 1920s every day at midnight.","genre_ids":[14,35,10749],"media_type":"movie","popularity":5.2251,"vote_count":7650,"poster_path":"/4wBG5kbfagTQclETblPRRGihk0I.jpg","release_date":"2011-05-11","vote_average":7.514,"backdrop_path":"/gR1LRuvKTzh2AvxGvfoBNNJHPMq.jpg","original_title":"Midnight in Paris","original_language":"en"},{"id":239,"adult":false,"title":"Some Like It Hot","video":false,"overview":"In Prohibition-era Chicago, musicians Joe and Jerry witness a mob hit, and flee the state in an all-female band disguised as Josephine and Daphne, but further complications set in.","genre_ids":[35,10749,80],"media_type":"movie","popularity":4.9341,"vote_count":3788,"poster_path":"/hVIKyTK13AvOGv7ICmJjK44DTzp.jpg","release_date":"1959-03-19","vote_average":8.086,"backdrop_path":"/5zTwAcnI3zCJ0mucPPnoBtkSWEV.jpg","original_title":"Some Like It Hot","original_language":"en"},{"id":2108,"adult":false,"title":"The Breakfast Club","video":false,"overview":"Five high school students from different walks of life endure a Saturday detention under a power-hungry principal. The disparate group includes rebel John, princess Claire, outcast Allison, brainy Brian and Andrew, the jock. Each has a chance to tell his or her story, making the others see them a little differently -- and when the day ends, they question whether school will ever be the same.","genre_ids":[35,18],"media_type":"movie","popularity":5.7903,"vote_count":8415,"poster_path":"/gp4zlj7wgbiofLMNsTPndMuO3PN.jpg","release_date":"1985-02-15","vote_average":7.725,"backdrop_path":"/kjVgUMsG0PKBXzlP8HGNQpWDxAX.jpg","original_title":"The Breakfast Club","original_language":"en"},{"id":603,"adult":false,"title":"The Matrix","video":false,"overview":"Set in the 22nd century, The Matrix tells the story of a computer hacker who joins a group of underground insurgents fighting the vast and powerful computers who now rule the earth.","genre_ids":[28,878],"media_type":"movie","popularity":22.54,"vote_count":27421,"poster_path":"/p96dm7sCMn4VYAStA6siNz30G1r.jpg","release_date":"1999-03-31","vote_average":8.238,"backdrop_path":"/tlm8UkiQsitc8rSuIAscQDCnP8d.jpg","original_title":"The Matrix","original_language":"en"}],"similar_content":[{"id":861101,"adult":false,"title":"Pluft, o Fantasminha","video":false,"overview":"A little kid-ghost called Pluft lives with his ghost-mother and ghost-uncle, in a remote house in a desert island. He doesn't even believe people real exist. His world will be thrown upside down, when an evil pirate (Perna de Pau) disembark on the island, after kidnapping the little girl Maribel (daughter of a famous captain), in search of Captain's hidden treasure. Three friendly sailors will help to free the girl. Based on a very well known Brazilian children's play.","genre_ids":[35,10751,14],"popularity":0.2878,"vote_count":4,"poster_path":"/iCrD6A21Wmzzm1v2bOVdqD8HxRP.jpg","release_date":"2022-07-21","vote_average":6.5,"backdrop_path":"/4aErColaMWJruY2wer2SsXNDdPC.jpg","original_title":"Pluft, o Fantasminha","original_language":"pt"},{"id":8216,"adult":false,"title":"Meet the Feebles","video":false,"overview":"Heidi, star of the \"Meet The Feebles Variety Hour\" discovers her lover Bletch the Walrus is cheating on her. And with all the world waiting for the show, the assorted co-stars must contend with drug addiction, extortion, robbery, disease, drug dealing, and murder.","genre_ids":[35,10402,14],"popularity":0.9539,"vote_count":311,"poster_path":"/31DqGazwdE9N4Y9FHC6Q4NvstuW.jpg","release_date":"1989-08-12","vote_average":6.339,"backdrop_path":"/fji432Vjgj89p0ISOJONYyfNUmy.jpg","original_title":"Meet the Feebles","original_language":"en"},{"id":8337,"adult":false,"title":"They Live","video":false,"overview":"A lone drifter stumbles upon a unique pair of sunglasses that reveal aliens are systematically gaining control of the Earth by masquerading as humans and lulling the public into submission.","genre_ids":[878,28,53],"popularity":5.1112,"vote_count":3366,"poster_path":"/ngnybFTuopfbfmmEeX9jjBQQmF6.jpg","release_date":"1988-11-04","vote_average":7.294,"backdrop_path":"/3k2DQBryXzaL7DoAtu6veWWluwt.jpg","original_title":"They Live","original_language":"en"},{"id":8840,"adult":false,"title":"DragonHeart","video":false,"overview":"In an ancient time when majestic fire-breathers soared through the skies, a knight named Bowen comes face to face and heart to heart with the last dragon on Earth, Draco. Taking up arms to suppress a tyrant king, Bowen soon realizes his task will be harder than he'd imagined: If he kills the king, Draco will die as well.","genre_ids":[14,28,12,18],"popularity":5.2051,"vote_count":2107,"poster_path":"/1J2FvxEoEKMFT9TjUdfhm0MJhZD.jpg","release_date":"1996-05-31","vote_average":6.545,"backdrop_path":"/xbqluNfftDJtxDsqcpx9kKme4LF.jpg","original_title":"DragonHeart","original_language":"en"},{"id":8967,"adult":false,"title":"The Tree of Life","video":false,"overview":"The impressionistic story of a Texas family in the 1950s. The film follows the life journey of the eldest son, Jack, through the innocence of childhood to his disillusioned adult years as he tries to reconcile a complicated relationship with his father. Jack finds himself a lost soul in the modern world, seeking answers to the origins and meaning of life while questioning the existence of faith.","genre_ids":[18,14],"popularity":3.6474,"vote_count":3278,"poster_path":"/l8cwuB5WJSoj4uMAsnzuHBOMaSJ.jpg","release_date":"2011-05-17","vote_average":6.727,"backdrop_path":"/xq1HIwZq9VbuvMQELAua1nqEkH.jpg","original_title":"The Tree of Life","original_language":"en"},{"id":9078,"adult":false,"title":"The Sword in the Stone","video":false,"overview":"Wart is a young boy who aspires to be a knight's squire. On a hunting trip he falls in on Merlin, a powerful but amnesiac wizard who has plans for him beyond mere squiredom. He starts by trying to give him an education, believing that once one has an education, one can go anywhere. Needless to say, it doesn't quite work out that way.","genre_ids":[16,10751,14],"popularity":3.8347,"vote_count":4047,"poster_path":"/7lyeeuhGAJSNXYEW34S8mJ1bwI8.jpg","release_date":"1963-12-25","vote_average":7.22,"backdrop_path":"/m1TOfgljbT3jOez3b4l1I1tm82W.jpg","original_title":"The Sword in the Stone","original_language":"en"},{"id":9334,"adult":false,"title":"The Scorpion King","video":false,"overview":"In ancient Egypt, peasant Mathayus is hired to exact revenge on the powerful Memnon and the sorceress Cassandra, who are ready to overtake Balthazar's village. Amid betrayals, thieves, abductions and more, Mathayus strives to bring justice to his complicated world.","genre_ids":[28,12,14],"popularity":5.8946,"vote_count":3319,"poster_path":"/aITIsX20tACn6jgtyDcCYpRT216.jpg","release_date":"2002-04-18","vote_average":5.593,"backdrop_path":"/nZSUgauXlVUrJGdGUGWMXCtnZx4.jpg","original_title":"The Scorpion King","original_language":"en"},{"id":9279,"adult":false,"title":"Jingle All the Way","video":false,"overview":"Howard Langston, a salesman for a mattress company, is constantly kept busy at his job, disappointing his son. After he misses his son's karate exposition, Howard vows to make it up to him by buying an action figure of his son's favorite television hero for Christmas. Unfortunately for Howard, it is Christmas Eve, and every store is sold out of Turbo Man. Now, Howard must travel all over town and compete with everybody else to find a Turbo Man action figure.","genre_ids":[10751,35,12],"popularity":4.6622,"vote_count":2888,"poster_path":"/lHLOUt0ZIQLC5asHdIQBoTUvaEp.jpg","release_date":"1996-11-21","vote_average":6.06,"backdrop_path":"/rnn6sGMGPpM8VfVmCMFxsjKvz7q.jpg","original_title":"Jingle All the Way","original_language":"en"},{"id":471877,"adult":false,"title":"Warkop DKI Reborn: Jangkrik Boss! Part 2","video":false,"overview":"Dono, Kasino, and Indro's adventure continues. They have to search for the treasure to pay their debts. They travel to Malaysia, but the bags with treasure codes was switched with a woman. They ended up at a haunted uninhabited island.","genre_ids":[35,28,12],"popularity":0.2157,"vote_count":9,"poster_path":"/s8hK5qbBYo98DLSVLof4bfUdlGN.jpg","release_date":"2017-08-31","vote_average":5.3,"backdrop_path":"/pzQJbaTbecfOhmz77sflpzAN9aT.jpg","original_title":"Warkop DKI Reborn: Jangkrik Boss! Part 2","original_language":"id"},{"id":9406,"adult":false,"title":"An American Werewolf in Paris","video":false,"overview":"An American man unwittingly gets involved with werewolves who have developed a serum allowing them to transform at will.","genre_ids":[27,35,14],"popularity":2.112,"vote_count":742,"poster_path":"/1NUOprbP7LLfKPArLJY7wziUiHT.jpg","release_date":"1997-05-29","vote_average":5.915,"backdrop_path":"/3umSuaSibCcNGAnsWYUyauLTZwE.jpg","original_title":"An American Werewolf in Paris","original_language":"en"},{"id":9387,"adult":false,"title":"Conan the Barbarian","video":false,"overview":"A horde of rampaging warriors massacre the parents of young Conan and enslave the young child for years on The Wheel of Pain. As the sole survivor of the childhood massacre, Conan is released from slavery and taught the ancient arts of fighting. Transforming himself into a killing machine, Conan travels into the wilderness to seek vengeance on Thulsa Doom, the man responsible for killing his family. In the wilderness, Conan takes up with the thieves Valeria and Subotai. The group comes upon King Osric, who wants the trio of warriors to help rescue his daughter who has joined Doom in the hills.","genre_ids":[12,14,28],"popularity":6.27,"vote_count":2723,"poster_path":"/qw2A587Ee61IwcSOLNFRhuOACZZ.jpg","release_date":"1982-03-16","vote_average":6.8,"backdrop_path":"/6cYPpzjHcxcSaXEQc8s3sMbcfZS.jpg","original_title":"Conan the Barbarian","original_language":"en"},{"id":1260004,"adult":false,"title":"Island of Death","video":false,"overview":"Dara disregarded her mother's prohibition to celebrate graduation with Pandu, Niki, Lathi, and Noah on a ship. Unbeknownst to them, their ship stranded on an unnamed island. Longing enveloped Dara for her mother as she and her friends were trapped there. Can Dara and her friends escape from the island?","genre_ids":[12,27],"popularity":2.9225,"vote_count":3,"poster_path":"/5Rvs6cM1yZs7iGRlpZNj7o2yFtK.jpg","release_date":"2024-10-10","vote_average":7.7,"backdrop_path":"/xdWp1LpiutVD79d9E68JaHrltU9.jpg","original_title":"Pulau Hantu","original_language":"id"},{"id":9495,"adult":false,"title":"The Crow","video":false,"overview":"Exactly one year after young rock guitarist Eric Draven and his fiancée are brutally killed by a ruthless gang of criminals, Draven, watched over by a hypnotic crow, returns from the grave to exact revenge.","genre_ids":[14,28,53],"popularity":5.8674,"vote_count":4428,"poster_path":"/rMMB3v6jYHjsvXRNJYESacoTD7j.jpg","release_date":"1994-05-11","vote_average":7.517,"backdrop_path":"/cLqvQbP2utIKHRonwXnDjY3l1kk.jpg","original_title":"The Crow","original_language":"en"},{"id":111,"adult":false,"title":"Scarface","video":false,"overview":"After getting a green card in exchange for assassinating a Cuban government official, Tony Montana stakes a claim on the drug trade in Miami. Viciously murdering anyone who stands in his way, Tony eventually becomes the biggest drug lord in the state, controlling nearly all the cocaine that comes through Miami. But increased pressure from the police, wars with Colombian drug cartels and his own drug-fueled paranoia serve to fuel the flames of his eventual downfall.","genre_ids":[28,80,18],"popularity":16.9729,"vote_count":12757,"poster_path":"/iQ5ztdjvteGeboxtmRdXEChJOHh.jpg","release_date":"1983-12-09","vote_average":8.155,"backdrop_path":"/1qM2BYNE11Viby8ImC9LC00DgDr.jpg","original_title":"Scarface","original_language":"en"},{"id":120,"adult":false,"title":"The Lord of the Rings: The Fellowship of the Ring","video":false,"overview":"Young hobbit Frodo Baggins, after inheriting a mysterious ring from his uncle Bilbo, must leave his home in order to keep it from falling into the hands of its evil creator. Along the way, a fellowship is formed to protect the ringbearer and make sure that the ring arrives at its final destination: Mt. Doom, the only place where it can be destroyed.","genre_ids":[12,14,28],"popularity":26.4802,"vote_count":27061,"poster_path":"/6oom5QYQ2yQTMJIbnvbkBL9cHo6.jpg","release_date":"2001-12-18","vote_average":8.429,"backdrop_path":"/z51Wzj94hvAIsWfknifKTqKJRwp.jpg","original_title":"The Lord of the Rings: The Fellowship of the Ring","original_language":"en"},{"id":121,"adult":false,"title":"The Lord of the Rings: The Two Towers","video":false,"overview":"Frodo Baggins and the other members of the Fellowship continue on their sacred quest to destroy the One Ring--but on separate paths. Their destinies lie at two towers--Orthanc Tower in Isengard, where the corrupt wizard Saruman awaits, and Sauron's fortress at Barad-dur, deep within the dark lands of Mordor. Frodo and Sam are trekking to Mordor to destroy the One Ring of Power while Gimli, Legolas and Aragorn search for the orc-captured Merry and Pippin. All along, nefarious wizard Saruman awaits the Fellowship members at the Orthanc Tower in Isengard.","genre_ids":[12,14,28],"popularity":19.571,"vote_count":23478,"poster_path":"/5VTN0pR8gcqV3EPUHHfMGnJYN9L.jpg","release_date":"2002-12-18","vote_average":8.413,"backdrop_path":"/kWYfW2Re0rUDE6IHhy4CRuKWeFr.jpg","original_title":"The Lord of the Rings: The Two Towers","original_language":"en"},{"id":146,"adult":false,"title":"Crouching Tiger, Hidden Dragon","video":false,"overview":"Two warriors in pursuit of a stolen sword and a notorious fugitive are led to an impetuous, physically-skilled, teenage nobleman's daughter, who is at a crossroads in her life.","genre_ids":[12,18,28,10749],"popularity":7.0749,"vote_count":3483,"poster_path":"/iNDVBFNz4XyYzM9Lwip6atSTFqf.jpg","release_date":"2000-07-06","vote_average":7.434,"backdrop_path":"/nSm9cij9VRrGDoZoS16CPnX0FqK.jpg","original_title":"卧虎藏龍","original_language":"zh"},{"id":162,"adult":false,"title":"Edward Scissorhands","video":false,"overview":"A small suburban town receives a visit from a castaway unfinished science experiment named Edward.","genre_ids":[14,18,10749],"popularity":10.2523,"vote_count":13595,"poster_path":"/e0FqKFvGPdQNWG8tF9cZBtev9Em.jpg","release_date":"1990-12-07","vote_average":7.718,"backdrop_path":"/uNLIMPxknsV4n3IAEDpS1iqF5dm.jpg","original_title":"Edward Scissorhands","original_language":"en"},{"id":122,"adult":false,"title":"The Lord of the Rings: The Return of the King","video":false,"overview":"As armies mass for a final battle that will decide the fate of the world--and powerful, ancient forces of Light and Dark compete to determine the outcome--one member of the Fellowship of the Ring is revealed as the noble heir to the throne of the Kings of Men. Yet, the sole hope for triumph over evil lies with a brave hobbit, Frodo, who, accompanied by his loyal friend Sam and the hideous, wretched Gollum, ventures deep into the very dark heart of Mordor on his seemingly impossible quest to destroy the Ring of Power.​","genre_ids":[12,14,28],"popularity":23.8641,"vote_count":26078,"poster_path":"/rCzpDGLbOoPwLjy3OAm5NUPOTrC.jpg","release_date":"2003-12-17","vote_average":8.494,"backdrop_path":"/2u7zbn8EudG6kLlBzUYqP8RyFU4.jpg","original_title":"The Lord of the Rings: The Return of the King","original_language":"en"},{"id":154,"adult":false,"title":"Star Trek II: The Wrath of Khan","video":false,"overview":"The starship Enterprise and its crew is pulled back into action when old nemesis, Khan, steals a top secret device called Project Genesis.","genre_ids":[28,12,878,53],"popularity":2.9409,"vote_count":2077,"poster_path":"/uPyLsKl8Z0LOoxeaFXsY5MxhR5s.jpg","release_date":"1982-06-04","vote_average":7.445,"backdrop_path":"/meqmvZjKpQ7WRhpZvIoKIAvioSD.jpg","original_title":"Star Trek II: The Wrath of Khan","original_language":"en"}],"external_ids":{"imdb_id":"tt33996087","twitter_id":null,"facebook_id":null,"wikidata_id":"Q126008203","instagram_id":null},"social_ids":{"twitter":null,"