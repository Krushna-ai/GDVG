rage":0},{"width":1920,"height":1080,"file_path":"/edGNFMik98aRNKh0NWehjnbclC0.jpg","iso_639_1":"en","vote_average":0},{"width":1920,"height":1080,"file_path":"/wxFkeV5Grsafoekyv0bJk4HqY9m.jpg","iso_639_1":"te","vote_average":0},{"width":1920,"height":1080,"file_path":"/bnLoqGWYeowxTgAQ0h6LUipxnOA.jpg","iso_639_1":"ta","vote_average":0},{"width":1920,"height":1080,"file_path":"/fbr2eV5yDhudDOVy4wtUtHrGMLd.jpg","iso_639_1":"en","vote_average":0},{"width":3840,"height":2160,"file_path":"/xeKZGfSVAM0NSeYClL5hWDxuDzn.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T06:55:16.726+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Marco","runtime":145,"tagline":"","homepage":"","overview":"The adoptive son of the Adattu family, Marco, sets off on a ruthless quest for vengeance after his brother is brutally murdered, finding only betrayal, loss and unimaginable brutality at every step."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"","iso_639_1":"ki","iso_3166_1":"KI","english_name":"Kikuyu"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"","iso_639_1":"ml","iso_3166_1":"IN","english_name":"Malayalam"},{"data":{"title":"Марко","runtime":0,"tagline":"","homepage":"","overview":"Гангстер Марко и его могущественная семья Адат, которые заправляют золотым бизнесом в мафиозных кругах Кералы, сталкиваются с угрозой извне."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"逆途","runtime":135,"tagline":"","homepage":"","overview":"　　影片以主角 Marco 的视角展开，他曾误入歧途成为黑帮成员，但内心深处一直保留着善良的本质。故事中，Marco 所在的城市出现了一系列危害社会安全的恶性事件，警方在调查过程中发现这些事件与黑帮的非法活动有千丝万缕的联系。Marco 在经历了一些事情后，开始反思自己的生活和选择。当他发现黑帮的阴谋可能会给城市里无辜的人们带来巨大灾难时，他决定挺身而出。他利用自己对黑帮内部情况的了解，开始暗中协助警方收集证据。在这个过程中，Marco 遭遇了来自黑帮内部的怀疑和追杀，那些曾经的 “兄弟” 对他反目成仇，给他设下了重重陷阱。但 Marco 没有放弃，他与警方紧密合作，同时也在努力保护那些被黑帮威胁的普通市民。强调了正义和救赎的力量。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Marco","runtime":0,"tagline":"","homepage":"","overview":"El hijo adoptivo de la familia Adattu, Marco, se embarca en una despiadada búsqueda de venganza después de que su hermano es brutalmente asesinado, encontrando solo traición, pérdida y una brutalidad inimaginable a cada paso."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"มาร์โก หมาบ้า พันธุ์ระห่ำ","runtime":0,"tagline":"","homepage":"","overview":"ลูกชายบุญธรรมของตระกูลอาดัตตู “มาร์โก” ออกเดินทางเพื่อล้างแค้นอย่างไร้ปรานี หลังพี่ชายของเขาถูกสังหารอย่างโหดเหี้ยม โดยมีเพียงการทรยศ ความสูญเสีย และความโหดร้ายเกินจินตนาการรออยู่ในทุกย่างก้าว"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"마르코","runtime":145,"tagline":"","homepage":"","overview":"케랄라의 유서 깊은 '아다투' 가문 출신이자 시각장애인인 '빅터'는 친구 '와심'이 살해당하는 현장을 목격한다. 범인은 금 밀수 조직 '아이작' 가문의 '러셀'. 그는 비밀을 감추기 위해 결국 빅터까지 살해한다. 빅터의 형이자 가문의 가장인 '조지'는 진실을 파헤치려 하고 해외에 머물던 양자 '마르코'는 동생의 죽음에 복수를 결심한다. 조지의 만류도 소용없다. 마르코는 빅터의 죽음에 연루된 이들을 향해 피의 심판을 맹세한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Marco","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Marco: Justiça Implacável","runtime":0,"tagline":"","homepage":"","overview":"Em Kerala, a influente família Adattu domina o comércio de ouro. Quando Victor, o irmão cego de Marco, é cruelmente assassinado, Marco retorna da Itália determinado a vingar sua morte. Ignorando os apelos de seu irmão George, para evitar a violência, Marco embarca em uma implacável caçada aos culpados, enfrentando traições e desafios brutais."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Marco","runtime":145,"tagline":"","homepage":"","overview":"En Kerala, la familia Adat reina en el comercio del oro y otros negocios influyentes. Con George Peter como respetado patriarca y Marco como temible hijo adoptivo, su imperio se basa en el poder y la lealtad, pero su mundo está plagado de peligros y conflictos."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Марко","runtime":0,"tagline":"","homepage":"","overview":"Марко — прийомний син кримінальної родини Аддат. Для нього немає нікого важливішого, ніж його сім’я. Коли знаходять тіло його сліпого брата, Марко готовий піти війною проти всіх, аби тільки знайти винних і покарати їх."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Marco","runtime":142,"tagline":"","homepage":"","overview":"Marco, der Adoptivsohn der Familie Adattu, begibt sich nach der brutalen Ermordung seines Bruders auf einen rücksichtslosen Rachefeldzug und findet dabei auf Schritt und Tritt nur Verrat, Verlust und unvorstellbare Brutalität."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Marco","runtime":0,"tagline":"","homepage":"","overview":"De geadopteerde zoon van de Adattu-familie, Marco, begint aan een meedogenloze zoektocht naar wraak nadat zijn broer op brute wijze is vermoord, waarbij hij op elke stap alleen verraad, verlies en onvoorstelbare wreedheid tegenkomt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"黃金之血：復仇馬可","runtime":0,"tagline":"","homepage":"","overview":"在印度喀拉拉邦，勢力龐大的阿達特家族壟斷黃金買賣，長兄喬治備受敬重，但真正令眾人畏懼的，卻是養子馬可。外表冷酷的他，將家人視為生命的重心，特別是失明的弟弟維克多與女友瑪莉亞。當維克多慘遭殺害後，馬可與喬治立誓復仇。在暴力與陰謀的漩渦中，馬可與瑪莉亞的感情也受到極大考驗。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Marco","runtime":0,"tagline":"","homepage":"","overview":"Marco, adoptivní syn rodiny Adattu, se po brutální vraždě svého bratra vydává na nemilosrdnou cestu za pomstou, na které ho na každém kroku čeká jen zrada, ztráta a nepředstavitelná brutalita."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"黃金之血：復仇馬可","runtime":0,"tagline":"","homepage":"","overview":"在印度喀拉拉邦，勢力龐大的阿達特家族壟斷黃金買賣，長兄喬治備受敬重，但真正令眾人畏懼的，卻是養子馬可。外表冷酷的他，將家人視為生命的重心，特別是失明的弟弟維克多與女友瑪莉亞。當維克多慘遭殺害後，馬可與喬治立誓復仇。在暴力與陰謀的漩渦中，馬可與瑪莉亞的感情也受到極大考驗。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Người Hùng Marco","runtime":0,"tagline":"","homepage":"","overview":"Tên gangster Marco và gia đình Adat quyền lực, những kẻ thống trị mafia vàng ở Kerala."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"}],"reviews_tmdb":[{"id":"678ce6ef35902b0f936e02b3","url":"https://www.themoviedb.org/review/678ce6ef35902b0f936e02b3","author":"priyaranjanpr11","content":"Good movie. Cast have done good job.","created_at":"2025-01-19T11:50:07.395Z","updated_at":"2025-10-08T22:47:21.880Z","author_details":{"name":"","rating":10,"username":"priyaranjanpr11","avatar_path":null}}],"recommendations":[{"id":1201262,"adult":false,"title":"Grafted","video":false,"overview":"When an awkward but brilliant Chinese student wins a scholarship into a prestigious New Zealand University, she finds a new way of achieving the popularity she craves one bloody body at a time.","genre_ids":[27],"media_type":"movie","popularity":4.5869,"vote_count":60,"poster_path":"/u53wFzLoJD7om52Hjma8G27LS2h.jpg","release_date":"2024-09-12","vote_average":5.7,"backdrop_path":"/sSrU5zYRqraYqNl2xsQOonNQbhh.jpg","original_title":"Grafted","original_language":"en"},{"id":1267319,"adult":false,"title":"Mantis","video":false,"overview":"The secret society of contract killers falls into chaos, unleashing a new breed of assassins. With old rules in ruins, who dares claim the shadows?","genre_ids":[28,80,53],"media_type":"movie","popularity":9.659,"vote_count":142,"poster_path":"/pzsXKLJsZ26HUV1oCMa7WiFFQbW.jpg","release_date":"2025-09-25","vote_average":6.232,"backdrop_path":"/yOFqBpJ0PEkBdQqalDEaeOiaKbz.jpg","original_title":"사마귀","original_language":"ko"},{"id":84092,"adult":false,"title":"Ramayana: The Legend of Prince Rama","video":false,"overview":"In Ayodhya, the royal palace of Kosala Kingdom in Ancient India, four princes were born to three queens, each of whom grew to great stature. Banished for 14 years due to court intrigue, Prince Rama retreated to the forest with his beautiful wife Sita. When Rama vanquishes the demons of the forest, he invites the wrath of the demon king Ravana, who kidnaps Sita. Based on the Indian epic the Ramayana.","genre_ids":[16,28,12,14],"media_type":"movie","popularity":0.8124,"vote_count":50,"poster_path":"/l4MNBj7Zn2iVNfwBdm80Am0Ll7w.jpg","release_date":"1993-01-10","vote_average":8.17,"backdrop_path":"/j4zVW7xqw3OdhjcqEyKgtDpiKJf.jpg","original_title":"Ramayana : The Legend of Prince Rama","original_language":"en"},{"id":1379877,"adult":false,"title":"Azaad","video":false,"overview":"In 1920s India, a young stable boy bonds with a spirited horse. Amid rebellion and tyranny, his quest to ride the majestic animal becomes a journey of courage, awakening him to the country's fight for freedom.","genre_ids":[18,28],"media_type":"movie","popularity":0.7188,"vote_count":11,"poster_path":"/yWFpiJcUJfXRbm3om48kNJ0MU7A.jpg","release_date":"2025-01-17","vote_average":6.7,"backdrop_path":"/zUCDf87awNIwV5N4NQdA807dGTP.jpg","original_title":"आज़ाद","original_language":"hi"},{"id":714338,"adult":false,"title":"Bulbbul","video":false,"overview":"A child bride grows up to be an enigmatic woman presiding over her household, harboring a painful past as supernatural murders of men plague her village.","genre_ids":[27,14,53],"media_type":"movie","popularity":1.1287,"vote_count":166,"poster_path":"/4XYEqHqvcf6vxFhNyeKZz5xbUfV.jpg","release_date":"2020-06-24","vote_average":6.5