5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"My Brother's Wife 3: The Woman Downstairs\",\"description\":\"My sister and I moved into a new house. We didn't do much but the woman downstairs came up to ask us to keep it down.  She said she was sensitive so we decided to keep it down.  Her gangster husband would beat her when he came home drunk.  Every time I heard her suffer from the beatings, I couldn't stand it and would stomp the floor to create a distraction.  She would come up telling us to be quiet.  I told her I did it intentionally. I also decided to do something about the woman who showed interest in me by memorizing my number.\",\"image\":\"https://image.tmdb.org/t/p/w500/dv6CvHgGTFH6bOwI0hPBMRbk417.jpg\",\"datePublished\":\"2017-01-14\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"Drama\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.8,\"bestRating\":10,\"ratingCount\":4}}"}}],["$","$L10",null,{"initialDrama":{"id":"2ac64f03-ca8f-4c3d-a280-c25ee79a8cbb","tmdb_id":453133,"imdb_id":null,"content_type":"movie","title":"My Brother's Wife 3: The Woman Downstairs","original_title":"형님아내3 (아랫집 부인)","overview":"My sister and I moved into a new house. We didn't do much but the woman downstairs came up to ask us to keep it down.  She said she was sensitive so we decided to keep it down.  Her gangster husband would beat her when he came home drunk.  Every time I heard her suffer from the beatings, I couldn't stand it and would stomp the floor to create a distraction.  She would come up telling us to be quiet.  I told her I did it intentionally. I also decided to do something about the woman who showed interest in me by memorizing my number.","poster_path":"/dv6CvHgGTFH6bOwI0hPBMRbk417.jpg","backdrop_path":"/2rW2u3nuObirCeejJYnUCItAv0E.jpg","release_date":"2017-01-14","first_air_date":null,"s