7DJ4e9XYymzZovT.jpg","iso_639_1":null,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/ceaS9zOX4GJPzZeUgsnjRy9JKck.jpg","iso_639_1":null,"vote_average":1.75},{"width":1735,"height":976,"file_path":"/5vGZFePsgr0IWGodL0z20PM0RDP.jpg","iso_639_1":"en","vote_average":1.75},{"width":1920,"height":1080,"file_path":"/iXlM95dPPsm9lPBcoQnxa78TqZF.jpg","iso_639_1":"de","vote_average":0},{"width":1920,"height":1080,"file_path":"/ehEQ2K3E6gSBt3zHjtJhAkABn44.jpg","iso_639_1":"de","vote_average":0},{"width":3840,"height":2160,"file_path":"/4qFgzt3njMA0EuBk5cx2gg2V8M7.jpg","iso_639_1":"pt","vote_average":0},{"width":3840,"height":2160,"file_path":"/rAAe5polKi8h5guoMymE6ixXgK6.jpg","iso_639_1":"cs","vote_average":0},{"width":3840,"height":2160,"file_path":"/heIJqoJCUHHjvuXD12xyL6GeOUZ.jpg","iso_639_1":"es","vote_average":0},{"width":3840,"height":2160,"file_path":"/sXu9kmgLBoMD6W7dLtN4WWhWLW5.jpg","iso_639_1":"no","vote_average":0},{"width":3840,"height":2160,"file_path":"/uQjCNUuPryK6zL7JjDsxNpzH1nr.jpg","iso_639_1":"pl","vote_average":0},{"width":3840,"height":2160,"file_path":"/1dQTkLamavEpbUVrggYey6i6lAd.jpg","iso_639_1":"fr","vote_average":0},{"width":3840,"height":2160,"file_path":"/ir6wAGysaXNAmHV5B7BupK93Wrg.jpg","iso_639_1":"sv","vote_average":0}]},"enriched_at":"2026-02-21T10:21:48.063+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Война миров","runtime":0,"tagline":"«Ваши данные смертельно опасны»","homepage":"","overview":"Скринлайф-экранизация романа «Война миров» Герберта Уэллса. Землю атакуют агрессивные пришельцы, использующие гигантских роботов с щупальцами. Людям предстоит бороться за выживание и попытаться дать отпор захватчикам. Фильм затронет темы слежки и конфиденциальности."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":91,"tagline":"Your data is deadly.","homepage":"https://www.amazon.com/gp/video/detail/B0DMF7MXKT","overview":"Will Radford is a top analyst for Homeland Security who tracks potential threats through a mass surveillance program, until one day an attack by an unknown entity leads him to question whether the government is hiding something from him... and from the rest of the world."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"O invazie uriașă se apropie, într-o reinterpretare proaspătă a legendarului roman cu același nume. Renumita actriță Eva Longoria este însoțită de celebrul rapper și actor Ice Cube, alături de Michael O’Neill și Iman Benson, într-o aventură palpitantă, desprinsă parcă din altă lume, care abordează în preponderență teme actuale precum tehnologia, supravegherea și intimitatea."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"A Guerra dos Mundos","runtime":90,"tagline":"","homepage":"https://www.primevideo.com/detail/0IB8U8AXJCFJ4WDD830GESW8A5","overview":"Will Radford é um renomado analista de cibersegurança do Departamento de Segurança Interna dos Estados Unidos, encarregado de rastrear possíveis ameaças à segurança nacional por meio de um programa de vigilância em massa. No entanto, um ataque inesperado por uma entidade desconhecida o leva a suspeitar que o governo esteja escondendo algo dele… e do restante do mundo."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"우주전쟁","runtime":145,"tagline":"","homepage":"","overview":"전설적인 동명 소설을 새롭게 재해석한 이번 작품은 거대한 침공의 서막을 알린다. 에바 롱고리아와 전설적인 래퍼이자 배우 아이스 큐브, 그리고 마이클 오닐과 이만 벤슨이 합류해, 기술과 감시, 사생활이라는 현대적 주제를 아우르는 짜릿한 우주급 모험을 선보인다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Wojna światów","runtime":145,"tagline":"","homepage":"","overview":"Will Radford jest czołowym analitykiem ds. cyberbezpieczeństwa w Homeland Security, który śledzi potencjalne zagrożenia dla bezpieczeństwa narodowego za pomocą programu masowej inwigilacji. Aż pewnego dnia atak nieznanej jednostki sprawia, że zaczyna się zastanawiać, czy rząd czegoś przed nim nie ukrywa... i przed resztą świata."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"La Guerre des mondes","runtime":91,"tagline":"Vos données sont mortelles.","homepage":"","overview":"Une invasion gargantuesque approche dans cette nouvelle interprétation du légendaire roman homonyme devenu un classique de la science-fiction. La célèbre Eva Longoria partage l'affiche avec le rappeur/acteur Ice Cube, Michael O'Neill et Iman Benson, dans une aventure extraordinaire abordant des thématiques actuelles telles que la technologie, la surveillance et la protection de la vie privée."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"מלחמת העולמות","runtime":0,"tagline":"","homepage":"","overview":"פלישה ענקית מגיעה עם הגרסה החדשה הזאת של הרומן המפורסם בעל אותו השם. השחקנית הנודעת אווה לונגוריה משתפת פעולה עם הראפר והשחקן האייקוני אייס קיוב, וביחד עם מייקל אוניל ואימאן בנסון יוצאים להרפתקה מותחת שלא מהעולם הזה, מלאה בנושאים עכשוויים של טכנולוגיה, מעקב ופרטיות."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"世界大戰","runtime":145,"tagline":"","homepage":"","overview":"一場龐大的入侵即將來臨，伴隨而來的是對同名傳奇小說的全新演繹。著名女演員伊娃・朗格莉亞聯同傳奇饒舌歌手兼演員冰塊酷巴，以及米高・奧尼爾與伊曼・賓森，展開一場驚心動魄、超越現實的歷險旅程，當中充滿與現代息息相關的科技、監控與私隱議題。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"La guerra de los mundos","runtime":90,"tagline":"","homepage":"","overview":"Will Radford, un destacado analista de ciberseguridad, pasa sus días rastreando posibles amenazas a la seguridad nacional a través de un programa de vigilancia masiva. Un ataque de una entidad desconocida le lleva a cuestionarse si el gobierno le está ocultando algo a él... y al resto del mundo."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Klodernes kamp","runtime":90,"tagline":"","homepage":"","overview":"Will Radford er en ledende cybersikkerhedsanalytiker for Homeland Security, der sporer potentielle trusler mod den nationale sikkerhed gennem et masseovervågningsprogram, indtil et angreb fra en ukendt enhed en dag får ham til at stille spørgsmålstegn ved, om regeringen skjuler noget for ham ... og for resten af verden."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Krieg der Welten","runtime":0,"tagline":"Eure Daten sind tödlich.","homepage":"","overview":"Will Radford ist ein Top-Cybersicherheitsanalytiker des Heimatschutzes, der potenzielle Bedrohungen für die nationale Sicherheit durch ein Massenüberwachungsprogramm aufspürt, bis ihn eines Tages ein Angriff eines unbekannten Wesens dazu bringt, sich zu fragen, ob die Regierung etwas vor ihm verbirgt … und vor dem Rest der Welt."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"La guerra dei mondi","runtime":0,"tagline":"","homepage":"","overview":"L'agente del Dipartimento della Sicurezza Interna degli Stati Uniti d'America (DHS) Will Radford lavora per un programma di sorveglianza governativo in grado di monitorare ogni persona sulla Terra. Il suo rapporto con la figlia incinta Faith e il figlio Dave è teso a causa del suo uso del programma per monitorarli costantemente. Mentre Will aiuta l'FBI a cercare un misterioso hacker noto come \"Disruptor\", tutto il pianeta viene colpito da uno sciame di meteoriti e Will e la sua amica Sandra, che lavora alla NASA, concludono che si tratta di un'invasione aliena. Will aiuta Dave e Faith a sfuggire all'invasione prima di essere convocato ad un incontro con il direttore del DHS Donald Briggs, il segretario alla difesa Walter Crystal e il presidente degli Stati Uniti. Quest'ultimo da il via ad un contrattacco militare, seguito da quello di altri paesi.\r (Wikipedia; testo disponibile secondo la licenza Creative Commons Attribuzione-Condividi allo stesso modo)"},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Világok harca","runtime":0,"tagline":"","homepage":"","overview":"Egy földhözragadt sci-fi film a District 9 szellemében, amely a magánélet kontra megfigyelés témáit feszegeti."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Maailmojen sota","runtime":0,"tagline":"","homepage":"","overview":"Will Radford on Homeland Security-viraston huipputason kyberturvallisuusanalyytikko, joka seuraa potentiaalisia uhkia massavalvontaohjelman avulla. Eräänä päivänä tuntemattoman tahon hyökkäys saa hänet epäilemään, että hallitus salaa jotain häneltä... ja muulta maailmalta."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"De oorlog der werelden","runtime":0,"tagline":"","homepage":"","overview":"Will Radford is een top analist op het gebied van cyberveiligheid bij Homeland Security. Hij houdt via een grootschalig surveillanceprogramma potentiële bedreigingen voor de nationale veiligheid in de gaten. Totdat hij op een dag door een aanval van een onbekende entiteit begint te twijfelen of de overheid iets voor hem... en de rest van de wereld, verborgen houdt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"La guerra de los mundos","runtime":91,"tagline":"","homepage":"","overview":"Will Radford, un destacado analista de ciberseguridad, pasa sus días rastreando posibles amenazas a la seguridad nacional a través de un programa de vigilancia masiva. Un ataque de una entidad desconocida le lleva a cuestionarse si el gobierno le está ocultando algo a él... y al resto del mundo."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"ウォー・オブ・ザ・ワールド","runtime":145,"tagline":"","homepage":"","overview":"ウィル・ラドフォードは、国土安全保障省のトップサイバーセキュリティアナリストです。大規模監視プログラムを通じて国家安全保障への潜在的な脅威を追跡しています。ある日、正体不明の組織による攻撃をきっかけに、政府が彼自身、そして世界から何かを隠しているのではないかと疑念を抱くようになります。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"वॉर ऑफ़ द वर्ल्ड्स","runtime":145,"tagline":"","homepage":"","overview":"विल रैडफोर्ड होमलैंड सिक्योरिटी के एक शीर्ष साइबर-सुरक्षा विश्लेषक हैं, जो एक व्यापक निगरानी कार्यक्रम के माध्यम से राष्ट्रीय सुरक्षा के लिए संभावित खतरों पर नज़र रखते हैं। एक दिन एक अज्ञात संस्था द्वारा किए गए हमले के बाद, उनके मन में यह सवाल उठता है कि क्या सरकार उनसे और बाकी दुनिया से कुछ छिपा रही है।"},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"","runtime":145,"tagline":"","homepage":"","overview":"Will Radford adalah seorang analis keamanan siber terkemuka untuk Departemen Keamanan Dalam Negeri yang melacak potensi ancaman terhadap keamanan nasional melalui program pengawasan massal, hingga suatu hari sebuah serangan oleh entitas tak dikenal membuatnya mempertanyakan apakah pemerintah menyembunyikan sesuatu darinya... dan dari seluruh dunia."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"ವಿಶ್ವ ಯುದ್ಧ","runtime":145,"tagline":"","homepage":"","overview":"ವಿಲ್ ರಾಡ್‌ಫೋರ್ಡ್ ಹೋಮ್‌ಲ್ಯಾಂಡ್ ಸೆಕ್ಯುರಿಟಿಯ ಉನ್ನತ ಸೈಬರ್-ಭದ್ರತಾ ವಿಶ್ಲೇಷಕರಾಗಿದ್ದು, ಅವರು ಸಾಮೂಹಿಕ ಕಣ್ಗಾವಲು ಕಾರ್ಯಕ್ರಮದ ಮೂಲಕ ರಾಷ್ಟ್ರೀಯ ಭದ್ರತೆಗೆ ಸಂಭಾವ್ಯ ಬೆದರಿಕೆಗಳನ್ನು ಪತ್ತೆಹಚ್ಚುತ್ತಾರೆ, ಒಂದು ದಿನ ಅಪರಿಚಿತ ಘಟಕದ ದಾಳಿಯು ಸರ್ಕಾರವು ಅವನಿಂದ ಮತ್ತು ಪ್ರಪಂಚದ ಉಳಿದ ಭಾಗಗಳಿಂದ ಏನನ್ನಾದರೂ ಮರೆಮಾಡುತ್ತಿದೆಯೇ ಎಂದು ಪ್ರಶ್ನಿಸುವಂತೆ ಮಾಡುತ್ತದೆ."},"name":"?????","iso_639_1":"kn","iso_3166_1":"IN","english_name":"Kannada"},{"data":{"title":"ലോകയുദ്ധം","runtime":145,"tagline":"","homepage":"","overview":"ഹോംലാൻഡ് സെക്യൂരിറ്റിയിലെ ഒരു മികച്ച സൈബർ സുരക്ഷാ വിശകലന വിദഗ്ദ്ധനാണ് വിൽ റാഡ്ഫോർഡ്. ഒരു കൂട്ട നിരീക്ഷണ പരിപാടിയിലൂടെ ദേശീയ സുരക്ഷയ്ക്ക് ഉണ്ടാകാവുന്ന ഭീഷണികൾ അദ്ദേഹം ട്രാക്ക് ചെയ്യുന്നു. ഒരു ദിവസം ഒരു അജ്ഞാത സ്ഥാപനത്തിന്റെ ആക്രമണം സർക്കാർ തന്നിൽ നിന്നും ലോകത്തിന്റെ മറ്റു ഭാഗങ്ങളിൽ നിന്നും എന്തെങ്കിലും മറച്ചുവെക്കുന്നുണ്ടോ എന്ന് അദ്ദേഹം ചോദ്യം ചെയ്യുന്നു."},"name":"","iso_639_1":"ml","iso_3166_1":"IN","english_name":"Malayalam"},{"data":{"title":"வார் ஆஃப் தி வேர்ல்ட்ஸ்","runtime":145,"tagline":"","homepage":"","overview":"வில் ராட்ஃபோர்ட், உள்நாட்டுப் பாதுகாப்புக்கான ஒரு சிறந்த சைபர்-பாதுகாப்பு ஆய்வாளர் ஆவார், அவர் ஒரு பெரிய கண்காணிப்புத் திட்டத்தின் மூலம் தேசியப் பாதுகாப்புக்கு ஏற்படக்கூடிய அச்சுறுத்தல்களைக் கண்காணிக்கிறார், ஒரு நாள் தெரியாத ஒரு நிறுவனத்தின் தாக்குதல், அரசாங்கம் அவரிடமிருந்தும் உலகின் பிற பகுதிகளிலிருந்தும் எதையாவது மறைக்கிறதா என்று அவரைக் கேள்வி கேட்க வைக்கும் வரை."},"name":"தமிழ்","iso_639_1":"ta","iso_3166_1":"IN","english_name":"Tamil"},{"data":{"title":"สงครามโลก","runtime":145,"tagline":"","homepage":"","overview":"วิลล์ แรดฟอร์ด เป็นนักวิเคราะห์ความปลอดภัยทางไซเบอร์ชั้นนำของกระทรวงความมั่นคงแห่งมาตุภูมิ ผู้ติดตามภัยคุกคามที่อาจเกิดขึ้นต่อความมั่นคงแห่งชาติผ่านโครงการเฝ้าระวังมวลชน จนกระทั่งวันหนึ่ง การโจมตีจากบุคคลที่ไม่รู้จัก ทำให้เขาตั้งคำถามว่ารัฐบาลกำลังปิดบังอะไรบางอย่างจากเขา... และจากส่วนอื่นๆ ของโลกหรือไม่"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"世界大战","runtime":145,"tagline":"","homepage":"","overview":"威尔·拉德福德是国土安全部的顶级网络安全分析师，他通过大规模监控项目追踪国家安全的潜在威胁。直到有一天，一个不明实体的攻击让他开始怀疑政府是否对他……以及世界其他地方隐瞒了什么。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"世界大战","runtime":0,"tagline":"","homepage":"","overview":"改编自同名传奇小说，一场浩劫级入侵大战即将上演。著名女演员伊娃·朗格利亚携手传奇说唱歌手兼演员艾斯·库伯、迈克尔·奥尼尔以及伊曼·本森联袂出演，共同演绎惊险的异世大战。科技、监控和隐私等当今社会主题内容贯穿全片。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"Válka světů","runtime":0,"tagline":"Vaše data jsou smrtící.","homepage":"","overview":"S tímto novým pojetím legendárního románu stejného jména přichází gigantická invaze. Známá herečka Eva Longoria se připojuje k ikonickému rapperovi a herci Ice Cubeovi, Michaelu O'Neillovi a Iman Benson v napínavém, nadpozemském dobrodružství plném současných témat, jako jsou technologie, sledování a soukromí."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Ο πόλεμος των κόσμων","runtime":0,"tagline":"","homepage":"","overview":"Ετοιμαστείτε για μια τεράστια εισβολή, σε μια νέα προσέγγιση του ομώνυμου θρυλικού μυθιστορήματος. Η διάσημη ηθοποιός Εύα Λονγκόρια συναντά τον εμβληματικό ράπερ και ηθοποιό Άις Κιουμπ, μαζί με τους Μάικλ Ο’Νιλ και Ιμάν Μπένσον, σε μια απίστευτη και καθηλωτική περιπέτεια που πραγματεύεται σύγχρονα θέματα τεχνολογίας, παρακολούθησης και ιδιωτικότητας."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Klodenes kamp","runtime":0,"tagline":"","homepage":"","overview":"En gigantisk invasjon er på vei i denne friske versjonen av den legendariske romanen med samme navn. Den kjente skuespillerinnen Eva Longoria får selskap av den ikoniske rapperen og skuespilleren Ice Cube, sammen med Michael O’Neill og Iman Benson, i et spennende eventyr fullt av aktuelle temaer som teknologi, overvåking og personvern."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Satu penaklukan besar bakal terjadi berdasarkan novel legenda ini yang diberi nafas baru, kisah dengan tajuk yang sama. Pelakun terkenal Eva Longoria disertai bersama oleh Ice Cube penyanyi rap dan pelakun, bersama dengan Micheal O'Neil dan Iman Benson, saksikan satu kisah yang amat menarik dipenuhi dengan tema teknologi masa kini, tinjaun dan privasi."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"Dünyalar Savaşı","runtime":0,"tagline":"","homepage":"","overview":"Bilim kurgu türünde dönüm noktası sayılan aynı isimli kitabın bu yepyeni yorumunda devasa bir istila gerçekleşmek üzere. Günümüz teknoloji, gözetim ve mahremiyet temalarının işlendiğ heyecan verici bu dünya dışı macera için ünlü aktris Eva Longoria, ikonik rapçi ve aktor Ice Cube, Michael O’Neill ve Iman Benson bir araya geliyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Will Radford é um analista de segurança cibernética de topo da Homeland Security que detecta potenciais ameaças à segurança nacional através de um programa de vigilância em massa, até que um dia um ataque de uma entidade desconhecida o leva a questionar se o governo está a esconder algo dele... e do resto do mundo."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Cuộc Chiến Giữa Các Thế Giới","runtime":0,"tagline":"","homepage":"","overview":"Will Radford — chuyên gia phân tích an ninh mạng hàng đầu của Bộ An ninh Nội địa — chuyên theo dõi các mối đe dọa đến an ninh quốc gia thông qua một chương trình giám sát diện rộng. Nhưng một cuộc tấn công bất ngờ từ một thực thể bí ẩn đã khiến anh bắt đầu nghi ngờ: phải chăng chính phủ đang che giấu điều gì đó… không chỉ với anh mà với toàn thế giới?"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"حرب العوالم","runtime":90,"tagline":"","homepage":"https://www.primevideo.com/detail/War-of-the-Worlds/0IB8U8AXJCFJ4WDD830GESW8A5","overview":"تدور أحداث فيلم \"حرب العوالم \" 2025 في عالم يتعرض لغزو فضائي، لكن الهجوم لا يكون بالطريقة التقليدية. تعتمد الكائنات الفضائية على سرقة المعلومات الشخصية للبشر واستغلالها عبر البيانات. يكتشف شخصية تدعى \"رادفورد\" مؤامرة كبيرة تهدد الأمن القومي، ويدرك أن المعركة هذه المرة ليست بالأسلحة فقط، بل من خلال الفضاء الرقمي."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"სამყაროთა ომი","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Війна світів","runtime":0,"tagline":"","homepage":"","overview":"Вілл Редфорд — провідний аналітик з кібербезпеки в компанії Хомленд Сек’юріті, завдання якого відстежувати потенційні загрози національній безпеці за допомогою програми масового стеження. Але одного разу атака невідомої організації змушує його замислитися, чи не приховує уряд щось від нього та від усього світу."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"La guerre des mondes","runtime":91,"tagline":"Vos données sont mortelles.","homepage":"","overview":"Une invasion gargantuesque se prépare dans cette nouvelle adaptation du roman légendaire qui porte le même titre."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Война на световете","runtime":0,"tagline":"","homepage":"","overview":"Уил Радфорд е топ анализатор в Министерството на вътрешната сигурност, който следи потенциални заплахи чрез програма за масово наблюдение. Но един ден нападение от неизвестен извършител го кара да се замисли дали правителството не крие нещо от него... и от целия свят."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Rat svjetova","runtime":0,"tagline":"Vaši podaci su smrtonosni.","homepage":"","overview":"Moderna adaptacija klasičnog romana H.G. Wellsa prati Willa Radforda, vrhunskog analitičara cyber sigurnosti za Domovinsku sigurnost, koji provodi dane prateći potencijalne prijetnje nacionalnoj sigurnosti kroz program masovnog nadzora, sve dok ga napad nepoznatog entiteta ne navede da se zapita da li vlada nešta skriva od njega i ostatka svijeta."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Världarnas krig","runtime":0,"tagline":"","homepage":"","overview":"En enorm invasion äger rum i den här nya tolkningen av den legendariska romanen med samma namn. Den kända skådespelerskan Eva Longoria får sällskap av den ikoniska rapparen och skådespelaren Ice Cube tillsammans med Michael O’Neill och Iman Benson för ett spännande äventyr som inte är av denna värld och som är fylld av samtida teman, som teknologi, övervakning och integritet."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"حرب العوالم","runtime":0,"tagline":"","homepage":"","overview":"يلوّح في الأفق غزو هائل في طرحٍ جديد لرواية أسطورية تحمل الاسم ذاته. يضم هذا العمل نخبة من النجوم، على رأسهم الممثلة الشهيرة إيفا لونغوريا، إلى جانب مغني الراب والممثل الأسطوري آيس كيوب، ومايكل أونيل، وإيمان بنسون، في مغامرة مشوقة تتجاوز حدود الخيال، وتغوص في قضايا معاصرة مثل التكنولوجيا والمراقبة والخصوصية."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[{"id":"688b04a2e6ed8e883ab5b289","url":"https://www.themoviedb.org/review/688b04a2e6ed8e883ab5b289","author":"MovieGuys","content":"Its amazing what you accomplish with a creative script, even on a limited budget. \r\n\r\n\"War of the Worlds\" isn't going to win any awards but  its nonetheless still quite entertaining. \r\n\r\nThe notion of the whole alien invasion playing out from the control room of a US NSA surveillance agent, is novel, as is the manner in which everything is nicely brought together. The acting  is decent too, so no complaints there, either. \r\n\r\nPerhaps the only limited downside is the special effects, which are only passable. That said, they still function well enough, to make the whole thing enjoyable. \r\n\r\nIn summary, a simple but watchable sci fi experience. A nice distraction for a wet weekend.","created_at":"2025-07-31T05:52:34.202Z","updated_at":"2025-07-31T05:56:21.691Z","author_details":{"name":"","rating":6,"username":"MovieGuys","avatar_path":null}},{"id":"6896e7c097e8b74ed492e923","url":"https://www.themoviedb.org/review/6896e7c097e8b74ed492e923","author":"Microcosmic","content":"Trash. Uber trash. Worst use of an IP to date.","created_at":"2025-08-09T06:16:32.146Z","updated_at":"2025-08-15T22:46:38.350Z","author_details":{"name":"Microcosmic","rating":2,"username":"Microcosmic","avatar_path":null}},{"id":"689e4f5d017d0bc9ecc70ac1","url":"https://www.themoviedb.org/review/689e4f5d017d0bc9ecc70ac1","author":"oynx","content":"amazing relative idea to this era , liked the movie","created_at":"2025-08-14T21:04:29.778Z","updated_at":"2025-08-29T22:12:24.044Z","author_details":{"name":"","rating":null,"username":"oynx","avatar_path":null}},{"id":"68a1cbcf459b98444f61c0da","url":"https://www.themoviedb.org/review/68a1cbcf459b98444f61c0da","author":"r96sk","content":"$11","created_at":"2025-08-17T12:32:15.871Z","updated_at":"2025-08-17T12:32:15.968Z","author_details":{"name":"","rating":2,"username":"r96sk","avatar_path":"/mwR7rFHoDcobAx1i61I3skzMW3U.jpg"}},{"id":"68a6310b410b9983f0d5504b","url":"https://www.themoviedb.org/review/68a6310b410b9983f0d5504b","author":"Chandler Danier","content":"I once watched Jake Gyllenhalle talk on the phone for 1.5 hours and I hated it. I watch Ice Cube squint at a screen and chat with friends and family for 1.5 hours and I love it.\r\n\r\nData! They're coming for data. They're going to eat all our data! Why not just copy the data? Why not just set up a separate server farm where they just make an infinite RickRoll for the aliens. There is technically unlimited data if you copy that data forever and if the aliens eat the data, does that mean there's space for more data on that hdd? If you could write the read spead of the aliens, you could just give them unlimited data off of some small device. That could keep them eating for a while and while they're distracted, you set up a nuclear bomb inside them that is on a timer and they could prevent it from going nuclear but doing so will cause them to sacrifice themselves for the greater good.\r\n\r\nAnyway. I like how this movie is shot. It is ridiculous and stupid. I happen to find it charming.","created_at":"2025-08-20T20:33:15.485Z","updated_at":"2025-08-20T20:33:15.548Z","author_details":{"name":"Chandler Danier","rating":7,"username":"chandlerdanier","avatar_path":null}},{"id":"68e11ef4c7094f6d9336dccb","url":"https://www.themoviedb.org/review/68e11ef4c7094f6d9336dccb","author":"kevin2019","content":"$12","created_at":"2025-10-04T13:19:48.447Z","updated_at":"2025-10-25T22:59:34.518Z","author_details":{"name":"","rating":null,"username":"kevin2019","avatar_path":null}},{"id":"68f1cc6d91c2020a290e476b","url":"https://www.themoviedb.org/review/68f1cc6d91c2020a290e476b","author":"misubisu","content":"Reports allege that the movie uses clips from real disasters and Middle East conflict zones (bombings, wildfires, military crashes) blended or overlaid with alien‑invasion CGI.\r\n\r\nThis is seriously fuc%ed up!\r\nWhat some humans will do to make money from the suffering of others.","created_at":"2025-10-17T04:56:13.976Z","updated_at":"2025-10-17T04:56:14.047Z","author_details":{"name":"misubisu","rating":1,"username":"misubisu","avatar_path":"/gYANFSSdtvtcGZqi2J2xzxRmQBx.jpg"}},{"id":"696fbfcf4c8a1c2652df0f82","url":"https://www.themoviedb.org/review/696fbfcf4c8a1c2652df0f82","author":"kurtsanorskie","content":"damn damn damn damn damn damndamn damn damndamn damn damndamn damn damndamn damn damndamn damn damndamn damn damndamn damn damndamn damn damndamn damn damndamn damn damndamn damn damndamn damn damn","created_at":"2026-01-20T17:47:59.416Z","updated_at":"2026-01-21T17:29:57.183Z","author_details":{"name":"","rating":null,"username":"kurtsanorskie","avatar_path":null}}],"recommendations":[{"id":986206,"adult":false,"title":"Night Carnage","video":false,"overview":"A blogger who is also a werewolf meets a dashing playboy with a dark secret of his own. Starring Logan Andrews and Christian Howard.","genre_ids":[28,27,10749],"media_type":"movie","popularity":7.23,"vote_count":63,"poster_path":"/w0wjPQKhlqisSbylf1sWZiNyc2h.jpg","release_date":"2025-07-29","vote_average":5.952,"backdrop_path":"/5xgxXZ9C8KZDg0xWbk6rX0XcO9T.jpg","original_title":"Night Carnage","original_language":"fr"},{"id":1311031,"adult":false,"title":"Demon Slayer: Kimetsu no Yaiba Infinity Castle","video":false,"overview":"The Demon Slayer Corps are drawn into the Infinity Castle, where Tanjiro, Nezuko, and the Hashira face terrifying Upper Rank demons in a desperate fight as the final battle against Muzan Kibutsuji begins.","genre_ids":[16,28,14],"media_type":"movie","popularity":83.7889,"vote_count":722,"poster_path":"/fWVSwgjpT2D78VUh6X8UBd2rorW.jpg","release_date":"2025-07-18","vote_average":7.679,"backdrop_path":"/lNYympQM5O6QSInusbyG9eJDIe4.jpg","original_title":"劇場版「鬼滅の刃」無限城編 第一章 猗窩座再来","original_language":"ja"},{"id":1234821,"adult":false,"title":"Jurassic World Rebirth","video":false,"overview":"Five years after the events of Jurassic World Dominion, covert operations expert Zora Bennett is contracted to lead a skilled team on a top-secret mission to secure genetic material from the world's three most massive dinosaurs. When Zora's operation intersects with a civilian family whose boating expedition was capsized, they all find themselves stranded on an island where they come face-to-face with a sinister, shocking discovery that's been hidden from the world for decades.","genre_ids":[878,12,28],"media_type":"movie","popularity":34.4455,"vote_count":2997,"poster_path":"/1RICxzeoNCAO5NpcRMIgg1XT6fm.jpg","release_date":"2025-07-01","vote_average":6.307,"backdrop_path":"/zNriRTr0kWwyaXPzdg1EIxf0BWk.jpg","original_title":"Jurassic World Rebirth","original_language":"en"},{"id":1087192,"adult":false,"title":"How to Train Your Dragon","video":false,"overview":"On the rugged isle of Berk, where Vikings and dragons have been bitter enemies for generations, Hiccup stands apart, defying centuries of tradition when he befriends Toothless, a feared Night Fury dragon. Their unlikely bond reveals the true nature of dragons, challenging the very foundations of Viking society.","genre_ids":[14,10751,28,12],"media_type":"movie","popularity":26.7743,"vote_count":2604,"poster_path":"/53dsJ3oEnBhTBVMigWJ9tkA5bzJ.jpg","release_date":"2025-06-06","vote_average":7.94,"backdrop_path":"/79PNOxNXSe5e0bhEj11QJPlsdCN.jpg","original_title":"How to Train Your Dragon","original_language":"en"},{"id":715253,"adult":false,"title":"Phantom","video":false,"overview":"In 1933, when Korea was under Japanese occupation, five people in Gyeongseong are suspected to be \"Phantom\" spies of the anti-Japanese organization.","genre_ids":[28,53,80],"media_type":"movie","popularity":3.247,"vote_count":64,"poster_path":"/n1rxZ4wovf7BYhLNwCqde8I3I2N.jpg","release_date":"2023-01-18","vote_average":6.875,"backdrop_path":"/wFzI8o0jEMYfNugglP4wjFIr647.jpg","original_title":"유령","original_language":"ko"},{"id":1319895,"adult":false,"title":"Hostile Takeover","video":false,"overview":"Follows Pete, a professional hitman, as he faces a group of assassins after the boss of a crime syndicate suspects disloyalty due to his attendance at Workaholics Anonymous meetings.","genre_ids":[28,35,53],"media_type":"movie","popularity":7.4487,"vote_count":65,"poster_path":"/AvAgo0AHVAFAPr0vZLAzHPq0ftL.jpg","release_date":"2025-08-08","vote_average":6.923,"backdrop_path":"/tIfLu82gSgcgsXS6jvNFjwMqcKp.jpg","original_title":"Hostile Takeover","original_language":"en"},{"id":1263256,"adult":false,"title":"Happy Gilmore 2","video":false,"overview":"Happy Gilmore isn't done with golf — not by a long shot. Since his retirement after his first Tour Championship win, Gilmore returns to finance his daughter's ballet classes.","genre_ids":[35],"media_type":"movie","popularity":6.3381,"vote_count":877,"poster_path":"/nRwDPfYUzzzUQarfMxvPlasxzpL.jpg","release_date":"2025-07-25","vote_average":6.556,"backdrop_path":"/stCEYCxA3SknIIne1H4LmaIJ8ii.jpg","original_title":"Happy Gilmore 2","original_language":"en"},{"id":987400,