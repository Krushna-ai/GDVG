NOnsdXsdY4kP6.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/eGcS4pWe0ZzNJ3HdGnoP5fNpEQJ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/nJA8Yx03qo0WpiwBgJwVXmHg7OO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:43:51.575+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Inseparables","runtime":107,"tagline":"La historia real de una amistad inseparable","homepage":"","overview":"Felipe un empresario adinerado que ha quedado tetrapléjico, debido a un accidente, está buscando a un asistente terapéutico. Se presentan varios muy calificados, pero él decide tomar al ayudante de su jardinero, Tito que ha decidido renunciar. Tito no reúne ni por cerca las condiciones requeridas para tal empleo, cosa que notan inmediatamente las personas más cercanas a Felipe: Verónica e Ivonne su ama de llaves, pero Felipe mantiene firme su decisión. Tito es la única persona, en mucho tiempo, que no lo trata con compasión.  Remake del film francés 'Intouchables' (2011)."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Inseparáveis","runtime":108,"tagline":"","homepage":"","overview":"Felipe é um rico empresário que ficou tetraplégico em um acidente e está procurando por um assistente. Existem vários qualificados, mas ele decide levar o auxiliar de seu jardineiro, Tito, que não reúne todas as condições para o cargo, como notam pessoas mais próximas a Felipe, como Verônica e Ivonne, sua governanta, mas Felipe permanece firme na sua decisão. Tito é a única pessoa em muito tempo, que não o trata com compaixão."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Λατίνοι Και Άθικτοι","runtime":108,"tagline":"","homepage":"","overview":"Ο Φελίπε είναι ένας οικονομικά ευκατάστατος επιχειρηματίας που ύστερα από ένα ατύχημα μένει τετραπληγικός και αναζητά βοηθό για να τον φροντίζει. Παρόλο που ο Φελίπε βλέπει αρκετούς υποψήφιους με τα απαραίτητα προσόντα για την δουλεία, αποφασίζει να προσλάβει τον Τίτο, που εργάζεται ως βοηθός κηπουρού. Ο Τίτο δεν έχει ούτε τα προσόντα ούτε τις προδιαγραφές για να φροντίζει τον Φελίπε, κάτι που γίνεται αμέσως αντιληπτό από τους ανθρώπους του περιβάλλοντος του Φελίπε, την Βερόνικα και την Υβόνη. Προσπαθούν να τον αποτρέψουν να προσλάβει τον Τιτο, αλλά αυτός εμμένει στην απόφαση του. Ο Τίτο είναι το μόνο άτομο που δεν του φέρεται με οίκτο. Παρά τις δυσκολίες, ο Τίτο ανταποκρίνεται στην αποστολή του και διαρκώς εκπλήσσει τον Φελίπε ενώ τον κάνει να χαμογελάσει ξανά. Σύντομα ο Τίτο βοηθάει τον Φελίπε να βρει ξανά νόημα στην ζωή, απολαμβάνοντας τις μικρές καθημερινές χαρές, κάτι που είχε από καιρό ξεχάσει."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Нераздвојни","runtime":0,"tagline":"","homepage":"","overview":"Фелипе је пословни човек који је после једне несреће остао непокретан и тражи терапеута. И поред више веома квалификованих кандидата, одлучује се за свог баштована Тита, који је хтео да се пензионише. Тито ни изблиза не испуњава услове неопходне за тај посао, што одмах примећују особе из Фелипеовог окружења, али он не одустаје од своје одлуке.  Римејк француског филма “Недодирљиви”."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Inseparables","runtime":108,"tagline":"","homepage":"","overview":"Felipe est un riche homme d'affaires devenu tétraplégique. Il est à la recherche d'un assistant thérapeutique pour l'aider dans ses tâches quotidiennes. Malgré une liste de candidats hautement qualifiés, il choisit Tito qui n'a pas vraiment le profil…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"1+1. Нарушая правила","runtime":109,"tagline":"","homepage":"","overview":"Филиппе — богатому бизнесмену, прикованному к инвалидному креслу, требуется помощник на дому. Но вместо квалифицированных специалистов, он неожиданно нанимает безработного Тито, у которого нет ни специального образования, ни навыков ухода за инвалидами. Дело в том, что Тито оказывается единственным, кто не проявляет к нему излишнего сострадания. Постепенно Тито осваивается с новыми обязанностями, а Филиппе начинает вновь ощущать вкус к жизни рядом со своим молодым и непосредственным помощником."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"形影不離","runtime":0,"tagline":"","homepage":"","overview":"家財萬貫的富翁因意外導致終生癱瘓，生活無法自理的他，高薪尋覓適合的看護人選，明明有眾多素質優良的應徵者排隊，他偏偏選中隨性妄為的超中二痞子園丁，這種出人命的任性決定，連管家都出面阻止，他卻執意要聘用他。於是一段奇妙的友誼就此展開，飆車、把妹、抽煙樣樣來，兩人天差地遠的身份背景，為富翁注入了不同以往的活力泉源，填補彼此生命缺陷的那一塊，成為超狂、超瘋、超反差的忘年好麻吉。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":108,"tagline":"The true story of an inseparable friendship","homepage":"","overview":"Felipe a wealthy businessman who has been quadriplegic, due to an accident, is looking for a therapeutic assistant. There are several highly qualified, but he decides to take the assistant of his gardener, Tito who has decided to resign."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Inseparables","runtime":0,"tagline":"La historia real de una amistad inseparable.","homepage":"","overview":"Felipe un empresario adinerado que ha quedado tetrapléjico, debido a un accidente, está buscando a un asistente terapéutico. Se presentan varios muy calificados, pero él decide tomar al ayudante de su jardinero, Tito que ha decidido renunciar. Tito no reúne ni por cerca las condiciones requeridas para tal empleo, cosa que notan inmediatamente las personas más cercanas a Felipe: Verónica e Ivonne su ama de llaves, pero Felipe mantiene firme su decisión. Tito es la única persona, en mucho tiempo, que no lo trata con compasión."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"განუყრელნი","runtime":0,"tagline":"","homepage":"","overview":"ფილიპეს - მილიონერს, რომელიც ინვალიდის სავარძელსაა მიჯაჭვული მომვლელი სჭირდება. მოულოდენლად ის გამოცდილი სპეციალისტის მაგივრად ტიტოს დაიქირავებს, რომელსაც არ აქვს გამოცდილება. ტიტოს დახმარებით ფილიპე კვლავ შეიგრძნობს ცხოვრებას."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"形影不离","runtime":108,"tagline":"","homepage":"","overview":"改编自感动亿万人的真人真事，金牌喜剧导演马可斯卡尼费利将拉丁美洲的文化风情融入电影中，因地制宜地注入别于原着小说的笑料，创下2016年阿根廷的票房奇蹟，吸引百万人次观看，票房延烧南美洲。不怕猪一般的队友，因为他是神一般的好朋友。家财万贯的富翁因意外导致终生瘫痪，生活无法自理的他，高薪寻觅适合的看护人选，明明有众多素质优良的应徵者排队，他偏偏选中随性妄为的超中二痞子园丁，这种出人命的任性决定，连管家都出面阻止，他却执意要聘用他。于是一段奇妙的友谊就此展开，飙车、把妹、抽烟样样来，两人天差地远的身份背景，为富翁注入了不同以往的活力泉源，填补彼此生命缺陷的那一块，成为超狂、超疯、超反差的忘年好麻吉。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"1+1. Порушуючи правила","runtime":0,"tagline":"","homepage":"","overview":"Філіппе - багатому бізнесмену, прикутого до інвалідного крісла, потрібен помічник. Але замість кваліфікованих фахівців, він несподівано наймає безробітного Тіто, у якого немає ні спеціальної освіти, ні навичок догляду за інвалідами. Справа в тому, що Тіто виявляється єдиним, хто не проявляє до нього зайвого жалю. Поступово Тіто освоюється з новими обов'язками, а Філіппе починає знову відчувати смак до життя поруч зі своїм молодим помічником."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"形影不離","runtime":0,"tagline":"","homepage":"","overview":"家財萬貫的富翁因意外導致終生癱瘓，生活無法自理的他，高薪尋覓適合的看護人選，明明有眾多素質優良的應徵者排隊，他偏偏選中隨性妄為的超中二痞子園丁，這種出人命的任性決定，連管家都出面阻止，他卻執意要聘用他。於是一段奇妙的友誼就此展開，飆車、把妹、抽煙樣樣來，兩人天差地遠的身份背景，為富翁注入了不同以往的活力泉源，填補彼此生命缺陷的那一塊，成為超狂、超瘋、超反差的忘年好麻吉。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":893204,"adult":false,"title":"Single Mother by Choice","video":false,"overview":"Tracking a real-life pregnancy, this fictional film tells the story of a Latinx workaholic who’s determined to have a baby on her own terms and gets more than she bargained for when she gets pregnant in the year 2020.","genre_ids":[35,18],"media_type":"movie","popularity":0.2228,"vote_count":42,"poster_path":"/1Nb3HcYjV3aEDWFrL0jsNmkFeJ0.jpg","release_date":"2021-11-02","vote_average":7.024,"backdrop_path":"/yGoYkj7Di7RtsrYvWJsadfQzBdT.jpg","original_title":"Single Mother by Choice","original_language":"en"},{"id":472035,"adult":false,"title":"Alanis","video":false,"overview":"A young Buenos Aires mother finds employment as a sex worker and struggles to live under the same laws that are supposed to protect her.","genre_ids":[18],"media_type":"movie","popularity":1.831,"vote_count":51,"poster_path":"/dla95sUlksJuVmXXgbu9mk2j650.jpg","release_date":"2017-09-21","vote_average":6.294,"backdrop_path":"/2RuUgEjSklKPK2GA7IZ2a35iqCR.jpg","original_title":"Alanis","original_language":"es"},{"id":314572,"adult":false,"title":"The Boss: Anatomy of a Crime","video":false,"overview":"This incredibly disturbing story follows the exploitation of an apprentice butcher, Hermógenes, and his trial after he murders his boss in broad daylight. Hermógenes, a farmhand from northern Argentina, relocates to Buenos Aires in search of a better life for himself and his young wife, but soon finds himself at the mercy of a corrupt boss. The film is based on a thorough investigation of a real event that happened in Buenos Aires 10 years ago. Almost every scene in the film is inspired by real facts or based on well documented daily practices of the “meat business” and its environment. Both a shocking exposé of unscrupulous practices in the meat industry and a heart-wrenching personal story, El Patrón became one of the most successful Argentine films of 2014.","genre_ids":[18,80],"media_type":"movie","popularity":0.4921,"vote_count":98,"poster_path":"/tqM5b356wYON9VcIKUTOONRUL7P.jpg","release_date":"2014-10-12","vote_average":7.6,"backdrop_path":"/ptISaxb6sZ5Jvt2r7An9hBbejQk.jpg","original_title":"El patrón, radiografía de un crimen","original_language":"es"},{"id":134096,"adult":false,"title":"2 + 2","video":false,"overview":"When the fun of double dating begins to grow old, Richard and Bettina share a dirty little secret with their friends Diego and Emilia: They live a double life as swingers, and would love to share this practice with them.","genre_ids":[35],"media_type":"movie","popularity":0.8567,"vote_count":95,"poster_path":"/2pM6DJtGUvRzgXFfxGBScMMafew.jpg","release_date":"2012-08-16","vote_average":6.584,"backdrop_path":"/9IcqA79TMkcHu6IQs6kkkIAO0YY.jpg","original_title":"Dos más dos","original_language":"es"},{"id":434357,"adult":false,"title":"Criando ratas","video":false,"overview":"Latest example of Spanish \"neokinki\" cinema, which was popular in the late seventies/early eighties, right after the end of Franco's dictatorship. Destructured families of low social classes are the perfect environment for delinquency, drugs, violence and broken lives.","genre_ids":[18],"media_type":"movie","popularity":0.3972,"vote_count":28,"poster_path":"/qwJ9KzAuuPHuRfyvZ9OkkW83Hgl.jpg","release_date":"2016-01-10","vote_average":5.464,"backdrop_path":"/xyKKFqiYX3zvVmwXU76oeaBJ2re.jpg","original_title":"Criando ratas","original_language":"es"},{"id":361251,"adult":false,"title":"Road to La Paz","video":false,"overview":"Sebastian is unemployed, finding pleasure only in his old Peugeot. He got married to his girlfriend Jazmin and having no income, he starts a job of a private ride service. One day, a regular customer, Jalil, an old Arab man suggests a long distance drive. During the ride from Buenos Aires of Argentina to La Paz of Bolivia, the two are in conflict with each other constantly. With a series of unexpected accidents, the journey brings a small but important change to both of their lives.","genre_ids":[18],"media_type":"movie","popularity":0.0555,"vote_count":22,"poster_path":"/13X26kk4pVuIJfW5Y0I9nlcSBEX.jpg","release_date":"2015-10-25","vote_average":7.114,"backdrop_path":"/1uXe0SYwB7ZEHYjpH3SU94eiaR6.jpg","original_title":"Camino a La Paz","original_language":"es"},{"id":352124,"adult":false,"title":"La duquesa roja","video":false,"overview":"An Andalusian duchess has the dilemma of what to do with a grove, whether to convert it into a natural reserve or to make a luxury urbanization. The duchess, who is torn between her aristocratic privileges and a social commitment that has cost her more than one dislike in the past, must make a decision about her lands, to which she wants to get some money without harming the people. On the other hand, An ambitious Basque financier, Antónón Ibarrondo, intends to build a luxury urbanization in the Marbella style in the grove. Around the duchess, the businessman, environmentalists and other members in the conflict, problems begin to arise and everything will be decided in a referendum, convened with the idea that it is the people who decide, which coincides with the annual celebration of the Pilgrimage del Pueblo.With a cast \"","genre_ids":[35],"media_type":"movie","popularity":0.2008,"vote_count":2,"poster_path":"/zBkr4OcenMkIaLfKNCGpAoKukQH.jpg","release_date":"1997-07-17","vote_average":3,"backdrop_path":"/p5lRdQbIWQHN3oYpUobSo2Svy7c.jpg","original_title":"La duquesa roja","original_language":"es"},{"id":332356,"adult":false,"title":"Killing Jesus","video":false,"overview":"Jesus of Nazareth’s life and ministry were subject to seismic social and political events that led to his execution and changed the world forever.","genre_ids":[10770,18,14],"media_type":"movie","popularity":0.6321,"vote_count":100,"poster_path":"/1Wr7apWkhqHSdzmxnQuzlKTzdK.jpg","release_date":"2015-04-05","vote_average":6.305,"backdrop_path":"/q5CQZRXM5PBMNga9G1cErB6gOs8.jpg","original_title":"Killing Jesus","original_language":"en"},{"id":651589,"adult":false,"title":"Sky High","video":false,"overview":"A commentary on Spanish society dressed as a thriller about the misadventures of a gang of young petty criminals after the real estate crash.","genre_ids":[28,18,53],"media_type":"movie","popularity":0.7591,"vote_count":228,"poster_path":"/pUT5Fa1TskzkTmATpYGiW49PTEg.jpg","release_date":"2020-12-18","vote_average":6.1,"backdrop_path":"/vx4bevtt3ZVgezPZsuiVxm90l5E.jpg","original_title":"Hasta el cielo","original_language":"es"},{"id":565716,"adult":false,"title":"American Factory","video":false,"overview":"In post-industrial Ohio, a Chinese billionaire opens a new factory in the husk of an abandoned General Motors plant, hiring two thousand blue-collar Americans. Early days of hope and optimism give way to setbacks as high-tech China clashes with working-class America.","genre_ids":[99],"media_type":"movie","popularity":1.0884,"vote_count":493,"poster_path":"/7jH3dQOJ3CHMrp9tWsI3rRCDiaD.jpg","release_date":"2019-08-21","vote_average":7.187,"backdrop_path":"/vzmUkbi07g2dKVL6YCr8FX3LFgn.jpg","original_title":"American Factory","original_language":"en"},{"id":72213,"adult":false,"title":"Courageous","video":false,"overview":"Law enforcement officers Adam Mitchell, Nathan Hayes, and their partners stand up to the worst the streets have to offer with confidence and focus. Yet at the end of the day, they face a challenge that none of them are truly prepared to tackle: fatherhood. They know that God desires to turn the hearts of fathers to their children, but their children are beginning to drift further and further away from them. When tragedy hits home, these men are left wrestling with their hopes, their fears, their faith, and their fathering. Can a newfound urgency help these dads draw closer to God... and to their children?","genre_ids":[18],"media_type":"movie","popularity":2.1831,"vote_count":397,"poster_path":"/hVRkbZRCoHtnfi0V9GFZ3uXjCNp.jpg","release_date":"2011-09-30","vote_average":7.61,"backdrop_path":"/mTufDWFNNtm4hJzRQi5cxsO5Ar4.jpg","original_title":"Courageous","original_language":"en"},{"id":366170,"adult":false,"title":"Yu-Gi-Oh!: The Dark Side of Dimensions","video":false,"overview":"Having faced each other on countless occasions, Yugi and Kaiba again put their pride and experience to the test in a duel that transcends dimensions.","genre_ids":[12,16],"media_type":"movie","popularity":1.5354,"vote_count":455,"poster_path":"/ti0CRprP9iSg9IDadTZ3TFnuczS.jpg","release_date":"2016-04-23","vote_average":7.6,"backdrop_path":"/s9q3uNEjqHnLDgPX78Yfaoy8p1I.jpg","original_title":"遊☆戯☆王 THE DARK SIDE OF DIMENSIONS","original_language":"ja"},{"id":575604,"adult":false,"title":"The Call","video":false,"overview":"Connected by phone in the same home but 20 years apart, a caller puts a woman’s past — and life — on the line to change her own fate.","genre_ids":[53,9648,878],"media_type":"movie","popularity":2.8836,"vote_count":937,"poster_path":"/oz8hvZHg7tIdGwh0ErPRhobJKPR.jpg","release_date":"2020-11-23","vote_average":7.504,"backdrop_path":"/iDw6J49rf7Xlu9QZBWpvmrMqSzI.jpg","original_title":"콜","original_language":"ko"},{"id":609242,"adult":false,"title":"The Heist of the Century","video":false,"overview":"In 2006, a group of thieves performed what is considered one of the most famous and smart bank heists in the history of Argentina. How they robbed the Rio bank is as surprising as what happened afterwards. This is their story.","genre_ids":[35,53,80],"media_type":"movie","popularity":2.4532,"vote_count":836,"poster_path":"/1zL4VCVin4S8kOXhszMDqfwWPCM.jpg","release_date":"2020-01-16","vote_average":7.734,"backdrop_path":"/wEVSupeNO7EjjCFieEv2zt4oJei.jpg","original_title":"El robo del siglo","original_language":"es"},{"id":689249,"adult":false,"title":"Money Heist: The Phenomenon","video":false,"overview":"A documentary on why 'Money Heist' sparked a wave of enthusiasm around the world for a lovable group of thieves and their professor.","genre_ids":[99],"media_type":"movie","popularity":1.2441,"vote_count":1082,"poster_path":"/AboUXTrDWEi0PuZUqaft0iwBTm7.jpg","release_date":"2020-04-03","vote_average":7.442,"backdrop_path":"/yEBBtk1eyZltGgJt8Z2zi3KIvvX.jpg","original_title":"La Casa de Papel: el fenómeno","original_language":"es"},{"id":626332,"adult":false,"title":"Flamin' Hot","video":false,"overview":"The inspiring true story of Richard Montañez, the Frito Lay janitor who channeled his Mexican American heritage and upbringing to turn the iconic Flamin' Hot Cheetos into a snack that disrupted the food industry and became a global pop culture phenomenon.","genre_ids":[18,36],"media_type":"movie","popularity":3.2169,"vote_count":791,"poster_path":"/a7KyFMPXj0iY4EoLq1PIGU1WJPw.jpg","release_date":"2023-03-11","vote_average":7.954,"backdrop_path":"/yYEOYzgqPB31mkSsuPdCvXH3zHv.jpg","original_title":"Flamin' Hot","original_language":"en"},{"id":625568,"adult":false,"title":"Unhinged","video":false,"overview":"Rachel is a divorced single mother whose bad day gets even worse. She's running late to drop her son off at school when she honks her horn impatiently at a fellow driver during rush-hour traffic. After an exchange of words, she soon realizes that the mysterious man is following her and her young son in his truck. A case of road rage quickly escalates, at horrifyingly psychotic proportions, into full-blown terror as Rachel discovers the psychopath's sinister plan for revenge. He is single-mindedly determined to teach her a deadly lesson.","genre_ids":[28,53,27],"media_type":"movie","popularity":3.5011,"vote_count":2460,"poster_path":"/xfIcONZO4AiWpzm3jEpbR4llzVX.jpg","release_date":"2020-07-16","vote_average":6.439,"backdrop_path":"/wXk9y36eTmNl6XwEuOfw6yNNClr.jpg","original_title":"Unhinged","original_language":"en"},{"id":458220,"adult":false,"title":"Palmer","video":false,"overview":"After 12 years in prison, former high school football star Eddie Palmer returns home to put his life back together—and forms an unlikely bond with Sam, an outcast boy from a troubled home. But Eddie's past threatens to ruin his new life and family.","genre_ids":[18],"media_type":"movie","popularity":3.5298,"vote_count":1859,"poster_path":"/xSDdRAjxKAGi8fUBLOqSrBhJmF0.jpg","release_date":"2021-01-28","vote_average":8.124,"backdrop_path":"/mlBmnjDJfsAhvqRVc2aFOjsfh8M.jpg","original_title":"Palmer","original_language":"en"},{"id":10330,"adult":false,"title":"Freaky Friday","video":false,"overview":"Mother and daughter bicker over everything -- what Anna wears, whom she likes and what she wants to do when she's older. In turn, Anna detests Tess's fiancé. When a magical fortune cookie switches their personalities, they each get a peek at how the other person feels, thinks and lives.","genre_ids":[10751,14,35,10749],"media_type":"movie","popularity":4.2271,"vote_count":4198,"poster_path":"/ipKcZ4Up7dp18XpsfYUc9NKZy3g.jpg","release_date":"2003-08-05","vote_average":6.6,"backdrop_path":"/aH4MrSu8fwjRiEMGfdRwpsYu2PW.jpg","original_title":"Freaky Friday","original_language":"en"},{"id":9339,"adult":false,"title":"Click","video":false,"overview":"A married workaholic, Michael Newman doesn't have time for his wife and children, not if he's to impress his ungrateful boss and earn a well-deserved promotion. So when he meets Morty, a loopy sales clerk, he gets the answer to his prayers: a magical remote that allows him to bypass life's little distractions with increasingly hysterical results.","genre_ids":[35,18,14],"media_type":"movie","popularity":5.7871,"vote_count":7437,"poster_path":"/oL0k5JA53PyoHSZqKb3cNkhwBCE.jpg","release_date":"2006-06-23","vote_average":6.3,"backdrop_path":"/h30q7IXCmlgR1wKLnp9LttH6BCG.jpg","original_title":"Click","original_language":"en"}],"similar_content":[{"id":48603,"adult":false,"title":"Swim Alone","video":false,"overview":"The film does not describe, rather it observes, in a distant manner, the world of Martin, a seventeen year old who feels he doesn’t belong anywhere, not at home, school, nor with his friends or members of his rock band. In search of some happiness, Martin takes off to the coastal town of Mar de Plata, where his older brother lives. Unglamorous, yet enchantingly addictive and refreshingly genuine, Acuña paints a confused and uncomfortable world, and makes us want revisit it over and over again.","genre_ids":[18],"popularity":0.9723,"vote_count":2,"poster_path":"/wTYslVk0T2QjlhiNlS7970p3WJ.jpg","release_date":"2003-06-05","vote_average":6,"backdrop_path":"/cyjZAgH6s03ZcejP2BUk8HiDTY3.jpg","original_title":"Nadar solo","original_language":"es"},{"id":43810,"adult":false,"title":"Down Argentine Way","video":false,"overview":"The story—in which an American heiress on holiday in South America falls in love with an Argentine horse breeder against the wishes of their families—takes a backseat to the spectacular location shooting and parade of extravagant musical numbers, which include the larger-than-life Carmen Miranda singing the hit “South American Way” and a showstopping dance routine by the always amazing Nicholas Brothers.","genre_ids":[35,18,10402,10749],"popularity":0.4944,"vote_count":26,"poster_path":"/gg3DgplgKq8ZBFnMwMfgGuhSZCs.jpg","release_date":"1940-10-11","vote_average":6.2,"backdrop_path":"/5kyuveLcxz9aS5ufKXWTPeILJ0S.jpg","original_title":"Down Argentine Way","original_language":"en"},{"id":518997,"adult":false,"title":"The Daughters of Fire","video":false,"overview":"Three women meet by chance at the end of the world, in Argentinian Patagonia, and set out on a polyamorous journey, caught up in the search for new kinds of relationships, far from possession and pain. They become the Daughters of Fire, a band dedicated to helping those women who look for their own path to erotica.","genre_ids":[18],"popularity":1.4445,"vote_count":32,"poster_path":"/k2w1f0Co3dgIKTSmNn13Y31ppPu.jpg","release_date":"2018-10-28","vote_average":4.219,"backdrop_path":"/x42ljBaT4Y7sELPGVYo9hihLv9j.jpg","original_title":"Las Hijas del Fuego","original_language":"es"},{"id":311215,"adult":false,"title":"Papeles en el viento","video":false,"overview":"When El Mono dies, his three longtime friends try to recover from the loss and want to secure his little girl's future. But for Fernando, Mauricio and El Ruso this will not be easy. They decide to recover a big investment El Mono had made when he had bought a soccer player who was supposed to become a star.","genre_ids":[35,18],"popularity":0.2092,"vote_count":26,"poster_path":"/1rJjtxIbNpbdoBJEuEjZnEQhB87.jpg","release_date":"2015-01-08","vote_average":6.2,"backdrop_path":"/ds3mnPcfw6DJbOv7inMosvlvA1G.jpg","original_title":"Papeles en el viento","original_language":"es"},{"id":46770,"adult":false,"title":"The South","video":false,"overview":"After the end of the military dictatorship in Argentina in 1983, Floreal is released from prison. Instead of returning to his wife, he wanders through the night of Buenos Aires. He meets some people from his past–most of which are only imaginary–and remembers the events of his imprisonment.","genre_ids":[18,10402],"popularity":0.2672,"vote_count":27,"poster_path":"/xyOeNv5YturVNqxBFQ5DQAKjp3E.jpg","release_date":"1988-03-05","vote_average":6.4,"backdrop_path":"/bW4B1w4eBBm7ogyXS6N7Y59t4GL.jpg","original_title":"Sur","original_language":"es"},{"id":1107798,"adult":false,"title":"Thesis on a Domestication","video":false,"overview":"A successful transgender actress and her lawyer husband decide to adopt a child, defying the conservative community in Argentina. But their attempt for a domestic happiness is thwarted when they visit the actress's hometown.","genre_ids":[18],"popularity":0.4149,"vote_count":3,"poster_path":"/cKPf1ttw7M63xNZ30wP1yIqlL9a.jpg","release_date":"2025-10-23","vote_average":6.7,"backdrop_path":"/iiKiCEonX9kcYDlqQtuJBsD87ES.jpg","original_title":"Tesis sobre una domesticación","original_language":"es"},{"id":35005,"adult":false,"title":"Conversations with Mother","video":false,"overview":"Jaime has lost his job and has to provide for his wife, son and daughter. Pressured by this circumstances, he visits his mom, who lives in an apartment he owns, to ask her to move with him so he can sell the apartment. But she is not going to cooperate. And, to Jaime's surprise, she also has a boyfriend!","genre_ids":[35,18],"popularity":0.2349,"vote_count":13,"poster_path":"/zIRCirg18lhRQoBCSZ9Dl6DVY7W.jpg","release_date":"2004-04-15","vote_average":5.615,"backdrop_path":"/hKnF7i81xpPMTAyAP4QDxJrIudG.jpg","original_title":"Conversaciones con mamá","original_language":"es"},{"id":44956,"adult":false,"title":"Explosive Brigade","video":false,"overview":"Emilio, Benito Alberto and Gino are four childhood friends who today belong to the same police group \"Z Brigade\". Your first mission is to address the assault to a bank, but the lack of vitality that characterizes them they help the assailants flee the scene! The sergeant in charge decides to send them back to the Police Academy. The instructor will Moria Casan, who will train them to face and try to capture \"Scar\", the most feared and elusive offender.","genre_ids":[35],"popularity":0.6593,"vote_count":7,"poster_path":"/o4HsaJteHKbYHKk7qqGPpVu0iZ3.jpg","release_date":"1986-02-02","vote_average":5.8,"backdrop_path":"/npD83J0oWYBtoYe8N93UfG4upjV.jpg","original_title":"Brigada Explosiva","original_language":"es"},{"id":309836,"adult":false,"title":"Hostage","video":false,"overview":"A weary British spy retreats to a Buenos Aires hotel and recalls his last dirty job, complete with lover.","genre_ids":[53,28,18],"popularity":3.5167,"vote_count":8,"poster_path":"/s9EMMMHKFjDMBrbw1Jz81MNXSoD.jpg","release_date":"1992-05-10","vote_average":3,"backdrop_path":"/41TZ9en5LHyxvb8JPvBiJCTugTJ.jpg","original_title":"Hostage","original_language":"en"},{"id":714888,"adult":false,"title":"Argentina 1985","video":false,"overview":"In the 1980s, a team of lawyers takes on the heads of Argentina's bloody military dictatorship in a battle against odds and a race against time.","genre_ids":[18,36,80],"popularity":1.1101,"vote_count":724,"poster_path":"/nmh7vD2eDVRqFJoCpEzVcfGcPPf.jpg","release_date":"2022-09-29","vote_average":7.819,"backdrop_path":"/gh1Rghpf3BIISHSAw9GsObG4TN3.jpg","original_title":"Argentina 1985","original_language":"es"},{"id":715398,"adult":false,"title":"Memoria interna","video":false,"overview":"","genre_ids":[18,878],"popularity":1.6647,"vote_count":1,"poster_path":"/hkRnbXvsmtIaHQ8gu1a1we1alyU.jpg","release_date":"2017-06-17","vote_average":7,"backdrop_path":"/aIjj38TByR7on7jeJGOXm5m0uLS.jpg","original_title":"Memoria interna","original_language":"es"},{"id":31432,"adult":false,"title":"The Four Horsemen of the Apocalypse","video":false,"overview":"Set in the years before and during World War I, this epic tale tells the story of a rich Argentine family, one of its two descending branches being half of French heritage, the other being half German. Following the death of the family patriarch, the man's two daughters and their families resettle to France and Germany, respectively. In time the Great War breaks out, putting members of the family on opposing sides.","genre_ids":[10752,10749,18],"popularity":0.672,"vote_count":58,"poster_path":"/262nYFe45BxX22M9TPhB4BwEqby.jpg","release_date":"1921-03-06","vote_average":6.551,"backdrop_path":"/rOedMeXSSCYl6taw7ectpUQpVg.jpg","original_title":"The Four Horsemen of the Apocalypse","original_language":"en"},{"id":885025,"adult":false,"title":"Poltergays: Pesadija en lo profundo del recto","video":false,"overview":"In 1981, the de facto government financed a Victor Melman / Champagne Oyarbide film, to reach a new audience and give a message in favor of the imminent takeover of the Malvinas. When the military saw the finished film the filmmakers had to go into exile in Guatemala and the film was banned. Wes Craven plagiarized it after seeing it in a Guatemalan screening.","genre_ids":[35,27],"popularity":0.1828,"vote_count":0,"poster_path":"/gQtYeJZFNYn5Ivno7TtvL4c0gda.jpg","release_date":"2013-08-29","vote_average":0,"backdrop_path":null,"original_title":"Poltergays: Pesadija en lo profundo del recto","original_language":"es"},{"id":1114139,"adult":false,"title":"The Glass Woman","video":false,"overview":"Laura lives in fear in a small town. Her ex partner, Hernán, was violent with her and now he's about to return to town. Laura must find a solution to never cross paths with him again.","genre_ids":[18,53],"popularity":0.1658,"vote_count":2,"poster_path":"/sUHbgUI7WeyHFnGUpTB1IK7OMGH.jpg","release_date":"2023-07-20","vote_average":4,"backdrop_path":"/nBaAARICywNA3JJ76PRot0hsplL.jpg","original_title":"La mujer de vidrio","original_language":"es"},{"id":507505,"adult":false,"title":"El Angel","video":false,"overview":"Buenos Aires, Argentina, 1971. Carlos Robledo Puch is a 19-year-old boy with an angelic face, but a vocational thief as well, who acts ruthlessly, without remorse. When he meets Ramón, they follow together a dark path of crime and death.","genre_ids":[18,80],"popularity":0.7675,"vote_count":569,"poster_path":"/hKtxOC2Mx9v4vx5TNJprzrFiy7.jpg","release_date":"2018-08-09","vote_average":7.4,"backdrop_path":"/gRxlzFYDKdzNnhu8OFIKm3i9b6f.jpg","original_title":"El Ángel","original_language":"es"},{"id":41924,"adult":false,"title":"Night Watch","video":false,"overview":"A long night's journey into day: Victor, a street hustler in the Santa Fe and Pueyrredón neighborhoods of Buenos Aires, from the evening of November 1, All Saints Day, to the dawn of November 2, All Souls Day. Victor's odyssey takes him from clients to friends to a gay gym then a hotel room and an all-night café. He plays pick-up soccer with kids whose parents are going through trash or waiting in parks. A vendor gives him a chrysanthemum. It seems he's being followed, and on the night streets, death is close at hand. Can Victor survive until dawn?","genre_ids":[18],"popularity":1.0038,"vote_count":17,"poster_path":"/jtgdwlqLW2agtAHnkkzOCeceDf.jpg","release_date":"2005-05-15","vote_average":5.5,"backdrop_path":"/ukdxIXrRTFL79IlXAv8ZZDaJ4DP.jpg","original_title":"Ronda nocturna","original_language":"es"},{"id":1095826,"adult":false,"title":"Chronicles of a Wandering Saint","video":false,"overview":"In a tiny rural village in Argentina, Rita Lopez, a pious yet insatiably competitive woman, discovers that staging a miracle could be her ticket to sainthood.","genre_ids":[18,35,14],"popularity":0.1704,"vote_count":6,"poster_path":"/2ZPnZ5tUOPvKaFr7033KLRlre45.jpg","release_date":"2024-06-28","vote_average":8,"backdrop_path":"/8M0UVVUVoDPHaL0oaNjX9fFjdWq.jpg","original_title":"Crónicas de una santa errante","original_language":"es"},{"id":886755,"adult":false,"title":"The Substitute","video":false,"overview":"Lucio, a prestigious university professor, takes the position of substitute teacher at a high school in the suburbs of Buenos Aires, where he grew up. Through tales, novels and poetry, he tries to distract his class from the harsh reality of their everyday lives. But soon, he must step out of his professional duties when Dilan, one of his students, is threatened by a local drug kingpin.","genre_ids":[18,80],"popularity":0.2192,"vote_count":40,"poster_path":"/6B24MiYkIlqqB2T43NohbMDt95i.jpg","release_date":"2022-10-20","vote_average":5.95,"backdrop_path":"/kCHImXJGEzD3ACuiNSRHsfKg6T0.jpg","original_title":"El suplente","original_language":"es"},{"id":41115,"adult":false,"title":"Garage Olimpo","video":false,"overview":"Maria is a militant activist in an organisation opposed to the military dictatorship in Argentina. She teaches reading and writing in the shanty towns and lives with her mother in an old and run-down residence. One morning, Maria is carried off, in front of her mother, by a military squad dressed in civilian clothes. The young woman is taken to the Olimpo garage, one of the numerous torture chambers which haunt Buenos Aires to the general indifference of the population. In order to make Maria talk, Tigre, the head of the centre, gives her to one of his best men, Felix.","genre_ids":[18],"popularity":1.4276,"vote_count":90,"poster_path":"/nm0GuXuM5zpsW9Hwv7kR1cXgXD6.jpg","release_date":"1999-09-02","vote_average":6.767,"backdrop_path":"/eDgznD35ujsh35AiUcOybxJSSuU.jpg","original_title":"Garage Olimpo","original_language":"es"},{"id":43428,"adult":false,"title":"Time for Revenge","video":false,"overview":"Two coworkers decide to blackmail the corrupt demolition company they work for by setting up a fake accident.","genre_ids":[80,18,53],"popularity":0.3165,"vote_count":38,"poster_path":"/toMHQMl23CGboMUX9dR7V3OxbsF.jpg","release_date":"1981-07-30","vote_average":7.382,"backdrop_path":"/rg4XBpSQqMDiA0YQiSTxoWJYsIL.jpg","original_title":"Tiempo de revancha","original_language":"es"}],"external_ids":{"imdb_id":"tt5680678","twitter_id":null,"facebook_id":null,"wikidata_id":"Q25861140","instagram_id":null,"mydramalist_id":"291115","rotten_tomatoes_id":"m/inseparables_2016"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148202,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AR","release_dates":[{"note":"","type":3,"iso_639_1":"es","descriptors":[],"release_date":"2016-08-11T00:00:00.000Z","certification":""}]},{"iso_3166_1":"AU","release_dates":[{"note":"SBS World Movies","type":6,"iso_639_1":"","descriptors":[],"release_date":"2024-02-05T00:00:00.000Z","certification":"M"}]},{"iso_3166_1":"BR","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2017-06-01T00:00:00.000Z","certification":""}]},{"iso_3166_1":"ES","release_dates":[{"note":"","type":3,"iso_639_1":"es","descriptors":[],"release_date":"2017-07-21T00:00:00.000Z","certification":""}]},{"iso_3166_1":"GR","release_dates":[{"note":"","t