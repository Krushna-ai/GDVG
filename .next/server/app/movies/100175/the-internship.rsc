ml8MSBG.jpg","iso_639_1":"zh","vote_average":3.334},{"width":1672,"height":2508,"file_path":"/p28DqqaN4dOP1OECjaWYVrBRMqP.jpg","iso_639_1":"zh","vote_average":0.166},{"width":2000,"height":3000,"file_path":"/fYqSOkix4rbDiZW0ACNnvZCpT6X.jpg","iso_639_1":"en","vote_average":0},{"width":2000,"height":3000,"file_path":"/27j9fRcvtaskGPsuHXvVTAi1fEc.jpg","iso_639_1":"fr","vote_average":0},{"width":2000,"height":3000,"file_path":"/boefNT9mmIP7giAc76XJb0fpxRj.jpg","iso_639_1":"pt","vote_average":0},{"width":595,"height":891,"file_path":"/euZui1pdwjYyHcrW3PCVnzuJFSC.jpg","iso_639_1":"en","vote_average":0},{"width":667,"height":1000,"file_path":"/jJN6DAHBxq07ccRwpb6AwXZUuyQ.jpg","iso_639_1":"en","vote_average":0},{"width":1696,"height":2528,"file_path":"/eteBu8WyYQbG0mKmRradJcvFBFb.jpg","iso_639_1":"ar","vote_average":0},{"width":2000,"height":3000,"file_path":"/AcYLuWkjDcvetxZ6XQHCb7ArwTA.jpg","iso_639_1":null,"vote_average":0},{"width":2000,"height":3000,"file_path":"/nU59LYgkpWf72SjxExjxixBUsp5.jpg","iso_639_1":"en","vote_average":0},{"width":1300,"height":1940,"file_path":"/a7hTimch8r7UiVcJPkYM4Aj5jyI.jpg","iso_639_1":"ru","vote_average":0},{"width":2000,"height":3000,"file_path":"/RFKe8ppw80tIEVtY1oT8102qPN.jpg","iso_639_1":"ru","vote_average":0},{"width":1400,"height":2100,"file_path":"/jfSAL27Kmu47F4KiQwNahNyDiPy.jpg","iso_639_1":"ru","vote_average":0},{"width":1122,"height":1686,"file_path":"/jQb73TCjNCZLOcxnbFnEK3TQty2.jpg","iso_639_1":"en","vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/eUERZRVjCTNdgnESlQxyaOJ2d4K.jpg","iso_639_1":null,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/5eqnrbV7V76weYdYyJjy27vSZLp.jpg","iso_639_1":null,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/hSqTU1jKnqLsXniT8OmFFEJ6h01.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/2EptPFNLmu61CzCSHW6J5vDqJRw.jpg","iso_639_1":"en","vote_average":0},{"width":1280,"height":720,"file_path":"/pKPOsCPQad6ITy3uzCVozwIOsTE.jpg","iso_639_1":"en","vote_average":0},{"width":1920,"height":1080,"file_path":"/4Sq0eKF8QPwIIIPF5N3zG4Tw2Zf.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T05:56:46.955+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":91,"tagline":"","homepage":"","overview":"A CIA-trained assassin recruits other graduates from her secret childhood program, The Internship, to violently destroy the organization. The CIA fights back with deadly force."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Une tueuse surentrainée et sans pitié, élevée depuis son enfance dans un programme top-secret de la CIA uniquement connu sous le nom L’Internat, est prête à démanteler l’institution qui lui a volé sa jeunesse. Elle rassemble les autres internes et mène une insurrection sanglante, poussant la CIA à déployer des forces toutes aussi mortelles pour les arrêter."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"The Internship","runtime":0,"tagline":"","homepage":"","overview":"Bezwzględna, wyszkolona zabójczyni, wychowana od dzieciństwa w tajnym programie CIA znanym jedynie jako Staż, jest gotowa zniszczyć instytucję, która ukradła jej młodość. Zbierając swoich towarzyszy stażystów, przewodzi krwawemu powstaniu – zmuszając CIA do użycia równie śmiercionośnej siły, aby ich powstrzymać."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"反叛行动","runtime":0,"tagline":"","homepage":"","overview":"一名冷酷且训练有素的杀手，自幼被培养于一个名为 The Internship 的 CIA 最高机密项目中。多年后，她决定摧毁这个夺走自己青春的机构。她召集昔日的“实习生”同伴，发动了一场血腥的反抗行动——迫使 CIA 动用同样致命的力量来镇压他们。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Nelítostná a vysoce vycvičená vražedkyně, vychovávaná od dětství v přísně tajném programu CIA známém pouze jako Stáž, je připravena rozbít instituci, která jí ukradla mládí. Shromáždí ostatní stážisty a vede krvavé povstání – donutí CIA k použití stejně smrtící síly, aby je zastavila."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"인턴십","runtime":0,"tagline":"","homepage":"","overview":"“배신당한 킬러들의 반란, CIA 내부를 격돌하다”  어린 시절부터 비밀 CIA ‘인턴십’으로 혹독한 훈련을 받아온 여성이 이제 그 프로그램이 자신의 삶을 빼앗아간 진짜 이유를 밝히기 위해 나선다. 그녀는 자신처럼 길러진 동료 인턴들을 모아 조직을 무너뜨리려 하고, 점점 더 치명적인 임무 속에서 배신과 살아남기 위한 본능이 충돌하게 된다. CIA는 이를 막기 위해 더욱 강력한 대응에 나서고, 인턴들과 기관 모두가 최후의 결전을 벌이게 되는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Una asesina entrenada por la CIA recluta a otros graduados de su programa secreto de la infancia, The Internship, para destruir violentamente la organización. La CIA contraataca con fuerza letal."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Una asesina entrenada por la CIA recluta a otros graduados de su programa secreto de la infancia, The Internship, para destruir violentamente la organización. La CIA contraataca con fuerza letal."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Thực Tập","runtime":0,"tagline":"","homepage":"","overview":"Một sát thủ được CIA huấn luyện chiêu mộ những người tốt nghiệp khác từ chương trình đào tạo bí mật thời thơ ấu của cô, “Chương trình Thực tập”, để tiêu diệt tổ chức bằng bạo lực. CIA chống trả bằng vũ lực chết người."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"O Estágio","runtime":91,"tagline":"","homepage":"","overview":"Uma assassina treinada pela CIA recruta outros graduados de seu programa secreto de infância, conhecido como “O Estágio”, para destruir violentamente a própria organização. Em resposta, a CIA reage com força letal."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Стажът","runtime":0,"tagline":"","homepage":"","overview":"Убиец, обучен от ЦРУ, привлича бивши участници от тайната детска програма „Стажът“, за да унищожат с насилие организацията. В отговор ЦРУ действа със смъртоносна сила."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Стажировка","runtime":0,"tagline":"","homepage":"","overview":"ЦРУ создало программу «Стажировка», чтобы с раннего возраста превращать одаренных детей в идеальных агентов и бойцов, готовых без колебаний выполнять приказы. Годы тренировок, боли и изоляции лишали их нормального детства, заменяя его дисциплиной и жестокими правилами. Одна из самых опасных выпускниц этой программы долгие годы была оружием в руках разведки, выполняя задания и устраняя врагов нации. Однако ненависть к тем, кто украл у нее право выбора, никуда не исчезла. Со временем она решается пойти против системы и объединяется с другими бывшими воспитанниками, такими же сломанными и опасными. Их цель заключается не только в мести, но и в желании остановить механизм, который продолжает создавать новых убийц. В ответ разведка объявляет охоту на своих бывших агентов, не оставляя им шанса на спокойную жизнь."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Morilka, izurjena pri CIA-i, rekrutira nekdanje pripravnike tajnega otroškega programa z imenom »Pripravništvo«, da bi uničila organizacijo, ki jo je ustvarila. A CIA udari nazaj s smrtonosno silo."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"المتدربون","runtime":0,"tagline":"","homepage":"","overview":"تدور أحداث الفيلم حول قاتلة مدربة من وكالة الاستخبارات المركزية تقوم بتجنيد خريجين من برنامج سري في طفولتها، بهدف تدمير المنظمة التي صنعتهم. ومع تصاعد المواجهة، تدخل وكالة المخابرات المركزية في صراع دموي لإيقافهم، لتتحول المهمة إلى حرب خطيرة مليئة بالخيانة والمواجهات القاتلة."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"實習生","runtime":0,"tagline":"","homepage":"","overview":"蕾妮自幼被納入美國中情局的「實習生」秘密計畫，被訓練成冷酷無情的菁英殺手。長大後的她，卻集結其他的實習生，回頭對抗這個奪走她童年的機構。面對親手培育出的殺手造反，中情局不得不動用同樣致命的武力，迎擊蕾妮的團隊。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"The Internship - Praktikum im Töten","runtime":91,"tagline":"","homepage":"","overview":"Eine von der CIA ausgebildete Attentäterin rekrutiert andere Absolventen des geheimen Programms „The Internship“, dem auch sie angehörte und das Ihre Kindheit und die vieler anderer zerstört hat, um diese Organisation gewaltsam zu zerschlagen. Die CIA schlägt mit tödlicher Gewalt zurück."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"המתמחה","runtime":0,"tagline":"","homepage":"","overview":"צעירה שעברה הכשרה חשאית מילדות במסגרת תוכנית סודית בשם \"ההתמחות\" מחליטה להתקומם נגד המערכת שגידלה אותה. היא מאתרת ומגייסת בוגרים נוספים של התוכנית כדי להפיל את הארגון מבפנים, אבל למפעיליה בסיי-איי-איי אין כוונה לאפשר להם לשחרר את סודותיהם והם משיבים מלחמה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Progetto Tirocinio","runtime":92,"tagline":"","homepage":"","overview":"Una spietata assassina, cresciuta in un programma segreto della CIA denominato proprio \"The Internship\", decide di ribellarsi all'organizzazione che le ha rubato l'infanzia. Riunisce altri stagisti per una sanguinosa rivolta, costringendo la CIA a impiegare la sua forza letale per fermarli."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Un asasin instruit de CIA recrutează alți absolvenți ai programului secret din copilărie, The Internship, pentru a distruge organizația prin violență. CIA ripostează cu forță letală."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"}],"reviews_tmdb":[{"id":"6975a3ac2495071dfd10648a","url":"https://www.themoviedb.org/review/6975a3ac2495071dfd10648a","author":"MovieGuys","content":"\"Rather silly\" is my first and lasting reaction to \"The Internship\". \r\n\r\nIt tediously recycles overused concepts to craft, if that's the right word, a predictable and oftentimes absurd, action espionage thriller. It's all about a group of super spy teens trying to escape the CIA, that created them. Worse still, the evil Russians are out to exterminate them, or are they? \r\n\r\nThe action, such as it is, is reasonably well done, if implausible, and the acting is alright but not inspired. \r\n\r\nIn summary, a very ordinary action spy thriller you have seen many, many times before in one form or another. A basic watch.","created_at":"2026-01-25T05:01:32.390Z","updated_at":"2026-01-25T05:01:32.416Z","author_details":{"name":"","rating":5,"username":"MovieGuys","avatar_path":null}}],"recommendations":[],"similar_content":[],"external_ids":{"imdb_id":"tt38238651","twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":100175,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"DE","release_dates":[{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-02-02T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"GB","release_dates":[{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-02-02T00:00:00.000Z","certification":"15"}]},{"iso_3166_1":"US","release_dates":[{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-01-13T00:00:00.000Z","certification":""}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikidata_metadata":{},"mood_tags":null,"trope_tags":null,"vibe_description":null,"ai_enriched_at":null,"ai_enrichment_version":0}}]]
