logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":4},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":6}],"link":"https://www.themoviedb.org/movie/524047-greenland/watch?locale=SK","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":4},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":6}],"flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":1},{"logo_path":"/iTzW2q9e1Kk10l2s934SDgPSJNm.jpg","provider_id":627,"provider_name":"Voyo","display_priority":41}]},"SM":{"link":"https://www.themoviedb.org/movie/524047-greenland/watch?locale=SM","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1}]},"TH":{"link":"https://www.themoviedb.org/movie/524047-greenland/watch?locale=TH","flatrate":[{"logo_path":"/kwuUSaCoI9XN0ofHGVTkRm4BMYt.jpg","provider_id":2283,"provider_name":"Monomax","display_priority":28}]},"TR":{"buy":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":5},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":6}],"link":"https://www.themoviedb.org/movie/524047-greenland/watch?locale=TR","rent":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":5},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":6}]},"TW":{"link":"https://www.themoviedb.org/movie/524047-greenland/watch?locale=TW","rent":[{"logo_path":"/9qSVItdgkVHH3Rrl9db2yRWsgBq.jpg","provider_id":159,"provider_name":"Catchplay","display_priority":13}],"flatrate":[{"logo_path":"/9qSVItdgkVHH3Rrl9db2yRWsgBq.jpg","provider_id":159,"provider_name":"Catchplay","display_priority":13}]},"UA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}],"link":"https://www.themoviedb.org/movie/524047-greenland/watch?locale=UA","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}]},"US":{"buy":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":6},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35}],"link":"https://www.themoviedb.org/movie/524047-greenland/watch?locale=US","rent":[{"logo_path":"/qR6FKvnPBx2O37FDg8PNM7efwF3.jpg","provider_id":10,"provider_name":"Amazon Video","display_priority":6},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":7},{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":16},{"logo_path":"/pTnn5JwWr4p3pG8H6VrpiQo7Vs0.jpg","provider_id":192,"provider_name":"YouTube","display_priority":17},{"logo_path":"/19fkcOz0xeUgCVW8tO85uOYnYK9.jpg","provider_id":7,"provider_name":"Fandango At Home","display_priority":35},{"logo_path":"/vLZKlXUNDcZR7ilvfY9Wr9k80FZ.jpg","provider_id":538,"provider_name":"Plex","display_priority":126}],"flatrate":[{"logo_path":"/jbe4gVSfRlbPTdESXhEKpornsfu.jpg","provider_id":1899,"provider_name":"HBO Max","display_priority":11},{"logo_path":"/5AkEgpCNaBP3Fbwd2m1GdQIk0vv.jpg","provider_id":1825,"provider_name":"HBO Max Amazon Channel","display_priority":12}]},"VA":{"link":"https://www.themoviedb.org/movie/524047-greenland/watch?locale=VA","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":0}]},"VE":{"buy":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":4}],"link":"https://www.themoviedb.org/movie/524047-greenland/watch?locale=VE","rent":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":3},{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":4}]},"ZA":{"buy":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}],"link":"https://www.themoviedb.org/movie/524047-greenland/watch?locale=ZA"}}},"wikidata_id":"Q73897733","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-08T23:32:42.929378+00:00","region":null,"main_poster":null,"images":null,"enriched_at":"2026-04-21T06:08:48.638+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":120,"tagline":"It's the end of the world as we know it.","homepage":"","overview":"John Garrity, his estranged wife and their young son embark on a perilous journey to find sanctuary as a planet-killing comet hurtles toward Earth. Amid terrifying accounts of cities getting levelled, the Garritys experience the best and worst in humanity. As the countdown to the global apocalypse approaches zero, their incredible trek culminates in a desperate and last-minute flight to a possible safe haven."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Groenlanda","runtime":119,"tagline":"","homepage":"","overview":"Ca să ajungă la loc sigur, o familie luptă cu haosul și panica tot mai mari provocate de apropierea unor fragmente de cometă care pot distruge o mare parte a planetei."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Greenland : Le Dernier Refuge","runtime":119,"tagline":"Si vous ne pouvez pas sauver le monde, protégez votre famille.","homepage":"","overview":"Une comète est sur le point de s’écraser sur la Terre et de provoquer un cataclysme sans précédent. John Garrity décide de se lancer dans un périlleux voyage avec son ex-épouse Allison et leur fils Nathan pour rejoindre le dernier refuge sur Terre à l’abri du désastre. Alors que l’urgence devient absolue et que les catastrophes s’enchainent de façon effrénée, les Garrity vont être témoin du meilleur comme du pire de la part d’une humanité paniquée au milieu de ce chaos."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":120,"tagline":"","homepage":"","overview":"En gigantisk komet har kurs mod Jorden. Ingeniøren John får besked på at køre til en militærbase med sin kone og lille søn, hvorfra de skal flyves i sikkerhed. Men snart bliver den lille familie adskilt. Nu må de klare sig, som de bedst kan, i et kaotisk og panikramt USA."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Гренландия","runtime":119,"tagline":"«Это конец света, каким мы его знаем»","homepage":"","overview":"Огромная комета мчится к Земле и угрожает уничтожить планету. Конец света кажется неизбежным. Единственное безопасное место – бункер в далёкой Гренландии. Джон, его жена и их сын отправляются в опасное путешествие, которое осложняется не только разрушающими последствиями кометы, но и паникой обезумевших людей, ведь во время глобальной катастрофы никакие человеческие законы уже не действуют..."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Greenland: Poslední úkryt","runtime":119,"tagline":"","homepage":"","overview":"John Garrity s manželkou Allison a malým synem Nathanem se vydávají na nebezpečnou cestu, aby našli útočiště, před obrovskou kometou rychle se blížící k Zemi. Uprostřed děsivých zpráv o tom, že města po celém světě jsou ničena úlomky komety, naši protagonisté bojují s rostoucí panikou a bezprávím, které je obklopuje. Budeme svědky zběsilého útěku do bezpečí. Podaří se jim najít poslední úkryt před globální apokalypsou a najít nový bezpečný domov?"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":119,"tagline":"","homepage":"","overview":"Ein riesiger Komet rast in hoher Geschwindigkeit auf die Erde zu und soll Berechnungen zufolge vor Eintritt in die Erdatmosphäre verglühen. Doch die Prognosen stimmen nicht – ein erstes Fragment des Kometen stürzt nicht ins Meer, sondern zerstört stattdessen ganz Florida. Gerüchte, dass nur ein ausgewählter Kreis von Personen in Sicherheit gebracht werden kann, machen bereits die Runde, als Ingenieur John Garrity von der US-Regierung aufgefordert wird, sich sofort gemeinsam mit seiner Frau Allison und Sohn Nathan zu einer Militärbasis zu begeben. Von dort aus sollen sie an einen Ort ausgeflogen werden, an dem das Überleben möglich sein soll: Grönland. Doch die Fahrt dorthin wird zum Spießrutenlauf und die Familie im Chaos verzweifelnd fliehender Menschen und plündernden Horden auseinandergerissen. Wie sollen sie sich je wiederfinden, und wo ist man überhaupt noch sicher?"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Greenland: El último refugio","runtime":120,"tagline":"","homepage":"","overview":"Cuando el mundo es consciente de que el asteroide más grande de la historia va a impactar en la Tierra y aniquilar todo rastro de vida, los gobiernos de todo el mundo realizan un sorteo en el cual los afortunados podrán sobrevivir en refugios secretos. Esta decisión desata un caos a nivel mundial. Muchos tendrán que emprender un peligroso viaje donde se enfrentarán a los más imponentes peligros de la naturaleza, lo que les obligará a encontrar la manera de mantenerse unidos mientras encuentran la forma de sobrevivir."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":119,"tagline":"Se non puoi salvare il mondo, proteggi la tua famiglia.","homepage":"","overview":"Gerard Butler interpreta John Garrity, un uomo che lotta per proteggere la sua famiglia quando i frammenti di una cometa precipitano sulla Terra preannunciando un evento di dimensioni apocalittiche. John, sua moglie Allison (Morena Baccarin) e il figlioletto Nathan (Roger Dale Floyd) cominciano quindi un pericoloso viaggio verso la Groenlandia, dove si trovano dei bunker che garantirebbero loro la salvezza."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":120,"tagline":"","homepage":"","overview":"Familjen Garrity kämpar för att överleva när en komet är på väg att krascha mot jorden. John, hans fru Allison och deras lille son Nathan tvingas till en riskfylld resa samtidigt som de kämpar mot den ökande paniken och laglösheten runt omkring dem. Nedräkningen till den globala apokalypsen har börjat och det finns bara en säker plats att ta sig till ..."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"末日逃生","runtime":119,"tagline":"彗星撞地球倒计时 人类24小时极限逃亡","homepage":"","overview":"科学家们发现，宇宙中的两颗彗星正在急速向地球逼近，不出意外的话，它们终将撞上地球，给地球带来无法估量的损失。为了避免造成世界级的恐慌，政府封锁了这一消息，偷偷在格陵兰岛建造了非常坚固的堡垒，只有躲进堡垒的人们才能够获得一线生机，而进入堡垒的条件非常的苛刻。杰夫（杰拉德·巴特勒 Gerard Butler 饰）是一名建筑工程师，他得到了进入堡垒的机会，于是决定带着妻子艾莉森（莫瑞娜·巴卡琳 Morena Baccarin 饰）和儿子内森（罗杰·戴尔·弗洛伊德 Roger Dale Floyd 饰）一起前往格陵兰岛。哪知道旅途进行到一半，察觉到了事件真相的军方开始了暴乱行动。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Destruição Final: O Último Refúgio","runtime":120,"tagline":"É o fim do mundo como o conhecemos.","homepage":"","overview":"Quando cientistas descobrem que um cometa atingirá a Terra em poucos dias e provavelmente causará a extinção da humanidade, uma família tenta cruzar o país para chegar a sua única esperança de sobrevivência: um grupo de abrigos subterrâneos em Greenland."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"Kończy się świat. Ocalisz tych, których kochasz?","homepage":"","overview":"Naukowcy nie mają wątpliwości: Ziemia nie zdoła uniknąć zderzenia ze zbliżającą się do niej potężną kometą, a jego skutki będą katastrofalne. Wybitny inżynier John Garrity (Gerard Butler) i jego rodzina są w grupie wybrańców, którym władze zaoferowały bezpieczne schronienie w położonym na odludziu tajnym bunkrze. Większość społeczeństwa nie otrzymuje takiej szansy. Podczas gdy fragmenty rozpadającej się komety niszczą miasta i zabijają tysiące ludzi, świat pogrąża się w chaosie. Wybuchają zamieszki, rozboje są na porządku dziennym, a służby tracą kontrolę nad sytuacją. W takich okolicznościach dotarcie na miejsce ewakuacji staje się śmiertelnie niebezpiecznym wyzwaniem. Moment decydującego uderzenia zbliża się nieubłaganie. John jest gotów na wszystko, by ocalić swoją żonę i kochanego syna. Najbliższe kilkanaście godzin zdecyduje o wszystkim."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Greenland - Az utolsó menedék","runtime":120,"tagline":"","homepage":"http://tefilmed.hu/filmjeink/greenland/","overview":"Egy hatalmas méretű üstökös közelít a Föld felé, amely az emberiség teljes pusztulását okozhatja. A totális káosz, és tömeges pánik közepette John Garrity is menekülésre kényszerül családjával. Az elszánt férfi csak egy dolgot akar: biztonságban tudni feleségét és kisfiát. A végzetes, apokaliptikus katasztrófa árnyékában Garrity bármire képes, hogy eljuttassa szeretteit a Föld utolsó, védelmet nyújtó menedékére."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Greenland: Posledný úkryt","runtime":0,"tagline":"","homepage":"","overview":"John Garrity, jeho manželka Allison a malý syn Nathan sa vydávajú na strastiplnú cestu, aby sa dostali na posledné bezpečné miesto na svete. Zo všetkých strán prichádzajú desivé správy o škodách, ktoré spôsobujú úlomky kométy. Tie fyzické však nie sú najhoršie - ľudí sa zmocňuje panika, prestávajú platiť základné princípy ľudskosti a všade vládne bezprávie. Šanca na záchranu sa zmenšuje každou minútou a nikto nechce pomáhať druhým, pretože v poslednom úkryte nie dosť miesta pre všetkých..."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Гренландія","runtime":119,"tagline":"","homepage":"","overview":"Уламки гігантської комети мчать до Землі і загрожують знищити планету. Кінець світу здається неминучим. Єдине безпечне місце –  бункер у далекій Гренландії. Джон, його дружина та син вирушають у небезпечну подорож. На їхньому шляху до порятунку – не лише руйнівні уламки комети, але й паніка людей, які збожеволіли від жаху. Під час глобальної катастрофи людські закони вже не діють і кожен – сам за себе..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"","runtime":120,"tagline":"","homepage":"","overview":"En familie kjemper for å overleve når en komet raser mot jorden. John Garrity, hans separerte kone Allison og sønnen Nathan begir seg ut på en farefull reise til deres eneste håp om trygghet. Mens flere byer rundt om i verden blir jevnet med jorden fra kometens fragmenter, opplever familien det beste og det verste menneskeheten kan by på, samtidig som de kjemper mot den økende panikken og lovløsheten rundt dem. Når nedtellingen til den globale apokalypsen nærmer seg null, er deres siste sjanse en desperat flytur til en mulig trygg havn."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"","runtime":120,"tagline":"","homepage":"","overview":"John Garrity on vaimostaan Allisonista ja pojastaan Nathanista vieraantunut rakennusmestari, joka saa yllättäen presidentillisen käskyn ottaa hatkat kaikesta, napata perhe mukaan ja ottaa nokka kohti läheistä sotilastukikohtaa. Maata nimittäin uhkaa  lähestyvä  Clark-niminen valtava komeetta. Media toitottaa vielä komeetan vaarattomuutta, mutta kesken Nathanin synttärikutsujen Clarkin palanen putoaa Yhdysvaltoihin, vaikka sen piti osua harmittomasti keskelle merta. Garrity tajuaa lopulta ottaa hätäviestin vakavasti, ja suuntaa kohti tukikohtaa, josta lähtee lento salaiseen määränpäähän. Perhe lähtee vaaralliselle matkalle samalla, kun he joutuvat taistelemaan ympärillään kasvavaa paniikkia ja sekasortoa vastaan. Lähtölaskenta maailmanlaajuista tuhoa vastaan on alkanut, ja on vain yksi turvallinen paikka, jonne paeta..."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"그린랜드","runtime":0,"tagline":"“오늘, 클라크 혜성이 지구를 향해 날아옵니다!”","homepage":"","overview":"혜성의 지구 충돌 속보를 지켜보던 존과 가족들. 미 항공우주국(NASA)의 예측과 달리 해상으로 떨어졌어야 할 파편은 캘리포니아를 비롯해 세계 대도시로 추락해 세계는 순식간에 혼돈에 빠진다. 지구의 3/4을 날려버릴 초대형 혜성 추락까지 남은 시간은 단 48시간. 존과 가족은 지구의 유일한 안전 대피소인 ‘그린란드’의 벙커로 향하는데... 인류의 마지막 카운트다운이 시작된다!"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Greenland - O Último Refúgio","runtime":120,"tagline":"","homepage":"https://www.cinemundo.pt/filmes/greenland-o-ultimo-refugio/","overview":"Uma família luta pela sobrevivência quando um cometa destruidor de planetas chega à Terra. John Garrity, a sua ex-mulher Allison, e o seu jovem filho, Nathan, fazem uma perigosa viagem até à sua derradeira esperança de salvação.Por entre terríveis relatos de destruição a nível mundial, a família Garrity experiencia o melhor e o pior da Humanidade, à medida que a contagem decrescente para o apocalipse global se aproxima do zero."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"末世綠洲","runtime":120,"tagline":"","homepage":"","overview":"彗星「奇克」撞擊地球，其碎片將變成無數高溫隕石，於24小時內墜落各地，摧毀一切，造成令人類幾近滅絕的巨災。全球唯一可避過這場空前浩劫的，就只有位於北極圈的格陵蘭。約翰（謝拉畢拿 飾）與分居妻子愛麗（莫蓮娜芭卡琳 飾），跟所有人一樣，不管生存機會有多渺茫，仍只想帶著獨生子拚命逃往格陵蘭的庇護站。隨著地球進入最後倒數，致命危機分秒來襲，全球77億人口，有多少可以登上這片綠洲？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Гренландия: Последно убежище","runtime":0,"tagline":"","homepage":"","overview":"Близо преминаваща комета се оказва далеч по-опасна от предвижданията и Джерард Бътлър ще трябва да спаси семейството си, бягайки към последното убежище на планетата."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"นาทีระทึก..วันสิ้นโลก","runtime":0,"tagline":"","homepage":"","overview":"เมื่ออุกกาบาตลูกใหญ่กำลังจะชนโลก \"จอห์น แกริตี้\" (เจอราด บัตเลอร์) และครอบครัวได้รับเลือกให้หลบภัยในศูนย์พักพิง แต่เขาต้องพบกับความโกลาหลจนมีเหตุให้พลัดพรากจากครอบครัว จอห์นจึงทำทุกวิถีทางเพื่อตามหาภรรยาและลูกซึ่งป่วยด้วยโรคเบาหวาน ก่อนโลกจะแตกดับลงต่อหน้า"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"天劫倒數","runtime":119,"tagline":"核彈級彗星來襲，24小時生存戰","homepage":"","overview":"地球面臨末日危機，偏離軌道的彗星即將衝破大氣層，將世界夷為平地。隨著全球陷入毀滅倒數的恐慌，為了生存挺身而戰的父親約翰（傑哈巴特勒 飾）決心把他的家人帶到選中之地，面對分秒必爭的生存關頭，這將成為地球上唯一安全的庇護所......。  兩顆彗星正在朝地球運動,人類即將面臨毀滅性撞擊,然而政府封鎖了內部消息,在格陵蘭建造了堡壘,只允許部分人類進入。John通過朋友得知了這個消息,並取得了一家三口進入堡壘的機會。然而,在逃亡的過程中,軍隊得知自己已經被政府拋棄,開始失去控制,劫持了去往格陵蘭的飛機,John的妻子與兒子也因此失散。 John只能去約定好的地方等待妻子與兒子,期望會合後一併開車前往目的地格陵蘭,這一路經歷了種種困難,他們一家人最終是否可以會合,安全抵達格陵蘭呢... ."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":119,"tagline":"","homepage":"","overview":"John Garrity, zijn vervreemde vrouw en hun jonge zoon beginnen aan een gevaarlijke reis om een toevluchtsoord te vinden terwijl een planeetdodende komeet naar de aarde raast. Te midden van angstaanjagende verhalen over steden die met de grond gelijk worden gemaakt, ervaren de Garrity's het beste en slechtste in de mensheid. Terwijl het aftellen naar de wereldwijde apocalyps nul nadert, culmineert hun ongelooflijke tocht in een wanhopige en last-minute vlucht naar een mogelijke veilige haven."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Greenland: Thảm Họa Thiên Thạch","runtime":0,"tagline":"","homepage":"","overview":"Trước thảm họa thiên thạch liên tiếp rơi xuống Trái đất và phá hủy tất cả mọi thứ nơi nó đi qua, John Garrity quyết tâm đưa vợ Allison, cùng con trai Nathan tìm đường trốn đến nơi trú ẩn an toàn - Greenland - hy vọng sống sót duy nhất của tất cả trước khi quá muộn. Mặt khác, họ phải cạnh tranh với những con người cũng đang tìm cách sinh tồn bằng mọi giá."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"El Día del Fin del Mundo","runtime":120,"tagline":"Hay que llegar al ultimo refugio","homepage":"","overview":"Un matrimonio a punto de separarse debe tratar de garantizar la seguridad de su hijo y ellos mismos cuando una catástrofe se avecina hacia el planeta. Un objeto del espacio está a punto de colisionar con la Tierra y esta familia es escogida para entrar en un búnker subterráneo. Sin embargo, tienen poco tiempo. Tan solo cuentan con 48 horas antes de que el mundo que conocen se destruya para siempre."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Greenland: Το Τελευταίο Καταφύγιο","runtime":0,"tagline":"Είναι το τέλος του κόσμου όπως το γνωρίζουμε.","homepage":"","overview":"Μια οικογένεια αγωνίζεται για επιβίωση καθώς ένας κομήτης που Θα καταστρέψει τον πλανήτη έρχεται προς τη Γη. Ο John Garrity (Gerard Butler), η αποξενωμένη σύζυγός του Allison (Morena Baccarin) και ο μικρός του γιος Nathan κάνουν ένα επικίνδυνο ταξίδι στην μοναδική τους ελπίδα για να σωθούν. Εν μέσω τρομακτικών ειδήσεων για πόλεις σε όλο τον κόσμο που ισοπεδώνονται από τα κομμάτια του κομήτη, ο John αντιμετωπίζει τη καλύτερη και τη χειρότερη πλευρά της ανθρωπότητας, ενώ πολεμούν τον αναπόφευκτο πανικό και την ανομία που τους περιβάλλει. Καθώς η αντίστροφη μέτρηση της παγκόσμιας αποκάλυψης πλησιάζει στο μηδέν, το απίστευτο ταξίδι τους καταλήγει σε μια απελπισμένη πτήση προς ένα πιθανό ασφαλές καταφύγιο"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Greenland: Son Sığınak","runtime":120,"tagline":"Dünyayı kurtaramıyorsan, aileni koru.","homepage":"","overview":"Dünya büyük bir tehlike ile karşı karşıyadır. Dünyanın yok olmasına neden olabilecek bir gök cismi gittikçe dünyaya yaklaşmaktadır. İnsanların kaçabilmesi için önlerinde sadece 48 saat vardır. Hayatta kalmak için zamana karşı yarışan evli bir çift, oğulları ile birlikte felaketten kurtulabilmek için Grönland’daki bir yeraltı sığınağına ulaşmaya çalışır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"גרינלנד","runtime":0,"tagline":"","homepage":"","overview":"ג'ון גאריטי, אשתו המנוכרת ובנם הצעיר יוצאים למסע מסוכן למצוא מקלט, בזמן שכוכב שביט הרסני מתקרב אל עבר כדור הארץ. כשהספירה לאחור לקראת השמדת העולם מתקרבת לאפס, המסע מגיע לשיאו בטיסה נואשת ברגע האחרון למקלט האפשרי."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":0,"tagline":"Civilizacija kakvu smo poznavali približila se svome kraju.","homepage":"","overview":"Kako se odbrojavanje do globalne apokalipse približava, obitelj Johna Garrityja se bori za opstanak. Zajedno sa svojim sinom Nathanom moraju krenuti na opasno putovanje kako bi se domogli jedine nade za spas, utočišta na Greenlandu. Usred zastrašujućih vijesti o uništenim gradovima širom svijeta, dok komadi kometa izazivaju katastrofu neviđenih razmjera, Garrityji doživljavaju najbolje i najgore od čovječanstva, u borbi protiv sve veće panike i bezakonja koje ih okružuju. Kako se odbrojavanje do globalne apokalipse približava nuli, njihov nevjerojatan put kulminira očajničkim i posljednjim letom u moguće sigurno utočište."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Grenlandija: išlikimas","runtime":0,"tagline":"","homepage":"","overview":"Paskutinės Žemės valandos prieš smogiant kometai. Vienintėlė saugi vieta - Grenlandija. Mokslininkai jau seniai seka artimajame kosmose praskriejančius asteroidus bei kometas, siekdami numatyti, kuris iš jų gali kelti grėsmę mūsų planetai. Nors dauguma didesniųjų objektų yra pastebėti, o jų trajektorijos apskaičiuotos, tikimybė, kad į Žemę trenksis iš kosmoso gelmių atskriejęs nekviestas svečias, išlieka. Tokiu atveju padariniai gali būti katastrofiniai. Naujausi asteroidų atvejai yra išsamiai ištirti ir aprašyti: 2013 m. netoli Rusijos Čeliabinsko miesto nukritusio maždaug 20-ies metrų skersmens asteroido sprogimo galia prilygo 440 tūkst. tonų trotilo; o žymiojo 1908-ųjų Tunguskos meteorito (kurio skersmuo galėjo siekti nuo 60 iki 190 metrų) sprogimas, pagal skaičiavimus, prilygo 15-ai milijonų tonų trotilo – t.y., buvo tūkstantį kartų galingesnis nei Hirosimos atominės bombos. Tačiau kas nutiktų, jei Žemė atsidurtų ne asteroido, o kometos kelyje?"},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Meteor pocinje da udara u zemlju i prijeti da unisti citavu planetu. Jedina sansa za spas jeste da se stigne do bunkera."},"name":"Bosanski","iso_639_1":"bs","iso_3166_1":"BS","english_name":"Bosnian"},{"data":{"title":"Groenland","runtime":119,"tagline":"","homepage":"http://entractfilms.com/films/groenland","overview":"Alors que la Terre est menacée de destruction par une comète, une famille se bat pour sa survie. John Garrity, sa femme Allison et son jeune fils Nathan entament un périlleux voyage vers leur seul espoir de refuge. Alors que des villes entières ont été décimées par des fragments de cette comète et que la panique et l’anarchie envahissent la planète, la famille Garrity fait face au pire et au meilleur de l’humanité. Leur incroyable périple culmine lorsqu’ils embarquent dans un avion en direction d’un possible bunker, quelques heures avant l’apocalypse."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"جرينلاند","runtime":0,"tagline":"","homepage":"","overview":"يشرع جون غاريتي وزوجته المنفصلة وابنهما الصغير في رحلة محفوفة بالمخاطر للعثور على ملاذ بينما يندفع مذنب مدمر نحو الأرض.  وسط روايات مرعبة عن مدن تدمرت ، فإن تجربة جاريتي هي الأفضل والأسوأ في الإنسانية.  مع اقتراب العد التنازلي لنهاية العالم، تبلغ رحلتهم المذهلة ذروتها في رحلة جوية يائسة في اللحظة الأخيرة إلى ملاذ آمن محتمل."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Гренланд: Последње уточиште","runtime":0,"tagline":"","homepage":"","overview":"Земљи прети апокалипса, али овај пут је у фокусу спашавање породице."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Grenlande","runtime":0,"tagline":"","homepage":"","overview":"Zemei tuvojas milzu komētas fragmenti, kuru spēkos ir iznīcināt cilvēci. Izdzīvot katastrofā var, vienīgi nokļūstot bunkuros tālu Grenlandē. Džons, viņa sieva Alisone un dēliņš Neitans dodas riskantā ceļojumā, lai izcīnītu savu vietu vienīgajā patvērumā. Apkārt virmojot šausminošām ziņām no pilsētām, kuras līdz ar zemi nolīdzinājuši komētas fragmenti, Garitī ģimene pieredz cilvēka dabas labākos un ļaunākos aspektus, spēkojoties ar aizvien pieaugošo paniku un nelikumībām. Kad pulkstenis skaita pēdējās sekundes līdz vispasaules apokalipsei, viņu neticamais brauciens sasniedz kulmināciju izmisīgā pēdējā brīža lidojumā uz iespējamo glābiņu."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"گرینلند","runtime":0,"tagline":"","homepage":"","overview":"دانشمندان متوجه می‌شوند که برخورد تکه‌های یک ستاره‌ی دنباله‌دار در روز‌های آتی به احتمال زیاد باعث انقراض بشریت خواهد شد و تنها راه نجات از این مهلکه پناه‌بردن به گروهی از پناهگاه‌های زیرزمینی واقع در گرین‌لند است. این فیلم ماجرای جان گریتی را دنبال می‌کند که به‌همراه همسرش آلیسون و پسر کم سن‌وسالش ..."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Grenlandija: Poslednje zatočišče","runtime":119,"tagline":"","homepage":"","overview":"Ob približevanju in odštevanju minut do globalne apokalipse se družina Johna Garrityja bori za obstanek. Z malim sinom Nathanom se morajo podati na nevarno potovanje, da bi se prebili do majhnega upanja za rešitev in preživetje - do Grenlandije. Med groznimi novicami o uničenih mestih po svetu in med preletavanjem kometov po nebu družina doživlja najboljše in najslabše, kar lahko ponudi človeštvo v boju proti največji paniki, ki jih obkroža."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"グリーンランド -地球最後の2日間-","runtime":0,"tagline":"世界崩壊まで残り48時間。そのとき何ができる?","homepage":"","overview":"ジョン・ギャリティと別居中の妻、そして幼い息子は、地球を破壊する彗星が地球に接近する中、聖域を探す危険な旅に出る。都市が破壊される恐怖の中、ギャリティ家は人間の最良と最悪の面を体験する。地球滅亡へのカウントダウンがゼロに近づく中、彼らの驚くべき旅は、可能性のある安全な避難所へのギリギリの絶望的な飛行で頂点に達する。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"გრენლანდია","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"}],"reviews_tmdb":[{"id":"5f731036d40d4c0038630b4b","url":"https://www.themoviedb.org/review/5f731036d40d4c0038630b4b","author":"Manuel São Bento","content":"$11","created_at":"2020-09-29T10:45:10.207Z","updated_at":"2021-06-23T15:58:45.339Z","author_details":{"name":"Manuel São Bento","rating":3,"username":"msbreviews","avatar_path":null}},{"id":"601b5ee181da39003fbe365a","url":"https://www.themoviedb.org/review/601b5ee181da39003fbe365a","author":"SWITCH.","content":"Briskly paced and littered with jagged, realistic edges though it is, 'Greenland' ultimately imagines a very sentimental planetary extinction. Perhaps the highest compliment I can pay this film is that it's far better than the annual paint-by-numbers Gerard Butler movie that humanity is used to receiving.\r\n- Jake Watt\r\n\r\nRead Jake's full article...\r\nhttps://www.maketheswitch.com.au/article/review-greenland-a-gerard-butler-flick-that-isnt-a-disaster","created_at":"2021-02-04T02:41:37.761Z","updated_at":"2021-06-23T15:58:51.201Z","author_details":{"name":"SWITCH.","rating":6,"username":"maketheSWITCH","avatar_path":"/klZ9hebmc8biG1RC4WmzNFnciJN.jpg"}},{"id":"6047957cc8a5ac006ffd7de1","url":"https://www.themoviedb.org/review/6047957cc8a5ac006ffd7de1","author":"Louisa Moore - Screen Zealots","content":"$12","created_at":"2021-03-09T15:34:20.493Z","updated_at":"2021-06-23T15:58:52.966Z","author_details":{"name":"Louisa Moore - Screen Zealots","rating":8,"username":"screenzealots","avatar_path":null}},{"id":"60784c017464570029d82567","url":"https://www.themoviedb.org/review/60784c017464570029d82567","author":"tmdb15435519","content":"Cue the epic music... and exactly the same elements, acting, cinematography, and script that are in nearly every disaster movie in the last 20 years.","created_at":"2021-04-15T14:21:53.787Z","updated_at":"2021-06-23T16:54:28.277Z","author_details":{"name":"","rating":5,"username":"tmdb15435519","avatar_path":null}}],"recommendations":[{"id":625568,"adult":false,"title":"Unhinged","video":false,"overview":"Rachel is a divorced single mother whose bad day gets even worse. She's running late to drop her son off at school when she honks her horn impatiently at a fellow driver during rush-hour traffic. After an exchange of words, she soon realizes that the mysterious man is following her and her young son in his truck. A case of road rage quickly escalates, at horrifyingly psychotic proportions, into full-blown terror as Rachel discovers the psychopath's sinister plan for revenge. He is single-mindedly determined to teach her a deadly lesson.","genre_ids":[28,53,27],"media_type":"movie","popularity":3.6267,"vote_count":2460,"poster_path":"/xfIcONZO4AiWpzm3jEpbR4llzVX.jpg","release_date":"2020-07-16","vote_average":6.439,"backdrop_path":"/wXk9y36eTmNl6XwEuOfw6yNNClr.jpg","original_title":"Unhinged","original_language":"en"},{"id":602211,"adult":false,"title":"Fatman","video":false,"overview":"A rowdy, unorthodox Santa Claus is fighting to save his declining business. Meanwhile, Billy, a neglected and precocious 12 year old, hires a hit man to kill Santa after receiving a lump of coal in his stocking.","genre_ids":[28,14,35],"media_type":"movie","popularity":1.4553,"vote_count":940,"poster_path":"/4n8QNNdk4BOX9Dslfbz5Dy6j1HK.jpg","release_date":"2020-10-19","vote_average":5.6,"backdrop_path":"/ckfwfLkl0CkafTasoRw5FILhZAS.jpg","original_title":"Fatman","original_language":"en"},{"id":577922,"adult":false,"title":"Tenet","video":false,"overview":"Armed with only one word - Tenet - and fighting for the survival of the entire world, the Protagonist journeys through a twilight world of international espionage on a mission that will unfold in something beyond real time.","genre_ids":[28,53,878],"media_type":"movie","popularity":8.4016,"vote_count":10865,"poster_path":"/aCIFMriQh8rvhxpN1IWGgvH0Tlg.jpg","release_date":"2020-08-22","vote_average":7.174,"backdrop_path":"/yY76zq9XSuJ4nWyPDuwkdV7Wt0c.jpg","original_title":"Tenet","original_language":"en"},{"id":553604,"adult":false,"title":"Honest Thief","video":false,"overview":"A bank robber tries to turn himself in because he's falling in love and wants to live an honest life...but when he realizes the Feds are more corrupt than him, he must fight back to clear his name.","genre_ids":[53,28,80],"media_type":"movie","popularity":2.9038,"vote_count":1858,"poster_path":"/zeD4PabP6099gpE0STWJrJrCBCs.jpg","release_date":"2020-09-03","vote_average":6.477,"backdrop_path":"/2M2JxEv3HSpjnZWjY9NOdGgfUd.jpg","original_title":"Honest Thief","original_language":"en"},{"id":606234,"adult":false,"title":"Archive","video":false,"overview":"2038: George Almore is working on a true human-equivalent AI, and his latest prototype is almost ready. This sensitive phase is also the riskiest as he has a goal that must be hidden at all costs—being reunited with his dead wife.","genre_ids":[878,18,14,53],"media_type":"movie","popularity":1.7028,"vote_count":775,"poster_path":"/hmz9ySdCqW9FiHpM9JdSCkjQzFA.jpg","release_date":"2020-08-13","vote_average":6.315,"backdrop_path":"/u9YEh2xVAPVTKoaMNlB5tH6pXkm.jpg","original_title":"Archive","original_language":"en"},{"id":551804,"adult":false,"title":"Freaky","video":false,"overview":"A mystical, ancient dagger causes a notorious serial killer to magically switch bodies with a 17-year-old girl.","genre_ids":[27,35],"media_type":"movie","popularity":2.8725,"vote_count":1789,"poster_path":"/8xC6QSyxrpm0D5A6iyHNemEWBVe.jpg","release_date":"2020-11-12","vote_average":6.6,"backdrop_path":"/lVbPO7RjsMWoUwH1ISRbZNbg62s.jpg","original_title":"Freaky","original_language":"en"},{"id":274855,"adult":false,"title":"Geostorm","video":false,"overview":"After an unprecedented series of natural disasters threatened the planet, the world's leaders came together to create an intricate network of satellites to control the global climate and keep everyone safe. But now, something has gone wrong: the system built to protect Earth is attacking it, and it becomes a race against the clock to uncover the real threat before a worldwide geostorm wipes out everything and everyone along with it.","genre_ids":[28,878,53],"media_type":"movie","popularity":9.2122,"vote_count":5072,"poster_path":"/nrsx0jEaBgXq4PWo7SooSnYJTv.jpg","release_date":"2017-10-12","vote_average":6.111,"backdrop_path":"/vIEuJiIZN9EclAJDmD49F2zUzuX.jpg","original_title":"Geostorm","original_language":"en"},{"id":590706,"adult":false,"title":"Jiu Jitsu","video":false,"overview":"Every six years, an ancient order of jiu-jitsu fighters joins forces to battle a vicious race of alien invaders. But when a celebrated war hero goes down in defeat, the fate of the planet and mankind hangs in the balance.","genre_ids":[28,878,14],"media_type":"movie","popularity":1.3144,"vote_count":649,"poster_path":"/eLT8Cu357VOwBVTitkmlDEg32Fs.jpg","release_date":"2020-11-20","vote_average":4.796,"backdrop_path":"/an4UrbuWK7TEOeur9TesuMzqSYC.jpg","original_title":"Jiu Jitsu","original_language":"en"},{"id":470610,"adult":false,"title":"Endless","video":false,"overview":"When madly in love high school graduates Riley and Chris are separated by a tragic car accident, Riley blames herself for her boyfriend's death while Chris is stranded in limbo. Miraculously, the two find a way to connect. In a love story that transcends life and death, both Riley and Chris are forced to learn the hardest lesson of all: letting go.","genre_ids":[10749,18,14],"media_type":"movie","popularity":2.1661,"vote_count":216,"poster_path":"/1ZViaX2oRnI0uM3Gf87Z7eCZ3hE.jpg","release_date":"2020-04-09","vote_average":6.7,"backdrop_path":"/o71u8V1u8uB4mL1kZjMjBGQU14M.jpg","original_title":"Endless","original_language":"en"},{"id":340102,"adult":false,"title":"The New Mutants","video":false,"overview":"Five young mutants, just discovering their abilities while held in a secret facility against their will, fight to escape their past sins and save themselves.","genre_ids":[878,27,28],"media_type":"movie","popularity":4.9208,"vote_count":3648,"poster_path":"/xiDGcXJTvu1lazFRYip6g1eLt9c.jpg","release_date":"2020-04-02","vote_average":6.085,"backdrop_path":"/1MoeNacOltBWojkStjhT3svBTOK.jpg","original_title":"The New Mutants","original_language":"en"},{"id":791373,"adult":false,"title":"Zack Snyder's Justice League","video":false,"overview":"Determined to ensure Superman's ultimate sacrifice was not in vain, Bruce Wayne aligns forces with Diana Prince with plans to recruit a team of metahumans to protect the world from an approaching threat of catastrophic proportions.","genre_ids":[28,12,14],"media_type":"movie","popularity":10.8081,"vote_count":10638,"poster_path":"/tnAuB8q5vv7Ax9UAEje5Xi4BXik.jpg","release_date":"2021-03-18","vote_average":8.096,"backdrop_path":"/13Nz8EchKRdCgJcKdEoJAnpiVn2.jpg","original_title":"Zack Snyder's Justice League","original_language":"en"},{"id":337401,"adult":false,"title":"Mulan","video":false,"overview":"When the Emperor of China issues a decree that one man per family must serve in the Imperial Chinese Army to defend the country from Huns, Hua Mulan, the eldest daughter of an honored warrior, steps in to take the place of her ailing father. She is spirited, determined and quick on her feet. Disguised as a man by the name of Hua Jun, she is tested every step of the way and must harness her innermost strength and embrace her true potential.","genre_ids":[12,14,28],"media_type":"movie","popularity":6.6237,"vote_count":6967,"poster_path":"/aKx1ARwG55zZ0GpRvU2WrGrCG9o.jpg","release_date":"2020-09-04","vote_average":6.837,"backdrop_path":"/zMrk2G3XsnfYKiIp1NEfdtvDyBH.jpg","original_title":"Mulan","original_language":"en"},{"id":775996,"adult":false,"title":"Outside the Wire","video":false,"overview":"In the near future, a drone pilot is sent into a deadly militarized zone and must work with an android officer to locate a doomsday device.","genre_ids":[53,28,878],"media_type":"movie","popularity":2.1813,"vote_count":1894,"poster_path":"/6XYLiMxHAaCsoyrVo38LBWMw2p8.jpg","release_date":"2021-01-15","vote_average":6.348,"backdrop_path":"/lOSdUkGQmbAl5JQ3QoHqBZUbZhC.jpg","original_title":"Outside the Wire","original_language":"en"},{"id":614911,"adult":false,"title":"The Midnight Sky","video":false,"overview":"A lone scientist in the Arctic races to contact a crew of astronauts returning home to a mysterious global catastrophe.","genre_ids":[878,18],"media_type":"movie","popularity":2.3182,"vote_count":1975,"poster_path":"/l8lXesOLXKS0VYjzWNZN6gDxv2F.jpg","release_date":"2020-12-10","vote_average":5.736,"backdrop_path":"/dueiWzWc81UAgnbDAyH4Gjqnh4n.jpg","original_title":"The Midnight Sky","original_language":"en"},{"id":567189,"adult":false,"title":"Tom Clancy's Without Remorse","video":false,"overview":"An elite Navy SEAL uncovers an international conspiracy while seeking justice for the murder of his pregnant wife.","genre_ids":[28,53,10752],"media_type":"movie","popularity":3.2198,"vote_count":2625,"poster_path":"/6GCOpT8QcNzup09TAMmvvk22LTR.jpg","release_date":"2021-04-29","vote_average":6.9,"backdrop_path":"/fPGeS6jgdLovQAKunNHX8l0avCy.jpg","original_title":"Tom Clancy's Without Remorse","original_language":"en"},{"id":458576,"adult":false,"title":"Monster Hunter","video":false,"overview":"A portal transports Cpt. Artemis and an elite unit of soldiers to a strange world where powerful monsters rule with deadly ferocity. Faced with relentless danger, the team encounters a mysterious hunter who may be their only hope to find a way home.","genre_ids":[28,14,12],"media_type":"movie","popularity":3.8016,"vote_count":3490,"poster_path":"/1UCOF11QCw8kcqvce8LKOO6pimh.jpg","release_date":"2020-12-03","vote_average":6.532,"backdrop_path":"/8tNX8s3j1O0eqilOQkuroRLyOZA.jpg","original_title":"Monster Hunter","original_language":"en"},{"id":675327,"adult":false,"title":"Shadow in the Cloud","video":false,"overview":"A WWII pilot traveling with top secret documents on a B-17 Flying Fortress encounters an evil presence on board the flight.","genre_ids":[27,28,10752],"media_type":"movie","popularity":2.0445,"vote_count":1039,"poster_path":"/t7EUMSlfUN3jUSZUJOLURAzJzZs.jpg","release_date":"2021-01-01","vote_average":5.8,"backdrop_path":"/aHYUj0hICtWZ5tPiCIm6pWUcjYK.jpg","original_title":"Shadow in the Cloud","original_language":"en"},{"id":630004,"adult":false,"title":"The Vault","video":false,"overview":"Madrid, Spain, 2010. While the whole city follows the national team's successful participation in the World Cup, a group of daring thieves look for a way into one of the most secure and guarded places on the planet.","genre_ids":[18,28,53],"media_type":"movie","popularity":3.5894,"vote_count":1044,"poster_path":"/kWhXubAiIcHW0xn5GThflqaKZqh.jpg","release_date":"2021-03-04","vote_average":6.808,"backdrop_path":"/s1ohP4iE2Lg2TVBJILOkbTsGGgu.jpg","original_title":"Way Down","original_language":"en"},{"id":590223,"adult":false,"title":"Love and Monsters","video":false,"overview":"Seven years since the Monsterpocalypse began, Joel Dawson has been living underground in order to survive. But after reconnecting over radio with his high school girlfriend Aimee, Joel decides to venture out to reunite with her, despite all the dangerous monsters that stand in his way.","genre_ids":[35,12,878],"media_type":"movie","popularity":3.9879,"vote_count":4350,"poster_path":"/718NnyxyQuBQcGWt9sdelA1Zc3h.jpg","release_date":"2020-10-16","vote_average":7.275,"backdrop_path":"/lA5fOBqTOQBQ1s9lEYYPmNXoYLi.jpg","original_title":"Love and Monsters","original_language":"en"},{"id":458220,"adult":false,"title":"Palmer","video":false,"overview":"After 12 years in prison, former high school football star Eddie Palmer returns home to put his life back together—and forms an unlikely bond with Sam, an outcast boy from a troubled home. But Eddie's past threatens to ruin his new life and family.","genre_ids":[18],"media_type":"movie","popularity":3.5674,"vote_count":1859,"poster_path":"/xSDdRAjxKAGi8fUBLOqSrBhJmF0.jpg","release_date":"2021-01-28","vote_average":8.124,"backdrop_path":"/mlBmnjDJfsAhvqRVc2aFOjsfh8M.jpg","original_title":"Palmer","original_language":"en"}],"similar_content":[{"id":359785,"adult":false,"title":"Dominion","video":false,"overview":"Earth's position in the universe has become of vital strategic importance to those who have, until now, only studied us from the far reaches of space. Knowing our weaknesses, they have planned their attack, and now, in just 5 days, life on Earth will change forever. Robert Casey, a retired US Intelligence agent turned UFO investigator, races to discover the truth about the Dominion and what it has in store for the human race. Time is running out...","genre_ids":[28,53,878],"popularity":0.2971,"vote_count":9,"poster_path":"/dFxIKXzxsTab3tF6K3jbS0aHlw9.jpg","release_date":"2015-09-14","vote_average":5.4,"backdrop_path":null,"original_title":"Dominion","original_language":"en"},{"id":111901,"adult":false,"title":"The Collapsed","video":false,"overview":"In the wake of the end of the world, a family of four desperately tries to survive. Their goal: escaping the city and traveling to the rural community they once called home.  The constant threat of a violent death forcing them to stay as far away from civilization as possible, they take to the forest, soon to discover the danger posed by other survivors may be the least of their worries.","genre_ids":[18,27,878],"popularity":0.151,"vote_count":31,"poster_path":"/m8burOTP8Oi3AGmDlXUGMDzVisY.jpg","release_date":"2011-07-02","vote_average":4,"backdrop_path":"/4HocFQH4Dr1Y6xCID24OKITYEpR.jpg","original_title":"The Collapsed","original_language":"en"},{"id":112235,"adult":false,"title":"Satham Podathey","video":false,"overview":"Bhanumathy tries to rebuild her life after escaping a suffocating marriage. As she finds hope and connection with her brother's friend Ravichandran, her past refuses to stay buried.","genre_ids":[53,10749],"popularity":0.1769,"vote_count":3,"poster_path":"/ijzi2nXbD9iqahs9P2Kwav38xKq.jpg","release_date":"2007-09-14","vote_average":5,"backdrop_path":null,"original_title":"சத்தம் போடாதே","original_language":"ta"},{"id":961256,"adult":false,"title":"Tokyo MER: Mobile Emergency Room: The Movie","video":false,"overview":"The individuals that comprise the Tokyo MER team rush to on-site disasters and accidents, performing life-saving treatment thanks to the OR equipped within their vehicle. Their one mission is simple: leave no one dead. But conflicts arise when an unprecedented event rocks Yokohama after a bomb explodes in Landmark Tower, leaving thousands fighting to escape. Although the chief doctor Kitami believes they should not wait and presses for a quick dispatch, the more level-headed Chief Kamoi of the elite Yokohama MER thinks otherwise — they need to wait until the area is safe to enter, or they won’t be able to save anyone.","genre_ids":[18,53],"popularity":3.0827,"vote_count":6,"poster_path":"/sWQPPw3dbhiRdTXuV3918FKhw4d.jpg","release_date":"2023-04-28","vote_average":7.333,"backdrop_path":"/lfxYh6qmCNVD25hgDS5cCZaF036.jpg","original_title":"劇場版TOKYO MER～走る緊急救命室～","original_language":"ja"},{"id":112631,"adult":false,"title":"Daniel & Ana","video":false,"overview":"Being kidnapped shatters a brother and sister's harmony, forcing them to confront their desires.","genre_ids":[53,18],"popularity":1.6266,"vote_count":112,"poster_path":"/9qdUuckSL6OAwp6aUpbMY6513YB.jpg","release_date":"2009-10-14","vote_average":6.75,"backdrop_path":"/xlEwMw3GB7NWmk75v1uwOwmAY4m.jpg","original_title":"Daniel & Ana","original_language":"es"},{"id":112648,"adult":false,"title":"Stranded","video":false,"overview":"The Russian space station Avma is disintegrating, and an international team of scientists is sent to the dying station to salvage valuable technology left on board. But fate has other plans, and when a rogue meteor collides with the station, leaving them with all communications lost, and life-giving oxygen bleeding into space, one man has only hours to save all the lives on board.","genre_ids":[12,878],"popularity":0.5742,"vote_count":14,"poster_path":"/xrUzIC82ZFtSlt6FQRDZsxnkgFG.jpg","release_date":"2002-01-20","vote_average":4.179,"backdrop_path":"/nsA3KgHpUoA2EoFQN84d8HuWnTo.jpg","original_title":"Stranded","original_language":"en"},{"id":369852,"adult":false,"title":"The Lost Choices","video":false,"overview":"A young women is raped while on her way home. When she is rejected by the police, because they don't believe her, she sets out revenge. But not only on her rapist, but also the police and everybody who did not believe her.","genre_ids":[53,18],"popularity":0.4571,"vote_count":11,"poster_path":"/mSBnujZ4ptmh8HT1tbLdtXTXBGM.jpg","release_date":"2015-10-28","vote_average":6.6,"backdrop_path":"/sMyPEwNHi4mpdqDylzLk0lJdkYa.jpg","original_title":"어떤살인","original_language":"ko"},{"id":112969,"adult":false,"title":"Slaughter of the Innocents","video":false,"overview":"A seasoned FBI Agent's child-genius son assists him on catching a child-killer, a schizophrenic mohab nut who believes he's been chosen by god to be a new Noah.","genre_ids":[27,28,53,9648],"popularity":0.3715,"vote_count":31,"poster_path":"/pUyIUwRsGaku48LpPWVNyylp9bh.jpg","release_date":"1993-09-17","vote_average":5.4,"backdrop_path":"/4s3MuDSkXxnfYW5owEm7t0rv2Bz.jpg","original_title":"Slaughter of the Innocents","original_language":"en"},{"id":112703,"adult":false,"title":"The Stepford Children","video":false,"overview":"Steven and Laura Harding, along with their kids David and Mary, have moved to the quiet community of Stepford. Steven joins the men's club, which is still assimilating their wives into robots. This time, they have begun to turn their out of control teens into robots as well. Once they are assimilated, they are obedient, homework loving, big band dancing droids. Laura, David, and Mary stumble onto this mystery, and they must avoid Steven's plans to turn them into robots.","genre_ids":[27,878,53,10770,9648],"popularity":0.4503,"vote_count":14,"poster_path":"/jGbW8HvDOW4GA3tbvUf8kUBOXS8.jpg