ount":0,"aspect_ratio":0.667,"vote_average":0},{"width":1080,"height":1620,"file_path":"/websxF9ChEAeYYZyQv3C8flAywZ.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1481,"file_path":"/lnLS3dCtUZlKYVPLxe9DJKQVHkV.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.675,"vote_average":0},{"width":1500,"height":2000,"file_path":"/zNShfVgFVMAyOf7qxO4pYxGD57W.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.75,"vote_average":0},{"width":2000,"height":3000,"file_path":"/q8gyI5ObOBa6mQQjZyeKbTAHw1Z.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/w0PCOfAa8Mf2r19Sms3CPZlD9dR.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1500,"height":2290,"file_path":"/7odSpax3f5XuivPn3bxjj71snfR.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.655,"vote_average":0},{"width":2000,"height":3000,"file_path":"/lJZrzjEk7vhLnHYdTU2GuNbiBL2.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":2857,"file_path":"/wTC68JsXaAZTdNb8D4q64fIWTnQ.jpg","iso_639_1":"el","iso_3166_1":"GR","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":2000,"height":3000,"file_path":"/j39lxKBzBvkbgVCmwXsZ1FjmRxm.jpg","iso_639_1":"th","iso_3166_1":"TH","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/dH9qwjzNb86rr6sIntLp5NvvOu2.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":949,"height":1405,"file_path":"/syghewqh8okNuncnVqB4xfEewq4.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.675,"vote_average":0},{"width":2000,"height":3000,"file_path":"/qbbPG32abJ9uGAM9ueOz4vd4Uqi.jpg","iso_639_1":"ja","iso_3166_1":"JP","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1589,"height":2384,"file_path":"/zhHGbl8SiL17e3ERQxcseHlMelA.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1500,"height":2250,"file_path":"/efKVOqiKS6KsG7jCPLo8n9mapNB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/cavK9ox37pxDg11RvJINMH63onU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":8,"aspect_ratio":1.778,"vote_average":6.312},{"width":3840,"height":2160,"file_path":"/92LX2nflnkxHtmV2WRb4I4lSXsY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":10,"aspect_ratio":1.778,"vote_average":6.2},{"width":3840,"height":2160,"file_path":"/mv8M0PqQYicndU7TGgBAHrI4uUo.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":8,"aspect_ratio":1.778,"vote_average":1.562},{"width":3840,"height":2160,"file_path":"/xyRbgz7v7b2M4ztbO9pR8TqN00I.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":1.434},{"width":3840,"height":2160,"file_path":"/8zgmZFQ4tNDgJRKIY4jOaG9JERR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":1280,"height":720,"file_path":"/6buNEHLr5lP5rfywG7ogH7KZ1wC.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.778,"vote_average":0.958},{"width":3000,"height":1687,"file_path":"/3VznXL6p58Rm1OiAUObURqGCvwR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":0.166},{"width":1919,"height":1080,"file_path":"/qKA2uZLb8aYIsf5b8dBM28Eu5RP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.777,"vote_average":0.166},{"width":2660,"height":1496,"file_path":"/mvAhAlzaIfqd3Y0T3RPdWXpKhGv.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/7PDa6zzKZCi0Nc6sZD9kIU8u9H3.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/uRXQxQMcA059Cp8NlPok7hW2m6v.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/4h9hGR2XU8JdGoREGVKcDynZkj.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/jvVtMIznmjh5PZPQOoSc5DWyNYO.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T04:28:46.641+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":100,"tagline":"No tiene sentido rezar.","homepage":"","overview":"En una aldea remota donde dos hermanos encuentran a un hombre infectado por un demonio que está a punto de dar a luz al mal mismo. En un momento en que el exorcismo parece ser de poca utilidad para protegerse del mal, después de advertir a los vecinos de la ciudad, deciden deshacerse del hombre, pero simplemente logran ayudarlo a librar el infierno."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"When Evil Lurks","runtime":100,"tagline":"There's no point in praying.","homepage":"","overview":"Residents of a small rural town discover that a demon is about to be born among them. They desperately try to escape before the evil is born, but it may be too late."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"When Evil Lurks","runtime":99,"tagline":"Prier ne vous sauvera pas.","homepage":"","overview":"Après avoir découvert un cadavre mutilé près de leur propriété, deux frères apprennent que les événements étranges survenant dans leur village sont causés par un esprit démoniaque qui a élu domicile dans le corps purulent d’un homme. Le mal dont souffre ce dernier ne tarde pas à se répandre comme une épidémie, affectant d’autres habitants de la région."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Одержимые злом","runtime":99,"tagline":"«Время молитв прошло»","homepage":"","overview":"Братья-фермеры Педро и Хайме обнаруживают в лесу изуродованное тело чистильщика, который, как выясняется, направлялся в соседний дом убить одержимого. Когда имеешь дело со злом, нужно соблюдать определённые правила, поэтому братья вместе с соседом Руисом решают отвезти заражённого подальше и там оставить, но тот по дороге исчезает. На следующий день демоническая сила убивает Руиса и его беременную жену, а братья пускаются в бега. Педро заезжает к бывшей супруге забрать детей, но приносит зло с собой."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"当邪恶潜伏时","runtime":0,"tagline":"","homepage":"","overview":"在一个偏远的村庄里，两兄弟发现一个被恶魔感染的人正要生下邪恶。他们决定除掉那个人，但只是成功地制造了混乱。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Коли зло ховається","runtime":99,"tagline":"Немає сенсу молитися.","homepage":"","overview":"У глухому селі двоє братів знаходять зараженого демоном чоловіка, який став ідеальною оболонкою для народження зла. Вони вирішують позбутися тіла, але лише поширюють хаос."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"O Mal que Nos Habita","runtime":99,"tagline":"Rezar não vai adiantar.","homepage":"","overview":"Em uma vila remota, dois irmãos encontram um homem possuído por demônios prestes a dar à luz ao mal encarnado. Eles decidem se livrar do sujeito, mas acabam apenas espalhando o caos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Zlo si umí počkat","runtime":0,"tagline":"","homepage":"","overview":"Obyvatelé malého venkovského městečka zjistí, že se mezi nimi má narodit démon. Zoufale se snaží uniknout, než se zlo zrodí, ale možná už je pozdě."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Amikor a gonosz leselkedik","runtime":0,"tagline":"Nincs értelme imádkozni.","homepage":"","overview":"Amikor két testvér, Pedro és Jimmy felfedezik, hogy egy közeli tanyán démoni fertőzés tanyázik – amelynek puszta közelsége megmérgezi a helyi állatállományt –, megpróbálják elűzni az áldozatot a földjükről. Mivel nem tartják be az ördögűzés megfelelő rítusait, meggondolatlan cselekedeteik véletlenül megszállási járványt indítanak el a vidéki közösségben. El kell menekülniük a támadó gonosz elől, amely mindenkit megront és megcsonkít, akivel kapcsolatba kerül, és segítségül kell hívniuk egy bölcs „tisztítót”, akinél az egyetlen eszköz van, amely megállíthatja ezt a természetfeletti járványt."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"وقتی شیطان در کمین است","runtime":0,"tagline":"دعا کردن سودی ندارد.","homepage":"","overview":"ساکنان یک شهر کوچک روستایی متوجه می‌شوند که یک شیطان در حال تولد در میان آن‌ها است. آنها ناامیدانه سعی می‌کنند قبل از تولد شیطان فرار کنند، اما ممکن است خیلی دیر شده باشد."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Ác Quỷ Ẩn Mình","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"When Evil Lurks","runtime":0,"tagline":"Pregare non vi salverà","homepage":"","overview":"Gli abitanti di un piccolo paese rurale scoprono che tra loro sta per nascere un demone. Tentano disperatamente di scappare prima che nasca il male, ma potrebbe essere troppo tardi."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Kad zlo vreba","runtime":0,"tagline":"","homepage":"","overview":"U udaljenom selu, dva brata pronalaze čovjeka zaraženog demonom, koji je postao savršena ljuštura za rađanje zla. Odluče se riješiti tijela, ali time samo šire kaos."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"","runtime":100,"tagline":"No tiene sentido orar.","homepage":"","overview":"Los vecinos de un pequeño pueblo rural descubren que un demonio está a punto de nacer entre ellos. Intentan desesperadamente escapar antes de que nazca el mal, pero puede que sea demasiado tarde."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Gdy rodzi się zło","runtime":0,"tagline":"Żadna modlitwa Ci nie pomoże.","homepage":"","overview":"Mieszkańcy małego wiejskiego miasteczka odkrywają, że demon ma się narodzić pośród nich. Rozpaczliwie próbują uciec, zanim zło się narodzi, ale może być już za późno."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"邪染小鎮","runtime":0,"tagline":"","homepage":"","overview":"謎樣巨響劃破鄉野的寧靜暗夜，農場主人佩德羅兄弟淸早出門探勘，只見身分不明的半截屍首倒臥血泊，切口整齊俐落。是他殺還是意外？兄弟循線前往鄰近人家，卻發現可疑份子早已臥病床上，身體腫脹、膿血俱流。沾染魔疫腐爛的身軀驅動恐懼，敎會也無能為力。深怕詛咒蔓延，佩德羅兄弟計畫將之搬離，卻忘記遵守古老禁忌：不要使用電燈、不要靠近動物、不要帶走任何靠近被附身者的東西、不要傷害他們⋯⋯。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Quando o Mal Espreita","runtime":99,"tagline":"","homepage":"","overview":"Moradores de uma pequena cidade rural descobrem que um demónio está prestes a nascer entre eles. Eles tentam desesperadamente escapar antes que o mal nasça, mas pode ser tarde demais."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"악이 도사리고 있을 때","runtime":100,"tagline":"그것은 우리 가까이에 있다","homepage":"","overview":"외딴 마을, 잔혹한 살인 사건의 실마리를 쫓던 형제는 마을 속에 숨어 지내는 한 가족이 관련된 것을 알게 된다. 악령이 깃들어 온몸이 부패해 죽어가는 아들 ‘유리엘’을 숨겨왔던 것. 두 형제는 ‘유리엘’을 마을 밖으로 유기하려 하지만 이미 악령의 봉인이 풀리고 마을을 잠식하는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"في قرية بعيدة ومعزولة، يكتشف شقيقين انتشار الشياطين والشر بالمنطقة هناك، فيصبح عليهما التعاون من أجل تطهير القرية من الدمار الشيطاني."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Pedro ve Jimmy kardeşler, yakınlardaki bir çiftlik evinde şeytani bir enfeksiyonun büyüdüğünü keşfettiklerinde kurbanı topraklarından çıkarmaya çalışırlar. Uygun şeytan çıkarma ayinlerine uymayan bu kişilerin pervasız eylemleri, istemeden de olsa kırsal topluluklarında bir mal mülk salgınını tetikler. Artık maruz kaldıkları herkesi yozlaştıran ve sakat bırakan, yaklaşmakta olan bir kötülükten kaçmaları ve bu doğaüstü vebayı durdurabilecek tek araçları elinde bulunduran büyümüş bir \"temizleyicinin\" yardımına başvurmaları gerekir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"When Evil Lurks","runtime":99,"tagline":"","homepage":"","overview":"In der argentinischen Provinz ist Aberglaube tief verankert. Bei den Brüdern Pedro und Jimi führt er zu nackter Panik, als sie in ihrer unmittelbaren Nachbarschaft einen furchtbar entstellten Mann finden, der in seinem Bett bei lebendigem Leib verrottet. Er muss von einem Dämon besessen sein! Doch wie wird man das blutrünstige Wesen aus den Tiefen der Hölle los, wenn sieben strenge Regeln jede Intervention unmöglich machen und der bestellte Exorzist zerfetzt in den Büschen liegt? Ihr verzweifelter Versuch, das Böse abzuwenden, führt in die Katastrophe. Denn es kennt kein Erbarmen, mit nichts und niemandem."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Ko je zlo na preži","runtime":0,"tagline":"Nima smisla moliti.","homepage":"","overview":"V majhnem podeželskem mestaecu dva brata najdeta z demoni okuženega človeka, ki je postal popoln zapredek za rojstvo zla. Odločita se, da se bosta znebila telesa, toda s tem samo širita kaos. Prebivalci obupano poskušajo pobegniti preden se to zlo rodi, a je morda že prepozno."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"When Evil Lurks","runtime":100,"tagline":"","homepage":"","overview":"Inwoners van een klein plattelandsstadje ontdekken dat er onder hen een demon geboren zal worden. Ze proberen wanhopig te ontsnappen voordat het kwaad geboren wordt, maar het kan te laat zijn."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"כשהרוע אורב","runtime":0,"tagline":"","homepage":"","overview":"תושבי עיירה כפרית קטנה מגלים שד עומד להיוולד ביניהם. הם מנסים נואשות לברוח לפני שהרוע נולד, אבל זה עלול להיות מאוחר מדי."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"When Evil Lurks – paha vaanii","runtime":99,"tagline":"","homepage":"","overview":""},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Εκεί που το Κακό Παραμονεύει","runtime":0,"tagline":"","homepage":"","overview":"Όταν τα αδέλφια Πέδρο και Τζίμι ανακαλύπτουν ότι μια δαιμονική οντότητα έχει στοιχειώσει ένα κοντινό αγροτόσπιτο δηλητηριάζοντας ταυτόχρονα τα ζώα της τριγύρω περιοχής, αποφασίζουν να προσπαθήσουν να την εκδιώξουν από τη γη τους. Όμως, η προσπάθειά τους αυτή θα προκαλέσει μεγαλύτερο κακό και οι απερίσκεπτες ενέργειές τους πυροδοτούν άθελά τους μια επιδημία δαιμονισμών στην κοινότητα. Τώρα, πρέπει να βρουν τρόπο να γλιτώσουν από το κακό, όσο αυτό διαφθείρει όποιον βρεθεί σε επαφή μαζί του. Για να τα καταφέρουν, θα ζητήσουν τη βοήθεια ενός βετεράνου εξορκιστή, ο οποίος είναι και ο μόνος που φαίνεται να ξέρει πώς μπορούν να σταματήσουν αυτή την υπερφυσική επιδημία. Όμως, θα καταλάβουν ότι κανείς δεν είναι ασφαλής - και κανείς δεν είναι αθώος…"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"ปีศาจ ลวง ตาย","runtime":0,"tagline":"","homepage":"","overview":"เมื่อสองพี่น้องเปโดร (เอเซเกียล โรดริเกซ) และจิมมี่ (เดเมียน ซาโลมอน) พบว่ามีการติดเชื้อจากปีศาจกำลังแพร่ระบาดอยู่ในบ้านไร่ใกล้เคียง ซึ่งมันเป็นพิษต่อปศุสัตว์ในท้องถิ่น พวกเขาพยายามขับไล่เหยื่อออกจากที่ดินของพวกเขา การไม่ปฏิบัติตามพิธีกรรมไล่ผีที่เหมาะสม การกระทำที่ประมาทของพวกเขาทำให้เกิดการแพร่กระจายของมันไปทั่วชุมชนในชนบทโดยไม่ได้ตั้งใจ ตอนนี้พวกเขาต้องวิ่งหนีความชั่วร้ายที่รุกล้ำเข้ามา ในขณะที่มันสร้างความเสียหายและทำลายล้างทุกคนที่ถูกเผชิญอยู่ พวกเขาต้องขอความช่วยเหลือจาก “ผู้เก็บกวาด” ที่ชั่วร้ายซึ่งกุมเครื่องมือเดียวที่สามารถหยุดยั้งโรคระบาดเหนือธรรมชาตินี้ได้"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"When Evil Lurks","runtime":0,"tagline":"","homepage":"","overview":"Bröderna Pedro och Jimi upptäcker en man besatt av en demon i deras lilla landsbygdsby. Mot bättre vetande bestämmer de sig för att göra sig av med kroppen, men utan att fördriva demonen ur kroppen sprider sig i stället förbannelsen. When Evil Lurks är en psykologisk folk horror-sägen som hyllats av kritiker och jämförts med John Carpenter, George Romero och Dario Argento."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Après avoir découvert un cadavre mutilé près de leur propriété, deux frères apprennent que les événements étranges survenant dans leur village sont causés par un esprit démoniaque qui a élu domicile dans le corps purulent d’un homme. Le mal dont souffre ce dernier ne tarde pas à se répandre comme une épidémie, affectant d’autres habitants de la région."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"邪染小鎮","runtime":0,"tagline":"","homepage":"","overview":"謎樣巨響劃破鄉野的寧靜闇夜，農場主人佩德羅兄弟淸早出門探勘，只見身分不明的半截屍首倒卧血泊，切口整齊俐落。是他殺還是意外？兄弟循線前往鄰近人家，卻發現可疑份子早已卧病床上，身體腫脹、膿血俱流。沾染魔疫腐爛的身軀驅動恐懼，敎會也無能為力。深怕詛咒蔓延，佩德羅兄弟計畫將之搬離，卻忘記遵守古老禁忌：不要使用電燈、不要靠近動物、不要帶走任何靠近被附身者的東西、不要傷害他們⋯⋯。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Tykantis blogis","runtime":100,"tagline":"","homepage":"","overview":"Beveik negyvas, groteskiškai ištinęs ir dvokiantis vyras guli Argentinos kaime ir aimanuoja, trokšdamas mirties. Jį apsėdo demonas. Norėdami užkirsti kelią sklindančiam blogiui, broliai Pedras ir Jimis nutempia jį į sunkvežimį, kad išgabentų kuo toliau nuo savų žemių."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Когато злото дебне","runtime":0,"tagline":"","homepage":"","overview":"Двама братя откриват обезобразено тяло до своята ферма и събират местното население да обсъдят какво да правят. Скоро научават, че всички тези странни събития, които се случват в селото им в последно време, се дължат на демон, вселил се в тялото на местен мъж. Той изчаква да се одобри процедурата по премахване на нежеланото създание. Следват опити за бягство, които държат протагонистите на ръба в желанието им да се измъкнат от ноктите на злото."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"邪悪なるもの","runtime":100,"tagline":"","homepage":"","overview":"悪魔に魂を乗っ取られて身体が腐敗する「悪魔憑き」の存在が、人々の生活に暗い影を落としている世界。悪魔憑きは処理人によって適切に処理されなければならず、古くから伝わる7つのルールを守らなければ、悪魔の力が伝染病のように広がって世界は終わりを迎えるという。ある日、ペドロとジミーの兄弟は村外れで変死体を発見し、さらに近隣の住民が家族に出た悪魔憑きを隠していることに気づく。兄弟は7つのルールに従って対処しようとするが、伝承を信じない人々の無謀な行動によってタブーが犯され、周囲は悪魔憑きで溢れかえってしまう。愛する家族を守るべく、姿の見えない悪がはびこるアルゼンチンをさまよう兄弟だったが……。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"}],"reviews_tmdb":[{"id":"654419b56beaea014b66763a","url":"https://www.themoviedb.org/review/654419b56beaea014b66763a","author":"MovieGuys","content":"I can see what When Evil Lurks is trying to achieve. Its an alternate take on reality, a horror infused, supernatural world, where demonic possession is an accepted occurrence. \r\n\r\nIts done convincingly, with an everyday vibe, where a possession event is akin to a serious crime or perhaps, a natural disaster. The problem is, the treatment is deeply, violently disturbing, to the point where you start to ask if this is, in fact, adding value as a creative work?\r\n\r\nIts a subjective point but I found this one too brutal and shocking, for me to really say I found it compelling. I think too, a more subtle approach could have been taken, with better results in terms of watch-ability.\r\n\r\nIn summary, makes the outlandishly otherworldly everyday, in a convincing manner but the delivery is on the heavy handed side of horror, to say the least.","created_at":"2023-11-02T21:50:45.315Z","updated_at":"2023-11-02T21:52:42.643Z","author_details":{"name":"","rating":6,"username":"MovieGuys","avatar_path":null}},{"id":"658c71f02716717128a5353a","url":"https://www.themoviedb.org/review/658c71f02716717128a5353a","author":"Chandler Danier","content":"Really hits with the catholic horror hard. Fades, though. There's only so many demons before they don't matter. Really enjoyable for an hour...some people to chat with for the last leg of slaying would be ideal.","created_at":"2023-12-27T18:50:24.091Z","updated_at":"2023-12-27T18:52:42.570Z","author_details":{"name":"Chandler Danier","rating":7,"username":"chandlerdanier","avatar_path":null}},{"id":"66d61b587d583dc4897e4214","url":"https://www.themoviedb.org/review/66d61b587d583dc4897e4214","author":"tmdb51616167","content":"$11","created_at":"2024-09-02T20:08:56.318Z","updated_at":"2024-09-03T03:38:35.614Z","author_details":{"name":"","rating":3,"username":"tmdb51616167","avatar_path":null}}],"recommendations":[{"id":1131755,"adult":false,"title":"A Creature Was Stirring","video":false,"overview":"A nurse taking care of her daughter's mysterious affliction struggles to hide her secrets when uninvited strangers take shelter in her house during a lethal blizzard.","genre_ids":[27],"media_type":"movie","popularity":0.5375,"vote_count":72,"poster_path":"/ikQG3byEFyfwcnF0zmyNtXTmr5v.jpg","release_date":"2023-12-08","vote_average":5.694,"backdrop_path":"/uvqf3e451hBviQiCvPx4lapVOKf.jpg","original_title":"A Creature Was Stirring","original_language":"en"},{"id":1010928,"adult":false,"title":"Wingwomen","video":false,"overview":"Tired of life on the run, a pro thief decides to retire — but not before one easy last job with her partner in crime and a feisty new getaway driver.","genre_ids":[28,35,18],"media_type":"movie","popularity":3.71,"vote_count":498,"poster_path":"/atatNvrn7kBvkARD2YodyYkKicr.jpg","release_date":"2023-11-01","vote_average":6.087,"backdrop_path":"/micMmUVPwGzw6lqzy96xmCgYxNL.jpg","original_title":"Voleuses","original_language":"fr"},{"id":489430,"adult":false,"title":"Terrified","video":false,"overview":"Police commissioner Funes and three researchers of supernatural phenomena investigate inexplicable events that are occurring in the suburbs of Buenos Aires.","genre_ids":[27],"media_type":"movie","popularity":4.538,"vote_count":789,"poster_path":"/eMP4F0POBgrB4icn6XgYeLLIrld.jpg","release_date":"2018-05-03","vote_average":6.703,"backdrop_path":"/wCCvFSOlzgWCySJH3HUHcEbAexa.jpg","original_title":"Aterrados","original_language":"es"},{"id":1081662,"adult":false,"title":"Appendage","video":false,"overview":"After hitting a breaking point, Hannah's inner thoughts physicalize into a monstrous creature that threatens to upend her life.","genre_ids":[27],"media_type":"movie","popularity":0.8314,"vote_count":174,"poster_path":"/xBlYO5Pih92UKBN3mYUh8Ptiqh2.jpg","release_date":"2023-03-11","vote_average":5.598,"backdrop_path":"/8BNA9L3JEJeMN7S21fzo9SeYUtU.jpg","original_title":"Appendage","original_language":"en"},{"id":965890,"adult":false,"title":"Vincent Must Die","video":false,"overview":"Vincent finds himself under attack for no apparent reason overnight. When the phenomenon intensifies, he must run and change his way of life completely.","genre_ids":[18,14,53],"media_type":"movie","popularity":1.1304,"vote_count":203,"poster_path":"/ztghAnb7nuhZ6q11cx1F9gBAJ6m.jpg","release_date":"2023-11-15","vote_average":6.3,"backdrop_path":"/32E8LziFHOD1xEtVh5tXpUBR93R.jpg","original_title":"Vincent doit mourir","original_language":"fr"},{"id":1056380,"adult":false,"title":"The Coffee Table","video":false,"overview":"Jesus and María are a couple going through a difficult time in their relationship. Nevertheless, they have just become parents. To shape their new life, they decide to buy a new coffee table. A decision that will change their existence.","genre_ids":[27,53,18,35],"media_type":"movie","popularity":2.0576,"vote_count":278,"poster_path":"/r8S7cc676EfgfUDVQKPrqRlbRFz.jpg","release_date":"2023-11-30","vote_average":6.915,"backdrop_path":"/7mij6m3a2rmaj7SvQf1dPyu7mqZ.jpg","original_title":"La mesita del comedor","original_language":"es"},{"id":724665,"adult":false,"title":"Confess, Fletch","video":false,"overview":"The roguishly charming and endlessly troublesome Fletch becomes the prime suspect in a murder case while searching for a stolen art collection. The only way to prove his innocence? Find out which of the long list of suspects is the culprit - from the eccentric art dealer and a missing playboy to a crazy neighbor and Fletch’s Italian girlfriend. Crime, in fact, has never been this disorganized.","genre_ids":[35,9648,80],"media_type":"movie","popularity":1.9007,"vote_count":378,"poster_path":"/h2oyiPu7aql1s1mLDoKBNAH7p3B.jpg","release_date":"2022-09-16","vote_average":6.224,"backdrop_path":"/3xGfsAYAxVmYj1CbE5vAkmMJbHo.jpg","original_title":"Confess, Fletch","original_language":"en"},{"id":842675,"adult":false,"title":"The Wandering Earth II","video":false,"overview":"Humans built huge engines on the surface of the earth to find a new home. But the road to the universe is perilous. In order to save earth, young people once again have to step forward to start a race against time for life and death.","genre_ids":[878,28,12],"media_type":"movie","popularity":4.5949,"vote_count":692,"poster_path":"/jAZzFYS36UFT0SKhKVmEY7qShal.jpg","release_date":"2023-01-22","vote_average":7.288,"backdrop_path":"/94cS0mzODEoNIXFT7nhPcI8V4IJ.jpg","original_title":"流浪地球2","original_language":"zh"},{"id":10523,"adult":false,"title":"W.","video":false,"overview":"The story of the eventful life of George W. Bush—his struggles and triumphs, how he found both his wife and his faith—and the critical days leading up to his decision to invade Iraq.","genre_ids":[18,36],"media_type":"movie","popularity":1.6394,"vote_count":670,"poster_path":"/nJm8UF4zbUYEoku9seEtz1PTJGS.jpg","release_date":"2008-10-17","vote_average":6.2,"backdrop_path":"/xly3gFyw440fmety8emBYXthyoS.jpg","original_title":"W.","original_language":"en"},{"id":1273678,"adult":false,"title":"We Need to Talk","video":false,"overview":"A woman in common, a daughter in half and a patrol car for two. Antonio and Pieraldo share many things: a less-than-brilliant career, a less-than-ideal partnership, a long-term but slightly bruised bond -- two lives apparently too quiet for two police officers that fate has cleverly wanted to intertwine. Danger was definitely not their profession... until, incredibly, they will have to face a real crime, a very intricate and risky case that, between challenges against time and twists, will change their lives forever.","genre_ids":[35,80],"media_type":"movie","popularity":0.2106,"vote_count":86,"poster_path":"/kD3IRg28Wqcm9VYpdFYbtZc4Q27.jpg","release_date":"2024-12-19","vote_average":5.157,"backdrop_path":"/4ozuEQbaanAPUl0K438XLP4tuFy.jpg","original_title":"Io e te dobbiamo parlare","original_language":"it"},{"id":934131,"adult":false,"title":"Soft & Quiet","video":false,"overview":"Taking place in real time, elementary school teacher Emily organizes a mixer of like-minded women, but an altercation between a woman from Emily’s past and the group leads to a volatile chain of events.","genre_ids":[27,53],"media_type":"movie","popularity":1.1058,"vote_count":202,"poster_path":"/atNLWJm8KO44xeVGxG4LAByr5tm.jpg","release_date":"2022-11-04","vote_average":6.426,"backdrop_path":"/aAK25IGWGCk33c2rO2eYcek9rIB.jpg","original_title":"Soft & Quiet","original_la