5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Daughter of Darkness\",\"description\":\"The police suspect a young teenager who was horrifically abused by her family and raped by her father of finally snapping and slaughtering them all.\",\"image\":\"https://image.tmdb.org/t/p/w500/2ggoyYfBIMD3WbHj36Qlr7wgyFV.jpg\",\"datePublished\":\"1993-10-28\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"zh\",\"genre\":[\"horror film\",\"rape and revenge film\",\"Thriller\",\"Horror\",\"Comedy\",null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.333,\"bestRating\":10,\"ratingCount\":27}}"}}],["$","$L10",null,{"initialDrama":{"id":"a3587748-6025-4cf1-935d-333d5349c173","tmdb_id":80794,"imdb_id":"tt0107572","content_type":"movie","title":"Daughter of Darkness","original_title":"滅門慘案之孽殺","overview":"The police suspect a young teenager who was horrifically abused by her family and raped by her father of finally snapping and slaughtering them all.","poster_path":"/2ggoyYfBIMD3WbHj36Qlr7wgyFV.jpg","backdrop_path":"/AFz4opHapnKfpZgdZ2v6dQ1LoM.jpg","release_date":"1993-10-28","first_air_date":null,"status":"published","original_language":"zh","origin_country":["HK"],"genres":[{"name":"horror film"},{"name":"rape and revenge film"},{"id":53,"name":"Thriller"},{"id":27,"name":"Horror"},{"id":35,"name":"Comedy"},"horror film","rape and revenge film"],"popularity":3.7736,"vote_average":5.333,"vote_count":27,"runtime":96,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:52:16.251768+00:00","updated_at":"2026-02-21T08:13:51.421+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":72157,"name":"Scholar Films Co., Ltd.","logo_path":null,"origin_country":""},{"id":96797,"name":"Martini Film Company Ltd.","logo_path":null,"origin_country":""},{"id":4054,"name":"Mandarin Films","logo_path":"/3FRmZA2Mizdncwk8pqgy27xXjhP.png","origin_country":"HK"}],"production_countries":[{"name":"Hong Kong","iso_3166_1":"HK"}],"spoken_languages":[{"name":"广州话 / 廣州話","iso_639_1":"cn","english_name":"Cantonese"},{"name":"普通话","iso_639_1":"zh","english_name":"Mandarin"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[{"id":570,"name":"rape"},{"id":9748,"name":"revenge"},{"id":11925,"name":"domestic violence"},{"id":33841,"name":"incest"}],"alternative_titles":[{"type":"","title":"Daughter of Darkness","iso_3166_1":"HK"},{"type":"","title":"쇼킹홍콩2","iso_3166_1":"KR"},{"type":"","title":"滅門慘案之孽殺","iso_3166_1":"TW"},{"type":"","title":"灭门惨案之孽杀","iso_3166_1":"CN"}],"videos":[],"watch_providers":{"results":{}},"wikidata_id":"Q16237432","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/oTKI3V3ohM4cJ4nrbcFJ37OC8qY.jpg","images":{"logos":[],"posters":[{"width":530,"height":763,"file_path":"/oTKI3V3ohM4cJ4nrbcFJ37OC8qY.jpg","iso_639_1":"zh","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/2ggoyYfBIMD3WbHj36Qlr7wgyFV.jpg","iso_639_1":"en","vote_average":3.334},{"width":775,"height":1080,"file_path":"/44q3cWqxnu1uGcJK0bCbgStrGKb.jpg","iso_639_1":"zh","vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/AFz4opHapnKfpZgdZ2v6dQ1LoM.jpg","iso_639_1":null,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/slEhRBD3PxvbA5H3vGEunP0hziy.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/AezmXyAMoTMoVgvpjExMukWD8vE.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T08:06:33.331+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Daughter of Darkness","runtime":96,"tagline":"","homepage":"","overview":"The police suspect a young teenager who was horrifically abused by her family and raped by her father of finally snapping and slaughtering them all."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"灭门惨案之孽杀","runtime":90,"tagline":"","homepage":"","overview":"阿惠（钟淑慧 饰）是家中的养女，因此每日过着寄人篱下的压抑生活，某日，养父阿麦（何家驹 饰）喝醉了酒，在醉意朦胧之中，他竟然丧尽天良地将阿惠强暴。受辱后的阿惠在家中孤立无援，便想到了男友阿奇（吴岱融 饰），然而，看到阿奇深爱自己的样子，于心不忍的阿惠选择了隐瞒实情。强暴事件之后，阿麦对于阿惠的骚扰变本加厉，他以阿惠的裸照相威胁，两人纠缠之际刚好被阿奇看到。愤怒的阿奇开枪打伤了阿麦后被击晕。愤怒之中，阿惠拾起枪将全家人杀死，后前往警局自首，将一切罪过揽到了自己身上，然而，接待她的警察在得知了实情之后对阿惠动了恻隐之心。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"La policía sospecha de un joven adolescente que fue maltratado horriblemente por su familia y violado por su padre de por fin asesinarlos y matarlos a todos."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Daughter of Darkness","runtime":96,"tagline":"DAUGHTER OF DARKNESS","homepage":"","overview":"Après avoir été violé par son père, l'adolescente Mak Wei-Fong décide de se venger contre sa famille abusive qui a gardé le silence sur cet acte et ainsi sauver la relation avec son petit ami."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Daughter of Darkness","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"어둠의 딸","runtime":0,"tagline":"","homepage":"","overview":"뤼 반장이 딸 하나만 남겨 놓고 하루아침에 일가족이 전부 몰살당한 사건을 맡는다. 진범은 아주 나쁜 놈도 아니고 집에서 천대받다가 색정광 아버지한테 덮쳐져 순결을 잃고 또 한 번 굴욕을 당하다 머리가 돌아버려 가족들을 몰살시킨 아방이다. 모든 걸 털어놓은 아방이 사형을 구형 받고 죽기 직전 출산이 허가되어 자식을 낳은 다음 남편과 함께 사진을 찍는다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Daughter of Darkness","runtime":0,"tagline":"","homepage":"","overview":"Policie podezírá mladou teenagerku, kterou její rodina strašlivě týrala a otec znásilňoval, že se nakonec zlomila a všechny je povraždila."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Diệt Môn Thảm Án 1","runtime":0,"tagline":"","homepage":"","overview":"Cảnh sát nghi ngờ một thiếu nữ bị gia đình ngược đãi khủng khiếp và bị cha mình cưỡng hiếp đã nổi cơn thịnh nộ và giết chết tất cả bọn họ."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"De politie verdenkt een jonge tiener, die op gruwelijke wijze werd misbruikt door haar familie en verkracht door haar vader, ervan dat ze ze uiteindelijk allemaal heeft afgemaakt en afgeslacht."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"滅門慘案之孽殺","runtime":0,"tagline":"","homepage":"","overview":"惠芳(鍾淑慧飾)為麥家養女，麥家一家四口把她當女傭使喚，唯一關心她的人就只有男友健(吳岱融) ，一日惠芳養父麥泉(何家駒飾) 借酒醉強暴惠芳，並強行拍下裸照，而惠芳只好投靠男友健，因怕被健看不起，惠芳並沒有將強暴之事告訴健，不料麥泉卻食髓其味，竟拿裸照威脅惠芳回麥家並再度強姦，麥全妻子與兒子也都支持強暴行動並參與其中，惠芳忍無可忍，發狂殺死養父全家並自首下獄。在獄中惠芳生下阿健孩子後槍斃處決，結束悽苦的一生。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"滅門慘案之孽殺","runtime":98,"tagline":"","homepage":"","overview":"惠芳（鍾淑慧飾）為麥家養女，麥家一家四口把她當女傭使喚，唯一關心她的人就只有男友健（吳岱融），一日惠芳養父麥泉（何家駒飾） 借酒醉強暴惠芳，並強行拍下裸照，而惠芳只好投靠男友健，因怕被健看不起，惠芳並沒有將強暴之事告訴健，不料麥泉卻食髓其味，竟拿裸照威脅惠芳回麥家並再度強姦，麥全妻子與兒子也都支持強暴行動並參與其中，惠芳忍無可忍，發狂殺死養父全家並自首下獄。在獄中惠芳生下阿健孩子後槍斃處決，結束悽苦的一生。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Fica întunericului","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"}],"reviews_tmdb":[],"recommendations":[{"id":83960,"adult":false,"title":"The Eternal Evil of Asia","video":false,"overview":"A fun-filled trip to Thailand turns out to be a deadly one for four best friends when they accidentally killed the sister of a local sorcerer. When one of them mysteriously died upon returning the remaining trio discovers that a curse has been cast upon them. They must turn to a Thai magician for help.","genre_ids":[28,14,27],"media_type":"movie","popularity":1.7768,"vote_count":22,"poster_path":"/2TOtVUmSUzXEpweCJzMxOKXMKYf.jpg","release_date":"1995-08-04","vote_average":4.6,"backdrop_path":"/qnFICToRFW0x8JJQYzlfsyqGD5d.jpg","original_title":"南洋十大邪術","original_language":"cn"},{"id":149180,"adult":false,"title":"Taste of Vengeance","video":false,"overview":"A group of Northern vigilantes, roaming the post Civil War south, attack and kill the fiancee of war veteran Brian, who is rescued by his friend, Daniel. The two, with brother Robert, set out to find the killers. But Brian, suffering from amnesia and becoming frustrated with not remembering the killer's faces, starts killing at random and loses the support of his two partners.","genre_ids":[37],"media_type":"movie","popularity":0.2652,"vote_count":4,"poster_path":"/aW9pl8pxJr7yP8Osaq5VNCI1D0K.jpg","release_date":"1968-04-02","vote_average":5.8,"backdrop_path":"/lL8SmsLf0DJbjQgWUotCEd3WCoo.jpg","original_title":"I vigliacchi non pregano","original_language":"it"},{"id":79329,"adult":false,"title":"Treevenge","video":false,"overview":"Treevenge details the experiences and horrifying reality of the lives of Christmas trees. Clearly, for trees, Christmas isn’t the exciting “peace on earth” that is experienced by most. After being hacked down, and shipped away from their homes, they quickly become strung up, screwed into an upright position for all to see, exposed in a humiliation of garish decorations. But this Christmas will be different, this Christmas the trees have had enough, this Christmas the trees will fight back. Treevenge could be a short film about the end of days for Christmas trees, or perhaps, the end of humanity?","genre_ids":[27,35],"media_type":"movie","popularity":0.1384,"vote_count":76,"poster_path":"/f6CSUFegpqyvG7k5y3pUnpikAH1.jpg","release_date":"2008-07-07","vote_average":6.599,"backdrop_path":"/x4LIiJtae15SkoGDKOBb6jWZs2g.jpg","original_title":"Treevenge","original_language":"en"},{"id":718314,"adult":false,"title":"FILM","video":false,"overview":"A boy walks through an abandoned building and films the interior. Suddenly his camera disappears.","genre_ids":[],"media_type":"movie","popularity":0.2159,"vote_count":11,"poster_path":"/pMjTLiyPKs0kPlG8S3LS2zySqrp.jpg","release_date":"2020-04-18","vote_average":7.2,"backdrop_path":"/iiwWSq6pQmaEnIX5FYGg2uWe5qH.jpg","original_title":"FILM","original_language":"en"},{"id":1165067,"adult":false,"title":"Cosmic Chaos","video":false,"overview":"Battles in virtual reality, survival in a post-apocalyptic wasteland, a Soviet spaceship giving a distress signal - Fantastic stories created with advanced special effects and passion.","genre_ids":[53,878],"media_type":"movie","popularity":1.5069,"vote_count":50,"poster_path":"/mClzWv7gBqgXfjZXp49Enyoex1v.jpg","release_date":"2023-08-03","vote_average":6,"backdrop_path":"/m2mzlsJjE3UAqeUB5fLUkpWg4Iq.jpg","original_title":"Cosmic Chaos","original_language":"en"},{"id":1136573,"adult":false,"title":"Man","video":false,"overview":"An experimental film through the eyes of a man","genre_ids":[18],"media_type":"movie","popularity":0.113,"vote_count":31,"poster_path":"/fRCD2RMKIHI5dhxsboehhpJ3ZJt.jpg","release_date":"2022-07-26","vote_average":6.9,"backdrop_path":null,"original_title":"Man","original_language":"en"},{"id":1149381,"adult":false,"title":"Soulcatcher","video":false,"overview":"A military contractor hired to seize a weapon that turns people into savage killers seeks revenge when his brother falls victim to the device.","genre_ids":[28,53],"media_type":"movie","popularity":0.8987,"vote_count":283,"poster_path":"/l1f9JSPjCfNftigEii1SDK1g2b3.jpg","release_date":"2023-08-02","vote_average":6.348,"backdrop_path":"/oPYJ1artbj7x8zgpJJkQMp0mNTW.jpg","original_title":"Operacja: Soulcatcher","original_language":"pl"},{"id":587727,"adult":false,"title":"Busty Girlfriend","video":false,"overview":"Mincheol and Suhee go to greet Minchul father (grandmother) before marriage. Dae - sik welcomes her daughter - in - law, Su - hee. But before marriage, Minchol and Suhee are separated by the difference in personality. Soon-hee, who was only preparing for marriage, is soon to live.","genre_ids":[10749],"media_type":"movie","popularity":3.0693,"vote_count":35,"poster_path":"/f6PfAXtFEkJRcBtOjbzOgz8qqSK.jpg","release_date":"2019-03-08","vote_average":7.3,"backdrop_path":"/zQKFPx03M9RKfEcRETXR2HoUZn1.jpg","original_title":"가슴 큰 여자친구","original_language":"ko"},{"id":588207,"adult":false,"title":"Alien: Containment","video":false,"overview":"Aboard a small escape pod, four survivors try to discover what caused the destruction of their spaceship.","genre_ids":[18,27,878],"media_type":"movie","popularity":2.1482,"vote_count":59,"poster_path":"/Au2rDB47SuP0U0y3MV8awoCO8qd.jpg","release_date":"2019-03-15","vote_average":6.076,"backdrop_path":"/wDhUsYN1Yk2wQufyFIq7gwIBlsq.jpg","original_title":"Alien: Containment","original_language":"en"},{"id":744234,"adult":false,"title":"John","video":false,"overview":"John tells the story of a young male, a psychiatric hospital patient who witnesses the death of another Black male patient at the hands of white staff. Blurring the boundaries between fact and fiction, this work draws from real life cases of mentally ill Black men who have died as a result of excessive force of the State.","genre_ids":[99],"media_type":"movie","popularity":0.0821,"vote_count":13,"poster_path":null,"release_date":"2020-09-17","vote_average":7.3,"backdrop_path":"/f2OZIyRsbE3uJ1UMVnGVDcSNtNX.jpg","original_title":"John","original_language":"en"},{"id":850880,"adult":false,"title":"Sayen: Desert Road","video":false,"overview":"Sayen follows a lead to the picturesque desolation of the Atacama De