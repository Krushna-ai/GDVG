":2000,"height":3000,"file_path":"/qOORhXp73GxPODFP2W22HTC6Sh4.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/yDeUwpZuuSHdv97vnixvk8M19Zr.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":800,"height":1138,"file_path":"/zEztQZhrA8SgAhQU1CYXl6LtlD7.jpg","iso_639_1":"bg","iso_3166_1":"BG","vote_count":0,"aspect_ratio":0.703,"vote_average":0},{"width":800,"height":1138,"file_path":"/rSWYehiizbsLhnplYQvB9HSH8Go.jpg","iso_639_1":"bg","iso_3166_1":"BG","vote_count":0,"aspect_ratio":0.703,"vote_average":0},{"width":1929,"height":2895,"file_path":"/s6xi1xrmnpfe79xjD1CbrZ4KqZx.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.666,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/s1r2aBDzkvlFkNnAgxWFTCQjKPe.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/6dUjU7doTgVxK9LKLn9OteZMEy8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/4RQ8grLKRjc3FzkCodrVWGTuClM.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/odGKYca6qO7xwWNLgrhDeFCZPzC.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1849,"height":1040,"file_path":"/bc2NRXbA3hc1OAhpyWMeX3pBtbM.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/4YEsGAC8u0fudbgMmxL20DXVW9p.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/2RF6Z6ilavjBJhj95PEQO1XbPN1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/3o0ZKwrPnsHDjirh5fBR88hMGlp.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/wkOSyBt7HwDcsraeF6kpqSK0ap5.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1600,"height":900,"file_path":"/bLZWfZHDUw1wqdWZLWAcLvTDlbJ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:36:04.861+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":148,"tagline":"You don't choose your family. We all belong to somebody, but to belong to Uxbal and Marambra, is both a blessing and a curse.","homepage":"http://www.biutiful-themovie.com/","overview":"This is a story of a man in free fall. On the road to redemption, darkness lights his way. Connected with the afterlife, Uxbal is a tragic hero and father of two who's sensing the danger of death. He struggles with a tainted reality and a fate that works against him in order to forgive, for love, and forever."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Бьютифул","runtime":0,"tagline":"","homepage":"","overview":"Разведенный отец двоих детей Уксбаль — свой человек в теневом мире Барселоны. Для правоохранительных органов он — нарушитель закона; для нелегальных иммигрантов, которым помогает получить работу, — добрый ангел. Узнав, что неизлечимо болен, Уксбаль начинает готовиться к смерти, размышляя о минувшем и улаживая дела в настоящем. И тут за расследование преступной деятельности героя берется его друг детства, а ныне — офицер полиции…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Biutiful","runtime":150,"tagline":"","homepage":"","overview":"Elokuvan päähenkilö Uxbal on Barcelonan pimeällä puolella luoviva pikkurikollinen ja yksinhuoltaja. Hänen lastensa äiti on hermoherkkä alkoholisti, jolla on suhde Uxbalin veljen kanssa. Uxbal saa kuulla olevansa kuolemansairas ja pyyteettömästi yrittää parhaansa mukaan laittaa asiat kuntoon julmassa maailmassa ennen kuolemaansa."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"","runtime":148,"tagline":"","homepage":"","overview":"Uxbal schlägt sich in Barcelonas Untergrund mit unsauberen Jobs durch. Er hat dabei aber immer das Wohlergehen seiner beiden Kinder Ana und Mateo im Sinn, die er mit unendlicher Zuneigung großzieht. Ihre Mutter Marambra liebt er zwar immer noch, ein Zusammenleben scheint jedoch unmöglich. Wie ein Wanderer bewegt sich Uxbal zwischen den Welten, auf der Suche nach Versöhnung mit seiner Frau, seinen Kindern und doch letztendlich mit sich selbst."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"Tú no eliges a tu familia. Todos somos de alguien, pero pertenecer a Uxbal y Marambra es tanto una bendición como una maldición.","homepage":"","overview":"Retrato de la vida de Uxbal: padre abnegado e hijo desamparado. Intermediario de la sombra. Próximo a los desaparecidos. Atraído por los fantasmas. Sensible a los espíritus. Superviviente en el corazón de una Barcelona invisible. Sintiendo que la muerte le ronda, intenta encontrar la paz, proteger a sus hijos, salvarse a sí mismo. La historia de Uxbal es sencilla y compleja, al igual que nuestras vidas de hoy."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":138,"tagline":"","homepage":"","overview":"À Barcelone, Uxbal, meurtri et obsédé par les fantômes de son passé auxquels il est confronté en raison de ses pouvoirs paranormaux, essaie de protéger ses enfants, Ana et Mateo, de l'influence néfaste de Maramba, son épouse alcoolique et dépressive. Mais, pour survivre, il exerce des activités criminelles qui le placent dans une situation précaire. Pour le compte de Hai, un gangster chinois, il organise un trafic de produits de contrefaçon, qu'il fait revendre dans la rue par des immigrés clandestins. Uxbal a aussi un don : il peut communiquer avec les morts. Il se sert de ce talent pour arrondir ses fins de mois. Mais sa vie bascule quand il apprend qu'il a un cancer de la prostate..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Bu filmde, baba olmayı, sevgiyi, ruhsallığı, suçu, pişmanlığı ve ölümlülüğü, Barcelona’nın tehlikeli yer altı dünyasında dengelemeye çalışan Uxbal’ın hikayesini izleyeceksiniz. Parasını kazanmak için hiçbir kural tanımıyor, çocukları için yaptığı fedakarlıklarda ise hiçbir sınır tanımıyor. Aynen hayatın kendisi gibi bu hikaye de başladığı yerde bitiyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":148,"tagline":"","homepage":"","overview":"Questa è la storia di un uomo in caduta libera. Sulla strada verso la redenzione, l'oscurità illumina la sua via. In comunicazione con la vita nell'aldilà, Uxbal è un eroe tragico e padre di due figli che sente il pericolo della morte, lotta contro una realtà corrotta e un destino che lavora contro di lui per perdonare, per amare e per sempre."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":147,"tagline":"Uma história de amor entre um pai e os seus filhos....","homepage":"http://www.biutiful-lapelicula.es/","overview":"Esta é a história de Uxbal, um homem em conflito, que luta para reconciliar a paternidade, o amor, a espiritualidade, o crime, a culpa e a mortalidade entre o perigoso submundo da Barcelona moderna. O seu meio de subsistência é ganho com biscates, os seus sacrifícios pelos filhos não têm limites. Tal como a vida, esta é uma história circular que termina onde começa. À medida que o destino o cerca e que vão sendo ultrapassados limites, um caminho fusco e redentor que se vai iluminando. Iluminando as heranças outorgadas de pai para filho, e a mão paternal orientadora que guia os caminhos da vida, sejam bons, maus - ou belos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"美错","runtime":0,"tagline":"","homepage":"","overview":"影片讲述了一个叫做乌克斯·鲍尔的男人的故事。　　乌克斯·鲍尔是慈祥的父亲，是充满了激情的恋人，也是一个不知所措的儿子，更是一个从事着非法交易的商人。　　他具有通灵的能力，能和死者对话；他亦被鬼魂所召唤，能感知精灵的存在。　　他从巴塞罗那的危机中逃遁了出来，学会了自我保护。他试图找回宁静的生活，保护自己的孩子，并拯救自我。　　乌克斯·鲍尔的故事既简单又复杂，反射的是人们的生活。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":142,"tagline":"","homepage":"","overview":"Mannen bakom Babel och Amores Perros har gjort sin bästa film! Detta är historien om en man i fritt fall. Överlevnadskonstnären Uxbal lever i skuggsidan av den annars så moderna och glittrande storstaden Barcelona. När han upptäcker att döden står för dörren försöker Uxbal säkra framtiden för sina två barn, återfinna kärleken och förlika sig med sitt öde. Men tiden är inte hans enda fiende."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":148,"tagline":"","homepage":"","overview":"Uxbal, konfliktní bývalý narkoman, hledá smíření se svým otcovstvím, láskou, duševnem, zločinem, vinou a smrtelností, obklopený nebezpečným podsvětím moderní Barcelony. Jeho obživa stojí mimo zákon a oběti, které je ochoten položit pro své děti, neznají hranic. Uxbalovi díky rakovině zbývají pouhé dva měsíce života, během nichž se snaží zajistit budoucnost svých dvou potomků, kteří bezcílně proplouvají životem. Zároveň se konfrontuje s přítelem z dětství, který je nyní policistou, se svojí bývalou manželkou, která je maniodepresivní prostitutkou, a dalšími výraznými postavami. Uxbal ztělesňuje velmi rozporuplného muže - oddaný otec, zhrzený milovník, pouliční zločinec, duchovně založený člověk. Jako život samotný, i tento příběh končí tam, kde všechno začíná. Obklopen osudem a překračující hranice, začíná Uxbal vidět svoji dosud mlžnou cestu jasněji a uvědomuje si svůj otcovský odkaz dětem."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":148,"tagline":"","homepage":"","overview":"'Biutiful' vertelt het verhaal van de criminele tussenbaas Uxbal, die in een vettig glimmend Barcelona de schakel is tussen een Chinees naaiatelier en illegale Afrikanen die nep spullen verkopen in combinatie met drugs."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Biutiful er historien om Uxbal (Javier Bardem) og hans kærlighed til sine børn. Han arbejder i Barcalonas underverden, hvor han importerer illegale kinesiske immigranter. I hverdagens uskyldige verden er han fokuseret på at være en kærlig far for sine to børn, men da han en dag får stillet en uafvendelig diagnose må han nu forholde sig til sin egen dødelighed og forsone sig med alle tilværelsens mørke sider. Samtidigt forsøger Uxbal at redde sine to børns tilværelse, inden han for evigt opsluges af det mørke, der har været hans ledestjerne."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":148,"tagline":"Ο δρόμος για τη λύτρωση περνάει από τη συγχώρεση.","homepage":"","overview":"Ο Ουζμπάλ ανακαλύπτει πως του απομένουν μόνο μερικοί μήνες ζωής και αποφασίζει να βάλει σε τάξη το χάος της ζωής του. Κατά τη διάρκεια της προσπάθειας του αυτής, περιπλανιέται στις φτωχογειτονιές και στον υπόκοσμο της Βαρκελώνης, ανάμεσα σε μετανάστες, συμμορίες και εμπόρους ναρκωτικών."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"ביותיפול","runtime":0,"tagline":"","homepage":"","overview":"סרטו של אינאריטו, (\"בבל\", \"אהבה נושכת\") שזיכה את כוכבו, חאווייר בארדם, בפרס השחקן הטוב ביותר בפסטיבל קאן, הוא אודיסיאה מופלאה ומרגשת על מסעו של אדם, המנסה בימיו האחרונים, לשפר את חייהם של האהובים עליו, לא תמיד בהצלחה. אחרי \"ארץ קשוחה\" בה היה רוצח פסיכופת ואחרי ההופעה המרגשת ב-\"הים שבפנים\", ו-\"השרמנטית של \"ויקי כריסטינה ברצלונה\" מתעלה בארדם מעל כל הישגיו עד כה ומעניק הופעה יוצאת דופן, באינטנסיביות שלה, (אין פריים כמעט שהוא לא על המסך) הופעה כובשת ונוגעת ומהפנטת."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Biutiful","runtime":140,"tagline":"","homepage":"","overview":"A Biutiful Uxbal (Javier Bardem) történetét meséli el. Uxbal szerető apa, meg nem értett fiú, megkínzott szerető, illegális üzletember, az ártatlanok barátja. Szellemidéző és spiritiszta. Igazi mestere a túlélésnek, aki napjainkban él Barcelona láthatatlan külvárosában. Amikor Uxbal megérzi halálának közeledtét, megpróbálja újra felvenni a kapcsolatot szeretteivel, és megmenteni gyermekeit u2013 és egyben önmagát. Uxbal története egy egyszerű történet: a hétköznapi emberek története, amit mindannyian átélünk."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Frumos","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":147,"tagline":"","homepage":"","overview":"Esta é a história de um homem que vive uma queda livre emocional. Em sua viagem em busca de redenção, a escuridão ilumina o seu caminho. Conectado ao outro mundo, Uxbal é um trágico herói e pai de dois filhos que, ao sentir o perigo iminente da morte, batalha contra uma dura realidade e um destino que o impede de perdoar, perdoar-se, por amor e para sempre."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Бʼютифул","runtime":0,"tagline":"","homepage":"","overview":"Розлучений батько двох дітей Уксбаль — своя людина в тіньовому світі Барселони. Для правоохоронних органів він є порушником закону; для нелегальних іммігрантів, яким допомагає отримати роботу, — добрим ангелом. Дізнавшись, що невиліковно хворий, Уксбаль починає готуватися до смерті..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"비우티풀","runtime":0,"tagline":"","homepage":"","overview":"나는 마약을 사고 팔고 밀입국자들을 짝퉁가방 공장에 알선하는 인력브로커다.  고질병 때문에 찾아간 병원에서 암이란다. 남은 시간 3개월…\r 엄마의 우울증 때문에 못난 아빠와 함께 사는 나의 착한 두 아이는, 아직 어리다.  죽은 자와 대화할 수 있는 나의 특별한 능력은… 불행히도 나의 죽음을 보게 한다.  너무나 많은 이들에게 끔찍한 죄를 저질렀다. 마지막 순간, 실패한 인생이라 불릴 것이다.  하지만 내가 태어나기도 전에 죽은 얼굴도 모르는 아버지를 여전히 그리워하는 것처럼,  험한 세상에 남겨질 나의 아이들에게는 좋은 기억을, ‘아름다운’ 세상을 선물하고 싶다.  3개월\r 한달\r 하루\r 한 시간\r 일분…\r 나의 아이들아, 미안하다…  그럼에도 불구하고.. 살아야 한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Бютифул","runtime":138,"tagline":"","homepage":"","overview":"Уксбал е антигерой с откровено декадентско битие, който прокарва пътя си в мрачна реалност. Камерата прониква в барселонския подземен свят, далеч не само от светлините, но и от всички разбирания за човешки ценности. В този пейзаж, граничещ със свръхестественото и фантасмагоричното, Хавиер Бардем ни представя една забележителна по своята сила интерпретация, с прецизна актьорска игра, без маниерност, с която изгражда тревожния образ на изпадналия си в пълна асфиксия герой."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Biutiful","runtime":0,"tagline":"Oddaný otec, bývalý narkoman, sklamaný milenec aj duchovne založený kriminálnik.","homepage":"","overview":"Príbeh muža v ťažkej životnej situácii. Na ceste k vykúpeniu medzi temnotou a svetlom. Nejakým spôsobom je spojený s posmrtným životom. Uxbal je tragický hrdina a otec dvoch detí, ktorý cíti nebezpečenstvo smrti. Bojuje s tvrdou realitou a osudom, ktorý pracuje proti nemu."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Stāsts par Ukbālu, par divu bērnu tēvu, kas iztiku pelna ar nelegālu biznesu. Apjaušot nāves nenovēršamību, viņš mēģina sakārtot savu dzīvi."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"最後的美麗","runtime":148,"tagline":"","homepage":"","overview":"鄔巴斯(哈維爾巴登飾)為一名深愛著孩子的單親爸爸，並且努力維繫小孩母親的關係，儘管小孩的母親有酗酒不良嗜好以及精神疾病。在這樣深情愛家庭的父親形象的另一面，鄔巴斯從事非法事業，交易買賣的內容，從仿冒品到房地產，樣樣都有。他還能夠探知亡靈的世界，但卻無法驅走老婆沉溺酗酒的心魔。鄔巴斯就這樣在愛與罪惡的夾縫中掙扎生存。某日他被檢驗出患了絕症，在生命突然進入倒數時刻，他不僅積極為巴塞隆納低下階層勞工謀取福利，更努力工作養育孩子，珍惜著每一刻與家人相處的時光，並且極力安排好所有的事情。不論他是為了贖罪，或者是無條件地付出愛，他盡力地將生命之光燃燒至最後一刻。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"BIUTIFUL ビューティフル","runtime":0,"tagline":"","homepage":"","overview":"バルセロナの片隅で、二人の幼い子供たちとひっそりと暮らしているウスパル。ある日、突然の末期ガン宣告を受けた彼は、余命の2ヶ月を子供たちのために生きようと決意する。巨匠イニャリトゥ監督が放つ感動作。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Cuộc Đời Đẹp","runtime":0,"tagline":"","homepage":"","overview":"Bộ phim nói về những ngày tháng cuối cùng trong cuộc đời của Uxbal (Javier Bardem), một người đàn ông bình thường như bao người đàn ông khác tại thành phố Barcelona. Cuộc sống của Uxbal không hề “tươi đẹp”, như tựa phim Biutiful. Công việc dĩ nhiên không dễ dàng, đời sống cá nhân của Uxbal cũng đầy khó khăn. Người vợ Marambra (Maricel Álvarez) mắc chứng rối loạn lưỡng cực, đòi trở lại sau khi li thân. Hai đứa con nhỏ thiếu vắng sự quan tâm, không người chăm sóc. Một người bạn thân của Uxbal bị cảnh sát bắt, gã buộc phải lo lắng cho vợ con mình nên đã phản bội... Uxbal sống trong một mớ quan hệ hỗn loạn. Như thể chưa đủ, số phận còn giáng cho Uxbal một cú chí mạng: anh bị ung thư, chỉ còn sống được vài tháng... Mặc dù phải làm việc phạm pháp để mưu sinh nhưng Uxbal không phải là người xấu. Anh luôn tìm mọi cách để làm điều tốt, luôn giúp đỡ bạn bè, người thân, nhưng cuộc sống vốn khắc nghiệt, khó khăn đến tàn nhẫn..."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"美麗末日","runtime":0,"tagline":"面對突然死期 應該為自己止痛？ 為家人拼命？ 為朋友盡力？ 抑或為身後留名？ 步向生命末日 扭轉無助命運 「愛」就是唯一可能！","homepage":"","overview":"Uxbal 從事非法事業，人生亦充滿奇幻。他能探知亡靈世界，卻不能挽救老婆酗酒的心魔。在人生最後的時光裏，他為巴塞隆拿的低下階層黑工謀福利，改善生活。同時，為了挽回兩個孩子的心，他繼續努力工作養育他們，並珍惜每一個共聚時刻。不管他是贖罪，或只是無條件付出愛，他確實在黑暗中燃點了光芒。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"Tú no eliges a tu familia. Todos pertenecemos a alguien, pero pertenecer a Uxbal y Marambra es a la vez una bendición y una maldición.","homepage":"","overview":"Retrato de la vida de Uxbal: padre abnegado e hijo desamparado. Intermediario de la sombra. Próximo a los desaparecidos. Atraído por los fantasmas. Sensible a los espíritus. Superviviente en el corazón de una Barcelona invisible. Sintiendo que la muerte le ronda, intenta encontrar la paz, proteger a sus hijos, salvarse a sí mismo. La historia de Uxbal es sencilla y compleja, al igual que nuestras vidas de hoy."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"Umierający na raka mężczyzna stara się zabezpieczyć przyszłość swoim dzieciom.","homepage":"","overview":"Umierający na raka mężczyzna stara się zabezpieczyć przyszłość swoim dzieciom."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Biutiful","runtime":0,"tagline":"","homepage":"","overview":"Oskaro laureatas Javieras Bardemas šiame filme vaidina Uksbalį - vyrą, veikiantį prieš įstatymą ir besistengiantį išlaikyti savo vaikus pavojingose Barselonos gatvėse. Žinia apie mirtiną ligą jį pastato akistaton su praeitimi ir dabartimi. Uksbaliui prieš akis praplaukia visas gyvenimas, tačiau jis dar turi truputį laiko padaryti pasaulį gražesnį..."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"เรื่องราวของผู้ชายที่ได้ชื่อว่าเป็นพ่อที่สู้ยิบตาเพื่อลูก พร้อมที่จะเสียสละเสี่ยงตนเอง ไม่ว่าจะต้องแลกด้วยอะไร แม้โลกจะโหดร้ายเพียงไหน แต่สิ่งที่สวยงามที่สุดในชีวิตของเขาคือ ลูกเท่านั้นที่ไม่ทำให้เขายอมแพ้"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"}],"reviews_tmdb":[{"id":"62e21804e18e3f027942e55f","url":"https://www.themoviedb.org/review/62e21804e18e3f027942e55f","author":"Filipe Manuel Neto","content":"$11","created_at":"2022-07-28T05:00:52.300Z","updated_at":"2022-07-28T05:00:52.401Z","author_details":{"name":"Filipe Manuel Neto","rating":6,"username":"FilipeManuelNeto","avatar_path":"/nidqITf735x9xxHfncXkT9BmOQ7.png"}}],"recommendations":[{"id":1164,"adult":false,"title":"Babel","video":false,"overview":"Tragedy strikes a married couple vacationing in the Moroccan desert, which jumpstarts an interlocking story involving four different families.","genre_ids":[18],"media_type":"movie","popularity":4.9336,"vote_count":4001,"poster_path":"/bZByZbvU7u14WjoUJERqCRW9saN.jpg","release_date":"2006-10-26","vote_average":7.166,"backdrop_path":"/9YoLdWeBSxAdR6BqQ5uS88d3FWO.jpg","original_title":"Babel","original_language":"en"},{"id":1913,"adult":false,"title":"The Sea Inside","video":false,"overview":"Ramón Sampedro is a ship mechanic and part-time poet left a quadriplegic following a diving accident. Ramón fought for 30 years for the legal right to end his own life. He develops close relationships with his long-term lawyer Julia and his friend Rosa, who tries to convince him that his life is worth living. Despite his situation, Ramón manages to inspire those around him to live life to the fullest.","genre_ids":[18],"media_type":"movie","popularity":2.7533,"vote_count":990,"poster_path":"/mQW1JJKCUg02cmWBzr9JFu9vM1V.jpg","release_date":"2004-09-03","vote_average":7.57,"backdrop_path":"/7XmDhCTkce5GH8KCdbMoTZdxn1p.jpg","original_title":"Mar adentro","original_language":"es"},{"id":12544,"adult":false,"title":"Respiro","video":false,"overview":"Grazia is a free-spirited mother-of-three married to shy fisherman Pietro and living on the idyllic but isolated island of Lampedusa in the Mediterranean Sea. She shows signs of manic depressive behavior — one moment she's laughing wildly and swimming half-naked in the sea, while the next she's curled in a ball on her bed. Out of her earshot, the adult members of her extended family vaguely discuss sending her to a facility of some sort in Northern Italy.","genre_ids":[35,18],"media_type":"movie","popularity":0.3243,"vote_count":117,"poster_path":"/3DUXqmOpHZBQSQOHQcAdK6GVlKg.jpg","release_date":"2002-05-18","vote_average":6.624,"backdrop_path":"/13vz8JX3tyyK258PBfPLE22OKV1.jpg","original_title":"Respiro","original_language":"it"},{"id":251736,"adult":false,"title":"Listen Up Philip","video":false,"overview":"Anger rages in Philip as he awaits the publication of his second novel. He feels pushed out of his adopted home city by the constant crowds and noise, a deteriorating relationship with his photographer girlfriend Ashley, and his own indifference to promoting the novel. When Philip's idol Ike Zimmerman offers his isolated summer home as a refuge, he finally gets the peace and quiet to focus on his favorite subject: himself.","genre_ids":[35,18],"media_type":"movie","popularity":0.7397,"vote_count":153,"poster_path":"/rHfrGEdTEW20W6L26qbJ0DFNDKo.jpg","release_date":"2014-10-17","vote_average":5.859,"backdrop_path":"/yuDDViMJppRKiDXTGXpHdofhkgx.jpg","original_title":"Listen Up Philip","original_language":"en"},{"id":69885,"adult":false,"title":"As Mães de Chico Xavier","video":false,"overview":"Three mothers see their reality become completely, they are: Ruth, whose teenage son, Raul, faces problems with drugs; Elisa, trying to make up for the absence of her husband giving full attention to the child, the little Theo, and Lara, teacher who faces the dilemma of an unplanned pregnancy. These three women, living in different times of their lives, seeking comfort next to Chico Xavier. And Karl reporter remains insisting on interviewing the medium, even without being prepared for it.","genre_ids":[18],"media_type":"movie","popularity":0.2422,"vote_count":47,"poster_path":"/clnDNQsAH75mw8gfaBnRQGOHxGt.jpg","release_date":"2011-04-01","vote_average":7.777,"backdrop_path":"/52BJhR4lGXPAr0LCUUf7giAagG5.jpg","original_title":"As Mães de Chico Xavier","original_language":"pt"},{"id":57052,"adult":false,"title":"The Right Distance","video":false,"overview":"The arrival of an attractive young teacher in a small town in the Po valley disturbs the drowsy life of the place, leading eventually to a murder.","genre_ids":[18,9648],"media_type":"movie","popularity":0.2281,"vote_count":70,"poster_path":"/4ZySEbzk0dQ3wsytqg9nItn8jlq.jpg","release_date":"2007-10-19","vote_average":6.9,"backdrop_path":"/pGj2RcsnY2zTexFdiTrqNnodSjU.jpg","original_title":"La giusta distanza","original_language":"it"},{"id":109979,"adult":false,"title":"18 Years Later","video":false,"overview":"Mirko and Genziano are two 35-year-old brothers who have not seen each other since their mother died in a freak accident in which they were involved—eighteen years ago. Since then, Genziano left to live in the UK and now is a stockbroker; Mirko instead remained in Rome, to stay with their father Marcello, working at the same run-down family shop. When Marcello dies, he leaves a task for the two brothers in his will: he asks them to take, on an old restored roadster, his ashes to the grave of his old mother in a village in Calabria, where the accident happened.","genre_ids":[18],"media_type":"movie","popularity":0.3963,"vote_count":34,"poster_path":"/bt6gViRmNHydQoRfCJ80D3ULQrK.jpg","release_date":"2010-07-04","vote_average":6.853,"backdrop_path":"/sOxLo0G9L9g0mzaXBnJGEOoJLwo.jpg","original_title":"Diciotto anni dopo","original_language":"it"},{"id":267804,"adult":false,"title":"In the Courtyard","video":false,"overview":"Antoine is a musician. The forties, he suddenly decides to end his career. After a few days of wandering, he gets a job as a janitor. Mathilde lives in the old building in the east of Paris where he takes office. This is a young retiree, generous and involved, who divides his time between his associational activities and the life of the condominium. One night, she discovers a disturbing crack on the wall of his living room. Gradually, his anxiety grew to turn into panic and if the building collapsed ... Slowly, Antoine befriends the woman he feared to see slip into madness. Between slips and concerns, both form an awkward tandem, humorous and solidarity which will, perhaps, through this bad patch.","genre_ids":[18,35],"media_type":"movie","popularity":0.2751,"vote_count":86,"poster_path":"/6mCfCONngJG0NPM6QpyBZxeCPuA.jpg","release_date":"2014-04-23","vote_average":5.8,"backdrop_path":"/7KwuFTnvGvWJuLi4BXs7Gf24T0B.jpg","original_title":"Dans la cour","original_language":"fr"},{"id":18257,"adult":false,"title":"Black Belt Jones","video":false,"overview":"Jones is a secret agent who has gone into semi-retirement, concentrating instead on teaching the martial arts to inner city youths. The karate school is run by a kindly old coot named Pops. His gambling debts, however, bring the local thug, Pinky, down on him. To make matters worse, Pinky is then hired by some white thugs who want to get a hold of the property Pops' school occupies so they can build a shopping mall. When things get heavy, Black Belt Jones leaps into action. Only he's not alone. Pops' daughter, Sidney, shows up to lend a hand, proving herself every bit as agile and powerful a martial artist as Jones.","genre_ids":[28,35,80],"media_type":"movie","popularity":0.5679,"vote_count":67,"poster_path":"/tnzPJzKr2IVPGqkkE6aCGNePDq0.jpg","release_date":"1974-01-28","vote_average":6.037,"backdrop_path":"/6eMtiAmWIGGFCEoRyJWLUcojPfU.jpg","original_title":"Black Belt Jones","original_language":"en"},{"id":196032,"adult":false,"title":"Easy Money III: Life Deluxe","video":false,"overview":"JW now lives in exile and is more than ever determined to find out what happened to his missing sister Camilla. Every trace leads him to the world of organized crime in Stockholm. Jorge is about to do his last score – the largest robbery in Swedish history. But during the complicated preparations he meets a woman from his past – Nadja.  Martin Hägerström is chosen to go undercover into the Serbian mafia, in order to get its notorious boss Radovan Krajnic behind bars. When an assassination attempt is made on Radovan, his daughter Natalie is pulled into the power struggle within the Serbian mafia.","genre_ids":[80,18,53],"media_type":"movie","popularity":0.307,"vote_count":102,"poster_path":"/oSTHRFOcC1l1qpW84n7RioCDRnY.jpg","release_date":"2013-08-30","vote_average":6.2,"backdrop_path":"/eWAyaR01f4TVui8vxLVFwUjx3hB.jpg","original_title":"Snabba cash - Livet deluxe","original_language":"sv"},{"id":518975,"adult":false,"title":"A Russian Youth","video":false,"overview":"A teenage soldier in World War I—a simple village boy with a naive youthful dream of fame and medals—throws himself into the unknown and goes blind in the first battle, thus taking on a new job: intercepting enemy planes by listening to the air through huge metal funnels.","genre_ids":[10752,18],"media_type":"movie","popularity":0.3345,"vote_count":27,"poster_path":"/xv5SiSVuMKXDdG8ozYLD59CBcZx.jpg","release_date":"2019-02-10","vote_average":5.2,"backdrop_path":"/9D951h8QRjG5sCQs0wghIu4lN56.jpg","original_title":"Мальчик русский","original_language":"ru"},{"id":32566,"adult":false,"title":"Bullet Boy","video":false,"overview":"Ricky is just out of a young offenders institute, heading home to Hackney and determined to go straight. Instead, he heads straight for trouble when he becomes involved in a street confrontation, siding with his best friend Wisdom against a local rude boy. The trouble escalates into a series of tit-for-tat incidents that threaten to spiral out of control. Ricky's 12-year-old brother Curtis, hero-worships Ricky, though he appears smart enough to know he doesn't want to follow his example. Yet, despite the stern warnings from his mother and support from her friends in the community, might Ricky's bad boy allure be too attractive for Curtis to resist?","genre_ids":[28,80,18],"media_type":"movie","popularity":0.2722,"vote_count":31,"poster_path":"/lZk17BnjqJTbXWu7xCimOJtjGuv.jpg","release_date":"2004-09-15","vote_average":5.532,"backdrop_path":"/eU9aNlCCgtwFBHgdbOHZG7Zqc2I.jpg","original_title":"Bullet Boy","original_language":"en"},{"id":273123,"adult":false,"title":"The Beginning and the End","video":false,"overview":"Set in the suburbs of Cairo in the late 1930s, the story follows a middle-class Egyptian family grappling with the hardships of life after the death of their father, their sole breadwinner. The mother and her four children—three brothers and their sister, Nefisah—struggle to avoid slipping into poverty. They all go in different directions which aren't exactly good.","genre_ids":[18],"media_type":"movie","popularity":0.2546,"vote_count":9,"poster_path":"/sdfyVkEozbXMsY1euPsx0wRteUa.jpg","release_date":"1960-10-31","vote_average":8,"backdrop_path":"/LE1BtIsFCH6hAEV2naQvvwFr9U.jpg","original_title":"بداية ونهاية","original_language":"ar"},{"id":99193,"adult":false,"title":"Kana Kanden","video":false,"overview":"Bhaskar, a research scholar in chemistry, succeeds in coming out with a prototype of a desalination plant which he wants to give to the government and solve a water crisis. Unable to secure proper funding, he meets Madan who promises to finance his project.","genre_ids":[10749,18],"media_type":"movie","popularity":0.3099,"vote_count":9,"poster_path":"/vMRBZ2kifGbhGCuYWQWYMGChR0e.jpg","release_date":"2005-05-13","vote_average":6.2,"backdrop_path":"/dt22CycJSFXnXvuHz6iT5jBRxhU.jpg","original_title":"கனா கண்டேன்","original_language":"ta"},{"id":323641,"adult":false,"title":"Dos mundos y un amor","video":false,"overview":"Cultural differences cause tensions in an international marriage.","genre_ids":[18,10749],"media_type":"movie","popularity":0.126,"vote_count":5,"poster_path":"/mdcBLUwcQps7KwDO8xeLIQZl1Pj.jpg","release_date":"1954-02-04","vote_average":8,"backdrop_path":null,"original_title":"Dos mundos y un amor","original_language":"es"},{"id":11516,"adult":false,"title":"Winged Migration","video":false,"overview":"This documentary follows various migratory bird species on their long journeys from their summer homes to the equator and back, covering thousands of miles and navigating by the stars. These arduous treks are crucial for survival, seeking hospitable climates and food sources. Birds face numerous challenges, including crossing oceans and evading predators, illness, and injury. Although migrations are undertaken as a community, birds disperse into family units once they reach their destinations, and every continent is affected by these migrations, hosting migratory bird species at least part of the year.","genre_ids":[99],"media_type":"movie","popularity":1.8473,"vote_count":196,"poster_path":"/qjv7cYLSufwf03So0SuRFU7sRxB.jpg","release_date":"2001-12-12","vote_average":7.6,"backdrop_path":"/c8lCUmgvyxfM3oJzbD9bQf8bV02.jpg","original_title":"Le Peuple migrateur","original_language":"fr"},{"id":55,"adult":false,"title":"Amores Perros","video":false,"overview":"A fatalistic car crash in Mexico city sets off a chain of events in the lives of three people: a supermodel, a young man wanting to run off with his sister-in-law, and a homeless man.","genre_ids":[18,53],"media_type":"movie","popularity":4.7541,"vote_count":2847,"poster_path":"/A4lH22nlFF7MdalGfcvSrlC1ttt.jpg","release_date":"2000-06-16","vote_average":7.633,"backdrop_path":"/nFXBmQAjNGdQUFPdTxE1OFqjx0X.jpg","original_title":"Amores perros","original_language":"es"},{"id":522373,"adult":false,"title":"Young Ahmed","video":false,"overview":"A young Belgian is incited by his imam to view a teacher as an apostate and assassinate her; after he fails, he is sent to juvenile reform.","genre_ids":[18],"media_type":"movie","popularity":0.4077,"vote_count":169,"poster_path":"/z4D3GE3JzyrFe7pnSUqDwdq1KhY.jpg","release_date":"2019-05-22","vote_average":6.266,"backdrop_path":"/y31BYaEd4IEtcUyMqmIoUhvm1OP.jpg","original_title":"Le jeune Ahmed","original_language":"fr"},{"id":1713,"adult":false,"title":"Jungle Fever","video":false,"overview":"A successful and married black man contemplates having an affair with a white girl from work. He's quite rightly worried that the racial difference would make an already taboo relationship even worse.","genre_ids":[18,10749],"media_type":"movie","popularity":1.0831,"vote_count":307,"poster_path":"/pw7cOdwCylBuiv6rvosBSkcgKEe.jpg","release_date":"1991-06-07","vote_average":6.4,"backdrop_path":"/2YQfKfYX0mvHPnFMP5wiL1kYYBU.jpg","original_title":"Jungle Fever","original_language":"en"},{"id":1414,"adult":false,"title":"Lovers of the Arctic Circle","video":false,"overview":"As young children, Otto and Ana become best friends, leading to the marriage of Ana's mother to Otto's father. When Otto and Ana become teenagers, they begin a sexual relationship, which they hide from their parents. The two fall deeply in love and seem destined to spend the rest of their lives together. However, their relationship is tested when Otto's mother dies and the two are separated.","genre_ids":[18,9648,10749],"media_type":"movie","popularity":0.5922,"vote_count":267,"poster_path":"/1hUFwXtUIJQdayIkaTR835QyaKT.jpg","release_date":"1998-09-04","vote_average":7.294,"backdrop_path":"/yGcfhstNqWEv31kRvwSVFw2JsBX.jpg","original_title":"Los amantes del Círculo Polar","original_language":"es"}],"similar_content":[{"id":71,"adult":false,"title":"Billy Elliot","video":false,"overview":"County Durham, England, 1984. The miners' strike has started and the police have started coming up from Bethnal Green, starting a class war with the lower classes suffering. Caught in the middle of the conflict is 11-year old Billy Elliot, who, after leaving his boxing club for the day, stumbles upon a ballet class and finds out that he's naturally talented. He practices with his teacher Mrs. Wilkinson for an upcoming audition in Newcastle-upon Tyne for the royal Ballet school in London.","genre_ids":[18,35,10402],"popularity":2.8329,"vote_count":4027,"poster_path":"/nOr5diUZxphmAD3li9aiILyI28F.jpg","release_date":"2000-09-28","vote_average":7.593,"backdrop_path":"/mTsbahr4SLqgVZkKRN0O8t5iA9y.jpg","original_title":"Billy Elliot","original_language":"en"},{"id":99,"adult":false,"title":"All About My Mother","video":false,"overview":"Following the tragic death of her teenage son, Manuela travels from Madrid to Barcelona in an attempt to contact the long-estranged father the boy never knew. She reunites with an old friend, an outspoken transgender sex worker, and befriends a troubled actress and a pregnant, HIV-positive nun.","genre_ids":[35,18],"popularity":2.4504,"vote_count":2027,"poster_path":"/hjQhzhkGYXPNM96k0mOgob6HMmn.jpg","release_date":"1999-04-16","vote_average":7.628,"backdrop_path":"/tilClWjFZeUTGJu0pxgF72fvUmN.jpg","original_title":"Todo sobre mi madre","original_language":"es"},{"id":101,"adult":false,"title":"Léon: The Professional","video":false,"overview":"Léon, the top hit man in New York, has earned a rep as an effective \"cleaner\". But when his next-door neighbors are wiped out by a loose-cannon DEA agent, he becomes the unwilling custodian of 12-year-old Mathilda. Before long, Mathilda's thoughts turn to revenge, and she considers following in Léon's footsteps.","genre_ids":[80,18,28],"popularity":13.1027,"vote_count":15811,"poster_path":"/bxB2q91nKYp8JNzqE7t7TWBVupB.jpg","release_date":"1994-09-14","vote_average":8.294,"backdrop_path":"/jRJrQ72VLyEnVsvwfep8Xjlvu8c.jpg","original_title":"Léon","original_language":"fr"},{"id":235,"adult":false,"title":"Stand by Me","video":false,"overview":"After learning that a boy their age has been accidentally killed near their rural homes, four boys decide to go see the body. Gordie, Vern, Chris, and Teddy encounter a mean junk man and a marsh full of leeches, but they also learn more about one another and their very different home lives. Just a lark at first, the boys' adventure evolves into a defining event in their lives.","genre_ids":[80,18],"popularity":6.377,"vote_count":6357,"poster_path":"/vz0w9BSehcqjDcJOjRaCk7fgJe7.jpg","release_date":"1986-08-08","vote_average":7.843,"backdrop_path":"/yjGllQUm28R4X9xD9T5xMszirgw.jpg","original_title":"Stand by Me","original_language":"en"},{"id":238,"adult":false,"title":"The Godfather","video":false,"overview":"Spanning the years 1945 to 1955, a chronicle of the fictional Italian-American Corleone crime family. When organized crime family patriarch, Vito Corleone barely survives an attempt on his life, his youngest son, Michael steps in to take care of the would-be killers, launching a campaign of bloody revenge.","genre_ids":[18,80],"popularity":36.9611,"vote_count":22507,"poster_path":"/3bhkrj58Vtu7enYsRolD1fZdja1.jpg","release_date":"1972-03-14","vote_average":8.687,"backdrop_path":"/tSPT36ZKlP2WVHJLM4cQPLSzv3b.jpg","original_title":"The Godfather","original_language":"en"},{"id":1592,"adult":false,"title":"Primal Fear","video":false,"overview":"Defense attorney Martin Vail takes on jobs for money and prestige rather than any sense of the greater good. His latest case involves an altar boy, accused of brutally murdering the archbishop of Chicago. Vail finds himself up against his ex-pupil and ex-lover, but as the case progresses and the Church's dark secrets are revealed, Vail finds that what appeared a simple case takes on a darker, more dangerous aspect.","genre_ids":[80,18,9648,53],"popularity":5.1981,"vote_count":3788,"poster_path":"/qJf2TzE8nRTFbFMPJNW6c8mI0KU.jpg","release_date":"1996-03-06","vote_average":7.656,"backdrop_path":"/dZM71rHXh3Oo3WZlw8YpMMsoVB5.jpg","original_title":"Primal Fear","original_language":"en"},{"id":1632,"adult":false,"title":"Mississippi Burning","video":false,"overview":"Two FBI agents investigating the murder of civil rights workers during the 60s seek to breach the conspiracy of silence in a small Southern town where segregation divides black and white. The younger agent trained in FBI school runs up against the small town ways of his partner, a former sheriff.","genre_ids":[18,80,9648,53],"popularity":2.3659,"vote_count":1879,"poster_path":"/wvEx2WbxZXYljQ9vSoq37NgeXcJ.jpg","release_date":"1988-12-08","vote_average":7.679,"backdrop_path":"/sYpNbnOlIKW5nlrPDFOGpnCUlz9.jpg","original_title":"Mississippi Burning","original_language":"en"},{"id":1725,"adult":false,"title":"West Side Story","video":false,"overview":"In Manhattan’s Upper West Side, rival gangs of Polish-Americans and newly arrived Puerto Ricans clash for control of the neighborhood, even as two young members from opposite sides fall dangerously in love.","genre_ids":[80,18,10749],"popularity":2.7798,"vote_count":2000,"poster_path":"/nzCMu6D5q60i2bVrIQ0DxlRSgCZ.jpg","release_date":"1961-12-13","vote_average":7.2,"backdrop_path":"/bkahbHkwBSbIDtTm667Tu1ba2bu.jpg","original_title":"West Side Story","original_language":"en"},{"id":1831,"adult":false,"title":"The Next Best Thing","video":false,"overview":"A comedy-drama about best friends - one a straight woman, Abbie, the other a gay man, Robert - who decide to have a child together. Five years later, Abbie falls in love with a straight man and wants to move away with her and Robert's little boy Sam, and a nasty custody battle ensues.","genre_ids":[35,18,10749],"popularity":0.5227,"vote_count":195,"poster_path":"/iYK1ZUtY4etcn91glUmrGuZRH6M.jpg","release_date":"2000-03-03","vote_average":5.259,"backdrop_path":"/gA319UUESvNt5jCsQ9YqSidJ2CE.jpg","original_title":"The Next Best Thing","original_language":"en"},{"id":656113,"adult":false,"title":"Jagame Thandhiram","video":false,"overview":"When a clever, carefree gangster is recruited to help an overseas crime lord take down a rival, he is caught off guard by the moral dilemmas that follow.","genre_ids":[80,18],"popularity":0.4231,"vote_count":53,"poster_path":"/goLoLNagbnWpPQh4YQE9R2hSLqj.jpg","release_date":"2021-06-18","vote_average":5.6,"backdrop_path":"/kZUxNvgXOapS3rl0j7Rbrdmf1r3.jpg","original_title":"ஜகமே தந்திரம்","original_language":"ta"},{"id":1985,"adult":false,"title":"The Constant Gardener","video":false,"overview":"Justin Quayle is a low-level British diplomat who has always gone about his work very quietly, not causing any problems. But after his radical wife Tessa is killed he becomes determined to find out why, thrusting himself into the middle of a very dangerous conspiracy.","genre_ids":[18,9648,53],"popularity":2.1832,"vote_count":1670,"poster_path":"/nkXq7V7mmJVbvwZGr3nxkHo7HkS.jpg","release_date":"2005-08-31","vote_average":6.991,"backdrop_path":"/ldPtMaobGaG7sSrKM1c9Vnd6UGq.jpg","original_title":"The Constant Gardener","original_language":"en"},{"id":1896,"adult":false,"title":"Salvador (Puig Antich)","video":false,"overview":"The story of Salvador Puig Antich, one of the last political prisoners to be executed under Franco's Fascist State in 1974.","genre_ids":[18,36],"popularity":0.4415,"vote_count":63,"poster_path":"/sckxel7UsvGbTc7DOJqLWy39SE1.jpg","release_date":"2006-05-23","vote_average":6.833,"backdrop_path":"/gygtjTTi3O9uDN5BevYAPWeVi2S.jpg","original_title":"Salvador (Puig Antich)","original_language":"ca"},{"id":273197,"adult":false,"title":"The Great Hypnotist","video":false,"overview":"The famous psychologist Xu Ruining has a raising career, when he met the troublesome patient Ren Xiaoyan. The meeting is not easy as feeble-looking Ren is point by point against him.","genre_ids":[53,18,9648],"popularity":0.5621,"vote_count":99,"poster_path":"/hqfKwoVMe3WCtTWWv2rIW6Oe05X.jpg","release_date":"2014-04-29","vote_average":6.646,"backdrop_path":"/xNEa9sFcTnHDXbxdUQlBshIDkdy.jpg","original_title":"催眠大师","original_language":"zh"},{"id":273404,"adult":false,"title":"I'll Follow You Down","video":false,"overview":"After the disappearance of a young scientist on a business trip, his son and wife struggle to cope, only to make a bizarre discovery years later - one that may bring him home.","genre_ids":[878,18,9648],"popularity":0.9537,"vote_count":190,"poster_path":"/3osrKXIz5OkSrpnEt1hqHAAyvbd.jpg","release_date":"2013-07-28","vote_average":6,"backdrop_path":"/hBaZ0cXy2gOwOvsywez8MHWgAjO.jpg","original_title":"I'll Follow You Down","original_language":"en"},{"id":1964,"adult":false,"title":"A Friend of Mine","video":false,"overview":"An introverted insurance executive at a car rental service is annoyed by his hyperactive, garrulous coworker, but the two end up becoming friends.","genre_ids":[18],"popularity":0.2274,"vote_count":76,"poster_path":"/yUbB44z9UTH4y4D7L02ruh4KfCB.jpg","release_date":"2006-10-05","vote_average":6.605,"backdrop_path":"/a77jYoKnQuAPTirVl5kZ2KJgyF5.jpg","original_title":"Ein Freund von mir","original_language":"de"},{"id":5717,"adult":false,"title":"Man Push Cart","video":false,"overview":"Every night while the city sleeps, Ahmad, a former Pakistani rock star turned immigrant, drags his heavy cart along the streets of New York. And every morning, he sells coffee and donuts to a city he cannot call his own. One day, however, the pattern of this harsh existence is broken by a glimmer of hope for a better life.","genre_ids":[18],"popularity":0.283,"vote_count":52,"poster_path":"/hGhGa4O6ztK5r3SeFlEmYZE7EUZ.jpg","release_date":"2006-05-10","vote_average":6.885,"backdrop_path":"/gVLGeaIeFscIQ3pdGCCmM3swotk.jpg","original_title":"Man Push Cart","original_language":"en"},{"id":5718,"adult":false,"title":"King of California","video":false,"overview":"Charlie gets released from an insane asylum and moves in with Miranda, the young daughter he left behind. Charlie believes that there is treasure hidden beneath the local Costco, so he puts together a plan to unearth the loot. By convincing Miranda to quit her job at McDonald's and instead work at the wholesale store, he is able to obtain a key. Although Miranda is skeptical, she helps her father with his irrational quest.","genre_ids":[35,18],"popularity":0.6089,"vote_count":377,"poster_path":"/zLoa3oJ83zo9g3mV9LNCHbqO7jH.jpg","release_date":"2007-01-24","vote_average":6.422,"backdrop_path":"/n0LDZHQJ67GZ3rX68juko8kGgDN.jpg","original_title":"King of California","original_language":"en"},{"id":276236,"adult":false,"title":"Tattoo Bar","video":false,"overview":"Although she's still hung up on the man who broke her heart, club dancer Simona pledges to eradicate all memories of him by removing the tattoos he put on her body. Complicating matters is Mariel, the owner of a Barcelona tattoo shop whose obsession with Simona's undulating form leads him to steal the money to help her pay for the necessary laser treatments.","genre_ids":[18],"popularity":1.7264,"vote_count":3,"poster_path":"/kRkiKJf7hHJXPyOqYvZUziNYPOY.jpg","release_date":"2000-11-17","vote_average":1.667,"backdrop_path":null,"original_title":"Tatawo","original_language":"es"},{"id":860061,"adult":false,"title":"Parachute","video":false,"overview":"Wendy, a Chinese “parachute kid,” is struggling to adapt to her new American life.","genre_ids":[18],"popularity":0.1768,"vote_count":1,"poster_path":"/u4HaSPKd23dXAAm5FPEBZzBQOBy.jpg","release_date":"2020-10-12","vote_average":9,"backdrop_path":null,"original_title":"Parachute","original_language":"en"},{"id":5961,"adult":false,"title":"Fanny and Alexander","video":false,"overview":"As children in the loving Ekdahl family, Fanny and Alexander enjoy a happy life with their parents, who run a theater company. After their father dies unexpectedly, however, the siblings end up in a joyless home when their mother, Emilie, marries a stern bishop. The bleak situation gradually grows worse as the bishop becomes more controlling, but dedicated relatives make a valiant attempt to aid Emilie, Fanny and Alexander.","