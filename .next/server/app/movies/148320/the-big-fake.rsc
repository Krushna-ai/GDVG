78,"vote_average":0},{"width":1920,"height":1080,"file_path":"/64QmgWxBiusyweK5jg2xvsLiFHA.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/hbGZ0dBaLFxCuk1mamsyEq5eRKP.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/ithB9whHq9QwIdquVZYL9CtXwJw.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:28:35.144+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Il Falsario","runtime":110,"tagline":"Falsamente ispirato ad una storia vera..","homepage":"https://www.netflix.com/it/title/81679860","overview":"Un aspirante artista diventa un abile falsario per bande criminali romane degli anni '70 in questo film drammatico basato su fatti realmente accaduti."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"The Big Fake","runtime":110,"tagline":"","homepage":"https://www.netflix.com/title/81679860","overview":"Toni Chichiarelli arrives in Rome with the dream of becoming a painter, but his talent leads him elsewhere — from art galleries to state secrets. Between art, crime, and power, his signature ends up everywhere — even in the history of Italy."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"El falsario","runtime":0,"tagline":"","homepage":"https://www.netflix.com/mx/title/81679860","overview":"Un artista en ciernes se convierte en un experto falsario para bandas criminales en la Roma de los años setenta. Drama inspirado en hechos reales."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Підробник","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ua/title/81679860","overview":"Рим, 1970-ті. Талановитий художник-початківець починає малювати підробки для кримінальних угрупувань у підпіллі міста. Драматичний фільм за мотивами реальних подій."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"O Falsário","runtime":0,"tagline":"","homepage":"https://www.netflix.com/br/title/81679860","overview":"Neste drama inspirado em uma história real, um artista começa a trabalhar como falsário para gangues criminosas no submundo de Roma, na década de 1970."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"El falsificador","runtime":0,"tagline":"","homepage":"https://www.netflix.com/es/title/81679860","overview":"En este drama inspirado en hechos reales, un joven artista se convierte en un gran falsificador que trabaja con criminales de los barrios más siniestros de la Roma de los años 70."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"L'Art du faux","runtime":110,"tagline":"","homepage":"https://www.netflix.com/fr/title/81679860","overview":"Rome, années 70. Toni s'installe en ville avec pour seuls bagages son talent pour la peinture et ses rêves d'artiste. Mais son appétit pour la vie, sa soif de gloire et peut-être même son envie de marquer l'histoire vont le conduire à devenir le plus grand faussaire de tous les temps, et l'un des mystères les plus fascinants de son pays."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"伪术奇才","runtime":0,"tagline":"","homepage":"","overview":"1970年代，托尼来到罗马，他身无长物，只有一身绘画才华，以及成为伟大艺术家的梦想。对生活、命运甚至历史的渴望，最终让他成为史上最伟大的伪造大师，更是牵动意大利最难解谜团的核心人物。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Fałszerz","runtime":110,"tagline":"","homepage":"https://www.netflix.com/pl/title/81679860","overview":"W tym dramacie inspirowanym prawdziwymi wydarzeniami początkujący artysta zostaje mistrzem fałszerstw w służbie gangów działających w mrocznym półświatku Rzymu lat 70."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Thiên tài làm giả","runtime":0,"tagline":"","homepage":"https://www.netflix.com/vn/title/81679860","overview":"Trong bộ phim chính kịch lấy cảm hứng từ sự kiện có thật, một họa sĩ đầy khát vọng trở thành bậc thầy làm giả cho các băng tội phạm ẩn náu trong thế giới ngầm Rome những năm 1970."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"จอมปลอม","runtime":0,"tagline":"","homepage":"https://www.netflix.com/th/title/81679860","overview":"ในภาพยนตร์ดราม่าจากเรื่องจริง จิตรกรที่ฝันอยากสร้างชื่อกลายมาเป็นนักปลอมแปลงภาพวาดมือฉมัง และต้องทำงานให้กับแก๊งอิทธิพลเถื่อนในเงามืดของกรุงโรมยุค 70"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Padělaný život","runtime":0,"tagline":"","homepage":"https://www.netflix.com/cz/title/81679860","overview":"Drama podle skutečných událostí z římského podsvětí 70. let, ve kterém se nadějný malíř pustí do padělání uměleckých děl pro nebezpečné zločince."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Il Falsario","runtime":110,"tagline":"","homepage":"https://www.netflix.com/nl/title/81679860","overview":"Een ambitieuze kunstenaar wordt een meestervervalser voor de criminele bendes die in de jaren 70 in Rome actief zijn, in dit op ware feiten gebaseerde drama."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Egy hamisító élete","runtime":0,"tagline":"","homepage":"https://www.netflix.com/hu/title/81679860","overview":"Az 1970-es évek Rómájában játszódó történetben Toni, a tehetséges, de szegény festőművész nagy reményekkel érkezik a fővárosba két barátjával. Zseniális festői, másoló készségével kezd érvényesülni: kezdetben festményeket hamisít, majd hamarosan az alvilág szolgálatába áll. A film a valóságban is létezett Antonio Chichiarelli életén alapul."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Der Fälscher","runtime":115,"tagline":"","homepage":"https://www.netflix.com/de/title/81679860","overview":"Toni Chichiarelli kommt mit dem Traum, Maler zu werden, nach Rom, doch sein Talent führt ihn in andere Richtungen – von Kunstgalerien zu Staatsgeheimnissen. Zwischen Kunst, Verbrechen und Macht findet sich seine Handschrift überall wieder – sogar in der Geschichte Italiens."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"빅 페이크","runtime":0,"tagline":"","homepage":"https://www.netflix.com/kr/title/81679860","overview":"1970년대 로마. 화가를 꿈꾸던 청년이 도시에서 암약하던 범죄 조직에 휘말려 위조 그림을 만들게 되고, 곧 모작의 대가가 된다. 실화에서 영감을 받은 드라마 영화."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Фалшификатът","runtime":0,"tagline":"","homepage":"","overview":"Тони Чикиарели пристига в Рим с мечтата да стане художник, но талантът му го отвежда по неочаквани пътища – от художествени галерии до държавни тайни. Между изкуството, престъпността и властта, неговият подпис присъства навсякъде – дори в страниците на историята на Италия."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"הזיוף הגדול","runtime":110,"tagline":"","homepage":"https://www.netflix.com/il/title/81679860","overview":"רומא, שנות ה-70. אומן בתחילת דרכו הופך לזייפן-על בשביל כנופיות פושעים שפועלות בעולם התחתון. סרט דרמה בהשראת אירועים אמיתיים."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Gerçek Sahtekâr","runtime":0,"tagline":"","homepage":"https://www.netflix.com/tr/title/81679860","overview":"Gerçek olaylardan esinlenen bu dram filminde 1970'lerin Roması'nda gelecek vadeden bir ressam, yeraltı suç çeteleri için ünlü tabloların taklitlerini yapar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"偽術奇才","runtime":110,"tagline":"","homepage":"https://www.netflix.com/tw/title/81679860","overview":"這部劇情片取材自真人真事，描述 1970 年代羅馬一位胸懷大志的藝術家成為替地下犯罪集團服務的偽造大師。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Il Falsario","runtime":110,"tagline":"","homepage":"","overview":"Toni Chichiarelli Erromara iristen da margolari izateko ametsarekin, baina bere talentuak beste leku batzuetara eramaten du — arte galerietatik hasi eta estatu sekretuetaraino. Artearen, krimenaren eta boterearen artean, bere sinadura nonahi amaitzen da — baita Italiako historian ere."},"name":"euskera","iso_639_1":"eu","iso_3166_1":"ES","english_name":"Basque"},{"data":{"title":"El falsificador","runtime":111,"tagline":"","homepage":"","overview":"En Toni Chichiarelli arriba a Roma amb el somni de convertir-se en pintor, però el seu talent el porta a altres llocs: des de galeries d'art fins a secrets d'estat. Entre l'art, el crim i el poder, la seva empremta acaba a tot arreu, fins i tot a la història d'Itàlia."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Svindleren","runtime":111,"tagline":"","homepage":"https://www.netflix.com/dk/title/81679860","overview":"En spirende kunstner bliver mesterfalskner for kriminelle bander i underverdenens i 1970'ernes Rom i dette drama inspireret af virkelige hændelser."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"UN FALSIFICADOR","runtime":111,"tagline":"","homepage":"","overview":"Toni Chichiarelli chega a Roma co soño de converterse en pintor, pero o seu talento lévao a outras cousas: desde galerías de arte ata segredos de estado. Entre a arte, o crime e o poder, a súa sinatura acaba por todas partes, mesmo na historia de Italia."},"name":"Galego","iso_639_1":"gl","iso_3166_1":"ES","english_name":"Galician"},{"data":{"title":"Život krivotvoritelja","runtime":111,"tagline":"","homepage":"https://www.netflix.com/hr/title/81679860","overview":"Umjetnik u usponu postane vrhunski krivotvoritelj za kriminalne bande u podzemlju Rima 1970-ih, u ovoj drami nadahnutoj stvarnim događajima."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"The Big Fake","runtime":111,"tagline":"","homepage":"https://www.netflix.com/id/title/81679860","overview":"Seorang calon seniman jadi pemalsu ulung bagi geng-geng kriminal yang bersembunyi di daerah rawan di Roma pada 1970-an dalam film drama yang terinspirasi kisah nyata ini."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"ビッグ・フェイク","runtime":111,"tagline":"","homepage":"https://www.netflix.com/jp/title/81679860","overview":"1970年代のローマ。画家を目指していた青年は、いつしか裏社会に潜む犯罪組織の下で、贋作のプロとしてその名を知られるようになる。実話に着想を得たヒューマンドラマ映画。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Mesterforfalskeren","runtime":111,"tagline":"","homepage":"https://www.netflix.com/no/title/81679860","overview":"En lovende kunstner blir en forfalsker for kriminelle gjenger i Romas underverden på 1970-tallet i dette dramaet inspirert av virkelige hendelser."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Грандиозная подделка","runtime":111,"tagline":"","homepage":"https://www.netflix.com/ru/title/81679860","overview":"Рим 1970-х. Молодой художник, одарённый и амбициозный, оказывается по ту сторону закона, когда его талант замечают криминальные круги и он становится фальсификатором."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Ett falskt liv","runtime":111,"tagline":"","homepage":"https://www.netflix.com/se/title/81679860","overview":"En skicklig konstnär börjar tillverka förfalskningar åt kriminella gäng i 1970-talets Rom i detta drama som inspirerats av verkliga händelser."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"V 1970-ih Toni Chichiarelli prispe v Rim z željo, da bi postal slikar, vendar ga njegov talent vodi drugam - od umetniških galerij do državnih skrivnosti. Med umetnostjo, kriminalom in močjo se njegov podpis znajde povsod - celo v zgodovini Italije. Na podlagi resničnih dogodkov."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"الخديعة الكبرى","runtime":0,"tagline":"","homepage":"https://www.netflix.com/sa/title/81679860","overview":"يتحول رسام طموح إلى مزوّر محترف يعمل لصالح عصابات إجرامية تمارس أنشطتها خفيةً في عالم \"روما\" المظلم خلال سبعينيات القرن الماضي، في هذا الفيلم الدرامي المستوحى من أحداث حقيقية."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"الخديعة الكبرى","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ae/title/81679860","overview":"يتحول رسام طموح إلى مزوّر محترف يعمل لصالح عصابات إجرامية تمارس أنشطتها خفيةً في عالم \"روما\" المظلم خلال سبعينيات القرن الماضي، في هذا الفيلم الدرامي المستوحى من أحداث حقيقية."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"偽術奇才","runtime":0,"tagline":"","homepage":"https://www.netflix.com/hk/title/81679860","overview":"這部劇情片取材自真人真事，描述 1970 年代羅馬一位胸懷大志的藝術家成為替地下犯罪集團服務的偽造大師。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"伪术奇才","runtime":0,"tagline":"","homepage":"https://www.netflix.com/sg-zh/title/81679860","overview":"在这部改编自真人真事的剧情片中，一个本想成为的艺术家的人却成了 20 世纪 70 年代罗马犯罪团伙的伪术大师。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"Suuri huijaus","runtime":0,"tagline":"","homepage":"https://www.netflix.com/fi/title/81679860","overview":"Taiteilijasta tulee rikollisjengien mestariväärentäjä tässä 1970-luvun tositapahtumiin perustuvassa elokuvassa, joka sijoittuu Rooman alamaailmaan."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"L'Art du faux","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ca-fr/title/81679860","overview":"Dans les années 1970 à Rome, un artiste en devenir se fait maître faussaire pour des gangs criminels de l'ombre dans ce film dramatique inspiré de faits réels."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Ο Πλαστογράφος","runtime":0,"tagline":"","homepage":"https://www.netflix.com/gr/title/81679860","overview":"Ένας επίδοξος καλλιτέχνης γίνεται κορυφαίος πλαστογράφος για συμμορίες του υποκόσμου της Ρώμης του '70. Μια δραματική ταινία εμπνευσμένη από πραγματικά γεγονότα."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"A Grande Farsa","runtime":0,"tagline":"","homepage":"https://www.netflix.com/pt/title/81679860","overview":"Um aspirante a artista torna-se num mestre falsificador ao serviço de gangues do submundo de Roma dos anos 70, neste drama inspirado em eventos reais."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Marele fals","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ro/title/81679860","overview":"Un tânăr artist devine maestru falsificator pentru bandele din lumea interlopă a Romei anilor ’70, într-un film dramatic inspirat de fapte reale."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"द बिग फ़ेक","runtime":0,"tagline":"","homepage":"https://www.netflix.com/in-hi/title/81679860","overview":"सच्ची घटनाओं से प्रेरित इस ड्रामा में, 1970 के दशक में एक महत्वाकांक्षी कलाकार रोम की अंधेरी गलियों में घूम रहीं क्रिमिनल गैंग्स के लिए जालसाज़ी का काम करने लगता है."},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"The Big Fake","runtime":0,"tagline":"","homepage":"https://www.netflix.com/my/title/81679860","overview":"Filem drama berdasarkan kisah sebenar ini menceritakan tentang seorang pelukis yang menjadi pemalsu karya terkenal untuk kumpulan jenayah di lorong suram Rom era 1970-an."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"The Big Fake","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ph/title/81679860","overview":"Isang aspiring artist ang naging master forger para sa mga criminal gang sa likod ng 1970s Rome sa drama film na ito na hango sa mga tunay na kaganapan."},"name":"","iso_639_1":"tl","iso_3166_1":"PH","english_name":"Tagalog"},{"data":{"title":"جاعل بزرگ","runtime":0,"tagline":"","homepage":"","overview":"رم، دهه ۱۹۷۰. تونی با رویای هنرمند بزرگ شدن وارد شهر می‌شود. اما عطش سیری‌ناپذیر او به زندگی، سرنوشت و شاید حتی تاریخ، او را به بزرگترین جاعل تاریخ بدل خواهد کرد."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[{"id":661539,"adult":false,"title":"A Complete Unknown","video":false,"overview":"New York, early 1960s. Against the backdrop of a vibrant music scene and tumultuous cultural upheaval, an enigmatic 19-year-old from Minnesota arrives in the West Village with his guitar and revolutionary talent, destined to change the course of American music.","genre_ids":[18,10402],"popularity":6.2729,"vote_count":1369,"poster_path":"/llWl3GtNoXosbvYboelmoT459NM.jpg","release_date":"2024-12-25","vote_average":7.081,"backdrop_path":"/kcCy5tKTe6WepVQ6SQaSewpmoCj.jpg","original_title":"A Complete Unknown","original_language":"en"},{"id":8417,"adult":false,"title":"Süss, the Jew","video":false,"overview":"Nazi historical drama about Duke Karl Alexander of Württemberg and his treasurer Süß Oppenheimer.","genre_ids":[18,36],"popularity":0.3031,"vote_count":45,"poster_path":"/3fN1p4OY7Mi0zXQqMJvCdhRwEYs.jpg","release_date":"1940-09-24","vote_average":4.3,"backdrop_path":"/4msV23h4lRFXQoOUUL8Oc0XTcxt.jpg","original_title":"Jud Süß","original_language":"de"},{"id":8434,"adult":false,"title":"Summer Things","video":false,"overview":"Two couple of friends, one very rich, the other almost homeless, decide to go on Holiday. Julie, a single mother, joins them too. Once at seaside, it starts a complicate love cross among them that will involve also a transsexual, a jealous brother, a Latin Lover and another nervous stressed couple. Not to mention about the daughter of one of them that is secretly in Chicago with one of her father's employees... At the end of the summer, all of them will join the same party...","genre_ids":[35,18,10749],"popularity":0.5262,"vote_count":102,"poster_path":"/laV4Xo5O1COZefAFPJLFZ28pkYS.jpg","release_date":"2002-03-04","vote_average":5.809,"backdrop_path":"/azkp4brPsmzJiyKw5ExkPDrVpWA.jpg","original_title":"Embrassez qui vous voudrez","original_language":"fr"},{"id":661436,"adult":false,"title":"An Accident","video":false,"overview":"In the 1980s, the building themes were transformed into bipolar moral dilemmas involving overly ambitious individuals who wanted to excel at any cost. The hero is the head of a demolition crew that demolishes large buildings, initially a sympathetic young man who, in the pursuit of career and accolades, begins to transgress the boundaries of what was then called socialist morality and legality. He gradually finds himself at odds with the principles of ordinary but honest people. The narrative's bland, proclamatory film is closely connected to its time of creation, and there are hardly any more timeless insights to be found.","genre_ids":[18],"popularity":0.2665,"vote_count":0,"poster_path":"/iFKRA8kCddfN0B23EXbSW3sOgI4.jpg","release_date":"1986-09-01","vote_average":0,"backdrop_path":null,"original_title":"Havárie","original_language":"cs"},{"id":8326,"adult":false,"title":"Holes","video":false,"overview":"After being wrongfully convicted for stealing a pair of shoes, Stanley Yelnats is sent away to Camp Green Lake, a boys detention facility where inmates are forced to dig holes all day in the hot desert sun as a form of character building. But Stanley and the other boys start to unravel a mystery, linked with the camps tough-as-nails warden —and possibly Stanley’s family itself.","genre_ids":[12,10751,18,35],"popularity":3.4761,"vote_count":1508,"poster_path":"/o2Dm2mcE1qW8vT0bpsJO5OMBbqa.jpg","release_date":"2003-04-18","vote_average":6.897,"backdrop_path":"/cVMK2k0Wbs8DV3IK5sS4ziVenrI.jpg","original_title":"Holes","original_language":"en"},{"id":8338,"adult":false,"title":"Blindness","video":false,"overview":"When a sudden plague of blindness devastates a city, a small group of the afflicted band together to triumphantly overcome the horrific conditions of their imposed quarantine.","genre_ids":[18,9648,878,53],"popularity":5.8895,"vote_count":1340,"poster_path":"/deBsx5IxyqCC217j3VY24TkkE0Z.jpg","release_date":"2008-05-14","vote_average":6.514,"backdrop_path":"/sN0czEtCT1jEFQVajWBsKwdFBKm.jpg","original_title":"Blindness","original_language":"en"},{"id":661475,"adult":false,"title":"Apinan vuosi","video":false,"overview":"A young student seeks direction in his life to counterbalance the studies through female adventures.","genre_ids":[18,35],"popularity":0.424,"vote_count":2,"poster_path":"/2OnmxCt66lXG1MuSky901gwGruq.jpg","release_date":"1983-11-11","vote_average":7,"backdrop_path":"/7XvomNV2M9UqZEa87IRk69F441R.jpg","original_title":"Apinan vuosi","original_language":"fi"},{"id":471103,"adult":false,"title":"The Fight for Rome II - The Betrayal","video":false,"overview":"The devious general Cethegus plays the Byzantine and Gothic forces against each other for his own gain.","genre_ids":[18,12,36],"popularity":0.2616,"vote_count":5,"poster_path":"/mSCCFODBAn6HE1fY3jbRegPJWZ0.jpg","release_date":"1969-02-21","vote_average":7,"backdrop_path":"/tM5nwmohCwKInwqbHyQ8WX9W75E.jpg","original_title":"Kampf um Rom II - Der Verrat","original_language":"de"},{"id":8619,"adult":false,"title":"Master and Commander: The Far Side of the World","video":false,"overview":"After an abrupt and violent encounter with a French warship inflicts severe damage upon his ship, a captain of the British Royal Navy begins a chase over two oceans to capture or destroy the enemy, though he must weigh his commitment to duty and ferocious pursuit of glory against the safety of his devoted crew, including the ship's thoughtful surgeon, his best friend.","genre_ids":[12,18,10752],"popularity":3.6584,"vote_count":3437,"poster_path":"/s1cVTQEZYn4nSjZLnFbzLP0j8y2.jpg","release_date":"2003-11-14","vote_average":7.181,"backdrop_path":"/zMHyNxNt4zhL939XX8QLBW3gWfu.jpg","original_title":"Master and Commander: The Far Side of the World","original_language":"en"},{"id":8649,"adult":false,"title":"Bringing Out the Dead","video":false,"overview":"Once called \"Father Frank\" for his efforts to rescue lives, Frank Pierce sees the ghosts of those he failed to save around every turn. He has tried everything he can to get fired, calling in sick, delaying taking calls where he might have to face one more victim he couldn't help, yet cannot quit the job on his own.","genre_ids":[18],"popularity":3.3849,"vote_count":1191,"poster_path":"/gE2Q8mL0m0EA6HakRyc92uzSPJn.jpg","release_date":"1999-10-22","vote_average":6.607,"backdrop_path":"/A1V1suhllQJ1CTrKpCulcM7mjyj.jpg","original_title":"Bringing Out the Dead","original_language":"en"},{"id":1460515,"adult":false,"title":"Out of Darkness","video":false,"overview":"How does a divorced, abused and suicidal woman become one of the most successful authors in history, redeeming marriages all over the globe? This incredible true and vulnerable story of God’s healing and redemption starts before Stormie Omartian’s successful book career. In 1970’s Hollywood, Stormie was a young and ambitious actress, navigating a path filled with career setbacks and a tumultuous marriage. Amidst her journey, she encountered Michael Omartian, a music producer who sparked her spiritual curiosity. As she grappled with accepting God’s unconditional love, Stormie was forced to confront her past traumas to break free from the darkness that consumed her.","genre_ids":[18],"popularity":0.1856,"vote_count":0,"poster_path":null,"release_date":"","vote_average":0,"backdrop_path":null,"original_title":"Out of Darkness","original_language":"en"},{"id":8680,"adult":false,"title":"The Shell Seekers","video":false,"overview":"Penelope Keeling, a sixty-four-year-old daughter of a famous artist, reflects on her life, and the fate and choices that defined it, when she arrives in the Mediterranean to stay with her headstrong daughter. Shifting through time, and falling into place like the pieces of a jigsaw, the truth of Penelope's rich, heartbreaking and surprising life unfolds.","genre_ids":[18,10749],"popularity":0.3819,"vote_count":7,"poster_path":"/y7oxk0TY47vpJ1v2kcnYak0GKkX.jpg","release_date":"2007-10-18","vote_average":6.9,"backdrop_path":"/3OqHYx2QlUQxbXx6TsCAenICQd7.jpg","original_title":"The Shell Seekers","original_language":"en"},{"id":471616,"adult":false,"title":"Indian Horse","video":false,"overview":"Follows the life of Native Canadian Saul Indian Horse as he survives residential school and life amongst the racism of the 1970s. A talented hockey player, Saul must find his own path as he battles stereotypes and alcoholism.","genre_ids":[18],"popularity":0.5887,"vote_count":76,"poster_path":"/6PRmK9svHolvZ2CLNoBkmViYlrB.jpg","release_date":"2018-04-13","vote_average":6.9,"backdrop_path":"/3An5TOYitpGnZWU3GhLGVKI4vcA.jpg","original_title":"Indian Horse","original_language":"en"},{"id":8741,"adult":false,"title":"The Thin Red Line","video":false,"overview":"The story of a group of men, an Army Rifle company called C-for-Charlie, who change, suffer, and ultimately make essential discoveries about themselves during the fierce World War II battle of Guadalcanal. It follows their journey, from the surprise of an unopposed landing, through the bloody and exhausting battles that follow, to the ultimate departure of those who survived.","genre_ids":[18,36,10752],"popularity":4.1493,"vote_count":3221,"poster_path":"/seMydAaoxQP6F0xbE1jOcTmn5Jr.jpg","release_date":"1998-12-23","vote_average":7.445,"backdrop_path":"/hsDyfAk2ml82IrpPC4AHvxvuTsn.jpg","original_title":"The Thin Red Line","original_language":"en"},{"id":1460563,"adult":false,"title":"Anonimato","video":false,"overview":"","genre_ids":[53,80,18,9648],"popularity":0.1832,"vote_count":1,"poster_path":"/kUyGAyBeEev1LNgajj6OEusnS5l.jpg","release_date":"2022-04-16","vote_average":8,"backdrop_path":"/yyizL1DG6a3CPRkPYtoub4tD0kD.jpg","original_title":"Anonimato","original_language":"es"},{"id":8827,"adult":false,"title":"99 Francs","video":false,"overview":"Paris, France, 2001. Octave Parango, a young advertiser working at the Ross & Witchcraft advertising agency, lives a suicidal existence, ruled by cynicism, irresponsibility and debauchery. The obstacles he will encounter in developing a campaign for a new yogurt brand will force him to face the meaning of his work and the way he manages his relationship with those who orbit around his egotistic lifestyle.","genre_ids":[18,35],"popularity":0.8294,"vote_count":779,"poster_path":"/8yj6tkyp7dvdzkkIasX2SUmZd81.jpg","release_date":"2007-09-26","vote_average":6.6,"backdrop_path":"/wHwpdFBkvHRKS1zXptaskCFJ8BK.jpg","original_title":"99 Francs","original_language":"fr"},{"id":8512,"adult":false,"title":"Devil in a Blue Dress","video":false,"overview":"In late 1940s Los Angeles, Easy Rawlins is an unemployed black World War II veteran with few job prospects. At a bar, Easy meets DeWitt Albright, a mysterious white man looking for someone to investigate the disappearance of a missing white woman named Daphne Monet, who he suspects is hiding out in one of the city's black jazz clubs. Strapped for money and facing house payments, Easy takes the job, but soon finds himself in over his head.","genre_ids":[53,80,9648],"popularity":3.3593,"vote_count":444,"poster_path":"/5lcJhwKGavLbPva17QkTBhLfqEk.jpg","release_date":"1995-09-29","vote_average":6.45,"backdrop_path":"/n6SFCz0OsyZ800ZSlaD5WpNmqCj.jpg","original_title":"Devil in a Blue Dress","original_language":"en"},{"id":8816,"adult":false,"title":"My Life as a Dog","video":false,"overview":"A boy, obsessed with comparing himself with those less fortunate, experiences a different life at the home of his aunt and uncle in 1959 Sweden.","genre_ids":[18,35],"popularity":1.1561,"vote_count":286,"poster_path":"/eVg9IsX2HtR1BNYH0UAhF4JPHi7.jpg","release_date":"1985-12-12","vote_average":7.212,"backdrop_path":"/zKqzUT0ZAljEYPLceye6ZT4H9By.jpg","original_title":"Mitt liv som hund","original_language":"sv"},{"id":277783,"adult":false,"title":"The Ski Bum","video":false,"overview":"A ski instructor tries to teach a bunch of insanely eccentric people how to ski while dealing with everyone wanting his attention.","genre_ids":[18,53],"popularity":0.3169,"vote_count":9,"poster_path":"/azlqAASgF9VLfaFD2x6pU1qbs8d.jpg","release_date":"1971-01-08","vote_average":4.333,"backdrop_path":null,"original_title":"The Ski Bum","original_language":"en"},{"id":1068115,"adult":false,"title":"Kdo se bojí, utíká","video":false,"overview":"In a school somewhere in the border region, a young teacher is trying to integrate Romani children into the classroom. But their families remain suspicious of education. The filmmakers have chosen a largely romantic view that does not penetrate beneath the surface. They have included numerous folklore examples, acting as the most attractive element. The real problems can thus only be imagined.","genre_ids":[18],"popularity":0.1505,"vote_count":0,"poster_path":"/6f5nLRpr9doVmCbK4ei9ylwsuV0.jpg","release_date":"1987-05-01","vote_average":0,"backdrop_path":null,"original_title":"Kdo se bojí, utíká","original_language":"cs"}],"external_ids":{"imdb_id":"tt36741457","twitter_id":null,"facebook_id":null,"wikidata_id":"Q137428545","instagram_id"