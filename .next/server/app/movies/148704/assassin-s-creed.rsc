:1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/lsjYmZVrcFxrc2NTbhIK5gvb844.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/amP1hksvGf12RYUNa0sQIBuTKxT.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/alAxRXOGVsLbaCsFMT1TlE4NpA.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/9ue3zTYSp3ASMODH9145HdFGghm.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/A4Hh0MpgCqnPpdUkYGu1KU1I1fG.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/2O1kB2NaOsU2zjqlH6PtHaX0FFQ.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/9Cmw6Vrvyr0v7yyFMezVbO1d2Ik.jpg","iso_639_1":"he","iso_3166_1":"IL","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/6IyvKMLt2jzeSXMdl6fkH6W2BKE.jpg","iso_639_1":"th","iso_3166_1":"TH","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/iOlrS7SFkvC2I3thcWF9QZiEDUu.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/x414Invgp0r9aIKSnpWYDpJTL5W.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/hq8YtXrik1a5xBhMyHBSQXQQdHy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/mbGUVXEia1Dsz4UQUQS0pjD8gGY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/eLSQfnKxQbxYhx3RlA3MfyVW2BK.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2048,"height":1152,"file_path":"/tT7f7wgUSTNRtf0EBVGMUdkm5FT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2178,"height":1225,"file_path":"/lg7c9YdB2Ao9pjmaNskiBcKaDSl.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1839,"height":1034,"file_path":"/fqcYIWRVVPsF46RnnESdjhenNIJ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0}]},"enriched_at":"2026-02-26T04:14:10.403+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":116,"tagline":"Your destiny is in your blood.","homepage":"https://www.20thcenturystudios.com/movies/assassins-creed","overview":"Through a technology that unlocks the genetic memories of his ancestor in 15th century Spain, Callum Lynch discovers he is a descendant of an ancient line of Assassins and amasses lethal skills to take on the oppressive Templar Order."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":108,"tagline":"Il tuo passato è il tuo destino","homepage":"https://www.foxmovies.com/movies/assassins-creed","overview":"Callum Lynch è un criminale che ha passato la vita entrando e uscendo di prigione. Condannato a morte, viene salvato, quando ha già l'ago dell'iniezione letale in vena, da una dottoressa della Abstergo, una multinazionale dietro cui si cela l'antico e misterioso Ordine dei Templari. Avendo individuato in Callum l'ultimo discendente dell'andaluso Aguilar de Nerha, vissuto nella Spagna del XV secolo, la Abstergo vuole costringerlo a rivivere i propri ricordi ancestrali, attraverso un futuristico macchinario denominato Animus, e a mettere così i Templari sulle tracce della smarrita mela dell'Eden, la reliquia in grado di controllare il libero arbitrio. Callum scopre in questo modo di appartenere all'antica Confraternita degli Assassini, che lotta da millenni contro i Templari per assicurare al mondo libertà e giustizia."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":116,"tagline":"Plongez dans l'histoire.","homepage":"","overview":"Grâce à une technologie révolutionnaire qui révèle la mémoire génétique, Callum Lynch revit les aventures de son ancêtre, Aguilar, dans l'Espagne du XVe siècle. Callum découvre qu'il est issu d'une mystérieuse société secrète, les Assassins, et amasse les connaissances dont il aura besoin pour affronter une autre redoutable organisation : l'Ordre des templiers."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":115,"tagline":"Tu destino está en tu sangre","homepage":"","overview":"Gracias a una revolucionaria tecnología que desbloquea los recuerdos genéticos, Callum Lynch vive las aventuras de su ancestro, Aguilar, en la España del siglo XV. Callum descubre que es el descendiente de una misteriosa sociedad secreta, los Asesinos, y que posee increíbles conocimientos y habilidades que le permitirán enfrentarse a la poderosa y opresora organización de los Templarios en el presente."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Кредо убийцы","runtime":115,"tagline":"","homepage":"","overview":"Благодаря революционной технологии, которая высвобождает генетическую память, Каллум Линч переживает приключения своего предка Агилара в Испании XV столетия. Заполучив невероятные знания и способности, Каллум сразится с рыцарями ордена тамплиеров в наше время."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":115,"tagline":"Dein Schicksal liegt in deinem Blut.","homepage":"","overview":"Callum Lynch soll wegen Mordes hingerichtet werden, doch kurz bevor das Urteil vollstreckt wird, kommt er im Auftrag der Firma Abstergo Industries in die Einrichtung der Wissenschaftlerin Sophia Rikkin nach Madrid, wo Menschen mit hohem Gewaltpotenzial geheilt werden sollen. Nur wenig später erfährt Callum jedoch, dass hinter der Organisation des Generaldirektors Alan Rikkin die moderne Inkarnation des Templerordens steckt. Die Templer wollen den legendären Apfel Edens finden, um damit den freien Willen der Menschheit zu steuern – und Callum soll ihnen dabei behilflich sein. Mittels einer Maschine durchlebt er die Erinnerungen seines Vorfahren Aguilar de Nerha, einem Assassinen zur Zeit der Spanischen Inquisition. Doch während er in der Vergangenheit seine Mission ausführt, erlernt Callum immer mehr Fähigkeiten, die er in der Gegenwart gegen die Templer einsetzen kann..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":140,"tagline":"Το πεπρωμένο σου είναι στο αίμα σου.","homepage":"https://www.facebook.com/AssassinsCreedMovie","overview":"Μέσω μιας επαναστατικής τεχνολογίας που ξεκλειδώνει τις γενετικές του μνήμες, ο Κάλουμ Λιντς βιώνει τις περιπέτειες του προγόνου του, Αγκιλάρ, στην Ισπανία του 15ου αιώνα. Ο Κάλουμ ανακαλύπτει ότι κατάγεται από μια μυστηριώδη κρυφή αδελφότητα, τους Assassins, και συγκεντρώνει φοβερές γνώσεις και ικανότητες για να αντιμετωπίσει την καταπιεστική και παντοδύναμη οργάνωση Templar στο σήμερα."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"אמונת המתנקש","runtime":115,"tagline":"","homepage":"","overview":"בעזרת טכנולוגיה מהפכנית שמשחררת את הזכרונות הגנטיים שלו, קאלם לינץ' חווה את הרפתקאות אבי אבותיו, אגילאר, בספרד של המאה ה-15. קאלם מגלה שהוא נצר לחברה סודית ומסתורית, המתנקשים, ושהוא נושא עמו ידע וכישורים אדירים שאיתם הוא יכול להתמודד עם ארגון הטמפלרים העוצמתי והמדכא בימינו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Assassin’s Creed: Codul Asasinului","runtime":115,"tagline":"Destinul tău este în sângele tău.","homepage":"","overview":"Marcat de tragedie la o vârstă fragedă, Cal Lynch este un condamnat la pedeapsa capitală, care primește o neașteptată șansă de a trăi datorită activităților misterioase ale Abstergo Industries. Printr-o tehnologie revoluționară care deblochează amintirile genetice din ADN-ul său, Cal este trimis înapoi în timp, în Spania secolului al XV-lea. Acolo, el trăiește experiențele rudei sale îndepărtate, Aguilar de Nerha, un membru al unei societăți secrete denumită Asasinii, care luptă pentru protejarea liberului arbitru de Cavalerii Templieri avizi de putere. Transformat de trecut, Cal începe să dobândească capacitățile fizice și cunoștințele necesare pentru a demola organizația opresivă a Cavalerilor Templieri în prezent."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":115,"tagline":"Semmi sem igaz. Minden megengedett.","homepage":"http://www.foxmovies.com/movies/assassins-creed","overview":"Egy forradalmian új technológia segítségével Callum Lynch újraéli egyik őse, a 15. századi Spanyolországban született Aguilar kalandjait. A férfi így érti meg, hogy egy titokzatos, ősi szövetség, az Orgyilkosok rendjének leszármazottja. Hihetetlen tudással és ügyességgel rendelkezik - de csak azért, hogy szembeszállhasson a nagy erejű és gonosz szándékú Templomosokkal."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Assassin's Creed: Кредо вбивці","runtime":115,"tagline":"Працюючи в пітьмі, ми служимо світлу","homepage":"","overview":"Завдяки революційній технології, яка розблоковує генетичну пам'ять, Каллум Лінч відтворює події із життя свого предка Aguilar, який жив в Іспанії у п'ятнадцятому столітті. Каллум усвідомлює, що є членом таємничого секретного товариства «Assassins», та накопичує неймовірні знання й навички, аби в наші дні протистояти могутній та жорстокій організації «Templar»"},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"","runtime":116,"tagline":"O seu destino está no seu sangue.","homepage":"","overview":"Por meio de uma tecnologia revolucionária que destrava suas memórias genéticas, Callum Lynch experimenta as aventuras de seu ancestral, Aguilar, na Espanha do século XV. Callum descobre que é descendente de uma misteriosa sociedade secreta, os Assassinos, e acumula conhecimentos e habilidades incríveis para enfrentar a organização opressiva e poderosa dos Templários nos dias de hoje."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":115,"tagline":"Przeznaczenie masz we krwi.","homepage":"","overview":"Ekranizacja serii bijących rekordy popularności gier komputerowych. Dzięki rewolucyjnej technice, która zapewnia dostęp do zapisanych w genach wspomnień, Callum Lynch może przeżywać przygody swego przodka, Aguilara z XV-wiecznej Hiszpanii. Odkrywa przy tym, że jest potomkiem tajnego stowarzyszenia Asasynów. Zdobywa niezwykłą wiedzę i umiejętności, które pozwalają mu stawić czoło okrutnej i potężnej organizacji Templariuszy we współczesnym świecie."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":115,"tagline":"Skæbnen er i blodet","homepage":"","overview":"Som ganske ung ser Cal Lynch sin mor blive dræbt, en begivenhed, der mærker ham for livet. 30 år senere, i 2016, ligger Cal spændt fast til et bord i et fængsel i Texas dømt til døden for diverse kriminalitet. Imidlertid dør Cal ikke. Han bliver \"hvervet\" af det mystiske Abstergo Industries, hvor videnskabskvinden Sofia Rikkin arbejder på at udrydde al ondskab. Ved hjælp af en revolutionerende teknologi, der frigiver de genetiske minder gemt i Cals dna, sendes han tilbage til 1400-tallets Spanien. Her gennemlever han sin fjerne slægtning Aguilar de Nerhas oplevelser. Aguilar er medlem af et hemmeligt samfund kendt som The Assassins, der kæmper for at beskytte den frie vilje mod de magtsyge Knights Templar. I takt med at Cal begynder at forstå sin egen fortid, tilegner han sig den viden og de fysiske færdigheder, der er nødvendige, hvis han skal besejre den tyranniske Templar-organisation i nutiden."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Assassin's Creed","runtime":115,"tagline":"Osud ti koluje v žilách.","homepage":"","overview":"Španělsko, 16. století. Doba útlaku inkvizice. V této době se ocitá Aguilar de Nerha, člen řádu Asasínů, organizace existenčně zasahující už do dob před narozením Krista, neustále bojující proti svým odvěkým nepřátelům, Templářům. Obě dvě strany znají pravdu a tvoří historii, aniž by prostý lid věděl, co se děje. Atentát na panovníka, Velká Francouzská revoluce, za vším tím mohly stát tyto dvě organizace, aniž by to někdo tušil. Ze začátku to neví ani Callum Lynch, ústřední hrdina filmu, dokud ho tajuplná společnost Abstergo Industries neposadí na křeslo se schopností ukazovat lidem genetické vzpomínky jejich předků a prožívat je. Callum se ocitá v mysli právě Aguilara, zároveň se ale stává součástí tajného plánu Templářů na získání tzv. Úlomků Ráje, mocných relikvií s mocí ovládat mysli lidí, které na naší planetě zanechala První Civilizace. Pokud se tyto prostředky dostanou do rukou Absterga, bude schopný si podmanit celý svět a zastavit ho můžou jen Asasíni..."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"刺客教條","runtime":115,"tagline":"","homepage":"","overview":"活在現代的卡倫林區透過革命性的科技解開了基因記憶，讓他經歷了15世紀祖先阿基拉在西班牙的冒險，而意外發現自己原來是神祕的「刺客」祕密組織的後代。在獲取驚人知識和技能之後，林區決定起身對抗專制壓迫的現代聖殿騎士團。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":115,"tagline":"Osud ti koluje v žilách","homepage":"https://voyo.markiza.sk/filmy/7000-assassin-s-creed","overview":"Usvedčený vrah Callum Lynch je nedobrovoľne vyslobodený z cely smrti len preto, aby sa stal súčasťou storočného boja medzi asasínmi, templármi a španielskymi inkvizítormi. Jeho novým väzením sa stáva tajné zariadenie Abstergo vybavené revolučnou technológiou Animus, ktorá odhaľuje v ľudskej DNA genetické spomienky a tým umožňuje vrátiť sa a prežiť spomienky predkov, ktoré boli doteraz stratené v minulosti. Callum sa vďaka Animusu prepojí so svojím predkom žijúcim v Granade a Seville v období španielskej inkvizície v 15. storočí. Volá sa Aguilar de Nerha a je členom bratstva asasínov, ktoré už niekoľko storočí vedie skrytú vojnu s templármi, svojimi odvekými nepriateľmi. Tajná organizácia asasínov sa zaviazala chrániť slobodnú vôľu ľudstva a snaží sa zabrániť tomu, aby sa templári s pomocou inkvizície zmocnili mocného artefaktu nazývaného Jablko Raja. A práve tento artefakt je podľa presvedčenia templárov nástrojom na ovládnutie celého sveta."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"","runtime":115,"tagline":"O teu destino está no teu sangue.","homepage":"","overview":"Através de uma tecnologia revolucionária que desvenda suas memórias genéticas, Callum Lynch revive as aventuras do seu antepassado, Aguilar, na Espanha do século XV. Callum descobre que é descendente de uma misteriosa sociedade secreta, os Assassinos, e que reúne conhecimentos e habilidades extraordinárias para controlar a opressiva e poderosa organização Templários no presente."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":115,"tagline":"Kaderin kanında yatıyor.","homepage":"","overview":"Genetik kodunun kilidini kırması ile atalarının hatıralarına erişim sağlayabilen Callum Lynch, 15. yüzyıl İspanya'sında yaşayan atası Aguilar'ın maceralarını kendi hafızalarında yer alacak kadar canlı bir şekilde deneyimler. Gizli bir topluluk olan Suikastçiler'in soyundan geldiğini öğrenen genç adam yeni kazandığı beceriler ile baskıcı ve güçlü organizasyon Tapınakçıların karşısına çıkar. Callum, günümüzde de varolan Tapınakçılar organizasyonunu alt etmek için geçmişindeki bilgi ve tecrübesini kullanacaktır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"刺客信条","runtime":115,"tagline":"信仰之跃 刺客重生","homepage":"","overview":"卡勒姆·林奇 在死刑即将执行之前清醒过来，发现他被索菲娅 选中，来参加一个能让人类摆脱暴力冲动的计划。虚拟现实机器 Animus 能让用户体验祖先的记忆，被绑在机器上之后，卡勒姆·林奇意识到他是生活在西班牙宗教法庭时期一位刺客阿圭拉的后裔，他们寻找的是可以控制自由意志的伊甸园苹果。索菲娅在父亲艾伦 施加的压力下不情愿地操纵着卡勒姆·林奇回到过去寻找伊甸园苹果在现代世界的下落，威胁着他身体和心理的健康。但在杀手同行穆萨 暗示了卡勒姆·林奇，提醒他艾伦有可能动机不纯之后，卡勒姆·林奇开始重新考虑他的行为和动机，而人类自由意志的命运也变得悬而未决……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":115,"tagline":"Tvoja sudbina je u tvojoj krvi.","homepage":"","overview":"Putem revolucionarne tehnologije koja ima mogućnost otključati genetička sjećanja ljudi, Callum Lynch na svojoj koži iskusi sjećanja svog davnog pretka, Aguilara, koji je živio u Španjolskoj tokom 15. stoljeća. Callum ubrzo otkrije da je pomotak linije drevnog tajnog društva ubojica, te stekne nevjerojatno znanje i sposobnosti kako bi se mogao boriti protiv vječnog neprijatelja ubojica, Templara, koji su prisutni i u današnjem vremenu i prijete uništenjem svijeta."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"Gracias a una revolucionaria tecnología que desbloquea los recuerdos genéticos, Callum Lynch vive las aventuras de su ancestro, Aguilar, en la España del siglo XV. Callum descubre que es el descendiente de una misteriosa sociedad secreta, los Asesinos, y que posee increíbles conocimientos y habilidades que le permitirán enfrentarse a la poderosa y opresora organización de los Templarios en el presente."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Орденът на асасините","runtime":115,"tagline":"Съдбата е в кръвта ти","homepage":"","overview":"\"Съдбата е написана в кръвта ти\" е буквална заплаха за Калъм Линч, който след куп генетични изследвания се оказва наследник на тайното общество на Асасините. Assassin's Creed е необятна, пресичаща времена и светове история за съдбата на човек, който се озовава в центъра на древна битка между две могъщи секти. Единствено чрез овладяване на спомените на своя прародител, запечатани в собствената му ДНК, той ще може да сложи край на конфликта и да спечели собственото си изкупление."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"어쌔신 크리드","runtime":115,"tagline":"“원하는 게 뭡니까?” “당신의 과거. 그곳에서 보고 듣고 느끼는 것들은 500년 전 조상의 기억이죠”","homepage":"","overview":"어린 시절의 트라우마로 암흑의 삶을 살던 사형수 칼럼 린치 는 의문의 조직, 앱스테르고의 과학자 소피아 에 의해 자신의 유전자에 과거의 비밀이 깃들어 있다는 사실을 깨닫게 된다. 유전자 속에 숨어 있는 기억을 찾아주는 최첨단 기술을 통해 15세기에 살았던 조상 '아귈라'의 모험을 직접 체험하게 된 그는 '아귈라'가 비밀 모임 ‘암살단’에 속해 있었다는 사실까지 알게 된다. 이후, 놀라운 지식과 기술을 축적한 그는 세상을 통제하려는 템플 기사단에 맞서게 되는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Тајно друштво убица","runtime":115,"tagline":"","homepage":"","overview":"Калум Линч открива да је потомак тајног друштва „Убица\" захваљујући револуционарној технологији која откључава његова генетска сећања. Помоћу ње он проживљава авантуре свог претка Агилара у Шпанији 15. века. Након што стекне невероватно знање и моћи, Линч се враћа у савремено доба како би се супротставио опасним и моћним витезовима темпларима."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Assassin's Creed","runtime":115,"tagline":"","homepage":"","overview":"Dankzij een revolutionaire technologie die de sleutel vormt tot het oprakelen van  iemands genetische herinneringen weet Callum Lynch de avonturen  van zijn voorvader Aguilar in het 15e eeuwse Spanje te beleven."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Žudikų brolija","runtime":115,"tagline":"Likimas užkoduotas tavo kraujyje","homepage":"","overview":"Dar viduramžiais paslaptingieji asasinai – elitiniai žudikai – krauju prisiekė saugoti Obuolį nuo Tamplierių ordino – ginti ir saugoti iki paskutinio atodūsio, iki paskutinės gyvos asasinų kartos. Jame slypinti pavojinga galia Tamplierius paverstų žiauriais ir vieninteliais šio pasaulio valdovais... Kriminalinis nusikaltėlis Callumas Lynchas nuo mirties bausmės yra išgelbėjamas savo paties budelių – paslaptingos organizacijas „Abstergo Industries“, kuri, prisidengdama moksline veikla, iš tiesų yra šiuolaikinis Tamplierių Ordinas. Callumas yra priverstas dalyvauti kvapą gniaužiančiame „Animus“ projekte. Inovatyviausių technologijų dėka, kurios suteikia galimybę patirti žmogaus genetikoje įšaldytus prisiminimus, Callumas turės pakartoti savo tolimo protėvio Aguilaro nuotykius. Patekęs į praėjusių amžių pasaulį, Callumas suvokia esąs Žudikų brolijos narys ir pamažu įgyja visas savo protėvio žinias bei įgūdžius, reikalingus įveikti Tamplierius."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Asasinov nazor","runtime":115,"tagline":"","homepage":"","overview":"S pomočjo revolucionarne tehnologije, ki zmore odkleniti spomine v njegovih genetskih zapisih, Callum Lynch izkusi pustolovščine svojega prednika Aguilarja v Španiji 15. stoletja. Pri tem odkrije, da je potomec skrivnostne in tajne organizacije asasinov in se dokoplje do neverjetnega znanja in sposobnosti."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"","runtime":115,"tagline":"Plongez dans l'histoire.","homepage":"","overview":"Callum est condamné à mort pour meurtre. Après son exécution, il est recueilli par une équipe de scientifiques qui cherchent à l'utiliser pour voyager dans le temps. Callum est dans la lignée des Assassins, une tribu qui s'oppose aux Templiers qui désirent mettre la main sur une pomme ancestrale afin d'asservir l'humanité. En retournant en 1492 dans la peau de son ancêtre, Callum doit retrouver un important garçon et éviter que la pomme ne tombe entre de mauvaises mains. En passant régulièrement du passé au présent, le prisonnier en apprend de plus en plus sur les intentions de ses sauveurs."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"Kuolemaan tuomittu Cal Lynch päätyy osalliseksi Abstergo Industriesin pyörittämää Animus-projektia, jossa samaa nimeä kantavalla laitteella pyritään kartoittamaan koehenkilöiden geneettistä muistia. Lynchin suonissa virtaa 1400-luvun Espanjassa temppeliherroja vastaan taistelleen salamurhaaja Aguilar de Nerhan veri. Animuksen avulla Lynch lähetetään takaisin menneisyyteen, inkvisition runtelemaan Espanjaan paikantamaan Abstergo Industriesin hamuamaa voimallista taikaesinettä, Eedenin omenaa. Lynchin tietoja ja taitoja tarvitaan nyt taistelussa mahtavaa ja tyrannimaista Templar-organisaatiota vastaan."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"アサシン クリード","runtime":115,"tagline":"歴史の迷宮に潜り込め。","homepage":"","overview":"記憶をなくした死刑囚カラム・リンチは、遺伝子操作をする装置によって祖先の記憶を追体験する。カラムの祖先はルネサンス期のスペインでテンプル騎士団に立ち向かうアサシン教団の一員で、人類支配の力を持つ禁断の秘宝のありかを知る、歴史上最後の人物でもあった。現在と過去を行き来する中で、カラムは人類の未来を左右する戦いに身を投じていく──！"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"Genom banbrytande teknik som låser upp Callum Lynchs genetiska minnen han får uppleva hans förfader Aguilars äventyr i 1300-talets Spanien. Callum upptäcker att han härstammar från ett mystiskt och hemligt sällskap, Assassinerna, och erhåller kunskap och förmågor för att ta sig an den grymma och kraftfulla Tempelherreorden i nutid."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"อัสแซสซินส์ ครีด","runtime":115,"tagline":"","homepage":"","overview":"เรื่องราวการปฏิวัติเทคโนโลยีทางวิทยาศาสตร์ที่ช่วยปลดล็อคความทรงจำเกี่ยวกับต้นกำเนิดของเขา คัลลั่ม ลินช์ ได้ย้อนกลับไปยังอดีตของบรรพบุรุษของเขาในช่วงศตวรรษที่ 15 คัลลั่มได้ค้นพบว่าเขาสืบเชื้อสายมาจากหนึ่งในสมาชิกกลุ่มนักฆ่าลึกลับ ซึ่งสมาชิกทุกคนในกลุ่มจะได้รับการฝึกฝนทักษะความรู้และความสามารถในการต่อสู้เพื่อมาต่อกรกับกลุ่มอัศวินเทมพลาร์จนถึงปัจจุบัน"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Sát Thủ Bóng Đêm","runtime":115,"tagline":"Số phận đã được ấn định trong huyết thống.","homepage":"","overview":"Nhờ vào một công nghệ cải tiến có thể phá vỡ những kí ức trong cấu trúc gien, Callum Lynch đã có thể làm sống lại kí ức về những cuộc phiêu lưu của tổ tiên mình – Aguilar – Tây Ban Nha vào thế kỉ 15. Thông qua kí ức này, Callum đã phát hiện rằng mình là hậu duệ của một hội kín bí ẩn mang tên Assassins và đồng thời tích lũy được hàng loạt kiến thức, kĩ năng không tưởng để đối đầu với một tổ chức đầy áp bức và hùng mạnh ngày nay – Hiệp Sĩ Dòng Đền."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Assassin's Creed: Slepkavas kodekss","runtime":115,"tagline":"","homepage":"","overview":"Pateicoties revolucionārajai tehnoloģijai, kura atbrīvo ģenētisko atmiņu, Kalums Linčs ir spējīgs izdzīvot sava 500 gadus senā priekšteča piedzīvojumus viduslaiku Spānijā. Ieguvis neticamas zināšanas un spējas, Kalums ir gatavs mest izaicinājumu slepenajam templiešu ordenim arī mūsdienās."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"Dalam adaptasi serial video game yang menuai banyak pujian ini, seorang pria yang akan dihukum mati diselamatkan dari eksekusi oleh satu organisasi misterius."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"刺客教條","runtime":115,"tagline":"繼承刺客基因 500年記憶潛逃 改寫世界歷史","homepage":"","overview":"卡勒姆·林奇 在死刑即將執行之前清醒過來，發現他被索菲婭 選中，要參加一個能讓人類擺脱暴力衝動的計劃。虛擬現實機器 Animus 能讓用戶體驗祖先的記憶，被綁在機器上之後，卡勒姆·林奇意識到他是生活在西班牙宗教法庭時期一位殺手的後裔，他們尋找的是可以控制自由意志的伊甸園蘋果。索菲婭被迫於父親艾倫 的壓力，她不情願地操縱著勒姆·林奇尋找伊甸園蘋果在現代世界的下落，威脅著他身體和心理的健康。但在殺手同行 Baptiste 暗示了卡勒姆·林奇，艾倫有可能動機不純之後，卡勒姆·林奇開始重新考慮他的行為和動機，而人類自由意志的命運懸而未決 。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"Fassbender spiller Callum Lynch, som opplever livet til sin stamfar fra 1400-tallet via en teknologi som låser opp hans genetiske minne. Callum fnner ut at han en gang tilhørte et hemmelig samfunn av snikmordere, og opparbeider seg dødbringende evner for å gå imot de tyranniske tempelridderne."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"أساسينز كريد","runtime":115,"tagline":"مصيرك في دمك.","homepage":"","overview":"من خلال الذكريات الجينية غير المؤمنة التي تسمح له باستعادة مغامرات سلفه في إسبانيا في القرن 15th ، يكتشف كالوم لينش أنه سليل مجتمع \"القتلة\" السري. بعد اكتساب معرفة ومهارات لا تصدق ، يستعد الآن لمواجهة فرسان الهيكل القمعيين في الوقت الحاضر."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"მკვლელის მრწამსი","runtime":115,"tagline":"შენი ბედი შენს სისხლშია.","homepage":"","overview":"კალუმ ლინჩი თავისი წინაპრის აგილარის თავგადასავლებით ცხოვრობს მე-15 საუკუნის ესპანეთში. კალუმი გაიგებს, რომ ის არის იდუმალი საიდუმლო საზოგადოების წევრების, მკვლელების შთამომავალი. წარმოუდგენელი ცოდნისა და უნარების დაგროვების შემდეგ, ის ეწინააღმდეგება ტამპლიერების ძლიერ და სასტიკ ორგანიზაციას ჩვენს დღეებში."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":115,"tagline":"Dein Schicksal liegt in deinem Blut.","homepage":"","overview":"In dieser Verfilmung der gefeierten Videospielreihe wird ein Mann in der Todeszelle von einer rätselhaften Organisation vor der Hinrichtung gerettet."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"","runtime":115,"tagline":"Dein Schicksal liegt in deinem Blut.","homepage":"","overview":"In dieser Verfilmung der gefeierten Videospielreihe wird ein Mann in der Todeszelle von einer rätselhaften Organisation vor der Hinrichtung gerettet."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"CH","english_name":"German"},{"data":{"title":"أساسينز كريد","runtime":115,"tagline":"مصيرك في دمك.","homepage":"","overview":"في هذا الفيلم المستوحى من سلسلة ألعاب فيديو شهيرة تحمل الاسم نفسه وحققت شهرةً، يُقدِم تنظيم غامض على إنقاذ رجل محكوم عليه بالإعدام."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"आलोचकों द्वारा सराही गई वीडियो गेम फ्रैंचाइज़ी पर आधारित इस फ़िल्म में, एक रहस्यमयी संगठन मौत की कगार पर खड़े एक व्यक्ति को मरने से बचा लेता है."},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"","runtime":115,"tagline":"Je lot zit in je bloed.","homepage":"","overview":"In deze verfilming van de veelgeprezen videogamefranchise wordt een man in de dodencel gered van executie door een mysterieuze organisatie."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"I denne filmversjonen av den kritikerroste dataspillserien blir en dødsdømt mann reddet fra henrettelse av en mystisk organisasjon."},"name":"Bokmål","iso_639_1":"nb","iso_3166_1":"NO","english_name":"Norwegian Bokmål"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"I denne filmversjonen av den kritikerroste dataspillserien blir en dødsdømt mann reddet fra henrettelse av en mystisk organisasjon."},"name":"","iso_639_1":"nn","iso_3166_1":"NN","english_name":"Norwegian Nynorsk"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"Dalam adaptasi francais permainan video pilihan pengkritik ini, seorang lelaki di penjara maut diselamatkan daripada pelaksanaan hukuman mati oleh organisasi misteri."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"Dalam adaptasi francais permainan video pilihan pengkritik ini, seorang lelaki di penjara maut diselamatkan daripada pelaksanaan hukuman mati oleh organisasi misteri."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"SG","english_name":"Malay"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"Sa pamamagitan ng teknolohiya na nagbubukas ng kanyang mga genetic na alaala, naranasan ni Callum Lynch ang mga pakikipagsapalaran ng kanyang ninuno sa ika-15 Siglong Espanya. Natuklasan niya na siya ay nagmula sa isang misteryosong lihim na lipunan, ang mga Assassin, at nakalikom ng kaalaman at kasanayan upang harapin ang mapang-api at makapangyarihang organisasyon ng Templar sa kasalukuyan."},"name":"","iso_639_1":"tl","iso_3166_1":"PH","english_name":"Tagalog"},{"data":{"title":"刺客信条","runtime":115,"tagline":"信仰之跃 刺客重生","homepage":"","overview":"在这部改编自备受赞誉的电子游戏系列的电影中，一个死囚在执行死刑时被神秘组织解救出来。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"Assassin’s Creed","runtime":115,"tagline":"El teu destí és a la teva sang","homepage":"","overview":"Gràcies a una revolucionària tecnologia que desbloqueja els records genètics, Callum Lynch viu les aventures del seu ancestre, Aguilar, a l'Espanya del segle XV. Callum descobreix que és el descendent d'una misteriosa societat secreta, els Assassins, i que posseeix coneixements i habilitats increïbles que li permetran enfrontar-se a la poderosa i opressora organització dels Templers en el present."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"اساسینز کرید","runtime":115,"tagline":"","homepage":"","overview":"فیلم اساسینز کرید، داستان مردی به نام کالوم لینچ را روایت می‌کند که می‌فهمد جدش آگیلار در قرن ۱۵ و در اسپانیا عضو حشاشین بوده‌است و با گروهی معروف به تمپلارها می‌جنگیده‌است. به او گفته می‌شود که تمپلارها در جستجوی سیب عدن هستند که حاوی کد ژنتیکی ارادهٔ آزاد در انسان است و توسط آن قادر به کنترل نسل بشر خواهند شد. برای همین کالوم را به کار می‌گیرند تا با استفاده از حافظهٔ ژنتیکی‌اش به حافظهٔ آگیلار دست یابند که آخرین کسی بوده که سیب عدن را در اختیار داشته تا بفهمند سیب عدن کجاست. کالوم اما در اثر این تجربه، مهارت‌ها و فنون جنگی آگیلار را یادمی‌گیرد و در دوراهی ادامهٔ راهش یا همکاری با دشمنانش قرار می‌گیرد."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"}],"reviews_tmdb":[{"id":"58a862ef92514156ab00a0a7","url":"https://www.themoviedb.org/review/58a862ef92514156ab00a0a7","author":"PeterJasonQuill","content":"Fun film. Has plenty of action sequences and great plot twists throughout the film that make it more interesting. Plenty of well developed characters throughout, and each character has great depth. The execution of the stunts was superb and had breathtaking set-pieces throughout. It's more faithful to the games than other previous game adaptions like Doom and Warcraft: The Beginning, and it moves away from the story while keeping what made the games so well received. A great movie, definitely worth the watch.","created_at":"2017-02-18T15:06:23.629Z","updated_at":"2021-06-23T15:57:54.481Z","author_details":{"name":"PeterJasonQuill","rating":9,"username":"Star Lord","avatar_path":"/69luddDoRLr53YtgEC4mCXlCkcR.jpg"}},{"id":"58b11610c3a368076c004fc9","url":"https://www.themoviedb.org/review/58b11610c3a368076c004fc9","author":"CraigJamesReview","content":"I actually really liked this- the action sequences are exciting and take on a kind of Jason Bourne-quality and Fassbender, Cotillard and Irons do a nice job of making the characters interesting and helping to overlook a lot of the silliness of the script. Overall an 8/10\r\n\r\nCheck out my full Youtube review. Trying to go for something funny, engaging, and informative so hope you guys like-https://youtu.be/Um2-B6Gs_QU","created_at":"2017-02-25T05:28:48.102Z","updated_at":"2021-06-23T15:57:55.042Z","author_details":{"name":"","rating":null,"username":"CraigJamesReview","avatar_path":null}},{"id":"58e3ad27c3a36872ee020a90","url":"https://www.themoviedb.org/review/58e3ad27c3a36872ee020a90","author":"Gimly","content":"I have the advantage of multiple _Assassin's Creed_ games under my belt, and even to me it was nonsense. Wastes an **incredible** cast on what will wind up contributing to the seemingly never-ending pile of lacklustre videogame adaptations.\r\n\r\n_Final rating:★★ - Had some things that appeal to me, but a poor finished product._","created_at":"2017-04-04T14:26:47.737Z","updated_at":"2021-06-23T15:57:56.216Z","author_details":{"name":"Gimly","rating":4,"username":"Ruuz","avatar_path":"/xUObnJSvHrFPsIpoDmb1jiQZLq7.jpg"}},{"id":"591d636dc3a368774e01d5d5","url":"https://www.themoviedb.org/review/591d636dc3a368774e01d5d5","author":"Per Gunnar Jonsson","content":"$11","created_at":"2017-05-18T09:03:41.777Z","updated_at":"2024-05-16T15:21:15.378Z","author_details":{"name":"Per Gunnar Jonsson","rating":6,"username":"Dark Jedi","avatar_path":null}},{"id":"597e057dc3a36854510191a1","url":"https://www.themoviedb.org/review/597e057dc3a36854510191a1","author":"Reno","content":"$12","created_at":"2017-07-30T16:12:45.550Z","updated_at":"2024-05-16T15:18:35.565Z","author_details":{"name":"Reno","rating":4,"username":"Rangan","avatar_path":"/6ZpVUJzqXMzH35VprEtnX0sNI3.jpg"}},{"id":"5c4400f9c3a36819fd23c511","url":"https://www.themoviedb.org/review/5c4400f9c3a36819fd23c511","author":"Lucky_Man","content":"I bought this movie recently for a very small amount, and began watching it with very small expectations.\r\n\r\nI was treated to a well-paced, stylish action film that relied more on esoteric ambiguity (and a passing knowledge of the video game franchise) than exposition and characterization. Rather than being a hindrance to the overall product, I believe this \"flaw\" serves the style of this movie wonderfully, and honors to source material to create an interesting and engaging fictional world.\r\n\r\nThe discerning eye of a devoted film-goer may think this movie is quite beautiful and would find very little argument from me. Certain shots and choices in lighting are remarkable, and the filmmakers emphasis on practicality over computer renderings translates very well during the action sequences. \r\n\r\nI would recommend this film - you may not love it, and you don't have to - but it is certainly worth watching.","created_at":"2019-01-20T05:02:49.128Z","updated_at":"2021-06-23T15:58:15.952Z","author_details":{"name":"","rating":7,"username":"Lucky_Man","avatar_path":"/u8FG18TbmH9YZX2CCkXOuU93WlH.jpg"}},{"id":"5e2f2970c56d2d00154e5c00","url":"https://www.themoviedb.org/review/5e2f2970c56d2d00154e5c00","author":"Matthew Brady","content":"YOU WERE THE CHOSEN ONE! You were supposed to destroy the bad video movies, not join them! Bring balance to cinema, not leave it in darkness!﻿","created_at":"2020-01-27T18:18:24.510Z","updated_at":"2021-06-23T15:58:33.503Z","author_details":{"name":"Matthew Brady","rating":4,"username":"MatthewL.Brady","avatar_path":"/k5J0l25FXOCw4TcX6iWaJmYpCZ4.jpg"}},{"id":"648c731bc2ff3d00e2df53a7","url":"https://www.themoviedb.org/review/648c731bc2ff3d00e2df53a7","author":"Filipe Manuel Neto","content":"$13","created_at":"2023-06-16T14:35:07.519Z","updated_at":"2023-06-16T14:35:07.651Z","author_details":{"name":"Filipe Manuel Neto","rating":3,"username":"FilipeManuelNeto","avatar_path":"/nidqITf735x9xxHfncXkT9BmOQ7.png"}}],"recommendations":[{"id":274870,"adult":false,"title":"Passengers","video":false,"overview":"A spacecraft traveling to a distant colony planet and transporting thousands of people has a malfunction in its sleep chambers. As a result, two passengers are awakened 90 years early.","genre_ids":[18,10749,878],"media_type":"movie","popularity":5.3387,"vote_count":14030,"poster_path":"/jK9S6HANSf2no64v1x1HxfcpmcA.jpg","release_date":"2016-12-21","vote_average":6.952,"backdrop_path":"/gHz4ZQytRs8YGrqFMwB3Vrr8pig.jpg","original_title":"Passengers","original_language":"en"},{"id":346672,"adult":false,"title":"Underworld: Blood Wars","video":false,"overview":"Vampire death dealer Selene fends off brutal attacks from both the Lycan clan and the Vampire faction that betrayed her. With her only allies, David and his father Thomas, she must stop the eternal war between Lycans and Vampires, even if it means she has to make the ultimate sacrifice.","genre_ids":[14,28,53,878,27],"media_type":"movie","popularity":5.1682,"vote_count":3879,"poster_path":"/v1ciDCWMG47gdT4kMyjyQbnLQQn.jpg","release_date":"2016-11-24","vote_average":5.913,"backdrop_path":"/b5QnSrjDRHUFg3hpjmwBwsJfzyP.jpg","original_title":"Underworld: Blood Wars","original_language":"en"},{"id":311324,"adult":false,"title":"The Great Wall","video":false,"overview":"European mercenaries searching for black powder become embroiled in the defense of the Great Wall of China against a horde of monstrous creatures.","genre_ids":[28,12,14],"media_type":"movie","popularity":7.2359,"vote_count":5460,"poster_path":"/p70dq1YxabemdZDm5K6Q8G10wSn.jpg","release_date":"2016-12-16","vote_average":6.027,"backdrop_path":"/th26RNksfM9nn7DPH06OqiV6BA2.jpg","original_title":"The Great Wall","original_language":"en"},{"id":330459,"adult":false,"title":"Rogue One: A Star Wars Story","video":false,"overview":"A rogue band of resistance fighters unite for a mission to steal the Death Star plans and bring a new hope to the galaxy.","genre_ids":[28,12,878],"media_type":"movie","popularity":7.1161,"vote_count":16161,"poster_path":"/i0yw1mFbB7sNGHCs7EXZPzFkdA1.jpg","release_date":"2016-12-14","vote_average":7.5,"backdrop_path":"/8mTHUXS3vwub5ZlovQkZ8veQUah.jpg","original_title":"Rogue One: A Star Wars Story","original_language":"en"},{"id":68735,"adult":false,"title":"Warcraft","video":false,"overview":"The peaceful realm of Azeroth stands on the brink of war as its civilization faces a fearsome race of invaders: orc warriors fleeing their dying home to colonize another. As a portal opens to connect the two worlds, one army faces destruction and the other faces extinction. From opposing sides, two heroes are set on a collision course that will decide the fate of their family, their people, and their home.","genre_ids":[28,12,14],"media_type":"movie","popularity":5.6481,"vote_count":7151,"poster_path":"/nZIIOs06YigBnvmlJ2hxZeA8eTO.jpg","release_date":"2016-05-25","vote_average":6.397,"backdrop_path":"/riaO9lEYnzlmkILiLG3Y6HtJaM3.jpg","original_title":"Warcraft","original_language":"en"},{"id":369885,"adult":false,"title":"Allied","video":false,"overview":"In 1942, an intelligence officer in North Africa encounters a female French Resistance fighter on a deadly mission behind enemy lines. When they reunite in London, their relationship is tested by the pressures of war.","genre_ids":[28,18,10752,10749,53],"media_type":"movie","popularity":4.7971,"vote_count":4724,"poster_path":"/sV4lXM32quwminL3TP36nlNPp7Q.jpg","release_date":"2016-11-23","vote_average":6.804,"backdrop_path":"/cdR0qwyaMfuZRfTYEixUmRnmdop.jpg","original_title":"Allied","original_language":"en"},{"id":173897,"adult":false,"title":"Resident Evil: The Final Chapter","video":false,"overview":"Picking up immediately after the events in Resident Evil: Retribution, Alice is the only survivor of what was meant to be humanity's final stand against the undead. Now, she must return to where the nightmare began - The Hive in Raccoon City, where the Umbrella Corporation is gathering its forces for a final strike against the only remaining survivors of the apocalypse.","genre_ids":[28,27,878],"media_type":"movie","popularity":0.2806,"vote_count":3409,"poster_path":"/7glPlA0xPpxPxBu0TnY4ulQVCV1.jpg","release_date":"2016-12-23","vote_average":6.1,"backdrop_path":"/sQRfWdDxH53Vk7ZJ1UqzcaBHocO.jpg","original_title":"Resident Evil: The Final Chapter","original_language":"en"},{"id":345920,"adult":false,"title":"Collateral Beauty","video":false,"overview":"Retreating from life after a tragedy, a man questions the universe by writing to Love, Time and Death. Receiving unexpected answers, he begins to see how these things interlock and how even loss can reveal moments of meaning and beauty.","genre_ids":[18,10749],"media_type":"movie","popularity":2.2768,"vote_count":5510,"poster_path":"/4vfqosgik5pLb32RpskYifp8PWJ.jpg","release_date":"2016-12-15","vote_average":7.218,"backdrop_path":"/iovi35nPfjbYTw2gRo7uImWblRU.jpg","original_title":"Collateral Beauty","original_language":"en"},{"id":259695,"adult":false,"title":"Live by Night","video":false,"overview":"A group of Boston-bred gangsters set up shop in balmy Florida during the Prohibition era, facing off against the competition and the Ku Klux Klan.","genre_ids":[80,18,53],"media_type":"movie","popularity":2.8097,"vote_count":1372,"poster_path":"/bkd46T4RplawnDjpHoI8mhzTLks.jpg","release_date":"2016-12-25","vote_average":6.272,"backdrop_path":"/vClMoGPBTt2mh1NFthtBCZlwO2r.jpg","original_title":"Live by Night","original_language":"en"},{"id":259316,"adult":false,"title":"Fantastic Beasts and Where to Find Them","video":false,"overview":"In 1926, Newt Scamander arrives at the Magical Congress of the United States of America with a magically expanded briefcase, which houses a number of dangerous creatures and their habitats. When the creatures escape from the briefcase, it sends the American wizarding authorities after Newt, and threatens to strain even further the state of magical and non-magical relations.","genre_ids":[14,12],"media_type":"movie","popularity":8.7573,"vote_count":19528,"poster_path":"/fLsaFKExQt05yqjoAvKsmOMYvJR.jpg","release_date":"2016-11-16","vote_average":7.308,"backdrop_path":"/8Qsr8pvDL3s1jNZQ4