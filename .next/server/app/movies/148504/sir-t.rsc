9:{"metadata":[["$","title","0",{"children":"Sirāt | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"A man and his son arrive at a rave lost in the mountains of Morocco. They are looking for Marina, their daughter and sister, who disappeared months ago at another rave. Driven by fate, they decide to follow a group of ravers in search of one last party, in hopes Marina will be there."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148504/sir-t"}],["$","meta","5",{"property":"og:title","content":"Sirāt"}],["$","meta","6",{"property":"og:description","content":"A man and his son arrive at a rave lost in the mountains of Morocco. They are looking for Marina, their daughter and sister, who disappeared months ago at another rave. Driven by fate, they decide to follow a group of ravers in search of one last party, in hopes Marina will be there."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148504/sir-t"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/bzBtsLi17rK4G6kDvOXfUZfAhca.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Sirāt"}],["$","meta","12",{"name":"twitter:description","content":"A man and his son arrive at a rave lost in the mountains of Morocco. They are looking for Marina, their daughter and sister, who disappeared months ago at another rave. Driven by fate, they decide to follow a group of ravers in search of one last party, in hopes Marina will be there."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/bzBtsLi17rK4G6kDvOXfUZfAhca.jpg"}],["$","link","14",{"rel":"ic