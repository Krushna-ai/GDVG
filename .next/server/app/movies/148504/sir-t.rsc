,"file_path":"/iOLrT64V9y6k60Bc94vNnBp4UEv.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2489,"height":1400,"file_path":"/w7vw4O3DAOGoIrnDU2LhvfUz8wq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1843,"height":1037,"file_path":"/5BTPLFDB5eAcPvJXr0grLne0kFx.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2496,"height":1404,"file_path":"/iG1tElwELmd7o4JUwbOOkD1yFHZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1833,"height":1031,"file_path":"/flEcfbfADxwovvIJYpkWyrpU0Qz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1679,"height":944,"file_path":"/yGJwM2BPU0vmeEn2jWGUc4NtpP1.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":1843,"height":1037,"file_path":"/5dD7YRDJKMYFN7Txjm6b0TnXot.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1689,"height":950,"file_path":"/nFd1DwFz7QLOzbOmw84JAfjsp4i.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1843,"height":1037,"file_path":"/uyz1OXJwNiDYa99W5zIV3wU7eJA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1843,"height":1037,"file_path":"/o4wd10W82ES4GWPugdn26kMnEoK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1843,"height":1037,"file_path":"/gEyWB4m0apO0QUUTE4cpS77qbds.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1843,"height":1037,"file_path":"/3ghRHnSIdGrwty6qCYNdrmF9Z83.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1843,"height":1037,"file_path":"/yhV0uo61SlJrSqhMqdRc5Xtbs0y.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1843,"height":1037,"file_path":"/AmhdJPus928Z9NFwQJ9Bz3m4spm.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2507,"height":1410,"file_path":"/hQKbSsKsNvJZSRnSmE4DIZAOMMI.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/2d5rp26XFJfvWHvrEqQPSUqGc3T.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/xx7jPKEp6lrY0RAoTadHCsEHupC.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3755,"height":2112,"file_path":"/4zsJOOlGyQKIqmH5wN22TkxR3lj.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3665,"height":2062,"file_path":"/jaX8FSZU28POnQ1dcgPOoScgGaI.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3676,"height":2068,"file_path":"/wjbZNZKnuB2ScDAlFyHoggvSmf0.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3663,"height":2060,"file_path":"/7PDMuvKxO0Hs5Eb7IR9mB6vSaE8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3656,"height":2057,"file_path":"/v1ZfrbBAOBynET9F96x7uDnTDff.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3659,"height":2058,"file_path":"/blDh1uFq7gHamoQhv6M0fnr3Gut.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3657,"height":2057,"file_path":"/pYVP10hWerUsA8aTitYD1RpGoWN.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/cTw9hiSCqQQWAh9CWCSL515f0dB.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/hcWs3iI0p9CQ4uACfcBYhxzYjD8.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/khj1jghNG0xeXcgZ8f6xw5PcDJH.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/jnDQt8fwA9gqiEMlcjQEDRPZreR.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-27T07:02:09.54+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Sirāt","runtime":120,"tagline":"","homepage":"","overview":"Un père et son fils parviennent à une rave perdue au cœur des montagnes du sud du Maroc. Ils cherchent Mar — fille et sœur — disparue depuis plusieurs mois lors de l’une de ces fêtes sans fin. Plongés dans la musique électronique et une liberté brute qui leur est étrangère, ils distribuent inlassablement sa photo. L’espoir s’amenuise, mais ils s’obstinent et suivent un groupe de ravers vers une dernière fête dans le désert. À mesure qu’ils s’enfoncent dans l’immensité brûlante, le voyage les confronte à leurs propres limites."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"https://sirat.lefilm.co/","overview":"A man and his son arrive at a rave lost in the mountains of Morocco. They are looking for Marina, their daughter and sister, who disappeared months ago at another rave. Driven by fate, they decide to follow a group of ravers in search of one last party, in hopes Marina will be there."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Sirat: Trance en el desierto","runtime":130,"tagline":"DANCE. SCREAM. EXPLODE.","homepage":"","overview":"Un hombre y su hijo que llegan a una rave perdidos en medio de lo que se describen como las áridas y fantasmagóricas montañas del sur de Marruecos."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"시라트","runtime":115,"tagline":"천국과 지옥을 잇는 다리, 건너려는 자 명심하라. 그 길은 머리카락보다 가늘고 칼날보다 날카롭다.","homepage":"","overview":"광활한 사막 한가운데에서 펼쳐지는 레이브 파티. 그곳에서 루이스는 아들 에스테반과 함께 실종된 딸을 찾아 헤맨다. 하지만 곧 그 길은 신의 심판대로 이어지는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"W Maroku, w masywie pustyni Saghro, Louis, któremu towarzyszy syn Stéphane, poszukuje swojej najstarszej córki Mariny, która zaginęła. Zbierają się tam różnorodne grupy imprezowiczów szukających kolejnej imprezy na krańcu afrykańskiego kontynentu. Wyruszają więc w ognistą odyseję w głąb pustyni Sahary, lustra piasku, które stawia bohaterów w obliczu ich własnych ograniczeń."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"接近终点","runtime":0,"tagline":"","homepage":"","overview":"父亲Sergi López带着儿子深入摩洛哥南部山区，闯入一场锐舞派对寻找数月前在此类永不停歇的迷幻狂欢中失踪的女儿兼妹妹Mar。置身于电子音乐轰鸣与陌生而原始的自由氛围中，他们不断向人递出Mar的照片。希望日渐渺茫，却仍追随一群锐舞者奔赴沙漠中的终极派对。当父子俩深入灼热荒原，这场追寻之旅终将迫使他们直面自身的局限。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"https://www.pandorafilm.de/filme/sirat.html","overview":"Ein Vater und sein Sohn kommen zu einem Rave tief in den Bergen Südmarokkos. Sie sind auf der Suche nach Mar - Tochter und Schwester - die vor Monaten auf einer dieser endlosen, schlaflosen Partys verschwunden ist."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Sirat","runtime":115,"tagline":"Balla. Crida. Explota.","homepage":"","overview":"Un pare i un fill arriben a una festa rave enmig de les muntanyes del sud del Marroc i s'endinsen en una subcultura desconeguda per a ells. Enmig del caos, intenten localitzar la Mar: la filla (i germana) desapareguda mesos enrere."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Сират","runtime":115,"tagline":"","homepage":"","overview":"Луис вместе с сыном отправляется в Марокко на поиски дочери, пропавшей на вечеринке в пустыне. Переезжая с места на место, они узнают о последнем полумифическом рейве на границе с Мавританией. Выжженные земли и первобытный ландшафт пустыни станут отражением их страхов и надежд, и на фоне надвигающегося апокалипсиса им предстоит пройти по тонкой грани между раем и адом."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Sirat","runtime":0,"tagline":"","homepage":"","overview":"Otac i sin dolaze na rave party u izoliranom, opustjelom planinskom području južnog Maroka. Traže Mar, svoju kćer i sestru, nestalu prije nekoliko mjeseci na jednoj od sličnih maratonskih rave zabava. Bezuspješno pokazuju njezinu fotografiju posjetiteljima, okruženi elektronskom glazbom i posebnom vrstom slobode kakvu nikad ranije nisu susreli. Sve očajniji, odlučuju pratiti skupinu rejvera do posljednjeg partyja koji će se održati duboko u pustinji, nadajući se da će tamo pronaći Mar."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Сират","runtime":0,"tagline":"Це треба побачити, щоб повірити","homepage":"","overview":"Луїс із сином та їхнім вірним собакою мандрують марокканською пустелею в пошуках зниклої доньки. Приєднавшись до групи рейверів, що прямують на чергову вечірку в серці Сахари, вони поринають у пекельну подорож крізь нескінченні піски. Безжальна пустеля змусить їх переосмислити власне життя."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"穿越地獄之門","runtime":0,"tagline":"","homepage":"","overview":"一對父子來到摩洛哥的沙漠邊緣，尋找失蹤已久的親人。他們先在一場午夜銳舞派對中發送協尋傳單，接著經由一群派對青年引導，直搗更深處、更荒涼的沙漠地帶。他們在日暮、音樂與沙漠間搖擺，逐漸逼近那條在伊斯蘭傳說中象徵天堂與地獄之間、纖細如髮絲的 Sirāt 西拉特橋......"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Sirat: Trance en el desierto","runtime":114,"tagline":"","homepage":"","overview":"Un hombre y su hijo que llegan a una rave perdidos en medio de lo que se describen como las áridas y fantasmagóricas montañas del sur de Marruecos."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Oče skupaj s sinom prispe na rave party v gorah južnega Maroka. Iščeta hčerko Mar, ki je pred meseci izginila na eni od teh neskončnih zabav. Udeležencem neuspešno kažeta njeno sliko, obkrožena z elektronsko glasbo in posebnim občutkom svobode, kakršne do sedaj nista poznala. Vse bolj obupana se odločita, da bosta sledila skupini raverjev do zadnje zabave v puščavo upajoč, da bosta tam našla Mar."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Sırat","runtime":115,"tagline":"","homepage":"","overview":"Sırat, bir babanın oğluyla beraber Fas’ın güneyindeki dağların derinliklerinde sırra kadem basan kızı Mar’ın izini sürmesini anlatıyor.  Süper 16mm filmin grenli dokusuyla göz alan, izleyicisini adının çağrıştırdığı gibi soluksuz bir gerginlikle sınayan Sırat, Laxe'ın 2020'de gösterilen Fire Will Come / Yangın Yeri filminden bu yana yönettiği ilk film.  Yönetmen Oliver Laxe, filmini şöyle tanımlıyor: “Sırat, sizi ölmeden ölüme sürükleyen bir içsel yol. Tıpkı ana karakterin deneyimlediği gibi. Aynı zamanda cehennemle cennet arasındaki köprünün adı. Umarım Sırat, içimizde saklı bir kıvılcımı tutuşturur ve ruhumuza dönüp bakmamıza vesile olur.”  Sırat İspanya'nın Oscar adayı oldu."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":115,"tagline":"","homepage":"","overview":"Rankasti kuluneen oloisia kaiuttimia kootaan jättitorneiksi Marokon erämaassa. Tornit näyttävät mitättömiltä valtavassa kanjonissa. Kangding Rayn musiikki räjähtää ilmoille. Nämä kanjonit ymmärtävät subwoofereiden kieltä.  Äkkiä kanjoni on täynnä. Näissä reiveissä ei ole kysymys muotinäytöksestä, vaan elämäntavasta. Paikalle saapuu kadonnutta tytärtään etsivä isä pienen poikansa kanssa. He näyttävät kadonneen Marin kuvaa kaikille vastaantulijoille ja kuulevat uusista reiveistä yhä kauempana aavikolla. Alkaa tajunnanräjäyttävä matka yli kaikkien odotusten."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"ซีรอต ฝ่าถนนโลกันตร์","runtime":0,"tagline":"","homepage":"","overview":"เมื่อสองพ่อลูกออกเดินทางผ่านทะเลทรายตอนใต้ของโมร็อกโก เพื่อตามหาลูกสาวที่หายตัวไปนานห้าเดือนแล้วหลังจากมีคนพบเห็นเธอครั้งล่าสุดที่ปาร์ตี้เรฟกลางทะเลทราย พวกเขาจึงมุ่งหน้าไปยังปาร์ตี้ทะเลทรายอีกแห่งที่กำลังจะเกิดขึ้นใกล้ชายแดนมอริเตเนีย ระหกระเหินไปกับคนหนุ่มสาวนักปาร์ตี้แปลกหน้ากลุ่มหนึ่ง ท่ามกลางข่าวความขัดแย้งระดับโลกที่รุกคืบใกล้ตัวเข้ามาทุกขณะ และฝุ่นทรายที่ซัดเข้าใส่ทุกสิ่งมีชีวิตอย่างไม่ปรานี พวกเขาทั้งหมดนี้จำต้องมุ่งหน้าสู่ภูมิประเทศดิบเถื่อนร้อนระอุ เพื่อผจญภัยครั้งสุดท้ายบนหนทางอันเป็นเส้นแบ่งเบาบางระหว่างสวรรค์กับนรก"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":120,"tagline":"Sinta a explosão.","homepage":"https://retratofilmes.com/sirat-2/","overview":"Pai e filho chegam a uma rave nas montanhas do sul do Marrocos. Ambos estão em busca de Mar — filha e irmã —, que desapareceu meses antes em uma dessas festas intermináveis. Cercados por música eletrônica e por uma sensação crua e desconhecida de liberdade, eles distribuem a foto da jovem repetidas vezes. A esperança vai se apagando, mas os dois persistem e seguem um grupo de frequentadores rumo a uma última festa no deserto. Conforme avançam por esse cenário escaldante, a jornada os obriga a confrontar seus próprios limites."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"穿越地獄之門","runtime":0,"tagline":"","homepage":"","overview":"父親 Sergi López 帶著兒子深入摩洛哥南部山區，闖入一場鋭舞派對尋找數月前在此類永不停歇的迷幻狂歡中失蹤的女兒兼妹妹 Mar。置身於電子音樂轟鳴與陌生而原始的自由氛圍中，他們不斷向人遞出 Mar 的照片。希望日漸渺茫，卻仍追隨一群鋭舞者奔赴沙漠中的終極派對。當父子倆深入灼熱荒原，這場追尋之旅終將迫使他們面對自身的局限"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Сират","runtime":0,"tagline":"","homepage":"","overview":"Луис заедно със сина си Естебан се отправя към мароканската пустиня, за да търси изчезналата си дъщеря Марина. Двамата се присъединяват към поредното рейв парти в пустинята. По пътя си се сблъскват с физически и емоционални изпитания, които поставят под въпрос човешките им граници и морални убеждения."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Sirāts","runtime":115,"tagline":"","homepage":"","overview":"Reiva gara piesātināta vitāla kinematogrāfiska sāga. Luiss, meklējot pazudušo meitu, kopā ar dēlu Estebanu un viņu suni Pipu ierodas muzikālā festivālā. Dodoties dziļāk svelmainajā tuksnesī kopā ar kopienu, kas metusies bēgšanā no dzīves un aizmirstībā, viņš sastopas ar patiesiem pārbaudījumiem. Islāma tradīcijā sirât nozīmē taisno ceļu – tiltu pāri ellei, smalkāku par matu un asāku par zobenu –, kas cilvēcei jāšķērso pastardienā, lai sasniegtu paradīzi. Šeit tilts stiepjas starp Maroku un Mauritāniju, lejā liesmu vietā atrodas kvēlošā Sahāra."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Luis con il giovane figlio Esteban si aggira in un rave party mostrando una foto della figlia Mar della quale ha perso da alcuni mesi le tracce e che vorrebbe trovare. Nessuno la conosce ma, nel corso della ricerca, l'uomo fa delle conoscenze che, dopo la chiusura della festa da parte dei militari, lo indirizzano verso un altro rave. Il viaggio non sarà dei più facili e non solo per le asperità del terreno."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":120,"tagline":"","homepage":"","overview":"Een man en zijn zoon arriveren bij een rave diep in de bergen van Marokko. Ze zijn op zoek naar Marina, hun dochter en zus, die maanden eerder verdween tijdens een andere rave. Gedreven door hoop en toeval volgen ze een groep feestgangers op weg naar een laatste feest, in de hoop haar daar terug te vinden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Luis přijíždí na divokou party uprostřed marockých hor, aby se svým malým synem hledal zmizelou dceru Mar. V obklopení hypnotických beatů a zvláštní, syrové svobody vyráží se skupinou techno nomádů pátrat na poslední akci kdesi hluboko v poušti. Karavana předělaných náklaďáků naložených soundsystémy, naftou a drogami se prodírá rozpáleným pískem. Putování se rychle mění v šílenou halucinační jízdu, z níž není snadného úniku. Sirat je rave apokalypsa, která šokovala Cannes a kromě Ceny poroty si odnesla pověst nejoriginálnějšího filmu festivalu s kultovním potenciálem."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":0,"tagline":"Η ταινία σοκ των Καννών","homepage":"","overview":"Στην καρδιά των άγριων και απόκοσμων ορεινών τοπίων του νότιου Μαρόκου, ένας πατέρας και ο γιος του ξεκινούν μια απεγνωσμένη αναζήτηση. Πηγαίνουν σε ένα ρέιβ πάρτι, για να βρουν την κόρη και αδελφή αντίστοιχα, η οποία έχει χαθεί μυστηριωδώς πριν από μήνες, σε ένα παρόμοιο πάρτι. Ωθούμενοι από τη μοίρα, αποφασίζουν να ακολουθήσουν μια ομάδα ρέιβερς στην αναζήτηση ενός τελευταίου πάρτι που θα γίνει στην έρημο, με την ελπίδα να είναι εκεί."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"}],"reviews_tmdb":[{"id":"68f92b863bbc94300b483308","url":"https://www.themoviedb.org/review/68f92b863bbc94300b483308","author":"Brent Marchant","content":"$11","created_at":"2025-10-22T19:07:50.290Z","updated_at":"2025-10-22T19:07:50.366Z","author_details":{"name":"Brent Marchant","rating":8,"username":"Brent_Marchant","avatar_path":null}}],"recommendations":[{"id":1284493,"adult":false,"title":"Haunted Minds","video":false,"overview":"A homeless veteran with PTSD gets offered money by his ex-sergeant to be hunted for sport. If he survives a month, he keeps the cash; if he dies, it goes to his estranged family. The hunt starts in six months abroad.","genre_ids":[18],"media_type":"movie","popularity":2.3284,"vote_count":25,"poster_path":"/hwGa0XshQ16NcizOkSuRQDsl6Pl.jpg","release_date":"2025-09-17","vote_average":4.98,"backdrop_path":"/2XUSqh4WiRgvRH7mTzKb0hoGqEs.jpg","original_title":"Les Tourmentés","original_language":"fr"},{"id":38762,"adult":false,"title":"Meat Grinder","video":false,"overview":"A poverty stricken woman starts a restaurant where she slaughters people and serves up human flesh, cut from her victims.","genre_ids":[27,53],"media_type":"movie","popularity":0.3756,"vote_count":50,"poster_path":"/bpmVJeTEJdBkWoSvX7wvk8ch5MH.jpg","release_date":"2009-03-19","vote_average":5.4,"backdrop_path":"/4Wv88dIty6JVuoRgPqukbEa3ZJ0.jpg","original_title":"เชือดก่อนชิม","original_language":"th"},{"id":267804,"adult":false,"title":"In the Courtyard","video":false,"overview":"Antoine is a musician. The forties, he suddenly decides to end his career. After a few days of wandering, he gets a job as a janitor. Mathilde lives in the old building in the east of Paris where he takes office. This is a young retiree, generous and involved, who divides his time between his associational activities and the life of the condominium. One night, she discovers a disturbing crack on the wall of his living room. Gradually, his anxiety grew to turn into panic and if the building collapsed ... Slowly, Antoine befriends the woman he feared to see slip into madness. Between slips and concerns, both form an awkward tandem, humorous and solidarity which will, perhaps, through this bad patch.","genre_ids":[18,35],"media_type":"movie","popularity":0.2751,"vote_count":86,"poster_path":"/6mCfCONngJG0NPM6QpyBZxeCPuA.jpg","release_date":"2014-04-23","vote_average":5.8,"backdrop_path":"/7KwuFTnvGvWJuLi4BXs7Gf24T0B.jpg","original_title":"Dans la cour","original_language":"fr"},{"id":1224668,"adult":false,"title":"Fury","video":false,"overview":"Alex, a young actress, is sexually assaulted at a New Year’s Eve party at a friend’s house. That night, she never manages to see the face of her aggressor, a fact that will end up eating away at her. Throughout the following year, she will have to face feelings of guilt, disgust and shame.  While Alex tries to channel all her pain through theatre, where she takes on the role of the famously vengeful Medea, her brother, Adrian, must face the guilt he feels at not having been able to protect his sister and his impulse to let himself be carried away by his own decisions.  What were once the typical conflicts you might expect between any siblings, give way to much more extreme and complex emotions.","genre_ids":[18],"media_type":"movie","popularity":0.7668,"vote_count":19,"poster_path":"/ywzUHtubAGbJilTBoypwzOWlKvs.jpg","release_date":"2025-03-28","vote_average":6.5,"backdrop_path":"/1lIdYSTnOEGVYaMbaeRGrrcS3OW.jpg","original_title":"La furia","original_language":"es"},{"id":1316416,"adult":false,"title":"Siko Siko","video":false,"overview":"Two cousins, both from a middle-class background, finally see their dream come true when their inheritance is rightfully returned to them following their uncle’s death. Soon after, and to their shock, they discover that the inheritance is in the form of illegal goods. To liquidate these goods, they create an elaborate mobile game to sell them through it. They call this game… “Siko Siko”. The cousins enjoy a brief moment of spectacular success before a mob boss appears in their lives, claiming to be the real owner of the goods!","genre_ids":[35],"media_type":"movie","popularity":1.2628,"vote_count":13,"poster_path":"/rIld9XgXWS7YYZOdJf6O1KPLYYV.jpg","release_date":"2025-03-30","vote_average":7.846,"backdrop_path":"/5uEkwwarjGu7fU0vQ9t7EFYwhzO.jpg","original_title":"سيكو سيكو","original_language":"ar"},{"id":10841,"adult":false,"title":"Breakthrough","video":false,"overview":"Starting in late May 1944, during the German retreat on the Eastern Front, Captain Stransky (Helmut Griem) orders Sergeant Steiner (Richard Burton) to blow up a railway tunnel to prevent Russian forces from using it. Steiner's platoon fails in its mission by coming up against a Russian tank. Steiner then takes a furlough to Paris just as the Allies launch their invasion of Normandy.","genre_ids":[18,36,10752],"media_type":"movie","popularity":0.9427,"vote_count":32,"poster_path":"/n0XQXNSbDsHaJYHwuPPa8IfjmBY.jpg","release_date":"1979-03-01","vote_average":5.703,"backdrop_path":"/css92P5JvODJEWXp38Eo7qZdFd6.jpg","original_title":"Steiner - Das Eiserne Kreuz Teil II","original_language":"de"},{"id":34883,"adult":false,"title":"My Prison Yard","video":false,"overview":"In Madrid, a petty thief who cannot adjust to life outside of jail puts together a theater troupe her friends -- a prostitute, a gypsy, and a Colombian immigrant -- in an attempt to make a go at a relatively straight life.","genre_ids":[18],"media_type":"movie","popularity":0.3356,"vote_count":18,"poster_path":"/ddjBBhWzOucqGhwqcpuiAxJ44GA.jpg","release_date":"2008-12-26","vote_average":5.8,"backdrop_path":"/8X43I6n31NXo2tQbsr8ldt1kzeL.jpg","original_title":"El patio de mi cárcel","original_language":"es"},{"id":1410189,"adult":false,"title":"Kontinental '25","video":false,"overview":"Orsolya is a bailiff in Cluj, the main city in Transylvania. One day she has to evict a homeless man from a cellar, an action with tragic consequences that triggers a moral crisis which Orsolya must weather as best she can.","genre_ids":[35,18],"media_type":"movie","popularity":2.0694,"vote_count":24,"poster_path":"/zilOI