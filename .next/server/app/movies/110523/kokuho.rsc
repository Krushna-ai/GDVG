dth":2000,"height":2823,"file_path":"/uoarHfEI4ZdYGjkSoghwjk3LMNK.jpg","iso_639_1":"en","vote_average":4.458},{"width":2000,"height":2829,"file_path":"/wl16Z3Krq53O5gxgvnDTqAUmxm0.jpg","iso_639_1":"en","vote_average":4.3},{"width":1555,"height":2333,"file_path":"/kOPgWwyiJGFG7VxfEMd2mFNCa7.jpg","iso_639_1":"en","vote_average":4.3},{"width":2000,"height":3000,"file_path":"/bPuH9nB995PE3P9j4sTanWsxfUW.jpg","iso_639_1":"ja","vote_average":3.334},{"width":990,"height":1418,"file_path":"/gwQcvBdoMWolyBcKn6VbdqJdUZx.jpg","iso_639_1":"ko","vote_average":3.334},{"width":1629,"height":2444,"file_path":"/dMnJMX4hMPLalOVcJCtOu4q0PAa.jpg","iso_639_1":"ja","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/mHzok6x9rd8dGdUxuhRXX9R7Qqy.jpg","iso_639_1":null,"vote_average":3.334},{"width":2000,"height":3000,"file_path":"/kEi0gMHpQ4v0x5vcl2Vti0fIGsB.jpg","iso_639_1":null,"vote_average":3.334},{"width":2000,"height":3000,"file_path":"/1zY9ePzjRQBzIV10IXnEpSd86wO.jpg","iso_639_1":null,"vote_average":3.334},{"width":836,"height":1254,"file_path":"/sjCOxESUeeoV2ngYaVGW9K4C2VW.jpg","iso_639_1":"en","vote_average":2.066},{"width":1366,"height":2048,"file_path":"/9u6zeKUDX07Fz5KjdeqCrclqStZ.jpg","iso_639_1":"ja","vote_average":1.75},{"width":1080,"height":1528,"file_path":"/dagujCbAfsfJwIMw6E57lJXJ1PF.jpg","iso_639_1":null,"vote_average":1.75}],"backdrops":[{"width":3000,"height":1688,"file_path":"/3C8yAIuXlH4BGCpTwEetIv0VBt8.jpg","iso_639_1":null,"vote_average":1.75},{"width":3200,"height":1800,"file_path":"/wZXZkD8BoKP2PZ5Uv6Z56f20l8p.jpg","iso_639_1":null,"vote_average":1.75},{"width":3200,"height":1800,"file_path":"/5nNCg8jTS0KpTavJIMRBLY27qXw.jpg","iso_639_1":null,"vote_average":1.75},{"width":2048,"height":1152,"file_path":"/5LxKYHQk9ZYouloaLHHFyK7jgv6.jpg","iso_639_1":null,"vote_average":1.75},{"width":3200,"height":1800,"file_path":"/hTkGyKOxR1ZP9EOxnfAfHuMnF6e.jpg","iso_639_1":null,"vote_average":1.75},{"width":2160,"height":1212,"file_path":"/8GdK1oGItvElGArQPeKRWkhYDzx.jpg","iso_639_1":null,"vote_average":1.75},{"width":3000,"height":1688,"file_path":"/n4oUkqAFJobDtGPKu9aLJPhvhse.jpg","iso_639_1":null,"vote_average":0},{"width":2048,"height":1149,"file_path":"/3U27dSDQdZ3TokmSfd8e9nfTt8o.jpg","iso_639_1":null,"vote_average":0},{"width":2000,"height":1123,"file_path":"/u4WzgrdRTwEzwDq3QTnMjCNjmcc.jpg","iso_639_1":null,"vote_average":0},{"width":2000,"height":1123,"file_path":"/2JGI8fWxddrkN6otY82HkbPPJr3.jpg","iso_639_1":null,"vote_average":0},{"width":3000,"height":1685,"file_path":"/aYFrK0FNqFVGXcWUMAA0v1vCmo.jpg","iso_639_1":null,"vote_average":0},{"width":2000,"height":1123,"file_path":"/ucp9G7j7hyN6dkUXX8nW44uWSUi.jpg","iso_639_1":null,"vote_average":0},{"width":1914,"height":1077,"file_path":"/x5aasckcnjxYPHx4frWWBbiFtzC.jpg","iso_639_1":null,"vote_average":0},{"width":2047,"height":1151,"file_path":"/fpuu9Zo30R7S5PY5B4fJsYLhTsF.jpg","iso_639_1":null,"vote_average":0},{"width":2047,"height":1151,"file_path":"/e5h8L7pWYmN0VKdbNmHPoWuF6hb.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-02-25T14:11:39.352+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Kokuho","runtime":174,"tagline":"","homepage":"https://www.palacecinemas.com.au/movies/kokuho","overview":"Nagasaki, 1964: Following the death of his yakuza father, 15-year-old Kikuo is taken under the wing of a famous kabuki actor. Alongside Shunsuke, the actor’s only son, he decides to dedicate himself to this traditional form of theatre. For decades, the two young men grow and evolve together – and one will become the greatest Japanese master of the art of kabuki."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"국보","runtime":175,"tagline":"최고를 향한 열망, 서로를 탐한 갈망","homepage":"","overview":"눈앞에서 아버지를 잃고 가부키 명문가 하나이 한지로에게 맡겨진 소년 키쿠오. 운명이 결정짓는 세계에 이방인으로 뛰어든 키쿠오는 명문가의 아들 슌스케와 부딪히며 라이벌로 성장하게 된다. 서로의 길을 시험하는 치열한 경쟁에 놓인 두 사람. 세상에 단 하나뿐인 이름 국보를 향해 달리기 시작하는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"国宝","runtime":0,"tagline":"","homepage":"","overview":"　本片改编自吉田为了采访3年，穿着歌舞伎的黑衣进入后台的经验而写出的长篇小说，出生于任侠一门、投身于歌舞伎世界、将青春献给演艺之路的喜久雄，赌上自己的生命去追求无尽的梦想的宏伟故事：舞台是从战后到高度经济成长期的日本。出生于任侠家族的喜久雄，遭遇了数奇的命运，被拽到歌舞伎演员的家中。不久后，在动荡的人生中，他作为歌舞伎演员的才能开花结果。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Le Maître du Kabuki","runtime":174,"tagline":"","homepage":"","overview":"Nagasaki, 1964 - A la mort de son père, chef d’un gang de yakuzas, Kikuo, 14 ans, est confié à un célèbre acteur de kabuki. Aux côtés de Shunsuke, le fils unique de ce dernier, il décide de se consacrer à ce théâtre traditionnel. Durant des décennies, les deux jeunes hommes évoluent côte à côte, de l’école du jeu aux plus belles salles de spectacle, entre scandales et gloire, fraternité et trahisons... L'un des deux deviendra le plus grand maître japonais de l'art du kabuki."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":174,"tagline":"","homepage":"https://kokuhou-movie.com/","overview":"後に国の宝となる男は、任侠の一門に生まれた。抗争で父を亡くした喜久雄（吉沢亮）は、上方歌舞伎の名門の当主・花井半二郎（渡辺謙）に引き取られ、歌舞伎の世界へ飛び込む。そこで、半二郎の実の息子として、生まれながらに将来を約束された御曹司・俊介（横浜流星）と出会う。正反対の血筋を受け継ぎ、生い立ちも才能も異なる2人は、ライバルとして互いに高め合い、芸に青春を捧げるが、多くの出会いと別れが運命の歯車を狂わせていく……。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"國寶","runtime":0,"tagline":"","homepage":"","overview":"橫跨半世紀、描繪日本歌舞伎文化的壯闊史詩。立花喜久雄（吉澤亮 飾）生於黑道之家，在衝突中喪父後，因獨有天分而獲歌舞伎名門花井半二郎（渡邊謙 飾）破格收入門下。喜久雄與花井家繼承人俊介（橫濱流星 飾）亦敵亦友，互相砥礪，將青春奉獻給舞台，命運和抉擇卻使兩人的人生軌跡起了重大變化。\r 血統與才能、榮耀與孤寂、信任與背叛，交織出一襲以藝術為名的華美之袍，上面卻爬滿蝨子。在劇變時代中、無形枷鎖下，要花多少代價，方可成就舉世無雙的「國寶」？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Національне надбання","runtime":0,"tagline":"","homepage":"","overview":"У повоєнній Японії, на тлі економічного буму, Кікуо Тачібана, що народився в родині якудза, потрапляє під опіку актора кабукі. Попри життєві труднощі, він розвивається у талановитого виконавця."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"สมบัติชาติ","runtime":0,"tagline":"","homepage":"","overview":"เมืองนางาซากิ ปี 1964 หลังจากการตายของยากูซ่าผู้เป็นพ่อ คิคุโอะ ในวัย 15 ปี ถูกรับเข้าไปอยู่ภายใต้การดูแลของนักแสดงคาบูกิชื่อดัง เขาได้ตัดสินใจที่จะทุ่มเทตัวเองในกับการแสดงแบบดั้งเดิมนี้ ร่วมกับ ชุนซูเกะ ลูกชายเพียงคนเดียวของนักแสดงคาบูกิ และหลังจากผ่านไปหลายทศวรรษ เด็กหนุ่มสองคนก็ได้เติบโตและพัฒนาไปด้วยกัน และเพียงคนเดียวเท่านั้นที่จะกลายมาเป็นปรมาจารย์ของศาสตร์แห่งคาบูกิที่ยิ่งใหญ่ท่ีสุดในญี่ปุ่น"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"國寶","runtime":0,"tagline":"","homepage":"","overview":"講述出身黑道家庭、擁有盛世美顏的喜久雄（吉澤亮 飾），在失去父親後，被歌舞伎名門花井半二郎（渡邊謙 飾）收留，意外踏入歌舞伎的世界。天賦異稟的喜久雄與花井家繼承人俊介（橫濱流星 飾）成為好友，成長經歷與才能都不同的兩人互相競爭成長，將青春奉獻給舞台。為了爬上歌舞伎的頂端，命運的抉擇與人生轉折讓他們兩人的未來走向截然不同的道路..."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Yakuza çete başı babası ölünce, 14 yaşındaki Kikuo ünlü bir Kabuki oyuncusunun yanına evlatlık verilir. Kikuo, adamın oğlu Shunsuke ile birlikte bu geleneksel Japon tiyatro sanatını öğrenmeye başlar. İki genç onlarca yıl boyunca büyür ve gelişir; skandallar ve zaferler, dostlukla ihanet arasında rakip ve kardeş olarak birlikte yol alırlar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"קוקוהו: מאסטר הקבוקי","runtime":174,"tagline":"","homepage":"","overview":"על רקע עולמו המסורתי של תיאטרון הקאבוקי. לאחר מות אביו, נער בשם קיקואו נלקח תחת חסותו של שחקן הקאבוקי הדגול האנאי הנג’ירו, ולומד לצדו של בנו הביולוגי של המאסטר. בין שני הנערים נרקמת מערכת יחסים מורכבת של ידידות ויריבות הנמשכת לאורך כמה עשורים.  הסרט עוקב אחר התפתחותם של שני אמנים המקדישים את חייהם למסורת עתיקה, עד שהאמביציה והשאיפה לשלמות גובות מהם מחיר אנושי כבד."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Kokuho - The Master of Kabuk","runtime":174,"tagline":"","homepage":"","overview":"Nach dem Tod seines Vaters wird der 14-jährige Kikuo unter die Fittiche des berühmten Kabuki-Schauspielers Hanjiro genommen. Zusammen mit Shunsuke, Hanjiros einzigem Sohn, beschliesst er, sich dieser traditionellen Form des Theaters zu widmen. Über Jahrzehnte hinweg entwickeln sich die beiden jungen Männer gemeinsam weiter – von der Schauspielschule bis zu den grossen Bühnen – zwischen Skandalen und Ruhm, Bruderschaft und Verrat. Regisseur Lee Sang-il hat mit seinem Spielfilm ein beeindruckendes, immersives Werk geschaffen, das uns in die Welt des Kabuki-Theaters entführt. Ein episches Kino- und Theaterspektakel!"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Kokuho: O Preço da Perfeição","runtime":174,"tagline":"","homepage":"https://imovision.com.br/kokuho","overview":"Nagasaki, 1964. Após a morte de seu pai, líder de uma gangue da yakuza, o jovem Kikuo, de 14 anos, é acolhido por um famoso ator de Kabuki. Ao lado de Shunsuke, o único filho do ator, ele decide se dedicar a essa tradicional forma de teatro. Ao longo das décadas, os dois jovens crescem e evoluem juntos, da escola de atuação aos palcos mais grandiosos. Em meio a escândalos e glórias, irmandade e traições, um deles se tornará o maior mestre japonês da arte do Kabuki."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Kokuho","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Национальное достояние","runtime":0,"tagline":"","homepage":"","overview":"Послевоенная Япония. После смерти отца-якудза парень становится актёром театра кабуки."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Kokuho - O Preço da Perfeição","runtime":174,"tagline":"","homepage":"","overview":"Em Kokuho - O Preço da Perfeição, o ano é 1964 em Nagasaki. Kikuo Tachibana é filho do líder de uma gangue da organização criminosa Yakuza. Após a morte de seu pai, assassinado por um grupo rival, o jovem de então 14 anos é adotado por um famoso ator de Kabuki – um tipo tradicional de teatro japonês – chamado Hanai Hanjiro. Ao lado de Shunsuke, o único e biológico filho do astro, Kikuo decide se dedicar à arte por trás desse espetáculo teatral. Envoltos nesse universo, os dois jovens crescem e se desenvolvem juntos, estabelecendo uma conexão emocional e artística. Kikuo e Shunsuke mergulham nesse mundo desde a escola de atuação até os grandes palcos enquanto lidam com sua irmandade, escândalos, sucessos e traições. Em meio a uma arte que valoriza a linhagem e a sucessão, preservando-se através das gerações, Kikuo com seu talento natural parece atingir a grandeza."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"}],"reviews_tmdb":[{"id":"699582f01fa6a7e7ca959e3b","url":"https://www.themoviedb.org/review/699582f01fa6a7e7ca959e3b","author":"Call Me Dunham","content":"First of all, I want to thank Feat Pictures for bringing this magical, lavish, and grand Japanese film to Indonesia. I genuinely couldn’t take my eyes off the screen while watching it. One of my favorite aspects is how carefully the film handles its use of music knowing exactly when to bring in the score and when to let silence take over. Moments of quiet often make the atmosphere hit even harder, and it’s rare to see that level of restraint and precision.\r\n\r\nIt honestly feels like a shame that the film only received an Oscar nomination for makeup. So many of its technical elements deserved recognition, especially the original score and the stunning cinematography. The close-up shots are particularly beautiful. In my opinion, the film was seriously snubbed in the Best International Feature Film category. On top of that, the drama between the two main characters is incredibly compelling, with a relationship dynamic that feels rich and well-developed.","created_at":"2026-02-18T09:14:24.360Z","updated_at":"2026-02-18T09:14:24.369Z","author_details":{"name":"Call Me Dunham","rating":9,"username":"Hamzah1905","avatar_path":null}}],"recommendations":[{"id":1406357,"adult":false,"title":"Frontline - Yokohama Bay","video":false,"overview":"In February 2020, a luxury cruise ship carrying a cluster infection of the novel coronavirus docks in Yokohama. Disaster Medical Assistance Teams work tirelessly to save lives while battling anxiety and fear surrounding the unknown virus.","genre_ids":[18],"media_type":"movie","popularity":0.6794,"vote_count":5,"poster_path":"/b7uQiic2gQQt5yJOqNgmYAFztlV.jpg","release_date":"2025-06-13","vote_average":6.6,"backdrop_path":"/rTHQPVtqU1LwKS6aok3z42qxu80.jpg","original_title":"フロントライン","original_language":"ja"},{"id":983683,"adult":false,"title":"Bill Burr Presents: Friends Who Kill","video":false,"overview":"In a night of killer comedy, Bill Burr hosts a showcase of his most raucous stand-up comic pals as they riff on everything from COVID to Michael Jackson.","genre_ids":[35],"media_type":"movie","popularity":0.4004,"vote_count":79,"poster_path":"/9gSpgNwjP3Qg8LAsrBgo1Fu6QdL.jpg","release_date":"2022-06-06","vote_average":5.411,"backdrop_path":"/2GFxMsZTiSU7i3GtwRnonx14nrb.jpg","original_title":"Bill Burr Presents: Friends Who Kill","original_language":"en"},{"id":161908,"adult":false,"title":"Head Over Heels 2","video":false,"overview":"Alice owns a network of sex shops and workaholic who, in trying to reconcile the harsh routine of work and family life, suffers nervous breakdown, she is forced by her husband to go to spa. Precisely at this time, appears unique opportunity to expand its business in New York. Using fun gimmicks, risks his health, leaves spa party there with family to ride, but actually in order to facilitate their professional interests. In trying to reconcile the agendas, engage in hilarious situations and mistakes that culminate in the possible separation of the couple.","genre_ids":[35,10749],"media_type":"movie","popularity":0.2441,"vote_count":180,"poster_path":"/9Qd8MSJLAtDHMiPrZ3kgHW63DIc.jpg","release_date":"2012-12-28","vote_average":6.342,"backdrop_path":"/kjTuxh0azwQEAsCmjFLsdRSs7wZ.jpg","original_title":"De Pernas pro Ar 2","original_language":"pt"},{"id":601893,"adult":false,"title":"Sonic the Hedgehog: Freedom Fighters Unite","video":true,"overview":"Sonic Conversion: the Freedom Fighters develop a De-Robotisizer and try it out on Bunnie.  Dulcy: After Dulcy exhibits strange behavior, Sally discovers she's going through a rites of passage state of her adolescence.  The Void: After Sonic is almost sucked inside the Void, he finds a huge ring which Sally believes is an ancient relic but which turns out to be a trick of Nagus.  Spyhog: After Antoine saves Sally's life during a raid, Sonic can't stand his bragging and zips in to see Uncle Chuck, who finds out his bug in Robotnik's hardware is malfunctioning.","genre_ids":[10751,35,12,16],"media_type":"movie","popularity":0.0557,"vote_count":7,"poster_path":"/irMZfL39xHwmQsPZOF8UEm33hkh.jpg","release_date":"2009-05-05","vote_average":6.2,"backdrop_path":null,"original_title":"Sonic the Hedgehog: Freedom Fighters Unite","original_language":"en"},{"id":11300,"adult":false,"title":"Something Wild","video":false,"overview":"A free-spirited woman \"kidnaps\" a yuppie for a weekend of adventure. But the fun quickly takes a dangerous turn when her ex-con husband shows up.","genre_ids":[80,35,10749],"media_type":"movie","popularity":3.0026,"vote_count":376,"poster_path":"/344lhBozqFWKxBb4fp6azYQMLEy.jpg","release_date":"1986-11-07","vote_average":6.628,"backdrop_path":"/b3J5vJWbyfbjPtgWKfCJYQ8kves.jpg","original_title":"Something Wild","original_language":"en"},{"id":62105,"adult":false,"title":"Re-Cut","video":false,"overview":"When twin girls are found dead in their family’s barn, reality star turned TV-reporter Meredith Phillips and her de-facto camera crew are dispatched to rural Wisconsin to investigate the gruesome deaths. In their relentless drive to break the story, the reporters become entangled in a deadly mystery and uncover the small town’s shocking secret. Edited together from the crew’s multiple cameras, the film documents their struggle to survive the most terrifying night of their lives and becomes the only evidence of a crime too horrific to imagine.","genre_ids":[27,53],"media_type":"movie","popularity":0.5333,"vote_count":113,"poster_path":"/b76EyFy1akO0nEHleChVpUetTW7.jpg","release_date":"2010-01-04","vote_average":6.6,"backdrop_path":null,"original_title":"Re-Cut","original_language":"en"},{"id":29514,"adult":false,"title":"Two Evil Eyes","video":false,"overview":"A duo of Edgar Allan Poe adaptations about a greedy wife's attempt to embezzle her dying husband's fortune, and a sleazy reporter's adoption of a strange black cat.","genre_ids":[27],"media_type":"movie","popularity":1.9019,"vote_count":322,"poster_path":"/zVWaQfaSZ7AWE0XqbMT57szVmXo.jpg","release_date":"1990-01-25","vote_average":6.13,"backdrop_path":"/wWucXwUmJiA5iUNqegJHbcy2Mzy.jpg","original_title":"Due occhi diabolici","original_language":"en"},{"id":194834,"adult":false,"title":"Re-Generator","video":false,"overview":"A plane containing a highly classified government project crashes outside of a small town in the US. Realizing the level of danger, the government tries to secretly fix the problem. As tensions grow, the situation gets out of control, and civilians from the town find themselves facing their worst nightmare: a genetically enhanced killing machine that doesn't know how to stop.","genre_ids":[28,878],"media_type":"movie","popularity":0.336,"vote_count":44,"poster_path":"/91DuiopktCSjCi4ozPePJWTaIL5.jpg","release_date":"2010-01-23","vote_average":6.216,"backdrop_path":"/wSLKn9Mml6W9h7pvCfxRjQdoAO9.jpg","original_title":"Re-Generator","original_language":"en"},{"id":1402613,"adult":false,"title":"Mahou Shoujo Sonico Magica","video":true,"overview":"This is an April Fool's joke by Nitroplus. On 01.04.2011, an official website for Mahou Shoujo Sonico Magika, a parody of SoniComi (a game by Nitroplus), was opened with the announcement of it being a TV anime. On the same day, the opening video for the so called TV anime was released on YouTube by NitroPlusChannel. This opening is essentially the entire anime. The title is a clear reference to Mahou Shoujo Madoka Magika, a TV anime which screenplay was written by a Nitroplus staffer Urobuchi Gen, who also got credited for screenplay for this anime on the official page. No screenplay was ever written, of course.","genre_ids":[16],"media_type":"movie","popularity":0.0382,"vote_count":5,"poster_path":"/aJ5s5JWEsG4F3pnBsKbjvKGhFhZ.jpg","release_date":"2011-04-01","vote_average":6,"backdrop_path":null,"original_title":"魔法少女そにこ☆マギカ PUELLA MAGI SONICO MAGICA","original_language":"ja"},{"id":29454,"adult":false,"title":"Face to Face","video":false,"overview":"A psychiatrist temporarily separated from her family begins to experience severe psychological distress while working at a mental hospital and returning to her childhood home. As her professional responsibilities and personal relationships intersect, she undergoes a breakdown that forces her to confront long-suppressed memories and fears.  (Note: This entry refers to the 1976 theatrical feature film (approximately 135 minutes), created by condensing and re-editing the four-part Swedish television miniseries originally produced the same year.)","genre_ids":[18],"media_type":"movie","popularity":0.8631,"vote_count":134,"poster_path":"/ulh7ILYfvSZExCXENEhySvuZLLl.jpg","release_date":"1976-04-05","vote_average":7.194,"backdrop_path":"/1Z08RUb16Yz091IpzIUTM2s0P7U.jpg","original_title":"Ansikte mot ansikte","original_language":"sv"},{"id":47850,"adult":false,"title":"Orchestra Rehearsal","video":false,"overview":"An orchestra assembles for a rehearsal in an ancient chapel under the inquisitive eyes of a TV documentary crew, but an uprising breaks out.","genre_ids":[35,18,10402],"media_type":"movie","popularity":1.3943,"vote_count":120,"poster_path":"/rtspkCHNKoDJxJnozzfoPY1qAct.jpg","release_date":"1979-02-22","vote_average":6.617,"backdrop_path":"/o5GFE1PdgnFhak7jGDjkUgppIEA.jpg","original_title":"Prova d'orchestra","original_language":"it"},{"id":18733,"adult":false,"title":"Happy Flight","video":false,"overview":"A variety of aviation professionals such as pilots, flight attendants, the ground crew, mechanics, dispatchers, controllers, and the bird patrol crew all support a single flight. They have only one mission: to secure the safety of the passengers.","genre_ids":[35,18],"media_type":"movie","popularity":0.9996,"vote_count":33,"poster_path":"/3bBJDGNDkvjAQoxexHlsAEFMY5i.jpg","release_date":"2008-11-15","vote_average":6.3,"backdrop_path":"/oXOcbJXXdYgaOvQFwY5qLLAXnhy.jpg","original_title":"ハッピーフライト","original_language":"ja"},{"id":225313,"adult":false,"title":"Hanni & Nanni 3","video":false,"overview":"The Lindenhof School is expecting a busload of proper young English ladies as exchange students. The shock is great when the students turn out to be teenage boys! But while Mademoiselle Bertoux is delighted to stage “Romeo and Juliet” with real boys, both Hanni and her sister Nanni fall for their “Romeo,” Clyde.","genre_ids":[10751,35],"media_type":"movie","popularity":0.3808,"vote_count":40,"poster_path":"/bn8W0RtKWOnvUCivQUX2tBVv7G3.jpg","release_date":"2013-05-08","vote_average":6.038,"backdrop_path":"/yYFQ22mTuPY6KLGnvH7AOnjvloT.jpg","original_title":"Hanni & Nanni 3","original_language":"de"},{"id":984945,"adult":false,"title":"(re)kindle","video":false,"overview":"Ana and Helen, two divorced women, were close friends as teenagers. Today, amidst the corona virus pandemic and in quarantine, they get in touch after 20 years via internet. Through video conference calls, memories, sensations and emotions reflourishes.","genre_ids":[18,10749],"media_type":"movie","popularity":0.4557,"vote_count":61,"poster_path":"/s72KUZGSTvRlRSyIhRKnevvO0G2.jpg","release_date":"2021-02-21","vote_average":7.4,"backdrop_path":"/qlRfgVw8b9cOuAHcA83tGCgKnzy.jpg","original_title":"(re)começo","original_language":"pt"},{"id":375486,"adult":false,"title":"Beck 31 - Gunvald","video":false,"overview":"An investigative journalist is found beaten to death in his home, where the fingerprints of a notorious criminal debt collector are also found. The murdered journalist has been threatened by right wing extremists, but it is the victim’s work with a book about “society’s dark side” that captures the Beck group’s interest.  When the case takes an unexpected and terrible turn, there is suddenly much more at stake than finding the journalist’s killer. Martin Beck and his colleagues have never had to protect the balance of their professional and private lives with the same tenacity as they do now.","genre_ids":[80,53,9648,18],"media_type":"movie","popularity":0.213,"vote_count":24,"poster_path":"/gWKcR2bZ6frUJsAVKq6P6XcvKg5.jpg","release_date":"2016-01-01","vote_average":5.6,"backdrop_path":"/8BxM7Kv0xTXas0zCto8fRZTUblp.jpg","original_title":"Beck 31 - Gunvald","original_language":"sv"},{"id":1290190,"adult":false,"title":"Lokah Chapter 1: Chandra","video":false,"overview":"The story follows Chandra , a mysterious, goth-influenced woman who has just moved to Bangalore and begins working night shifts at a café. Across the road from her apartment live Sunny and Venu, two aimless bachelors. Sunny becomes infatuated with Chandra, observing her odd routines, strange visitors, and reclusive nature. Their dynamic changes when Sunny gets a glimpse of Chandra in her act.","genre_ids":[28,12,14],"media_type":"movie","popularity":1.6909,"vote_count":41,"poster_path":"/nRn6is4m5sikO1rSoCoRT2rYtXB.jpg","release_date":"2025-08-28","vote_average":7.4,"backdrop_path":"/tkRZ8BpIlvQIFBQWwEHuAlxczyb.jpg","original_title":"ലോകഃ Chapter 1: ചന്ദ്ര","original_language":"ml"},{"id":49687,"adult":false,"title":"Marriage Italian Style","video":false,"overview":"During the bombing of Naples in World War II, a cynical businessman helps a naive prostitute, who spends the next two decades desperate to have him reciprocate her feelings.","genre_ids":[18,10749,35],"media_type":"movie","popularity":0.9641,"vote_count":538,"poster_path":"/1VVQFXwr4i6QSAoPnCs9UmGTUVw.jpg","release_date":"1964-12-18","vote_average":7.709,"backdrop_path":"/gyoYWae5mqg6MjbwKu1AE9bgGMt.jpg","original_title":"Matrimonio all'italiana","original_language":"it"}],"similar_content":[{"id":159,"adult":false,"title":"Maybe... Maybe Not","video":false,"overview":"The heterosexual man Axel is thrown out of his girlfriends home for cheating and ends up moving in with a gay man. Axel learns the advantages of living with gay men even though they are attracted to him and when his girlfriend wants him back he must make a tough decision.","genre_ids":[35,18],"popularity":0.5168,"vote_count":117,"poster_path":"/2TcZBHcseRXLxNq2RXnKIsbKZwi.jpg","release_date":"1994-10-05","vote_average":6.218,"backdrop_path":"/cLOyix71NJwkfwt77bnmmy9ibJO.jpg","original_title":"Der bewegte Mann","original_language":"de"},{"id":418927,"adult":false,"title":"Discreet","video":false,"overview":"After years in hiding and struggling to control his demons, an eccentric drifter returns home and discovers that his childhood abuser, the center of his pain, is still alive.","genre_ids":[9648,53,18],"popularity":0.1164,"vote_count":12,"poster_path":"/u64zo6uaxexc0gaQcS3nwDQar7L.jpg","release_date":"2017-02-11","vote_average":4.2,"backdrop_path":"/5ueOmNSvWjDx3IwjReSshuLOLUH.jpg","original_title":"Discreet","original_language":"en"},{"id":246933,"adult":false,"title":"Ladyboy","video":false,"overview":"Kristian, who is a transvestite, still lives at home with his mother Emma, because she loves him just the way he is. Life as a transvestite offers many humiliations from the outside world, but with his mom, Kristian feels that he can be himself. Until one day when Emma meets the alcoholic Søren, who does not have the same tolerance...","genre_ids":[18],"popularity":2.1635,"vote_count":6,"poster_path":"/806r1ykWmV8cwy1nS4JF8ROYxsN.jpg","release_date":"2011-10-26","vote_average":4.5,"backdrop_path":"/le6KrBt01d8gL0ZKjs6ByZmHnHf.jpg","original_title":"Ladyboy","original_language":"da"},{"id":763605,"adult":false,"title":"Poppy Field","video":false,"overview":"A young Romanian gendarme, Cristi, tries to find the balance between two apparently opposing parts of his identity: that of a man working in a macho hierarchical environment and that of a closeted gay person who tries to keep his personal life a secret. Cristi is called in for an intervention at a movie theatre, where an ultra-nationalist, homophobic group has interrupted the screening of a queer film. After one of the protesters threatens to out him, Cristi spirals out of control.","genre_ids":[18,10749],"popularity":0.2443,"vote_count":15,"poster_path":"/3b9Q2OjWnfSpaXJMX8wmWyYc5il.jpg","release_date":"2022-04-08","vote_average":5.333,"backdrop_path":"/1sWLVybHa27QvfzChPuzNlWaesn.jpg","original_title":"Câmp de maci","original_language":"ro"},{"id":665,"adult":false,"title":"Ben-Hur","video":false,"overview":"In 26 AD, Judah Ben-Hur, a Jew in ancient Judea, opposes the occupying Roman empire.  Falsely accused by a Roman childhood friend-turned-overlord of trying to kill the Roman governor, he is put into slavery and his mother and sister are taken away as prisoners.","genre_ids":[36,18,12],"popularity":8.8819,"vote_count":3042,"poster_path":"/m4WQ1dBIrEIHZNCoAjdpxwSKWyH.jpg","release_date":"1959-11-18","vote_average":7.883,"backdrop_path":"/sU3gFo7Gn67zjtKXIvzJ4omcUbH.jpg","original_title":"Ben-Hur","original_language":"en"},{"id":950481,"adult":false,"title":"Divine Providence","video":false,"overview":"Divine Providence is a forthcoming narrative short film centered around and inspired by the city of Providence, Rhode Island. Set in the late 1970s, the film tells the story of a tumultuous confession that brings the lives of a lonely parish priest and a guilt-ridden mobster crashing together, forcing the two men to tear open old wounds and confront the demons of their respective pasts.","genre_ids":[18,80],"popularity":0.3509,"vote_count":0,"poster_path":"/iUOZEk5kXSTzT165Deb82e401Zw.jpg","release_date":"","vote_average":0,"backdrop_path":null,"original_title":"Divine Providence","original_language":"en"},{"id":1966,"adult":false,"title":"Alexander","video":false,"overview":"Alexander, the King of Macedonia, leads his legions against the giant Persian Empire. After defeating the Persians, he leads his army across the then known world, venturing farther than any westerner had ever gone, all the way to India.","genre_ids":[10752,36,28,12,18,10749],"popularity":4.7502,"vote_count":3451,"poster_path":"/jrwQu72sGwGqwE8Ijne89PSIvhp.jpg","release_date":"2004-11-21","vote_average":5.95,"backdrop_path":"/h21dxRjtR7xOhyZljtSYeTETCht.jpg","original_title":"Alexander","original_language":"en"},{"id":2054,"adult":false,"title":"Mr. Holland's Opus","video":false,"overview":"In 1965, passionate musician Glenn Holland takes a day job as a high school music teacher, convinced it's just a small obstacle on the road to his true calling: writing a historic opus. As the decades roll by with the composition unwritten but generations of students inspired through his teaching, Holland must redefine his life's purpose.","genre_ids":[18,10402],"popularity":1.1019,"vote_count":441,"poster_path":"/kBmwWeSN3ajnYHZ3dSybEobxEPI.jpg","release_date":"1995-12-29","vote_average":6.954,"backdrop_path":"/oUptKQLatCgywVDx0ETVhq7knHt.jpg","original_title":"Mr. Holland's Opus","original_language":"en"},{"id":251594,"adult":false,"title":"Undress Me","video":false,"overview":"Mikaela has undergone gender reassignment and is now a woman. One night at a bar, she meets a guy and takes him back to her place.","genre_ids":[18],"popularity":0.8685,"vote_count":24,"poster_path":"/9uonem5TUObM0i5rKeN8HNd3yh1.jpg","release_date":"2012-10-13","vote_average":5.7,"backdrop_path":"/AvVYEZQ0wmFSp8H1HaK5EqaswSI.jpg","original_title":"Ta av Mig","original_language":"en"},{"id":249916,"adult":false,"title":"Appropriate Behavior","video":false,"overview":"Shirin is struggling to become an ideal Persian daughter, politically correct bisexual and hip young Brooklynite but fails miserably in her attempt at all identities.","genre_ids":[35,18,10749],"popularity":0.5768,"vote_count":104,"poster_path":"/ywa3IaNZz6m7jMur18zn4de59CV.jpg","release_date":"2015-03-14","vote_average":6.2,"backdrop_path":"/omcxgWYYbNOxUPahj1IGNrY4Aeo.jpg","original_title":"Appropriate Behavior","original_language":"en"},{"id":1378,"adult":false,"title":"Shortbus","video":false,"overview":"In post-9/11 New York City, an eclectic group of citizens find their lives entangled, personally, romantically, and sexually, at Shortbus, an underground Brooklyn salon infamous for its blend of art, music, politics, and carnality.","genre_ids":[10749,18,35],"popularity":3.7742,"vote_count":560,"poster_path":"/s8QBrWgpZpYrySSyTQ0xbFLPKrS.jpg","release_date":"2006-10-04","vote_average":6.3,"backdrop_path":"/a9VOWosINcLNJQb3hNZAqEShVTM.jpg","original_title":"Shortbus","original_language":"en"},{"id":592035,"adult":false,"title":"Bathroom Stalls & Parking Lots","video":false,"overview":"Far from his home country of Brazil, a gay man goes on a San Francisco adventure with his friends in order to find the right hookup.","genre_ids":[18,35],"popularity":0.1741,"vote_count":6,"poster_path":"/nWD7O2e1uWxpdx5iTh0hq2TKP2u.jpg","release_date":"2019-03-30","vote_average":4,"backdrop_path":"/3EWUqP2Dqc8jDXtWzVBb94hzyfH.jpg","original_title":"Bathroom Stalls & Parking Lots","original_language":"en"},{"id":765264,"adult":false,"title":"And Returning","video":false,"overview":"Rina wants to tell her best friend, Eli, about her arranged marriage, by dating her on the last night they could be together.","genre_ids":[18,10749],"popularity":0.9135,"vote_count":1,"poster_path":"/c9MlUX7FJFv5C5XFBxJZ1pSNsIM.jpg","release_date":"2020-02-20","vote_average":1,"backdrop_path":"/8qtFqeXTwzhLPWglR9cioOYtPUH.jpg","original_title":"Dan Pulang","original_language":"id"},{"id":249638,"adult":false,"title":"Something Must Break","video":false,"overview":"A gritty story taking place in Stockholm, about the passionate love between the self-abusive Sebastian who wants to be a woman, and the easy-going Andreas who is certainly not gay.","genre_ids":[18,10749],"popularity":0.2678,"vote_count":34,"poster_path":"/6xQjWEhJ2f1Ba3HjaI3uzQM9iZn.jpg","release_date":"2014-03-28","vote_average":6.1,"backdrop_path":"/aUkG7cGpQUsjw7XD1dYmTLSwd3.jpg","original_title":"Nånting måste gå sönder","original_language":"sv"},{"id":979,"adult":false,"title":"Irreversible","video":false,"overview":"A woman’s lover and her ex-boyfriend take justice into their own hands after she becomes the victim of a rapist. Because some acts can’t be undone. Because man is an animal. Because the desire for vengeance is a natural impulse. Because most crimes remain unpunished.","genre_ids":[18,53,80],"popularity":8.8872,"vote_count":3199,"poster_path":"/rxeDxo8FvZpLu6iplNpxdtAVnfu.jpg","release_date":"2002-05-22","vote_average":7.175,"backdrop_path":"/xV1EfNSEg6id6juJPr1vM6p9x5X.jpg","original_title":"Irréversible","original_language":"fr"},{"id":421759,"adult":false,"title":"Broadcasting Christmas","video":false,"overview":"When the opportunity to co-host a talk show with the fabulous talk show diva Veronika presents itself two weeks before Christmas, Emily thinks this is her big break. To her surprise, she discovers she has stiff competition with Charlie, the local TV anchor who is her near equal on another station. With such interest and support for both reporters, a contest is created: for the two weeks leading up to Christmas, who can cover the best and most meaningful Christmas stories on the local news?","genre_ids":[10770,10749,18,35],"popularity":0.3091,"vote_count":76,"poster_path":"/c8VrxCL42EejLOWbzSfkLoLix5Q.jpg","release_date":"2016-11-23","vote_average":5.7,"backdrop_path":"/aAhOB50wfXdTQ00Uzm0dUVLDUGj.jpg","original_title":"Broadcasting Christmas","original_language":"en"},{"id":2119,"adult":false,"title":"Days of Thunder","video":false,"overview":"Talented but unproven stock car driver Cole Trickle gets a break and with the guidance of veteran Harry Hogge turns heads on the track. The young hotshot develops a rivalry with a fellow racer that threatens his career when the two smash their cars. But with the help of his doctor, Cole just might overcome his injuries-- and his fear.","genre_ids":[12,28,18],"popularity":5.3759,"vote_count":1641,"poster_path":"/8UvcoeMJag8UWGF8sg7eYspzq0Q.jpg","release_date":"1990-06-27","vote_average":6.35,"backdrop_path":"/t61Pj0FsdvM5JSEdzTcbpLM4ZaH.jpg","original_title":"Days of Thunder","original_language":"en"},{"id":249330,"adult":false,"title":"Words of Devotion","video":false,"overview":"Their love feels solid—until an old friend reappears and Ootani starts wondering if he’s really the one Tachibana wants.","genre_ids":[18,10749],"popularity":0.2945,"vote_count":16,"poster_path":"/l7zjtBF6Bf6CKYfTgTehMlE7lTx.jpg","release_date":"2007-10-27","vote_average":4.938,"backdrop_path":"/pWn3sG5ejyV3oLzTv2GbDI5tLfy.jpg","original_title":"愛の言霊","original_language":"ja"},{"id":591526,"adult":false,"title":"Tenderness","video":false,"overview":"It's the first time Adrien is entering a homosexual sauna. In the space of one night, he discovers this microcosm where the comic aspect of the individual tragedies encounters the passing of time and where hope mingles with melancholy.","genre_ids":[18],"popularity":0.3507,"vote_count":5,"poster_path":"/abOQvJeb6CvoqHEuUYwCtO4qGry.jpg","release_date":"2