5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Kokuho\",\"description\":\"Nagasaki, 1964: Following the death of his yakuza father, 15-year-old Kikuo is taken under the wing of a famous kabuki actor. Alongside Shunsuke, the actor’s only son, he decides to dedicate himself to this traditional form of theatre. For decades, the two young men grow and evolve together – and one will become the greatest Japanese master of the art of kabuki.\",\"image\":\"https://image.tmdb.org/t/p/w500/a15F5KJ4mleusJR1YKP4zUyZaxG.jpg\",\"datePublished\":\"2025-06-06\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Drama\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.176,\"bestRating\":10,\"ratingCount\":34}}"}}],["$","$L10",null,{"initialDrama":{"id":"5daa1c64-ec8e-45d4-9e99-7d0e3047a841","tmdb_id":1379266,"imdb_id":"tt35231039","content_type":"movie","title":"Kokuho","original_title":"国宝","overview":"Nagasaki, 1964: Following the death of his yakuza father, 15-year-old Kikuo is taken under the wing of a famous kabuki actor. Alongside Shunsuke, the actor’s only son, he decides to dedicate himself to this traditional form of theatre. For decades, the two young men grow and evolve together – and one will become the greatest Japanese master of the art of kabuki.","poster_path":"/a15F5KJ4mleusJR1YKP4zUyZaxG.jpg","backdrop_path":"/3C8yAIuXlH4BGCpTwEetIv0VBt8.jpg","release_date":"2025-06-06","first_air_date":null,"status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":18,"name":"Drama"}],"popularity":6.1227,"vote_average":8.176,"vote_count":34,"runtime":174,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T21:46:50.782267+00:00","updated_at":"2026-02-21T07:34:40.924+00:00","tagline":null,"homepage":"https://www.palacecinemas.com.au/movies/kokuho","budget":8000000,"re