":5,"aspect_ratio":1.778,"vote_average":1.434},{"width":3840,"height":2160,"file_path":"/z09QxlvUXAyQfZbgggjcL2w04QU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":1.434},{"width":1920,"height":1080,"file_path":"/n4GiahbsK9qZe8JC5v6kPFENXlH.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":1.434},{"width":1920,"height":1080,"file_path":"/uXsE8WOKB55GxLMfvMxmNVq6yMk.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":1.434},{"width":1280,"height":720,"file_path":"/hxNxbBuuWD7kw06g9g6jge9N7JZ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/1aWpHzY3Y4bODkhQkSARTYLbXW.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/9aIeqazwPiIQ1ClfxhwhCQ0IGzA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":3840,"height":2160,"file_path":"/bUcmY4GuJRIwQbZ8mYy1lWWDfNI.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1280,"height":720,"file_path":"/zBgz8ZQveXkRRysFnZaYi0fD6QM.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/mooabI47OLF0sZi6wsw7KmnF0AM.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":2000,"height":1125,"file_path":"/yzrGHCY0iRwdTXJpn1iUFiFYKxH.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/v8P8WLP6R7HDHUUykHJvfFkJrzz.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/lcCaABDOzD8v3ZSIudT5msnrkQ7.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/bcwEXWvGCUF3DCXSyLypZkqgXxu.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/2c3NYVUbRvYQeHgaR4HqKBD5csc.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/igmvRtYSm6viwEFFKfna6ckGHRt.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3000,"height":1688,"file_path":"/bJ63tGI6ou0f9s7aTj0Qu5SOQJn.jpg","iso_639_1":"ko","iso_3166_1":"KR","vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1920,"height":1080,"file_path":"/iov1XbPUAKRgoTAlfVbhorSbIj2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/qEKTokfD3n6ueo24GTiU9sg1EiA.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/bUpnpwCTNHCT7aZHZIKn6NGUFUW.jpg","iso_639_1":"ka","iso_3166_1":"GE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/lL5Jn3cjWw7vTBVleU4o212AcqA.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1911,"height":1075,"file_path":"/8HzC4v2roWDJKg5YK58jFhUsUUk.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/bUILTt7RtX6YFtIjpqI1oaZm4Bh.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/wLpLv0PzcvsbJOrw5Ocifn6JuiQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/hvZlJkVdVhop1z5eedtzQpaVaaS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2156,"file_path":"/cMp6bAeTxnsihEhGWkuSgbYo8Qy.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.781,"vote_average":0},{"width":3840,"height":2160,"file_path":"/wajlGQsw35aBPnWLthQlYChxkTF.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/h0zqhGfbN6gad3DCosyIAMijUTQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/36PThNOylBPqDxQ8C5MVIvqxaAT.jpg","iso_639_1":"ja","iso_3166_1":"JP","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/frYa3OjYZQrpoCCJLvaI7nM4sNn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/tovS85nDSOSDjtLfGw4eoiAVZ9b.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/rIvNRUyAXyQVGDrod5O7ilDVGXe.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/ui7xv8nC6V8UFB2F20pvRZdiSga.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T04:12:58.169+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":108,"tagline":"Feel the love.","homepage":"https://www.20thcenturystudios.com/movies/deadpool","overview":"The origin story of former Special Forces operative turned mercenary Wade Wilson, who, after being subjected to a rogue experiment that leaves him with accelerated healing powers, adopts the alter ego Deadpool. Armed with his new abilities and a dark, twisted sense of humor, Deadpool hunts down the man who nearly destroyed his life."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":109,"tagline":"Vous allez prendre votre pied !","homepage":"","overview":"Deadpool, est l'anti-héros le plus atypique de l'univers Marvel. À l'origine, il s'appelle Wade Wilson : un ancien militaire des Forces Spéciales devenu mercenaire. Après avoir subi une expérimentation hors norme qui va accélérer ses pouvoirs de guérison, il va devenir Deadpool. Armé de ses nouvelles capacités et d'un humour noir survolté, Deadpool va traquer l'homme qui a bien failli anéantir sa vie."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":108,"tagline":"Testemunha o início de um final feliz.","homepage":"","overview":"Depois de ter sido sujeito a uma experiência clandestina que o deixa com o poder de cicatrização acelerada, Wade Wilson adopta o alter ego Deadpool. Armado com as suas novas habilidades, além dum negro e retorcido sentido de humor, Deadpool persegue o homem que quase destruiu a sua vida."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":109,"tagline":"Duro. Listo. El puto amo.","homepage":"","overview":"Basado en el anti-héroe menos convencional de Marvel, Deadpool narra el origen de un ex agente de las fuerzas especiales llamado Wade Wilson, reconvertido a mercenario, y que tras ser sometido a un cruel experimento para curar su cáncer adquiere poderes de curación rápida, adoptando entonces el alter ego de Deadpool. Armado con sus nuevas habilidades y un oscuro y retorcido sentido del humor, Deadpool intentará dar caza al hombre que casi destruye su vida."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Дэдпул","runtime":108,"tagline":"«Стань свидетелем, как он кончит»","homepage":"","overview":"Уэйд Уилсон — наёмник. Будучи побочным продуктом программы вооружённых сил под названием «Оружие X», Уилсон приобрёл невероятную силу, проворство и способность к исцелению. Но страшной ценой: его клеточная структура постоянно меняется, а здравомыслие сомнительно. Всё, чего Уилсон хочет, — это держаться на плаву в социальной выгребной яме. Но течение в ней слишком быстрое."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":109,"tagline":"Erleben Sie den Anfang eines Happy Ends","homepage":"","overview":"Um seinem sicheren Tod durch Krebs zu entkommen, willigt Wade Wilson in ein riskantes Experiment ein, das ihn heilen und in einen Supersöldner verwandeln soll. Doch den Preis für sein Überleben bezahlt Wilson am Ende mit schweren Qualen und körperlicher Entstellung. Getrieben von Rache und durch Selbstheilungskräfte nahezu unsterblich geworden, jagt Wilson nun als Mutant Deadpool seine Peiniger und gefährdet damit seine große Liebe Vanessa, die er nach seiner Verwandlung voller Scham aus seinem Leben verbannte."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"死侍","runtime":0,"tagline":"不死现身","homepage":"","overview":"油嘴滑舌的雇佣兵韦德·威尔森与俏皮可爱的瓦内莎邂逅，但在爱情最美满的时刻，他被诊断患有晚期癌症，留在世上的时间所剩无几。极度绝望之际，他接受了弗朗西斯私人组织的邀请，对其基因做了改造，以谋求体能的突变。在忍受了一系列的残酷折磨后，韦德终于治好了癌症，蜕变成拥有不死之身的超级战士，但是代价却是失去了人类的面容。狡猾的弗朗西斯逃之夭夭，而韦德却无法以恐怖的面容去面对女友。在此之后，他化身死侍，穿梭于每一个黑暗角落，寻找阿贾克斯的踪影。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"דדפול","runtime":0,"tagline":"לצדק יש פנים חדשות.","homepage":"","overview":"איש קומנדו לשעבר הופך ללוחם חסר מעצורים, לאחר שניסוי העניק לו כוחות על. חמוש בחרבות ובלשון עוקצנית, הוא יוצא למסע נקמה באדם שהרס את פניו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":108,"tagline":"Buďte svědky, začátku šťastného konce.","homepage":"","overview":"Než se stal Deadpoolem, byl Wadem Wilsonem, bývalým členem speciálních jednotek. Když mu lékaři diagnostikovali pokročilé stadium rakoviny, podrobil se experimentální léčbě v rámci programu Weapon X, známého a populárního především mezi x-menovskými mutanty. Díky tomu se Wade zbavil rakoviny, a nejenže zůstal naživu, ale také jako bonus získal schopnost rychlého samouzdravování. Bohužel však – například oproti Wolverinovi, který po podobné léčbě zůstal celkem sexy – z tohoto pokusu vyšel trvale znetvořený. Vypadá dle vlastních slov jako „avokádo, které mělo sex se starším avokádem“. I proto celkem bez většího odporu přijal okostýmované alter ego jménem Deadpool."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":108,"tagline":"Γίνετε μάρτυρες της αρχής ενός ευτυχισμένου τέλους","homepage":"","overview":"Η ιστορία του Ουέιντ Ουίλσον, ενός πρώην πράκτορα των Ειδικών Δυνάμεων και νυν μισθοφόρου, ο οποίος, μετά από ένα μη-εγκεκριμένο πείραμα που του δίνει την ικανότητα να θεραπεύεται πολύ γρήγορα, υιοθετεί το alter ego Deadpool. Οπλισμένος με νέες ικανότητες και μία σκοτεινή, διεστραμμένη αίσθηση του χιούμορ, ο Deadpool κυνηγά τον άνδρα που σχεδόν κατέστρεψε τη ζωή του."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"","runtime":108,"tagline":"Nagy erő. Nagy pofa. Jó segg.","homepage":"","overview":"A szuperhősök korát éljük, de vár még néhány meglepetés. Wade Wilson a különleges erőknél szolgált, azután zsoldos lett. Egy furcsa, alig legális kísérlet eredményeképpen a szervezete meghökkentő képességekre tett szert: hihetetlenül gyorsan meggyógyul, bármi baj éri.  De nem ez az egyetlen fegyvere: őrült, gonosz humora is van - és nem fél használni.  A szupererős ember, aki a valóságból átlépett a hősök birodalmába, most élete legnehezebb háborújába indul: bosszút akar állni azon az emberen, aki egykor majdnem tönkretette őt."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":108,"tagline":"","homepage":"","overview":"Wade Wilson is een speciale agent van de overheid die, nadat hij onderworpen is aan een behandeling die hem bovenmenselijke genezende krachten heeft gegeven, een alter-ego in de vorm van 'Deadpool' aanneemt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":108,"tagline":"Il Supereroe che non ti aspetti","homepage":"","overview":"Tratto dal fumetto sul più irriverente anti-eroe dell’universo Marvel, il film racconta la storia del mercenario Wade Wilson, ex agente operativo delle Special Forces, che, dopo essere stato sottoposto a un terribile esperimento, acquisisce l’eccezionale potere del Fattore Rigenerante e abbraccia una nuova identità. Con la sua nuova abilità di guarire rapidamente e un pungente senso dell’umorismo, Deadpool andrà a caccia dell’uomo che gli ha quasi rovinato la vita."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"เดดพูล","runtime":0,"tagline":"","homepage":"","overview":"เมื่อการทดลองอันล้มเหลวส่งผลให้นายทหารรับจ้างมีพลังเหนือธรรมชาติและช่วยเยียวยารักษาร่างกายได้ เขาจึงสร้างตัวตนขึ้นมาใหม่เพื่อไล่ล่าบุคคลที่เคยทำลายชีวิตเขา"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":108,"tagline":"Zeki. Çevik. Küfürbaz.","homepage":"","overview":"Eski bir özel kuvvetler görevlisi olan Wade Wilson ordudan ayrıldıktan sonra kendi çöplüğünde, kendi kurallarına göre takılan, kötünün iyisi bir adamdır. Hayatına yeni giren Vanessa ile harika bir uyumu varken, bir şeylerin tam da yolunda gittiğini düşünürken kanser olduğu gerçeğiyle yüz yüze kalır. Sevdiği kadını bu acılı süreci izlemekten kurtarmak için onu terk eden Wade, kendisine tedavi umudu sunan bir bilimsel projeye katılır. Fakat bu proje sadece bir \"yan etki\" olarak kansere tedavi olacaktır. Asıl amaç birtakım DNA'ları tetiklemektir. Akla gelmeyecek acılara göğüs geren Wade, her şey sona erdiğinde üstün yeteneklere sahip olur. Fakat tüm bu özellikleriyle tek bir amacı vardır: Ajax \"Francis\"ten intikam almak!"},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Priča o omiljenom Marvelovom liku Deadpoolu, odnosno bivšem pripadniku specijalnih jedinica Wadeu Wilsonu (Ryan Reynolds) koji nakon rigoroznih eksperimenata stiče supermoći, uključujući i mogućnost brzog zacjelivanja, i pretvara se u njegov alter ego, Deadpoola. Ubrzo neuništivi antiheroj na rubu razuma, sa novim sposobnostima i smrtonosnim smislom za humor, kreće u potragu za čovjekom koji mu je zamalo uništio život."},"name":"Bosanski","iso_639_1":"bs","iso_3166_1":"BS","english_name":"Bosnian"},{"data":{"title":"","runtime":108,"tagline":"Cwaniaczek. Przyjemniaczek. Przystojniaczek.","homepage":"","overview":"Wade Wilson (Ryan Reynolds) - niegdyś agent służb specjalnych, a obecnie najemnik - poddany zostaje nielegalnemu eksperymentowi, w wyniku którego nabywa niezwykłych mocy samouzdrawiania. Odtąd staje się znany jako \"Deadpool\" i wyposażony w nowe zdolności oraz czarne poczucie humoru wyrusza z misją wymierzenia sprawiedliwości człowiekowi, który niemal zniszczył mu życie."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"Simte dragostea.","homepage":"","overview":"Supranumit „Mercenarul cu gură mare”, Deadpool obține, în urma unui experiment militar care dorea să redea abilitatea de regenerare rapidă a lui Wolverine, puteri incredibile (invulnerabilitatea la puteri telepatice și telekinezice, rezistența la droguri și toxine, dar și prelungirea vieții grație puterilor de refacere ale organismului său). Acestea vin, însă, și cu unele inconveniente: instabilitatea psihică și un fizic desfigurat."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"پښتو","iso_639_1":"ps","iso_3166_1":"PS","english_name":"Pushto"},{"data":{"title":"ددپول","runtime":0,"tagline":"شاهد آغاز یک پایان خوش باش","homepage":"","overview":"مامور ویژه ای بنام «وید ویلسون» (رایان رینالدز) که تبدیل به یک مزدور شده است، تحت یک آزمایشی شرورانه قرار میگیرد و قدرت های ویژه ای بدست می آورد. او با استفاده از این قدرتش شروع میکند به شکار افرادی که زندگی اش را نابود کردند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"??????","iso_639_1":"ky","iso_3166_1":"KG","english_name":"Kirghiz"},{"data":{"title":"","runtime":108,"tagline":"Uudentyyppinen supersankari.","homepage":"","overview":"Marvelin sarjakuviin perustuva Deadpool kertoo entisestä erikoisjoukkojen miehestä Wade Wilsonista, joka ryhtyy palkkasotilaaksi. Hänet kuitenkin altistetaan valvomattomaan kokeiluun, joka antaa hänelle supervoimat ja hänestä tulee Deadpool. Deadpool etsii käsiinsä miehen, joka melkein tuhosi hänet, aseenaan supervoimat ja kieroutunut huumorintaju."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"","runtime":108,"tagline":"Overvær starten af begyndelse","homepage":"","overview":"Deadpool er Marvel Comics mest ukonventionelle antihelt, og filmen fortæller historien om den tidligere Special Force agent og lejesoldat, Wade Wilson, der efter at være blevet udsat for et skrupelløst eksperiment, som efterlader ham med stærkt helbredende kræfter, udvikler alteregoet Deadpool. Bevæbnet med sine nye evner og en sort, skæv form for humor påbegynder Deadpool jagten på den mand, som næsten ødelagde hans liv."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Дедпул","runtime":0,"tagline":"Крута дупа. Дотепна дупа. Класна дупа.","homepage":"","overview":"Головний герой фантастичного бойовика – Вейд Вілсон (Райан Рейнольдс). Єдиним його порятунком від смертельної хвороби стала участь в експериментальному лікуванні, яке він пройшов в лабораторії «Зброя Х». Тепер його клітини мають здатність надшвидкої регенерації, а він, таким чином, стає ідеальним вбивцею. З цього моменту вбивство стало його роботою, і він не може зупиниться, оскільки це єдиний спосіб реалізувати себе."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"데드풀","runtime":108,"tagline":"마블 역사상 가장 매력 터지는 히어로","homepage":"","overview":"특수부대 요원 출신의 용병 웨이드 윌슨은 취향과 장난기마저 똑 닮은 바네사를 만나 행복한 나날을 보낸다. 하지만 행복은 광고처럼 짧은 법. 말기 암 선고를 받은 웨이드는 비밀 임상실험에 참여하며 재기를 노린다. 극한의 고문으로 이뤄진 실험 후 웨이드는 암을 치료할뿐더러 무한한 재생 능력을 얻으며 불사의 존재가 된다. 하지만 동시에 부작용으로 호러영화에 어울릴 법한 외양을 갖는다. 스스로 슈트까지 지어 입고 데드풀이 된 웨이드는 자신을 고문한 자를 찾아 제대로 복수한 뒤 당당히 바네사 앞에 나서려 한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":108,"tagline":"","homepage":"","overview":"Baserat på Marvel Comics mest okonventionelle antihjälte är detta berättelsen om före detta legosoldaten Wade Wilson, som efter att ha utsatts för en rad grymma och oortodoxa experiment utvecklat helande krafter. Han antar alter-egot Deadpool och beväpnad med sina nya förmågor och en mörk, vriden humor, börjar han jaga dem som stod bakom experimenten."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Film action berjudul “Deadpool” ini merupakan film yang bercerita tentang seorang pria yang berprofesi sebagai tentara bayaran bernama Wade Wilson ( Ryan Reynolds ). Wade yang sedang mengalami sakit sekarat karena kanker dan mendapatkan sebuah tawaran untuk percobaan perubahan genetik di mana bisa mengubah dirinya dan menjadi seorang superhero. Karena penyakit yang dideritanya, Wade akhirnya memutuskan untuk melakukan percobaan tersebut. Percobaan tersebut akhirnya membuat diri Wade berubah drastis dan menjadi seorang superhero yang dijuluki dengan Deadpool."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"デッドプール","runtime":0,"tagline":"呼んだ?","homepage":"","overview":"ウェイド・ウィルソンは、以前は優秀な特殊部隊の傭兵として活躍していたが、今は悪者を気まぐれに痛めつけては金を稼いでいる。すっかり正義のヒーロー気取りの彼は恋人との結婚も決まり幸福の絶頂にあったが、いきなり末期ガンだと診断される。とある組織にガンを根治できると聞いたウェイドは、彼らに同行して人体実験を受ける。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Дедпул","runtime":109,"tagline":"Правосъдието има ново лице","homepage":"","overview":"Това е историята за произхода на Дедпул. Бившият агент от Специалните сили Уейд Уилсън става наемник, след като в опит да спаси живота си участва в експеримент, в резултат от който получава нечовешки сили и способности, но губи човешкия си образ и така приема алтер егото Дедпул. Въоръжен с новите си сили и старото си извратено, изкривено чувство за хумор Дедпул тръгва по следите на човека, който е унищожил живота му и застрашава любимата му."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Дедпул","runtime":0,"tagline":"","homepage":"","overview":"Филм је заснован на Марвеловом стрипу о неконвенционалном анти-хероју Дедпулу. У фокусу приче је бивши припадник специјалних јединица – плаћеник Вејд Вилсон који након ригорозних експеримената стиче натприродну моћ исцељења и претвара се у његов алтер его, Дедпула."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"","runtime":108,"tagline":"Drsný byť, každého zbiť a mať sexi riť.","homepage":"","overview":"Predtým, ako sa stal Deadpoolom, bol Wade Wilson členom špeciálnych jednotiek. Keď mu lekári diagnostikovali pokročilé štádium rakoviny, podrobil sa experimentálnej liečbe v rámci programu Weapon X, známeho a populárneho predovšetkým medzi x-menovskými mutantmi. Vďaka tomu sa Wade zbavil rakoviny a nielenže prežil, ale ako bonus získal schopnosť rýchleho samouzdravovania. Oproti Wolverinovi, ktorý po podobnej liečbe zostal celkom sexy – z tohoto pokusu vyšiel trvale znetvorený. Vypadá podľa vlastných slov ako “avokádo, ktoré malo sex so starším avokádom“. Aj preto bez väčšieho odporu prijal „okostýmované“ alter ego s názvom Deadpool."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"","runtime":108,"tagline":"Súper Héroe, súper rudo, súper nalgas.","homepage":"","overview":"Basado en el anti-héroe menos convencional de la Marvel, Deadpool narra el origen de un ex-operativo de la fuerzas especiales llamado Wade Wilson, reconvertido a mercenario, y que tras ser sometido a un cruel experimento adquiere poderes de curación rápida, adoptando Wade entonces el alter ego de Deadpool. Armado con sus nuevas habilidades y un oscuro y retorcido sentido del humor, Deadpool intentará dar caza al hombre que casi destruye su vida."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":107,"tagline":"Com Grandes Poderes, Vem Grandes Irresponsabilidades.","homepage":"http://www.deadpoolfilme.com.br","overview":"Baseado no anti-herói não convencional da Marvel Comics, Deadpool conta a história da origem do ex-agente das Forças Especiais que se tornou o mercenário Wade Wilson. Depois de ser submetido a um desonesto experimento que o deixa com poderes de cura acelerada, Wade adota o alter ego de Deadpool. Armado com suas novas habilidades e um senso de humor negro e distorcido, Deadpool persegue o homem que quase destruiu sua vida."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"惡棍英雄：死侍","runtime":0,"tagline":"不死現身","homepage":"","overview":"故事敘述前特種部隊成員韋德·威爾遜被診出患有癌症，為了求治癒而自願接受人體實驗，使自己擁有快速癒合的能力；但這卻完全毀了他的生活和面容，因此便以「死侍」的名號對向他做實驗的神秘人展開過程不時帶有暴力和幽默感的追殺。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":108,"tagline":"Ressentez l'amour.","homepage":"","overview":"Wade Wilson, ancien membre des forces spéciales, découvre qu'il est atteint d'un cancer en phase terminale. Devant sa fin imminente, il accepte de suivre un traitement mis au point par le machiavélique Ajax. Grâce aux procédés génétiques, le jeune homme devient un mutant doté de la capacité de guérir ses blessures instantanément, mais il est complètement défiguré. Pour interrompre les expériences qui vont le transformer en esclave, il s'évade du laboratoire secret. Wade Wilson cache la laideur de son visage avec un masque et endosse un costume rouge. Sous le surnom Deadpool, il se lance à la poursuite du malfaisant Ajax et de sa bande."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"ديدبول","runtime":0,"tagline":"اشعر بالحب.","homepage":"","overview":"كان ديدبول/ويد ويلسون يعمل في السابق في القوات الخاصة، لكنه سرعان ما تحول إلى مرتزق ومنح لنفسة أسم (ديدبول) بعد أن تعرض إلى تجربة قاسية تركته بمهارات عالية مثل القدرة على إعادة شفاء نفسة، يخرج (ديدبول) بمهاراته إلى الشارع لينتقم من الرجل الذي دمر حياته."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"","runtime":0,"tagline":"Chứng kiến sự khởi đầu của một cái kết có hậu.","homepage":"","overview":"Lấy cảm hứng từ nhân vật \"phản anh hùng\" tiếng tăm bậc nhất trong tuyển tập truyện tranh Marvel, Deadpool xoay quanh câu chuyện về Wade Wilson - kẻ ban đầu nằm trong Lực Lượng Đặc Biệt sau đó trở thành một lính đánh thuê. Sau khi trải qua một cuộc thử nghiệm tàn khốc, anh có được năng lực tự phục hồi phi thường, từ đó lấy biệt danh Deadpool. Mang trong mình khả năng mới và khiếu hài hước dị thường, Deadpool quyết săn lùng người đàn ông đã hủy hoại cả cuộc đời mình."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Bivši specijalni agent, sada plaćenik, Wade Wilson, biva podložen ilegalnom eksperimentu koji mu podari nadljudske moći. Nakon što jedva uspije pobjeći, on preuzima svoj novi alter ego i nazove se Deadpool. Naoružan novim moćima i veoma uvrnutim smislom za humor, Deadpool kreće u lov na čovjeka koji mu je gotovo potpuno uništio život, no usput planira i ponovno osvojiti svoju bivšu ljubav."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"დედპული","runtime":0,"tagline":"","homepage":"","overview":"მას შემდეგ, რაც ფილმის მთავარ გმირს დაუსვეს სასიკვდილო დიაგნოზი, მას შესთავაზეს ექსპერიმენტალური ოპერაციის გაკეთება, რომელიც დაუმარცხებელ ჯარისკაცად გადააქცევდა. ასე შეიქმნა მარველის ახალი გმირი დედპული..."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Deadpool forteller historien om hvordan Wade Wilson går fra å være en spesialsoldat til å bli en hardbarka og farlig leiemorder. Etter å ha blitt utsatt for et mislykket eksperiment som gir han selvhelbredende krefter, tar han til seg alteregoet Deadpool. Bevæpnet med sine nye evner og en mørk, vridd sans for humor, jakter Deadpool ned mannen som nesten ødela livet hans."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Дедпул","runtime":0,"tagline":"","homepage":"","overview":""},"name":"","iso_639_1":"mk","iso_3166_1":"MK","english_name":"Macedonian"},{"data":{"title":"ഡെഡ്പൂള്‍","runtime":108,"tagline":"","homepage":"","overview":""},"name":"","iso_639_1":"ml","iso_3166_1":"IN","english_name":"Malayalam"},{"data":{"title":"","runtime":108,"tagline":"","homepage":"","overview":"Basert på Marvel Comics mest utradisjonelle anti-helt, forteller DEADPOOL opprinnelseshistorien om tidligere Special Forces leiesoldaten Wade Wilson, som etter å ha blitt utsatt for et forbryter-eksperiment som etterlater ham med akselererte helbredende krefter, og utvikler alter ego Deadpool. Væpnet med sine nye evner og en mørk, forvrengt sans for humor, jakter Deadpool ned mannen som nesten ødela sitt liv."},"name":"Bokmål","iso_639_1":"nb","iso_3166_1":"NO","english_name":"Norwegian Bokmål"},{"data":{"title":"","runtime":106,"tagline":"","homepage":"","overview":"Film pripoveduje zgodbo o bivšem agentu Wadeu Wilsonu, ki po rigoroznem eksperimentu pridobi nadnaravno moč celjenja in se preobrazi v svoj alterego, Deadpool. Oborožen s svojo novo sposobnostjo ter temačnim smislom za humor se Deadpool odpravi iskati moža, ki mu je uničil življenje."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Dedpūls","runtime":0,"tagline":"","homepage":"","overview":"Veids Vilsons - specvienības kaujinieks, kurš pakļauts slepenam eksperimentam iegūst ne tikai neticamu spēku, veiklību un paātrinātu pašizdziedināšanos, bet arī nestabilu psihi. Apbruņojies ar jauniegūtajām spējām un pavisam melnu humora izjūtu, viņš tagad ir zināms kā Dedpūls un viņa mērķis ir cilvēks, kurš nesenā pagātnē ir izpostījis viņa dzīvi."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Deadpool","runtime":110,"tagline":"","homepage":"","overview":"Veidas Vilsonas (akt. Ryan Reynolds) – buvęs specialiųjų pajėgų kariškis, kurio gyvenimą apkartina žinia apie negailestingą vėžį. Ši žinia stiprų ir aktyvų vyrą griaužia tiek fiziškai, tiek emociškai. Nesusitaikęs su mintimi, jog gyvenimas artėja link pabaigos, Veidas ryžtasi eksperimentiniam gydymui. Šis gydymas apvers jo gyvenimą aukštyn kojomis."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"死侍：不死現身","runtime":0,"tagline":"最醒 最玩嘢 最寸寸貢 最反傳統嘅超級漫畫英雄","homepage":"","overview":"在《狼人外傳》中早已驚鴻一瞥的賴恩尼諾斯，飾演由前特種部隊變成僱傭兵的 Wade Wilson，受到地下組織進行實驗性手術後，讓他身體擁有快速再生的特異能力！這位喜歡打嘴砲的惡棍英雄，憑著一身獨特好本領，展開史上最殘酷大報復，把那些毀掉他生活的仇人逐一獵殺！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Dedpul","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ozbek","iso_639_1":"uz","iso_3166_1":"UZ","english_name":"Uzbek"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"euskera","iso_639_1":"eu","iso_3166_1":"ES","english_name":"Basque"},{"data":{"title":"","runtime":0,"tagline":"Dur. Llest. El puto amo.","homepage":"","overview":"Basat en l'anti-heroi menys convencional de la Marvel, Deadpool narra l'origen d'un ex-operatiu de les forces especials anomenat Wade Wilson, reconvertit a mercenari, i que després de ser sotmès a un cruel experiment adquireix poders de curació ràpida, adoptant Wade aleshores l'alter ego de Deadpool. Armat amb les seves noves habilitats i un sentit fosc i recargolat de l'humor, Deadpool intentarà caçar l'home que gairebé destrueix la seva vida."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Deadpool on Marveli universumi kõige omapärasem antikangelane, endine eriväelane ja palgasõdur Wade Wilson (Ryan Reynolds), kellel diagnoositakse vähk. Kuna tal pole midagi kaotada, liitub mees äärmusliku eksperimendiga, mille tulemusel omandab kiire paranemisvõime ja võtab kasutusele alter ego Deadpool. Relvastatuna oma uute võimete ning erakordselt väärastunud huumorimeelega, asub Deadpool jahtima meest, kes oleks ta elu peaaegu täielikult hävitanud."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"}],"reviews_tmdb":[{"id":"56c146cac3a36817f900d5f0","url":"https://www.themoviedb.org/review/56c146cac3a36817f900d5f0","author":"huy.duc.eastagile","content":"A funny movie with a romantic love story.\r\n\r\nWade Wilson (Ryan Reynolds) is a former Special Forces operative who now works as a mercenary. His world comes crashing down when evil scientist Ajax (Ed Skrein) tortures, disfigures and transforms him into Deadpool. \r\n\r\nThe rogue experiment leaves Deadpool with accelerated healing powers and a twisted sense of humor. With help from mutant allies Colossus and Negasonic Teenage Warhead (Brianna Hildebrand), Deadpool uses his new skills to hunt down the man who nearly destroyed his life.","created_at":"2016-02-15T03:32:26.766Z","updated_at":"2021-06-23T15:57:45.294Z","author_details":{"name":"","rating":9.5,"username":"huy.duc.eastagile","avatar_path":null}},{"id":"56ca035a9251414a7a0062f0","url":"https://www.themoviedb.org/review/56ca035a9251414a7a0062f0","author":"Wong","content":"I actually enjoyed the movie so much that i'll recommend it to all my friends, at first i didn't really want to watch it because i'm not into super hero movies at all, but i did anyway, i mean people were talking so much about it i had to see it myself and what an awesome choice i made. The good thing about this movie is that Deadpool is a hero but in a very comedic way, you don't usually expect comedy from a superhero film but this one was full of comedy and the way they treated the plot was amazing, it was there, humor was there in every scene, even when there was fighting or romance or any other scene, the writers managed to add comedy everywhere in a very good way that'll surprisingly make you want to watch it again, and again. Thank you for taking the time read my review and if you're asking yourself if you should watch this movie, it's a definite Yes.","created_at":"2016-02-21T18:35:06.961Z","updated_at":"2021-06-23T15:57:45.385Z","author_details":{"name":"Wong","rating":7,"username":"WongKentir","avatar_path":null}},{"id":"57375b8bc3a3687e1a0046bf","url":"https://www.themoviedb.org/review/57375b8bc3a3687e1a0046bf","author":"Reno","content":"$11","created_at":"2016-05-14T17:08:27.579Z","updated_at":"2024-05-16T15:18:29.623Z","author_details":{"name":"Reno","rating":6.5,"username":"Rangan","avatar_path":"/6ZpVUJzqXMzH35VprEtnX0sNI3.jpg"}},{"id":"57ad1b93925141588400129e","url":"https://www.themoviedb.org/review/57ad1b93925141588400129e","author":"talisencrw","content":"Though I have always been a DC enthusiast, I was intrigued by the idea of the Deadpool movie, and knew I'd end up watching it (I probably see 70% of DC films that are released and maybe 20% of Marvel ones). I enjoyed its definitely postmodern approach--and wish Reynolds' Green Lantern movie had one-tenth the humour and charm that THIS film had.\r\n\r\nIt'll be very interesting to see how comic-book movies are affected, both short- and long-term by its massive success.","created_at":"2016-08-12T00:42:59.904Z","updated_at":"2021-06-23T15:57:50.213Z","author_details":{"name":"","rating":9,"username":"talisencrw","avatar_path":null}},{"id":"58c17054925141732700ace9","url":"https://www.themoviedb.org/review/58c17054925141732700ace9","author":"mattwilde123","content":"This film was very funny. Ryan Reynolds was made for this role. The innuendos did get a bit much though.\r\n\r\nIt was well written and the direction was very good but it did go into a territory that it was trying to make fun of. I got bored of all the action hero conventions after a while.\r\n\r\n★★★½","created_at":"2017-03-09T15:10:12.915Z","updated_at":"2021-06-23T15:57:55.460Z","author_details":{"name":"","rating":7,"username":"mattwilde123","avatar_path":"/wCTsgKvihctPGp4Ms7Y373baeHm.jpg"}},{"id":"592b7805c3a368783e069f68","url":"https://www.themoviedb.org/review/592b7805c3a368783e069f68","author":"jamitchell1509","content":"As a comic book fan, I was fairly dubious about Deadpool’s cinematic outing. I wasn't altogether sure that a film that would obviously have to be fun, self-referential and self-aware could also be able to talk about a character who not only becomes seriously ill, but also struggles to keep a grip on his sanity well enough to do the character justice. \r\n\r\nWhen I watched the film, it was clear that I had been over-thinking. Perhaps the makers of the film had thought the same as me. Perhaps they thought that trying to be lighthearted and slightly dark at the same time would be like trying to keep too many balls in the air. I say that because the issue of Deadpool’s sanity, or lack thereof, is only touched upon. If that is the case, I think it is quite a clever decision in a ‘let's not try to run before we can walk’ kind of a way. If not, Tim Miller has still given us a very enjoyable film, in which, Ryan Reynolds shines as an extremely good comedic actor.","created_at":"2017-05-29T01:23:17.816Z","updated_at":"2021-06-23T15:57:57.929Z","author_details":{"name":"","rating":8,"username":"jamitchell1509","avatar_path":null}},{"id":"5e08146e4c1d9a0015e34b0a","url":"https://www.themoviedb.org/review/5e08146e4c1d9a0015e34b0a","author":"Gimly","content":"$12","created_at":"2019-12-29T02:50:22.571Z","updated_at":"2021-06-23T15:58:30.897Z","author_details":{"name":"Gimly","rating":6,"username":"Ruuz","avatar_path":"/xUObnJSvHrFPsIpoDmb1jiQZLq7.jpg"}},{"id":"63f6908bd1ca2a00f0092377","url":"https://www.themoviedb.org/review/63f6908bd1ca2a00f0092377","author":"Dicky Pratama","content":"Its my favorite film, this film really fun even its action","created_at":"2023-02-22T22:00:43.597Z","updated_at":"2023-03-03T19:42:48.219Z","author_details":{"name":"Dicky Pratama","rating":10,"username":"ImBotAndroid","avatar_path":"/3l1IP0dzfTnoSqnrYWDkyvSONi.jpg"}},{"id":"645ed6416e0d72013dcb26ef","url":"https://www.themoviedb.org/review/645ed6416e0d72013dcb26ef","author":"Andre Gonzales","content":"Awesome movie. I could have lived without the play by play commentary from him. Like he say's people have tried to shut him up.","created_at":"2023-05-13T00:13:53.757Z","updated_at":"2023-05-13T00:13:53.839Z","author_details":{"name":"Andre Gonzales","rating":10,"username":"SoSmooth1982","avatar_path":"/ast1oGYDI7Li9daLuOV4UxGiXj.jpg"}},{"id":"661731e4e295b4017daefa71","url":"https://www.themoviedb.org/review/661731e4e295b4017daefa71","author":"tmdb16591261","content":"As a kid I loved this, and honestly I can see why. I liked reading the comics and this movie does a good job of making what makes Deadpool unique in the comics and putting that in the movie. **(He's childish, immature, funny, and breaks the 4th wall).** All with great cameos of other characters that are also featured in the deadpool comics.","created_at":"2024-04-11T00:42:12.145Z","updated_at":"2024-04-11T15:03:30.548Z","author_details":{"name":"","rating":7,"username":"tmdb16591261","avatar_path":null}},{"id":"66576672115b93ee91a526c8","url":"https://www.themoviedb.org/review/66576672115b93ee91a526c8","author":"CinemaSerf","content":"$13","created_at":"2024-05-29T17:31:30.374Z","updated_at":"2024-05-29T17:31:30.491Z","author_details":{"name":"CinemaSerf","rating":8,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}},{"id":"69220223d17f113730a3aebd","url":"https://www.themoviedb.org/review/69220223d17f113730a3aebd","author":"ACER9867","content":"A Funny Movie and a bit romantic and the couple chemistry in the movie is great and the color grading is top notch overall it's an fantastic movie.","created_at":"2025-11-22T18:34:11.917Z","updated_at":"2025-11-30T17:55:16.019Z","author_details":{"name":"","rating":null,"username":"ACER9867","avatar_path":null}}],"recommendations":[{"id":383498,"adult":false,"title":"Deadpool 2","video":false,"overview":"Wisecracking mercenary Deadpool battles the evil and powerful Cable and other bad guys to save a boy's life.","genre_ids":[28,35,12],"media_type":"movie","popularity":8.9135,"vote_count":18957,"poster_path":"/to0spRl1CMDvyUbOnbb4fTk3VAd.jpg","release_date":"2018-05-15","vote_average":7.488,"backdrop_path":"/3P52oz9HPQWxcwHOwxtyrVV1LKi.jpg","original_title":"Deadpool 2","original_language":"en"},{"id":271110,"adult":false,"title":"Captain America: Civil War","video":false,"overview":"Following the events of Age of Ultron, the collective governments of the world pass an act designed to regulate all superhuman activity. This polarizes opinion amongst the Avengers, causing two factions to side with Iron Man or Captain America, which causes an epic battle between former allies.","genre_ids":[12,28,878],"media_type":"movie","popularity":13.6256,"vote_count":23764,"poster_path":"/rAGiXaUfPzY7CDEyNKUofk3Kw2e.jpg","release_date":"2016-04-27","vote_average":7.446,"backdrop_path":"/wdwcOBMkt3zmPQuEMxB3FUtMio2.jpg","original_title":"Captain America: Civil War","original_language":"en"},{"id":284052,"adult":false,"title":"Doctor Strange","video":false,"overview":"After his career is destroyed, a brilliant but arrogant surgeon gets a new lease on life when a sorcerer takes him under her wing and trains him to defend the world against evil.","genre_ids":[14,12,28],"media_type":"movie","popularity":11.5246,"vote_count":23180,"poster_path":"/xf8PbyQcR5ucXErmZNzdKR0s8ya.jpg","release_date":"2016-10-25","vote_average":7.417,"backdrop_path":"/3zvZ699gMW2RhWc0GisIukzq0Ls.jpg","original_title":"Doctor Strange","original_language":"en"},{"id":209112,"adult":false,"title":"Batman v Superman: Dawn of Justice","video":false,"overview":"Fearing the actions of a god-like Super Hero left unchecked, Gotham City’s own formidable, forceful vigilante takes on Metropolis’s most revered, modern-day savior, while the world wrestles with what sort of hero it really needs. And with Batman and Superman at war with one another, a new threat quickly arises, putting mankind in greater danger than it’s ever known before.","genre_ids":[28,12,14],"media_type":"movie","popularity":12.9094,"vote_count":18768,"poster_path":"/5UsK3grJvtQrtzEgqNlDljJW96w.jpg","release_date":"2016-03-23","vote_average":5.989,"backdrop_path":"/mwuP3Ah8b7SKnmSCk8EaQw7jrEq.jpg","original_title":"Batman v Superman: Dawn of Justice","original_language":"en"},{"id":140607,"adult":false,"title":"Star Wars: The Force Awakens","video":false,"overview":"Thirty years after defeating the Galactic Empire, Han Solo and his allies face a new threat from the evil Kylo Ren and his army of Stormtroopers.","genre_ids":[12,28,878],"media_type":"movie","popularity":11.6191,"vote_count":20300,"poster_path":"/wqnLdwVXoBjKibFRR5U3y0aDUhs.jpg","release_date":"2015-12-15","vote_average":7.25,"backdrop_path":"/8BTsTfln4jlQrLXUBquXJ0ASQy9.jpg","original_title":"Star Wars: The Force Awakens","original_language":"en"},{"id":118340,"adult":false,"title":"Guardians of the Galaxy","video":false,"overview":"Light years from Earth, 26 years after being abducted, Peter Quill finds himself the prime target of a manhunt after discovering an orb wanted by Ronan the Accuser.","genre_ids":[28,878,12],"media_type":"movie","popularity":10.3704,"vote_count":29354,"poster_path":"/r7vmZjiyZw9rpJMQJdXpjgiCOk9.jpg","release_date":"2014-07-30","vote_average":7.905,"backdrop_path":"/vmBSlRZYKfNdaDZ7wGkrSNbmdMI.jpg","original_title":"Guardians of the Galaxy","original_language":"en"},{"id":269149,"adult":false,"title":"Zootopia","video":false,"overview":"Determined to prove herself, Officer Judy Hopps, the first bunny on Zootopia's police force, jumps at the chance to crack her first case - even if it means partnering with scam-artist fox Nick Wilde to solve the mystery.","genre_ids":[16,12,10751,35],"media_type":"movie","popularity":25.4602,"vote_count":17721,"poster_path":"/hlK0e0wAQ3VLuJcsfIYPvb4JVud.jpg","release_date":"2016-02-11","vote_average":7.759,"backdrop_path":"/9tOkjBEiiGcaClgJFtwocStZvIT.jpg","original_title":"Zootopia","original_language":"en"},{"id":246655,"adult":false,"title":"X-Men: Apocalypse","video":false,"overview":"After the re-emergence of the world's first mutant, world-destroyer Apocalypse, the X-Men must unite to defeat his extinction level plan.","genre_ids":[28,12,878,14],"media_type":"movie","popularity":10.7103,"vote_count":13593,"poster_path":"/ikA8UhYdTGpqbatFa93nIf6noSr.jpg","release_date":"2016-05-18","vote_average":6.519,"backdrop_path":"/sTQNRqLbfCXolrb5CizAW1dj528.jpg","original_title":"X-Men: Apocalypse","original_language":"en"},{"id":263115,"adult":false,"title":"Logan","video":false,"overview":"In the near future, a weary Logan cares for an ailing Professor X in a hideout on the Mexican border. But Logan's attempts to hide from the world and his legacy are upended when a young mutant arrives, pursued by dark forces.","genre_ids":[28,18,878],"media_type":"movie","popularity":11.4007,"vote_count":20155,"poster_path":"/fnbjcRDYn6YviCcePDnGdyAkYsB.jpg","release_date":"2017-02-28","vote_average":7.818,"backdrop_path":"/2aQyMFEtppL6dNK384l5qhGSn5G.jpg","original_title":"Logan","original_language":"en"},{"id":270487,"adult":false,"title":"Hail, Caesar!","video":false,"overview":"When a Hollywood star mysteriously disappears in the middle of filming, the studio sends their fixer to get him back.","genre_ids":[35,80,18,9648,36],"media_type":"movie","popularity":3.8049,"vote_count":3955,"poster_path":"/ozY79UvbYvJUWFg2UCM1CDQ7rBl.jpg","release_date":"2016-02-05","vote_average":5.936,"backdrop_path":"/zIUigIht3f9osNGyleF6B3jBbl7.jpg","original_title":"Hail, Caesar!","original_language":"en"},{"id":24428,"adult":false,"title":"The Avengers","video":false,"overview":"When an unexpected enemy emerges and threatens global safety and security, Nick Fury, director of the international peacekeeping agency known as S.H.I.E.L.D., finds himself in need of a team to pull the world back from the brink of disaster. Spanning the globe, a daring recruitment effort begins!","genre_ids":[878,28,12],"media_type":"movie","popularity":50.5441,"vote_count":36098,"poster_path":"/RYMX2wcKCBAr24UyPD7xwmjaTn.jpg","release_date":"2012-04-25","vote_average":7.951,"backdrop_path":"/pGFQCp12a8andfPlpnmXz44IIvY.jpg","original_title":"The Avengers","original_language":"en"},{"id":136795,"adult":false,"title":"The Heat","video":false,"overview":"Uptight and straight-laced, FBI Special Agent Sarah Ashburn is a methodical investigator with a reputation for excellence--and hyper-arrogance. Shannon Mullins, one of Boston P.D.'s \"finest,\" is foul-mouthed and has a very short fuse, and uses her gut instinct and street smarts to catch the most elusive criminals. Neither has ever had