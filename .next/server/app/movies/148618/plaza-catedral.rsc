o":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/d6CNUw19Rr1ZFCR0wEBWm5brVCm.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/gJ7XYuKA0xGZDHC7LEtpQVDu7ES.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/oebUrPamdJx1BAeF7VXUwfrA51X.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/pph62BoXp1JwcTSihNW6ggniqkX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/zIuvsmCDYmakyBhg64sCYXei4GL.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/ixukce7BvwowiOCNrSAYNwpIUL3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T09:08:05.804+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":94,"tagline":"","homepage":"","overview":"Alicia is a 42-year-old-woman whose grief has caused her estrangement from society. Her world is turned upside down when 14-year-old Chief, a young boy who looks after people’s cars, stumbles into her house, bleeding."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Alicia es una mujer de 42 años cuyo duelo la ha llevado a alejarse de la sociedad. Su mundo se pone patas arriba cuando Chief, un niño de 14 años que cuida los autos de la gente, entra a su casa sangrando."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":94,"tagline":"","homepage":"","overview":"Alicia, 42 anos, é uma mulher de luto que, pela dor que está sentindo, afastou-se da sociedade. O seu mundo fica virado do avesso quando um menino de 14 anos, que cuida dos carros na praça à frente de sua residência, aparece ensanguentado em sua porta."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"כיכר הקתדרלה","runtime":94,"tagline":"","homepage":"","overview":"אלישיה בת ה-42 היא אישה מוכת צער, צער שגרם לה להתנכר לחברה. עולמה מתהפך כאשר ילד בן 14 שמטפל במכוניות של אנשים, נקלע לביתה ומדמם."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"La vida de una mujer de 40 años que está pasando un duelo cambia por completo cuando un chico de 14 años aparece en su casa sangrando."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"大教堂广场","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"6 yaşındaki oğlunu korkunç bir kazada kaybeden Alicia, o günden sonra oldukça kederli günler yaşamaya başlar. Eşiyle boşanan genç kadın, yaşadığı plazanın önünde arabalara göz kulak olan 13 yaşındaki bir çocukla tanışır ve zaman geçtikçe aralarında güçlü bir bağ oluşur. Bir gün çocuğu sokakta kanlar içinde bulan Alicia, ona ne kadar değer verdiğini ve yaşama tekrar tutunması için bir sebebinin olduğunu farkeder."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Η ζωή μιας 40χρονης γυναίκας που πενθεί θα αλλάξει εντελώς όταν ένα αιμόφυρτο 14χρονο αγόρι εμφανίζεται στο σπίτι της."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"大教堂廣場","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":4011,"adult":false,"title":"Beetlejuice","video":false,"overview":"A newly dead New England couple seeks help from a deranged demon exorcist to scare an affluent New York family out of their home.","genre_ids":[14,35],"media_type":"movie","popularity":8.3613,"vote_count":8294,"poster_path":"/nnl6OWkyPpuMm595hmAxNW3rZFn.jpg","release_date":"1988-03-30","vote_average":7.367,"backdrop_path":"/yRKyJJYIzfeiVDHBe4LXguPQCvD.jpg","original_title":"Beetlejuice","original_language":"en"},{"id":11324,"adult":false,"title":"Shutter Island","video":false,"overview":"World War II soldier-turned-U.S. Marshal Teddy Daniels investigates the disappearance of a patient from a hospital for the criminally insane, but his efforts are compromised by troubling visions and a mysterious doctor.","genre_ids":[18,53,9648],"media_type":"movie","popularity":14.6244,"vote_count":25460,"poster_path":"/nrmXQ0zcZUL8jFLrakWc90IR8z9.jpg","release_date":"2010-02-14","vote_average":8.2,"backdrop_path":"/8xt8AMb1OKC63AdhNSaYBWxB4Iq.jpg","original_title":"Shutter Island","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":28.4976,"vote_count":26828,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.903,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":264660,"adult":false,"title":"Ex Machina","video":false,"overview":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl.","genre_ids":[18,878],"media_type":"movie","popularity":7.7588,"vote_count":14042,"poster_path":"/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg","release_date":"2015-01-21","vote_average":7.573,"backdrop_path":"/uqOuJ50EtTj7kkDIXP8LCg7G45D.jpg","original_title":"Ex Machina","original_language":"en"},{"id":389,"adult":false,"title":"12 Angry Men","video":false,"overview":"The defense and the prosecution have rested and the jury is filing into the jury room to decide if a young Spanish-American is guilty or innocent of murdering his father. What begins as an open and shut case soon becomes a mini-drama of each of the jurors' prejudices and preconceptions about the trial, the accused, and each other.","genre_ids":[18],"media_type":"movie","popularity":12.4833,"vote_count":9766,"poster_path":"/ow3wq89wM8qd5X7hWKxiRfsFf9C.jpg","release_date":"1957-04-10","vote_average":8.556,"backdrop_path":"/w4bTBXcqXc2TUyS5Fc4h67uWbPn.jpg","original_title":"12 Angry Men","original_language":"en"},{"id":680,"adult":false,"title":"Pulp Fiction","video":false,"overview":"A burger-loving hit man, his philosophical partner, a drug-addled gangster's moll and a washed-up boxer converge in this sprawling, comedic crime caper. Their adventures unfurl in three stories that ingeniously trip back and forth in time.","genre_ids":[53,80,35],"media_type":"movie","popularity":22.3091,"vote_count":29739,"poster_path":"/vQWk5YBFWF4bZaofAbv0tShwBvQ.jpg","release_date":"1994-09-10","vote_average":8.486,"backdrop_path":"/96hiUXEuYsu4tcnvlaY8tEMFM0m.jpg","original_tit