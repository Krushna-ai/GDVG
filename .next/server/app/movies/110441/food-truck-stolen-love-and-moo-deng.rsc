yBsoqPU.jpg","iso_639_1":"th","vote_average":0},{"width":1365,"height":2048,"file_path":"/fsSNZU1ZAuHR01ruUGKqUBiKElx.jpg","iso_639_1":"th","vote_average":0},{"width":1365,"height":2048,"file_path":"/zrrGllLbjE0IZp9I65719aVwbXC.jpg","iso_639_1":"th","vote_average":0},{"width":1365,"height":2048,"file_path":"/vieLiefRgbSxOPCXVVvqzcvTGaI.jpg","iso_639_1":"th","vote_average":0},{"width":1500,"height":2222,"file_path":"/fOhSmHSEm0iVQ2AdG5SkjXnsvUM.jpg","iso_639_1":"en","vote_average":0}],"backdrops":[{"width":3700,"height":2081,"file_path":"/hyl6es0MyJ1tEmziR293GxdIQKZ.jpg","iso_639_1":null,"vote_average":3.334},{"width":3700,"height":2081,"file_path":"/ffs1GAQYA0TtE4SCQItbiOhzS52.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-02-21T13:12:06.522+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"“มะเหมี่ยว” (มาริโอ้ เมาเร่อ) อดีตช่างเสียงในกองถ่าย ที่ปลดระวางมาเป็นอินฟลูเอ็นเซอร์ Live ASMR จำใจต้องร่วมเดินทางกับ “ซารัง” เด็กชายชาวเกาหลี ที่พลัดหลงจากแม่ที่มาถ่ายงานในเมืองไทย เด็กน้อยงอนแม่เลยแอบหนีขึ้นรถ Foodtruck ของ “เจ็ก” ทำเอากองถ่ายวุ่นวายเมื่อลูกชายของลูกค้าหายไป โดยที่ เจ็ก (แจ็ค เฉลิมพล) และ “บ็อบบี้” (แจ๊ส ผดุง) อาร์ตไดเรคเตอร์ที่ติดรถมาด้วย ไม่รู้เลยว่ารถของตัวเองจะนำพา “มะเหมี่ยว” หวนกลับไปหาอดีตอีกครั้ง ระหว่างเส้นทางมุ่งสู่บางแสน มะเหมี่ยว, เจ็ก และ  บ็อบบี้ ต้องเผชิญหน้ากับตำรวจท้องที่เล็ก ๆ ที่ใฝ่ฝันอยากทำคดีใหญ่ ได้ไล่ล่าผู้ร้ายในแบบหนังฮอลลีวู้ด มัคทายกผู้เชิญชวนให้คนมาทำบุญที่วัด เจ้าหน้าที่สวนสัตว์ที่รักสัตว์ที่ตัวเองดูแลดั่งลูกไปจนถึงฮิปโปแคระเซเลบตัวนั้น"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Food Truck: Stolen Love... and Moo Deng","runtime":105,"tagline":"Love is on the menu but every recipe has its secrets.","homepage":"http://www.foodtruckthemovie.com","overview":"Jake and Bobby, with the art director by the truck, don't know their vehicle will force Mamiew to face his past once more."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[{"id":747,"adult":false,"title":"Shaun of the Dead","video":false,"overview":"Shaun lives a supremely uneventful life, which revolves around his girlfriend, his mother, and, above all, his local pub. This gentle routine is threatened when the dead return to life and make strenuous attempts to snack on ordinary Londoners.","genre_ids":[27,35],"popularity":7.3685,"vote_count":9139,"poster_path":"/dgXPhzNJH8HFTBjXPB177yNx6RI.jpg","release_date":"2004-04-09","vote_average":7.539,"backdrop_path":"/wb34q3VgzHgL8frVMywrN3wXmqx.jpg","original_title":"Shaun of the Dead","original_language":"en"},{"id":773,"adult":false,"title":"Little Miss Sunshine","video":false,"overview":"A family loaded with quirky, colorful characters piles into an old van and road trips to California for little Olive to compete in a beauty pageant.","genre_ids":[35,18],"popularity":4.379,"vote_count":7670,"poster_path":"/niNdhTpPHSgw22tK0PLjQMV640v.jpg","release_date":"2006-07-26","vote_average":7.69,"backdrop_path":"/fs6p6TfZgblhmTk0hCeEINdeCAl.jpg","original_title":"Little Miss Sunshine","original_language":"en"},{"id":764838,"adult":false,"title":"Niagara","video":false,"overview":"A comedy drama about the fall, mourning and rebuilding of oneself around three brothers in their fifties who will have to reconnect after the death of their father who died prematurely from an unfortunate Ice Bucket Challenge.","genre_ids":[18,35],"popularity":0.2055,"vote_count":4,"poster_path":"/vw2sU6haK17yEv2LkyNUi4xfNNf.jpg","release_date":"2022-09-16","vote_average":6.2,"backdrop_path":"/fbPGNA9BRt2NGoPHVavjnsXdVDt.jpg","original_title":"Niagara","original_language":"fr"},{"id":1989,"adult":false,"title":"My Blueberry Nights","video":false,"overview":"Elizabeth has just been through a particularly nasty breakup, and now she's ready to leave her friends and memories behind as she chases her dreams across the country. In order to support herself on her journey, Elizabeth picks up a series of waitress jobs along the way. As Elizabeth crosses paths with a series of lost souls whose yearnings are even greater than her own, their emotional turmoil ultimately helps her gain a greater understanding of her own problems...","genre_ids":[18,10749],"popularity":1.6605,"vote_count":829,"poster_path":"/w9w3m2IB9QRZXxi6R51ZamKv3HS.jpg","release_date":"2007-11-28","vote_average":6.405,"backdrop_path":"/tj8T9OIM0E51Jf61RJbRbG6vnIJ.jpg","original_title":"藍莓之夜","original_language":"cn"},{"id":249703,"adult":false,"title":"Do I Have to Take Care of Everything?","video":false,"overview":"A comedy about a chaotic morning in a family with kids, and a mother who is determined that it's best to take care of everything herself.","genre_ids":[35,18,10751],"popularity":0.1842,"vote_count":20,"poster_path":"/v7iFf1ibLZvNbNB0tY2SdRdkj3O.jpg","release_date":"2012-02-17","vote_average":6.1,"backdrop_path":"/2cw4SYZF0E4HIV9ZfOMjmwDKGqV.jpg","original_title":"Pitääkö mun kaikki hoitaa?","original_language":"fi"},{"id":920,"adult":false,"title":"Cars","video":false,"overview":"Lightning McQueen, a hotshot rookie race car driven to succeed, discovers that life is about the journey, not the finish line, when he finds himself unexpectedly detoured in the sleepy Route 66 town of Radiator Springs. On route across the country to the big Piston Cup Championship in California to compete against two seasoned pros, McQueen gets to know the town's offbeat characters.","genre_ids":[16,12,35,10751],"popularity":9.3041,"vote_count":14884,"poster_path":"/2Touk3m5gzsqr1VsvxypdyHY5ci.jpg","release_date":"2006-06-08","vote_average":7.021,"backdrop_path":"/sd4xN5xi8tKRPrJOWwNiZEile7f.jpg","original_title":"Cars","original_language":"en"},{"id":2123,"adult":false,"title":"Me, Myself & Irene","video":false,"overview":"Rhode Island State Trooper Charlie Baileygates has a multiple personality disorder. One personality is crazy and aggressive, while the other is more friendly and laid back. Both of these personalities fall in love with the same woman named Irene after Charlie loses his medication.","genre_ids":[35],"popularity":4.8853,"vote_count":4150,"poster_path":"/rvRrcbLbpn7UJGRH1JupgHOeJFq.jpg","release_date":"2000-06-22","vote_average":6.609,"backdrop_path":"/8qLen3NLCVSu1I9aqGWbTUIoBLQ.jpg","original_title":"Me, Myself & Irene","original_language":"en"},{"id":862,"adult":false,"title":"Toy Story","video":false,"overview":"Led by Woody, Andy's toys live happily in his room until Andy's birthday brings Buzz Lightyear onto the scene. Afraid of losing his place in Andy's heart, Woody plots against Buzz. But when circumstances separate Buzz and Woody from their owner, the duo eventually learns to put aside their differences.","genre_ids":[10751,35,16,12],"popularity":18.8109,"vote_count":19557,"poster_path":"/uXDfjJbdP4ijW5hWSBrPrlKpxab.jpg","release_date":"1995-11-22","vote_average":7.971,"backdrop_path":"/bSoOThXLrbgtphS2eZjwy2xYwVt.jpg","original_title":"Toy Story","original_language":"en"},{"id":525,"adult":false,"title":"The Blues Brothers","video":false,"overview":"Jake Blues, just released from prison, puts his old band back together to save the Catholic home where he and his brother Elwood were raised.","genre_ids":[10402,35,28,80],"popularity":4.4067,"vote_count":4490,"poster_path":"/rhYJKOt6UrQq7JQgLyQcSWW5R86.jpg","release_date":"1980-06-16","vote_average":7.719,"backdrop_path":"/bk2fTuIhQIvdAA3RbnrnvLvuaTc.jpg","original_title":"The Blues Brothers","original_language":"en"},{"id":276,"adult":false,"title":"The Edukators","video":false,"overview":"Three activists cobble together a kidnapping plot after they encounter a businessman in his home.","genre_ids":[18,35],"popularity":1.1312,"vote_count":371,"poster_path":"/jpiXFtvBYemLbAktLPNx5xDGvJn.jpg","release_date":"2004-10-25","vote_average":7.155,"backdrop_path":"/whgmJ6vRE7o8zszh60kicT1vVSy.jpg","original_title":"Die fetten Jahre sind vorbei","original_language":"de"},{"id":339,"adult":false,"title":"Night on Earth","video":false,"overview":"A quintet of cabbies in five cities and their remarkable fares on the same eventful night.","genre_ids":[35,18],"popularity":1.5888,"vote_count":1014,"poster_path":"/ktejUHCo6c8DekpOtR3uSb6oDXr.jpg","release_date":"1991-12-12","vote_average":7.5,"backdrop_path":"/s7lwxcX5iZuOdoQhM77WyQaPtWv.jpg","original_title":"Night on Earth","original_language":"en"},{"id":15789,"adult":false,"title":"A Goofy Movie","video":false,"overview":"Goofy’s teenage son Max is desperate to impress his crush and fit in at school. After well-meaning but ignorant Goofy suddenly whisks him away on a cross-country road trip—messing up Max’s first date plans in the process—Goofy’s old-school parenting and Max’s desire for independence lead to a vacation of hilarious mishaps, as they both learn to understand and listen to eachother.","genre_ids":[12,35,10749,16,10751],"popularity":2.5903,"vote_count":1878,"poster_path":"/bycmMhO3iIoEDzP768sUjq2RV4T.jpg","release_date":"1995-04-05","vote_average":7.021,"backdrop_path":"/Sb2cLe2xW5OATkZZJBbGrB6qjl.jpg","original_title":"A Goofy Movie","original_language":"en"},{"id":17711,"adult":false,"title":"The Adventures of Rocky & Bullwinkle","video":false,"overview":"Rocky and Bullwinkle have been living off the finances made from the reruns of their cartoon show. Boris and Natasha somehow manage to crossover into reality and team up with Fearless Leader, an evil criminal turned media mogul with some evil plans up his sleeve. Rocky and Bullwinkle must stop the three of them before they wreak havoc.","genre_ids":[10751,12,16,35,14],"popularity":1.1865,"vote_count":388,"poster_path":"/xCFSsftt2rglC81I6QLWcZSTCBM.jpg","release_date":"2000-06-30","vote_average":4.267,"backdrop_path":"/9K1y8HCokYpuU92jKauiFwu0y7P.jpg","original_title":"The Adventures of Rocky & Bullwinkle","original_language":"en"},{"id":17728,"adult":false,"title":"Wieners","video":false,"overview":"A road trip comedy about three friends who travel across the country in a Wiener Wagon to beat up a popular daytime talk show therapist.","genre_ids":[35],"popularity":0.4707,"vote_count":66,"poster_path":"/bEvjo0S31AproMQ0jA4EqpXj0RK.jpg","release_date":"2008-06-03","vote_average":4.4,"backdrop_path":"/Ge8qhLW6RaBRMcYgNcTNQYKyHs.jpg","original_title":"Wieners","original_language":"en"},{"id":15673,"adult":false,"title":"Connie and Carla","video":false,"overview":"After accidentally witnessing a mafia hit in the Windy City, gal pals Connie and Carla skip town for L.A., where they go way undercover as singers working the city's dinner theater circuit ... disguised as drag queens. Now, it's not enough that they become big hits on the scene; things get extra-weird when Connie meets Jeff -- a guy she'd like to be a woman with.","genre_ids":[35,80,10402],"popularity":0.9432,"vote_count":92,"poster_path":"/mR0K8S5s2c5uxpcevnVam17HFrh.jpg","release_date":"2004-04-16","vote_average":5.8,"backdrop_path":"/co2HWhWxNvyWWRLEpudY659gqK3.jpg","original_title":"Connie and Carla","original_language":"en"},{"id":18269,"adult":false,"title":"Lady and the Tramp II: Scamp's Adventure","video":false,"overview":"Lady and Tramp's mischievous pup, Scamp, gets fed up with rules and restrictions imposed on him by life in a family, and longs for a wild and free lifestyle. He runs away from home and into the streets where he joins a pack of stray dogs known as the \"Junkyard Dogs.\" Buster, the pack's leader, takes an instant disliking to the \"house-dog\" and considers him a rival. Angel, a junkyard pup Scamp's age, longs for the safety and comfort of life in a family and the two become instant companions. Will Scamp choose the wild and free life of a stray or the unconditional love of his family?","genre_ids":[16,10751,10749,12],"popularity":2.6776,"vote_count":1303,"poster_path":"/nS3nhUZUSY8dWEsRmKILfiOC3F0.jpg","release_date":"2001-02-18","vote_average":6.35,"backdrop_path":"/rPIVGon9dNpgMvlGKqG2tvIG8vo.jpg","original_title":"Lady and the Tramp II: Scamp's Adventure","original_language":"en"},{"id":266364,"adult":false,"title":"4 Kings","video":false,"overview":"Zien is a conman who makes and sells fake Buddhist amulets. His nephew Riang is a chip off the old block, with many generations of gamblers' blood running through his veins.","genre_ids":[35],"popularity":0.1724,"vote_count":1,"poster_path":"/kmkfQMfjzRbvksBdhfXCwHPiECc.jpg","release_date":"2014-01-30","vote_average":6,"backdrop_path":"/6PeaPyHVtyuxyN6pum4Si2u0xbS.jpg","original_title":"สีเรียงเซียนโต๊ด","original_language":"th"},{"id":964911,"adult":false,"title":"Wes Is Dying","video":false,"overview":"An irreverent and eccentric road trip comedy that celebrates DIY filmmaking and bromances, Wes Schlagenhauf Is Dying follows two filmmakers who set out to make their masterpiece while on a journey toward an estranged, purportedly languishing friend.","genre_ids":[35],"popularity":0.1165,"vote_count":0,"poster_path":"/k0sg1kBgaOMw1B8PVSDlpBaa7FH.jpg","release_date":"2022-06-09","vote_average":0,"backdrop_path":"/bTGRTpfJTFqUDhv30UgtshhwmQC.jpg","original_title":"Wes Is Dying","original_language":"en"},{"id":19405,"adult":false,"title":"Recess: School's Out","video":false,"overview":"The school year is finally ending, and T.J. Detweiler is looking forward to summer. But boredom quickly sets in when his friends leave for camp — until T.J. uncovers an evil plot to do away with summer vacation! A crazy former principal, Dr. Benedict, is planning to use a laser beam to alter the weather and create permanent winter. Faced with the dire threat of year-round school, T.J. rounds up the RECESS gang and bands together with some unexpected allies — Miss Finster and Principal Prickly — in a nonstop adventure to save everyone's summer break. As the kids discover the heroes inside themselves, a platoon of wacky characters, far-out music, and sci-fi surprises turn this madcap mission into a major victory for fun!","genre_ids":[10751,16,35],"popularity":1.6982,"vote_count":362,"poster_path":"/qsUCoeTwCNIrvDrUiWlTCgyRFZy.jpg","release_date":"2001-02-16","vote_average":6.6,"backdrop_path":"/v69OaHOYjdihRz0o0nVUylUyraa.jpg","original_title":"Recess: School's Out","original_language":"en"},{"id":19423,"adult":false,"title":"Going the Distance","video":false,"overview":"Nick is a successful young man whose comfortable West Coast life couldn't be better. However, when his girlfriend falls under the influence of lecherous music producer Lenny Swackhammer, Nick impulsively decides to travel to Toronto to intervene. Nick's buddies Tyler and Dime  opt to turn the quest into a cross-country road trip that's complete with wacky antics and encounters with beautiful women.","genre_ids":[35,10749],"popularity":1.0929,"vote_count":81,"poster_path":"/shmF571Ph6U5E03ahuuzOPi6rl9.jpg","release_date":"2004-08-20","vote_average":5.512,"backdrop_path":"/fFE4JwHNbzNGRBcvEciblTDigxF.jpg","original_title":"Going the Distance","original_language":"en"}],"external_ids":{"imdb_id":"tt38079900","twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":110441,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"TH","release_dates":[{"note":"","type":1,"iso_639_1":"th","descriptors":[],"release_date":"2025-08-25T00:00:00.000Z","certification":""},{"note":"","type":3,"iso_639_1":"th","descriptors":[],"release_date":"2025-08-28T00:00:00.000Z","certification":"13"}]},{"iso_3166_1":"US","release_dates":[{"note":"The Culver Theater","type":2,"iso_639_1":"","descriptors":[],"release_date":"2026-01-14T00:00:00.000Z","certification":""}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on