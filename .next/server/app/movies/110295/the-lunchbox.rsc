9:{"metadata":[["$","title","0",{"children":"The Lunchbox | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"A mistaken delivery in Mumbai's famously efficient lunchbox delivery system (Mumbai's Dabbawallahs) connects a young housewife to a stranger in the dusk of his life. They build a fantasy world together through notes in the lunchbox. Gradually, this fantasy threatens to overwhelm their reality."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/110295/the-lunchbox"}],["$","meta","5",{"property":"og:title","content":"The Lunchbox"}],["$","meta","6",{"property":"og:description","content":"A mistaken delivery in Mumbai's famously efficient lunchbox delivery system (Mumbai's Dabbawallahs) connects a young housewife to a stranger in the dusk of his life. They build a fantasy world together through notes in the lunchbox. Gradually, this fantasy threatens to overwhelm their reality."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/110295/the-lunchbox"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/jSOiz1h97i3qwjZJXY8SeLvjPsl.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"The Lunchbox"}],["$","meta","12",{"name":"twitter:description","content":"A mistaken delivery in Mumbai's famously efficient lunchbox delivery system (Mumbai's Dabbawallahs) connects a young housewife to a stranger in the dusk of his life. They build a fantasy world together through notes in the lunchbox. Gradually, this fantasy threatens to overwhelm their reality."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w5