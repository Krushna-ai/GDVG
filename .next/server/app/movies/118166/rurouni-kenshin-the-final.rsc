3-the-final/watch?locale=TW","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"TZ":{"link":"https://www.themoviedb.org/movie/602063-the-final/watch?locale=TZ","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"UA":{"link":"https://www.themoviedb.org/movie/602063-the-final/watch?locale=UA","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"UG":{"link":"https://www.themoviedb.org/movie/602063-the-final/watch?locale=UG","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"US":{"link":"https://www.themoviedb.org/movie/602063-the-final/watch?locale=US","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":2},{"logo_path":"/dpR8r13zWDeUR0QkzWidrdMxa56.jpg","provider_id":1796,"provider_name":"Netflix Standard with Ads","display_priority":154}]},"UY":{"link":"https://www.themoviedb.org/movie/602063-the-final/watch?locale=UY","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"VE":{"link":"https://www.themoviedb.org/movie/602063-the-final/watch?locale=VE","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"YE":{"link":"https://www.themoviedb.org/movie/602063-the-final/watch?locale=YE","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZA":{"link":"https://www.themoviedb.org/movie/602063-the-final/watch?locale=ZA","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZM":{"link":"https://www.themoviedb.org/movie/602063-the-final/watch?locale=ZM","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZW":{"link":"https://www.themoviedb.org/movie/602063-the-final/watch?locale=ZW","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":4}]}}},"wikidata_id":"Q103820244","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-21T21:59:58.334388+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":[{"data":{"title":"Rurouni Kenshin: The Final","runtime":138,"tagline":"The Future Starts Here","homepage":"http://rurouni-kenshin.jp","overview":"In 1879, Kenshin and his allies face their strongest enemy yet: his former brother-in-law Enishi Yukishiro and his minions, who've vowed their revenge."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Kenshin : L’Achèvement","runtime":138,"tagline":"L'ennemi final connaît son mystère","homepage":"","overview":"En 1879, Kenshin se bat avec ses alliés contre son plus grand ennemi : son ancien beau-frère Enishi Yukishiro, entouré de ses sbires qui ont juré de se venger."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"浪客剑心最终章：人诛篇","runtime":0,"tagline":"","homepage":"","overview":"电影系列里最可怕的敌人雪代缘在本片现身。他对东京发动大规模攻击，意在报复剑心。参与《神剑闯江湖》前几部电影的王牌演员阵容再度聚首，替剑心扛下这最后一战，同时迈向崭新的终极高峰：《The Final》。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Rurouni Kenshin - The Final","runtime":0,"tagline":"","homepage":"","overview":"Enishi, il cognato di Kenshin, vuole ancora vendicare la morte di sua sorella avvenuta 15 anni prima per mano del samurai vagabondo che però ha già fatto ammenda per il terribile atto. Ma Enishi è pronto a tutto ed è accecato dalla vendetta anche a sacrificare la propria umanità!"},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Samurai X: O Final","runtime":139,"tagline":"O futuro começa aqui","homepage":"https://www.netflix.com/br/title/81313227","overview":"Em 1879, Kenshin e seus aliados enfrentam o inimigo mais forte de todos: seu ex-cunhado Enishi Yukishiro e seus subordinados, que juraram vingança."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Rurouni Kenshin: The Final - Part 4","runtime":79,"tagline":"Ostatni wróg zna sekret blizny.","homepage":"","overview":"W roku 1879 Kenshin musi zmierzyć się z wrogiem silniejszym niż wszyscy poprzedni. To jego pałający żądzą zemsty były szwagier — Enishi Yukishiro."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Samurái X: El fin","runtime":0,"tagline":"","homepage":"","overview":"En 1879, Kenshin y sus aliados se enfrentan a los enemigos más poderosos que jamás hayan conocido: su excuñado Enishi Yukishiro y sus secuaces, que juraron venganza."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"바람의 검심 최종장: 더 파이널","runtime":0,"tagline":"","homepage":"","overview":"그놈의 빰에 아직 십자 흉터가 있는가? 켄신의 과거를 알고 있는 남자, 에니시. 한때는 가족이었던 그가 사상 최강의 적이 되어 켄신 앞에 서고, 드디어 마지막 전투의 서막이 오른다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"รูโรนิ เคนชิน ซามูไรพเนจร ปัจฉิมบท","runtime":0,"tagline":"","homepage":"","overview":"ปี 1879 เคนชินและพวกพ้องเผชิญหน้ากับยูกิชิโระ เอนิชิ ศัตรูที่แข็งแกร่งที่สุดซึ่งเป็นน้องชายอดีตภรรยาของเคนชิน พร้อมกับลิ่วล้อที่ตั้งตาล้างแค้นอย่างไม่ปรานี"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"神劍闖江湖︰The Final","runtime":0,"tagline":"","homepage":"","overview":"1879 年，劍心與夥伴們面對前所未見的強敵：劍心的前小舅子雪代緣，以及他那誓言復仇的一群手下。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Rurouni Kenshin: Το Τέλος","runtime":0,"tagline":"","homepage":"","overview":"Το 1879, ο Κένσιν και οι σύμμαχοί του έρχονται αντιμέτωποι με τον ισχυρότερο εχθρό τους: τον πρώην κουνιάδο του, Ενίσι Γιουκίσιρο, και τους φιλέκδικους ακόλουθούς του."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Rurouni Kenshin: The Final","runtime":0,"tagline":"","homepage":"","overview":"Der legendäre Schwertkämpfer Kenshin Himura, hat nach der Meiji-Restauration aufgehört, mit dem Schwert zu töten. Er versucht ein friedliches Leben mit Kaoru Kamiya zu führen, die im Dorf eine Schwertkampfschule betreibt. Doch dieses nimmt ein jähes Ende, als sein Lieblingsrestaurant Akabeko zerstört wird. Kenshin Himura findet dort eine Notiz mit der Aufschrift „Jinchū“, die Unheil verspricht."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Kenshin, el guerrero samurái: El final","runtime":139,"tagline":"Kenshin, el guerrero samurái: El final","homepage":"","overview":"Kenshin Himura (Takeru Satoh) es un legendario espadachín. Tras la Restauración Meiji, ha dejado de matar con la espada. Intenta llevar una vida tranquila con Kaoru Kamiya que dirige una escuela de espadachines en el pueblo. Todo cambia cuando el restaurante Akabeko, que es el lugar favorito de Kenshin para comer, es destruido y él encuentra una nota en la que pone \"Junchu\"."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Lãng Khách Kenshin: Hồi Kết","runtime":0,"tagline":"","homepage":"","overview":"Năm 1879, Kenshin và các đồng minh đối mặt với kẻ thù mạnh nhất từ trước đến nay: kẻ từng là em vợ anh, Enishi Yukishiro, và đám tay sai quyết trả thù của hắn."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Rurouni Kenshin: A vég","runtime":138,"tagline":"","homepage":"","overview":"1879-ben Kenshin és szövetségesei eddigi legerősebb ellenségükkel néznek szembe: korábbi sógorával, Enishi Yukishiróval és csatlósaival, akik bosszút esküdtek ellenük."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Kenshin Himura is een legendarische zwaardvechter. Hij is gestopt met het doden door middel van het zwaard. Hij probeert een vredig leven te leiden met Kaoru Kamiya die in het dorp een zwaardvechtersschool runt. Maar de zaken veranderen als het Akabeko restaurant, waar Kenshin Himura het liefst gaat eten, wordt verwoest. Kenshin Himura vindt daar een briefje waarop geschreven staat \"Junchu\"."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"רורואוני קנשין: סוף דבר","runtime":0,"tagline":"","homepage":"","overview":"ב-1879, קנשין ובני בריתו ניצבים בפני האויב האכזרי ביותר שפגשו עד כה: אנישי יוקישירו, גיסו של קנשין, וחייליו חדורי הנקמה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Бродяга Кэнсин: Финал","runtime":138,"tagline":"","homepage":"","overview":"Химура Кэнсин - легендарный мечник, который после реставрации Мэйдзи перестал убивать. Он пытается жить мирной жизнью с Камия Каору, которая управляет школой фехтования. Всё меняется. Ресторан Акабеко, любимое место Кэнсина, разрушен. Он находит там записку с надписью «Джунчу»."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Мандрівний Кеншін. Кінець","runtime":138,"tagline":"","homepage":"","overview":"У 1879 р. Кеншін із союзниками протистоїть найсильнішому ворогу — його колишньому швагрові Еніші Юкішіро, який поклявся помститися за смерть сестри, і його прислужникам."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"浪客劍心 最終章 The Final","runtime":0,"tagline":"","homepage":"","overview":"1879 年，劍心與夥伴們面對前所未見的強敵：劍心的前小舅子雪代緣，以及他那誓言復仇的一羣手下。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"るろうに剣心 最終章 The Final","runtime":0,"tagline":"未来はここから始まるー","homepage":"","overview":"「剣心にとって最も大事なエピソード。これをやらずに、るろうに剣心は終われない」と覚悟を決めた製作陣が挑んだファン待望の最終章！ 剣心に復讐するため、東京を総攻撃するシリーズ最恐の敵・縁。 これまでのるろ剣オールスターが集結し、剣心のため、新時代のため、最後の戦いへ挑む究極のクライマックス「The Final」。 さらに、戦いの理由は幕末へと遡り、剣心の頬に刻まれた〈十字傷の謎〉に迫る「The Beginning」へと続いていく。「The Final」で明かされる、剣心が斬殺した妻・巴の存在。 剣心はなぜ〈不殺の誓い〉を立てたのか？そして剣心はなぜ妻を斬殺しなければならなかったのか？"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Potulný samuraj Kenšin: Konec","runtime":139,"tagline":"","homepage":"","overview":"V roce 1879 se Kenšin a jeho spojenci musí postavit zatím nejmocnějšímu nepříteli: Kenšinovu bývalému švagrovi Enišimu Jukiširovi a jeho poskokům, kteří přísahali pomstu."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Rurouni Kenshin: Final","runtime":0,"tagline":"","homepage":"","overview":"Kenshin Himura; nam-ı diğer Battousai, efsanevi bir kılıç ustasıdır. Meiji Restorasyonu'ndan sonra kılıçla öldürmeyi bırakmıştır. Köyde, kılıç ustalığı okulu işleten Kaoru Kamiya ile huzurlu bir hayat yaşamaya çalışmaktadır. Bir gün ustamızın en sevdiği yemek mekanı olan Akabeko Restaurant yıkılır. Kenshin Himura orada \"Junchu\" yazılı bir not bulur. Son düşmanı intikam ateşiyle yanan tanıdık biridir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Klajoklis Kenšinas: Paskutinis skyrius I dalis","runtime":0,"tagline":"","homepage":"","overview":"Kenšino praeitis jį užklumpa ir tampa užeigos „Akabeko“ sunaikinimo priežastimi, kuri buvo mėgstamiausia Kenšino valgymo vieta. Ten jis randa raštelį su ant jo parašytu žodžiu „Junchu“."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Kenshin: O Samurai Errante: O Final","runtime":139,"tagline":"","homepage":"https://www.netflix.com/pt/title/81313227","overview":"Em 1879, Kenshin e os seus aliados enfrentam o seu mais difícil desafio até à data: a vingança de Enishi Yukishiro, o seu antigo cunhado, e os sequazes dele."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Kenshin Rătăcitorul: Sfârşitul","runtime":139,"tagline":"","homepage":"","overview":"Ajutat de aliați, Kenshin își înfruntă în 1879 cel mai puternic vrăjmaș: fostul cumnat, Enishi Yukishiro, care a jurat răzbunare laolaltă cu acoliții săi."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"နာမည်ကြီး Rurouni Kenshi series ကိုအခြေခံပြီး နောက်ဆုံးထွက်ရှိလာတဲ့ နာမည်ကြီးလူသတ်သမားဘတ်တိုဆိုင်းရဲ့ live action ဇာတ်ကားကိုတင်ဆက်ပေးလိုက်ပါတယ် The Final နဲ့ The beginning ဆိုပြီးထွက်ရှိမှာပါ အခုကတော့ The Finalက Netflix မှာအရင်ထွက်လာပါပြီဒီကားမှာတော့ Kenshinတစ်ယောက် လူမသတ်တော့ဘူးလို့လည်းသစ္စာဆိုထားပြီး ဘဝကိုအေးအေးဆေးဆေးဖြတ်သန်းနေခဲ့ပါတယ် ဒါပေမယ့် အတိတ်မှာ သူ့ဇနီးကိုသတ်မိခဲ့တဲ့ Kenshinတစ်ယောက် လက်စားချေမှုတွေ အပြစ်ကြွေးတွေကို ဒီဇာတ်ကားမှာ ဘယ်လိုကြုံတွေ့ရမလဲ ကြည့်ရမှာပါ သူ့ကိုလက်စားလာချေမယ်လူကရော ဘယ်သူဖြစ်မလဲဆိုတော့ အားလုံးပဲ ခန့်မှန်းမိကြမယ်ထင်ပါတယ် ဘာတွေဆက်ဖြစ်မလဲကတော့ ဇာတ်ကားထဲမှာဆက်ကြည့်ပြီး အားပေးကြပါဦးနော်"},"name":"","iso_639_1":"my","iso_3166_1":"MY","english_name":"Burmese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"1879 möter Kenshin och hans allierade sin starkaste fiende hittills: hans före detta svåger Enishi Yukishiro och hans undersåtar, som har lovat att hämnas."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Скитникът Кеншин: Финалът","runtime":0,"tagline":"","homepage":"","overview":"Химура Кеншин (Такеру Сато) е легендарен мечоносец. След настъпването на епохата Мейджи той спира да убива и живее спокоен живот с Камия Каору (Еми Такей), която ръководи кендо училище. Но нещата се променят. когато \"Акабеко\", любимото място за хранене на Кеншин, е унищожено и единственото нещо, което е оставено там, е бележка с надпис \"Човекът съди\"."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Potulný samuraj Kenšin: Koniec","runtime":0,"tagline":"Budúcnosť začína tu","homepage":"","overview":"V roku 1879 sa Kenšin a jeho spojenci musia postaviť zatiaľ najmocnejšiemu nepriateľovi: Kenšinovmu bývalému švagrovi Enišimu Jukiširovi a jeho poskokom, ktorí prisahali pomstu."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Rurouni Kenshin: The Final","runtime":138,"tagline":"","homepage":"http://rurouni-kenshin.jp","overview":"Kenshin Himura (Takeru Satoh) adalah seorang pendekar pedang legendaris. Setelah Restorasi Meiji, ia berhenti membunuh dengan pedang. Ia mencoba menjalani hidup damai bersama Kaoru Kamiya, yang mengelola sekolah ilmu pedang di desa. Keadaan berubah. Restoran Akabeko, tempat makan favorit Kenshin Himura, hancur. Kenshin Himura menemukan catatan bertuliskan \"Junchu\" di sana."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"}],"reviews_tmdb":[{"id":"68db81e5ee45dbe7c1530fd3","url":"https://www.themoviedb.org/review/68db81e5ee45dbe7c1530fd3","author":"Alunauwie","content":"Rurouni Kenshin: The Final blends emotional storytelling with exhilarating action, diving into Kenshin’s unresolved past through a well-developed new villain. Strong performances—especially from Takeru Satoh and Mackenyu—enhance the film’s depth, making it a powerful continuation of the beloved saga.\r\n\r\nRead the full review here: (Indonesian version : alunauwie.com) and  (English version : uwiepuspita.com)","created_at":"2025-09-30T07:08:21.378Z","updated_at":"2025-09-30T07:08:21.444Z","author_details":{"name":"","rating":10,"username":"Alunauwie","avatar_path":null}}],"recommendations":[{"id":672322,"adult":false,"title":"Rurouni Kenshin: The Beginning","video":false,"overview":"Before he was a protector, Kenshin was a fearsome assassin known as Battosai. But when he meets gentle Tomoe Yukishiro, a beautiful young woman who carries a huge burden in her heart, his life will change forever.","genre_ids":[28,12,18,10749],"media_type":"movie","popularity":3.6138,"vote_count":527,"poster_path":"/rODS466qSdrwMlGdbUwPENhDN2c.jpg","release_date":"2021-06-04","vote_average":7.655,"backdrop_path":"/iGmfHHa3CSqKrH3yeS9CQVLAVUl.jpg","original_title":"るろうに剣心 最終章 The Beginning","original_language":"ja"},{"id":221732,"adult":false,"title":"Rurouni Kenshin Part III: The Legend Ends","video":false,"overview":"Shishio sets sail in his ironclad ship to bring down the government. In order to stop him, Kenshin trains with his old master to learn his final technique.","genre_ids":[28,12,14],"media_type":"movie","popularity":2.2924,"vote_count":550,"poster_path":"/3sw2YRF0UR4jeZJ2yvpgk4qvMQK.jpg","release_date":"2014-09-13","vote_average":7.7,"backdrop_path":"/4UXfZjqt0C5kHTROotrsnfDYCh.jpg","original_title":"るろうに剣心　伝説の最期編","original_language":"ja"},{"id":127533,"adult":false,"title":"Rurouni Kenshin Part I: Origins","video":false,"overview":"In 1868, after the Bakumatsu war ends, the ex-assassin Kenshin Himura traverses Japan with an inverted sword, to defend the needy without killing.","genre_ids":[12,28,14,10752,36],"media_type":"movie","popularity":2.8098,"vote_count":883,"poster_path":"/vo3Zs07PZfKNsTrU0pcPZONJcN5.jpg","release_date":"2012-08-25","vote_average":7.5,"backdrop_path":"/2bHoj05gR7I5gp4oeoDCY6bU42d.jpg","original_title":"るろうに剣心","original_language":"ja"},{"id":12277,"adult":false,"title":"Undercover Brother","video":false,"overview":"An Afro-American organization, the B.R.O.T.H.E.R.H.O.O.D., is in permanent fight against a white organization \"The Man\" defending the values of the black people in North America. When the Afro-American candidate Gen. Warren Boutwell behaves strangely in his presidential campaign, Undercover Brother is hired to work undercover for \"The Man\" and find what happened with the potential candidate.","genre_ids":[28,35],"media_type":"movie","popularity":3.6712,"vote_count":415,"poster_path":"/vkPm29sqtEjoekOhXbqxTcgpJ4y.jpg","release_date":"2002-05-31","vote_average":5.876,"backdrop_path":"/sxoz5X2wlLrQtY7hSTe1sEnLKfc.jpg","original_title":"Undercover Brother","original_language":"en"},{"id":1064517,"adult":false,"title":"Fist of the Condor","video":false,"overview":"Upon the empire’s fall to invading conquistadors, the 16th-century Incas quickly concealed a sacred manual containing the secrets behind their deadly fighting technique. But after centuries of careful safeguarding, the manual is again at risk of falling into the wrong hands, leaving its rightful guardian to battle the world’s greatest assassins to protect the ancient secrets within.","genre_ids":[28],"media_type":"movie","popularity":0.8133,"vote_count":78,"poster_path":"/odpaGY2lG32NG4GL2PuGPt7UUTy.jpg","release_date":"2023-04-04","vote_average":7.2,"backdrop_path":"/yY9ltYgq1SGXJiYziUqzfENTq4K.jpg","original_title":"El puño del cóndor","original_language":"es"},{"id":390930,"adult":false,"title":"If Cats Disappeared from the World","video":false,"overview":"A postman learns that he doesn't have much time left to live due to a terminal illness. A devil then appears in front of him and offers to extend his life if he picks something in the world that will disappear. The man thinks about his relationships with ex-friends, ex-lovers, relatives and colleagues who will be sincerely sad when he dies.","genre_ids":[18,14],"media_type":"movie","popularity":0.5449,"vote_count":68,"poster_path":"/zADvypcSTAViDW4TbzAOeRapPj3.jpg","release_date":"2016-05-14","vote_average":6.8,"backdrop_path":"/pNDmV7AY84jgw2bMB34DF4aWKdc.jpg","original_title":"世界から猫が消えたなら","original_language":"ja"},{"id":173705,"adult":false,"title":"Female Teacher: In Front of the Students","video":false,"overview":"The lovely Reiko has taken a new teaching job at a creepy old high school.  She is an extremely attractive woman and the young students in her class have fallen for her.  One night, after tennis practice, she is brutally assaulted in the locker room shower by a man with a stocking over his face.  Left on the floor naked and in shock, she discovers a single puzzle piece left behind by the crazed man.  A few days later, a pair of students enact a perverted sexual revenge on Reiko for kicking someone off the tennis team.  Could one of these students be the man who brutalized her in the locker room?  Who owns the strange puzzle piece?  As the mystery unfolds, Reiko must come to terms with her own sexual urges and fate.","genre_ids":[18,9648,27],"media_type":"movie","popularity":1.7559,"vote_count":37,"poster_path":"/ilMXOocCCwPWCcDLLa6M0ga8vWt.jpg","release_date":"1982-04-09","vote_average":6.2,"backdrop_path":"/27FRFe8lu1C1LStWmzwOa87vo98.jpg","original_title":"女教師 生徒の眼の前で","original_language":"ja"},{"id":42230,"adult":false,"title":"The Mighty Peking Man","video":false,"overview":"Word of a monster ape ten stories tall living in the Himalayas reaches fortune hunters in Hong Kong. They travel to India to capture it, but wild animals and quicksand dissuade all but Johnny, an adventurer with a broken heart. He finds the monster and discovers it's been raising a scantily-clad woman, Samantha, since she survived a plane crash years before that killed her parents. In the idyllic jungle, Johnny and Samantha fall in love. Then Johnny asks her to convince \"Utam\" to go to Hong Kong. Lu Tien, an unscrupulous promoter, takes over: Utam is in chains for freak show exhibitions. When Lu Tien assaults Samantha, Utam's protective instincts take over: havoc in Hong Kong.","genre_ids":[28,14,12,27],"media_type":"movie","popularity":0.7722,"vote_count":63,"poster_path":"/89vf9Gzxj50YdqB9X1zwFMxjNrC.jpg","release_date":"1977-08-11","vote_average":5.1,"backdrop_path":"/cV592GNIOkyI1J4fz6jFUuytF9e.jpg","original_title":"猩猩王","original_language":"zh"},{"id":589064,"adult":false,"title":"Kuessipan","video":false,"overview":"Two childhood friends from the same Quebec Innu community begin to realize that they face very different futures.","genre_ids":[18],"media_type":"movie","popularity":0.2113,"vote_count":30,"poster_path":"/r3bbJkJq9wKMT4CW9G8eL8lQbTW.jpg","release_date":"2019-10-04","vote_average":6.5,"backdrop_path":"/6igkfgJoLGft02eHFIqoCJLYVll.jpg","original_title":"Kuessipan","original_language":"fr"},{"id":341443,"adult":false,"title":"Vampire in Love","video":false,"overview":"Kiira seems like an ordinary young girl, who likes to talk with her friends and to dress up. Her ultimate goal is to become the world's best baker, but what differentiates her from others is that she is a vampire. She has never told anyone her secret, including her childhood friend Tetsu, whom she played with everyday and liked as a child. After her parents died when Kiira was only 12-years-old, she had to go live with her relatives and lost contact with Tetsu.  Now, 8 years later, Tetsu appears at the bakery where Kiira is working part-time. Kiira is ecstatic to see her first love again. Soon, they are dating and Kiira dreams of having a family with Tetsu. Kiira also becomes filled with worries because she is vampire.","genre_ids":[18,10749],"media_type":"movie","popularity":0.5868,"vote_count":26,"poster_path":"/kdwqZ5dq06iyfCura3Sb0TM0BFF.jpg","release_date":"2015-04-17","vote_average":6.9,"backdrop_path":"/gtFHXXOcvTBrBwp6tYlg3MtnsBl.jpg","original_title":"恋する・ヴァンパイア","original_language":"ja"},{"id":407777,"adult":false,"title":"Karate Kill","video":false,"overview":"When a mysterious loner and Karate master Kenji's little sister goes missing in Los Angeles, whoever stands in his way of finding her will face the wrath of a lethal KARATE KILL!","genre_ids":[28],"media_type":"movie","popularity":0.6599,"vote_count":34,"poster_path":"/nJ2ybTAMo90frsdaXJl5JqwGSEP.jpg","release_date":"2016-09-03","vote_average":5.029,"backdrop_path":"/xABSsJt7OBxbGGXGQ9CKagDk9Cm.jpg","original_title":"KARATE KILL","original_language":"ja"},{"id":410223,"adult":false,"title":"Teiichi: Battle of Supreme High","video":false,"overview":"Teiichi Akaba is a student at a prestigious private male high school known for producing important politicians and bureaucrats. His dream is to become the prime minster and make his own country. To help achieve his dream, he wants to become elected as his school's student council president. The elected student president receives privileges and a better chance for promotions later in the political & bureaucrat world. A power struggle takes place surrounding the student election.","genre_ids":[35,18],"media_type":"movie","popularity":0.6181,"vote_count":26,"poster_path":"/jJEhedACf9mTssmvekrgKXxgZ0i.jpg","release_date":"2017-04-29","vote_average":6.885,"backdrop_path":"/nlboYsHYsMwgsrKkqA8KS6cr51I.jpg","original_title":"帝一の國","original_language":"ja"},{"id":726657,"adult":false,"title":"Brave: Gunjyou Senki","video":false,"overview":"Students, including Aoi Nishino, take part in class and sports activity at a prestigious high school. Aoi Nishino is a member of the school's archery club. He practices archery studiously and doesn't socialize much with the other students. His childhood friend Haruka Seno is also a member of the archery club, but she worries about Aoi Nishino. One day, thunder strikes the school grounds. After that, the ordinary lives of the students changes drastically. Many samurai descend on the school grounds. It appears that the entire school has traveled back in time to the Sengoku period. Making things worse, they realize that they are in the time right before the Battle of Okehazama takes place.","genre_ids":[28,36,9648,14],"media_type":"movie","popularity":0.5836,"vote_count":13,"poster_path":"/wmQ2ITqePFSHtIcTerBHPtOe98J.jpg","release_date":"2021-03-12","vote_average":6.846,"backdrop_path":"/g9fvWmUK6cuZNawImNTNRuhTBFj.jpg","original_title":"ブレイブ -群青戦記-","original_language":"ja"},{"id":268689,"adult":false,"title":"Wicked Flying Monkeys","video":false,"overview":"Ozzy is an enthusiastic and friendly flying monkey, son of the legendary Goliath, the brave warrior. They serve Evilene - the wicked witch - just as the rest of their kin. But Ozzy is not happy about it and when Evilene's plans put Oz once again in peril, Ozzy reaches out to the Champions of Oz, three great friends (the Lion, the Scarecrow and the Tinman) with incredible qualities that have taken Emerald City to its maximum splendor.","genre_ids":[14,16,12],"media_type":"movie","popularity":0.3507,"vote_count":23,"poster_path":"/6AAl2v9ZTNuUjptVKNOV6jWL4ts.jpg","release_date":"2015-03-26","vote_average":5.7,"backdrop_path":"/9AHoyKsBKaQKIjR60ETU4xBceSI.jpg","original_title":"Wicked Flying Monkeys","original_language":"es"},{"id":520788,"adult":false,"title":"Dystopia","video":false,"overview":"It is the year 2037. Our world is dying, slowly, from a virus that has rendered mankind infertile. Not a single child has been born in 25 years. Governments are now powerless puppets for the biggest corporations and Biocorp, the world's biggest, keeps promising a cure that never comes","genre_ids":[878],"media_type":"movie","popularity":1.4492,"vote_count":57,"poster_path":"/8luuxpom0e0u8q3x4MtvKR0tozA.jpg","release_date":"2018-01-02","vote_average":5.2,"backdrop_path":"/2uAyKQf5nej3TiWUqbanr6Zb9YU.jpg","original_title":"Mad World","original_language":"en"},{"id":150421,"adult":false,"title":"Futari wa Precure Max Heart: The Movie","video":false,"overview":"The Courageous Warriors of the Garden of Hope have summoned Nagisa, Honoka, and Hikari to protect their kingdom from a witch who plans to steal the Diamond Line, which is a set of jewelry the queen of the Garden of Hope wears to a ceremony every year to replenish the water of the kingdom. The witch plans to resurrect the Dark Lord and if she does so, not only will the Garden of Hope be destroyed, but other kingdoms in the galaxies, including the Garden of Rainbows and the Garden of Light.  Source: ANN","genre_ids":[16,14,35,28,12,10751],"media_type":"movie","popularity":0.7064,"vote_count":23,"poster_path":"/tXOicosGwKr8MVGIzuAVw5bgspQ.jpg","release_date":"2005-04-16","vote_average":5.9,"backdrop_path":"/uZ75qknyruQ7QlLEKTxQxax0btY.jpg","original_title":"映画 ふたりはプリキュア Max Heart","original_language":"ja"},{"id":31600,"adult":false,"title":"Target","video":false,"overview":"A Texan with a secret past searches Europe with his son after the KGB kidnaps his wife.","genre_ids":[28,53],"media_type":"movie","popularity":0.8964,"vote_count":113,"poster_path":"/2yL873UZkBHOrrt709rDeAm2Fba.jpg","release_date":"1985-11-08","vote_average":5.898,"backdrop_path":"/qUnqakZT80gjcspVeC7K2EQ8hfO.jpg","original_title":"Target","original_language":"en"},{"id":645440,"adult":false,"title":"Revue Starlight: The Movie","video":false,"overview":"The stage emulates life and compresses it, setting free skills learned over lifetimes in brief but dazzling displays for the amusement and judgment of others. For the performers, it is the ultimate risk, and some will rise while others must fall. Nowhere is this truer than at the Seisho Music Academy, where music, dance and real weapons all come into play in the creation of the next great Star. Karen and Hikari’s destinies have been linked since a childhood promise, but their journeys here have taken very different paths. Now, after Hikari leaves, Karen must discover who she is without her opposite, while Hikari must rediscover her own course. Nor are they the only girls who must reassess and change if they want to achieve their dreams, as the dance, magic, and swordplay continue!","genre_ids":[16,18,14,28,10402],"media_type":"movie","popularity":1.3628,"vote_count":33,"poster_path":"/fQS5v2gglHPfx4BLjPhkuBqSntm.jpg","release_date":"2021-06-04","vote_average":8.3,"backdrop_path":"/83Ll67qs3LvexBRSO4lqzJPjsO6.jpg","original_title":"劇場版 少女☆歌劇 レヴュースタァライト","original_language":"ja"},{"id":865208,"adult":false,"title":"4 Mysterious Stories","video":false,"overview":"A four-piece omnibus-style special drama produced by the production staff of \"The Really Scary Story\" and the JRA Japan Racing Association. 6 people gather at a coffee shop on a winter day. While having fun conversations as usual, they begin to talk about mysterious events that they have recently experienced.","genre_ids":[9648],"media_type":"movie","popularity":0.4047,"vote_count":2,"poster_path":"/3jLAvgiNF5LNZRX2HQEvFfOBLwO.jpg","release_date":"2020-12-26","vote_average":6.5,"backdrop_path":"/h412DYofGFOE2xzqop0gKiqvD0o.jpg","original_title":"4つの不思議なストーリー～超常ミステリードラマSP","original_language":"ja"},{"id":874847,"adult":false,"title":"A Different Girl","video":false,"overview":"Tells the story of unpredictable events that take place in the close relationship between a perfectionist Wan Jun, his girlfriend Ji Yeon, and Ye Ri, who has a crush on Wan Jun .","genre_ids":[35,10749],"media_type":"movie","popularity":0.356,"vote_count":1,"poster_path":"/pz9V8h2OZxh0xK5f1RQ0lgH0wcx.jpg","release_date":"2021-10-14","vote_average":7,"backdrop_path":"/y8vE2tOGywTPmUve0QNEPbnFT3j.jpg","original_title":"색다른 그녀","original_language":"ko"}],"similar_content":[{"id":12715,"adult":false,"title":"Firewalker","video":false,"overview":"A pair of adventurers try to track down an ancient Aztec/Mayan/Egyptian/Apache horde of gold.","genre_ids":[28,12,35],"popularity":4.1358,"vote_count":194,"poster_path":"/qFUBCOH0HxI9qRcjoG9xChfwEsk.jpg","release_date":"1986-11-21","vote_average":5.291,"backdrop_path":"/s2479rHYhMekJWDHJxXQXgdFkl6.jpg","original_title":"Firewalker","original_language":"en"},{"id":12720,"adult":false,"title":"Suicide Club","video":false,"overview":"When the bizarre mass suicide of 54 high school girls throwing themselves in front of a subway train appears to instigate a string of suicides around the country, Detective Kuroda strives to find the answer, which isn't as simple as he had hoped.","genre_ids":[18,27,53],"popularity":1.4214,"vote_count":541,"poster_path":"/pnmP8OdxzzoYskyx7GbO0EGL6Dk.jpg","release_date":"2001-10-29","vote_average":6.4,"backdrop_path":"/pK8jgMF9o5SBq7grQzVnpeqib7Y.jpg","original_title":"自殺サークル","original_language":"ja"},{"id":12724,"adult":false,"title":"The Convent","video":false,"overview":"A group of college students break into an abandoned convent and become possessed by demonic spirits.","genre_ids":[27,28,35],"popularity":0.7103,"vote_count":66,"poster_path":"/ehDQuLqA0Lj03k4uM5MKzphbi0Y.jpg","release_date":"2000-01-21","vote_average":5.4,"backdrop_path":"/oRNBwIFSZeMdi3WCpTggA6OMHA8.jpg","original_title":"The Convent","original_language":"en"},{"id":12764,"adult":false,"title":"Missing in Action 2: The Beginning","video":true,"overview":"Prequel to the first Missing In Action, set in the early 1980s it shows the capture of Colonel Braddock during the Vietnam war in the 1970s, and his captivity with other American POWs in a brutal prison camp, and his plans to escape.","genre_ids":[28,10752],"popularity":1.0345,"vote_count":309,"poster_path":"/vOgiL2KQYyTHJ225lT5QB5B9kO0.jpg","release_date":"1985-03-01","vote_average":5.735,"backdrop_path":"/7xADC2HSQw9fAQuPMPsZS2XVPV7.jpg","original_title":"Missing in Action 2: The Beginning","original_language":"en"},{"id":12780,"adult":false,"title":"Iron Monkey","video":false,"overview":"In this Hong Kong variation of Robin Hood, corrupt officials of a Chinese village are robbed by a masked bandit known as \"Iron Monkey\", named after a benevolent deity. When all else fails, the Governor forces a traveling physician into finding the bandit.","genre_ids":[28,80,18],"popularity":1.9673,"vote_count":320,"poster_path":"/qXYISomt08V5PUqCzYRLVSQZmWP.jpg","release