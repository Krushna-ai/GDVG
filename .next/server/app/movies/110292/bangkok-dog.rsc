9:{"metadata":[["$","title","0",{"children":"Bangkok Dog | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Agent Andrew Kang is sent to Thailand on a dangerous undercover mission to take down the human trafficking ring run by the sadistic crimelord Dominick Mesias. His street smarts and fighting skills win over the local gangsters and he rises up the Bangkok underworld but the closer he gets to cracking the case, the more he loses himself in the role."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/110292/bangkok-dog"}],["$","meta","5",{"property":"og:title","content":"Bangkok Dog"}],["$","meta","6",{"property":"og:description","content":"Agent Andrew Kang is sent to Thailand on a dangerous undercover mission to take down the human trafficking ring run by the sadistic crimelord Dominick Mesias. His street smarts and fighting skills win over the local gangsters and he rises up the Bangkok underworld but the closer he gets to cracking the case, the more he loses himself in the role."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/110292/bangkok-dog"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/9N0wRpjRsKZBZuBHaTPwIRyIvgQ.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Bangkok Dog"}],["$","meta","12",{"name":"twitter:description","content":"Agent Andrew Kang is sent to Thailand on a dangerous undercover mission to take down the human trafficking ring run by the sadistic crimelord Dominick Mesias. His street smarts and fighting skills win over the local gangsters and he rises up the Bangkok underworld but the clo