ht":2160,"file_path":"/zTvGsmqTn0p13fQHDoHiZHiT5v9.jpg","iso_639_1":null,"vote_average":1.222},{"width":1442,"height":811,"file_path":"/wxH023kub9V9c8wRUglyPZt6hBG.jpg","iso_639_1":null,"vote_average":0.166},{"width":1525,"height":858,"file_path":"/3JGYWymKOjD4vBqnR5gIMJIsmzv.jpg","iso_639_1":"zh","vote_average":0},{"width":1417,"height":797,"file_path":"/iaVwwp1Eoywo2mjrfNpZ8OTOpKM.jpg","iso_639_1":null,"vote_average":0},{"width":2160,"height":1215,"file_path":"/go295NSoNxgNzGmPNj5zaHItdDo.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T07:44:04.715+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":118,"tagline":"","homepage":"","overview":"没有通天本领也能踏上取经路？小猪妖决定离开浪浪山，和蛤蟆精、黄鼠狼精、猩猩怪组团取经。西行路上，小妖怪们将遇到怎样的考验？最终他们又能否实现心愿，活成自己喜欢的样子？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Nobody","runtime":118,"tagline":"","homepage":"","overview":"The Little Pig Yao decides to leave Langlang Mountain to join the pilgrimage. On the journey west, what trials will the little monsters face? In the end, will they achieve their dreams and live as they truly desire?"},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"랑랑산 꼬마요괴","runtime":0,"tagline":"","homepage":"","overview":""},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"浪浪山小妖怪","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"浪浪山小妖怪","runtime":0,"tagline":"","homepage":"","overview":"浪浪山的野生小豬妖一心想進大王洞，卻因為一次意外得罪了大王，無奈之下他被迫離開浪浪山，與發小蛤蟆精、黃鼠狼精、猩猩怪組成“草根取經團”，假扮唐僧師徒搶先前往西天取經。一路上，他們歷經荒誕冒險，各自完成了自我成長，也取得了屬於自己的真經。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"浪浪山小妖怪","runtime":118,"tagline":"","homepage":"","overview":"沒有通天本領也能踏上取經路？小豬妖決定離開浪浪山，和蛤蟆精、黃鼠狼精、猩猩怪組團取經。西行路上，小妖怪們將遇到怎樣的考驗？最終他們又能否實現心願，活成自己喜歡的樣子？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Маленькие демоны путешествуют на Запад","runtime":118,"tagline":"","homepage":"","overview":"Маленький поросёнок Яо решает покинуть гору Лангланг, чтобы присоединиться к паломничеству. С какими испытаниями столкнутся маленькие монстры на пути на запад? В конце концов, смогут ли они осуществить свои мечты и жить так, как им действительно хочется?"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"แก๊งไซอิ๋วกำมะลอ","runtime":0,"tagline":"","homepage":"","overview":"ปีศาจหมูน้อยตัดสินใจออกเดินทางจากภูเขาหลางหลาง พร้อมแก๊งปีศาจคางคก ปีศาจพังพอน และปีศาจกอริลลา เพื่อมุ่งหน้าสู่การผจญภัยในดินแดนทางทิศตะวันตก"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Tiểu Yêu Quái Núi Lãng Lãng","runtime":0,"tagline":"","homepage":"","overview":"Tiểu Heo Yêu quyết định rời núi Lang Lang để tham gia cuộc hành hương. Trên hành trình về phương Tây, những chú tiểu quái vật sẽ phải đối mặt với những thử thách nào? Cuối cùng, liệu chúng có đạt được ước mơ và sống như mong muốn?"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Nobody","runtime":118,"tagline":"","homepage":"","overview":"El pequeño demonio cerdo decidió abandonar la Montaña Langlang y formar un equipo de base con el demonio sapo, el demonio comadreja y el demonio gorila, para emprender el viaje hacia el oeste."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Nobody","runtime":118,"tagline":"","homepage":"","overview":"El pequeño demonio cerdo decidió abandonar la Montaña Langlang y formar un equipo de base con el demonio sapo, el demonio comadreja y el demonio gorila, para emprender el viaje hacia el oeste."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Nobody","runtime":0,"tagline":"","homepage":"","overview":"O pequeno porco Yao decide deixar a montanha Langlang para se juntar à peregrinação. Na jornada para o oeste, que provações os monstrinhos enfrentarão? No final, eles conseguirão realizar seus sonhos e viver como realmente desejam?"},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"}],"reviews_tmdb":[],"recommendations":[{"id":1500536,"adult":false,"title":"Dead to Rights","video":false,"overview":"During the 1937 Nanjing Massacre, a postman poses as a photo developer, helping Japanese forces while secretly sheltering Chinese refugees. He later risks his life evacuating them and revealing evidence of the atrocities.","genre_ids":[18,10752,36],"media_type":"movie","popularity":3.1035,"vote_count":67,"poster_path":"/rx9xTly73NssFHPg9gKrX9tJdDI.jpg","release_date":"2025-07-19","vote_average":8,"backdrop_path":"/ngLgoY3MTfLANqv9cpXr96saaFV.jpg","original_title":"南京照相馆","original_language":"zh"},{"id":1144107,"adult":false,"title":"The Legend of Hei 2","video":false,"overview":"When an attack shatters the fragile peace between the spirit world and humanity, Hei teams up with Luye, the last disciple of his Shifu Wuxian, to expose a conspiracy that threatens both realms - and the bond they've sworn to protect.","genre_ids":[16,14,28],"media_type":"movie","popularity":6.4349,"vote_count":43,"poster_path":"/l1Q7YzanazjJescEkSfcRuIj1hR.jpg","release_date":"2025-07-18","vote_average":8.442,"backdrop_path":"/uJEZaEM2hY3MG50CgZ3z9jeTwmp.jpg","original_title":"罗小黑战记 2","original_language":"zh"},{"id":1406607,"adult":false,"title":"The Stage","video":false,"overview":"During the Republican era, wars and conflicts were frequent. On stage, the \"Overlord\" sings with resounding passion, while below, the absurd spectacle of life unfolds. They must both secure the opera troupe's livelihood and appease the audience in their seats. Once the curtain rises, how should this play be performed?","genre_ids":[18,35],"media_type":"movie","popularity":1.332,"vote_count":39,"poster_path":"/wSFGtkoz8SW6yIgu1Xvxs584QQt.jpg","release_date":"2025-07-12","vote_average":7.256,"backdrop_path":"/6ggN6nRgJskoRIEVYmvY1hyRvBv.jpg","original_title":"戏台","original_language":"zh"},{"id":1139695,"adult":false,"title":"She's Got No Name","video":false,"overview":"A bizarre case caused thousands of waves. There are different opinions on the truth. When the whole story of the case was gradually restored like pieces of a puzzle, people realized that the truth was not that important anymore.","genre_ids":[18,80],"media_type":"movie","popularity":1.1245,"vote_count":9,"poster_path":"/2C1yy7lPYAYvbtW8bDckGGdPhmt.jpg","release_date":"2025-06-14","vote_average":4.7,"backdrop_path":"/busvJ951z67XMmGbAWgFHhXwdSf.jpg","original_title":"酱园弄·悬案","original_language":"zh"},{"id":1419406,"adult":false,"title":"The Shadow's Edge","video":false,"overview":"Macau Police brings the tracking expert police officer out of retirement to help catch a dangerous group of professional thieves.","genre_ids":[28,80,18,53],"media_type":"movie","popularity":183.5286,"vote_count":442,"poster_path":"/e0RU6KpdnrqFxDKlI3NOqN8nHL6.jpg","release_date":"2025-08-16","vote_average":7.2,"backdrop_path":"/zXINNssll2zsPGqd7F7Llrw7Uql.jpg","original_title":"捕风追影","original_language":"zh"},{"id":810674,"adult":false,"title":"A Girl on the Shore","video":false,"overview":"Keisuke Isobe and Koume Satou live a rather dull life. But when Koume's crush breaks her heart, their situation becomes quite unordinary. She starts a \"no-strings-attached\" relationship with Keisuke, whom she had previously rejected, both finding solace in the other in order to fill the emotional voids in their lives.","genre_ids":[18,10749],"media_type":"movie","popularity":0.7375,"vote_count":24,"poster_path":"/8BXrZeE1yRSMGXJAge5ylu00PVC.jpg","release_date":"2021-08-20","vote_average":6.979,"backdrop_path":"/upaBFRSzTSVN5EyI2ot6mimy3h7.jpg","original_title":"うみべの女の子","original_language":"ja"},{"id":1464818,"adult":false,"title":"Girl on Edge","video":false,"overview":"Figure skater Jiang struggles to salvage her career under the ruthless eye of her mother and coach, Wang. At the rink, she finds a kindred spirit in Zhong. But when Wang begins to train Zhong, tension builds and Jiang’s ambition spirals into destructive obsession.","genre_ids":[18,9648],"media_type":"movie","popularity":0.702,"vote_count":9,"poster_path":"/r7797stbGbTlCNNe0C1SyYTYixJ.jpg","release_date":"2025-07-12","vote_average":6,"backdrop_path":"/6AhO4G645SltMCaP2OnSVor7HDf.jpg","original_title":"花漾少女杀人事件","original_language":"zh"},{"id":923612,"adult":false,"title":"Dutiful Son","video":false,"overview":"After a typhoon ravages their mother's burial place, five brothers embark on a visit to her grave, only to find that the body has disappeared. In a grotesque turn of events, they return home to find their mother's reanimated corpse waiting for them. The real test of their filial devotion begins.","genre_ids":[35,27],"media_type":"movie","popularity":0.3632,"vote_count":3,"poster_path":"/wq8Uour5zgPB22zycsiXGibDSpY.jpg","release_date":"2022-01-27","vote_average":7,"backdrop_path":"/laOwpEnf7MwmhbXPVDXq7ZTWs8I.jpg","original_title":"효자","original_language":"ko"},{"id":1497970,"adult":false,"title":"Tom and Jerry: Forbidden Compass","video":false,"overview":"The iconic cat-and-mouse duo accidentally travel through time in a museum. Along their journey, they meet a group of intriguing new companions and become involved in a final showdown with m