5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Nobody\",\"description\":\"The Little Pig Yao decides to leave Langlang Mountain to join the pilgrimage. On the journey west, what trials will the little monsters face? In the end, will they achieve their dreams and live as they truly desire?\",\"image\":\"https://image.tmdb.org/t/p/w500/oqS3wJX3wNj4DciCyTznnMZ3Fuu.jpg\",\"datePublished\":\"2025-08-02\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Animation\",\"Adventure\",\"Fantasy\",\"Comedy\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.798,\"bestRating\":10,\"ratingCount\":57}}"}}],["$","$L10",null,{"initialDrama":{"id":"56f16648-f3ae-40da-a386-27d42b1feb10","tmdb_id":1304434,"imdb_id":"tt36733027","content_type":"movie","title":"Nobody","original_title":"浪浪山小妖怪","overview":"The Little Pig Yao decides to leave Langlang Mountain to join the pilgrimage. On the journey west, what trials will the little monsters face? In the end, will they achieve their dreams and live as they truly desire?","poster_path":"/oqS3wJX3wNj4DciCyTznnMZ3Fuu.jpg","backdrop_path":"/xawDFjfjBmtKYC29bZOYnYPGa8e.jpg","release_date":"2025-08-02","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":16,"name":"Animation"},{"id":12,"name":"Adventure"},{"id":14,"name":"Fantasy"},{"id":35,"name":"Comedy"}],"popularity":4.936,"vote_average":7.798,"vote_count":57,"runtime":118,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-26T16:49:46.413729+00:00","updated_at":"2026-02-21T07:32:36.923+00:00","tagline":null,"homepage":null,"budget":0,"revenue":215367669,"production_companies":[{"id":6223,"name":"Shanghai Animation Film Studio","logo_path":"/lOxuAoSiKVeePamkUq5VCyUFiPw.png","origin_country":"CN"},{"id":270440,"name":"Shanghai Xiaomutou Film and Televis