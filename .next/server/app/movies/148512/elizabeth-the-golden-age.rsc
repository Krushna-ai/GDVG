0,"aspect_ratio":0.7,"vote_average":0},{"width":1000,"height":1426,"file_path":"/h8ktpfEbCHZG4aveHYQaIPsPq0C.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.701,"vote_average":0},{"width":1000,"height":1500,"file_path":"/9Vi7Jjm85UCbJZD31PoqTHkwDmD.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":500,"height":750,"file_path":"/vX4vp0az2yn11KycIFZaNf1yvZ2.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/qX8RupOUuE20XQwHotnaqwSa8AT.jpg","iso_639_1":"sv","iso_3166_1":"SE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/d59FhDe241KbmmtM2tzqKs75bVg.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/y1BppoT1MCVwdK4ThtIZ3iX77bu.jpg","iso_639_1":"ro","iso_3166_1":"RO","vote_count":1,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1600,"height":900,"file_path":"/sRx1eyBP8ydHQixz5ejV09YVZrn.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/y6fvAce9NJbt16YRDEJ6AVooKM8.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/dQw2lWQs6qssPbgxG3wmS1dkquc.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/9hANzgEPadpnqOIINGigOkC5r7O.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/7NvMR6ihwuH8aXQ8PnVxSpxaMxV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":2.278},{"width":1920,"height":1080,"file_path":"/wsTWmTiSvEAJtdql9vIHynbZ7ta.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":3,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/843MdySW7QGhCdbYiOaHJ7zJPNF.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/22XnR4TnWEcIC7a675JrSvkBSfY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/nwfi0mjXSuERpqfkXOrirCj1I3Y.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":0.958},{"width":1280,"height":720,"file_path":"/hjqF9AUSyvtKdnrgzuYK9PBj0Jt.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/7VrXKHCArbCTUmCi68YBvTVqvjq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/7RzZcWuHQ598Qga7oDnbrCRklfo.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/j3F07Pt9aSYwDIasrj8UC3qricf.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/6Fexd6Hggi38jgXMBOye2ajWHKR.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/9w99OhovDskQnDTLE8dmtQex6nH.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/xeQOAlGe7iga5pzJyIGKbSK1AlB.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3000,"height":1688,"file_path":"/h9L7YZzfC7C4pYbbA9Y5ttS8rqZ.jpg","iso_639_1":"sv","iso_3166_1":"SE","vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2895,"height":1628,"file_path":"/owOSOrGtdEjBXBeAIjL7EYqCxz8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-27T09:52:20.758+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":114,"tagline":"Woman. Warrior. Queen.","homepage":"","overview":"When Queen Elizabeth's reign is threatened by ruthless familial betrayal and Spain's invading army, she and her shrewd adviser must act to safeguard the lives of her people."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Elizabeth: Das goldene Königreich","runtime":115,"tagline":"Frau. Kriegerin. Königin.","homepage":"","overview":"England 1585. Immer häufiger ist Königin Elizabeth den Anfeindungen des Königs von Spanien ausgesetzt, der den Inselstaat unter seine Kontrolle bringen will. Als Elizabeths engster Berater Sir Francis Walsingham ein spanisches Mordkomplott gegen seine Königin aufdeckt, beginnt ein offener Krieg zwischen den beiden Großmächten. Elizabeths einzige Hoffnung gegen die unbesiegbare Spanische Armada ist der Abenteurer und Seefahrer Sir Walter Raleigh, an den die pflichtbewusste Königin ihr Herz verliert..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":114,"tagline":"Donna. Guerriero. Regina.","homepage":"http://www.elizabeththegoldenage.net/","overview":"Filippo II, re di Spagna e fervente cattolico, è fermamente deciso a detronizzare l'\"eretica\" Elisabetta I e a incoronare regina d'Inghilterra la cugina Maria Stuarda. Sostenuto dalla Chiesa di Roma e armato di un poderoso esercito il sovrano spagnolo ordisce un complotto ai danni di Elisabetta, che da trent'anni governa gli inglesi con forza e saggezza. Mentre il fondamentalismo cattolico di Filippo e dell'Inquisizione minaccia l'Europa protestante, la presenza a corte di Raleigh, un cittadino senza titolo nobiliare con la vocazione per l'esplorazione e per la navigazione su mari perigliosi, indebolisce le salde certezze della regina. Dimenticando il suo ruolo, Elisabetta si scopre vulnerabile e innamorata. Ma la politica estera la reclama. L' \"invincibile\" Armada di Filippo, centotrenta galere e trentamila uomini, è salpata per l'Inghilterra."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Золотой век","runtime":114,"tagline":"","homepage":"","overview":"1585 год. В мире господствует католическая Испания во главе с королем Филиппом. Ей в состоянии противостоять только Англия с королевой-протестанткой Елизаветой. Но в самой Англии нет единства. Половина населения превозносит Марию Стюарт, и мечтает видеть ее на английском троне, считая Елизавету незаконнорожденной дочерью Генриха VIII. Испанский король, воспользовавшись сложной ситуацией при английском дворе, готовит заговор. В результате он направляет мощную армаду кораблей к берегам Англии…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Elizabeth: Altın Çağ","runtime":114,"tagline":"","homepage":"","overview":"1558-1603 yılları arasında 45 yıl tahtta kalan I. Elizabeth, tarihin en ünlü kraliçelerinden biri idi. İskoçya Kraliçesi kuzeni Mary Stuart, İspanya Kralı Philip ile birlikte İngiliz tahtını eline geçirmek için gizli komplolar düzenlerken I. Elizabeth'in hayatı da büyük bir karmaşa içindedir.Bir yandan, savaşa hazırlanmakta olan imparatorluğunu koruyabilmek için sorumluluklarını yerine getirmeye çalışırken bir yandan da, yakışıklı denizci Raleigh'e karşı hissettiği tutkulu aşkla başa çıkmaya çalışmaktadır. Sadık ve güvenilir danışmanı Sir Francis Walsingham, her ne kadar onu bütün komplolardan korumaya çalışsa da I. Elizabeth, hayatının en zor sınavlarından birini vermek üzeredir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Elizabeth : l'âge d'or","runtime":0,"tagline":"","homepage":"","overview":"En 1585, Elizabeth Ière règne sur l'Angleterre depuis près de trente ans. Le vent destructeur du catholicisme fondamentaliste souffle sur l'Europe, sous la conduite de Philippe II d'Espagne. Soutenu par l'Eglise de Rome, le roi dispose d'une armée puissante et d'une Armada qui domine les mers. Philippe II est déterminé à renverser la reine \"hérétique\" et à ramener l'Angleterre au sein de l'Église romaine catholique.Elizabeth se prépare à la guerre contre l'Espagne mais doit aussi mener un combat plus intime contre ses sentiments pour Walter Raleigh, pirate au service de Sa Majesté.L'amour étant interdit à une souveraine vouée corps et âme à son pays, la reine encourage sa dame d'honneur préférée, Bess, à se rapprocher de Raleigh. Elizabeth observe l'idylle naissante."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Elizabeth - A Idade de Ouro","runtime":114,"tagline":"Mulher; guerreira; rainha.","homepage":"","overview":"Em 1585, a rainha Isabel I de Inglaterra governa há quase três décadas quando o rei Filipe II da Espanha, I de Portugal, decide lutar contra o protestantismo inglês e francês, e assim, fazer frente à Inglaterra e destronar Isabel I por via de uma massiva invasão, usando a Invencível Armada. Cabe ao aventureiro Sir Walter Raleigh defender o solo inglês do invasor."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Elizabeth: Az aranykor","runtime":114,"tagline":"","homepage":"","overview":"1585-öt írunk. I. Erzsébet királynő idestova három évtizede ül a trónon. Angliát vallási ellentétek feszítik, miközben az udvarban folyó ármánykodás is állandó veszélyt jelent. Ugyanekkor a katolicizmus pusztító szele söpör végig Európán. A római egyház támogatásával és az inkvizícióval felfegyverkezve II. Fülöp király armadája fenyegeti Angliát. A spanyol uralkodónak, a világ legnagyobb hatalmú emberének eltökélt szándéka, hogy letaszítja a trónról a protestáns eretneket. A küzdelem mellett szükségképpen háttérbe szorul a királynő magánélete, beteljesületlen szerelem fűzi Sir Walter Raleigh-hez."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Elizabeth: La edad de oro","runtime":114,"tagline":"Mujer. Guerrera. Reina","homepage":"","overview":"Cuenta la historia de una época, la historia de la lucha de una mujer para controlar el amor, aplastar a sus enemigos y consolidarse en el trono de Inglaterra. La reina Isabel I Tudor debe enfrentarse a la traición en el seno de su familia y a sangrientas conspiraciones para arrebatarle el trono. Isabel es consciente de cómo beneficia a la monarquía inglesa el hecho de que el Rey de Inglaterra sea, al mismo tiempo, el jefe supremo de la Iglesia Anglicana, después de haber roto Enrique VIII toda relación con Roma (Acta de Supremacía de 1534). Sin embargo, el poderoso rey español Felipe II está decidido a restaurar el catolicismo en Inglaterra con la ayuda de su ejército y su invicta armada."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"伊丽莎白：黄金时代","runtime":0,"tagline":"","homepage":"","overview":"故事发生在前作《伊丽莎白》的十五年后，此时的英国女王伊丽莎白一世(凯特·布兰切特饰)已经被政敌的无数次阴谋暗算历练得更加强大，她已经不再把国内的阴谋家们放在眼里，因为在她身边依然有那个忠诚无二的皇家重臣弗朗西斯·沃辛汉爵士(杰弗瑞·拉什饰)守护者。而女王则开始为壮大大不列颠的实力而伤神。摆在她面前的难题主要有两个：一是对内，如何降服处处与她作对的苏格兰女王玛丽·斯图尔特(萨曼莎·莫顿饰)；第二是对外，怎样将英国海军训练装备的更加强大，从而击败来自大洋彼岸的不可一世的西班牙王国的“无敌舰队”，并最终能英国登上海上霸主的地位。然而，伊丽莎白一世虽为至高无上的女王，但作为一个同样有血有肉、有七情六欲的女人，她在情感方面，则主要是与英国的沃尔特·罗利爵士(克里夫·欧文饰)纠缠不清。在英国的历史上，风流倜傥的爵士是伊丽莎白一世的宠臣，他热衷于冒险，为了替女王陛下寻找财富，于1584年4月率领由两艘帆船组成的探险队远征新大陆，三个月后，罗利爵士在今天的美国北卡罗来纳州登陆，成为最早抵达新大陆的西方人。虽然他的远洋探险并没有找到什么财富，但他对新大陆的精彩描述还是得到了伊丽莎白女王的赞赏。但事实上，这个号称女王情人的罗利已有家室，却始终无法摆脱女王对他的迷恋……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":114,"tagline":"","homepage":"","overview":"\"The Golden Age\" berättar historien om en kvinnas försök att kontrollera sin kärlek, förgöra sina fiender och säkra sin position som en älskad ikon i Västvärlden. Elizabeths kusin Maria I av Skottland konspirerar med kung Filip II av Spanien för att överta tronen som Englands drottning. Elizabeth förbereder sig att gå i krig för att försvara sitt välde, men måste samtidigt kämpa för att balansera sina kungliga uppgifter med sin oväntade åtrå till äventyraren Sir Walter Raleigh. Uppföljaren till filmen Elizabeth (1998)."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Královna Alžběta: Zlatý věk","runtime":114,"tagline":"Žena. Bojovnice. Královna.","homepage":"","overview":"Královna Alžběta I čelí dvojí výzvě, když je její vláda ohrožena zahraničními vlivy a ještě se musí vypořádat s pokušením ze strany charismatického námořníka na domácí půdě."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":114,"tagline":"Kvinde. Kriger. Dronning.","homepage":"","overview":"Det går rigtig godt i England under dronning Elizabeth i sidste halvdel af 1500-tallet. Kunst, uddannelse og tøjmode har alle gode dage og sørme om ikke også kirken er rimelig tilfreds. Desværre har Elizabeth det lidt sværere på privatfronten, hvor hendes forhold til levemanden og eventyren Sir Walter Raleigh er kendetegnet ved både op- og nedture."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Ελισσάβετ: Η Χρυσή Εποχή","runtime":114,"tagline":"","homepage":"","overview":"Πρόκειται για τη συνέχεια της πρώτης ταινίας από το 1998, και παρουσιάζει τη χρυσή εποχή της βασιλείας της Ελισσάβετ της Αγγλίας, και την επική μάχη της ενάντια στην Ισπανική Αρμάδα."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"","runtime":114,"tagline":"","homepage":"","overview":"Het verhaal van de kruistocht van een vrouw om liefde, het verslaan van vijanden en het behouden van haar positie in de de westelijke wereld. Wanneer de katholieke Mary Stuart, de nicht van de protestantse koningin Elizabeth I, een band schept met Phillip van Spanje voor een hogere positie op de troon, is het Sir Francis Walsingham die de koningin tegen Mary Stuart moet beschermen in een machtsstrijd om de Engelse troon. Elizabeth moet sterk in haar schoenen staan en zelfs bereid zijn een oorlog te beginnen. En terwijl iedereen van haar verwacht dat ze trouwt met een geschikte partij om zo de opvolging veilig te stellen, wordt ze heimelijk verliefd op de avonturier, ontdekker en piraat Walter Raleigh."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"אליזבט: תור הזהב","runtime":0,"tagline":"אישה. לוחמת. מלכה.","homepage":"","overview":"השחקנית קייט בלאנשט חוזרת לתפקיד שהעניק לה מועמדות לאוסקר והבמאי שקאר קאפור חוזר לכיסא הבמאי להמשך המאוחר הזה לדרמה הביוגרפית עטורת השבחים \"אליזבת\" מ-1998, שחוקר את רומן המאה ה-16 בין המלכה אליזבת וההרפתקן הנודע סר וולטר ריילי (קלייב אוון). מייקל הירטס מצטרף אל וויליאם ניקולסון לכתיבת התסריט, והשחקן ג'פרי ראש חוזר לתפקידו כסר פרנסיס וולשינגהם."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"골든 에이지","runtime":0,"tagline":"","homepage":"","overview":"16세기 말, 신교도와 구교도의 대립으로 대륙간의 전쟁이 한창인 시대. 영국은 신교도인 여왕 엘리자베스 1세가 통치하고 있다. 구교도가 주권을 잡은 스페인은 왕위 계승 서열 2위인 메리 스튜어트를 이용해 영국을 점령하고자 엘리자베스의 암살음모를 계획한다. 국가 간의 동맹을 목적으로 여왕의 구혼자들이 줄을 잇는 사이, 엘리자베스는 자유로운 탐험가 월터 라일리 경에게 빠져들지만 나라를 통치하는 ‘여왕’의 위치 때문에 애써 마음을 숨긴다. 라일리 경에 대한 마음은 점점 커져만 가고 여자로서의 삶과 여왕으로서의 권위에서 갈등하던 엘리자베스는 메리 스튜어트의 암살 음모를 발각하게 된다. 반역자로 사형에 처해진 메리 스튜어트의 죽음을 빌미로 스페인은 영국과의 거대 전쟁을 선포하는데… 한 여자로서의 인생에 사랑이라는 축복 대신 전쟁이라는 무거운 짐을 짊어진 그녀는 운명이 자신의 어깨 위에 얹어놓은 여왕의 자리를 인정하고 검을 손에 쥔다. 그리고 이제, 스페인 무적함대에 맞선 역사상 가장 위대한 전쟁을 시작한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Elizabeta: Zlata doba","runtime":0,"tagline":"","homepage":"","overview":"Devet let po prvem filmu, ki je prejel sedem nominacij za oskarje, se vračamo v 16. stoletje, čas vladanja odločne kraljice Elizabete, ki se je za dobrobit svoje dežele odpovedala zvezam z moškimi. Tokrat njeno vladavino ogroža naduti španski kralj in njegovo mogočno ladjevje, edino rešitev pa nudi sila postavni kapitan piratov Raleigh. Elizabeth se znajde v skušnjavi, zato Raleigha z ljubezensko spletko drži blizu dvora, kar pa le še poveča njeno duševno trpljenje. Toda resnična nevarnost preti precej bližje, kot si Elizabeta lahko predstavlja."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Elizabeth: Złoty wiek","runtime":114,"tagline":"Kobieta. Dowódca. Królowa.","homepage":"","overview":"Anglia, rok 1585. Królowa Elżbieta I sprawuje rządy od ponad 30 lat. Na dworze trwają poszukiwania odpowiedniego kandydata na męża, który zapewniłby monarchii kontynuację. Żaden z kandydatów nie przypada Elżbiecie do gustu. Jej serce zaczyna bić mocniej, gdy zostaje jej przedstawiony podróżnik i odkrywca Walter Raleigh, który zdaje się wart bliższego poznania. Tymczasem hiszpański król Filip II zamierza obalić królową i zmusić naród do porzucenia wiary protestanckiej. Elżbieta po raz kolejny postanawia poświęcić sprawy osobiste na rzecz Anglii."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Єлизавета: Золотий вік","runtime":0,"tagline":"Жінка. Воїн. Королева.","homepage":"","overview":"Дія фільму розгортається в 1585 році, католицька Іспанія на чолі з королем Філіпом II - одна з найсильніших держав світу того часу. Вважаючи протестантську Англію загрозою для Іспанії, а також незадоволений частими нападами англійських мореплавців на іспанські судна, Філіп розгортає кампанію по захопленню Англії, плануючи приєднати її землі до Іспанії і зробити свою доньку Ізабеллу королевою Англії. Тим часом в Англії радник кололеви Френсіс Уослінгем наполягає на одруженні королеви Єлизавети I на одному з претендентів, в числі яких були Іван Грозний, король Швеції Ерік XIV і австрійський ерцгерцог Карл. Королева старіє, спадкоємців у неї немає, і після її смерті трон Англії міг перейти до Марії Стюарт ..."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Elizabeth: Epoca de Aur","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Елизабет: Златният век","runtime":114,"tagline":"Жена. Воин. Кралица.","homepage":"","overview":"Кралица Елизабет I се бори да усмири любовта си, да защити империята си и да утвърди позицията си на иконичен образ в западния свят."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Elizabeth: A Era de Ouro","runtime":0,"tagline":"","homepage":"","overview":"Há quase três décadas no comando da Inglaterra, a Rainha Elizabeth I enfrenta ameaças ao seu poder, impostas por governos estrangeiros e pelo seu próprio país. Simultaneamente, o Rei da Espanha Felipe II, apoiado pelo Vaticano, planeja destronar a rainha e restaurar o catolicismo na nação britânica. Elizabeth se prepara para entrar em guerra, ao mesmo tempo em que luta contra uma paixão inesperada."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"エリザベス：ゴールデン・エイジ","runtime":0,"tagline":"","homepage":"","overview":"1585年、エリザベス1世はプロテスタントの女王としてイギリスを統治していた。だが、欧州全土をカトリックの国にしようと目論むスペイン国王フェリペ2世は彼女の失脚を画策する。そんな女王の前に、新世界から戻ったばかりの冒険家ローリー卿が現れる。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Elizabeth: L’edat d’or","runtime":0,"tagline":"Dona. Guerrera. Reina","homepage":"","overview":"La reina Isabel I d'Anglaterra ha d'enfrontar-se a una traïció en el si de la seva pròpia família i també amb el poderós rei espanyol Felip II, que està decidit a restaurar el catolicisme a Anglaterra amb l'ajuda del seu exèrcit."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"伊莉莎白：輝煌年代","runtime":0,"tagline":"","homepage":"","overview":"16世紀，伊莉莎白一世（凱特布蘭琪 飾）統治英國近30年，卻仍然受到王室成員背叛的威脅。對岸的歐洲諸國也由西班牙國王菲利浦二世（荷帝莫拉 飾）率領一股天主教基本教義派的風暴襲捲著歐洲。菲利浦二世仗著羅馬教廷宗教大審判的撐腰，以及西班牙在海上艦隊的優勢，對伊莉莎白一世造成不可小覷的威脅。為了捍衛英國，不惜和勢力強大的菲利浦二世展開大戰，同時又不自主地愛上平民華特羅利（克里夫歐文飾），這段身分懸殊又不可能有結果的戀情讓她備受煎熬。面對種種壓力，英國在伊莉莎白一世的統治下，如何締造出輝煌時期。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"อลิซาเบธ: ราชินีบัลลังก์ทอง","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Elizabeth: La edad de oro","runtime":114,"tagline":"Mujer. Guerrera. Reina.","homepage":"","overview":"Cuenta la historia de una época, la historia de la lucha de una mujer para controlar el amor, aplastar a sus enemigos y consolidarse en el trono de Inglaterra. La reina Isabel I Tudor debe enfrentarse a la traición en el seno de su familia y a sangrientas conspiraciones para arrebatarle el trono. Isabel es consciente de cómo beneficia a la monarquía inglesa el hecho de que el Rey de Inglaterra sea, al mismo tiempo, el jefe supremo de la Iglesia Anglicana, después de haber roto Enrique VIII toda relación con Roma (Acta de Supremacía de 1534). Sin embargo, el poderoso rey español Felipe II está decidido a restaurar el catolicismo en Inglaterra con la ayuda de su ejército y su invicta armada."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Nữ Hoàng Elizabeth Đệ Nhất: Thời Đại Hoàng Kim","runtime":0,"tagline":"","homepage":"","overview":"Tiếp theo bộ phim Elizabeth (1998) kể về quá trình lên ngôi của nữ hoàng Anh Elizabeth I, bộ phim Elizabeth: The Golden Age (Nữ hoàng Elizabeth: Thời đại hoàng kim 2007) được xem là phần 2, với ê kíp thực hiện chính đã tham gia từ phần 1.\r Trong phần 2, khán giả sẽ được quay về với bối cảnh châu Âu vào thời kỳ cuối thế kỷ 16, khi diễn biến chính trị, xã hội và chiến tranh ngày một phức tạp và đỉnh điểm là cuộc chiến tranh giữa 2 đế quốc Anh và Tây Ban Nha. Đã có một cuộc viễn chinh của một người phụ nữ nhằm chế ngự tình yêu, sự đe dọa của kẻ thù và lòng tôn kính của thần dân ở vương quốc bà trị vì. Đó chính là Nữ hoàng của vương quốc Anh - Elizabeth đệ nhất, người được mệnh danh là \"Woman Warrior Queen - Nữ Hoàng Chiến Binh\". Một Nữ hoàng Elizabeth trưởng thành chịu đựng nhiều cuộc khủng hoảng vào cuối triều đại của bà bao gồm các mưu đồ của tòa án, một âm mưu ám sát, Armada (Hạm đội) Tây Ban Nha và những thất vọng về cuộc tình lãng mạn..."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Elžbieta: aukso amžius","runtime":0,"tagline":"","homepage":"","overview":"„Elžbieta: aukso amžius“ prasideda tuo karalienės valdymo laikotarpiu, kuomet visi trokšta užimti sostą, o aplink valdovę verda intrigos bei išdavystės. Netrūksta ir išorinių problemų: Ispanijos karalius Filipas II siekia užkariauti Angliją ir paversti ją katalikiška šalimi. Besiruošdama mūšiui su Ispanija, karalienė susipainioja savo jausmuose. Iš vienos pusės ją kamuoja karališki įsipareigojimai, iš kitos – netikėtai suliepsnoję jausmai serui Valteriui...\r „Elžbieta: aukso amžius“ – tai pritrenkiantis pasakojimas apie didingą istorijos laikmetį, apie moterį, tuo pat metu sugebėjusią būti ir valdove, ir meiluže. Tai juosta apie istorinę asmenybę, kurios vardas su didžiule pagarba iki šiol tariamas ne tik Jungtinėje Karalystėje, bet ir visoje Europoje bei Vakarų pasaulyje.\r Nesuprasti savo aplinkoje, abu šie vyrai pamažu ima pažinti vienas kitą. Ir nors tai vyksta neakivaizdžiai, neišvengiamai artėja atomazga, po kurios išlikti galės tik vienas iš jų."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"ელისაბედი: ოქროს ხანა","runtime":0,"tagline":"","homepage":"","overview":"ფილმში მოთხრობილია მე15ე საუკუნის ინგლისის დედოფალ ელისაბედზე."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"Kráľovná Alžbeta: Zlatý vek","runtime":0,"tagline":"","homepage":"","overview":"Postavila sa proti najmocnejšej armáde sveta. Unikla pokusu o atentát. Pre vyššie záujmy obetovala svoju lásku a dala popraviť svoju príbuznú. Volala sa Alžbeta a predovšetkým vďaka nej sa môže Británia chváliť prívlastkom Veľká. Katolícke Španielsko chce koncom 16. storočia zničiť silnejúce protestantské Anglicko. Kráľ Filip II. buduje silnú armádu, ale potrebuje zámienku na to, aby mohol na Anglicko zaútočiť, preto intrigami nachystá pascu na kráľovnú Alžbetu a jej hlavného poradcu, Sira Walsinghama, na čo využije Alžbetinu sesternicu, škótsku kráľovnú Máriu Stuartovnu, ktorá je v domácom väzení na severe krajiny. Pasca zaklapne, španielska armáda vypláva, aby sa spojila s francúzskymi pozemnými vojskami, a zaútočí. V tom čase sa kráľovná Alžbeta beznádejne zamiluje do moreplavca Waltera Raliegha, ktorého si chce udržať v blízkosti trónu a ďaleko od mora a Ameriky. Vie však, že dôležitejšie ako jej srdce je kráľovstvo. Obetuje lásku pre veľkosť krajiny?"},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Elisabet – kultainen aikakausi","runtime":114,"tagline":"","homepage":"","overview":"On vuosi 1585, ja on kulunut miltei kolme vuosikymmentä siitä, kun nuori Elizabeth nousi Englannin valtaistuimelle. Verinen kamppailu Englannin kruunusta on raivonnut taukoamatta, ja nyt Englannin kanaalin toiselta rannalta nousee jälleen uusi vihollinen: Espanjan Filip II on päättänyt liittää saarivaltakunnan katolilaisten vaikutuspiiriin. Elizabethin on tehtävä kaikkensa pysyvänsä Euroopan mahtavimpana kuninkaallisena."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Elizabeth : L'Âge d'or","runtime":114,"tagline":"Femme. Guerrière. Reine.","homepage":"","overview":"Grande-Bretagne, 1585. La reine Elizabeth, sur le trône depuis 27 ans, se régale des récits de voyage de Walter Raleigh, charismatique explorateur tout juste rentré du Nouveau-Monde afin de lui réclamer son soutien financier pour l'établissement d'une colonie en Virginie. Entre autres vertus bénéfiques pour la reine protestante, son flirt avec le séduisant aventurier la distrait des menaces que les catholiques, dirigés par Marie Stuart, font peser sur son royaume. Bien qu'assignée à résidence, cette dernière conspire avec le roi Philippe II pour l'assassiner et lancer l'Armada, l'imposante flotte du monarque espagnol, contre les troupes britanniques. Avec l'aide de son fidèle conseiller Francis Walsingham, qui comme elle maudit l'Inquisition, Elizabeth va déjouer ces complots."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Elizabete. Zelta laikmets","runtime":0,"tagline":"","homepage":"","overview":"Katoliskā Spānija, kur valda Felipe II, ir visspēcīgākā valsts Eiropā. Viņš vēlas iekarot Angliju un izveido vērā ņemamu floti. Anglijā valda Elizabete, neprecējusies, bez bērniem, saukta par karalieni jaunavu. Viņas padomdevējs Frānsiss Volsingems uzstāj, ka viņai jāprecas un jārada pēcnācēji, citādi troni ieņems Skotijas karaliene Mērija, kura ir katoliete. Galma pieņemšanā uzrodas angļu jūrasbraucējs Volters Rolijs, kurš savaldzina Elizabeti ar aizjūru stāstiem. Viņš aizēno visus dižciltīgos Elizabetes pielūdzējus. Mērija dod pavēli uzbrukt Elizabetei. Volsingems liek Elizabetei pieņemt lēmumu, neizrādot žēlsirdību. Bet Felipe tikai gaidījis, lai būtu pamatots iegansts uzbrukt Anglijai."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Zlatne godine kraljice Elizabete","runtime":0,"tagline":"Žena. Ratnica. Kraljica.","homepage":"","overview":"1585. je godina. Kraljica Elizabetha već treće desetljeće vlada Engleskom, ali i dalje je suočena s pretenzijama na prijestolje i obiteljskim izdajama. Kontinentom u to vrijeme doslovno hara katolicizam utjelovljen u liku španjolskoga kralja Philpa II. Uz potporu pape i inkvizicije, s velikom vojskom i moćnom mornaricom, Philip II predstavlja direktnu prijetnju Elizabethi i njenoj zemlji. Pobožan je Philip naime odlučio svrgnuti s prijestolja protestantske heretike i Englesku ponovno učiniti kraljevinom u službi Rimske Katoličke Crkve."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"伊莉莎白：輝煌年代","runtime":0,"tagline":"","homepage":"","overview":"16 世紀，伊莉莎白一世（凱特布蘭琪 飾）統治英國近 30 年，卻仍然受到王室成員背叛的威脅。對岸的歐洲諸國也由西班牙國王菲利浦二世（荷帝莫拉 飾）率領一股天主教基本教義派的風暴襲捲著歐洲。菲利浦二世仗著羅馬教廷宗教大審判的撐腰，以及西班牙在海上艦隊的優勢，對伊莉莎白一世造成不可小覷的威脅。為了捍衞英國，不惜和勢力強大的菲利浦二世展開大戰，同時又不自主地愛上平民華特羅利（克裏夫歐文飾），這段身分懸殊又不可能有結果的戀情讓她備受煎熬。面對種種壓力，英國在伊莉莎白一世的統治下，如何締造出輝煌時期。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[{"id":"665b733ebd337355d3bc3a6d","url":"https://www.themoviedb.org/review/665b733ebd337355d3bc3a6d","author":"CinemaSerf","content":"Sadly, someone agreed that a sequel to \"Elizabeth\" (1998) was required so we ended up with this rather fanciful vehicle for a still competent Cate Blanchett but not so much for a terribly wooden Clive Owen as the seafaring Walter Raleigh. Following the execution of Mary, Queen of Scots (Samantha Morton), England is facing impending invasion by the Spanish Armada. The (largely forgivable) factual inaccuracies that dogged the first film are somehow magnified in this rather poor follow up. It really does miss Sir Richard Attenbourgh and despite the best efforts of Geoffrey Rush is left too much to likes of the somewhat flighty Abbie Cornish. As you'd expect, the film looks great and the use of CGI is effectively complementary - especially as things hot up, but none of that really helps enliven the rather ponderous pace of this history. Fortunately the Queen didn't live too much longer after this so we ought to be safe from \"Elizabeth III - the Essex Years.\"","created_at":"2024-06-01T19:15:10.407Z","updated_at":"2024-06-01T19:15:10.525Z","author_details":{"name":"CinemaSerf","rating":6,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":4518,"adult":false,"title":"Elizabeth","video":false,"overview":"The story of the ascension to the throne and the early reign of Queen Elizabeth the First, the endless attempts by her council to marry her off, the Catholic hatred of her and her romance with Lord Robert Dudley.","genre_ids":[18,36],"media_type":"movie","popularity":3.1485,"vote_count":1475,"poster_path":"/qEk48VLOdibXFVIEzE9ETZUBcCs.jpg","release_date":"1998-09-13","vote_average":7.169,"backdrop_path":"/LTjGvAf92YLudl5zqJP9tHLuSo.jpg","original_title":"Elizabeth","original_language":"en"},{"id":3902,"adult":false,"title":"I'm Not There","video":false,"overview":"Six actors portray six personas of music legend Bob Dylan in scenes depicting various stages of his life, chronicling his rise from unknown folksinger to international icon and revealing how Dylan constantly reinvented himself.","genre_ids":[18,10402],"media_type":"movie","popularity":1.2647,"vote_count":757,"poster_path":"/bucgvB7gQqcl1m71efHkenfIMTj.jpg","release_date":"2007-10-01","vote_average":6.5,"backdrop_path":"/hXGZv8TAFP52jxIZLdIDCVmPJBQ.jpg","original_title":"I'm Not There","original_language":"en"},{"id":408616,"adult":false,"title":"The Journey","video":false,"overview":"Firebrand Democratic Unionist Party leader Ian Paisley and Sinn Fein politician Martin McGuinness, two implacable enemies in Northern Ireland, are forced to take a short journey together in which they will take the biggest leap of faith and change the course of history.","genre_ids":[18],"media_type":"movie","popularity":0.4382,"vote_count":57,"poster_path":"/avmWN1YGYbzW4n1cbffw4uLCZSr.jpg","release_date":"2017-03-30","vote_average":6.3,"backdrop_path":"/dJxJ00NCbYVErMcaYNTQLS89BHO.jpg","original_title":"The Journey","original_language":"en"},{"id":9648,"adult":false,"title":"The Man Who Sued God","video":false,"overview":"A lawyer becomes a fisherman from frustration. When his one piece of property, his boat, is struck by lightning and destroyed he is denied insurance money because it was “an act of God”. He re-registers as a lawyer and sues the insurance company and, as God’s representative, The Church.","genre_ids":[35],"media_type":"movie","popularity":0.458,"vote_count":71,"poster_path":"/4mB43zGijLyPZPgX9jC3oRtC4BY.jpg","release_date":"2001-10-25","vote_average":6.331,"backdrop_path":"/ehLNVWeksv50rGuIt04JOApWkfT.jpg","original_title":"The Man Who Sued God","original_language":"en"},{"id":12660,"adult":false,"title":"Charlotte Gray","video":false,"overview":"This is a drama set in Nazi-occupied France at the height of World War II. Charlotte Gray tells the compelling story of a young Scottish woman working with the French Resistance in the hope of rescuing her lover, a missing RAF pilot. Based on the best-selling novel by Sebastian Faulks.","genre_ids":[18,36,10749,10752],"media_type":"movie","popularity":1.0669,"vote_count":182,"poster_path":"/6RnRclsipl3cZKnDfsu0MrqWCwI.jpg","release_date":"2001-12-28","vote_average":6.142,"backdrop_path":"/9jo4LVTFj1zKk9nCzulUiGWSnB.jpg","original_title":"Charlotte Gray","original_language":"en"},{"id":26108,"adult":false,"title":"Stage Beauty","video":false,"overview":"Humble Maria, who outfits top London theater star Ned Kynaston, takes none of the credit for the male actor's success at playing women. And because this is the 17th century, Maria, like other females, is prohibited from pursuing her dream of acting. But when powerful people support her, King Charles II lifts the ban on female stage performers. And just as Maria aided Ned, she needs his help to learn her new profession.","genre_ids":[35,10749],"media_type":"movie","popularity":0.752,"vote_count":144,"poster_path":"/q3rTkp6d8NG2dPdb3Ert3C0YojK.jpg","release_date":"2004-09-03","vote_average":6.6,"backdrop_path":"/gHvK2mylJnSIh1pdgGxaGsgNgyB.jpg","original_title":"Stage Beauty","original_language":"en"},{"id":1279112,"adult":false,"title":"Elizabeth Taylor: The Lost Tapes","video":false,"overview":"Newly discovered interviews with Elizabeth Taylor and unprecedented access to the star’s personal archive reveal the complex inner life and vulnerability of the groundbreaking icon.","genre_ids":[99],"media_type":"movie","popularity":0.812,"vote_count":11,"poster_path":"/aHeRe3fNLxr4eebkLN2WXXAkb53.jpg","release_date":"2024-05-16","vote_average":6.636,"backdrop_path":"/ovtUVT50eMPspiErQVS6ApADWC9.jpg","original_title":"Elizabeth Taylor: The Lost Tapes","original_language":"en"},{"id":130370,"adult":false,"title":"On the Sly","video":false,"overview":"In a world and in a time not so faraway lived a little girl who had the feeling to be invisible in her parents eyes. To be sure, she decided to disappear.","genre_ids":[10751],"media_type":"movie","popularity":0.0764,"vote_count":8,"poster_path":"/z4pQMclmNl2ROp57nb7PK0yobGv.jpg","release_date":"2011-09-30","vote_average":5.3,"backdrop_path":"/jr5zuwQq6zf5I6pjIH3VPpM0Yi0.jpg","original_title":"À pas de loup","original_language":"fr"},{"id":38415,"adult":false,"title":"Bran Nue Dae","video":false,"overview":"In the Summer of 1965 a young man is filled with the life of the idyllic old pearling port Broome - fishing, hanging out with his mates and his girl. However his mother returns him to the religious mission for further schooling. After being punished for an act of youthful rebellion, he runs away from the mission on a journey that ultimately leads him back home.","genre_ids":[35,18,10749],"media_type":"movie","popularity":0.1974,"vote_count":30,"poster_path":"/7tB7mr0OqHsgATo58PAtSNJpaP7.jpg","release_date":"2009-08-09","vote_average":5.4,"backdrop_path":"/8a00YiXut68tymakaAHL2tHpu99.jpg","original_title":"Bran Nue Dae","original_language":"en"},{"id":480242,"adult":false,"title":"Piripkura","video":false,"overview":"The last two surviving members of the Piripkura people, a nomadic tribe in the Mato Grosso region of Brazil,  struggle to maintain their indigenous way of life amidst the region's massive deforestation. Living deep in the rainforest, Pakyî and Tamandua live off the land relying on a machete, an ax, and a torch lit in 1998.","genre_ids":[99],"media_type":"movie","popularity":1.8695,"vote_count":5,"poster_path":"/elWge9owHyh5XQxCXM5PdrTjyW6.jpg","release_date":"2018-03-01","vote_average":8,"backdrop_path":"/h5qur9zYUMMHrONvXedReAcFhkU.jpg","original_title":"Piripkura","original_language":"pt"},{"id":1005251,"adult":false,"title":"The Sparring Partner","video":false,"overview":"Adapted from a sensational real-life case in 2013, the intricate story begins when a young man partners with his friend to murder and dismember his parents. Pleading not guilty, the defense attorneys soon turn on each other, as the defendants play the devil and idiot game. Meanwhile, heated debates emerge inside the jury room, where nine jurors grapple with the truth.","genre_ids":[80,18],"media_type":"movie","popularity":0.7672,"vote_count":45,"poster_path":"/2Jh0O3AwUK7zzzAvkGf9xRfmB76.jpg","release_date":"2022-10-27","vote_average":7.1,"backdrop_path":"/uRbzr3dYlWa6NK1ya8fEPqDOUyK.jpg","original_title":"正義迴廊","original_language":"cn"},{"id":341104,"adult":false,"title":"Notebook","video":false,"overview":"Sarah, Sreedevi and Pooja are best friends who are studying in the same school. However, problems start brewing in their lives when Sreedevi gets pregnant.","genre_ids":[18,10751],"media_type":"movie","popularity":0.196,"vote_count":12,"poster_path":"/pv3gub5Z1tJvCCSfYoXzF09O5xI.jpg","release_date":"2006-12-22","vote_average":7,"backdrop_path":"/kPrk0hKRafnPjFBOXDQme0slc50.jpg","original_title":"നോട്ട്ബുക്ക്‌","original_language":"ml"},{"id":573468,"adult":false,"title":"The Reformer. Zwingli: A Life's Portrait","video":false,"overview":"Zurich in 1519: The young widow Anna Reinhart lives a barren life between fear of the church and worries about the future of her three children, when the arrival of a man in the city causes turmoil: The young priest Ulrich Zwingli takes up his new position at the Grossmünster in Zurich and sparks fierce discussions with his sermons against the grievances of the Catholic Church. Zwingli's revolutionary thoughts frighten Anna. But when she sees how Zwingli lives charity and not just preaches, she increasingly becomes fascinated by him. But Zwingli's success quickly becomes dangerous. His ideas almost trigger a civil war, and at the same time a struggle for power and interpretive sovereignty breaks out in the inner circle of the movement. When the Catholic forces begin to form internationally, the relationship between Zwingli and Anna is put to a hard test.","genre_ids":[36],"media_type":"movie","popularity":0.2576,"vote_count":14,"poster_path":"/zPDAvTeGPTNDNGFPENisyBFrhio.jpg","release_date":"2019-01-17","vote_average":6.429,"backdrop_path":"/gWrTW1zP00EnUBLo5aCcfkJnvDA.jpg","original_title":"Zwingli","original_language":"de"},{"id":241070,"adult":false,"title":"Divorce Corp.","video":false,"overview":"More money flows through the family courts, and into the hands of courthouse insiders, than in all other court systems in America combined – over $50 billion a year and growing. Through extensive research and interviews with the nation’s top divorce lawyers, mediators, judges, politicians, litigants and journalists, DIVORCE CORP. uncovers how children are torn from their homes, unlicensed custody evaluators extort money, and abusive judges play god with people’s lives while enriching their friends. This explosive documentary reveals the family courts as unregulated, extra-constitutional fiefdoms. Rather than assist victims of domestic crimes, these courts often precipitate them. And rather than help parents and children move on, as they are mandated to do, these courts - and their associates - drag out cases for years, sometimes decades, ultimately resulting in a rash of social ills, including home foreclosure, bankruptcy, suicide and violence.","genre_ids":[99,18],"media_type":"movie","popularity":0.1614,"vote_count":11,"poster_path":"/fU2ojj5ULLjHbcQXrRshQm1YDEZ.jpg","release_date":"2014-01-10","vote_average":8,"backdrop_path":"/o4nDU4eW5vOP1xzO6rCTOYs0aEb.jpg","original_title":"Divorce Corp.","original_language":"en"},{"id":51384,"adult":false,"title":"Lovely, Still","video":false,"overview":"A holiday fable that tells the story of an elderly man discovering love for the first time.","genre_ids":[18,10749],"media_type":"movie","popularity":3.1281,"vote_count":41,"poster_path":"/p5o2waFH3ioBOZuHKlx1kzk9Rdi.jpg","release_date":"2009-10-03","vote_average":6.61,"backdrop_path":"/avwnjFQMCsKG4aVTKXLhd368eza.jpg","original_title":"Lovely, Still","original_language":"en"},{"id":103119,"adult":false,"title":"Two Flags West","video":false,"overview":"A group of confedarate prisoners is sent to a unionist fort in the west to help the local garrison to fight the indians.","genre_ids":[37,10752],"media_type":"movie","popularity":0.7408,"vote_count":29,"poster_path":"/334zxF6EMlrhqcvWkt9OrNdG8HL.jpg","release_date":"1950-10-12","vote_average":6.2,"backdrop_path":"/mqBCk5qzWXAZPIgFulNFqc0xbwn.jpg","original_title":"Two Flags West","original_language":"en"},{"id":77852,"adult":false,"title":"Enigma","video":false,"overview":"Floating dead in space, transport ship Genesis become an unsolvable mystery. All hands on board have been killed. What began as a simple transport mission for the crew of the Genesis, ends with not only their bloodshed, but the loss of an important military prisoner. The people of earth are in a time of crisis. They are waging war against a far superior opponent, an alien race called the Cnidarians. After a bloody assault on a military ship, the Vendetta, USSM special forces were able to capture their first Cnidarian prisoner, code named 71099. But commonly known through out the fleet as Ediolon, the phantom. Realizing that a military transport would be too obvious of a target to their enemy, the USSM enlisted the freelance ship Genesis, commanded by Nathaniel J Rhys to secretly transport the prisoner to the high security prison located on Mars' moon Demos. The ship never arrived.","genre_ids":[878],"media_type":"movie","popularity":0.7665,"vote_count":15,"poster_path":"/imydHdAQT6WwVAT6jyrmdhFqT3P.jpg","release_date":"2009-05-30","vote_average":4.8,"backdrop_path":"/oFVDe7ix4leywkiYENodtjBC9oa.jpg","original_title":"Enigma","original_language":"en"},{"id":177489,"adult":false,"title":"Victoria & Albert","video":false,"overview":"The passionate love story that was Queen Victoria and Prince Albert's lengthy marriage. Beginning in 1837, the year of King William IV's death and 18-year-old Victoria's ascension to the throne, the series charts the tumultuous period in 19th Century England where Victoria comes to terms with the enormous duties that lay ahead of her, while also falling deeply in love with her beloved Albert of Saxe-Coburg-Gotha. The marriage and birth of their nine children are featured, as is Albert's frustration by the inactivity he experienced in the early years of his role as Prince Consort.","genre_ids":[10749,18],"media_type":"movie","popularity":0.3616,"vote_count":12,"poster_path":"/gIEsZrRsAP0rfmkhb8C9cuYrfaz.jpg","release_date":"2001-08-26","vote_average":7.6,"backdrop_path":"/rLrpwqVnqAJXE9fWE1fIqtC9xGB.jpg","original_title":"Victoria & Albert","original_language":"en"},{"id":70406,"adult":false,"title":"Falling Rocks","video":false,"overview":"6 Friends, 1 Killer, No Mercy! Slow moving thriller that builds up towards a nerve wrecking end.","genre_ids":[18,53],"media_type":"movie","popularity":0.3135,"vote_count":6,"poster_path":"/eSQYo8j5VEpxmksTBtQGgOGRYUk.jpg","release_date":"2000-06-29","vote_average":5.9,"backdrop_path":null,"original_title":"Falling Rocks","original_language":"de"},{"id":280538,"adult":false,"title":"Freddie Mercury the Video Collection","video":true,"overview":"Freddie Mercury lives again in this compilation of his best solo material. Included are the live and studio versions of 'Barcelona', Freddie's smash hit rendition of 'The Great Pretender' and 'Living On My Own'.","genre_ids":[10402],"media_type":"movie","popularity":0.0662,"vote_count":3,"poster_path":"/kdEznmZX61ux74QffV1EJy5sbgO.jpg","release_date":"2000-06-27","vote_average":7.7,"backdrop_path":"/xJ2J3P6jnoxqQpSu4sTn8RvCavK.jpg","original_title":"Freddie Mercury the Video Collection","original_language":"en"}],"similar_content":[{"id":66,"adult":false,"title":"Absolute Power","video":false,"overview":"A master thief coincidentally is robbing a house where a murder—in which the President of the United States is involved—occurs in front of his eyes. He is forced to run, while holding evidence that could convict the President.","genre_ids":[80,18,28],"popularity":2.2658,"vote_count":1203,"poster_path":"/izvyt3cxlilhbYwybTOteDWqf99.jpg","release_date":"1997-02-14","vote_average":6.658,"backdrop_path":"/cLftTzGw40BlLw8IggKSWDjKOQo.jpg","original_title":"Absolute Power","original_language":"en"},{"id":858024,"adult":false,"title":"Hamnet","video":false,"overview":"The powerful story of love and loss that inspired the creation of Shakespeare's timeless masterpiece, Hamlet.","genre_ids":[18,10749,36],"popularity":68.9666,"vote_count":732,"poster_path":"/vbeyOZm2bvBXcbgPD3v6o94epPX.jpg","release_date":"2025-11-26","vote_average":7.727,"backdrop_path":"/73BClq9FOcrWrutnpiqhCNEWEwJ.jpg","original_title":"Hamnet","original_language":"en"},{"id":3033,"adult":false,"title":"Gods and Monsters","video":false,"overview":"It's 1957, and James Whale's heyday as the director of \"Frankenstein,\" \"Bride of Frankenstein\" and \"The Invisible Man\" is long behind him. Retired and a semi-recluse, he lives his days accompanied only by images from his past. When his dour housekeeper, Hannah, hires a handsome young gardener, the flamboyant director and simple yard man develop an unlikely friendship, which will change them forever.","genre_ids":[18],"popularity":0.955,"vote_count":382,"poster_path":"/awvJH3NtXoStsjAtX