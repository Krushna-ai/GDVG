5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Naruto Shippuden the Movie: The Lost Tower\",\"description\":\"Assigned on a mission to capture Mukade, a missing-nin, Naruto Uzumaki sets out for the once glorious historic ruins of \\\"Ouran\\\", where he pursues and corners the rouge ninja. Mukade's goal is revealed to be a dormant leyline within the ruins; he unleashes the power of the leyline, causing a light to envelop Naruto, sending him into the past, 20 years before the series began. When Naruto awakens, he comes into contact with the Fourth Hokage, Minato Namikaze.\",\"image\":\"https://image.tmdb.org/t/p/w500/6e2YvN1tQK4xQHlmy7GJTuXOt2u.jpg\",\"datePublished\":\"2010-07-31\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"adventure film\",\"action film\",\"fantasy film\",\"Adventure\",\"Action\",\"Animation\",null,null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.178,\"bestRating\":10,\"ratingCount\":500}}"}}],["$","$L10",null,{"initialDrama":{"id":"6d5cc203-4904-4f13-b565-a1133178c337","tmdb_id":50723,"imdb_id":"tt1703048","content_type":"movie","title":"Naruto Shippuden the Movie: The Lost Tower","original_title":"劇場版 NARUTO -ナルト- 疾風伝 ザ・ロストタワー","overview":"Assigned on a mission to capture Mukade, a missing-nin, Naruto Uzumaki sets out for the once glorious historic ruins of \"Ouran\", where he pursues and corners the rouge ninja. Mukade's goal is revealed to be a dormant leyline within the ruins; he unleashes the power of the leyline, causing a light to envelop Naruto, sending him into the past, 20 years before the series began. When Naruto awakens, he comes into contact with the Fourth Hokage, Minato Namikaze.","poster_path":"/6e2YvN1tQK4xQHlmy7GJTuXOt2u.jpg","backdrop_path":"/a4MrZ711OIObIhSGF8SqcZQTyZo.jpg","release_date":"2010-07-31","first_air_date":null,"status":"published",