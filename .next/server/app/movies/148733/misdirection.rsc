5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Misdirection\",\"description\":\"A desperate couple have pulled off a string of high-end break-ins to pay off a mob debt. When they attempt to rob their latest victim, they find themselves caught in a deadly game of cat and mouse. The tables are turned and the hunters become the hunted.\",\"image\":\"https://image.tmdb.org/t/p/w500/z7padnoIDHbmxPdqEHryhqlaVqc.jpg\",\"datePublished\":\"2026-01-13\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"US\",\"inLanguage\":\"en\",\"genre\":[\"Horror\",\"Thriller\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.982,\"bestRating\":10,\"ratingCount\":28}}"}}],["$","$L10",null,{"initialDrama":{"id":"3dcfd7f2-39ab-446c-b356-872b4e38c41e","tmdb_id":1146344,"imdb_id":"tt6374142","content_type":"movie","title":"Misdirection","original_title":"Misdirection","overview":"A desperate couple have pulled off a string of high-end break-ins to pay off a mob debt. When they attempt to rob their latest victim, they find themselves caught in a deadly game of cat and mouse. The tables are turned and the hunters become the hunted.","poster_path":"/z7padnoIDHbmxPdqEHryhqlaVqc.jpg","backdrop_path":"/pgVvGaqM77sQR90OeMMVNvQAxbg.jpg","release_date":"2026-01-13","first_air_date":null,"status":"published","original_language":"en","origin_country":["US"],"genres":[{"id":27,"name":"Horror"},{"id":53,"name":"Thriller"}],"popularity":58.2973,"vote_average":5.982,"vote_count":28,"runtime":84,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-26T01:36:39.998528+00:00","updated_at":"2026-02-26T01:36:39.846+00:00","tagline":"Vengeance runs deep.","homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":110831,"name":"Storyoscopic Films","logo_path":null,"origin_country":""},{"id":2373,"name":"Patriot Pictures","logo_path":"/wcQ30Rj2FP8d8VkAcOYqXCHCm