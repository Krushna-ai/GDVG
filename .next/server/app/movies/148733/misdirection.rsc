,"file_path":"/gaezslYxaWPTnHzuseMTplDwy3G.png","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":9.601,"vote_average":0},{"width":1861,"height":604,"file_path":"/frPmZvibyfrIbybqrHd0wyTXCmC.png","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":3.081,"vote_average":0},{"width":1500,"height":184,"file_path":"/jupGicQdLqmb9WtqQHrlyHELCh1.png","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":8.152,"vote_average":0}],"posters":[{"width":2000,"height":3000,"file_path":"/mTyT4StWHYwr4kPCJbhyxcYU0P7.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":2000,"height":3000,"file_path":"/3Kc2VPwDO9wxcKG99PIo4Hsd2Fr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":960,"height":1440,"file_path":"/z7padnoIDHbmxPdqEHryhqlaVqc.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":3,"aspect_ratio":0.667,"vote_average":2.278},{"width":2000,"height":3000,"file_path":"/u9ebASTgYomEuSeAIL1siPpJxiy.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":3,"aspect_ratio":0.667,"vote_average":2.278},{"width":1795,"height":2687,"file_path":"/tDPW2j6L6r6YfsChYLfLRQ6Vjwh.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":2,"aspect_ratio":0.668,"vote_average":1.75},{"width":500,"height":750,"file_path":"/GoXqwtLk02ALYYzDevu3tM9AHR.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":3,"aspect_ratio":0.667,"vote_average":1.222},{"width":1000,"height":1483,"file_path":"/pQ5E101AU3rnpCo3Kv6NOIXcbGI.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":3,"aspect_ratio":0.674,"vote_average":0.166},{"width":500,"height":750,"file_path":"/zqEJum03kBVPN3cgygxImL1Fvus.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":800,"height":1200,"file_path":"/shkOlUxb3Qx9KTEOaYoKVJ8jpP4.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/5WdD871bhSX6zaMnxtQKWbJBCEh.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/acQsZDaaPZsOQ2jEMPd4vdGRXn8.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/d94m0KTk0TTn4mj2dpZavhGgBqI.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/pgVvGaqM77sQR90OeMMVNvQAxbg.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/ysJWEFErQZcEp2qopxGmgfFlX9e.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/15sarvi4KF6WFtCQbKgcxG8iOj.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T04:33:21.716+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Misdirection","runtime":84,"tagline":"Vengeance runs deep.","homepage":"","overview":"A desperate couple have pulled off a string of high-end break-ins to pay off a mob debt. When they attempt to rob their latest victim, they find themselves caught in a deadly game of cat and mouse. The tables are turned and the hunters become the hunted."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Ложный след","runtime":84,"tagline":"","homepage":"","overview":"Сара и Джейсон связаны не только чувствами, но и большими долгами перед криминальными авторитетами. Желая как можно скорее расплатиться по счетам и наконец вернуться к нормальной жизни, они взламывают и грабят дома состоятельных людей. Последней целью отчаянных героев становится шикарный особняк успешного адвоката по имени Дэвид - по слухам, в его сейфе хранится крупная сумма денег. Их как раз должно хватить, чтобы решить вопрос с мафией. Поначалу всё идет хорошо, однако хозяин неожиданно возвращается. Очень скоро становится ясно, что Дэвид - далеко не беззащитная жертва. Ограбление превращается в смертельно опасную игру в кошки-мышки."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Misdirection","runtime":84,"tagline":"Zemsta jest głęboka.","homepage":"","overview":"Zdesperowana para, która dokonała serii luksusowych włamań, aby spłacić dług wobec mafii. Próbując okraść swoją ostatnią ofiarę, wpadają w śmiertelnie niebezpieczną grę w kotka i myszkę. Sytuacja się odwraca, a myśliwi stają się zwierzyną."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"猎局反转","runtime":0,"tagline":"","homepage":"","overview":"这部电影讲述了一对走投无路的夫妇，他们接连实施了一系列高端入室盗窃，只为偿还欠黑帮的债务。当他们试图抢劫最新的目标时，却发现自己陷入了一场致命的猫鼠游戏中，局势发生逆转，猎人变成了猎物。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Una pareja se ve obligada a llevar a cabo una serie de atracos de alto nivel para saldar su peligrosa deuda con la mafia. Cuando su último robo, dirigido a un importante abogado defensor, se descontrola, se ven atrapados en una red de secretos, engaños y consecuencias mortales."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Una pareja se ve obligada a llevar a cabo una serie de atracos de alto nivel para saldar su peligrosa deuda con la mafia. Cuando su último robo, dirigido a un importante abogado defensor, se descontrola, se ven atrapados en una red de secretos, engaños y consecuencias mortales."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Заблуда","runtime":0,"tagline":"","homepage":"","overview":"Отчаяна двойка, извършила серия от луксозни обири, за да изплати мафиотски дълг, се опитва да ограби последната си жертва. Но вместо лесна плячка, те попадат в смъртоносна игра на котка и мишка, където ролите се обръщат и ловците стават преследваните."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Misdirection: Rache sitzt tief","runtime":0,"tagline":"","homepage":"","overview":"Ein verzweifeltes Paar versucht mit einer Serie von Einbrüchen seine Schulden bei der Mafia abzubezahlen. Doch der letzte Coup geht schief, als das Einbruchsopfer den Spieß umdreht."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Dezorientarea","runtime":84,"tagline":"","homepage":"","overview":"Un cuplu disperat a comis o serie de spargeri sofisticate pentru a-și plăti datoria față de mafie. Când încearcă să-și jefuiască cea mai recentă victimă, se trezesc prinși într-un joc mortal de-a șoarecele și pisica. Rolurile se inversează, iar vânătorii devin vânați, luptând pentru supraviețuire într-o confruntare tensionată, unde fiecare mișcare poate fi ultima."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":85,"tagline":"","homepage":"","overview":"Een stel pleegt een reeks grootschalige overvallen om een ​​schuld aan de maffia af te betalen. Wanneer hun laatste inbraak - gericht op een prominente advocaat - volledig uit de hand loopt, raken ze verstrikt in een web van geheimen, bedrog en dodelijke gevolgen. De rollen zijn nu omgedraaid en de jagers worden de prooi."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Bẫy Ngầm","runtime":0,"tagline":"","homepage":"","overview":"Một cặp đôi túng quẫn, vì món nợ khổng lồ với băng mafia, đã chọn con đường liều mạng: đột nhập vào những ngôi nhà sang trọng, đánh cắp tài sản để gom tiền trả nợ. Mọi thứ tưởng chừng nằm trong tầm kiểm soát cho đến khi họ chọn sai mục tiêu. Ngôi nhà mới này không chỉ có của cải — mà còn ẩn chứa một thế lực nào đó đang chờ sẵn.\r Khi màn đêm buông xuống, kế hoạch trơn tru của họ nhanh chóng biến thành cơn ác mộng. Từng bước, những kẻ săn mồi bỗng trở thành con mồi trong trò chơi rượt đuổi chết chóc. Không còn đường lui, họ buộc phải tìm cách sống sót giữa mê cung bẫy rập, nơi mỗi tiếng động đều có thể là tín hiệu cho một cái chết đang tiến đến rất gần."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[],"external_ids":{"imdb_id":"tt6374142","twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148733,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"PH","release_dates":[{"note":"","type":1,"iso_639_1":"","descriptors":[],"release_date":"2026-01-13T00:00:00.000Z","certification":""}]},{"iso_3166_1":"RO","release_dates":[{"note":"Voyo","type":4,"iso_639_1":"en","descriptors":[],"release_date":"2026-02-24T00:00:00.000Z","certification":"15"}]},{"iso_3166_1":"US","release_dates":[{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-02-10T00:00:00.000Z","certification":""}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikidata_metadata":{},"mood_tags":null,"trope_tags":null,"vibe_description":null,"ai_enriched_at":null,"ai_enrichment_version":0}}]]
