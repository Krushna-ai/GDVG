9_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":800,"height":1200,"file_path":"/1PHrDKxnAUTZl4Kaw4ULUxYaVxh.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1500,"height":2122,"file_path":"/s1DCabJDgTPcNY1jO9SUKdoF5MT.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.707,"vote_average":0},{"width":1080,"height":1600,"file_path":"/ljVVGTaQSqS8gZe8TIsAtEmcxNS.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.675,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/wbA13Xns8EtbIubDOPLl7kCYYA4.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1600,"height":900,"file_path":"/u9F6ezLnFNOWx6qVQjdJB0mMPtU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1446,"height":813,"file_path":"/wHEKPrkFQZGHuDXjTVmLJHq0CH2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":1920,"height":1080,"file_path":"/g4UENnpS57Ow7VBdFWOt2roaqUU.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/jqo6CW16zbvEIXWVufth7Cen6xM.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/amvUKikKGEyReP4HDEhxYCvl0k3.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:33:05.131+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Clan","runtime":109,"tagline":"The true story of Argentina's most notorious crime family","homepage":"","overview":"In Argentina, between 1982 and 1985, the Puccios, a well-established family of San Isidro, an upper-class suburb of Buenos Aires, kidnap several people and hold them as hostages for a ransom."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":108,"tagline":"El crimen era un asunto de familia.","homepage":"","overview":"La historia se basa en el caso policial del Clan Puccio, que conmocionó a la sociedad argentina a principios de los 80. Tras la aparente normalidad de los Puccio se oculta un siniestro clan dedicado al secuestro y al asesinato. Arquímedes, el patriarca, lidera y planifica las operaciones. Alejandro, el hijo mayor, estrella de un club de rugby, se sirve de su popularidad para no levantar sospechas. Los demás miembros de la familia son cómplices en mayor o menor grado de los crímenes del clan y viven de los beneficios obtenidos de los rescates que pagan los familiares de los secuestrados."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Le Clan","runtime":108,"tagline":"L'histoire vraie de la famille criminelle la plus notoire d'Argentine","homepage":"","overview":"Dans l’Argentine des années 1980, un clan machiavélique auteur de kidnappings et de meurtres vit sous l’apparence d’une famille ordinaire dans un quartier tranquille de Buenos Aires. Le clan est mené d’une main de fer par Arquimedes, le patriarche. Il contraint Alejandro, son fils aîné, une star du rugby évoluant dans la mythique équipe nationale, Los Pumas, ainsi protégé de tous soupçons par sa popularité, à lui fournir des candidats au kidnapping."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"O Clã","runtime":108,"tagline":"","homepage":"","overview":"Baseado na história de uma das gangues mais conhecidas da Argentina, os Puccio, o filme narra sobre essa família que ficou conhecida na década de 1980 por sequestrar e matar várias pessoas. O clã estava composto pelo pai da família, Arquímesdes, seus dois filhos, Daniel e Alejandro, o militar aposentado Rodolfo Franco e mais dois amigos, Roberto Oscar Díaz e Guillermo Fernández Laborde."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Il clan","runtime":108,"tagline":"La vera storia della famiglia criminale più famigerata dell'Argentina","homepage":"","overview":"Negli anni Ottanta, in Argentina, Arquimides Puccio è il patriarca di un clan familiare di Buenos Aires. Benestanti, amati dai loro vicini, rispettati da chiunque e con un figlio che milita nella nazionale di rugby, i Puccio nascondono un inquietante segreto. Sono infatti responsabili di alcuni rapimenti che, in assenza del pagamento di ingenti riscatti, culminano in omicidi."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Η Φαμίλια","runtime":110,"tagline":"Το έγκλημα είναι οικογενειακή υπόθεση","homepage":"https://www.facebook.com/ElClandefilm","overview":"Κατά τη δεκαετία του 1980, η φαμίλια Πούτσιο διεύθυνε μια μακάβρια επιχείρηση. Πίσω από το προσωπείο της υψηλής κοινωνίας, με ένα μέλος τους παίκτη της εθνικής ομάδας ράγκμπι, οι Πούτσιο επιδίδονταν σε κατά συρροή απαγωγές κατοίκων της ίδιας τους της γειτονιάς, αρπάζοντας τα λύτρα, αλλά δολοφονώντας τα θύματα τους."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Клан","runtime":108,"tagline":"","homepage":"","overview":"Правдивая история клана Пуччио. Эта семья похищала и убивала людей в 1980-х."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"클랜","runtime":108,"tagline":"완벽한 가족의 추악한 민낯이 폭로된다","homepage":"","overview":"80년대 초반의 위태로운 아르헨티나,  사람들이 실종되는 사건이 심심치 않게 발생하곤 한다.  모범적인 부부와 사이 좋은 다섯 자녀의 단란한 푸치오 가족은  결코 입 밖으로 뱉어서는 안 될 끔찍한 비밀을 품고 사는데……  연인, 친구, 동료… 누구도 의심하지 않았다.  전 세계를 충격에 빠뜨린 실제 이야기.  다정한 이웃의 추악한 민낯이 낱낱이 공개된다!"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"犯罪家族","runtime":0,"tagline":"","homepage":"","overview":"　　影片根据一个真实的故事改编——普奇奥家族。这个富裕的布宜诺斯艾利斯家族索取赎金，杀人赚钱。根据阿根廷犯罪史上一次可怕的事件，电影剖析了罪恶的道德模糊性和平凡性。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Çete","runtime":110,"tagline":"","homepage":"","overview":"Film, 1980'lerde Arjantin'deki adam kaçırma ve cinayetlerle yaşanan Clan Puccio olayına odaklanıyor. Puccio Clan’ın gerçek hikâyesine dayanan filmde, San Isidro, geleneksel komşu ilişkileri içerisindeki tipik bir aile evinde kötü bir grup çocuk kaçırma ve cinayet ile iç içedir. Alejandro’nun en büyük oğlu CASI’de ünlü bir ragbi oyuncusudur. Alejandro’nun suçlu olduğuna yönündeki şüphelere oğlunun popülaritesi kalkan olur.  Film Arjantin’in askeri diktatörlükten yeniden demokrasiye geçişi gözler önüne serer."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":109,"tagline":"‎Die wahre Geschichte von Argentiniens berüchtigtster Krimifamilie‎","homepage":"","overview":"Nach außen hin scheinen die Puccios eine gewöhnliche, gutbürgerliche Großfamilie zu sein. Im Buenos Aires der frühen 80er Jahre betreiben sie mehrere beliebte Lokalitäten. Doch die sind nur Tarnung für die wahren finsteren Machenschaften der Familie. Das skrupellose Familienoberhaupt Arquímedes ist der Kopf hinter den alltäglichen kriminellen Geschäften, bei denen die Puccios neben Entführungen samt Lösegeld Forderungen auch nicht vor Mord zurückschrecken. Dabei benutzt der Patriarch seinen ältesten Sohn Alejandro und dessen Status als besonders populärer Rugby-Nationalspieler, um entsprechende Opfer auszuwählen. Doch als Alejandro schließlich Zweifel an den Taten seiner Familie bekommt und damit deren gesamte Existenz gefährdet, zieht er den Zorn seines erbarmungslosen Vaters auf sich."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"O Clã","runtime":108,"tagline":"A verdadeira história da família criminosa mais notória da Argentina.","homepage":"","overview":"Na década de 1980, uma família argentina de classe média alta fica conhecida por sequestrar e matar pessoas. Arquimedes Puccio, o patriarca da família, lidera o clã com mão de ferro sob uma aparente normalidade."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"De film vertelt het waargebeurde verhaal van de rijke Puccio clan uit de wijk San Isidro in de jaren 80. De familie stond erom bekend dat ze mensen ontvoerden en daar losgeld voor eisten, maar ze vervolgens doodden. Ze ontvoerden mensen uit hun eigen omgeving, de jachtclub en de wijk waar ze woonden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Dzielnicą San Isidro rządzi bezwzględny ojciec Arquímedes. Parają się porwaniami oraz zabójstwami."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"El clan","runtime":108,"tagline":"La realidad supera a la ficción.","homepage":"","overview":"La historia se basa en el caso policial del Clan Puccio, que conmocionó a la sociedad argentina a principios de los 80. Tras la aparente normalidad de la familia Puccio se oculta un siniestro clan dedicado al secuestro y al asesinato. Arquímedes, el patriarca, miembro del Servicio de Inteligencia desde la dictadura, lidera y planifica las operaciones. Alejandro, el hijo mayor, estrella de un club de rugby, se sirve de su popularidad para no levantar sospechas. Los demás miembros de la familia son cómplices en mayor o menor grado de los crímenes del clan, y viven de los beneficios obtenidos de los rescates que pagan los familiares de los secuestrados."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"A klán","runtime":0,"tagline":"","homepage":"","overview":"Az igaz történeten alapuló filmdráma a Puccio dinasztia életét mutatja be. A család nevéhez számos emberrablási eset és gyilkosság köthető, a múlt század nyolcvanas éveiben."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Клан","runtime":0,"tagline":"","homepage":"","overview":"Початок 80-их, Аргентина. Після семи років панування найжорстокішої диктатури, до влади приходить демократія, яка послідовно усуває колишніх силовиків як пережиток минулого. Одним з відсторонених виявляється Архімед Пуччіо, колишній співробітник аргентинських спецслужб, який звик за старого режиму жити на широку ногу, і не хоче задовольнятися нинішніми особняком в передмісті Буенос-Айреса і сімейним магазинчиком спортивного інвентарю. Тому Архімед налагоджує побічний сімейний бізнес - він викрадає людей."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"大犯罪家","runtime":0,"tagline":"","homepage":"","overview":"普契歐家族住在環境清幽的郊區，表面上看來家庭和樂­，但其實是個「犯罪家族」，身為一家之主的老爸心狠手辣卻又威風凜凜­，逼著兒子綁架勒贖，把人質藏在住家地下室，然後一案接著一案，越搞越大，最後他們一共犯下4樁綁架案和­3件謀殺案，直到東窗事發......。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Klanen","runtime":0,"tagline":"","homepage":"","overview":"Filmen bygger på den sande historie om familien Puccio, som satte en skræk i livet på Buenos Aires´ pæne borgerskab tilbage i 1980’erne. Under den såkaldte ´beskidte krig´ havde familiens patriark, Arquímedes, specialiseret sig i at få regimets politiske modstandere til at forsvinde. Nu er manden imidlertid arbejdsløs, så han beslutter sig for at fortsætte kidnapningsarbejdet i eget regi – med hele familien som mere eller mindre frivilligt medsammensvorne. Løsesummerne er med til at opretholde familiens sociale status, men det er ikke ensbetydende med at ofrene overlever opholdet i villaens interimistiske fangekælder."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Klanen","runtime":0,"tagline":"","homepage":"","overview":"Baserat på den sanna historien om familjen Puccio.\r Familjen Puccio är inte en familj som andra. Mellan läxläsande och fredagsmys sysselsätter de sig med mord och kidnappning. Platsen är 1980-talets Buenos Aires efter diktaturens fall. Pappa Arquímedes har tidigare jobbat med att kidnappa och oskadliggöra meningsmotståndare för militärjuntans säkerhetstjänst. Nu är han arbetslös, och återupptar kidnappningsverksamheten - denna gång i sin familjs regi. Mellan läxläsande och fredagsmys sysselsätter de sig med mord och kidnappning. Platsen är 1980-talets Buenos Aires efter diktaturens fall. Pappa Arquímedes har tidigare jobbat med att kidnappa och oskadliggöra meningsmotståndare för militärjuntans säkerhetstjänst. Nu är han arbetslös, och återupptar kidnappningsverksamheten - denna gång i sin familjs regi."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Кланът","runtime":110,"tagline":"Престъплението е като семеен бизнес","homepage":"","overview":"Продуцентите на \"Диви истории\" и режисьора Пабло Траперо (\"Златен лъв\" за режисура) представят съспенс трилъра - \"Кланът\", базиран върху истински събития, шокирали Аржентина през 80-те години. В един обикновен дом в квартала Сан Исидро, семейство Пучио правят зловещи планове за отвличания и убийства. Архимед, главата на семейството, планира и ръководи операциите. Алехандро, най-големият му син е звезда в престижен клуб по ръгби и в митичния национален отбор Лос Пумас. Той се съгласява да съдейства на баща си като предлага хора за отвличане, тъй като неговата популярност го пази и държи извън подозрения. Водейки рисков и много опасен начин на живот, те се издържат от големите откупи плащани от семействата на жертвите. Създаден по действителната история за семейство Пучио, филмът е изпълнен с напрежение и интриги до края. Действието се развива в последните години на аржентинската военна диктатура и връщането на демокрацията."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"綁票家族","runtime":0,"tagline":"","homepage":"","overview":"普契歐家族住在環境清幽的郊區，表面上看來家庭和樂­，但其實是個「犯罪家族」，身為一家之主的老爸心狠手辣卻又威風凜凜­，逼著兒子綁架勒贖，把人質藏在住家地下室，然後一案接著一案，越搞越大，最後他們一共犯下 4 樁綁架案和­3 件謀殺案，直到東窗事發. . . . . . 。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"კლანი","runtime":0,"tagline":"არგენტინის ყველაზე ცნობილი კრიმინალური ოჯახის ნამდვილი ამბავი","homepage":"","overview":"ნამდვილი ისტორია პუჩიოს კლანზე. ოჯახი, რომელმაც გაიტაცა და მოკლა ადამიანები 80-იან წლებში."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"エル・クラン","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"ในประเทศอาร์เจนตินา ระหว่างปีพ.ศ. 2525 ถึง 2528 ครอบครัว Puccios ซึ่งเป็นครอบครัวที่มีฐานะมั่นคงจากเมืองซานอิซิดโร ชานเมืองชนชั้นสูงของบัวโนสไอเรส ได้ลักพาตัวบุคคลหลายรายและจับพวกเขาเป็นตัวประกันเพื่อเรียกค่าไถ่"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"השבט","runtime":0,"tagline":"","homepage":"","overview":"ארגנטינה, שנות ה-80. סיפורה האמיתי והמצמרר של משפחה רגילה למראה, אשר מתפרנסת למחייתה מחטיפה של בני עשירים ושחרורם תמורת כופר."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"}],"reviews_tmdb":[{"id":"5851b806c3a3682fb801f078","url":"https://www.themoviedb.org/review/5851b806c3a3682fb801f078","author":"Reno","content":"$11","created_at":"2016-12-14T21:22:14.448Z","updated_at":"2024-05-16T15:18:33.134Z","author_details":{"name":"Reno","rating":6,"username":"Rangan","avatar_path":"/6ZpVUJzqXMzH35VprEtnX0sNI3.jpg"}}],"recommendations":[{"id":391709,"adult":false,"title":"Apprentice","video":false,"overview":"When ambitious young correctional officer Aiman is transferred to the country's highest-security prison, he catches the attention of the seasoned chief executioner Rahim. Aiman's desire to become the hangman's apprentice is not only professional but born of an unspeakable urge to reconnect with a past that haunts him.","genre_ids":[18],"media_type":"movie","popularity":0.2841,"vote_count":56,"poster_path":"/vp6ZqO6No0NbfcpwSmcQCyLU2SZ.jpg","release_date":"2016-06-01","vote_average":6.9,"backdrop_path":"/Al4VabdLNPYjZWmcyWTYzZB5l3f.jpg","original_title":"Apprentice","original_language":"ms"},{"id":355594,"adult":false,"title":"Isla bonita","video":false,"overview":"Summer in Menorca. The young Olivia has lost all understanding for the world. She just ended an affair in order to begin a real relationship, but no sooner had it started than this also ends. She is comforted and receives prosaic advice from her sculptor mother Nuria. When pensioned advertisement filmmaker Fernando moves into their guesthouse, a fresh wind blows over the island. While Olivia sees him as a father figure, Fernando tries to seduce Nuria. ISLA BONITA is a charming, wonderfully cheerful comedy full of misunderstandings – and a bijou homage to the idyllic holiday island of Menorca. Director and main actor Fernando Colomo delights us with this semi-autobiographic fiction film.","genre_ids":[35],"media_type":"movie","popularity":0.6409,"vote_count":21,"poster_path":"/2crOBSJVF8RvSdEcFG3dbaAyzft.jpg","release_date":"2015-11-06","vote_average":5.2,"backdrop_path":"/wxQ4HdCV6JQaOA5pmiudQYXFThR.jpg","original_title":"Isla bonita","original_language":"es"},{"id":72855,"adult":false,"title":"Jackal of Nahueltoro","video":false,"overview":"Based on an actual murder case that ignited a furious debate over the death penalty in Chile in 1960, this experimental social drama portrays the life and death of an illiterate peasant who, while drunk, murdered the woman with whom he had a relationship and her five children.","genre_ids":[18,53],"media_type":"movie","popularity":0.1997,"vote_count":29,"poster_path":"/ouJ6G1XZZFSAOVAGNkM3vtE24oP.jpg","release_date":"1970-05-04","vote_average":6.7,"backdrop_path":"/9R0u13JM7MZ4p6QF6NTQiX1v1xq.jpg","original_title":"El Chacal de Nahueltoro","original_language":"es"},{"id":324463,"adult":false,"title":"The Devil's Scarab","video":false,"overview":"A series of crimes against redheads scares the people from a little town. After the death of his brother, the 13 year old Alberto decides to investigate what is happening and is helped by the experienced but forgetful Inspector Pimentel.","genre_ids":[12,9648],"media_type":"movie","popularity":0.2365,"vote_count":40,"poster_path":"/qV1NEYRmDwhwtVX1dRm1vuQaCg2.jpg","release_date":"2016-04-14","vote_average":4.9,"backdrop_path":"/wAIHHeRMTkwR4TecyMk7QWRMPSV.jpg","original_title":"O Escaravelho do Diabo","original_language":"pt"},{"id":44096,"adult":false,"title":"Scheherazade, Tell Me a Story","video":false,"overview":"Heba is a TV presenter interested in broadcasting stories that touch on the everyday secret lives of women and the social injustices they face. Her frank style in broadcasting puts her husband's job and consequently her marriage in jeopardy.","genre_ids":[18],"media_type":"movie","popularity":0.358,"vote_count":31,"poster_path":"/8ZvdtedtXy3JxfNIuPUJnHU9LMt.jpg","release_date":"2009-06-24","vote_average":6.435,"backdrop_path":"/hT9bSswKaiV2Ny3zoCJYn1YS5re.jpg","original_title":"احكي يا شهرزاد","original_language":"ar"},{"id":125948,"adult":false,"title":"A Red Bear","video":false,"overview":"Bear has never gotten over the separation from his wife and daughter after having been convicted for armed robbery and homicide and sent to prison. Now he is out, to finally get his cut of the money and reunite with his family, or at least avenge the damage done.","genre_ids":[80,18,53,28],"media_type":"movie","popularity":0.1991,"vote_count":34,"poster_path":"/kD8SPTJVhjUvJOvB6Xhe7crkLN4.jpg","release_date":"2002-05-23","vote_average":7.1,"backdrop_path":"/7jmPLMQyNv746EZED5uMSSFdny9.jpg","original_title":"Un oso rojo","original_language":"es"},{"id":38042,"adult":false,"title":"The Loc