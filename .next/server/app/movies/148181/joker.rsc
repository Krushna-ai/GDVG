639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":1435,"height":807,"file_path":"/8OaM8fbjwt5ThpWAhhBiYYMF2DT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1484,"height":835,"file_path":"/x9CodnKnGkU1hZ1ElVL1JeUW0hs.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1484,"height":835,"file_path":"/89q8zjGxqNm42LE859O1LnuyTBK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":1484,"height":835,"file_path":"/dnfEocMgrY7SJvJVBNu2canPYxq.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":3676,"height":2068,"file_path":"/gvbkQXQOboajTpR2ib5gwzqzUMv.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3682,"height":2071,"file_path":"/brUkl3PG7ost8P5GNCOq6l2S1Qi.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3679,"height":2069,"file_path":"/hTYaQzj5LMckdgEwiBQZzDtjD9e.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/aGGo10clEH5SGCiVyGcm37GpRUp.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":null,"enrichment_cycle":0,"translations":[{"data":{"title":"Coringa","runtime":122,"tagline":"Coloque um sorriso nessa cara.","homepage":"https://www.warnerbros.com.br/filmes/coringa","overview":"Isolado, intimidado e desconsiderado pela sociedade, o fracassado comediante Arthur Fleck inicia seu caminho como uma mente criminosa após assassinar três homens em pleno metrô. Sua ação inicia um movimento popular contra a elite de Gotham City, da qual Thomas Wayne é seu maior representante."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":122,"tagline":"Put on a happy face.","homepage":"http://www.jokermovie.net/","overview":"During the 1980s, a failed stand-up comedian is driven insane and turns to a life of crime and chaos in Gotham City while becoming an infamous psychopathic crime figure."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Джокер","runtime":122,"tagline":"«Сделай счастливое лицо»","homepage":"","overview":"Готэм, начало 1980-х годов. Комик Артур Флек живет с больной матерью, которая с детства учит его «ходить с улыбкой». Пытаясь нести в мир хорошее и дарить людям радость, Артур сталкивается с человеческой жестокостью и постепенно приходит к выводу, что этот мир получит от него не добрую улыбку, а ухмылку злодея Джокера."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Жокера","runtime":121,"tagline":"Сложете си щастливото лице.","homepage":"","overview":"Артър Флек, клоун на партита и неуспял комик, води беден живот с болната си майка. Когато обаче обществото го отлъчва и заклеймява като изрод, той решава да приеме живота на престъпниление и хаос в Готъм Сити."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":122,"tagline":"Alegra esa cara.","homepage":"","overview":"Arthur Fleck es un hombre ignorado por la sociedad, cuya motivación en la vida es hacer reír. Pero una serie de trágicos acontecimientos le llevarán a ver el mundo de otra forma. Película basada en Joker, el popular personaje de DC Comics y archivillano de Batman, pero que en este film toma un cariz más realista y oscuro."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Guasón","runtime":122,"tagline":"","homepage":"","overview":"Arthur Fleck es un hombre ignorado por la sociedad, cuya motivación en la vida es hacer reír. Pero una serie de trágicos acontecimientos le llevarán a ver el mundo de otra forma."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Джокер","runtime":0,"tagline":"Зроби щасливе обличчя.","homepage":"","overview":"Ґотем, початок 1980-х років. Комік Артур Флек живе з хворою матір’ю, яка змалку вчила його «ходити з усмішкою». Намагаючись нести у світ хороше й дарувати людям радість, Артур стикається з людською жорстокістю та поступово доходить висновку, що цей світ отримає від нього не добру усмішку, а посмішку лиходія Джокера."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"조커","runtime":122,"tagline":"내 인생이 비극인 줄 알았는데, 코미디였어","homepage":"","overview":"홀어머니와 사는 아서 플렉은 코미디언을 꿈꾸지만 그의 삶은 좌절과 절망으로 가득 차 있다. 광대 아르바이트는 그에게 모욕을 가져다주기 일쑤고, 긴장하면 웃음을 통제할 수 없는 신경병 증세는 그를 더욱 고립시킨다. 정부 예산 긴축으로 인해 정신과 약물을 지원하던 공공의료 서비스마저 없어져 버린 어느 날, 아서는 지하철에서 시비를 걸어온 증권사 직원들에게 얻어맞던 와중에 동료가 건네준 권총으로 그들을 쏴 버리고 만다. 군중들은 지배계급에 대한 저항의 아이콘이 된 그를 추종하기 시작하며 광대 마스크로 얼굴을 가리고 거리로 쏟아져 나오기 시작하는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":122,"tagline":"Préparez votre plus beau sourire.","homepage":"","overview":"Dans les années 1980, à Gotham City, Arthur Fleck, un humoriste de stand‐up raté, bascule dans la folie et devient le Joker."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"ג'וקר","runtime":122,"tagline":"עטה פרצוף שמח.","homepage":"","overview":"קומיקאי כושל, שלא זוכה להערכה ומרגיש מנוכר, מתחיל בהדרגה לאבד את שפיותו ובונה לעצמו דמות אלימה ורצחנית."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":0,"tagline":"Setz ein Grinsen auf.","homepage":"","overview":"Gotham City im Jahr 1981: Der mental instabile Arthur Fleck führt wahrlich nicht das Leben, von dem man träumt: Vollgepumpt mit Medikamenten geht er seiner Arbeit als kostümierter Werbeschildträger nach und wird nicht selten das Ziel von Spott und Attacken. Abends zieht es ihn in sein heruntergekommenes Apartment, wo er sich um seine kranke Mutter kümmern muss. Gemeinsam hoffen sie auf ein besseres Leben, das Arthur als Stand-Up-Komiker realisieren will. Als plötzlich die Förderung für seine psychologische Betreuung gestrichen wird, nimmt das Unheil seinen Lauf. Die Schusswaffe eines Kollegen, die Suche nach seinem echten Vater und plötzlicher Ruhm sorgen dafür, dass der einstmals harmlose Exzentriker die ganze Stadt in Angst und Schrecken versetzt …"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"小丑","runtime":122,"tagline":"摆出一张笑脸吧","homepage":"","overview":"亚瑟·弗兰克是一个依靠扮演小丑赚取营生的普通人，患有精神疾病的他和母亲一同住在哥谭市的一座公寓里，幻想成为脱口秀演员的亚瑟为了这个目标而努力的生活着，但是现实却屡次击败他的梦想，亚瑟渐渐地变得越来越癫狂，某天在地铁上，亚瑟为了自保杀害了几名嘲笑他的人，同时，一个疯狂的想法在亚瑟心灵萌发……  在看似和平的哥谭市，即将发生翻天覆地的巨变。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":122,"tagline":"Fai un bel sorriso.","homepage":"","overview":"Arthur Fleck vive con l'anziana madre in un palazzone fatiscente e sbarca il lunario facendo pubblicità per la strada travestito da clown, in attesa di avere il giusto materiale per realizzare il desiderio di fare il comico. La sua vita, però, è una tragedia: ignorato, calpestato, bullizzato, preso in giro da da chiunque, ha sviluppato un tic nervoso che lo fa ridere a sproposito incontrollabilmente, rendendolo inquietante e allontanando ulteriormente da lui ogni possibile relazione sociale. Ma un giorno Arthur non ce la fa più e reagisce violentemente, pistola alla mano. Mentre la polizia di Gotham City dà la caccia al clown killer, la popolazione lo elegge a eroe metropolitano, simbolo della rivolta degli oppressi contro l'arroganza dei ricchi."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":122,"tagline":"","homepage":"","overview":"Arthur Fleck är en man som möts av grymhet och förakt från samhället. På dagtid arbetar han som clown och på kvällarna försöker han slå igenom som stå-upp-komiker, men det känns som om skratten alltid är på hans bekostnad. Han är helt ur synk med verkligheten och hans okontrollerbara och opassande skratt, som bara ökar när han försöker behärska det, leder till mer hån och även våld."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":122,"tagline":"Φόρεσε το χαμόγελο σου","homepage":"","overview":"Σε μια ταραγμένη Γκόθαμ Σίτι ο Άρθουρ Φλεκ είναι ένας κοινωνικά απροσάρμοστος, μοναχικός άντρας που ζει με τη μητέρα του και δουλεύει ως κλόουν. Ονειρεύεται καριέρα κωμικού, αλλά όταν η ασφυκτική πίεση του περιβάλλοντός του κορυφωθεί, η έκρηξή του θα λάβει απρόβλεπτες διαστάσεις."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"ჯოკერი","runtime":0,"tagline":"","homepage":"","overview":"დრამატული ამბავი ქალაქ გოთემის ყველაზე საშიში, მოუხელთებელი და მანიპულატორი ბოროტმოქმედის ჯოკერის და მისი აქამდე უცნობი წარსულის შესახებ, თუ როგორ გადაიქცა ერთ-ერთ ყველაზე ცნობილ, შეშლილ და სასტიკ მანიაკად. მოვლენები 1980-იან წლებში ვითარდება"},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Arthur Fleck kæmper for at finde sin plads i mængden. I den fjendtlige by Gotham, der emmer af splittelse, går han rundt i de mørke gader iført to forskellige masker. Den maske, han dagligt maler på i sit job som klovn, og den anden han aldrig kan tage af. Den er hans forklædning - hans meningsløse forsøg på at passe ind i samfundet i stedet for at være den mand, der gang på gang skuffes af livet. Arthur er faderløs, og hans skrøbelige mor er hans bedste ven. Hun gav ham kælenavnet Happy. Et navn, der fremmaner hans smil og skjuler smerten indeni. Men da han bliver mobbet af teenagere på gaden, hånet af forretningsmænd i metroen og drillet af hans klovnekollegaer, bringes den udstødte mand kun endnu mere ude af synk med alle omkring ham."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":122,"tagline":"","homepage":"","overview":"Nem volt még őrültebb, veszélyesebb és viccesebb antihős a képregényvilágban. De hogyan lett Jokerből Joker, a komor Batman örök ellensége és ellentéte? Ez a történet megmutatja, miképpen válhat egy ártatlan lúzerből világok felforgatója, hadseregek legyőzője és szuperhősök méltó ellenfele."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":122,"tagline":"Nahoď úsměv","homepage":"","overview":"Zkrachovalý komediant Arthur Fleck se dlouho pohybuje na tenké hranici mezi realitou a šílenstvím. Jednoho dne se ve svém obleku klauna potuluje po ulicích Gotham City a dostává se do konfliktu s brutálními zloději. Pomalu se roztáčí spirála událostí dosahující hrozivých rozměrů. Všemi opuštěný Fleck se začne čím dál více propadat do hlubin šílenství a postupně se mění v ikonu zločinu, kterou svět brzy bude znát pod jménem Joker."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"小丑","runtime":122,"tagline":"","homepage":"","overview":"亞瑟·弗蘭克是一名以小丑職業為生的普通人，患有精神疾病的他和母親一同住在哥譚市的一座公寓裡。幻想成為脫口秀演員的亞瑟為了這個目標而努力的生活著，但是現實卻屢次擊敗他的夢想，亞瑟漸漸地變得越來越癲狂。某天在地鐵上，亞瑟為了自保殺害了幾名嘲笑他的人；同時，一個瘋狂的想法在亞瑟心靈萌發……  在看似和平的哥譚市，即將發生翻天覆地的巨變。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"โจ๊กเกอร์","runtime":0,"tagline":"เตรียมปั้นหน้ามีความสุข!","homepage":"","overview":"เรื่องราวชีวิตในช่วงตกต่ำของจอมวายร้ายจิตป่วง ซึ่งเป็นจุดกำเนิดที่ไม่เคยมีใครกล่าวถึงมาก่อนบนจอยักษ์ และภาพยนตร์จะพาคุณไปรู้จักกับ \"อาร์เธอร์ เฟล็ก\" ชายผู้ถูกเมินเฉยจากสังคม กับชีวิตของเขาที่เปรียบเสมือนนิทานสอนใจ"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":122,"tagline":"Hymy naamalle","homepage":"","overview":"Yhteiskunnan hylkäämä, pakonomaisista naurukohtauksista kärsivä Arthur Fleck yrittää nousta suosituksi stand up -koomikoksi. Arthur yrittää selvitä raskaasta arjestaan käymällä terapiassa, tekemällä satunnaisia töitä ja huolehtimalla iäkkäästä äidistään. Kun Arthur kohtaa elämässään yhä uusia vastoinkäymisiä ja terapiakin säästösyistä lopetetaan, hän ajautuu lopulta väkivallan ja koston tielle. Arthurin psykoosin kasvaessa hänestä tulee Gothamin hulluin rikollinen ja sarjamurhaaja , Jokeri, eli ”Vitsailija”."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"","runtime":122,"tagline":"Moja mama mi vždy hovorí, aby som sa usmieval a nasadil šťastnú tvár.","homepage":"","overview":"Skrachovaný komediant Arthur Fleck sa dlho pohybuje na tenkej hranici medzi realitou a šialenstvom. V jeden deň sa potuluje vo svojom obleku klauna po uliciach Gotham City a dostáva sa do konfliktu s brutálnymi zlodejmi. Pomaly sa roztáča špirála udalostí, ktorá vyústi do hrozivých rozmerov. Opustený Fleck začne čoraz viac prepadať do hlbín šialenstva a postupne sa mení v ikonického zločinca, ktorého už čoskoro bude svet poznať pod menom Joker."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"","runtime":122,"tagline":"","homepage":"","overview":"De jaren 80. Een clown, Arthur Fleck genaamd, voelt zich uitgekotst en verstoten door de maatschappij. Geleidelijk aan wordt hij krankzinnig, en ontpopt hij zich van vriendelijke, vrolijke clown tot schurk, beter bekend als 'de Joker'. Iemand die kickt op haat en het creëren van chaos."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Selama 1980-an, seorang pelawak berdiri gagal didorong gila dan beralih ke kehidupan kejahatan dan kekacauan di Kota Gotham sambil menjadi tokoh kejahatan psikopat terkenal."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"","runtime":122,"tagline":"Mutluluk maskeni tak.","homepage":"","overview":"Joker, başarısız bir komedyen olan Arthur Fleck'in hayatına odaklanıyor. Toplum tarafından dışlanan bir adam olan Arthur, hayatta yapayalnızdır. Sürekli bir bağ kurma arayışında olan Arthur, yaşamını taktığı iki maske ile geçirir. Gündüzleri, geçimini sağlamak için palyaço maskesini yüzüne takan Arthur, geceleri ise asla üzerinden silip atamayacağı bir maske takar. Babasız büyüyen Arthur’u en yakın arkadaşı olan annesi Happy adıyla çağırır. Bu lakap, Arthur’un içindeki acıyı gizlemesine yardımcı olur. Ancak maruz kaldığı zorbalıklar, onun gitgide toluma aykırı bir adam haline gelmesine neden olur. Yavaş yavaş psikolojik olarak tekinsiz sulara yelken açılan Arthur, bir süre sonra kendisini Gotham Şehri’nde suç ve kaosun içinde bulur. Arthur, zamanla kendi kimliğinden uzaklaşıp Joker karakterine bürünür."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"JOKER 小醜","runtime":0,"tagline":"","homepage":"","overview":"導演杜德菲力斯執導的《小醜》是這個經典反派在大銀幕上前所未見的原創獨立電影。杜德菲力斯鏡頭下的 Arthur Fleck (華堅馮力士 飾) 在葛鹹城掙紮求存。他是個出租小醜，渴望能夠成為棟篤笑匠，卻發現自己的人生更像個笑話。Arthur 受盡社會的冷漠和殘酷所折磨，作出一個醜惡的決定，引發出一連串無可挽回的事件。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":122,"tagline":"Põe uma cara feliz!","homepage":"","overview":"Arthur Fleck é um homem que enfrenta a crueldade e o desprezo da sociedade, juntamente com a indiferença de um sistema que lhe permite passar da vulnerabilidade para a depravação. Durante o dia é um palhaço e à noite luta para se tornar um artista de stand-up comedy…mas descobre que é ele próprio a piada. Sempre diferente de todos em seu redor, o seu riso incontrolável e inapropriado, ganha ainda mais força quando tenta contê-lo, expondo-o a situações ridículas e até à violência. Preso numa existência cíclica que oscila entre o precipício da realidade e da loucura, uma má decisão acarreta uma reacção em cadeia de eventos crescentes e, por fim, mortais."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Joker","runtime":122,"tagline":"Zawsze nadrabiaj miną.","homepage":"","overview":"Historia jednego z cieszących się najgorszą sławą super-przestępców uniwersum DC — Jokera po raz pierwszy na wielkim ekranie. Przedstawiony przez Phillipsa obraz kultowego czarnego charakteru, Arthura Flecka, człowieka zepchniętego na margines, to nie tylko kontrowersyjne studium postaci, ale także opowieść ku przestrodze w szerszym kontekście."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Џокер","runtime":0,"tagline":"Насмеј се.","homepage":"","overview":"Артур Флек, неуспешни је стандaп комичар, који дању ради као кловн. Осећа се одбаченим од стране друштва, а своју неприлагођеност окружењу открива сваки пут када се манијакално смеје у најмање прикладним тренуцима. Његовом душевном стању не помажу ни озбиљни психички проблеми од којих пати. Артур се стара о својој мајци, али се види да му видно недостаје очинска фигура, па је принуђен да је тражи међу људима као што су телевизијски водитељ Мареј Френклин и милијардер Томас Вејн. У свом психичком расулу, њему се чини да је насиље једино решење…"},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"","runtime":122,"tagline":"Affichez votre plus beau sourire.","homepage":"https://www.warnerbroscanada.com/fr/films/joker","overview":"Arthur Fleck rêve de devenir humoriste, mais gagne modestement sa vie comme clown en faisant de la réclame pour des magasins en faillite. Atteint de troubles mentaux, il habite avec sa mère invalide dont il partage la passion pour l’animateur de talk-show Murray Franklin. Souvent objet de moquerie de la part de ses collègues, Arthur a l’habitude d’encaisser les coups. Cependant, tandis qu’il se déplace avec son costume, il est agressé une première fois par des adolescents dans une ruelle, puis il subit la fronde de trois financiers dans le métro. Incapable de se contrôler davantage, il abat ces derniers un à un et prend la fuite. Dans la foulée, Gotham City voit naître un mouvement de masse contre les élites au pouvoir alors que les clowns se multiplient dans les rues. Enhardi, Arthur plonge dans une folie meurtrière."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"جوكر","runtime":0,"tagline":"وضع على وجه سعيد.","homepage":"","overview":"خلال الثمانينيات من القرن الماضي، ممثل كوميدي فاشل - مدفوعًا بالجنون - يتحول إلى حياة الجريمة والفوضى في مدينة قوثام بينما يصبح شخصية مجرمة بنفسية سيئة."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"ジョーカー","runtime":0,"tagline":"笑いの仮面をかぶれ","homepage":"","overview":"1981年、犯罪が多発する大都会ゴッサムシティ。ピエロの仕事をしているアーサーは貧しく、老いた母親ペニーと暮らす上、突然笑いだしてしまうという心の病に悩むが、TV界の人気司会者フランクリンを憧れの対象にして日々耐え忍んでいた。ある日、失業したアーサーは地下鉄で、女性客に嫌がらせをしていた男性3人組を偶然持っていた拳銃で皆殺しにしてしまう。以後アーサーは、自身の心にあった怒りを解放させていく。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Joker: Gã Hề","runtime":120,"tagline":"Cười lên nào.","homepage":"","overview":"Joker từ lâu đã là siêu ác nhân huyền thoại của điện ảnh thế giới. Nhưng có bao giờ bạn tự hỏi, Joker đến từ đâu và điều gì đã biến Joker trở thành biểu tượng tội lỗi của thành phố Gotham? JOKER sẽ là cái nhìn độc đáo về tên ác nhân khét tiếng của Vũ trụ DC – một câu chuyện gốc thấm nhuần, nhưng tách biệt rõ ràng với những truyền thuyết quen thuộc xoay quanh nhân vật mang đầy tính biểu tượng này. Bộ phim đã xuất sắc giành giải thưởng Sư Tử Vàng- Phim Hay Nhất tại LHP Venice lần thứ 76, cùng tràng pháo tay dài 8 phút, và lời khen ngợi dành cho diễn xuất của tài tử Joaquin Phoenix. Một bộ phim không thể bỏ lỡ của tháng 10 năm nay."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Džokers","runtime":0,"tagline":"","homepage":"","overview":"Pirmo reizi uz lielajiem ekrāniem filma par ikonisko Gotemas ļaundari - Džokeru. Arturs Fleks ir vīrs, kurš cenšas atrast savu vietu pilsētas sašķeltajā sabiedrībā. Dienā strādājot par klaunu gadījuma darbos, bet vakaros cenšoties kļūt par atzītu stand-up komiķi, viņš nonāk pie atziņas, ka izjokots tiek viņš pats. Ierauts vienladzības un nežēlības cilkliskajā esamībā, Arturs pieņem vienu sliktu lēmumu, kas uzsāk ķēdes reakciju viņa transformācijā par Džokeru."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ozbek","iso_639_1":"uz","iso_3166_1":"UZ","english_name":"Uzbek"},{"data":{"title":"","runtime":122,"tagline":"Pune-ți o față fericită.","homepage":"","overview":"Arthur Fleck are probleme psihice și e maltratat de societate. El se revoltă, iar drumul lui îl aduce față în față cu alter ego-ul lui: Joker."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Džoker","runtime":0,"tagline":"Priča o čovjeku kojem je društvo okrenulo leđa.","homepage":"","overview":"Uvijek sam u gomili, Arthur Fleck je čovjek koji traži bliskost. No, dok korača utabanim ulicama Gothama i vozi se javnim prijevozom neprijateljskog grada prepunog podjela i nezadovoljstva, Arthur nosi dvije maske. Jednu nanosi za svoj posao klauna, a drugu nikada ne može skinuti. To je maska koju projicira u uzaludnom pokušaju da se osjeća kao dio svijeta oko sebe, a ne kao neshvaćen čovjek kojeg život stalno poražava."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Džokeris","runtime":0,"tagline":"","homepage":"","overview":"Džokeris, ko gero, yra vienas spalvingiausių blogiukų kino istorijoje. „Gimęs“ 1940 m., be daugybės komiksų, Džokeris iki šiol yra pasirodęs daugiau nei 250-yje filmų, televizijos serialų, knygų ir vaizdo žaidimų. Didžiuosiuose ekranuose Džokeris debiutavo 1966-aisiais, tačiau tikra megažvaigžde tapo 1989 m., kuomet jį suvaidino pats Džekas Nikolsonas.  Venecijos kino festivalyje Geriausiu metų filmu pripažintoje juostoje režisierius Todd Phillips pateikia dar nematytą Džokerio atsiradimo istoriją. Gotamo mieste savo vietos gyvenime nerandantis Artūras Flekas (aktorius Joaquin‘as Phoenix‘as) dienomis dirba samdomu klounu, o vakarais stengiasi prasimušti kaip „stand-up“ komikas. Deja, nesėkmingai. Suirzęs, nusivylęs ir kartėlio kupinas Flekas vieną dieną tampa chuliganų auka. Galutinai nusivylęs ir ėmęs prarasti sveiką protą, Flekas pamažu ima virsti cinišku, žiauriu ir negailestingu Džokeriu."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Jokker","runtime":0,"tagline":"","homepage":"","overview":"Ühiskonnast kõrvale heidetud Arthur Fleck luusib mööda Gothami tänavaid, et tunda inimeste lähedust. Päeval klounina raha teenides, lootes nii olla osake ühiskonnast, võõrdub mees ühiskonnast veelgi. Hüljatu ja kiusatuna, hakkab Arthuri sees kasvama viha. Algab aeglane muutus, mille käigus saab heidikust geniaalne kurikael, keda inimesed saavad tundma Jokkerina."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"جوکر","runtime":0,"tagline":"","homepage":"","overview":"داستان «جوکر» در دهه‌ی ۱۹۸۰ میلادی روی می‌دهد و زندگی «آرتور فلک» استند-آپ کمدین شکست‌خورده‌ای را روایت می‌کند که با طرد شدن از سوی جامعه به دنیای زیرزمینی جنایت‌ در شهر گاتهام گرایش پیدا می‌کند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"جوكر","runtime":0,"tagline":"","homepage":"","overview":""},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"","runtime":122,"tagline":"","homepage":"","overview":"Den mislykkede komikeren Arthur Fleck er langsomt på vei inn i galskapen, når han forvandler seg til den kriminelle mesterhjernen Joker."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"","runtime":122,"tagline":"Setz ein Grinsen auf.","homepage":"","overview":"Ein psychisch kranker Komiker kämpft 1981 in Gotham City darum, gesehen zu werden. Als er sich gegen Angreifer zur Wehr setzen muss, wendet sich sein Leben zum Bösen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"CH","english_name":"German"},{"data":{"title":"","runtime":122,"tagline":"","homepage":"","overview":"गोथम सिटी में, मानसिक रूप से परेशान, कॉमेडियन ऑर्थर फ्लेक के साथ समाज द्वारा दुर्व्यवहार किया जाता है. वह अपने अपमान का बदला लेने के लिए, एक हत्यारा बन जाता है."},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"","runtime":117,"tagline":"","homepage":"","overview":"Dramski triler režiserja Todda Phillipsa spremlja legendarnega stripovskega zlikovca v izvirni samostojni zgodbi o izvoru, kakšne še nismo videli na velikih platnih. Mučna in tragična pripoved se vrti okrog umsko trpinčenega komika Arthurja Flecka, v fantastični predstavi Joaquina Phoenixa, ki si prizadeva, da bi se uveljavil v razdeljeni družbi velemesta Gotham, ki ga zapostavlja in odriva na socialni rob. Živi sam z duševno bolno materjo, podnevi dela kot najeti klovn za oglaševanje lokalov in si želi postati zvezda komičnih stand-up predstav, vendar so vse šale ponavadi le na njegov račun. Ujet v krogu životarjenja med apatijo in krutostjo Arthur sprejme slabo odločitev, ki povzroči verižno reakcijo nasilja in smrti. Bolečina ga naposled pahne v soočenje s svojim drugim jazom, poznejšim Batmanovim največjim sovražnikom: Jokerjem."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"","runtime":0,"tagline":"Alegra aquesta cara","homepage":"","overview":"Arthur Fleck és un home ignorat per la societat, la motivació de la qual a la vida és fer riure. Però una sèrie de tràgics esdeveniments us portaran a veure el món d'una altra manera. Pel·lícula basada en Joker, el popular personatge de DC Comics i arxivillà de Batman, però que en aquest film pren un caire més realista i fosc."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"","runtime":122,"tagline":"","homepage":"","overview":"In Gotham City in 1981 probeert een arme komiek met psychische problemen gezien te worden. Zijn leven neemt een duistere wending als hij wordt aangevallen en terugvecht."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"","runtime":122,"tagline":"Setz ein Grinsen auf.","homepage":"","overview":"Ein psychisch kranker Komiker kämpft 1981 in Gotham City darum, gesehen zu werden. Als er sich gegen Angreifer zur Wehr setzen muss, wendet sich sein Leben zum Bösen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"","runtime":122,"tagline":"","homepage":"","overview":"Gotham City, 1981: En mislykket komiker med psykiske problemer gjør alt for å bli sett. Når han omsider slår tilbake, tar livet hans en mørk vending."},"name":"Bokmål","iso_639_1":"nb","iso_3166_1":"NO","english_name":"Norwegian Bokmål"},{"data":{"title":"","runtime":122,"tagline":"","homepage":"","overview":"Gotham City, 1981: En mislykket komiker med psykiske problemer gjør alt for å bli sett. Når han omsider slår tilbake, tar livet hans en mørk vending."},"name":"","iso_639_1":"nn","iso_3166_1":"NN","english_name":"Norwegian Nynorsk"},{"data":{"title":"小丑","runtime":122,"tagline":"摆出一张笑脸吧","homepage":"","overview":"1981 年的哥谭市，一名苦苦挣扎的相声演员遭受心理疾病的折磨。渴望成名的他反击中伤自己的人，经历了黑暗且令人心痛的波折。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"Әзілкеш","runtime":0,"tagline":"","homepage":"","overview":"Джокер немесе Әзілкеш 2019"},"name":"қазақ","iso_639_1":"kk","iso_3166_1":"KZ","english_name":"Kazakh"}],"reviews_tmdb":[{"id":"5d975abdae26be001abe129b","url":"https://www.themoviedb.org/review/5d975abdae26be001abe129b","author":"Manuel São Bento","content":"$11","created_at":"2019-10-04T14:44:13.190Z","updated_at":"2021-06-23T15:58:27.606Z","author_details":{"name":"Manuel São Bento","rating":9,"username":"msbreviews","avatar_path":null}},{"id":"5dac3463174a870019a7c547","url":"https://www.themoviedb.org/review/5dac3463174a870019a7c547","author":"solstafir7","content":"$12","created_at":"2019-10-20T10:18:11.465Z","updated_at":"2021-06-23T15:58:28.173Z","author_details":{"name":"","rating":null,"username":"solstafir7","avatar_path":null}},{"id":"5db52049d40d4c0014fd08bc","url":"https://www.themoviedb.org/review/5db52049d40d4c0014fd08bc","author":"ikomrad","content":"The Joker is similar to the DC Joker character but is not a criminal genius. The movie was a great depiction of how a person who has been mistreated, lied to, and ignored, totally lacking access to human compassion, can snap. The acting is top notch, and it puts a spotlight on the importance of mental health in modern times.","created_at":"2019-10-27T04:42:49.176Z","updated_at":"2021-06-23T15:58:28.328Z","author_details":{"name":"","rating":9,"username":"ikomrad","avatar_path":null}},{"id":"5dd9cdd528723c0014588c1f","url":"https://www.themoviedb.org/review/5dd9cdd528723c0014588c1f","author":"Sheldon Nylander","content":"$13","created_at":"2019-11-24T00:24:53.294Z","updated_at":"2021-06-23T15:58:29.293Z","author_details":{"name":"Sheldon Nylander","rating":7,"username":"dalboz","avatar_path":"/d9fi8H0uBIhn9B9WY8Avo5L1vzm.jpg"}},{"id":"5de278e63faba000150b67f4","url":"https://www.themoviedb.org/review/5de278e63faba000150b67f4","author":"Leno","content":"*A Masterpiece*.\r\n\r\nThe movie shows the escalating events that made Arthur become the Joker. Initially an inoffensive poor and sick man, Arthur suffered a tide of unfortunate events that pushed him closer and closer to the edge. \r\n\r\nIgnored and despised by everyone, sick and alone in the world, and neglected by the State, Arthur becomes progressively more violent until he breaks.\r\n\r\nMuch more than one more Super-hero movie, *Joker* uses well-known characters to promote the reflection on the \"ignored\" ones. At least, ignored until they become a Joker.","created_at":"2019-11-30T14:12:54.562Z","updated_at":"2021-06-23T15:58:29.470Z","author_details":{"name":"Leno","rating":9,"username":"fLeno","avatar_path":"/vNPHnw6jgbERZmhNlDk3OwL9KgH.jpg"}},{"id":"5df59eaad1a89300197854b5","url":"https://www.themoviedb.org/review/5df59eaad1a89300197854b5","author":"Wuchak","content":"$14","created_at":"2019-12-15T02:47:06.716Z","updated_at":"2021-06-23T15:58:29.935Z","author_details":{"name":"","rating":8,"username":"Wuchak","avatar_path":"/4KVM1VkqmXLOuwj1jjaSdxbvBDk.jpg"}},{"id":"5e0e888768188800145829f8","url":"https://www.themoviedb.org/review/5e0e888768188800145829f8","author":"JPV852","content":"_Joker_ is a tour-de-force of a movie, not quite like anything I've seen, maybe since Taxi Driver. At its core it's a movie about the breaking point of a broken man, wrapped under the banner of a comic book movie that, take out the Waynes, works on its own.\r\nJoaquin Phoenix truly gives a transformative performance (not unlike Heath Ledger) and will say is deserving of an Academy Award. The supporting cast all did well, though, and it is a small role, Zazie Beetz was great and De Niro had his moments, particularly at the end.\r\n\r\nGot to hand it to Todd Phillips, between this and the good, albeit flawed, War Dogs, has proven to be more than those Hangover movies.\r\n\r\nNo, this isn't a feel-good movie and while it does sit at the top of my 2019 list, not entirely sure when I'd revisit. **4.75/5**","created_at":"2020-01-03T00:19:19.624Z","updated_at":"2021-06-23T15:58:31.509Z","author_details":{"name":"","rating":9,"username":"JPV852","avatar_path":"/xNLOqXXVJf9m7WngUMLIMFsjKgh.jpg"}},{"id":"5e2f26e44ca676001249c3c2","url":"https://www.themoviedb.org/review/5e2f26e44ca676001249c3c2","author":"Matthew Brady","content":"$15","created_at":"2020-01-27T18:07:32.017Z","updated_at":"2021-06-23T15:58:33.464Z","author_details":{"name":"Matthew Brady","rating":8,"username":"MatthewL.Brady","avatar_path":"/k5J0l25FXOCw4TcX6iWaJmYpCZ4.jpg"}},{"id":"5e31cc72c56d2d001851772a","url":"https://www.themoviedb.org/review/5e31cc72c56d2d001851772a","author":"lamachat","content":"It is intersting to analyze this movie in a context of global increase of violent social movements against the Establishment. Joker succeed in making me accept a violent reactions without really explicit political fundation.","created_at":"2020-01-29T18:18:26.733Z","updated_at":"2021-06-23T15:58:33.586Z","author_details":{"name":"","rating":null,"username":"lamachat","avatar_path":null}},{"id":"5e4d8cba283ed900195ccff2","url":"https://www.themoviedb.org/review/5e4d8cba283ed900195ccff2","author":"Per Gunnar Jonsson","content":"$16","created_at":"2020-02-19T19:30:02.315Z","updated_at":"2024-05-16T15:21:17.497Z","author_details":{"name":"Per Gunnar Jonsson","rating":3,"username":"Dark Jedi","avatar_path":null}},{"id":"60739f5f7776f0005810629a","url":"https://www.themoviedb.org/review/60739f5f7776f0005810629a","author":"r96sk","content":"$17","created_at":"2021-04-12T01:16:15.424Z","updated_at":"2021-06-23T15:58:54.317Z","author_details":{"name":"","rating":10,"username":"r96sk","avatar_path":"/mwR7rFHoDcobAx1i61I3skzMW3U.jpg"}},{"id":"621a97793a48c5006d1e59e4","url":"https://www.themoviedb.org/review/621a97793a48c5006d1e59e4","author":"AstroNoud","content":"Carried by a terrific Phoenix, ‘Joker’ leaves an emotional impact as we see a bullied clown slowly transform into someone who enjoys creating chaos. Too bad we don't get to enjoy Phoenix as Joker more, though, because pretty soon after the turning point, the movie ends.\r\n\r\n10/10","created_at":"2022-02-26T21:11:21.299Z","updated_at":"2022-02-26T21:11:21.299Z","author_details":{"name":"","rating":10,"username":"AstroNoud","avatar_path":"/6zLnrhVdSDzTjhwjKxE5xQdk2Wu.jpg"}},{"id":"627f007f2dc9dc009eed60e9","url":"https://www.themoviedb.org/review/627f007f2dc9dc009eed60e9","author":"iltnoob","content":"It was exactly what it wanted to be, and it pulled it off perfectly. The \"slow\" parts add a lot to the atmosphere and it all culminates in a dramatic and unforgettable ending.","created_at":"2022-05-14T01:06:07.034Z","updated_at":"2022-06-15T19:25:02.498Z","author_details":{"name":"","rating":10,"username":"iltnoob","avatar_path":null}},{"id":"62dfa90b33a53305200fa01a","url":"https://www.themoviedb.org/review/62dfa90b33a53305200fa01a","author":"Martha","content":"I knew it was gonna be super hard for me to like a Joker after Heath Ledger... Cameron in Gotham did awesome, Leto was really insane as Mr. J. But, I wanted a Joker stand alone... And this is what they gave me...\r\n\r\nBrilliant. From start to finish i just was on the edge of my seat. This movie pulled at my heart. I saw myself in this character and understand every reason why a series of bad days could make a person ... Snap. Well done.","created_at":"2022-07-26T08:42:51.056Z","updated_at":"2022-07-26T14:24:11.525Z","author_details":{"name":"Martha","rating":10,"username":"MonsterMartha","avatar_path":null}},{"id":"63bf6cd423be46007cb9ab32","url":"https://www.themoviedb.org/review/63bf6cd423be46007cb9ab32","author":"GenerationofSwine","content":"It's not an incel movie, despite what people are saying. And it's no a White Supremacy film either. It's not even a pro T-word president film. In fact, it addresses some pretty heavy left wing issues. Or at least issues that were traditionally on the left before things went...weird and all topsy turvy.\r\n\r\nHowever, it is also NOT a Marvel Film, so of you are walking in expecting a Marvel style movie you will walk out hating it. So don't go in expecting an MCU film.\r\n\r\nInstead you get a dramatic, slow moving, intensely building movie that develops it's characters.\r\n\r\nAnd it really develops them, when you start watching the film the Joker was sympathetic... and by the time you walked out you really hated him.\r\n\r\nAnd that is all I feel comfortable saying without spoiling things.","created_at":"2023-01-12T02:13:40.091Z","updated_at":"2023-01-12T02:13:40.252Z","author_details":{"name":"","rating":10,"username":"GenerationofSwine","avatar_path":"/xYhvrFNntgAowjRsf6mRg9JgITr.jpg"}},{"id":"64a6df942b531d00e86cd12b","url":"https://www.themoviedb.org/review/64a6df942b531d00e86cd12b","author":"Andre Gonzales","content":"Really crazy dramatized movie. Slowly watching him go crazy. Pretty shocking ending and I wasn't expecting it.","created_at":"2023-07-06T15:36:52.490Z","updated_at":"2023-07-06T15:36:52.571Z","author_details":{"name":"Andre Gonzales","rating":6,"username":"SoSmooth1982","avatar_path":"/ast1oGYDI7Li9daLuOV4UxGiXj.jpg"}},{"id":"6538b07e9c24fc0126569ed9","url":"https://www.themoviedb.org/review/6538b07e9c24fc0126569ed9","author":"Alunauwie","content":"The scenario told in this film depicts a situation in which we frequently disregard the feelings and situations of others around us, people who may not have the same advantages as us. We can sense the psychological upheaval that Joker is experiencing from his point of view. All disappointment and rage build up and eventually explode. The people of Gotham rebelled as a result of their dissatisfaction and indignation at the injustice they faced.\r\n\r\nThe Joker is also seen dancing on a car in the midst of the rioting, surrounded by people shouting his name. Making them an embodiment of \"Hero\" in order for them to share their ideas.\r\n\r\nRead more for Indonesian review in\r\nhttp://www.alunauwie.com/2020/07/joker-all-i-have-are-negative-thoughts.html","created_at":"2023-10-25T06:06:54.631Z","updated_at":"2023-10-25T16:00:22.483Z","author_details":{"name":"","rating":9,"username":"Alunauwie","avatar_path":null}},{"id":"6613eb2b3d7454018507df9b","url":"https://www.themoviedb.org/review/6613eb2b3d7454018507df9b","author":"mehdiebrahimzadehofficial","content":"$18","created_at":"2024-04-08T13:03:39.998Z","updated_at":"2024-04-09T15:46:36.979Z","author_details":{"name":"","rating":null,"username":"mehdiebrahimzadehofficial","avatar_path":null}},{"id":"6902e664bd646073256e88aa","url":"https://www.themoviedb.org/review/6902e664bd646073256e88aa","author":"misubisu","content":"$19","created_at":"2025-10-30T04:15:32.889Z","updated_at":"2025-10-30T04:15:32.982Z","author_details":{"name":"misubisu","rating":5,"username":"misubisu","avatar_path":"/gYANFSSdtvtcGZqi2J2xzxRmQBx.jpg"}}],"recommendations":[{"id":466272,"adult":false,"title":"Once Upon a Time... in Hollywood","video":false,"overview":"Los Angeles, 1969. TV star Rick Dalton, a struggling actor specializing in westerns, and stuntman Cliff Booth, his best friend, try to survive in a constantly changing movie industry. Dalton is the neighbor of the young and promising actress and model Sharon Tate, who has just married the prestigious Polish director Roman Polanski…","genre_ids":[35,18,53],"media_type":"movie","popularity":13.2711,"vote_count":14577,"poster_path":"/8j58iEBw9pOXFD2L0nt0ZXeHviB.jpg","release_date":"2019-07-24","vote_average":7.423,"backdrop_path":"/kKTPv9LKKs5L3oO1y5FNObxAPWI.jpg","original_title":"Once Upon a Time... in Hollywood","original_language":"en"},{"id":559969,"adult":false,"title":"El Camino: A Breaking Bad Movie","video":false,"overview":"In the wake of his dramatic escape from captivity, Jesse Pinkman must come to terms with his past in order to forge some kind of future.","genre_ids":[80,18,53],"media_type":"movie","popularity":6.3644,"vote_count":5509,"poster_path":"/ePXuKdXZuJx8hHMNr2yM4jY2L7Z.jpg","release_date":"2019-10-11","vote_average":7.043,"backdrop_path":"/uLXK1LQM28XovWHPao3ViTeggXA.jpg","original_title":"El Camino: A Breaking Bad Movie","original_language":"en"},{"id":496243,"adult":false,"title":"Parasite","video":false,"overview":"All unemployed, Ki-taek's family takes peculiar interest in the wealthy and glamorous Parks for their livelihood until they get entangled in an unexpected incident.","genre_ids":[35,53,18],"media_type":"movie","popularity":32.1545,"vote_count":20183,"poster_path":"/7IiTTgloJzvGI1TAYymCfbfl3vT.jpg","release_date":"2019-05-30","vote_average":8.494,"backdrop_path":"/hiKmpZMGZsrkA3cdce8a7Dpos1j.jpg","original_title":"기생충","original_language":"ko"},{"id":492188,"adult":false,"title":"Marriage Story","video":false,"overview":"A stage director and an actress struggle through a grueling, coast-to-coast divorce that pushes them to their personal extremes.","genre_ids":[18],"media_type":"movie","popularity":4.7509,"vote_count":7315,"poster_path":"/2JRyCKaRKyJAVpsIHeLvPw5nHmw.jpg","release_date":"2019-09-28","vote_average":7.731,"backdrop_path":"/wDwQXLDUuiEaaiuWIDBpbqnwYGX.jpg","original_title":"Marriage Story","original_language":"en"},{"id":530915,"adult":false,"title":"1917","video":false,"overview":"At the height of the First World War, two young British soldiers must cross enemy territory and deliver a message that will stop a deadly attack on hundreds of soldiers.","genre_ids":[10752,36,18,28,12],"media_type":"movie","popularity":8.3821,"vote_count":13303,"poster_path":"/iZf0KyrE25z1sage4SYFLCCrMi9.jpg","release_date":"2019-12-25","vote_average":7.985,"backdrop_path":"/2lBOQK06tltt8SQaswgb8d657Mv.jpg","original_title":"1917","original_language":"en"},{"id":398978,"adult":false,"title":"The Irishman","video":false,"overview":"Pennsylvania, 1956. Frank Sheeran, a war veteran of Irish origin who works as a truck driver, accidentally meets mobster Russell Bufalino. Once Frank becomes his trusted man, Bufalino sends him to Chicago with the task of helping Jimmy Hoffa, a powerful union leader related to organized crime, with whom Frank will maintain a close friends