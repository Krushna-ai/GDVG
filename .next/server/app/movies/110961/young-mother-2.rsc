5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Young Mother 2\",\"description\":\"Yeong-gil is in graduate class and is stressed about getting a job. To make things worse, he's not had any experience with women yet, so he's always searching for something in his dreams but wakes up to nothing. Then one day, there is a change in his life, he puts his hand in The Box of Pandora and gets a job although it wasn't a regular position. He sleeps with his female superior during the interview even though it's not how he imagined it. Then one day, he visits Joo-yeon's home and meets her beautiful mother. Can he keep himself from being seduced by this woman?\",\"image\":\"https://image.tmdb.org/t/p/w500/4cKnB9YbAKgM028qd5ok5hf9nrF.jpg\",\"datePublished\":\"2014-05-29\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"erotic film\",\"Drama\",\"Romance\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.2,\"bestRating\":10,\"ratingCount\":18}}"}}],["$","$L10",null,{"initialDrama":{"id":"67715a8d-b0e5-4917-92a3-1f0b3317ae02","tmdb_id":276126,"imdb_id":"tt7652302","content_type":"movie","title":"Young Mother 2","original_title":"젊은 엄마 2","overview":"Yeong-gil is in graduate class and is stressed about getting a job. To make things worse, he's not had any experience with women yet, so he's always searching for something in his dreams but wakes up to nothing. Then one day, there is a change in his life, he puts his hand in The Box of Pandora and gets a job although it wasn't a regular position. He sleeps with his female superior during the interview even though it's not how he imagined it. Then one day, he visits Joo-yeon's home and meets her beautiful mother. Can he keep himself from being seduced by this woman?","poster_path":"/4cKnB9YbAKgM028qd5ok5hf9nrF.jpg","backdrop_path":"/8cgTc0Rw7dHGl1zePZacZ3rYn1m.jpg","release_date":"2014-05-29","first_air_date":null,"status":"published","original_language":"ko","origin_country":["KR"],"genres":[{"name":"erotic film"},{"id":18,"name":"Drama"},{"id":10749,"name":"Romance"},"erotic film"],"popularity":8.484,"vote_average":6.2,"vote_count":18,"runtime":89,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-01T21:58:44.078398+00:00","updated_at":"2026-02-22T21:19:03.338+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[],"production_countries":[{"name":"South Korea","iso_3166_1":"KR"}],"spoken_languages":[{"name":"한국어/조선말","iso_639_1":"ko","english_name":"Korean"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[{"id":33841,"name":"incest"},{"id":155477,"name":"softcore"}],"alternative_titles":[{"type":"romanization","title":"Jeolm-eun eom-ma-2","iso_3166_1":"KR"}],"videos":[],"watch_providers":{"results":{}},"wikidata_id":"Q22974875","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"KR","main_poster":"/4cKnB9YbAKgM028qd5ok5hf9nrF.jpg","images":{"logos":[],"posters":[{"width":740,"height":1054,"file_path":"/4cKnB9YbAKgM028qd5ok5hf9nrF.jpg","iso_639_1":"id","vote_average":0.166},{"width":1200,"height":1800,"file_path":"/4qRfmz6jShJ3qg65QLMVdC1avWY.jpg","iso_639_1":null,"vote_average":0},{"width":1200,"height":1800,"file_path":"/2Ovjr2XCHCvwyI5Pf6xZvuVO0oc.jpg","iso_639_1":null,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/8cgTc0Rw7dHGl1zePZacZ3rYn1m.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T07:08:11.334+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Young Mother 2","runtime":89,"tagline":"","homepage":"","overview":"Yeong-gil is in graduate class and is stressed about getting a job. To make things worse, he's not had any experience with women yet, so he's always searching for something in his dreams but wakes up to nothing. Then one day, there is a change in his life, he puts his hand in The Box of Pandora and gets a job although it wasn't a regular position. He sleeps with his female superior during the interview even though it's not how he imagined it. Then one day, he visits Joo-yeon's home and meets her beautiful mother. Can he keep himself from being seduced by this woman?"},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"젊은 엄마 2","runtime":89,"tagline":"","homepage":"","overview":"첫 경험에 대한 치명적인 유혹  거부할 수 없는 판도라의 상자가 열린다!  대학 졸업반인 영길은 취업에 대한 스트레스로 연일 힘든 나날을 보내고 있다. 설상가상으로 아직까지 여자 경험이 없는 영길은 첫 경험에 대한 강한 열망으로 매일 밤 꿈 속을 헤매지만 깨어보면 한낮 백일몽에 불과하다. 그러던 어느 날, 영길의 일상에 변화가 생기기 시작한다. 우연히 손에 넣은 판도라의 상자를 열게 된 후, 비정규직이긴 하지만 일거리를 얻었고, 원하는 방식은 아니었지만 면접 자리에서 여자 상사와 첫 경험도 하게 된다. 그리고 오늘의 역할 대행은 까칠하고 싸가지 없는 주연의 남자 친구. 그렇게 찾아 가게 된 주연의 집에서 뜻밖에 젊고 아름다운 그녀의 엄마를 만난다. 영길은 거부 할 수 없는 젊은 엄마의 치명적인 유혹에서 빠져 나올 수 있을까?"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"年轻母亲2","runtime":89,"tagline":"年轻母亲2","homepage":"","overview":"Yeong gil在研究生班，强调的是找份工作。更糟糕的是，他还没有和女人的任何经历，所以他总是在梦中寻找一些东西，但却什么也没有醒来。然后有一天，他的生活发生了变化，他把手放在潘多拉的盒子里，得到了一份工作，虽然这不是一个固定的位置。他与他的女上司在采访中睡觉，尽管这不是他想象的那样。然后有一天，他去Joo yeon的家，遇到了她的美丽的母亲。他能阻止自己被这个女人勾引吗？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Young Mother 2","runtime":0,"tagline":"","homepage":"","overview":"Yeong Gil está en la clase de posgrado y está estresado por conseguir un trabajo. Para empeorar las cosas, todavía no ha tenido ninguna experiencia con mujeres, por lo que siempre está buscando algo en sus sueños pero no se despierta. Entonces, un día, hay un cambio en su vida, pone su mano en La Caja de Pandora y consigue un trabajo aunque no era un puesto regular. Duerme con su superiora durante la entrevista, aunque no es como se lo imaginó. Entonces, un día, visita la casa de Joo Yeon y conoce a su hermosa madre."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"年輕母親2","runtime":0,"tagline":"","homepage":"","overview":"一個缺乏性經驗的青年，在朋友珠妍的家裡遇到了她的漂亮媽媽後，被激發起性的本能"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"年輕母親 2","runtime":0,"tagline":"","homepage":"","overview":"一個缺乏性經驗的青年，在朋友珠妍的家裏遇到了她的漂亮媽媽後，被激發起性的本能"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":366170,"adult":false,"title":"Yu-Gi-Oh!: The Dark Side of Dimensions","video":false,"overview":"Having faced each other on countless occasions, Yugi and Kaiba again put their pride and experience to the test in a duel that transcends dimensions.","genre_ids":[12,16],"media_type":"movie","popularity":1.6354,"vote_count":455,"poster_path":"/ti0CRprP9iSg9IDadTZ3TFnuczS.jpg","release_date":"2016-04-23","vote_average":7.6,"backdrop_path":"/s9q3uNEjqHnLDgPX78Yfaoy8p1I.jpg","original_title":"遊☆戯☆王 THE DARK SIDE OF DIMENSIONS","original_language":"ja"},{"id":616219,"adult":false,"title":"Shining Modern History","video":false,"overview":"Hyeon Dae and Min Joo thought one of them getting married would end the sex-partner relationship. However, they can't hold in their desires and Hyeon Dae destroys himself with sex, while Min Joo can't give up what she can't have. At the same time, they have a complicated and ugly relationship with past characters.","genre_ids":[18,10749],"media_type":"movie","popularity":1.6746,"vote_count":11,"poster_path":"/ppjHTqju6TriB9wSjIwURdDmQlP.jpg","release_date":"2019-07-18","vote_average":4.3,"backdrop_path":"/shH1PjPD7pjEZg0fJtWXlHa3Do7.jpg","original_title":"발광하는 현대사","original_language":"ko"},{"id":109149,"adult":false,"title":"Perfect Education: A Maid for You","video":false,"overview":"The seventh film of “The Perfect Education” series tells the tale of a man and a girl who pursue love to the point of madness. With erotic dances and love scenes shot in 3D, the film dpicts a “pure love” story tied with sexual desires. “Welcome home, Master!” Kabashima is a regular at the maid cafe. He is head over heels in love with Ichigo, a maid who works there. On her birthday, he is waiting for her by the back door, she exits finally…several hours later, she awakes only to find herself surrounded by thin, plywood walls, her feel, hand, and mouth bound and gagged with packing tape. Amid the darkness, Kabashima quietly opens his mouth, “this is our house. Let’s live intimately together.”","genre_ids":[18],"media_type":"movie","popularity":0.5965,"vote_count":2,"poster_path":"/jJDcQBVttj6zcDhmrBsnTnag8DJ.jpg","release_date":"2010-01-30","vote_average":2.5,"backdrop_path":"/10Yy2TfqAtOTmQD9i1a0l0SCLrg.jpg","original_title":"完全なる飼育 メイド、for you","original_language":"ja"},{"id":76600,"adult":false,"title":"Avatar: The Way of Water","video":false,"overview":"Set more than a decade after the events of the first film, learn the story of the Sully family (Jake, Neytiri, and their kids), the trouble that follows them, the lengths they go to keep each other safe, the battles they fight to stay alive, and the tragedies they endure.","genre_ids":[28,12,878],"media_type":"movie","popularity":38.9747,"vote_count":13731,"poster_path":"/t6HIqrRAclMCA60NsSmeqe9RmNV.jpg","release_date":"2022-12-14","vote_average":7.598,"backdrop_path":"/cd8YDn7M0lfaHhZdU6MvCDxPalP.jpg","original_title":"Avatar: The Way of Water","original_language":"en"},{"id":811948,"adult":false,"title":"Demon Slayer: Kimetsu no Yaiba - The Hashira Meeting Arc","video":true,"overview":"Tanjiro and Nezuko have been apprehended by the Demon Slayer Hashira, a group of extremely skilled swordfighters. Tanjiro undergoes trial for violating the Demon Slayer code, specifically smuggling Nezuko, a Demon, onto Mt. Natagumo. A recap of Kimetsu no Yaiba episodes 22–26, with new footage and special end credits.","genre_ids":[16,28,14,53],"media_type":"movie","popularity":3.9763,"vote_count":256,"poster_path":"/j1FpReEQXp8JsgNQZcfGvzeXNoI.jpg","release_date":"2021-12-01","vote_average":7.018,"backdrop_path":"/daeD5T4MxFk5MppZlaNZoaK6lE9.jpg","original_title":"鬼滅の刃 柱合会議・蝶屋敷編","original_language":"ja"},{"id":539686,"adult":false,"title":"Shamshera","video":true,"overview":"Set in the 1800s, the film is about a \"dacoit\" tribe who take charge in fight for their rights and independence against the British.","genre_ids":[28,18,12],"media_type":"movie","popularity":0.9291,"vote_count":55,"poster_path":"/rryN6GhaoovO3sM8IEqGyKgCmXf.jpg","release_date":"2022-07-22","vote_average":5.482,"backdrop_path":"/dNozI03ORnJVydsHPe1SoHGk0cM.jpg","original_title":"शमशेरा","original_language":"hi"},{"id":604822,"adult":false,"title":"Vanguard","video":false,"overview":"Covert security company Vanguard is the last hope of survival for an accountant after he is targeted by the world's deadliest mercenary organization.","genre_ids":[28,12,35,80,53],"media_type":"movie","popularity":2.4582,"vote_count":596,"poster_path":"/mKvw1Ic9enfFlCPBNJGiejRPMUO.jpg","release_date":"2020-01-22","vote_average":6.4,"backdrop_path":"/4TGqXMsy9qM2nAUq4rYrErjkMXL.jpg","original_title":"急先锋","original_language":"zh"},{"id":279229,"adult":false,"title":"Sapphire Blue","video":false,"overview":"Gwen has just discovered, that she's the final member of the secret time-traveling Circle of Twelve. Now she has to juggle with constant trips to the past, her relationships with Gideon and figuring out dark secrets surrounding the Circle.","genre_ids":[14,10749,18],"media_type":"movie","popularity":3.0299,"vote_count":1020,"poster_path":"/kxRqokSkj6HWuwVCbnddPFg73CM.jpg","release_date":"2014-08-14","vote_average":7.106,"backdrop_path":"/y95HIJdesNQQaujZkGZczX7ejp2.jpg","original_title":"Saphirblau","original_language":"de"},{"id":603206,"adult":false,"title":"Dream Horse","video":false,"overview":"The inspiring true story of Dream Alliance, an unlikely race horse bred by small town bartender, Jan Vokes. With very little money and no experience, Jan convinces her neighbors to chip in their meager earnings to help raise Dream and compete with the racing elites. Their investment pays off as Dream rises through the ranks and becomes a beacon of hope in their struggling community.","genre_ids":[35,18],"media_type":"movie","popularity":1.183,"vote_count":135,"poster_path":"/uF1mnSdf9EqDIm5XfODAHU6AcWC.jpg","release_date":"2021-05-21","vote_average":7,"backdrop_path":"/rZpyIeadpjHDJDBdl7BNLRtPF49.jpg","original_title":"Dream Horse","original_language":"en"},{"id":768744,"adult":false,"title":"My Hero Academia: World Heroes' Mission","video":false,"overview":"A mysterious group called Humarize strongly believes in the Quirk Singularity Doomsday theory which states that when quirks get mixed further in with future generations, that power will bring forth the end of humanity. In order to save everyone, the Pro-Heroes around the world ask UA Academy heroes-in-training to assist them and form a world-class selected hero team. It’s up to the heroes to save the world and the future of heroes in what is the most dangerous crisis to take place yet in My Hero Academia.","genre_ids":[16,28,12,878],"media_type":"movie","popularity":4.7849,"vote_count":606,"poster_path":"/AsTlA7dj2ySGY1pzGSD0MoHFhEF.jpg","release_date":"2021-08-06","vote_average":7.6,"backdrop_path":"/g3pIN5kRvmtcdtzjsJomZ1sw2QO.jpg","original_title":"僕のヒーローアカデミア THE MOVIE ワールド ヒーローズ ミッション","original_language":"ja"},{"id":1045944,"adult":false,"title":"The Boss Baby: Christmas Bonus","video":false,"overview":"Christmas Eve takes a twisty turn when the Boss Baby accidentally swaps places with one of Santa's elves and gets stranded at the North Pole.","genre_ids":[16,10751,12],"media_type":"movie","popularity":1.5498,"vote_count":314,"poster_path":"/iMmMxF6f2OonUrXrHKBLSYAhXly.jpg","release_date":"2022-12-06","vote_average":6.683,"backdrop_path":"/nITzFbM1JS7WEvFjjGL0kCb2yPr.jpg","original_title":"The Boss Baby: Christmas Bonus","original_language":"en"},{"id":1013870,"adult":false,"title":"Kids vs. Aliens","video":false,"overview":"All Gary wants is to make awesome home movies with his best buds. All his older sister Samantha wants is to hang with the cool kids. When their parents head out of town one Halloween weekend, an all-time rager of a teen house party turns to terror when aliens attack, forcing the siblings to band together to survive the night.","genre_ids":[27,878,53],"media_type":"movie","popularity":0.5189,"vote_count":82,"poster_path":"/f87UCQzVwMlzGFePtCtZS4TgAFp.jpg","release_date":"2023-01-20","vote_average":5.354,"backdrop_path":"/qkv9i6XvM5O7iYYsJHQff4ZN01J.jpg","original_title":"Kids vs. Aliens","original_language":"en"},{"id":533592,"adult":false,"title":"Scooby-Doo! and the Gourmet Ghost","video":false,"overview":"The Scooby gang visits a culinary resort run by Fred's uncle, Bobby Flay. While enjoying the sights, a ghost attacks the guests and destroys the resort, leaving the gang to put a stop to its threat.","genre_ids":[16,12,10751,35],"media_type":"movie","popularity":1.0698,"vote_count":173,"poster_path":"/AtHngeqD4K1Oj01ulWc1aDJhU8H.jpg","release_date":"2018-08-28","vote_average":7.994,"backdrop_path":"/ySEZExyAwNJN3iCSdHxNsHelLAU.jpg","original_title":"Scooby-Doo! and the Gourmet Ghost","original_language":"en"},{"id":953553,"adult":false,"title":"Gabriel's Rapture: Part II","video":false,"overview":"In the fifth installment of the Gabriel's Inferno series, Gabriel and Julia’s happiness is threatened by a conspiring student and academic politics. When Gabriel is confronted b