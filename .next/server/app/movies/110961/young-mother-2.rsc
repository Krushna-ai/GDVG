9:{"metadata":[["$","title","0",{"children":"Young Mother 2 | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Yeong-gil is in graduate class and is stressed about getting a job. To make things worse, he's not had any experience with women yet, so he's always searching for something in his dreams but wakes up to nothing. Then one day, there is a change in his life, he puts his hand in The Box of Pandora and gets a job although it wasn't a regular position. He sleeps with his female superior during the interview even though it's not how he imagined it. Then one day, he visits Joo-yeon's home and meets her beautiful mother. Can he keep himself from being seduced by this woman?"}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/110961/young-mother-2"}],["$","meta","5",{"property":"og:title","content":"Young Mother 2"}],["$","meta","6",{"property":"og:description","content":"Yeong-gil is in graduate class and is stressed about getting a job. To make things worse, he's not had any experience with women yet, so he's always searching for something in his dreams but wakes up to nothing. Then one day, there is a change in his life, he puts his hand in The Box of Pandora and gets a job although it wasn't a regular position. He sleeps with his female superior during the interview even though it's not how he imagined it. Then one day, he visits Joo-yeon's home and meets her beautiful mother. Can he keep himself from being seduced by this woman?"}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/110961/young-mother-2"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/4cKnB9YbAKgM028qd5ok5hf9nrF.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10