9:{"metadata":[["$","title","0",{"children":"Joaquim | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Brazil, 18th century. The colony of Portugal endures a decline in gold production. A Portuguese minority rules over a corrupt and autocratic society. Joaquim is an efficient soldier, famous for capturing gold smugglers. While waiting for his promotion to Lieutenant, he leaves for a risky mission in search of new gold mines - the only way to buy the freedom of Blackie, a slave he is in love with. Inspired by the true story of Tiradentes, the first leader of the Brazilian revolutionary movement."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148330/joaquim"}],["$","meta","5",{"property":"og:title","content":"Joaquim"}],["$","meta","6",{"property":"og:description","content":"Brazil, 18th century. The colony of Portugal endures a decline in gold production. A Portuguese minority rules over a corrupt and autocratic society. Joaquim is an efficient soldier, famous for capturing gold smugglers. While waiting for his promotion to Lieutenant, he leaves for a risky mission in search of new gold mines - the only way to buy the freedom of Blackie, a slave he is in love with. Inspired by the true story of Tiradentes, the first leader of the Brazilian revolutionary movement."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148330/joaquim"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/y1KE2HYfKHwXN0j454Fqf60CIh3.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Joaquim"}],["$","meta","12",{"name":"twitter:description","content":"Brazil, 18th century. The colony of Portugal endures a decline in gold production. A Portuguese minority rules over a corrupt and autocratic society. Joaquim is an efficient soldier, famous for capturing gold smugglers. While waiting for his promotion to Lieutenant, he leaves for a risky mission in search of new gold mines - the only way to buy the freedom of Blackie, a slave he is in love with. Inspired by the true story of Tiradentes, the first leader of the Brazilian revolutionary movement."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/y1KE2HYfKHwXN0j454Fqf60CIh3.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
