5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Joaquim\",\"description\":\"Brazil, 18th century. The colony of Portugal endures a decline in gold production. A Portuguese minority rules over a corrupt and autocratic society. Joaquim is an efficient soldier, famous for capturing gold smugglers. While waiting for his promotion to Lieutenant, he leaves for a risky mission in search of new gold mines - the only way to buy the freedom of Blackie, a slave he is in love with. Inspired by the true story of Tiradentes, the first leader of the Brazilian revolutionary movement.\",\"image\":\"https://image.tmdb.org/t/p/w500/y1KE2HYfKHwXN0j454Fqf60CIh3.jpg\",\"datePublished\":\"2017-04-20\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"BR\",\"inLanguage\":\"pt\",\"genre\":[\"Drama\",\"History\",null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7,\"bestRating\":10,\"ratingCount\":17}}"}}],["$","$L10",null,{"initialDrama":{"id":"cbf86364-e7f5-455f-88c1-3ad2a8500d3f","tmdb_id":436349,"imdb_id":"tt4895628","content_type":"movie","title":"Joaquim","original_title":"Joaquim","overview":"Brazil, 18th century. The colony of Portugal endures a decline in gold production. A Portuguese minority rules over a corrupt and autocratic society. Joaquim is an efficient soldier, famous for capturing gold smugglers. While waiting for his promotion to Lieutenant, he leaves for a risky mission in search of new gold mines - the only way to buy the freedom of Blackie, a slave he is in love with. Inspired by the true story of Tiradentes, the first leader of the Brazilian revolutionary movement.","poster_path":"/y1KE2HYfKHwXN0j454Fqf60CIh3.jpg","backdrop_path":"/mwU1pRytsXVOy91yrQZCpOddnOk.jpg","release_date":"2017-04-20","first_air_date":null,"status":"published","original_language":"pt","origin_country":["BR"],"genres":[{"id":18,"name":"Drama"},{"id":36,"name":"History"},"biographical film","drama film"],"popularity":3.8312,"vote_average":7,"vote_count":17,"runtime":97,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-25T00:54:12.139307+00:00","updated_at":"2026-02-25T00:54:11.985+00:00","tagline":null,"homepage":"https://facebook.com/joaquimofilme/","budget":0,"revenue":0,"production_companies":[{"id":8680,"name":"Ukbar Filmes","logo_path":"/lTvO3MFX5eogjWEpWmLUipxeKVi.png","origin_country":"PT"},{"id":32606,"name":"REC Produtores Associados","logo_path":"/mzMiVv4SNmqgiFqxekIPueW4YKf.png","origin_country":"BR"}],"production_countries":[{"name":"Portugal","iso_3166_1":"PT"},{"name":"Brazil","iso_3166_1":"BR"}],"spoken_languages":[{"name":"Español","iso_639_1":"es","english_name":"Spanish"},{"name":"Português","iso_639_1":"pt","english_name":"Portuguese"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[],"alternative_titles":[],"videos":[{"id":"62ffc875839d93007b62720e","key":"5PlEaR0R9fQ","name":"JOAQUIM dir. Marcelo Gomes","site":"YouTube","size":1080,"type":"Trailer","official":false,"iso_639_1":"en","iso_3166_1":"US","published_at":"2018-02-25T22:07:12.000Z"}],"watch_providers":{"results":{"BR":{"buy":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":13}],"link":"https://www.themoviedb.org/movie/436349-joaquim/watch?locale=BR","rent":[{"logo_path":"/8z7rC8uIDaTM91X0ZfkRf04ydj2.jpg","provider_id":3,"provider_name":"Google Play Movies","display_priority":13}],"flatrate":[{"logo_path":"/7EpFKOCMrlo3bjsyBMrec64c7Wb.jpg","provider_id":484,"provider_name":"Claro tv+","display_priority":21},{"logo_path":"/rvepVasXaE7VFNNXR9pm0tGMu97.jpg","provider_id":2157,"provider_name":"Reserva Imovision Amazon Channel","display_priority":57}]},"ES":{"link":"https://www.themoviedb.org/movie/436349-joaquim/watch?locale=ES","flatrate":[{"logo_path":"/kO2SWXvDCHAquaUuTJBuZkTBAuU.jpg","provider_id":63,"provider_name":"Filmin","display_priority":7}]}}},"wikidata_id":"Q28226119","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-25T00:54:12.139307+00:00","region":null,"main_poster":null,"images":{"logos":[],"posters":[{"width":1000,"height":1460,"file_path":"/y1KE2HYfKHwXN0j454Fqf60CIh3.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":2,"aspect_ratio":0.685,"vote_average":3.334},{"width":640,"height":960,"file_path":"/eKfMerCWSnXe7fhcT54yEFnjzXC.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":640,"height":960,"file_path":"/rOo44MDyKeyoqdsoXNLSRtLQnuD.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":800,"height":1200,"file_path":"/aWY58P9tkQQMx3vq2Fdh5R7o1Mf.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1400,"height":787,"file_path":"/mwU1pRytsXVOy91yrQZCpOddnOk.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.779,"vote_average":3.334},{"width":1400,"height":787,"file_path":"/giVycoIZsL4m3QOn8i8MrYb1JJj.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.779,"vote_average":3.334}]},"enriched_at":"2026-04-21T04:50:44.15+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Joaquim","runtime":0,"tagline":"","homepage":"","overview":"Século XVIII. A colônia dos Brasis, parte do Império Português, enfrenta um declínio na produção de ouro. Uma minoria portuguesa governa de forma autoritária e corrupta uma sociedade composta, em sua maioria, por escravos africanos, indígenas e mestiços. Joaquim é um militar de destaque na captura de contrabandistas de ouro. Ele espera que sua dedicação seja recompensada com uma patente de tenente para que possa comprar a liberdade da escrava Preta, por quem é apaixonado. A promoção nunca chega, ele se desespera. Neste momento, Joaquim é designado para uma arriscada missão: encontrar novas minas de ouro no temido Sertão Proibido. Cumpri-la será a única forma de conseguir sua promoção e a liberdade de sua amada."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":97,"tagline":"","homepage":"https://facebook.com/joaquimofilme/","overview":"Brazil, 18th century. The colony of Portugal endures a decline in gold production. A Portuguese minority rules over a corrupt and autocratic society. Joaquim is an efficient soldier, famous for capturing gold smugglers. While waiting for his promotion to Lieutenant, he leaves for a risky mission in search of new gold mines - the only way to buy the freedom of Blackie, a slave he is in love with. Inspired by the true story of Tiradentes, the first leader of the Brazilian revolutionary movement."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"淘金英雄","runtime":0,"tagline":"","homepage":"","overview":"滂沱大雨中隱見砍下的首級橫擱樹墩，華堅一早已預見自己的命運。18 世紀的巴西，他受僱於葡萄牙殖民政府捉拿淘金走私犯，為了錢及女人，參與尋覓新金礦的危險任務。一行五人各懷鬼胎深入叢林，陰謀衝突逐步浮現，華堅終於覺醒。高美斯以半真實半虛構重塑巴西民族英雄的傳奇，以西部片的冷靜視角曝露殖民地時代的壓迫剝削，至今仍殘存於巴西社會。手提攝影機追蹤華堅的軌跡，捕捉他的躁動不安與對不義制度的怒火，至投身革命爭取國家獨立的決意，其餘的已是歷史。入圍柏林影展角逐金熊獎。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"诺金","runtime":95,"tagline":"","homepage":"","overview":"在十八世纪葡萄牙的巴西殖民地，有一个名叫诺金的男人，他因为出身的原因升职无望，还处处受人牵制，直到有一天，他爱上一个名叫小黑的奴隶，他想花钱把小黑买下来，然而小黑的主人却不同意，就在诺金努力跟小黑的主人沟通的时候，小果因为不堪忍受主人的压迫，杀了主人逃跑了。 就在此时，诺金却得到了一个机会，如果他能找到金子，那么他便可以升职，也意味着他可以得到绝对的话语权，于是他带着几个同行的人开启了自己的寻金之路，因为一路上条件艰苦，同行的人都没能坚持下去，于是他独自出发，锲而不舍的寻找，终于，诺金找到了梦寐以求的金子，但此时的诺金，也彻底改变了自己的想法，发出一声反抗的呐喊，走上了革命的道路。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":97,"tagline":"","homepage":"","overview":"Brazilië in de 18de eeuw. Er is een groeiende bezorgdheid in deze Portugese kolonie waar de goudwinning in verval is. Het land wordt geregeerd door corrupte koloniale ambtenaren. Luitenant Joaquim heeft naam gemaakt als jager op goudsmokkelaars."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":97,"tagline":"","homepage":"","overview":"Au 18e siècle, le Brésil est dirigé par des officiers coloniaux corrompus. Joaquim est un soldat célèbre pour avoir capturé des contrebandiers d’or. Lorsqu’il part pour une mission risquée, l’injustice dont il est témoin le pousse à devenir Tiradentes, leader du mouvement révolutionnaire brésilien."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"En el Brasil del siglo XVIII, la producción de oro se hunde mientras una pequeña élite portuguesa controla una sociedad llena de corrupción y abuso de poder."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"}],"reviews_tmdb":[],"recommendations":[{"id":427,"adult":false,"title":"Mon Oncle","video":false,"overview":"Genial, bumbling Monsieur Hulot loves his top-floor apartment in a grimy corner of the city, and cannot fathom why his sister's family has moved to the suburbs. Their house is an ultra-modern nightmare, which Hulot only visits for the sake of stealing away his rambunctious young nephew. Hulot's sister, however, wants to win him over to her new way of life, and conspires to set him up with a wife and job.","genre_ids":[35],"media_type":"movie","popularity":0.7842,"vote_count":602,"poster_path":"/wH6RyPiXFy8INLbViVkchLVOmBc.jpg","release_date":"1958-05-10","vote_average":7.4,"backdrop_path":"/hSbkxFnGi99pueUze7KUJuy9CWE.jpg","original_title":"Mon oncle","original_language":"fr"},{"id":548544,"adult":false,"title":"Invisible Life","video":false,"overview":"Rio de Janeiro, Brazil, 1950. In the conservative home of the Gusmão family, Eurídice and Guida are two inseparable sisters who support each other. While Guida can share with her younger sister the details of her romantic adventures, Eurídice finds in her older sister the encouragement she needs to pursue her dream of becoming a professional pianist.","genre_ids":[18],"media_type":"movie","popularity":0.7189,"vote_count":337,"poster_path":"/dHmy5vHcEfeBfy72sWxAdeSBLmn.jpg","release_date":"2019-08-30","vote_average":7.8,"backdrop_path":"/u2Av6NyDeLkwYTBXxIGousLNzz.jpg","original_title":"A Vida Invisível","original_language":"pt"},{"id":447450,"adult":false,"title":"The Beautiful Occasion","video":false,"overview":"A fun fair, on a wasteland, on the outskirts of a small provincial town in the south of France.","genre_ids":[18],"media_type":"movie","popularity":0.0775,"vote_count":4,"poster_path":"/8tl7tcJEQtGW729E9HdfwGOJuLQ.jpg","release_date":"2017-04-12","vote_average":4.25,"backdrop_path":"/xIwPTLKeQ7ag3dySd41vCGzfc7q.jpg","original_title":"La belle occasion","original_language":"fr"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":23.0611,"vote_count":11386,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":105,"adult":false,"title":"Back to the Future","video":false,"overview":"Eighties teenager Marty McFly is accidentally sent back in time to 1955, inadvertently disrupting his parents' first meeting and attracting his mother's romantic interest. Marty must repair the damage to history by rekindling his parents' romance and - with the help of his eccentric inventor friend Doc Brown - return to 1985.","genre_ids":[12,35,878],"media_type":"movie","popularity":18.3599,"vote_count":21418,"poster_path":"/vN5B5WgYscRGcQpVhHl6p9DDTP0.jpg","release_date":"1985-07-03","vote_average":8.323,"backdrop_path":"/qskzmLTbarKnXDbo2HRj4NJ3vcW.jpg","original_title":"Back to the Future","original_language":"en"},{"id":13510,"adult":false,"title":"Eden Lake","video":false,"overview":"When a young couple goes to a remote wooded lake for a romantic getaway, their quiet weekend is shattered by an aggressive group of local kids. Rowdiness quickly turns to rage as the teens terrorize the couple in unimaginable ways, and a weekend outing becomes a bloody battle for survival.","genre_ids":[27,53],"media_type":"movie","popularity":5.0582,"vote_count":2024,"poster_path":"/tOg6ElTe1mJwaCFN0172U4oso22.jpg","release_date":"2008-09-12","vote_average":6.832,"backdrop_path":"/s9v1QZMVhwShQ7415jPhtfqzyjG.jpg","original_title":"Eden Lake","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":30.0131,"vote_count":26824,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.903,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":466272,"adult":false,"title":"Once Upon a Time... in Hollywood","video":false,"overview":"Los Angeles, 1969. TV star Rick Dalton, a struggling actor specializing in westerns, and stuntman Cliff Booth, his best friend, try to survive in a constantly changing movie industry. Dalton is the neighbor of the young and promising actress and model Sharon Tate, who has just married the prestigious Polish director Roman Polanski…","genre_ids":[35,18,53],"media_type":"movie","popularity":13.2711,"vote_count":14577,"poster_path":"/8j58iEBw9pOXFD2L0nt0ZXeHviB.jpg","release_date":"2019-07-24","vote_average":7.423,"backdrop_path":"/kKTPv9LKKs5L3oO1y5FNObxAPWI.jpg","original_title":"Once Upon a Time... in Hollywood","original_language":"en"},{"id":297222,"adult":false,"title":"PK","video":false,"overview":"A stranger in the city asks questions no one has asked before. Known only by his initials, the man's innocent questions and childlike curiosity take him on a journey of love, laughter and letting go.","genre_ids":[35,18,878],"media_type":"movie","popularity":7.0848,"vote_count":1122,"poster_path":"/z2x2Y4tncefsIU7h82gmUM5vnBJ.jpg","release_date":"2014-12-18","vote_average":7.698,"backdrop_path":"/gxfvtq5eYiClS2X7hxAAPBNrbWA.jpg","original_title":"पीके","original_language":"hi"},{"id":272,"adult":false,"title":"Batman Begins","video":false,"overview":"Driven by tragedy, billionaire Bruce Wayne dedicates his life to uncovering and defeating the corruption that plagues his home, Gotham City.  Unable to work within the system, he instead creates a new identity, a symbol of fear for the criminal underworld - The Batman.","genre_ids":[18,80,28],"media_type":"movie","popularity":13.2944,"vote_count":22280,"poster_path":"/sPX89Td70IDDjVr85jdSBb4rWGr.jpg","release_date":"2005-06-10","vote_average":7.721,"backdrop_path":"/9IIBboV7MCT0bTxzXHmWK1Hq558.jpg","original_title":"Batman Begins","original_language":"en"},{"id":475557,"adult":false,"title":"Joker","video":false,"overview":"During the 1980s, a failed stand-up comedian is driven insane and turns to a life of crime and chaos in Gotham City while becoming an infamous psychopathic crime figure.","genre_ids":[80,53,18],"media_type":"movie","popularity":19.3785,"vote_count":27338,"poster_path":"/udDclJoHjfjb8Ekgsd4FDteOkCU.jpg","release_date":"2019-10-01","vote_average":8.128,"backdrop_path":"/hO7KbdvGOtDdeg0W4Y5nKEHeDDh.jpg","original_title":"Joker","original_language":"en"},{"id":19995,"adult":false,"title":"Avatar","video":false,"overview":"In the 22nd century, a paraplegic Marine is dispatched to the moon Pandora on a unique mission, but becomes torn between following orders and protecting an alien civilization.","genre_ids":[28,12,14,878],"media_type":"movie","popularity":34.6739,"vote_count":33504,"poster_path":"/gKY6q7SjCkAU6FqvqWybDYgUKIF.jpg","release_date":"2009-12-16","vote_average":7.6,"backdrop_path":"/vL5LR6WdxWPjLPFRLe133jXWsh5.jpg","original_title":"Avatar","original_language":"en"},{"id":49530,"adult":false,"title":"In Time","video":false,"overview":"In the not-too-distant future, the aging gene has been switched off. To avoid overpopulation, time has become the currency and the way people pay for luxuries and necessities. The rich can live forever, while the rest struggle to negotiate for their immortality. A poor young man who suddenly comes into a fortune of time finds himself on the run from a corrupt police force known as the \"time keepers\".","genre_ids":[28,53,878],"media_type":"movie","popularity":8.4209,"vote_count":11972,"poster_path":"/3Mwj2sIONQckOZP3YwsUXF7U5I4.jpg","release_date":"2011-10-27","vote_average":6.97,"backdrop_path":"/pxL08w7Eq0vKrQ3mJzYp0VHGaKG.jpg","original_title":"In Time","original_language":"en"},{"id":150540,"adult":false,"title":"Inside Out","video":false,"overview":"When 11-year-old Riley moves to a new city, her Emotions team up to help her through the transition. Joy, Fear, Anger, Disgust and Sadness work together, but when Joy and Sadness get lost, they must journey through unfamiliar places to get back home.","genre_ids":[16,10751,12,18,35],"media_type":"movie","popularity":15.6425,"vote_count":23187,"poster_path":"/2H1TmgdfNtsKlU9jKdeNyYL5y8T.jpg","release_date":"2015-06-17","vote_average":7.909,"backdrop_path":"/jJKZaTBNenlFclQyjrnvzkRmvWE.jpg","original_title":"Inside Out","original_language":"en"},{"id":97630,"adult":false,"title":"Zero Dark Thirty","video":false,"overview":"A chronicle of the decade-long hunt for al-Qaeda terrorist leader Osama bin Laden a