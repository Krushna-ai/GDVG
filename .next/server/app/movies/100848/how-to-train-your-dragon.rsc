5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"How to Train Your Dragon\",\"description\":\"On the rugged isle of Berk, where Vikings and dragons have been bitter enemies for generations, Hiccup stands apart, defying centuries of tradition when he befriends Toothless, a feared Night Fury dragon. Their unlikely bond reveals the true nature of dragons, challenging the very foundations of Viking society.\",\"image\":\"https://image.tmdb.org/t/p/w500/41dfWUWtg1kUZcJYe6Zk6ewxzMu.jpg\",\"datePublished\":\"2025-06-06\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"US\",\"inLanguage\":\"en\",\"genre\":[\"sword and sorcery film\",\"teen film\",\"action film\",\"monster film\",\"family film\",\"fantasy film\",\"adventure film\",\"speculative fiction film\",\"Fantasy\",\"Family\",\"Action\",\"Adventure\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.924,\"bestRating\":10,\"ratingCount\":2723}}"}}],["$","$L10",null,{"initialDrama":{"id":"72f429d7-6e05-4226-a5ec-a0514cb2079a","tmdb_id":1087192,"imdb_id":"tt26743210","content_type":"movie","title":"How to Train Your Dragon","original_title":"How to Train Your Dragon","overview":"On the rugged isle of Berk, where Vikings and dragons have been bitter enemies for generations, Hiccup stands apart, defying centuries of tradition when he befriends Toothless, a feared Night Fury dragon. Their unlikely bond reveals the true nature of dragons, challenging the very foundations of Viking society.","poster_path":"/41dfWUWtg1kUZcJYe6Zk6ewxzMu.jpg","backdrop_path":"/79PNOxNXSe5e0bhEj11QJPlsdCN.jpg","release_date":"2025-06-06","first_air_date":null,"status":"published","original_language":"en","origin_country":["US"],"genres":[{"name":"sword and sorcery film"},{"name":"teen film"},{"name":"action film"},{"name":"monster film"},{"name":"family film"},{"name":"fantasy film"},{"name":"adventure film"},{"name":"spe