iCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":2}],"flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZM":{"link":"https://www.themoviedb.org/movie/1465711-depeche-mode-m/watch?locale=ZM","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":0}]},"ZW":{"link":"https://www.themoviedb.org/movie/1465711-depeche-mode-m/watch?locale=ZW","flatrate":[{"logo_path":"/pbpMk2JmcoNnQwx5JGpXngfoWtp.jpg","provider_id":8,"provider_name":"Netflix","display_priority":4}]}}},"wikidata_id":"Q133866372","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-26T01:33:41.256597+00:00","region":null,"main_poster":null,"images":{"logos":[{"width":413,"height":609,"file_path":"/dK3sZnTjxurh6mEVHql2x4nIOcr.png","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.678,"vote_average":0}],"posters":[{"width":1800,"height":2700,"file_path":"/qz0EgfYwfrqhC2yTIqNkSY4P2Jo.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":3,"aspect_ratio":0.667,"vote_average":2.278},{"width":689,"height":1034,"file_path":"/g7vprmAKv8TwEYCN3Rn8qwuMPE7.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":3,"aspect_ratio":0.666,"vote_average":1.222},{"width":900,"height":1350,"file_path":"/A1fT6OjcMYsYu4PcgCBWBGGxj98.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":0.667,"vote_average":0.166},{"width":1080,"height":1600,"file_path":"/3ZcnHJYmC9A4TIALJcC8TPPjRdc.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.675,"vote_average":0},{"width":2000,"height":2963,"file_path":"/1je8iMt8vWqs9KFCJ0WIHIxLrPY.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.675,"vote_average":0},{"width":2000,"height":2963,"file_path":"/dCtovozU2pzBFPwQlqIqXQOP8YX.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.675,"vote_average":0},{"width":2000,"height":2963,"file_path":"/cNUAwYtMuyHXxR5zfOIsot7OXVX.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.675,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/nMbK6zeHGjKtph5odcyHrNkVmLP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/3uLAbruFWpV40TOQHIROcApCbYU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":3840,"height":2160,"file_path":"/54njo3uz95TmkKVrWUX8ylYnpg5.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166}]},"enriched_at":"2026-04-21T05:01:14.558+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":95,"tagline":"","homepage":"https://depechemodem.com/","overview":"Depeche Mode: M captures the band's 2023 Mexico City shows, blending concert footage with interstitial elements, exploring music, mortality, and Mexican culture's relationship with death."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":95,"tagline":"","homepage":"","overview":"Depeche Mode: M fängt die Konzerte der Band in Mexiko-Stadt im Jahr 2023 ein, verbindet Konzertmitschnitte mit Zwischensequenzen und beschäftigt sich mit Musik, Sterblichkeit und der Beziehung der mexikanischen Kultur zum Tod."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"電影以 Depeche Mode 在 2023 年 Memento Mori 巡迴演唱會中的標誌性表演為框架，探索墨西哥文化與死亡的關係。由屢獲殊榮的墨西哥電影製片人 Fernando Frías 構思並執導，記錄了 Depeche Mode 在墨西哥城三場全數售罄的演出，吸引了超過 20 萬名歌迷到場。當中融合了演唱會片段、解讀性插曲以及資料檔案。  《DEPECHE MODE：M》頌揚了樂團在全球的影響力，同時深入探討音樂、死亡和墨西哥傳統之間的深刻聯繫——在一個神聖的交匯點，痛苦、回憶、歡樂和舞蹈在這裡交融，融合成某種深刻而美麗的人性。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Depeche Mode: M","runtime":95,"tagline":"","homepage":"","overview":"DEPECHE MODE: M es un viaje cinematográfico hacia el corazón de la relación que la cultura mexicana mantiene con la muerte, enmarcado por las icónicas presentaciones de Depeche Mode durante su gira Memento Mori de 2023. Concebida y dirigida por el galardonado cineasta mexicano Fernando Frías, la película documenta los tres conciertos con localidades agotadas que la banda ofreció en la Ciudad de México ante más de 200 000 fans, entrelazando imágenes de las presentaciones con secuencias interpretativas y material de archivo. DEPECHE MODE: M celebra la influencia mundial de la banda mientras explora la profunda conexión entre la música, la mortalidad y la tradición mexicana: un encuentro sagrado donde el dolor, la memoria,la alegría y la danza se funden entre sí, diluyéndose en algo profundamente humano y hermoso a la vez."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":98,"tagline":"","homepage":"","overview":"Film concerto che intreccia le riprese dei tre show sold out al Foro Sol Stadium di Città del Messico, accompagnando il pubblico in un intenso viaggio musicale."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Це кінематографічна подорож у саме серце відносин мексиканської культури зі смертю в обрамленні культових виступів Depeche Mode під час їхнього туру 2023 року Memento Mori. Створений титулованим мексиканським режисером Фернандо Фріасом, фільм документує три концерти групи з повним аншлагом у Мехіко, які відвідали понад 200 000 фанів, поєднуючи концертні кадри з інтерпретаційними вставками й архівним матеріалом. Depeche Mode: M відзначає глобальний вплив гурту, водночас занурюючись у потужні зв’язки між музикою, смертю та мексиканськими традиціями. Це священне місце зустрічі болю, спогадів, радощів і танців, що розчиняються одне в одному й перетворюються на глибоку та прекрасну ілюстрацію людської природи."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Depeche Mode : M immortalise les concerts du groupe à Mexico en 2023, mêlant images de concert et intermèdes, et explorant la musique, la mortalité et le rapport de la culture mexicaine à la mort."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"赶时髦乐队：墨西哥亡灵纪行","runtime":0,"tagline":"","homepage":"","overview":"《Depeche Mode: M》记录了该乐队 2023 年在墨西哥城的演出，将演唱会片段与穿插的元素融合在一起，探讨了音乐、死亡以及墨西哥文化与死亡的关系。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"O filmie: „M” meksykańskiego reżysera Fernando Fríasa, który opisuje go jako filmową podróż w głąb relacji meksykańskiej kultury ze śmiercią, ujętą w porywające występy na żywo zespołu Depeche Mode podczas trasy koncertowej Memento Mori. Film łączy fragmenty koncertów z interpretacyjnymi przerywnikami i materiałami archiwalnymi. Film będzie również dostępny w limitowanej dystrybucji kinowej."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Koncertní snímek Depeche Mode: M je filmová cesta do srdce mexické kultury a jejího vztahu ke smrti, rámovaná ikonickými vystoupeními skupiny Depeche Mode během jejich posledního turné „Memento Mori“ v roce 2023. Film, jehož autorem a režisérem je oceněný mexický filmař Fernando Frias, zachycuje tři vyprodané koncerty kapely v Mexico City, kterých se zúčastnilo přes 200 000 fanoušků, a kombinuje záběry z koncertů s archivním materiálem. Depeche Mode: M oslavuje celosvětový věhlas kapely a zároveň se zabývá hlubokým propojením mezi hudbou, smrtelností a mexickou tradicí – posvátným místem setkání, kde se bolest, vzpomínky, radost a tanec prolínají a splývají v něco hluboce a krásně lidského."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Depeche Mode: M captura los shows de la banda en la Ciudad de México en 2023, combinando imágenes de conciertos con elementos intersticiales, explorando la música, la mortalidad y la relación de la cultura mexicana con la muerte."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[{"id":271352,"adult":false,"title":"Death Cab for Cutie: Live at the Mt. Baker Theatre","video":false,"overview":"On April 22 and 23, 2009, Death Cab for Cutie returned to Bellingham, WA, where they had formed over ten years prior, to perform two sold-out concerts at the historic Mt. Baker Theatre.  This film features previously unreleased performances from these two very special nights as well as interviews with band members about the band's early days in Bellingham.","genre_ids":[10402],"popularity":0.1951,"vote_count":0,"poster_path":"/i4ZrAJx6Y0JEx7d0ZKhJPcYUaJS.jpg","release_date":"2011-05-31","vote_average":0,"backdrop_path":null,"original_title":"Death Cab for Cutie: Live at the Mt. Baker Theatre","original_language":"en"},{"id":132,"adult":false,"title":"Gimme Shelter","video":false,"overview":"A detailed chronicle of the famous 1969 tour of the United States by the British rock band The Rolling Stones, which culminated with the disastrous and tragic concert held on December 6 at the Altamont Speedway Free Festival, an event of historical significance, as it marked the end of an era: the generation of peace and love suddenly became the generation of disillusionment.","genre_ids":[99,10402],"popularity":0.8766,"vote_count":189,"poster_path":"/fFLKCqI7nfkie9V1LmBLljiNV4j.jpg","release_date":"1970-12-13","vote_average":7.3,"backdrop_path":"/c4Chm8w7AsekIkPb6KSxUxCzXq2.jpg","original_title":"Gimme Shelter","original_language":"en"},{"id":271278,"adult":false,"title":"Frank Sinatra: In Concert at Royal Festival Hall","video":false,"overview":"Frank Sinatra: In Concert at the Royal Festival Hall was an CBS musical television special starring Frank Sinatra broadcast on February 4, 1971, of a concert given by Sinatra at London's Royal Festival Hall on November 16, 1970. The special was directed by Bill Miller, and produced by Harold Davison.  Sinatra was introduced on stage by Grace Kelly. Kelly had starred alongside Sinatra in the 1956 film High Society, the last film she made before her marriage to Rainier III, Prince of Monaco.  Sinatra had been follicularly challenged for many years, hence all the hats in publicity stills, album covers etc. TV directors were forbidden to photograph him from the back because of this. However, at this concert, Sinatra had completed a very successful hair transplant and deliberately turned his back on the main audience a couple of times to acknowledge the audience sitting backstage, along with running his hand over the back of his head to draw attention to his new coiffure.","genre_ids":[10402,10770,99],"popularity":0.5782,"vote_count":3,"poster_path":"/rsP9W42wc9ZTgtBiQhzTCbVz5HV.jpg","release_date":"1971-02-04","vote_average":7,"backdrop_path":"/9fAKxK20aqytTf89nSfYaHmZ6XW.jpg","original_title":"Frank Sinatra: In Concert at Royal Festival Hall","original_language":"en"},{"id":1058923,"adult":false,"title":"Billie Eilish: Live at the O2 (Extended Cut)","video":false,"overview":"For the first time in her career, global superstar Billie Eilish is releasing a visual record of her formidable live performance. Featuring intimate and unforgettable moments between Billie and her audience, this compelling concert film takes viewers on a visually captivating journey from beginning to end, to the heart of Eilish's record-breaking sold-out Happier Than Ever, The World Tour.","genre_ids":[10402],"popularity":0.1679,"vote_count":8,"poster_path":"/sYk7kDaZSnhu7zq2BYMt5TZ9B3Y.jpg","release_date":"2023-01-27","vote_average":8.4,"backdrop_path":"/nzTPR0uo1tYzNX7qVoA36GWLPQx.jpg","original_title":"Billie Eilish: Live at the O2 (Extended Cut)","original_language":"en"},{"id":1254724,"adult":false,"title":"SUGA | Agust D TOUR 'D-DAY' THE MOVIE","video":false,"overview":"As the grand finale of the world tour, \"SUGA | Agust D TOUR 'D-DAY' THE FINAL\" marked the culmination of 25 concerts held in 10 cities, which captivated a total audience of 290,000 throughout its run. Experience the pulsating energy and excitement of \"'D-DAY' THE FINAL\" on screen, everything from the exquisite sounds traversing the boundary between \"21st Century Pop Icon\" BTS member SUGA and solo artist Agust D, electrifying performance, explosive energy, to special duet stages featuring fellow BTS members RM, Jimin, and Jung Kook.","genre_ids":[10402,99],"popularity":0.3408,"vote_count":10,"poster_path":"/A4IzXiX0LjIn3BQHRCcePXzaE4M.jpg","release_date":"2024-04-10","vote_average":6.3,"backdrop_path":"/qd09px0NYGVneO0I2ZFi0yJSqA6.jpg","original_title":"슈가｜어거스트 디 투어 '디-데이' 더 무비","original_language":"ko"},{"id":1454836,"adult":false,"title":"Ryuichi Sakamoto | Playing the Orchestra 2014","video":false,"overview":"Ryuichi Sakamoto sadly passed away at the age of 71 on March 28, 2023. His music never stops and continues to leave a lasting impression on people living in the present. Playing the Orchestra 2013\" was the first time in 16 years that Ryuichi Sakamoto performed with a full orchestra in Japan and created a sensation. This film is an updated version of the 2014 Tokyo performance, which he conducted himself. In this film, Sakamoto conducts all the pieces while playing the piano, The film features Sakamoto playing the piano and conducting all the pieces, and a variety of music from YMO's masterpieces such as \"Merry Christmas Mr. Lawrence\" and \"The Last Emperor\" to his own film music, all performed by the magnificent Tokyo Philharmonic Orchestra.","genre_ids":[10402,99],"popularity":0.1277,"vote_count":1,"poster_path":"/q83ivwlHHZ2FEaEGpIC0J9lCYUo.jpg","release_date":"2025-01-03","vote_average":8,"backdrop_path":"/uZbRNwzjl69cb7pQr1RXXrnxHtC.jpg","original_title":"Ryuichi Sakamoto | Playing the Orchestra 2014","original_language":"ja"},{"id":1257357,"adult":false,"title":"Cavepeople","video":false,"overview":"January 13th, 2024; Suffolk County's punk, grunge, and emo scenes are showcased through the more than a hundred attendees at Caveversary; an annual celebration of the independent basement venue, The Cave.","genre_ids":[99,10402],"popularity":0.3233,"vote_count":0,"poster_path":"/thXd8xWvAT3IWNCprQojQjdYWC8.jpg","release_date":"2024-05-10","vote_average":0,"backdrop_path":"/kRD7BpXtJfgjhOCuDXzzkKJvtwX.jpg","original_title":"Cavepeople","original_language":"en"},{"id":1266394,"adult":false,"title":"Zara Larsson 'Venus Tour'","video":false,"overview":"Experience Zara Larsson's majestical, sold-out performance at AFAS Live in Amsterdam - available from 3 April in cinematic quality. Electropop queen Zara Larsson performs songs from her fourth studio album 'Venus', alongside fan-favourites 'Lush Life', 'I Would Like', 'Never Forget You' and 'Symphony', on her first European tour since 2019. Captured on 26 February 2024 at AFAS Live, the show features luscious pastel and magenta stage lighting, ethereal orbital-like visuals, a powerful female collective of musicians and dancers, plus all the frills and sparkle. Shooting to multi-platinum stardom over the past decade, Zara continues her reign of 'mothering' - sorry - owning the stage as if it were her last concert, radiating confidence, charm, and (unsurprisingly) some pretty killer dance moves in front of thousands of fans.","genre_ids":[10402],"popularity":0.1992,"vote_count":0,"poster_path":"/tbG0XijVYNouA665LHCqzLEogZj.jpg","release_date":"2024-04-03","vote_average":0,"backdrop_path":"/wC6uHcYnHrlDDGfsh2mGh33PNn7.jpg","original_title":"Zara Larsson 'Venus Tour'","original_language":"en"},{"id":1467526,"adult":false,"title":"Star Rail LIVE 2025 - Honkai: Star Rail 2nd Anniversary Concert","video":false,"overview":"Celebrate Honkai: Star Rail's 2nd Anniversary with a one-day-only, cinema screening featuring powerful performances of the Space Fantasy RPG's most iconic tracks! This screening showcases recorded performances from the Star Rail LIVE 2025 concert held in Shanghai on May 3, 2025.  The Cosmos Resonates for You!\r Attention, passengers, the Express is about to make the jump!\r The universe resonates in harmony because you chose the Trailblaze.\r This musical celebration is dedicated to every Trailblazer who journeys with the Express. Happy 2nd Anniversary! May this journey lead us starward!","genre_ids":[10402,14,16],"popularity":0.5122,"vote_count":1,"poster_path":"/oBkzIO2tTHgxCxdZLULonpnbzvf.jpg","release_date":"2025-05-03","vote_average":10,"backdrop_path":"/xax3cYB9kQpUPjFKqHSLYKBnVmd.jpg","original_title":"《崩坏：星穹铁道》「2025星铁LIVE」演唱会","original_language":"zh"},{"id":15583,"adult":false,"title":"Nine Inch Nails: Beside You in Time","video":false,"overview":"Capturing the powerful intensity and artistry of Nine Inch Nails' amazing live performances during the 2005-2006 “Live: With Teeth” Tour, the Beside You In Time concert film showcases the band in peak form.  A visually stunning experience with an array of inventive and ingenious lighting designs that draws the viewer in while focusing the force of NIN’s epic sound into visual form.","genre_ids":[10402],"popularity":0.1779,"vote_count":21,"poster_path":"/yt9PMVHPyVKgYKXKu98dLLMipzo.jpg","release_date":"2007-02-23","vote_average":7.7,"backdrop_path":"/48GPtkMWHn72MdD50dyXytLlNHG.jpg","original_title":"Nine Inch Nails: Beside You in Time","original_language":"en"},{"id":665399,"adult":false,"title":"BTS World Tour: Love Yourself - Japan Edition","video":true,"overview":"BTS perform their Japan concert at Tokyo Dome and Fukuoka Yahuoku Dome during their Love Yourself World Tour.","genre_ids":[10402,99],"popularity":0.1428,"vote_count":327,"poster_path":"/dA0MVEjNOP3GmWigu6Cs3I399Zt.jpg","release_date":"2019-10-09","vote_average":9.2,"backdrop_path":null,"original_title":"BTS World Tour: Love Yourself - Japan Edition","original_language":"ko"},{"id":1262209,"adult":false,"title":"aespa: WORLD TOUR in cinemas","video":false,"overview":"Witness the unparalleled energy of aespa’s live performance captured from their electrifying show at London's O2 Arena, their first-ever UK show. With their futuristic stage visuals, high-energy choreography and captivating vocals, they fiercely commanded the stage delivering fan favourites including ‘Next Level’, ‘Savage’, ‘Girls’, ‘Spicy’ and ‘Black Mamba’. The film also highlights individual performances by each member, complemented by exclusive behind-the-scenes interviews, offering a glimpse behind the curtain.","genre_ids":[10402,99],"popularity":0.2793,"vote_count":1,"poster_path":"/3mAdm8A64YF5cXmrEUq79t8mzge.jpg","release_date":"2024-04-10","vote_average":8,"backdrop_path":"/iTQc2qln7CyHIoYuNe0PJiikqv4.jpg","original_title":"에스파: 월드 투어 인 시네마","original_language":"ko"},{"id":283559,"adult":false,"title":"One Direction: Where We Are - The Concert Film","video":false,"overview":"Where We Are: Live from San Siro Stadium features the entire 23 track concert filmed at San Siro Stadium in Milan in June 2014, as well as 24 minutes of bonus content including backstage footage of One Direction and their crew.","genre_ids":[10402,99],"popularity":0.3798,"vote_count":168,"poster_path":"/8b8DHnN9R8lRMbflfnNAV87qGZQ.jpg","release_date":"2014-10-08","vote_average":8.4,"backdrop_path":"/71jft7p3jnqrFTizptt5dbTK3gh.jpg","original_title":"One Direction: Where We Are - The Concert Film","original_language":"en"},{"id":1465180,"adult":false,"title":"ATEEZ WORLD TOUR [TOWARDS THE LIGHT : WILL TO POWER] IN CINEMAS","video":false,"overview":"Kicking off in Seoul in January 2024, ATEEZ’s monumental world tour, TOWARDS THE LIGHT : WILL TO POWER, ignited Japan, North America, Europe, and beyond with unstoppable energy. Now, its breathtaking opening chapter returns, reborn on the big screen.  From powerful performances of signature hits like \"WONDERLAND (Symphony No.9 “From The Wonderland”)”, \"Crazy Form\", \"Say My Name\", and \"Guerrilla\" to mesmerizing unit and solo stages showcasing each member’s unique color, ATEEZ’s overwhelming energy takes over SCREENX, 4DX, and ULTRA 4DX where available.  The voyage towards the light sets sail once again!","genre_ids":[10402,99],"popularity":0.3915,"vote_count":2,"poster_path":"/hhh0aaPabgPhK6t01eSy87A2NnJ.jpg","release_date":"2025-05-07","vote_average":9,"backdrop_path":"/4Q3YVgwn9rhm42Ejqj4uIkJhAve.jpg","original_title":"에이티즈 월드 투어 [투워즈 더 라이트 : 윌 투 파워] 인 시네마","original_language":"ko"},{"id":1265582,"adult":false,"title":"LiSA LiVE Is SMiLE ALWAYS -LANDER -","video":false,"overview":"Global J-pop sensation LiSA will transport fans to the final stop of her “LiVE SMiLE ALWAYS -LANDER-” tour at the Tokyo Garden Theater in an epic never-before-seen concert film. LiSA brings her unique ideas and feelings, high energy, and powerful vocals to the sold-out crowd, where she becomes one with each and every fan as their voices and souls unite together, amplified by the support of the band.","genre_ids":[10402],"popularity":0.2204,"vote_count":2,"poster_path":"/8GfjPTpk9kSCI8N5ZXIl2bWyUD.jpg","release_date":"2024-08-17","vote_average":8,"backdrop_path":"/1nKquKwel0qM4UlZRVd2IxvzFN8.jpg","original_title":"LiSA LiVE is Smile Always〜LANDER〜","original_language":"ja"},{"id":278585,"adult":false,"title":"Free Tibet","video":false,"overview":"A film about the Tibetan Freedom Concert in San Francisco in 1996.","genre_ids":[99,10402],"popularity":0.376,"vote_count":0,"poster_path":"/cpxPKEdymBBhY0mO4lPTpAMEv3T.jpg","release_date":"1998-09-11","vote_average":0,"backdrop_path":"/ng8o4dVEYFuvZVlA17tpzya28Yt.jpg","original_title":"Free Tibet","original_language":"en"},{"id":278625,"adult":false,"title":"Santana: Corazón Live from Mexico: Live It to Believe It","video":false,"overview":"Includes the concert film, a “making of the concert” 30 minute documentary film shot in Puerto Vallarta, Riviera Nayarit, and Guadalajara, entitled “Live It To Believe It,” along with a live CD from December 14, 2013.  Superstar performances at this concert event include Elan Atias, Chocquibtown, Lila Downs, Gloria Estefan, Juanes, Miguel, Fher Olvera (of Mana), Niña Pastori, Samuel Rosa (of Skank), Cindy Blackman Santana, Salvador Santana, Romeo Santos, Soledad, and Diego Torres.","genre_ids":[10402],"popularity":0.2886,"vote_count":4,"poster_path":"/4kGbgVF0W4mUhRhDOptieJjlPla.jpg","release_date":"2014-09-09","vote_average":6.2,"backdrop_path":"/fkTpSEzFey0Ah6lmrDsLUM97lxU.jpg","original_title":"Santana: Corazón Live from Mexico: Live It to Believe It","original_language":"es"},{"id":662860,"adult":false,"title":"Kui saabub õhtu","video":false,"overview":"","genre_ids":[99,10402,10770],"popularity":0.1285,"vote_count":2,"poster_path":"/aMPXJmlPS7c21qSwrYjhntTsp9N.jpg","release_date":"1955-04-25","vote_average":8.2,"backdrop_path":"/zAMFzBotx3Tr8M2iRsdXBqsYJ1y.jpg","original_title":"Kui saabub õhtu","original_language":"et"},{"id":862759,"adult":false,"title":"Melody Gardot: From Paris with Love","video":false,"overview":"Melody Gardot performs her new album Sunset in the Blue, from the Radio France studios accompanied by a trio of musicians and 40 instrumentalists from the in-house orchestra.","genre_ids":[10402],"popularity":0.1864,"vote_count":2,"poster_path":"/ndqMtb7DJ606xhe27Gn5W5hUaaX.jpg","release_date":"2020-12-02","vote_average":8,"backdrop_path":"/552I16Fo99615QrlaWqKMbsrM6Q.jpg","original_title":"Melody Gardot - From Paris with Love","original_language":"fr"},{"id":1460687,"adult":false,"title":"Garden State - The 20th Anniversary Concert","video":false,"overview":"Be a part of The Garden State 20th Anniversary Concert. This one night only musical event features songs from the iconic Grammy Award-winning soundtrack that defined a generation. Watch performances by the original artists including The Shins, Iron & Wine, Frou Frou, Colin Hay, Thievery Corporation, Remy Zero, Cary Brothers, Bonnie Somerville, and Sophie Barker from Zero 7. Plus more special guests.  Whether you remember the first time you heard “New Slang” or the emotional pull of “Let Go,” this is for fans of the film and music alike and is not to be missed.","genre_ids":[10402,35,99],"popularity":0.3241,"vote_count":2,"poster_path":"/8mlY0sgIpzQ6XLe9dfpJjXYon7L.jpg","release_date":"2025-04-06","vote_average":10,"backdrop_path":null,"original_title":"Garden State - The 20th Anniversary Concert","original_language":"en"}],"external_ids":{"imdb_id":"tt36590288","twitter_id":"","facebook_id":"","wikidata_id":"Q133866372","instagram_id":"","metacritic_id":"movie/depeche-mode-m","rotten_tomatoes_id":"m/depeche_mode_m"},"social_ids":{"twitter":"","facebook":"","instagram":""},"gdvg_id":148727,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"CH","release_dates":[{"note":"","type":3,"iso_639_1":"de","descriptors":[],"release_date":"2025-10-28T00:00:00.000Z","certification":"6"}]},{"iso_3166_1":"DO","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-10-28T00:00:00.000Z","certification":""}]},{"iso_3166_1":"HK","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-10-28T00:00:00.000Z","certification":""}]},{"iso_3166_1":"NL","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-10-28T00:00:00.000Z","certification":"AL"}]},{"iso_3166_1":"UA","release_dates":[{"note":"","type":2,"iso_639_1":"","descriptors":[],"release_date":"2025-10-28T00:00:00.000Z","certification":""}]},{"iso_3166_1":"US","release_dates":[{"note":"Tribeca Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-06-05T00:00:00.000Z","certification":""},{"note":"","type":2,"iso_639_1":"","descriptors":[],"release_date":"2025-10-28T00:00:00.000Z","certification":""}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikidata_metadata":{},"mood_tags":null,"trope_tags":null,"vibe_description":null,"ai_enriched_at":null,"ai_enrichment_version":0}}]]
