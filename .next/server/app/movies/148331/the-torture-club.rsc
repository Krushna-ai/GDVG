V37Rn6khmLpz6YretSt.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2410,"height":1356,"file_path":"/tz9MgKBvl4zwnnVAG3GRw44MEiX.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2560,"height":1440,"file_path":"/b78udS3FupIbonzxcFeVmaFjHra.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2560,"height":1440,"file_path":"/yWny69LdsVzIZNReBFPHeLC87N3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/AnYVKPNxST3TSbw84u1BzUC1v8n.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T02:56:05.997+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Torture Club","runtime":97,"tagline":"","homepage":"","overview":"The \"Torture Club\" is an official after-school activity at the private school Saint Honesty Gakuen. Yuzuki has no idea about the club when she enrolls, and gets abducted by the club members and hauled off the club-room. There, she finds out that upper-class student Aoi, her secret idol, is in the club, and decides to join, but…"},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"女子高校拷问部","runtime":107,"tagline":"","homepage":"http://iron-maiden.jp/","overview":"被称为永远萝莉系平面偶像的女星木岛法子在11月2日未发行的电影《女子高校拷问部》中上演全裸拷问SM戏，以及同性激情戏，女星魂大爆发。由在「PSYCHO-PASS」和老虚合作的脚本深见真原作，αAlfLayla作画的拷问4格漫画「女子高校拷问部」宣布改编真人电影，目前电影的海报公开，耻度让人无法直视！木岛法子从16岁开始作为平面偶像出道，她的写真DVD在购物网站销量总是排第一。她主演的《女子高校拷问部》根据因离奇设定而倍受欢迎的同名漫画改编，片中有捆绑、滴蜡烛、鞭打、吊起来等SM画面，当然也包括女同戏份。木岛法子说：“虽然很多都是第一次尝试，但既然决定做我就讨厌半吊子，所以非常努力演出。我原本就很喜欢可爱的女孩，拍摄时一直想着演对手戏的吉住春奈，感觉喜欢上她了，所以和她拍的床戏我没有任何抵触心理，表现也很大胆。”据悉，片中最让木岛法子痛苦的就是“虫刑”，她的手被绑住，无数甲虫的幼虫在她全身蠕动，是很疯狂的一种SM。木岛法子说：“我真是很受不了，光看照片都够难受了，可那都是工作人员辛苦养大的，把本来很小的幼虫养得肥大……拍完那个我都哭了。”木岛法子饰演的角色还从M转变成了S，随着拍摄进展她要让对手戏演员受伤，因为不忍伤害别人手下留情，结果反复拍了多次才成功。片中木岛法子还有一段自慰的戏份，她说：“那个真的好难，我看了导演的上一部作品学习，在家练习，拍摄完后导演还表扬我很棒。今后如果有需要我还可以全裸上镜。”"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"The Torture Club","runtime":97,"tagline":"","homepage":"","overview":"Als Schulmädchen Yuzuki den Eignungstest für die Universität ausfüllt, hat sie keine Ahnung, dass ihr ihre Antworten auch Zugang zum exklusiven Torture Club verschaffen werden. Dort findet sie sich anfänglich auf der Maso-Seite wieder, allerdings nur, bis sich ihre Beziehung zur dominanten Aoi vertieft. Die jungen Frauen tauschen ihre SM-Rollen nicht nur, sondern verlieben sich auch ineinander. Ein klarer Bruch der Clubregeln, auf den eine harte Bestrafung steht."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"ちょっとかわいいアイアンメイデン","runtime":0,"tagline":"青春は痛くてーーみ・だ・ら。","homepage":"","overview":"桜舞う入学初日、晴れて中学生の一員となった武藤結月は女子高特有の百合に憧れていた。そんな所を見計らったかのように容姿端麗な高等部の上級生舟木碧生から声をかけられ、部活動へと誘われる。色めき立つ結月はその活動内容を聞くと、信じ難いことに学校公認で合理的に拷問を行い研究するという拷問部だった。想像を絶する答えに逃亡を図るも、拘束具を取り付けられ、同級生の小橋蒼空、その姉の小橋悠里、初等部の新崎苺花の部員達の前に晒され、半ば強制的に入部させられる。徐々にディープな世界を知っていく結月と、個性的な部員達の拷問ライフが始まった。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"İşkence Klubü","runtime":0,"tagline":"","homepage":"","overview":"Film prestijli bir kadın lisesinde bir işkence kulübünde; Yuzuki Muto'nun okula girmesinin hemen ardından, İşkence Kulübü'ne üye oldu. Kulüp, öğrencileri gizlice sorgu uzmanı olarak askeri ve polis alanlarına girmeye zorlar. Kulübün üyesi olan Kıdemli öğrenci Aoi Funaki, Yuzuki Muto da dahil olmak üzere üyelere işkence yaptı. +16 yapımdır"},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"고문 클럽","runtime":0,"tagline":"","homepage":"","overview":"꿈에도 생각 못한 고급 사립여고에 입학하게 된 유즈키. 어느 화창한 봄날, 그녀는 학교에서 정식으로 승인 받은 고문클럽에 강제로 끌려간다. 꾸준한 연습과 습득으로 고문을 예술로 승화시키는 고문클럽. 입학시험 때 첫눈에 반한 선배, 아오이가 클럽에 있는 것을 알게 된 유즈키는 클럽에 가입하여 하드트레이닝을 시작한다. 섹슈얼한 고문의 세계로 여러분을 초대합니다! (2014년 제18회 부천국제판타스틱영화제)"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Chotto Kawaii Iron Maiden","runtime":0,"tagline":"","homepage":"","overview":"Adaptación cinematográfica del popular cómic del mismo título por su extraordinaria premisa. El prometedor Yoshida Kota, conocido por su estilo humorístico y sensual en películas como Usotsuki Paradox, crea un drama único de la mayoría de edad sobre el amor entre dos chicas, con elementos de deportes y perseverancia en todas partes. El \"Club de la tortura\" es una actividad oficial después de la escuela en la escuela privada Saint Honesty Gakuen. Yuzuki (Kijima Noriko) no tiene idea sobre el club cuando se inscribe, y los miembros del club la secuestran y la retiran del salón del club. Allí, ella descubre que la estudiante de clase alta Aoi (Yoshizumi Haruna), su ídolo secreto, está en el club, y decide unirse, pero ..."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"The Torture Club","runtime":0,"tagline":"","homepage":"","overview":"Le \"Torture Club\" est une activité extrascolaire officielle de l'école privée Saint Honesty Gakuen. Yuzuki n'a aucune idée du club lorsqu'elle s'inscrit et est enlevée par les membres du club et emmenée hors de la salle du club. Là, elle découvre qu'Aoi, une étudiante de la classe supérieure, son idole secrète, est dans le club et décide de le rejoindre, mais..."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Câu Lạc Bộ Lạc Giới","runtime":0,"tagline":"","homepage":"","overview":"Nội dung xoay quanh một câu lạc bộ đặc biệt chuyên đào tạo về tra tấn, nó phục vụ sau này cho các lĩnh vực về quân sự, các chuyên gia thẩm vấn cũng như cảnh sát và hoạt động một cách bí mật. Đặc biệt, các thành viên ở đây tất cả đều là nữ mà không có bất kỳ nam giới nào, tại đây đa phần đều là những nữ sinh trẻ xinh đẹp với khả năng chịu đựng rất tốt. Trong đó, Aoi Funaki (Haruna Yoshizumi) chính là người cầm đầu cũng như đào tạo cho nhiều nữ sinh tại đây."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"女子高校拷問社","runtime":0,"tagline":"","homepage":"","overview":"被稱為永遠蘿莉系平面偶像的女星木島法子在11月2日未發行的電影《女子高校拷問部》中上演全裸拷問SM戲，以及同性激情戲，女星魂大爆發。由在「PSYCHO-PASS」和老虛合作的腳本深見真原作，alpha;AlfLayla作畫的拷問4格漫畫「女子高校拷問部」宣佈改編真人電影，目前電影的海報公開，恥度讓人無法直視！據悉，電影將在今年7月19日在日本全國上映。。。木島法子從16歲開始作為平面偶像出道，她的寫真DVD在購物網站銷量總是排第一。她主演的《女子高校拷問部》根據因離奇設定而倍受歡迎的同名漫畫改編，片中有捆綁、滴蠟燭、鞭打、吊起來等SM畫面，當然也包括女同戲份。木島法子說：;雖然很多都是第一次嘗試，但既然決定做我就討厭半吊子，所以非常努力演出。我原本就很喜歡可愛的女孩，拍攝時一直想著演對手戲的吉住春奈，感覺喜歡上她了，所以和她拍的床戲我沒有任何牴觸心理，表現也很大膽。據悉，片中最讓木島法子痛苦的就是;蟲刑，她的手被綁住，無數甲蟲的幼蟲在她全身蠕動，是很瘋狂的一種SM。木島法子說：;我真是很受不了，光看照片都夠難受了，可那都是工作人員辛苦養大的，把本來很小的幼蟲養得肥大拍完那個我都哭了。木島法子飾演的角色還從M轉變成了S，隨著拍攝進展她要讓對手戲演員受傷，因為不忍傷害別人手下留情，結果反覆拍了多次才成功。片中木島法子還有一段自我解決的戲份，她說：;那個真的好難，我看了導演的上一部作品學習，在家練習，拍攝完後導演還表揚我很棒。今後如果有需要我還可以全裸上鏡。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Clubul torturii","runtime":0,"tagline":"","homepage":"","overview":"„Clubul Torturii” este o activitate oficială după-școală la școala privată Saint Honesty Gakuen.  Yuzuki habar n-are despre club când se înscrie și este răpită de membrii clubului și scoasă din camera clubului.  Acolo, ea află că studentul din clasa superioară Aoi, idolul ei secret, este în club și decide să se alăture, dar..."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"The Torture Club","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"女子高校拷問社","runtime":97,"tagline":"","homepage":"","overview":"被稱為永遠蘿莉系平面偶像的女星木島法子在 11 月 2 日未發行的電影《女子高校拷問社》中上演全裸拷問 SM 戲，以及同性激情戲，女星魂大爆發。由在「PSYCHO - PASS」和老虛合作的劇本深見真原作，alpha; AlfLayla 作畫的拷問 4 格漫畫「女子高校拷問部」宣佈改編真人電影，目前電影的海報公開，恥度讓人無法直視！據悉，電影將在今年 7 月 19 日在日本全國上映。。。木島法子從 16 歲開始作為平面偶像出道，她的寫真 DVD 在購物網站銷量總是排第一。她主演的《女子高校拷問社》根據因離奇設定而倍受歡迎的同名漫畫改編，片中有捆綁、滴蠟燭、鞭打、吊起來等 SM 畫面，當然也包括女同戲份。木島法子説：; 雖然很多都是第一次嘗試，但既然決定做我就討厭半吊子，所以非常努力演出。我原本就很喜歡可愛的女孩，拍攝時一直想著演對手戲的吉住春奈，感覺喜歡上她了，所以和她拍的牀戲我沒有任何牴觸心理，表現也很大膽。據悉，片中最讓木島法子痛苦的就是; 蟲刑，她的手被綁住，無數甲蟲的幼蟲在她全身蠕動，是很瘋狂的一種 SM。木島法子説：; 我真是很受不了，光看照片都夠難受了，可那都是工作人員辛苦養大的，把本來很小的幼蟲養得肥大拍完那個我都哭了。木島法子飾演的角色還從 M 轉變成了 S，隨著拍攝進展她要讓對手戲演員受傷，因為不忍傷害別人手下留情，結果反覆拍了多次才成功。片中木島法子還有一段自我解決的戲份，她説：; 那個真的好難，我看了導演的上一部作品學習，在家練習，拍攝完後導演還表揚我很棒。今後如果有需要我還可以全裸上鏡。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"}],"reviews_tmdb":[],"recommendations":[{"id":10802,"adult":false,"title":"Showgirls","video":false,"overview":"Fresh to Las Vegas with no connections, Nomi Malone takes a job as an exotic dancer. Her talents are quickly noticed by Cristal, a headlining dancer who senses an opportunity to bolster her own act. But Nomi won’t play second fiddle and soon begins her venomous path to the top, ruthlessly backstabbing anyone who gets in her way.","genre_ids":[18],"media_type":"movie","popularity":6.3009,"vote_count":1351,"poster_path":"/o4HT3Ap5c99W4FYpdXUtTvxGgPc.jpg","release_date":"1995-09-22","vote_average":5.587,"backdrop_path":"/jL3G2f8uNCFejJRlIqCzRp8Y7eV.jpg","original_title":"Showgirls","original_language":"en"},{"id":884139,"adult":false,"title":"No Heaven, But Love.","video":false,"overview":"1999— The Age of Apocalypse, where violence was rampant. In those days, nothing was easy. A story about the love and friendship of girls, which was hotter than any other summer... Joo-young and Ye-ji’s relationship is tender but ultimately feels like an impossible one.","genre_ids":[18,10749],"media_type":"movie","popularity":0.9112,"vote_count":4,"poster_path":"/4M8yROWhbDP1T2AH2ORikImsCXA.jpg","release_date":"2024-10-16","vote_average":8,"backdrop_path":"/6XQIukr8kNXr4NMNsFcekSi2Sds.jpg","original_title":"우리는 천국에 갈 순 없지만 사랑은 할 수 있겠지","original_language":"ko"},{"id":193717,"adult":false,"title":"The Gifted Hands","video":false,"overview":"While investigating the kidnapping and murder of a little girl, a detective spots a piece of graffiti that depicts the crime scene perfectly—but the graffiti was drawn a month before the crime took place, and that the artist knows more than he is telling.","genre_ids":[9648],"media_type":"movie","popularity":0.512,"vote_count":55,"poster_path":"/9a5ajYpawjv5Ujz5Hf9QeZq3LZE.jpg","release_date":"2013-03-06","vote_average":6,"backdrop_path":"/q2VAZ4q3cB8BGgfAbVE8IIu8Bej.jpg","original_title":"사이코메트리","original_language":"ko"},{"id":734969,"adult":false,"title":"The Brightest Roof in the Universe","video":false,"overview":"14 year-old schoolgirl Tsubame is into university student Toru. She sees him in her area and really wants to be his. She struggles with how to inform him of her love. Then her stepmother becomes pregnant and she is distracted with that development. The one reliable part of her life is the calligraphy class she attends, but then she runs into a woman.","genre_ids":[18,10751,14,10749],"media_type":"movie","popularity":0.6575,"vote_count":15,"poster_path":"/vCiO5NeIrygCYmwrJQxkXe9URBO.jpg","release_date":"2020-09-04","vote_average":7.4,"backdrop_path":"/6bzFTC6qw0T12Vsjv07uZR8FySh.jpg","original_title":"宇宙でいちばんあかるい屋根","original_language":"ja"},{"id":16722,"adult":false,"title":"The Telling","video":false,"overview":"In this horror anthology film, three girls pledge the most popular - and cruelest - sorority on campus. For their final task, they must tell the scariest story they know. Containing three distinct stories - one featuring a murderous doll, one a has-been actress and her run in with a film crew of the undead and, finally, a hunt-and-kill fright-fest.","genre_ids":[27,53],"media_type":"movie","popularity":0.4756,"vote_count":25,"poster_path":"/hAL5hsqZWBHqdTgT9dGggcFtpzB.jpg","release_date":"2009-04-14","vote_average":3.24,"backdrop_path":"/Aq6qBJpgIGylTDrTpyWysrmN3El.jpg","original_title":"The Telling","original_language":"en"},{"id":114,"adult":false,"title":"Pretty Woman","video":false,"overview":"While on a business trip in Los Angeles, Edward Lewis, a millionaire entrepreneur who makes a living buying and breaking up companies, picks up a prostitute, Vivian, while asking for directions; after, Edward hires Vivian to stay with him for the weekend to accompany him to a few social events, and the two get closer only to discover there are significant hurdles to overcome as they try to bridge the gap between their very different worlds.","genre_ids":[10749,35],"media_type":"movie","popularity":10.5175,"vote_count":8840,"poster_path":"/hVHUfT801LQATGd26VPzhorIYza.jpg","release_date":"1990-03-23","vote_average":7.455,"backdrop_path":"/sGEqHTylawwS6hwKultk1mKUjdB.jpg","original_title":"Pretty Woman","original_language":"en"},{"id":497582,"adult":false,"title":"Enola Holmes","video":false,"overview":"While searching for her missing mother, intrepid teen Enola Holmes uses her sleuthing skills to outsmart big brother Sherlock and help a runaway lord.","genre_ids":[12,9648,80],"media_type":"movie","popularity":7.4265,"vote_count":6450,"poster_path":"/riYInlsq2kf1AWoGm80JQW5dLKp.jpg","release_date":"2020-09-23","vote_average":7.235,"backdrop_path":"/pQQggUuDMleFSl2tQYxzTmKIiLU.jpg","original_title":"Enola Holmes","original_language":"en"},{"id":260513,"adult":false,"title":"Incredibles 2","video":false,"overview":"Elastigirl springs into action to save the day, while Mr. Incredible faces his greatest challenge yet – taking care of the problems of his three children.","genre_ids":[28,12,16,10751],"media_type":"movie","popularity":8.4509,"vote_count":13510,"poster_path":"/9lFKBtaVIhP7E2Pk0IY1CwTKTMZ.jpg","release_date":"2018-06-14","vote_average":7.453,"backdrop_path":"/mabuNsGJgRuCTuGqjFkWe1xdu19.jpg","original_title":"Incredibles 2","original_language":"en"},{"id":341174,"adult":false,"title":"Fifty Shades Darker","video":false,"overview":"When a wounded Christian Grey tries to entice a cautious Ana Steele back into his life, she demands a new arrangement before she will give him another chance. As the two begin to build trust and find stability, shadowy figures from Christian’s past start to circle the couple, determined to destroy their hopes for a future together.","genre_ids":[18,10749],"media_type":"movie","popularity":7.6223,"vote_count":7875,"poster_path":"/w3qa274gvca9t8pkUoG8nfQgTU3.jpg","release_date":"2017-02-08","vote_average":6.475,"backdrop_path":"/16aJtXO6lObbBUr11IvkjB1QD1f.jpg","original_title":"Fifty Shades Darker","original_language":"en"},{"id":241259,"adult":false,"title":"Alice Through the Looking Glass","video":false,"overview":"Alice Kingsleigh returns to Underland and faces a new adventure in saving the Mad Hatter.","genre_ids":[12,10751,14],"media_type":"movie","popularity":5.6312,"vote_count":6707,"poster_path":"/kbGamUkYfgKIYIrU8kW5oc0NatZ.jpg","release_date":"2016-05-25","vote_average":6.56,"backdrop_path":"/A6d09KtZKdVGSg0gzsldjDwwvhD.jpg","original_title":"Alice Through the Looking Glass","original_language":"en"},{"id":511785,"adult":false,"title":"Alex Strangelove","video":false,"overview":"Alex Truelove is on a quest to lose his virginity, an event eagerly awaited by his patient girlfriend and cheered on with welcome advice by his rowdy friends. But Alex, a super gregarious dude, is oddly unmotivated. A magical house party throws Alex into the presence of Elliot, a hunky college guy, who pegs Alex as gay and flirts hard. Alex is taken aback but after a series of setbacks on the girlfriend front he takes the plunge and learns some interesting new facts about himself.","genre_ids":[35,18],"media_type":"movie","popularity":0.6895,"vote_count":1565,"poster_path":"/6OemqmvthXswt5KFmtXBCMMloJ4.jpg","release_date":"2018-04-16","vote_average":6.6,"backdrop_path":"/rFVdcLMOXcDCBK4wrKj1cYWt2zL.jpg","original_title":"Alex Strangelove","original_language":"en"},{"id":81250,"adult":false,"title":"Geek Charming","video":false,"overview":"Film geek Josh is looking for the subject of his new documentary when a chance meeting puts the perfect star in his sights—Dylan, his school's most popular junior. But Dylan's hopes of using the film to become Blossom Queen don't quite match with Josh's goal to make a hard-hitting exposé about popularity. Will Josh shoot the film as planned, or show Dylan as the truly interesting person she is?","genre_ids":[35,18,10751,10770],"media_type":"movie","popularity":1.1651,"vote_count":785,"poster_path":"/xweQBQSYQyHKiUxN1nCDQbLvJE0.jpg","release_date":"2011-11-11","vote_average":6.7,"backdrop_path":"/5btPLADkUW3gxzIs25VdqRAOMtB.jpg","original_title":"Geek Charming","original_language":"en"},{"id":102382,"adult":false,"title":"The Amazing Spider-Man 2","video":false,"overview":"For Peter Parker, life is busy. Between taking out the bad guys as Spider-Man and spending time with the person he loves, Gwen Stacy, high school graduation cannot come quickly enough. Peter has not forgotten about the promise he made to Gwen’s father to protect her by staying away, but that is a promise he cannot keep. Things will change for Peter when a new villain, Electro, emerges, an old friend, Harry Osborn, returns, and Peter uncovers new clues about his past.","genre_ids":[28,12,878],"media_type":"movie","popularity":11.4865,"vote_count":14006,"poster_path":"/dGjoPttcbKR5VWg1jQuNFB247KL.jpg","release_date":"2014-04-16","vote_average":6.526,"backdrop_path":"/k0hlAzTryCYX1O1LyC6P8tAa8s0.jpg","original_title":"The Amazing Spider-Man 2","original_language":"en"},{"id":436969,"adult":false,"title":"The Suicide Squad","video":false,"overview":"Supervillains Harley Quinn, Bloodsport, Peacemaker and a collection of nutty cons at Belle Reve prison join the super-secret, super-shady Task Force X as they are dropped off at the remote, enemy-infused island of Corto Maltese.","genre_ids":[28,35,12],"media_type":"movie","popularity":11.8868,"vote_count":9401,"poster_path":"/q61qEyssk2ku3okWICKArlAdhBn.jpg","release_date":"2021-07-28","vote_average":7.468,"backdrop_path":"/jlGmlFOcfo8n5tURmhC7YVd4Iyy.jpg","original_title":"The Suicide Squad","original_language":"en"},{"id":43347,"adult":false,"title":"Love & Other Drugs","video":false,"overview":"Maggie is an alluring free spirit who won't let anyone – or anything – tie her down. But she meets her match in Jamie, whose relentless and nearly infallible charm serves him well with the ladies and the cutthroat world of pharmaceutical sales. Maggie and Jamie's evolving relationship takes them both by surprise, as they find themselves under the influence of the ultimate drug: love.","genre_ids":[18,35,10749],"media_type":"movie","popularity":5.6786,"vote_count":5498,"poster_path":"/wZLM2uKJRYNchLmiCIjosX0rXy8.jpg","release_date":"2010-11-22","vote_average":7,"backdrop_path":"/fGBJEfGjHmhg7nLAT0Jkcv9qV5e.jpg","original_title":"Love & Other Drugs","original_language":"en"},{"id":12,"adult":false,"title":"Finding Nemo","video":false,"overview":"Nemo, an adventurous young clownfish, is unexpectedly taken from his Great Barrier Reef home to a dentist's office aquarium. It's up to his worrisome father Marlin and a friendly but forgetful fish Dory to bring Nemo home -- meeting vegetarian sharks, surfer dude turtles, hypnotic jellyfish, hungry seagulls, and more along the way.","genre_ids":[16,10751],"media_type":"movie","popularity":15.4915,"vote_count":20290,"poster_path":"/eHuGQ10FUzK1mdOY69wF5pGgEf5.jpg","release_date":"2003-05-30","vote_average":7.817,"backdrop_path":"/eCynaAOgYYiw5yN5lBwz3IxqvaW.jpg","original_title":"Finding Nemo","original_language":"en"},{"id":181812,"adult":false,"title":"Star Wars: The Rise of Skywalker","video":false,"overview":"The surviving Resistance faces the First Order once again as the journey of Rey, Finn and Poe Dameron continues. With the power and knowledge of generations behind them, the final battle begins.","genre_ids":[12,28,878],"media_type":"movie","popularity":10.5788,"vote_count":10633,"poster_path":"/db32LaOibwEliAmSL2jjDF6oDdj.jpg","release_date":"2019-12-18","vote_average":6.273,"backdrop_path":"/jOzrELAzFxtMx2I4uDGHOotdfsS.jpg","original_title":"Star Wars: The Rise of Skywalker","original_language":"en"},{"id":640,"adult":false,"title":"Catch Me If You Can","video":false,"overview":"A true story about Frank Abagnale Jr. who, before his 19th birthday, successfully conned millions of dollars worth of checks as a Pan Am pilot, doctor, and legal prosecutor. An FBI agent makes it his mission to put him behind bars. But Frank not only eludes capture, he revels in the pursuit.","genre_ids":[18,80],"media_type":"movie","popularity":11.0348,"vote_count":16791,"poster_path":"/ctjEj2xM32OvBXCq8zAdK3ZrsAj.jpg","release_date":"2002-12-16","vote_average":7.977,"backdrop_path":"/ggC3Brchf4RqPitEh7cROFoeAWn.jpg","original_title":"Catch Me If You Can","original_language":"en"},{"id":11544,"adult":false,"title":"Lilo & Stitch","video":false,"overview":"As Stitch, a runaway genetic experiment from a faraway planet, wreaks havoc on the Hawaiian Islands, he becomes the mischievous adopted alien \"puppy\" of an independent little girl named Lilo and learns about loyalty, friendship, and ʻohana, the Hawaiian tradition of family.","genre_ids":[16,10751,35],"media_type":"movie","popularity":7.7646,"vote_count":6977,"poster_path":"/d73UqZWyw3MUMpeaFcENgLZ2kWS.jpg","release_date":"2002-06-21","vote_average":7.562,"backdrop_path":"/AcxbOWUbwtIEDisfuhNGHQNfnMK.jpg","original_title":"Lilo & Stitch","original_language":"en"},{"id":291270,"adult":false,"title":"Anomalisa","video":false,"overview":"An inspirational speaker becomes reinvigorated after meeting a lively woman who shakes up his mundane existence.","genre_ids":[16,18,10749,35],"media_type":"movie","popularity":1.5684,"vote_count":1798,"poster_path":"/4DJ1zNr4Y6q7zQ27goEYla46VdO.jpg","release_date":"2015-12-30","vote_average":7.102,"backdrop_path":"/xNykrL50OsygNTtFuHCw9U0D3eu.jpg","original_title":"Anomalisa","original_language":"en"}],"similar_content":[{"id":48650,"adult":false,"title":"Room in Rome","video":false,"overview":"A hotel room in the center of Rome serves as the setting for Alba and Natasha, two sexy and recently acquainted women, to have a physical adventure that touches their very souls.","genre_ids":[18,10749],"popularity":4.804,"vote_count":813,"poster_path":"/w90ItYf9qagQKVEBr1uFxPomAtf.jpg","release_date":"2010-05-07","vote_average":6.416,"backdrop_path":"/30TgnSvXiL7NQoQ5WWwHqw0FRhA.jpg","original_title":"Habitación en Roma","original_language":"es"},{"id":48651,"adult":false,"title":"Haha we Tofaha","video":false,"overview":"In a house the popular area, Abdeen, live Haha and his sister, Tuffaha, Haha works as \"Nubachi\" whose duty is to collect gift money thrown at belly dancers, at wedding parties, from under the dancers, while Tuffaha works as a nurse in a hospital. A conflict arises between them about who gets to keep the family home, as Haha wants to get married a live in it, and Tuffaha is in love with Fawzi, a gas cylinder mobile salesman, and wants to marry him and live in family home, but Haha disapproves this relationship.","genre_ids":[35,12],"popularity":0.4978,"vote_count":19,"poster_path":"/33sd8JsnEJVXK0ggdwF2neHPFg3.jpg","release_date":"2005-12-31","vote_average":5.2,"backdrop_path":"/9TQ3JGvOblrhm5ifuoPqCPU7upx.jpg","original_title":"حاحا وتفاحة","original_language":"ar"},{"id":48653,"adult":false,"title":"Harim Karim","video":false,"overview":"Kareem, a divorced young man, seeks the help of his girl friends from college to get back to his wife, Gigi. However, most of them like him, which makes the situation even more complicated as he tries to win Gigi back.","genre_ids":[35,10749],"popularity":0.4726,"vote_count":21,"poster_path":"/MdRbjpqRn5WOvwjJukRKuTRAfd.jpg","release_date":"2005-08-15","vote_average":5.238,"backdrop_path":"/xJF9o44AwMpn4nNB9hw1NDCkRzg.jpg","original_title":"حريم كريم","original_language":"ar"},{"id":48658,"adult":false,"title":"She Made Me a Criminal","video":false,"overview":"The movie is about a very naive young man, who wants to fix his house before it falls, but does not have the money, and rich girl who likes to spend money uncontrollably, whose father is scrooge, who would not give her access to her trust fund. In order to force her father to give her money, she stages a kidnapping with the assistance of her best friend and the naive young man, who ends up falling in love with her.","genre_ids":[10749,35,12],"popularity":0.9242,"vote_count":53,"poster_path":"/9InvbMsehKRhHMSbPvAJrK0boCz.jpg","release_date":"2006-03-15","vote_average":6.67,"backdrop_path":"/gyWQES8SdLH7pwNReQnpqu7Pz7x.jpg","original_title":"جعلتني مجرماً","original_language":"ar"},{"id":313219,"adult":false,"title":"Grasshopper","video":false,"overview":"Movie contains the stories of three people: Suzuki (Toma Ikuta), Kujira (Tadanobu Asano) and Semi (Ryosuke Yamada).  Suzuki is a former middle school teacher. His girlfriend was killed, which led him to quit his job and attempt to take revenge on her murderer. To do so, Suzuki has to infiltrate the underground world of criminals. Kujira is a contract killer for hire. He makes his targets fall into confusion and eventually commit suicide. Semi is a contract killer who uses the knife to take out his targets.","genre_ids":[80,53,28,18],"popularity":0.6663,"vote_count":15,"poster_path":"/h9YkeTwcSnep0ZvEA6U5KtqCzb5.jpg","release_date":"2015-11-07","vote_average":5.933,"backdrop_path":"/44L1vTmftGyK0aRtKFJMAMHsEc4.jpg","original_title":"グラスホッパー","original_language":"ja"},{"id":513327,"adult":false,"title":"All You Ever Wished For","video":false,"overview":"A young New York fashion executive's trip to Milan takes a bad turn when he is kidnapped and whisked off to an Alpine village to be held for ransom money. Little does he (or his three abductors) know that the small, rustic cottage they end up spending the night in is under a gypsy love spell. Or that when they awaken, they will be Smitten! by the first living soul that meets their eyes.","genre_ids":[18,35],"popularity":0.3715,"vote_count":6,"poster_path":"/8oV7BGXV0xYqeHYdt9q5PA6ukDC.jpg","release_date":"2018-08-03","vote_average":4.7,"backdrop_path":"/shStY99upTamPRfWu9EjcV7P6ij.jpg","original_title":"All You Ever Wished For","original_language":"en"},{"id":48615,"adult":false,"title":"Devotion","video":false,"overview":"In total despair, Anja is about to throw herself from a bridge. At that very moment, Henry drives past in his car. Thinking she's a prostitute, he invites her home with him. Anja pretends to be what Henry initially thought. She refuses to explain the reasons for her apparent attempt at suicide. The two begin to play strange games, engage in unusual sex, leading Anja to try fleeing the apartment, but Henry catches her. Forced by Henry, Anja tells him about Lilly who was raped and then killed someone, leaving Henry with the impression that Lilly and Anja are one, the same person. They play more mind games, make love, and after Anja going back and forth trying to leave, Henry finally lets her go. She goes, but is back again soon after. And with a vengeance, she causes a series of strange events which will change the course of both of their lives","genre_ids":[18,53],"popularity":1.0029,"vote_count":14,"poster_path":"/bPvUPLNdXjzEOeWM5rul35vztnp.jpg","release_date":"2003-02-08","vote_average":4.5,"backdrop_path":null,"original_title":"Devot","original_language":"de"},{"id":48621,"adult":false,"title":"Al-Zamahlawia","video":false,"overview":"The film revolves around the families of Shehata Hussein and Salim Abu Nawas (Salah Eidullah and Izzat Abu Auf), one of whom belongs to Zamalek football Club and the other to Al-Ahli football  Club. Both families have a lot of hostile feelings because of their extreme football fanaticism. Abeer Abu Nawas (Bushra) is in love with Hassan Ibn Shehata (Ahmed Azmi), which puts this story of love in front of the obstacle of football fanaticism of both families.","genre_ids":[35],"popularity":0.1942,"vote_count":9,"poster_path":"/3XYWW1ciPHGWbgUlgIaocahNNY2.jpg","release_date":"2008-11-03","vote_average":4.222,"backdrop_path":"/bh3BRWWPbY2SYMVeSrmR1dMszk3.jpg","original_title":"الزمهلاوية","original_language":"ar"},{"id":313026,"adult":false,"title":"Holger sacht nix","video":false,"overview":"Completely burnt out, without a job or prospects, but with her son Theo in tow, Olga has to bury her high-flying big city and career dreams and seek shelter with her parents back in her home village in her early 30s. While mother Lilo is happy to have the two of them with her, Holger continues to punish daughter and grandson with stoic disregard. Holger cannot forgive Olga for refusing to take over her parents' farm, breaking off her engagement to the young farmer Nico head over heels and simply moving to the big city.","genre_ids":[35],"popularity":0.1466,"vote_count":1,"poster_path":"/cHsHgcBhEqRX0uRWGJpTAB2lBT5.jpg","release_date":"2011-10-26","vote_average":4,"backdrop_path":null,"original_title":"Holger sacht nix","original_language":"de"},{"id":48722,"adult":false,"title":"The Dictator","video":false,"overview":"A satirical political story about a ruler who thwarts those who object to his orders, he's feared by everyone because of his severe dictatorship. Many situations takes place between him and his twin children that deal with the crises of the ordinary citizen until a violent surprise turns things upside down.","genre_ids":[35,18],"popularity":0.2242,"vote_count":6,"poster_path":"/d3jPi1xortcHfrX2E4Va7HzCTyx.jpg","release_date":"2009-09-20","vote_average":4.7,"backdrop_path":null,"original_title":"الدكتاتور","original_language":"ar"},{"id":49013,"adult":false,"title":"Cars 2","video":false,"overview":"Star race car Lightning McQueen and his pal Mater head overseas to compete in the World Grand Prix race. But the road to the championship becomes rocky as Mater gets caught up in an intriguing adventure of his own: international espionage.","genre_ids":[16,10751,12,35],"popularity":11.6595,"vote_count":8352,"poster_path":"/okIz1HyxeVOMzYwwHUjH2pHi74I.jpg","release_date":"2011-06-11","vote_average":6.172,"backdrop_path":"/4BS8tgBNWg2jPiDlBwM2iJe1xB7.jpg","original_title":"Cars 2","original_language":"en"},{"id":901410,"adult":false,"title":"xxxHOLiC","video":false,"overview":"To be free of his dark visions, Kimihiro Watanuki will work for Dimensional Witch Yūko, a mystical woman quick to help those in a bind—for a fee.","genre_ids":[18,9648,53],"popularity":1.12,"vote_count":27,"poster_path":"/9anVNOiOTBhO1vet1Q31rQR2xtO.jpg","release_date":"2022-04-29","vote_average":6.574,"backdrop_path":"/wN6aUgXotlGVSgKGOdeYpWeyCnD.jpg","original_title":"ホリック xxxHOLiC","original_language":"ja"},{"id":901414,"adult":false,"title":"Encore Martha","video":false,"overview":"Follows two women who re-encounter each other after 30 years apart. Against all odds, they fall in love once again, and despite that youth is no longer on their side, they decide to spend the remaining of their twilight years in each other’s arms, no matter how much that may be.","genre_ids":[10749,18,10751],"popularity":0.1576,"vote_count":0,"poster_path":"/d3iW9lc8o2IuNlb5K8Ww9BimMY4.jpg","release_date":"2021-12-10","vote_average":0,"backdrop_path":"/zcSZGRHlxXA1PlNTRW1AaGUaCWQ.jpg","original_title":"安可瑪莎","original_language":"zh"},{"id":705990,"adult":false,"title":"Take Me Home","video":false,"overview":"Same-sex couple Eun-soo and Ye-won are living together happily. One day, a terrible traffic accident occurs and Eun-soo is seriously injured and her sister Eunhae dies. Eun-soo is disabled and Eunhae's daughter Soo-min became an orphan. Now Eun-soo and Ye-won are in a position to take charge of Soo-min.","genre_ids":[18,10749],"popularity":0.2667,"vote_count":2,"poster_path":"/fUTVoqYpygh9CYgkVDdQ1h5xXnq.jpg","release_date":"2020-10-28","vote_average":6,"backdrop_path":"/8JKSzVjGewevLZKhQP4rNugr1Dt.jpg","original_title":"담쟁이","original_language":"ko"},{"id":48954,"adult":false,"title":"The 'Maggie'","video":false,"overview":"The poor, elderly—and the wily, when it comes to parting those who can afford it from their money—Scottish skipper of a broken-down old 'puffer' boat tricks an American tycoon into paying him to transport his personal cargo. When the tycoon learns of the trick, he attempts to track down the boat and remove his possessions.","genre_ids":[35],"popularity":0.3342,"vote_count":38,"poster_path":"/dNOaqMf1k2mvLHvCIpCAi7W78wf.jpg","release_date":"1954-02-25","vote_average":6.3,"backdrop_path":"/ww7Ttoe3EqWEC6iQ3SrtZnlwPgD.jpg","original_title":"The 'Maggie'","original_language":"en"},{"id":513810,"adult":false,"title":"The Security Men","video":false,"overview":"A group of night security guards working at the fictional Whittington shopping centre in Greater Manchester must create an elaborate scheme to hide a robbery that has taken place on their watch.","genre_ids":[35,10770],"popularity":0.2278,"vote_count":0,"poster_path":"/DWSGvtJHXwKEIAF4ffNuQvGHh8.jpg","release_date":"2013-04-12","vote_average":0,"backdrop_path":"/kYCkUH3ZzHerB2brPqfxTbPqRAu.jpg","original_title":"The Security Men","original_language":"en"},{"id":706566,"adult":false,"title":"Caution, Hazardous Wife: The Movie","video":false,"overview":"At the end of the TV series of the same name, it is revealed that the husband works for the Public Security Bureau, and their marriage is a cover to keep her under surveillance. In spite of his mission, he falls in love with Nami and tries to convince her not to get involved in other people’s affairs. She is being monitored as a state-level security risk, and the bureau is unwilling to tolerate any more trouble from her. However, to save a friend, Nami runs out of the house and risks everything she has to confront the enemy. When she comes home, she finds her husband pointing a gun at her! A gunshot echoes through the quiet, upscale neighborhood…The movie picks up where the controversial ending of the drama series left off!!","genre_ids":[28,35,10749],"popularity":0.7332,"vote_count":15,"poster_path":"/67FAUFk5eduymBslaEzxZ5w7O4R.jpg","release_date":"2021-03-19","vote_average":7.2,"backdrop_path":"/sDkylBf6ATZJ3Gtre7CAtsF3q1l.jpg","original_title":"劇場版 奥様は、取り扱い注意","original_language":"ja"},{"id":49267,"adult":false,"title":"Just One Time","video":false,"overview":"When the fiancé of a fireman reluctantly agrees to participate in a ménage à trois with another woman, she does so on the condition that he reciprocate the favor with another man, which ultimately puts their impending marriage in jeopardy.","genre_ids":[35,10749],"popularity":0.389,"vote_count":20,"poster_path":"/cAdV1mRjpkrqp8Y72iRH3khJQZH.jpg","release_date":"1999-09-13","vote_average":4.675,"backdrop_path":"/gtHBcZWZ31wvgT1rj7luhTehKeV.jpg","original_title":"Just One Time","original_language":"en"},{"id":314027,"adult":false,"title":"Alessandro Siani - Tienimi presente","video":false,"overview":"","genre_ids":[35,10751],"popularity":0.7418,"vote_count":14,"poster_path":"/yrNbVd6FGeoQyPWbX6UauG9QCLH.jpg","release_date":"2007-04-23","vote_average":7,"backdrop_path":"/hEOuGhjxNlfgF6j3XeEcbckXis9.jpg","original_title":"Alessandro Siani - Tienimi presente","original_language":"it"},{"id":49677,"adult":false,"title":"Peony Pavilion","video":false,"overview":"In 1930s Suzhou, the fifth wife of an opium-addicted aristocrat, her husband's female cousin, and a handsome instructor develop an intense relationship.","genre_ids":[18,10749],"popularity":0.6289,"vote_count":13,"poster_path":"/8vp4GgM9wJKaTvzvSzD4WKPMla0.jpg","release_date":"2001-12-07","vote_average":6.7,"backdrop_path":"/mXeLbkvoRoqimpzsxPI7REiQ2Ec.jpg","original_title":"遊園驚夢","original_language":"zh"}],"external_ids":{"imdb_id":"tt3617996","twitter_id":null,"facebook_id":null,"wikidata_id":"Q11272005","instagram_id":null,"mydramalist_id":"265499"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148331,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"JP","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2014-07-19T00:00:00.000Z","certification":"15"}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikidata_metadata":{"distributors":["Kadokawa Future Publishing"]},"mood_tags":null,"trope_tags":null,"vibe_description":null,"ai_enriched_at":null,"ai_enrichment_version":0}}]]
