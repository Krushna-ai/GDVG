5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Torture Club\",\"description\":\"The \\\"Torture Club\\\" is an official after-school activity at the private school Saint Honesty Gakuen. Yuzuki has no idea about the club when she enrolls, and gets abducted by the club members and hauled off the club-room. There, she finds out that upper-class student Aoi, her secret idol, is in the club, and decides to join, but…\",\"image\":\"https://image.tmdb.org/t/p/w500/rJQQxeNqf4Cs0NtlftVJyfHDoEc.jpg\",\"datePublished\":\"2014-07-19\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Drama\",\"Comedy\",null,null,null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.188,\"bestRating\":10,\"ratingCount\":48}}"}}],["$","$L10",null,{"initialDrama":{"id":"d823292d-6f10-4a83-8cdf-b950b6ad0486","tmdb_id":297090,"imdb_id":"tt3617996","content_type":"movie","title":"The Torture Club","original_title":"ちょっとかわいいアイアンメイデン","overview":"The \"Torture Club\" is an official after-school activity at the private school Saint Honesty Gakuen. Yuzuki has no idea about the club when she enrolls, and gets abducted by the club members and hauled off the club-room. There, she finds out that upper-class student Aoi, her secret idol, is in the club, and decides to join, but…","poster_path":"/rJQQxeNqf4Cs0NtlftVJyfHDoEc.jpg","backdrop_path":"/bYXYrMZeS792zS87xD9ySUALVgK.jpg","release_date":"2014-07-19","first_air_date":null,"status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":18,"name":"Drama"},{"id":35,"name":"Comedy"},"romance film","LGBT-related film","LGBTQ+-related film","LGBTQ-related film"],"popularity":14.0234,"vote_average":5.188,"vote_count":48,"runtime":97,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-25T00:54:39.300799+00:00","updated_at":"2026-02-25T00:54:39.1