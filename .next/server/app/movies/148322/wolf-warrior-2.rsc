_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":583,"height":1000,"file_path":"/aSm1UZjL2Kpym3UbSK6FJH6f5T8.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.583,"vote_average":0},{"width":1024,"height":1568,"file_path":"/cchYSzC3ZmpBNw7Osea7tJlD4e3.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.653,"vote_average":0},{"width":1024,"height":1568,"file_path":"/c0abz4Yuncok0TA3ppruxYVCbp1.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.653,"vote_average":0},{"width":1024,"height":1568,"file_path":"/goc7d5kQMnITSzdQmqo3g2F5rPL.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.653,"vote_average":0},{"width":1280,"height":1935,"file_path":"/q8KiosbRW65iPr66sNQAQ3RTcHc.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.661,"vote_average":0},{"width":500,"height":750,"file_path":"/teGmeconjRui8LWr3xPC5URv38f.jpg","iso_639_1":"ko","iso_3166_1":"KR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1065,"height":1609,"file_path":"/Geeae0c4DDg1rI1XqjOm25BIoG.jpg","iso_639_1":"th","iso_3166_1":"TH","vote_count":0,"aspect_ratio":0.662,"vote_average":0},{"width":1000,"height":1407,"file_path":"/p7BS3nOUCuvjaewxTEbIAc8NAUq.jpg","iso_639_1":"zh","iso_3166_1":"HK","vote_count":0,"aspect_ratio":0.711,"vote_average":0},{"width":2000,"height":3000,"file_path":"/7GQUntB4H6wcGnt0OUL1MyokJ9a.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":950,"height":1361,"file_path":"/6BrzTWK2EWeVi3MBy6ivcQcSXWr.jpg","iso_639_1":"ko","iso_3166_1":"KR","vote_count":0,"aspect_ratio":0.698,"vote_average":0},{"width":900,"height":1350,"file_path":"/aOOpg3ZcKYcesTbmz1Ezgdd2oZq.jpg","iso_639_1":"uk","iso_3166_1":"UA","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1400,"file_path":"/bG4BTO49G55wBGJobBNz6ZGMWV7.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.714,"vote_average":0},{"width":2000,"height":3000,"file_path":"/9YNgmMc8p5gnURyv3idLdt3Zc2n.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1672,"height":2508,"file_path":"/xovwi6e3fcXkwkVu6A4ORfNxP2E.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/mjudUA3QNsJCtuDeXUx55MLzuKM.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/dpbjivY5OdZjAr1gmRZVCsEkYRC.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/udCrc8kFlPL0vzxky2g2jXhxCai.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/9eEWktJWPcVFl77LHIaVDFz8wuy.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/aOmKcHieab95f2aDSFzF2C4L5Sl.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/t5Fivf6oPnhoqSN5tpHK7PZn5GG.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:52:13.6+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Wolf Warrior 2","runtime":124,"tagline":"","homepage":"","overview":"China's deadliest special forces operative settles into a quiet life on the sea. When sadistic mercenaries begin targeting nearby civilians, he must leave his newfound peace behind and return to his duties as a soldier and protector."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"战狼2","runtime":123,"tagline":"犯我中华者 虽远必诛","homepage":"","overview":"　　在非洲附近的大海上。主人公冷锋遭遇人生滑铁卢，被“开除军籍”。本想漂泊一生的他却被一场突如其来的意外打破了他的计划，他被卷入了一场非洲国家叛乱。本可以安全撤离却因无法忘记曾经为军人的使命，孤身犯险冲回沦陷区，带领身陷屠杀中的同胞和难民展开生死逃亡。随着斗争的持续，体内的狼性逐渐复苏，最终孤身闯入战乱区域为同胞而战斗。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Wolf Warrior 2","runtime":0,"tagline":"","homepage":"","overview":"Un soldat des forces spéciales chinoises reprend le combat pour protéger les habitants d'un pays africain en guerre contre des mercenaires et des trafiquants d’armes."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Война волков 2","runtime":123,"tagline":"","homepage":"","overview":"Самый смертоносный спецназовец Китая поселился в спокойной жизни на море. Когда садистские наемники начинают атаковать близлежащих гражданских лиц, он должен оставить свой новообретённый мир позади и вернуться к своим обязанностям солдата и защитника."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Wolf Warrior 2","runtime":0,"tagline":"Wolf Warrior 2","homepage":"","overview":"Secuela de la película de acción exitosa \"Wolf Warrior\" (2015) La operación más peligrosa de las fuerzas especiales de China se instala en una vida tranquila en el mar. Cuando los mercenarios sádicos comienzan a atacar a civiles cercanos, él debe dejar atrás su nueva paz y volver a sus deberes como soldado y protector."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Войната на вълците 2","runtime":126,"tagline":"","homepage":"","overview":"Най-опасният от спец частите на Китай се отдава на спокоен живот край морето. Но когато садистични наемници започват да тормозят цивилни лица, той трябва да зареже спокойния живот и да се върне към задълженията си."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"זאב לוחם 2","runtime":0,"tagline":"","homepage":"","overview":"חייל של הכוחות המיוחדים והקטלנים ביותר של סין מתמקם לחיים שקטים ליד הים. כאשר שכירי חרב סדיסטיים מתחילים למקד אזרחים הסמוכים אליו, הוא חייב לעזוב את שלווה החדשה שלו מאחור ולחזור לתפקידו כחייל ומגן."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Wolf Warrior 2","runtime":0,"tagline":"Savaşçı Kurt 2","homepage":"","overview":"Çin Özel Kuvvetlerinden bir asker olan Yeng Feng denizde sakin bir hayat kurmuştur. Sadist paralı askerler civardaki sivilleri hedef alınca yeni bulduğu huzuru bırakıp askerlik ve koruyuculuk görevine dönmek zorunda kalır…"},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Wolf Warrior 2","runtime":0,"tagline":"","homepage":"","overview":"Bývalý příslušník elitní čínské speciální jednotky Wolf Warriors, Leng Feng, se po incidentu s chamtivým developerem dostal na tři roky do vězení. Po propustění se rozhodl dát své schopnosti a zkušenosti do služeb firmy operující v jisté africké zemi. Jednoho dne v zemi vypukne ozbrojený převrat a on se ocitá v epicentru bojů mezi znepřátelenými stranami. Poblíž něj uvízla v následném chaose i skupinka čínských dělníků a čínský lékař Dr. Chen. Leng bere na sebe nelehký úkol evakuovat všechny do přístavu, kde na ně čekají lodě čínského námořnictva..."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Harcos Farkas II","runtime":123,"tagline":"","homepage":"","overview":"Kína különleges osztagának egyik ügynöke visszavonul, hogy ezután egy nyugodtabb életet élhessen. Egy napon szadista zsoldosok veszik célkeresztbe a közeli civileket, így hősünknek ott kell hagynia a béke szigetét, hogy újból megvédhesse az ártatlanokat."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"특수부대 전랑2","runtime":0,"tagline":"제한시간 18시간! 모두의 목숨을 구하라!","homepage":"","overview":"특수부대 ‘전랑’ 출신의 ‘렁펑‘(오경)은 아프리카에서 수 백명의 인질을 볼모로 국가를 장악하려는 테러집단과 마주하게 된다. 인질들을 구출하기 위해 허락된 시간은 단 18시간! UN도 국가도 포기한 전쟁에서 ‘렁펑’은 테러집단을 소탕하고 인질을 무사히 구출할 수 있을 것인가!"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"กองพันหมาป่า","runtime":123,"tagline":"กองพันหมาป่า","homepage":"","overview":"เรื่องราวของอดีตเจ้าหน้าที่พิเศษแห่งหน่วยฝูงรบหมาป่าเลิงเฝิง (อู๋จิง) ที่ได้ตัดสินใจเดินทางมายังแอฟริกาเพื่อหาความสงบ แต่ดูเหมือนชะตากรรมจะไม่ให้เขาได้มีเวลาพักเมื่อตัวเขา ต้องเข้าไปพัวพันกับความวุ่นวายของกลุ่มกบฎต่อต้านรัฐบาล รวมถึงภารกิจช่วยชีวิต ราเชล (เซลินา เจด) แพทย์จิตอาสาประจำแอฟริกาให้รอดพ้นจากเงื้อมมือของกลุ่มทหารรับจ้างสุดโหดที่นำโดยจอมซาดิสต์อย่างบิ๊ก แดดดี (แฟรงก์ กริลโล) และผู้ที่จะยุติเรื่องราวนี้ได้มีเพียงนักรบหมาป่าผู้นี้เท่านั้"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Wolf Warrior 2","runtime":0,"tagline":"","homepage":"","overview":"Leng Feng (Jing Wu) war in der chinesischen Spezialeinheit Wolf Warriors. Diese bestens ausgebildeten, super erfahrenen Soldaten töten so treffsicher wie sonst niemand im Land. Aber Leng Feng flog raus. Also ging der ehemalige Elitesoldat an die Küste Afrikas, wo er ein neues Leben führt, ohne Töten und Todesangst. Doch Leng Feng kann sein Exil nicht lange genießen, kann dem Kampf nicht lange entkommen: Eine Rebellenarmee greift Zivilisten an und löst damit einen Bürgerkrieg aus, der von einer internationalen Söldnertruppe verschärft wird. Der Ex-Warrior denkt gar nicht daran, nur zuzuschauen. Er greift erneut zur Waffe, damit die Unschuldigen einen Beschützer haben und der Anführer der Söldner Big Daddy (Frank Grillo) einen würdigen Gegner. Gekämpft wird mit Patronen, Fäusten und Panzern…"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Wolf Warrior 2","runtime":0,"tagline":"","homepage":"","overview":"Le più mortali forze speciali della Cina si acquartierano in un tranquillo paese marittimo. Quando i mercenari iniziano a prendere di mira, con sadismo i vicini civili, deve interrompere la sua vita equilibrata e tornare ai suoi doveri di guerriero e protettore."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Wilk Wojny 2","runtime":0,"tagline":"","homepage":"","overview":"Chiński członek specjalnych sił zbrojnych prowadzi spokojne życie nad morzem. Kiedy sadystyczni najemnicy zaczynają zabijać lokalnych cywili, mężczyzna musi porzucić dotychczasowe życie i powrócić do swoich obowiązków jako żołnierz i obrońca."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Lobo Guerreiro 2","runtime":0,"tagline":"Qualquer um que ofenda a China será punido, não importa quão longe esteja.","homepage":"","overview":"Depois de realizar uma ação contra uma perigosa organização criminosa e eliminar o filho de um grande traficante, Leng Feng, um soldado do batalhão de forças especiais da China, foi perseguido e terminou se aposentando quando a ameaça acabou. Agora, Feng vive tranquilamente em um barco. Quando um grupo de mercenários começa a atacar um povoado perto de onde Feng está atracado, o ex,soldado se vê obrigado a voltar à ativa, uma vez que jurou proteger os inocentes. Um novo duelo tem início e o inimigo será mais feroz do que nunca!"},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"戰狼2","runtime":126,"tagline":"犯我中華者 雖遠必誅","homepage":"","overview":"在非洲大公海上，捲入非洲叛亂的冷峰本來可以安全撤離，卻放不下曾身為軍人的使命感，衝入淪陷區，拯救面臨屠殺危機的同胞和難民。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Zhan Lang II","runtime":123,"tagline":"","homepage":"","overview":"Leng Feng is het dodelijkste lid van de special forces in China. Hij heeft besloten zich terug te trekken en een rustig leventje te leiden aan de zee. Maar wanneer sadistische huurlingen de burgers die in die omgeving wonen terroriseren....,"},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Wolf Warrior 2","runtime":0,"tagline":"","homepage":"","overview":"Uno de los mejores soldados de las fuerzas especiales chinas decide llevar una vida tranquila, pero cuando unos mercenarios empiezan a causar revuelo, tendrá que dejar esa tranquilidad para restablecer el orden."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"戰狼 2","runtime":0,"tagline":"","homepage":"","overview":"冷鋒（吳京飾）送戰友俞飛（戰狼中隊的分隊長，前集犧牲）的骨灰回老家，俞家卻正遭不法奸商強拆，由於拆遷隊頭目揚言要在冷鋒他們走後報復俞飛家人，冷鋒將其踢成重傷。冷鋒因傷人被開除軍籍並被判監禁，期間未婚妻龍小雲（餘男飾，前集女主角）向其求婚，卻在前往邊境執行任務時失蹤。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Chiến Lang 2","runtime":0,"tagline":"","homepage":"","overview":"Đặc nhiệm nguy hiểm nhất của lực lượng đặc biệt Trung Quốc ổn định cuộc sống yên tĩnh trên biển. Khi những tên lính đánh thuê tàn bạo bắt đầu nhắm vào dân thường gần đó, anh ta phải bỏ lại sự bình yên mới tìm được phía sau và quay trở lại nhiệm vụ của mình như một người lính và người bảo vệ."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Wolf Warrior II","runtime":0,"tagline":"","homepage":"","overview":"O πλέον θανατηφόρος πράκτορας των ειδικών δυνάμεων της Κίνας έχει εγκατασταθεί κοντά στη θάλασσα με σκοπό να κάνει μια ήσυχη ζωή. Όταν όμως σαδιστές μισθοφόροι αρχίζουν να τρομοκρατούν αθώους πολίτες, πρέπει να εγκαταλείψει την ειρηνική του ζωή και να επιστρέψει στα καθήκοντα του ως στρατιώτης και προστάτης."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"戦狼 ウルフ・オブ・ウォー","runtime":0,"tagline":"","homepage":"","overview":"アフリカ、マダガスカル海域。一人の男が、海賊に襲われた貨物船を救出した。男の名はレン。元特殊部隊「戦狼」の精鋭だ。とある事件から軍籍を剥奪されたレンは、反政府 勢力に殺害された恋人・ロンの敵を討つべく、この地に渡っていたのだ。しかし、その最中、反乱が勃発。命からがら護衛艦に避難したレンだが、戦闘地域に民間人が取り残されているという話を耳にし、単独、戦地に舞い戻る。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Війна вовків 2","runtime":0,"tagline":"","homepage":"","overview":"Фільм розповідає історію китайського солдата Лен Феня. Він виконує місії спеціального призначення у всьому світі. Наразі Фень опинився в африканській країні та повинен захистити працівників медичної допомоги від місцевих повстанців та небезпечних торговців зброєю."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"المحارب الذئب 2","runtime":0,"tagline":"","homepage":"","overview":"يقرر أحد أفراد قوات العمليات الخاصة في الصين أن ينعم بحياة هادئة بعيدًا عن المشاكل على شاطيء البحر، وعندما يقرر مجموعة من المرتزقة استهداف المدنيين، عليه أن يودع السلام الذي يعيشه في الوقت الحالي لكي يقوم بواجباته."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Războiul lupilor 2","runtime":0,"tagline":"","homepage":"","overview":"Filmul este continuarea celui din 2015 si spune povestea unui soldat chinez, numit Leng Feng, care are misiuni speciale in intreaga lume. In aceasta continuare, se afla intr-o tara africana unde protejeaza personalul medical de rebelii locali si de dealerii de arme periculosi..."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"}],"reviews_tmdb":[],"recommendations":[{"id":933379,"adult":false,"title":"A Song of Sword as Pillow: Practice Travel","video":false,"overview":"\"Turning a blind eye is the same crime as the executioner\".  　　The first extra-long theatrical version of the series, the story revolves around the treacherous struggle that takes place in Shandong Linqing between many Jianghu sects, the protagonist Cao Gang young master Luo Tong involved in a conspiracy against the Cao Gang, facing the imminent destruction of the Cao Gang, as well as the pursuit of many Jianghu sects, Luo Tong in his childhood friend Hongniang, create the gods Jiang Yuan, reckless righteous Long Shun's help, step by step closer to the truth, each with their own beliefs and Adherence, and the result of a full-blooded and fervent battle ......","genre_ids":[16,28],"media_type":"movie","popularity":0.2545,"vote_count":2,"poster_path":"/8jpnBbBibgHaGpAQDspPBdXo5s.jpg","release_date":"2022-02-01","vote_average":8.5,"backdrop_path":"/tr2IpqNUuuZ9RLOCQ2VrTThkOJc.jpg","original_title":"枕刀歌之尘世行","original_language":"zh"},{"id":45611,"adult":false,"title":"Jack Hunter and the Lost Treasure of Ugarit","video":false,"overview":"Jack Hunter, an adventurous treasure seeker, goes to Syria after his mentor and father figure Professor Fredrick Shaffer is killed. Professor Frederick Shaffer believed that the people of Ugarit, a town in Syria that existed during the Pharoah’s reign, had buried a treasure before they were wiped out by the Pharoahs. Jack Hunter is one of the few archaeologists in the world who can interpret Ugarit writings","genre_ids":[12,28],"media_type":"movie","popularity":0.7275,"vote_count":46,"poster_path":"/q2NdUrQrkIfjYPShFuHxsvpe9mY.jpg","release_date":"2010-03-01","vote_average":6.4,"backdrop_path":"/bSB8HQc01JHXQ1hvypnWIlJKFqL.jpg","original_title":"Jack Hunter and the Lost Treasure of Ugarit","original_language":"en"},{"id":188598,"adult":false,"title":"Ilo Ilo","video":false,"overview":"During the late 1990s, a busy working-class Singaporean couple hires a Filipino woman as a maid and nanny to their young son.","genre_ids":[18,10751],"media_type":"movie","popularity":0.4044,"vote_count":119,"poster_path":"/AfVMrZHiZQW8ONm6Rok3afvHbXB.jpg","release_date":"2013-08-29","vote_average":6.895,"backdrop_path":"/3MPwbz1ILBWs3LGTOuM4NirvBj9.jpg","original_title":"爸妈不在家","original_language":"zh"},{"id":9835,"adult":false,"title":"Jane Austen's Mafia!","video":false,"overview":"After growing up poor in Salmonella, Vincenzo Cortino installs himself as the preeminent, if bumbling, Mafia don of the New World. But now he must pass on power to one of his two sons: either level-headed veteran Anthony or vituperative loose cannon Joey.","genre_ids":[35,80],"media_type":"movie","popularity":0.9245,"vote_count":208,"poster_path":"/gGgirOcInrfjWgemKMjvZc3fGtU.jpg","release_date":"1998-07-24","vote_average":5.44,"backdrop_path":"/fyhxTKsJ3x47z9rgMvkqL1haT6S.jpg","original_title":"Jane Austen's Mafia!","original_language":"en"},{"id":554205,"adult":false,"title":"A Cool Fish","video":false,"overview":"Cop-turned-security guard Ma Xianyong finds himself in a criminal twilight zone when two unrelated events turn his world upside down. The mysterious disappearance of his boss has implications for his financial security. Even more perilous is the abduction of his paralyzed sister who, unknown to Ma, makes a morbid deal with her captors.","genre_ids":[35,53,80],"media_type":"movie","popularity":0.5291,"vote_count":96,"poster_path":"/xhXIJFaCgnnNxmMc2wWz9J11sey.jpg","release_date":"2018-11-15","vote_average":7.016,"backdrop_path":"/iRBJXdXjATsm0Qnq6JYrBSTQ3qq.jpg","original_title":"无名之辈","original_language":"zh"},{"id":51306,"adult":false,"title":"Lost on Journey","video":false,"overview":"A boss of a toy corporation, Chenggong Li, tries to head back to Chan Sar to celebrate the Chinese New Year with his family. However, plans don't go as smoothly after he crosses paths with a stranger, Geng Niu.","genre_ids":[35],"media_type":"movie","popularity":0.8069,"vote_count":101,"poster_path":"/afGsGhnndLRoMmt7wvRnIyauGLw.jpg","release_date":"2010-06-04","vote_average":7.104,"backdrop_path":"/4GnuNli4YFpXCu8nKSAuNtrlQ1G.jpg","original_title":"人在囧途","original_language":"zh"},{"id":335462,"adult":false,"title":"Wolf Warrior","video":false,"overview":"A Chinese special force soldier with extraordinary marksmanship is confronted by a group of deadly foreign mercenaries who are hired to assassinate him by a vicious drug lord.","genre_ids":[28,10752],"media_type":"movie","popularity":2.1747,"vote_count":273,"poster_path":"/9tGyxJcPUQclngSCcT18oEs80Yn.jpg","release_date":"2015-04-02","vote_average":6.198,"backdrop_path":"/zUmcuYkAbbl5YX4wabqdKLWSBlZ.jpg","original_title":"战狼","original_language":"zh"},{"id":267800,"adult":false,"title":"Sundown","video":false,"overview":"High school seniors Logan and Blake prepare for an epic Spring Break as they travel to the beautiful and exotic Mexican beach resort of Puerto Vallarta hoping to hook up with their high school crushes. Surrounded by hot girls in teeny bikinis, the guys are truly in heaven. After meeting at a club, Logan falls for a mysterious local beauty named Gaby but then realizes the next morning, when his grandfather’s Rolex watch is missing, that she was after more than just his heart.","genre_ids":[10749,35],"media_type":"movie","popularity":0.6183,"vote_count":96,"poster_path":"/kuqB9ejNH7w4n2067ZSMuwhNnwm.jpg","release_date":"2016-05-16","vote_average":5.792,"backdrop_path":"/p5AwpwkF6gcRJ04NEbtUQM7vJMN.jpg","original_title":"Sundown","original_language":"en"},{"id":188183,"adult":false,"title":"Finding Mr. Right","video":false,"overview":"When Jiajia, a young woman in Beijing who lives a luxurious life provided by her wealthy boyfriend, gets pregnant, she goes to the United States, hoping that the baby will be born an American citizen. There she meets Frank who offers help and makes her think twice about who her Mr. Right really is.","genre_ids":[35,10749],"media_type":"movie","popularity":1.174,"vote_count":118,"poster_path":"/i5878aOaviEYHhddwBzEVW0RazX.jpg","release_date":"2013-03-21","vote_average":6.419,"backdrop_path":"/hNSpy8v7xKC21rr1wTVDpDku544.jpg","original_title":"北京遇上西雅图","original_language":"zh"},{"id":574303,"adult":false,"title":"Jo Pil-ho: The Dawning Rage","video":false,"overview":"On the run from a dogged internal affairs agent, a corrupt cop reluctantly teams up with a defiant teen to unravel a conspiracy before it's too late.","genre_ids":[28,80,18,53],"media_type":"movie","popularity":0.8907,"vote_count":123,"poster_path":"/k4QPUYRupu7Jv8ZWS9hiLw5OuhB.jpg","release_date":"2019-03-20","vote_average":6.102,"backdrop_path":"/57rzB3e08jiNexS4tq1K5efdLe.jpg","original_title":"악질경찰","original_language":"ko"},{"id":45380,"adult":false,"title":"Crazy Stone","video":false,"overview":"Three thieves try to steal a valuable jade that is tightly guarded by a security chief. But the security guards are not the only obstacle these thieves are facing. An extremely unlucky internationally known master thief is also trying to get a hand on this piece of precious jade. What would be the final destination of this piece of crazy stone?","genre_ids":[28,35],"media_type":"movie","popularity":0.8352,"vote_count":139,"poster_path":"/4NVNv2sQKZKb1HtGExUqp3Ukd7f.jpg","release_date":"2006-06-30","vote_average":7.612,"backdrop_path":"/8xzVdkNPNbqT6kJA6IHaRKFpt0B.jpg","original_title":"疯狂的石头","original_language":"zh"},{"id":538246,"adult":false,"title":"La Dama del Corvette","video":false,"overview":"No one could've ever imagined that this beautiful women who never leaves her sports car has the guts to collect debts in cold blood.","genre_ids":[28,80],"media_type":"movie","popularity":0.0286,"vote_count":94,"poster_path":"/1zG6IWEDM15TFkIYHM9t0Mc34il.jpg","release_date":"2016-01-01","vote_average":6.383,"backdrop_path":"/89znt7oJAcueBnGb98tizxeoVmY.jpg","original_title":"La Dama del Corvette","original_language":"es"},{"id":714338,"adult":false,"title":"Bulbbul","video":false,"overview":"A child bride grows up to be an enigmatic woman presiding over her household, harboring a painful past as supernatural murders of men plague her village.","genre_ids":[27,14,53],"media_type":"movie","popularity":0.9224,"vote_count":166,"poster_path":"/4XYEqHqvcf6vxFhNyeKZz5xbUfV.jpg","release_date":"2020-06-24","vote_average":6.572,"backdrop_path":"/rfxj5AoOuvbqi0019TVZLy6gyCC.jpg","original_title":"बुलबुल","original_language":"hi"},{"id":531593,"adult":false,"title":"Reprisal","video":false,"overview":"Jacob, a bank manager haunted by a violent heist that took the life of a coworker, teams up with his ex-cop neighbor, James, to bring down the assailant. While the two men work together to figure out the thief’s next move, Gabriel, the highly-trained criminal, is one step ahead. When Gabriel kidnaps Jacob’s wife and daughter, Jacob barrels down a path of bloodshed that initiates an explosive counterattack and brings all three men to the breaking point.","genre_ids":[28,12,53],"media_type":"movie","popularity":0.7772,"vote_count":299,"poster_path":"/AiRrAJn4MvZxsmaDwEo8gw4FmQh.jpg","release_date":"2018-08-31","vote_average":5.206,"backdrop_path":"/pP4qymqnkjKoJrKuqqR4I3xTrmo.jpg","original_title":"Reprisal","original_language":"en"},{"id":294992,"adult":false,"title":"The Taking of Tiger Mountain","video":false,"overview":"Yang Zirong disguises himself as a bandit to infiltrate and destroy a bandit group. He joins hands with a hostage, and together, they fight against the warlord, Hawk.","genre_ids":[53,10752,12],"media_type":"movie","popularity":1.1536,"vote_count":208,"poster_path":"/7seDCoxCBa3O4bUbA4xlKtRfs2U.jpg","release_date":"2014-12-24","vote_average":6.587,"backdrop_path":"/woMqcz0ZDL9HuPQIWSZ7BrWWqLR.jpg","original_title":"智取威虎山","original_language":"zh"},{"id":13345,"adult":false,"title":"A Chinese Odyssey Part One: Pandora's Box","video":false,"overview":"When the Goddess of Happiness tosses the Longevity Monk and his disciples out of heaven (because the Monkey King tried to attain immortality), the Monkey King is reincarnated as the Joker. He now spends his time chasing two jealous women. When one of them is dying, the Joker goes back in time in an attempt to save her.","genre_ids":[28,12,14,35,10749],"media_type":"movie","popularity":2.2441,"vote_count":298,"poster_path":"/wIDDJ3FXPmVnNpxVoZOvjjcKVqj.jpg","release_date":"1995-01-21","vote_average":7.554,"backdrop_path":"/nC9RgXHTTa4hF7cKVxXkTQFyhpS.jpg","original_title":"西遊記第壹佰零壹回之月光寶盒","original_language":"cn"},{"id":369552,"adult":false,"title":"L.O.R.D: Legend of Ravaging Dynasties","video":false,"overview":"Based on the novel of the same name, the film depicts the endless battles of four kingdoms as they fight for power and domination of the one ultimate realm.Based on his 2 beloved fantasy novels with 6 million copies sold, L.O.R.D is acclaimed writer and director Guo Jingming’s follow up to his Tiny Times films.  The action-adventure odyssey is set in a world of warring Sorcerers, Lords and Beasts. The first CGI Film to come from China","genre_ids":[16,14,18,878],"media_type":"movie","popularity":1.0157,"vote_count":141,"poster_path":"/nQvnVtuL1xoPqK8WJ57yUQ9htJo.jpg","release_date":"2016-09-29","vote_average":7.018,"backdrop_path":"/lKilKeX1rlIhRcY4xQPP4bmuct9.jpg","original_title":"爵迹","original_language":"zh"},{"id":70577,"adult":false,"title":"Faces in the Crowd","video":false,"overview":"Anna is living with \"face-blindness\" after surviving a serial killer's attack. As she lives with her condition, one in which facial features change each time she loses sight of them, the killer closes in.","genre_ids":[53,80],"media_type":"movie","popularity":0.7993,"vote_count":513,"poster_path":"/A3EtPBwTZe1Dfx1xvjCtReUxDsD.jpg","release_date":"2011-10-25","vote_average":6.085,"backdrop_path":"/eL05IPWMWl4EzFMwej2vd5vwV9I.jpg","original_title":"Faces in the Crowd","original_language":"en"},{"id":415214,"adult":false,"title":"Operation Mekong","video":false,"overview":"The Chinese government launches a daring operation to arrest a violent drug cartel following the discovery of thirteen Chinese crew members' bodies on two ships sailing through the Mekong River.","genre_ids":[28,12,80,10752],"media_type":"movie","popularity":1.4018,"vote_count":267,"poster_path":"/wghFabaZgRorsMQWuPtKUlzq4W1.jpg","release_date":"2016-09-30","vote_average":7,"backdrop_path":"/xUmZHFZa85KxIKzsIdr16oGMjCH.jpg","original_title":"湄公河行动","original_language":"zh"}],"similar_content":[{"id":8814,"adult":false,"title":"Doom","video":false,"overview":"A team of space marines known as the Rapid Response Tactical Squad, led by Sarge, is sent to a science facility on Mars after somebody reports a security breach. There, they learn that the alert came after a test subject, a mass murderer purposefully injected with alien DNA, broke free and began killing people. Dr. Grimm, who is related to team member Reaper, informs them all that the chromosome can mutate humans into monsters -- and is highly infectious.","genre_ids":[28,27,878],"popularity":3.3331,"vote_count":2383,"poster_path":"/y50lH061yWOvEstoZRn7lYs0huk.jpg","release_date":"2005-10-20","vote_average":5.181,"backdrop_path":"/9EpgaLS44zlXoTSAOhGiJmkIA4B.jpg","original_title":"Doom","original_language":"en"},{"id":10617,"adult":false,"title":"Once Upon a Time in China","video":false,"overview":"In late 19th-century Canton, legendary hero Wong Fei-Hung battles foreign forces' (English, French and American) plundering of China. When Aunt Yee returns from America totally westernised, Wong assumes the role of protector. This proves difficult when his martial arts school and local militia become involved in fierce battles with foreign and local governments. As violence escalates, even Aunt Yee has to question her new western ideals, but is it possible to fight guns with Kung Fu?","genre_ids":[28,18],"popularity":2.0674,"vote_count":473,"poster_path":"/dkBQC0jmkmTOJJMgwsBdgkzZ6Ry.jpg","release_date":"1991-08-15","vote_average":7.1,"backdrop_path":"/shl0ELODK3VgHr7pu8VTz2a8olW.jpg","original_title":"黃飛鴻","original_language":"cn"},{"id":10618,"adult":false,"title":"Once Upon a Time in China II","video":false,"overview":"Wong Fei-Hung faces the White Lotus Society, a fanatical cult seeking to drive the Europeans out of China through violence, even attacking Chinese who follow Western ways. Wong must also defend revolutionary Dr. Sun Yat Sen from the military.","genre_ids":[28,35],"popularity":2.0071,"vote_count":279,"poster_path":"/jvrQXnpgSpKXQ3fkz5p6RV8jZJa.jpg","release_date":"1992-04-16","vote_average":7.176,"backdrop_path":"/zrSmI2wP2WIkWrgfP7IDSY1F9fW.jpg","original_title":"黃飛鴻之二：男兒當自強","original_language":"cn"},{"id":10619,"adult":false,"title":"Once Upon a Time in China III","video":false,"overview":"Master Wong and his disciples enroll in the 'Dancing Lion Competition' to stop an assassination plot and to battle an arrogant, deceitful opponent.","genre_ids":[28],"popularity":1.4333,"vote_count":215,"poster_path":"/8TmkTiHOTAyAjmbtDVi5f78a5ow.jpg","release_date":"1993-01-14","vote_average":6.47,"backdrop_path":"/8W9dXK2Q0lajJnE5jZSTwAduTu2.jpg","original_title":"黃飛鴻之三：獅王爭霸","original_language":"cn"},{"id":10620,"adult":false,"title":"Once Upon a Time in China and America","video":false,"overview":"So goes to the U.S. to open a martial arts school. Around this time, many Chinese people were sold off to U.S. railroad companies, and were brutally treated by the Americans under the harsh working conditions. Thus, the American workers' hatred towards the Chinese immigrants is high. As a result, So gets into trouble with the Americans and the mob, and calls Master Wong for help.","genre_ids":[28,37],"popularity":1.3026,"vote_count":114,"poster_path":"/6hSNNOwJIYkNXYjn6yhJPCd9oio.jpg","release_date":"1997-02-01","vote_average":5.904,"backdrop_path":"/AmzrZsqKxBYrJnEmGVt1PdgQK97.jpg","original_title":"黃飛鴻之西域雄獅","original_language":"cn"},{"id":10632,"adult":false,"title":"The Hunted","video":false,"overview":"In the wilderness of British Columbia, two hunters are tracked and viciously murdered by Aaron Hallam. A former Special Operations instructor is approached and asked to apprehend Hallam—his former student—who has 'gone rogue' after suffering severe battle stress from his time in Kosovo.","genre_ids":[18,28,53,80],"popularity":1.9748,"vote_count":889,"poster_path":"/AvdBPe2XSKm3cGyTKFgbquC2jCo.jpg","release_date":"2003-03-11","vote_average":6.2,"backdrop_path":"/2T3k09YnrM03CQd1yK3ZQLEHEZH.jpg","original_title":"The Hunted","original_language":"en"},{"id":9502,"adult":false,"title":"Kung Fu Panda","video":false,"overview":"Chosen by prophecy but doubted by all, Po is an unlikely Dragon Warrior—a clumsy panda thrust into the world of kung fu as 