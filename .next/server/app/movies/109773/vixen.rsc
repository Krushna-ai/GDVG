5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Vixen\",\"description\":\"An international conference on the future of cyber security held in China's tallest building is interrupted by a group of terrorists taking advantage of the lockdown ahead of the meeting.  The only delegate not held by the terrorists Sunny Liu finds herself in the unenviable position of being the lone chance of stopping them. The terrorists think catching a single woman is easy, but they may have underestimated their prey.\",\"image\":\"https://image.tmdb.org/t/p/w500/AvGvz3HBiVvGd44MipdtdLJjqec.jpg\",\"datePublished\":\"2024-08-01\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Action\",\"Adventure\",\"Crime\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7,\"bestRating\":10,\"ratingCount\":1}}"}}],["$","$L10",null,{"initialDrama":{"id":"4cd181e9-93e2-4cca-bf28-4d0972b2a5df","tmdb_id":604811,"imdb_id":"tt8392146","content_type":"movie","title":"Vixen","original_title":"Vixen","overview":"An international conference on the future of cyber security held in China's tallest building is interrupted by a group of terrorists taking advantage of the lockdown ahead of the meeting.  The only delegate not held by the terrorists Sunny Liu finds herself in the unenviable position of being the lone chance of stopping them. The terrorists think catching a single woman is easy, but they may have underestimated their prey.","poster_path":"/AvGvz3HBiVvGd44MipdtdLJjqec.jpg","backdrop_path":"/3FN6DqHaIQjGavhSqviuNQwA2zu.jpg","release_date":"2024-08-01","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":28,"name":"Action"},{"id":12,"name":"Adventure"},{"id":80,"name":"Crime"}],"popularity":7.5465,"vote_average":7,"vote_count":1,"runtime":88,"number_of_seasons":null,"number_of_episodes":n