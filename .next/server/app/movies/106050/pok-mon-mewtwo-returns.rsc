5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Pokémon: Mewtwo Returns\",\"description\":\"The Team Rocket leader, Giovanni, has found Mewtwo in a remote area of the Johto region. As Giovanni tries to re-capture Mewtwo, Ash and his friends are kidnapped by Domino, a new Team Rocket member, while trying to rescue Pikachu from Jessie and James. The Clone Pokemon are also captured and are then used as bait for Mewtwo. The situation then becomes a battle between the wills of Mewtwo and Giovanni; and Mewtwo also tries to discover if it and the clones have a purpose in life, even though they are products of science.\",\"image\":\"https://image.tmdb.org/t/p/w500/zIYljUBF2rXzB0yYZVEPY1l8zHp.jpg\",\"datePublished\":\"2001-08-17\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"fantasy\",\"Animation\",\"Family\",\"Action\",\"Adventure\",\"Drama\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.7,\"bestRating\":10,\"ratingCount\":421}}"}}],["$","$L10",null,{"initialDrama":{"id":"8cba078f-62ee-474b-b6ed-481ce887fb0e","tmdb_id":36897,"imdb_id":"tt0304564","content_type":"movie","title":"Pokémon: Mewtwo Returns","original_title":"ポケットモンスター ミュウツー! 我ハココニ在リ MEWTWO SAGA","overview":"The Team Rocket leader, Giovanni, has found Mewtwo in a remote area of the Johto region. As Giovanni tries to re-capture Mewtwo, Ash and his friends are kidnapped by Domino, a new Team Rocket member, while trying to rescue Pikachu from Jessie and James. The Clone Pokemon are also captured and are then used as bait for Mewtwo. The situation then becomes a battle between the wills of Mewtwo and Giovanni; and Mewtwo also tries to discover if it and the clones have a purpose in life, even though they are products of science.","poster_path":"/zIYljUBF2rXzB0yYZVEPY1l8zHp.jpg","backdrop_path":"/pJszL2mPl084IDSzLDPH8NqIq0r.jpg","release_date":"