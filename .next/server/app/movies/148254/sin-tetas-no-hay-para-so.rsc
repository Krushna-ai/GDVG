5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Sin tetas no hay paraíso\",\"description\":\"Catalina is a young, beautiful girl living in extreme poverty with her brother Bayron and her mother Hilda. She becomes obsessed with getting breast implants to get social status and money. She leaves her boyfriend Albeira and becomes a prostitute for drug dealers. In this way she will enjoy all the luxuries that she lacks. Meanwhile, her ex-boyfriend Albeira and her mother Hilda begin a relationship behind her back.\",\"image\":\"https://image.tmdb.org/t/p/w500/4fIx3BgiU7u9ZuMG74JYidIVboM.jpg\",\"datePublished\":\"2010-07-23\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CO\",\"inLanguage\":\"es\",\"genre\":[\"Crime\",\"Drama\",null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.3,\"bestRating\":10,\"ratingCount\":106}}"}}],["$","$L10",null,{"initialDrama":{"id":"5532bdc8-9e0c-4530-b8c0-5daf93541a64","tmdb_id":107748,"imdb_id":"tt1933647","content_type":"movie","title":"Sin tetas no hay paraíso","original_title":"Sin tetas no hay paraíso","overview":"Catalina is a young, beautiful girl living in extreme poverty with her brother Bayron and her mother Hilda. She becomes obsessed with getting breast implants to get social status and money. She leaves her boyfriend Albeira and becomes a prostitute for drug dealers. In this way she will enjoy all the luxuries that she lacks. Meanwhile, her ex-boyfriend Albeira and her mother Hilda begin a relationship behind her back.","poster_path":"/4fIx3BgiU7u9ZuMG74JYidIVboM.jpg","backdrop_path":"/mEXcEYJf71nN7H6bGRrYuBFz8hb.jpg","release_date":"2010-07-23","first_air_date":null,"status":"published","original_language":"es","origin_country":["CO"],"genres":[{"id":80,"name":"Crime"},{"id":18,"name":"Drama"},"film based on a novel","drama film"],"popularity":3.7809,"vote_average":7.3,"vote_count":106,"runt