9:{"metadata":[["$","title","0",{"children":"Sin tetas no hay paraíso | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Catalina is a young, beautiful girl living in extreme poverty with her brother Bayron and her mother Hilda. She becomes obsessed with getting breast implants to get social status and money. She leaves her boyfriend Albeira and becomes a prostitute for drug dealers. In this way she will enjoy all the luxuries that she lacks. Meanwhile, her ex-boyfriend Albeira and her mother Hilda begin a relationship behind her back."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148254/sin-tetas-no-hay-para-so"}],["$","meta","5",{"property":"og:title","content":"Sin tetas no hay paraíso"}],["$","meta","6",{"property":"og:description","content":"Catalina is a young, beautiful girl living in extreme poverty with her brother Bayron and her mother Hilda. She becomes obsessed with getting breast implants to get social status and money. She leaves her boyfriend Albeira and becomes a prostitute for drug dealers. In this way she will enjoy all the luxuries that she lacks. Meanwhile, her ex-boyfriend Albeira and her mother Hilda begin a relationship behind her back."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148254/sin-tetas-no-hay-para-so"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/4fIx3BgiU7u9ZuMG74JYidIVboM.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Sin tetas no hay paraíso"}],["$","meta","12",{"name":"twitter:description","content":"Catalina is a young, beautiful girl living in extreme poverty with 