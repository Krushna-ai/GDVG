":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/r77Ng9SQolGRsMvCGBZoDVc7Emy.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:06:27.672+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":108,"tagline":"","homepage":"http://www.sintetaslapelicula.com/","overview":"Catalina is a young, beautiful girl living in extreme poverty with her brother Bayron and her mother Hilda. She becomes obsessed with getting breast implants to get social status and money. She leaves her boyfriend Albeira and becomes a prostitute for drug dealers. In this way she will enjoy all the luxuries that she lacks. Meanwhile, her ex-boyfriend Albeira and her mother Hilda begin a relationship behind her back."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"A sus trece años, Catalina empezó a asociar la prosperidad de las niñas de su barrio con el tamaño de sus tetas. Pues quienes las tenían pequeñas, como ella, tenían que resignarse a vivir en medio de las necesidades y a estudiar o trabajar de mesera en algún restaurante de la ciudad. En cambio, quienes las tenían grandes como Yessica o Paola, se paseaban orondas por la vida, en lujosas camionetas, vestidas con trajes costosos y efectuando compras suntuosas que terminaron haciéndola agonizar de envidia. Por eso se propuso, como única meta en su vida, conseguir, a como diera lugar y cometiendo todo tipo de errores, el dinero para mandarse a implantar un par de tetas de silicona, capaces de no caber en las manos abiertas de hombre alguno. Pero nunca pensó que, contrario a lo que ella creía, sus soñadas prótesis no se iban a convertir en el cielo de su felicidad y en el instrumento de su enriquecimiento sino, en su tragedia personal y su infierno..."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Sin Tetas no hay Paraíso","runtime":0,"tagline":"","homepage":"","overview":"A sus trece años, Catalina empezó a asociar la prosperidad de las niñas de su barrio con el tamaño de sus tetas. Pues quienes las tenían pequeñas, como ella, tenían que resignarse a vivir en medio de las necesidades y a estudiar o trabajar de mesera en algún restaurante de la ciudad. En cambio, quienes las tenían grandes como Yessica o Paola, se paseaban orondas por la vida, en lujosas camionetas, vestidas con trajes costosos y efectuando compras suntuosas que terminaron haciéndola agonizar de envidia."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Sem Tetas Não Há Paraíso","runtime":0,"tagline":"","homepage":"","overview":"A adaptação cinematográfica da popular telenovela sobre uma jovem obcecada por implantes mamários."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Без бюста нет рая","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Catalina est une jeune et jolie fille qui vit dans une extrême pauvreté avec son frère Bayron et sa mère Hilda. Elle devient obsédée par l'idée de se faire poser des implants mammaires afin d'obtenir un statut social et de l'argent. Elle quitte son petit ami Albeira et devient prostituée pour des trafiquants de drogue. Elle pourra ainsi profiter de tout le luxe qui lui manque. Pendant ce temps, son ex-petit ami Albeira et sa mère Hilda entament une relation dans son dos."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"}],"reviews_tmdb":[],"recommendations":[{"id":40074,"adult":false,"title":"Alucarda","video":false,"overview":"A young girl's arrival at a convent after the death of her parents marks the beginning of a series of events that unleash an evil presence on the girl and her mysterious new friend, an enigmatic figure known as Alucarda. Demonic possession, Satan worship, and vampirism follows.","genre_ids":[27],"media_type":"movie","popularity":0.6004,"vote_count":141,"poster_path":"/AnTomUY0xeHF42f3LZFhCGIklW5.jpg","release_date":"1977-12-26","vote_average":6.4,"backdrop_path":"/xOuFz7t8zFEMLmzCHxnSLLkvNST.jpg","original_title":"Alucarda, la hija de las tinieblas","original_language":"es"},{"id":10251,"adult":false,"title":"5ive Girls","video":false,"overview":"Five wayward teenage girls are sent to a reformatory and discover they possess unique powers to battle the ancient demon, Legion, which holds thrall over the sinister institution.","genre_ids":[27,53],"media_type":"movie","popularity":1.5412,"vote_count":105,"poster_path":"/9EKL1Ta42cj9rSqopfu3QJFE3G1.jpg","release_date":"2007-02-07","vote_average":5.271,"backdrop_path":"/9QMbzoO8Xwsjo2Enyvhns6yHDck.jpg","original_title":"5ive Girls","original_language":"en"},{"id":453807,"adult":false,"title":"Justice","video":false,"overview":"A U.S. Marshal seeking justice for his brother's murder defends a small town from a corrupt Mayor and his henchmen with intents to revive the civil war.","genre_ids":[37],"media_type":"movie","popularity":0.8395,"vote_count":45,"poster_path":"/uqvjf3HOGiWLgUB6h15yKb2p2x6.jpg","release_date":"2017-09-15","vote_average":5.6,"backdrop_path":"/32EMFV8Ms3GIGz9OyVthkUJmhJJ.jpg","original_title":"Justice","original_language":"en"},{"id":28574,"adult":false,"title":"Violence in a Women's Prison","video":false,"overview":"Laura Kendall, also known as Emanuelle, arrives at a remote prison with a long, fictional rap sheet that will allow her to go undercover to report on the cruelties behind bars.","genre_ids":[28,53,27],"media_type":"movie","popularity":0.7023,"vote_count":67,"poster_path":"/2xZhQL4ZbIDPmJj4WHBMFEoQmPg.jpg","release_date":"1982-09-09","vote_average":5.634,"backdrop_path":"/j9FxvsK0TMmTxluA3i0a3uN40vS.jpg","original_title":"Viole