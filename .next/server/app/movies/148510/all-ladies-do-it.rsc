WJ3Zu0KKwmbpDp2.jpg","release_date":"1994-01-27","vote_average":5.5,"backdrop_path":"/rE9ze3zdhZE8492KPDXiCergZl0.jpg","original_title":"L'uomo che guarda","original_language":"it"},{"id":1029599,"adult":false,"title":"Eagle and Jaguar, The Legendary Warriors","video":false,"overview":"In a post-apocalyptic future in which water has almost disappeared, two young survivors travel back in time to find the mythical power of the prehispanic God of water, and so be able to create the vital resource. However, when they arrive at the present they discover that the power is in the hands of an unscrupulous businessman who had always wanted to monopolize water and who knows everything about prehispanic myths. The Aztaya brotherhood, a group of heroes, successors from the legendary Aztec and Mayan warriors, will begin the adventure to prevent the villain's plan and help the travelers to change their sad future, teaming up to fight the powerful enemy and his dark allies. To win, the heroes will have to awake the greatest warriors of Aztec and Mayan mythology: The Eagle and the Jaguar.","genre_ids":[16,12,28],"media_type":"movie","popularity":0.1696,"vote_count":49,"poster_path":"/6qR9WbXYIddZcVk6nxFULfHcKmK.jpg","release_date":"2022-09-29","vote_average":6.837,"backdrop_path":"/nnkiORKM1Q4AU1eWULI1PiWOTLu.jpg","original_title":"Águila y Jaguar: Los guerreros legendarios","original_language":"es"},{"id":258750,"adult":false,"title":"Gun Woman","video":false,"overview":"A brilliant doctor on a quest for revenge buys a young woman and trains her to be the ultimate assassin, implanting gun parts in her body that she must later assemble and use to kill her target before she bleeds to death.","genre_ids":[53,28],"media_type":"movie","popularity":0.8901,"vote_count":128,"poster_path":"/4zbT9LhgIvU7bcfKz5XixhJrYZx.jpg","release_date":"2014-02-28","vote_average":5.02,"backdrop_path":"/gDSkgz56Dg0T5SXBC0HrmXO6AHl.jpg","original_title":"女体銃 ガン・ウーマン GUN WOMAN","original_language":"ja"},{"id":35102,"adult":false,"title":"The Forbidden Legend: Sex & Chopsticks","video":false,"overview":"Simon is a scion of a wealthy family who struggles to have a stable relationship because of his womanizing ways. When he finds a wife, Moon, he spots another woman and conspires to marry her.","genre_ids":[35,18,10749],"media_type":"movie","popularity":1.9489,"vote_count":51,"poster_path":"/sc9LlvsdofSmImbodqrgmK774EA.jpg","release_date":"2008-09-19","vote_average":5.725,"backdrop_path":"/dOQ2fjItwIoMJ3xYLLpYgsbRZSu.jpg","original_title":"金瓶梅","original_language":"cn"}],"similar_content":[{"id":69,"adult":false,"title":"Walk the Line","video":false,"overview":"A chronicle of country music legend Johnny Cash's life, from his early days on an Arkansas cotton farm to his rise to fame with Sun Records in Memphis, where he recorded alongside Elvis Presley, Jerry Lee Lewis and Carl Perkins.","genre_ids":[18,10402,10749],"popularity":2.6787,"vote_count":3073,"poster_path":"/p8lPTjvjOjTfvC1E9pmMwcF9vkn.jpg","release_date":"2005-09-13","vote_average":7.495,"backdrop_path":"/pMBKzEotLUzk3NuQiyVjZEDlH70.jpg","original_title":"Walk the Line","original_language":"en"},{"id":71,"adult":false,"title":"Billy Elliot","video":false,"overview":"County Durham, England, 1984. The miners' strike has started and the police have started coming up from Bethnal Green, starting a class war with the lower classes suffering. Caught in the middle of the conflict is 11-year old Billy Elliot, who, after leaving his boxing club for the day, stumbles upon a ballet class and finds out that he's naturally talented. He practices with his teacher Mrs. Wilkinson for an upcoming audition in Newcastle-upon Tyne for the royal Ballet school in London.","genre_ids":[18,35,10402],"popularity":2.8329,"vote_count":4027,"poster_path":"/nOr5diUZxphmAD3li9aiILyI28F.jpg","release_date":"2000-09-28","vote_average":7.593,"backdrop_path":"/mTsbahr4SLqgVZkKRN0O8t5iA9y.jpg","original_title":"Billy Elliot","original_language":"en"},{"id":88,"adult":false,"title":"Dirty Dancing","video":false,"overview":"Expecting the usual tedium that accompanies a summer in the Catskills with her family, 17-year-old Frances 'Baby' Houseman is surprised to find herself stepping into the shoes of a professional hoofer—and unexpectedly falling in love.","genre_ids":[18,10402,10749],"popularity":7.2383,"vote_count":6424,"poster_path":"/9Jw6jys7q9gjzVX5zm1z0gC8gY9.jpg","release_date":"1987-08-21","vote_average":7.328,"backdrop_path":"/6iDQCBUSZKzY8Rnu8ECwl2gXcfG.jpg","original_title":"Dirty Dancing","original_language":"en"},{"id":136,"adult":false,"title":"Freaks","video":false,"overview":"A circus' beautiful trapeze artist agrees to marry the leader of side-show performers, but his deformed friends discover she is only marrying him for his inheritance.","genre_ids":[18,27],"popularity":1.8676,"vote_count":1283,"poster_path":"/fX2Wxd0W9E7eVClUd8kJTfennoV.jpg","release_date":"1932-01-01","vote_average":7.77,"backdrop_path":"/r18vpGFsNf6n984x4KdJmAAWKkP.jpg","original_title":"Freaks","original_language":"en"},{"id":153,"adult":false,"title":"Lost in Translation","video":false,"overview":"Two lost souls visiting Tokyo -- the young, neglected wife of a photographer and a washed-up movie star shooting a TV commercial -- find an odd solace and pensive freedom to be real in each other's company, away from their lives in America.","genre_ids":[18,35,10749],"popularity":5.9969,"vote_count":7908,"poster_path":"/3jCLmYDIIiSMPujbwygNpqdpM8N.jpg","release_date":"2003-09-18","vote_average":7.383,"backdrop_path":"/6ITVHoipvxAS8luzKtHTbPaHLtT.jpg","original_title":"Lost in Translation","original_language":"en"},{"id":198,"adult":false,"title":"To Be or Not to Be","video":false,"overview":"During the Nazi occupation of Poland, an acting troupe becomes embroiled in a Polish soldier's efforts to track down a German spy.","genre_ids":[35,10752,10749],"popularity":1.8362,"vote_count":810,"poster_path":"/dDQRpEoyjHT4fzw9cNklIvZ