stine.","genre_ids":[35,18,10749],"popularity":2.8523,"vote_count":455,"poster_path":"/5qHh1Vp2TOOX5IaTVt4wyT8OTnR.jpg","release_date":"1968-09-04","vote_average":7.287,"backdrop_path":"/fPFuTcXcxYR6odkHA7PW786ZWjV.jpg","original_title":"Baisers volés","original_language":"fr"},{"id":258,"adult":false,"title":"Bed and Board","video":false,"overview":"Parisian everyman Antoine Doinel has married his sweetheart Christine Darbon, and the newlyweds have set up a cozy domestic life of selling flowers and giving violin lessons while Antoine fitfully works on his long-gestating novel. As Christine becomes pregnant with the couple's first child, Antoine finds himself enraptured with a young Japanese beauty. The complications change the course of their relationship forever.","genre_ids":[35,18,10749],"popularity":1.2493,"vote_count":303,"poster_path":"/s9R5wKbrB9SfOG1FzbICbOsssX8.jpg","release_date":"1970-09-09","vote_average":7.097,"backdrop_path":"/9JJqO2yNfoE4uAbu5FDhIhwbqpq.jpg","original_title":"Domicile conjugal","original_language":"fr"},{"id":259,"adult":false,"title":"Love on the Run","video":false,"overview":"Now in his thirties, Antoine Doinel is a divorced proofreader in love with a record seller. Colette Tazzi, now a lawyer, buys his first published autobiography, leading them to a chance meeting.","genre_ids":[10749,18,35],"popularity":0.7107,"vote_count":210,"poster_path":"/shUrax1ZJXYyclxUaktsTBUHMa9.jpg","release_date":"1979-01-24","vote_average":7.036,"backdrop_path":"/7LmhNfSkSkE296AvQbLZK4jgbnp.jpg","original_title":"L'Amour en fuite","original_language":"fr"},{"id":93,"adult":false,"title":"Anatomy of a Murder","video":false,"overview":"Semi-retired Michigan lawyer Paul Biegler takes the case of Army Lt. Manion, who murdered a local innkeeper after his wife claimed that he raped her. Over the course of an extensive trial, Biegler parries with District Attorney Lodwick and out-of-town prosecutor Claude Dancer to set his client free, but his case rests on the victim's mysterious business partner, who's hiding a dark secret.","genre_ids":[80,18,9648],"popularity":1.6093,"vote_count":1126,"poster_path":"/b2G1QSAwtBv9luhEwErIgSRaU92.jpg","release_date":"1959-07-01","vote_average":7.835,"backdrop_path":"/xfEU7DOlQPwz8Y0TBhKmpETuNIc.jpg","original_title":"Anatomy of a Murder","original_language":"en"},{"id":102,"adult":false,"title":"Open Hearts","video":false,"overview":"Cecilie and Joachim are about to get married when a freak car accident leaves Joachim disabled, throwing their lives into a spin. The driver of the other car, Marie, and her family don’t get off lightly, either. Her husband Niels works in the hospital where he meets Cecilie and falls madly in love with her.","genre_ids":[18,10749],"popularity":0.5564,"vote_count":121,"poster_path":"/hOrV2fCw2kmSiS4ZMGFPfXqr3lt.jpg","release_date":"2002-09-06","vote_average":7.1,"backdrop_path":"/1pRNzOM7OQA29cVayaCheBI4vn7.jpg","original_title":"Elsker dig for evigt","original_language":"da"},{"id":110,"adult":false,"title":"Three Colors: Red","video":false,"overview":"Part-time model Valentine unexpectedly befriends a retired judge after she runs over his dog. At first, the grumpy man shows no concern about the dog, and Valentine decides to keep it. But the two form a bond when she returns to his house and catches him listening to his neighbors’ phone calls.","genre_ids":[18,9648,10749],"popularity":2.7179,"vote_count":1522,"poster_path":"/JHmsBiX1tjCKqAul1lzC20WcAW.jpg","release_date":"1994-05-12","vote_average":7.907,"backdrop_path":"/pZcoSJUb3Lgr9Rzg2shg1PtTBP9.jpg","original_title":"Trois couleurs : Rouge","original_language":"fr"},{"id":112,"adult":false,"title":"Italian for Beginners","video":false,"overview":"Several lonely hearts in a semi-provincial suburb of a town in Denmark use a beginner's course in Italian as the platform to meet the romance of their lives. The film, which unspools the connections and family drama shared between the students, complies with several aesthetic principles of Dogme 95 movement.","genre_ids":[35,18,10749],"popularity":0.5491,"vote_count":149,"poster_path":"/yviUKuVb9BXYPqkWvp8JZFj2wVb.jpg","release_date":"2000-12-07","vote_average":6.393,"backdrop_path":"/iiFzTxQZ647q0zc9F0w90lwn0PE.jpg","original_title":"Italiensk for begyndere","original_language":"da"},{"id":116,"adult":false,"title":"Match Point","video":false,"overview":"Chris, a former tennis pro, takes a job as an instructor and befriends his wealthy young student, Tom. After being introduced to his family, Chris is soon engaged to Tom's sister, Chloe. Despite the professional and financial advantages that this relationship affords him, Chris becomes obsessed with Tom's fiancee, American actress Nola.","genre_ids":[18,10749,53],"popularity":3.3606,"vote_count":4298,"poster_path":"/vHjEVTD8ucuwKSFOZJeyAnTZYli.jpg","release_date":"2005-10-26","vote_average":7.359,"backdrop_path":"/yUJf20GQ5vifhk9QDxUGotAEaLz.jpg","original_title":"Match Point","original_language":"en"},{"id":261,"adult":false,"title":"Cat on a Hot Tin Roof","video":false,"overview":"An alcoholic ex-football player drinks his days away, having failed to come to terms with his sexuality and his real feelings for his football buddy who died after an ambiguous accident. His wife is crucified by her desperation to make him desire her: but he resists the affections of his wife. His reunion with his father—who is dying of cancer—jogs a host of memories and revelations for both father and son.","genre_ids":[18],"popularity":1.0242,"vote_count":819,"poster_path":"/5djZZECgqDGuSI1INmrdAcGRBb0.jpg","release_date":"1958-08-29","vote_average":7.6,"backdrop_path":"/3Yz8IcUBPZ8zDff0ktHZk24Rot0.jpg","original_title":"Cat on a Hot Tin Roof","original_language":"en"},{"id":267,"adult":false,"title":"Live Flesh","video":false,"overview":"When Victor attempts to seduce Elena, all he gets for his trouble is a one-way, six-year ticket to prison, where he concentrates on strengthening his mind, his body... and his desire for vengeance on the man who put him there. After his release and still madly in love with her, Victor will stop at nothing to win her over even if means revenge, for Elena has married David, the cop who sent him to prison!","genre_ids":[18,10749,53],"popularity":1.4467,"vote_count":724,"poster_path":"/7YPGYeamF6AuyxhKqbd5oNKKCCy.jpg","release_date":"1997-10-10","vote_average":7.034,"backdrop_path":"/tR5JCOmayMV7Ml2ycA7NQ5E8Xyo.jpg","original_title":"Carne trémula","original_language":"es"},{"id":269,"adult":false,"title":"Breathless","video":false,"overview":"A small-time thief steals a car and impulsively murders a motorcycle policeman. Wanted by the authorities, he attempts to persuade a girl to run away to Italy with him.","genre_ids":[18,80],"popularity":2.2884,"vote_count":1978,"poster_path":"/9Wx0Wdn2EOqeCZU4SP6tlS3LOml.jpg","release_date":"1960-03-16","vote_average":7.496,"backdrop_path":"/4WGuyWf1f94CsEeVIIqDKGw5rmO.jpg","original_title":"À bout de souffle","original_language":"fr"},{"id":273,"adult":false,"title":"The White Sound","video":false,"overview":"Lukas, a young schizophrenic man, has to deal with a new town, a new relationship, and the paranoia in his head.","genre_ids":[18],"popularity":0.2192,"vote_count":58,"poster_path":"/kYJLb69aANQhf6EvewCnKRpiJ5O.jpg","release_date":"2001-12-31","vote_average":7,"backdrop_path":"/bGpRDAU5b0Ejc64wydAxt2ovx20.jpg","original_title":"Das weisse Rauschen","original_language":"de"}],"external_ids":{"imdb_id":"tt0104014","twitter_id":null,"facebook_id":null,"wikidata_id":"Q2642294","instagram_id":null,"mydramalist_id":"552"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148510,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"DE","release_dates":[{"note":"","type":3,"iso_639_1":"