9:{"metadata":[["$","title","0",{"children":"Project Silence | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Due to sudden deteriorating weather conditions, visibility on the Airport Bridge is severely impaired, leaving people stranded and at risk of the bridge collapsing due to a series of chain collisions and explosions. Amidst the chaos, the canine subjects \"Echo\" from the military experiment \"Project Silence,\" who were being transported in secret, break free, and all human survivors become targets of relentless attacks."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/102631/project-silence"}],["$","meta","5",{"property":"og:title","content":"Project Silence"}],["$","meta","6",{"property":"og:description","content":"Due to sudden deteriorating weather conditions, visibility on the Airport Bridge is severely impaired, leaving people stranded and at risk of the bridge collapsing due to a series of chain collisions and explosions. Amidst the chaos, the canine subjects \"Echo\" from the military experiment \"Project Silence,\" who were being transported in secret, break free, and all human survivors become targets of relentless attacks."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/102631/project-silence"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/55jsexep1uh1ieMwyJMVapTETMM.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Project Silence"}],["$","meta","12",{"name":"twitter:description","content":"Due to sudden deteriorating weather conditions, visibility on the Airport Bridge is severely impaired, l