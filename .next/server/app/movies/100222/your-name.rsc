9:{"metadata":[["$","title","0",{"children":"Your Name. | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"High schoolers Mitsuha and Taki are complete strangers living separate lives. But one night, they suddenly switch places. Mitsuha wakes up in Taki’s body, and he in hers. This bizarre occurrence continues to happen randomly, and the two must adjust their lives around each other."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/100222/your-name"}],["$","meta","5",{"property":"og:title","content":"Your Name."}],["$","meta","6",{"property":"og:description","content":"High schoolers Mitsuha and Taki are complete strangers living separate lives. But one night, they suddenly switch places. Mitsuha wakes up in Taki’s body, and he in hers. This bizarre occurrence continues to happen randomly, and the two must adjust their lives around each other."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/100222/your-name"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/q719jXXEzOoYaps6babgKnONONX.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Your Name."}],["$","meta","12",{"name":"twitter:description","content":"High schoolers Mitsuha and Taki are complete strangers living separate lives. But one night, they suddenly switch places. Mitsuha wakes up in Taki’s body, and he in hers. This bizarre occurrence continues to happen randomly, and the two must adjust their lives around each other."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/q719jXXEzOoYaps6babgKnONONX.jpg"}],["$","link","14",{"