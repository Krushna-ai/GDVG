:3.334},{"width":1707,"height":960,"file_path":"/mMmmAADAYrLozZk8GXqZt8dAmem.jpg","iso_639_1":null,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/2DBdjVPKKXAA3o78vgpwXIsP1ou.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/koDRwH9v90kAUjaxYRuBttNzfQp.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/pXvhvLws2YIqkeCYINBUNAeep4L.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/rZmfK4W54BmngQSfETVr3HQdTjI.jpg","iso_639_1":"zh","vote_average":0},{"width":2048,"height":1152,"file_path":"/wxJZqjgDWB7JRXgrYU4yROIgTYs.jpg","iso_639_1":"zh","vote_average":0},{"width":2048,"height":1152,"file_path":"/fsWSwwI7eNBytkMiZMeUu55vDun.jpg","iso_639_1":null,"vote_average":0},{"width":2048,"height":1152,"file_path":"/zL1jN3Nij1yWX6zocXsFr3fguG9.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-02-21T11:28:57.59+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Prosecutor","runtime":117,"tagline":"Fight for justice.","homepage":"","overview":"A poor young man is wrongly charged with drug trafficking after being deceived. An ex-prosecutor investigates the case, uncovers a corrupt lawyer team's scheme, and restores justice despite obstruction from evil forces."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"誤判","runtime":117,"tagline":"","homepage":"","overview":"根據真實案件改編。青年馬家傑在一無所知的情況下被指販賣毒品，其辯護律師表面正義，實際誤導馬家傑認罪以換取真兇無罪釋放。檢察官霍子豪發現當中端倪，毅然以一己之力暗中調查，奈何癒揭癒深，發現背後竟牽涉一個龐大的犯罪團體。霍子豪不惜以自己的職業生涯和生命安全作冒險，堅持還無辜者清白，並以真相將真正罪犯繩之以法，成功守住了律政司的公信力和法律的威嚴，同時避免一次重大的誤判。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"误判","runtime":118,"tagline":"为正义出拳","homepage":"","overview":"贫苦青年马志杰借出了住址而误收毒品包裹，在辩护律师的诱骗和误导下承认了贩毒控罪。曾是干探的检察官霍子豪凭其警察触觉和执着，不惜违规为此冤案展开调查，抽丝剥茧揭开辩护律师团队的真面目。在欧柏文等恶势力的重重阻挠下，霍子豪勇破难关且设下圈套，成功还原真相并将真正罪犯绳之以法，守住了法律的威严，阻止了一次无情的误判。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Savcı","runtime":0,"tagline":"Adalet için savaş.","homepage":"","overview":"Gerçek bir Hong Kong mahkeme davasından esinlen bu filmde, yanlışlıkla uyuşturucu kaçakçılığıyla suçlanan genç bir adamın hikâyesi anlatılıyor. Eski bir savcı olan Fok Chi Ho, davayı araştırmaya başlar ve yozlaşmış bir avukat ekibinin planını ortaya çıkarır. Fok, adaleti sağlamak için kendi hayatını ve kariyerini riske atar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Een arme jongeman wordt ten onrechte beschuldigd van drugshandel nadat hij is misleid. Een ex-officier van justitie onderzoekt de zaak, ontdekt het plan van een corrupt advocatenteam en herstelt gerechtigheid ondanks obstructie van kwade krachten."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"誤判","runtime":0,"tagline":"","homepage":"","overview":"一個由快遞包裹引發的誤判冤案：因幫朋友代收快遞包裹，一個香港年輕人捲入了一樁販毒案中，並因此判刑27年。甄子丹飾演的檢察官試圖糾正這場誤判，在過程中發現了更深層的黑暗。該故事由一樁發生在香港的真實案件改編而來，2016年一位香港青年因幫朋友代收快遞而遭判刑20餘年，2021年法庭再審後宣佈無罪並當庭釋放。該案在香港社會一度引起軒然大波，香港的法治也因此面臨民眾的詰問與譴責。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Обвинитель","runtime":117,"tagline":"","homepage":"","overview":"Бывший детектив, а ныне прокурор использует свое полицейское чутье и настойчивость для восстановления справедливости. Его методы не совсем легальны, зато эффективны."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"התובע","runtime":0,"tagline":"","homepage":"","overview":"בחור צעיר עני מואשם בטעות בהברחת סמים לאחר שנפל קורבן להונאה. תובע לשעבר חוקר את המקרה, מגלה את מזימתה של קבוצת עורכי דין מושחתת, ומחזיר את הצדק למרות התנגדות מצד כוחות רשע."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Погрешна преценка","runtime":0,"tagline":"","homepage":"","overview":"Един беден младеж е погрешно обвинен в трафик на наркотици, след като е бил измамен. Бивш прокурор разследва случая, разкрива схемата на корумпиран адвокатски екип и възстановява справедливостта въпреки препятствията от зли сили."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Phán Quyết Sai Lầm","runtime":0,"tagline":"","homepage":"","overview":"Một vụ án buôn bán ma túy bất công khiến bị cáo phải đối mặt với án tù 27 năm. Công tố Tử Hào, một cựu thanh tra, đã dựa vào sự nhạy bén và kiên trì của mình để mở cuộc điều tra. Cuộc đấu tranh sinh tử ở hậu trường sắp nổ ra. Ngày xét xử cuối cùng đang đến gần. Liệu Tử Hào có thể đập tan sự bất công và lật ngược bản án?"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"열혈검사","runtime":117,"tagline":"좀 치는 검사의 오판을 뒤집을 목숨을 건 마지막 한판 승부가 시작된다!","homepage":"","overview":"마약 밀매 혐의로 기소된 청년의 사건을 맡게 된 형사 출신 검사 ‘곽자호’(견자단). 곽자호는 사건을 담당한 구백문 변호사의 부당한 변호로 청년이 억울하게 기소되었다는 사실을 알게 된다. 수사를 진행할수록 홍콩에 마약을 유통하는 거대 조직의 뒤를 구백문 변호사가 봐주고 있다는게 밝혀지고, 곽자호는 정의를 위해 목숨과 경력을 걸고 수사에 나서는데…."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"The Prosecutor","runtime":0,"tagline":"","homepage":"","overview":"Filmul urmărește povestea intensă a unui procuror ambițios care, în timp ce investighează un caz de corupție la nivel înalt, descoperă o conspirație ce amenință să dezvăluie secrete întunecate ale propriei sale familii. Pe măsură ce urmărește firul corupției, el este prins între datoria profesională și loialitatea față de cei dragi. Într-o cursă contra cronometru pentru adevăr, protagonistul trebuie să decidă ce este dispus să sacrifice pentru a aduce justiția în fața lumii."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"دادستان","runtime":0,"tagline":"","homepage":"","overview":"داستان مرد جوانی که اشتباهاً متهم به قاچاق مواد مخدر می‌‌شود. یک دادستان سابق پس از بررسی پرونده تصمیم می‌گیرد وارد عمل شود و عدالت را اجرا کند."},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"The Prosecutor","runtime":117,"tagline":"","homepage":"","overview":"The Prosecutor je snímek, který je inspirován skutečným právním případem v Hongkongu, a sleduje příběh muže, který falešně přizná k obchodování s drogami. Jenomže policista, ze kterého se nyní stal státní zástupce (Donnie Yen), se případem zabývá, a je přesvědčen o jeho nevině, tudíž se rozhodne pokračovat ve vlastním vyšetřování, přičemž riskuje svou kariéru i život, aby skutečného pachatele postavil před soud."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"O Promotor","runtime":0,"tagline":"Lute por justiça.","homepage":"","overview":"Um jovem pobre é injustamente acusado de tráfico de drogas após ser enganado. Um ex-promotor investiga o caso e descobre o esquema de uma equipe de advogados corruptos."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Прокурор","runtime":0,"tagline":"","homepage":"","overview":"Нещасний молодий чоловік опинився в біді, коли його помилково звинувачують у злочині, якого той не скоював. Колишній прокурор береться особисто розслідувати цю дивну справу, щоб зрештою викрити цілу дієву злочинну схему справжньої корупції та беззаконня, які вже багато років поспіль активно працюють разом. Він готовий піти на все, аби лише відновити справедливість."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"The Prosecutor","runtime":99,"tagline":"","homepage":"","overview":"Ein armer junger Mann wird zu Unrecht des Drogenhandels beschuldigt, nachdem er betrogen wurde. Ein ehemaliger Staatsanwalt untersucht den Fall, deckt die Machenschaften eines korrupten Anwaltsteams auf und stellt trotz der Behinderung durch böse Mächte die Gerechtigkeit wieder her."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"The Prosecutor","runtime":0,"tagline":"","homepage":"","overview":"Un jeune homme pauvre est accusé à tort de trafic de drogue après avoir été trompé. Un ancien procureur enquête sur l'affaire, découvre le complot d'une équipe d'avocats corrompus et rétablit la justice malgré l'obstruction des forces du mal."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"El Fiscal: El Lado Oscuro de la Justicia","runtime":0,"tagline":"","homepage":"","overview":"La trama sigue a un joven, Ma Ka-kit, que es injustamente acusado de tráfico de drogas después de alquilar su dirección para ganar dinero extra. Un fiscal, Fok, con fuertes convicciones, investiga el caso a pesar de las dudas y la oposición, descubriendo una trama de corrupción que involucra a un sindicato del crimen y a un abogado corrupto. Fok se ve obligado a arriesgar su carrera y su vida para destapar la verdad y llevar a los verdaderos culpables ante la justicia."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"The Prosecutor","runtime":0,"tagline":"","homepage":"","overview":"Fok Chi-ho, poliziotto mosso da uno spiccato senso della giustizia, rassegna le proprie dimissioni dalle forze dell'ordine come forma di protesta, dopo l'assoluzione con formula piena di un criminale che aveva arrestato in flagranza di reato. Deluso dal sistema, Chi-ho decide di rimettersi a studiare per diventare avvocato e cercare di ristabilire la giustizia nelle aule dei tribunali. A partire dal caso di un povero giovane, ingiustamente accusato di traffico di stupefacenti."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"เดอะ โปรซิคิวเตอร์ เกิดมาเก็บเจ้าพ่อ","runtime":0,"tagline":"","homepage":"","overview":"อดีตเจ้าหน้าที่ตำรวจที่ผันตัวมาเป็นอัยการ เขาได้ค้นพบเครือข่ายการคอร์รัปชันภายในระบบกฎหมาย ซึ่งบีบบังคับให้เขาต้องเผชิญกับทั้งอุปสรรคทางราชการและการข่มขู่คุกคามทางกายภาพเพื่อพิสูจน์ความบริสุทธิ์ของมา"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"The Prosecutor","runtime":0,"tagline":"","homepage":"","overview":"Biedny młody mężczyzna zostaje niesłusznie oskarżony o handel narkotykami po tym, jak został oszukany. Były prokurator bada sprawę, odkrywa spisek skorumpowanej grupy prawników i przywraca sprawiedliwość mimo przeszkód ze strony złowrogich sił."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"El fiscal","runtime":0,"tagline":"LUCHA POR LA JUSTICIA","homepage":"","overview":"Un exdetective se convierte en fiscal y enfrenta la corrupción en el sistema judicial. Al investigar un caso lleno de dudas, se embarca en una misión personal para hacer justicia, enfrentándose a traficantes de drogas, conspiraciones y jueces corruptos en un intenso thriller de acción."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Un jove pobre és acusat injustament de tràfic de drogues després de ser enganyat. Un exfiscal investiga el cas, descobreix l'intent d'un equip d'advocats corruptes i restaura la justícia malgrat l'obstrucció de les forces del mal."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"}],"reviews_tmdb":[{"id":"678aaca4b9d1d10ef197c971","url":"https://www.themoviedb.org/review/678aaca4b9d1d10ef197c971","author":"Chris Sawin","content":"$11","created_at":"2025-01-17T19:16:52.524Z","updated_at":"2025-01-17T19:16:52.609Z","author_details":{"name":"Chris Sawin","rating":8,"username":"ChrisSawin","avatar_path":null}}],"recommendations":[{"id":522811,"adult":false,"title":"The Accidental Detective 2: In Action","video":false,"overview":"A comic book storekeeper, Dae-man, and the legendary homicide detective, Tae-su, who met on previous case quit their jobs to open a private detective agency.","genre_ids":[35,80],"media_type":"movie","popularity":0.9042,"vote_count":40,"poster_path":"/tbXQWdfzEUUQJXhkieQwaQ4XAqf.jpg","release_date":"2018-06-13","vote_average":6.413,"backdrop_path":"/1kzsu5rW3xt4K96hXyooWAxBeVD.jpg","original_title":"탐정: 리턴즈","original_language":"ko"},{"id":92989,"adult":false,"title":"A Summer at Grandpa's","video":false,"overview":"A coming-of-age story about a young brother and sister whom spend a pivotal summer in the country with their grandparents.","genre_ids":[18],"media_type":"movie","popularity":0.9303,"vote_count":50,"poster_path":"/gnmZGNut8TLk5630yiGgoMvPaah.jpg","release_date":"1984-11-24","vote_average":7.42,"backdrop_path":"/b0Jsfl5xW87GOAAFEoqaf3GAIXF.jpg","original_title":"冬冬的假期","original_language":"zh"},{"id":1311537,"adult":false,"title":"Octopus with Broken Arms","video":false,"overview":"Coinciding with a grand local holiday celebration, wealthy businessman Zheng Bingrui invites his daughter Tingting's teacher Li Huiping and a group of classmates' parents to a party at his home, but Tingting is suddenly kidnapped. Police officer Zhang Jingxian led the team to investigate the case, the kidnappers to Ting Ting life threat, requiring Zheng Li with a huge ransom to the appointment, along the way the two found the kidnapping case behind the hidden secrets ......","genre_ids":[80,9648,53],"media_type":"movie","popularity":0.6247,"vote_count":20,"poster_path":"/npcFyS4d2t3XGtIffINI5AapIst.jpg","release_date":"2024-12-28","vote_average":6.85,"backdrop_path":"/l7BD0M3S1lb9w4FcUJPppAq5XIY.jpg","original_title":"误杀3","original_language":"zh"},{"id":1014214,"adult":false,"title":"Singham Again","video":false,"overview":"The cop universe expands with newer additions while the old ones return led by Bajirao Singham. Singham Again interweaves the mythological epic Ramayana's good vs evil narrative when his wife Avni Kamath gets abducted by Danger Lanka setting Bajirao and his gang of Sangram Bhalerao and Veer Sooryavanshi along with Satya and Shakti Shetty on a mission to rescue her.","genre_ids":[28,18,53,80],"media_type":"movie","popularity":1.4282,"vote_count":36,"poster_path":"/2JbNkHg8m7LaBy61LyrnnlenaxY.jpg","release_date":"2024-11-01","vote_average":4.889,"backdrop_path":"/kQGJ3Cv7AKAvmdUaCLihkxVMMqs.jpg","original_title":"सिंघम अगेन","original_language":"hi"},{"id":751391,"adult":false,"title":"Young Ip Man: Crisis Time","video":false,"overview":"In 1917 young Ip Man first came to Hong Kong to study, but his peaceful campus life was unexpectedly broken. A shocking hostage situation occurred on the day when the school held an English speech contest. All students in the school were held hostage, and one person was killed every minute. Facing the immediate crisis, Ip Man stepped forward, but unexpectedly discovered that the kidnapper was his master, and his good brother turned out to be an accomplice of the kidnapper.","genre_ids":[28],"media_type":"movie","popularity":1.0925,"vote_count":36,"poster_path":"/jWeP8CIjHY7iPpcV9mWPWJEWez9.jpg","release_date":"2020-10-08","vote_average":5.625,"backdrop_path":"/2HRXtyR5Xd2ann68k9wOCHzJs8X.jpg","original_title":"少年叶问之危机时刻","original_language":"zh"},{"id":942894,"adult":false,"title":"Avarice","video":false,"overview":"Kate, a gifted archer, is on vacation with her family when they are ambushed by a team of mercenaries in a vicious home invasion. Kate’s husband and daughter are abducted during the violent onslaught, and she must rely on her archery skills to defeat their captors and save her family.","genre_ids":[53,28],"media_type":"movie","popularity":2.5019,"vote_count":42,"poster_path":"/4uhSK3rq6aymSlzgoX3EKm1y2sf.jpg","release_date":"2022-12-08","vote_average":5.6,"backdrop_path":"/oGSZhcYamvXNN6UFx68lYznGpDM.jpg","original_title":"Avarice","original_language":"en"},{"id":390945,"adult":false,"title":"Pro","video":false,"overview":"“PRO” takes viewers on an unforgettable ride into the ultra-elite world of the superstars of professional bike racing: Bobby Julich, Chris Horner, Freddie Rodriguez, Mike Sayers, Gord Fraser, Henk Vogels, Mark McCormack, Jonas Carney, Trent Klasna, Michael Creed, Erik Saunders, Tim Johnson and more. These superstars and their teams star in “PRO”, director Jamie Paolinetti’s follow up film to the cult phenomenon, The Hard Road.","genre_ids":[99],"media_type":"movie","popularity":0.1182,"vote_count":3,"poster_path":null,"release_date":"2004-10-04","vote_average":5.2,"backdrop_path":null,"original_title":"Pro","original_language":"en"},{"id":1200251,"adult":false,"title":"Lonesome Soldier","video":false,"overview":"Based on a true American story, Lonesome Soldier immerses viewers in the captivating journey of Jackson Harlow, a young man hailing from the heart of Tennessee to the war-torn lands of Iraq. Haunted by the vivid memories of war, Jackson's homecoming proves to be a profound turning point in his life, as he discovers that the battle he faces is far from over—it’s just different.  Lonesome Soldier vividly portrays the profound challenges and profound triumphs experienced by those who have bravely faced the crucible of war, only to return to a world that may never fully comprehend their struggles.","genre_ids":[18,10752,53],"media_type":"movie","popularity":1.3608,"vote_count":3,"poster_path":"/vogNJaF8eCpfhemCgCZNRW7Zq2M.jpg","release_date":"2023-11-03","vote_average":5.7,"backdrop_path":"/1urraINhjp8NDGwVF6gWwza6gY2.jpg","original_title":"Lonesome Soldier","original_language":"en"},{"id":1360838,"adult":false,"title":"Blade of Fury","video":true,"overview":"Pei Xing, known as the Jackal, once traded lives for money without emotion. After witnessing the powerful crush those fighting for justice, his sense of righteousness awakens. Now, he seeks revenge, punishing the wicked while facing off against other skilled swordsmans.","genre_ids":[12,28],"media_type":"movie","popularity":4.3158,"vote_count":14,"poster_path":"/utyfULeHcVAwyc3uAYMDpxeTLdN.jpg","release_date":"2024-09-28","vote_average":6.6,"backdrop_path":"/dTsVTo5zmh9yZFGg08LmXkmPkS7.jpg","original_title":"捉刀人","original_language":"zh"},{"id":404358,"adult":false,"title":"What is the Ghost Up To?","video":false,"overview":"Cheondong got dumped by his first love Murim 8 years ago. He's on the verge of getting sick of his boring life when Murim appears in front of him as a ghost. Even before he could accept Murim's death, Murim asks him for a favor. It's to find his boyfriend. Cheondong gets angry at first but he ends up looking for her boyfriend...","genre_ids":[],"media_type":"movie","popularity":0.1406,"vote_count":4,"poster_path":"/lAGymcf7RaB0JdhuXnqn5ZGIleQ.jpg","release_date":"2015-07-31","vote_average":6.6,"backdrop_path":null,"original_title":"귀신은 뭐하나","original_language":"ko"},{"id":198992,"adult":false,"title":"A Thousand Year-Old Fox","video":false,"overview":"Once upon a time, under the reign of the three kingdoms, there was a woman who tempts a Buddhist priest named Cho. She is a one-thousand-year-old fox who intends to reincarnate as a human being. Not knowing this, Cho lives with the fox. But in the end, they get separated harboring sadness of unfulfilled love in this world.","genre_ids":[28,14,27],"media_type":"movie","popularity":0.1811,"vote_count":8,"poster_path":"/4JmNFZ4RodjI3u2FfJuFIYspkz1.jpg","release_date":"1969-03-08","vote_average":6.6,"backdrop_path":"/7X9JMXfBYd4b6UTK0bl9gzX9R75.jpg","original_title":"천년호","original_language":"ko"},{"id":101335,"adult":false,"title":"Boys Are Easy","video":false,"overview":"A man wants to see his three daughters get married.","genre_ids":[35,10749],"media_type":"movie","popularity":0.6136,"vote_count":8,"poster_path":"/yjdJtNJzZlMDFvVyroSEycVe86L.jpg","release_date":"1993-08-12","vote_average":6.75,"backdrop_path":"/y1q31wQEfPABbWELzgHfRHzH09n.jpg","original_title":"追男仔","original_language":"cn"},{"id":411268,"adult":false,"title":"Line Walker","video":false,"overview":"The details of undercover police officers are deleted from a police database and a senior officer is left struggling to know who are the undercover officers and who are the criminals.","genre_ids":[28,80,18],"media_type":"movie","popularity":0.8778,"vote_count":73,"poster_path":"/ePNjPe80sb1NitOLHTGh1DxDkWO.jpg","release_date":"2016-08-11","vote_average":6.466,"backdrop_path":"/7q1DrXVUVCHTm6rMGtRcLSqDO3D.jpg","original_title":"使徒行者","original_language":"cn"},{"id":1158249,"adult":false,"title":"Project Eerie","video":false,"overview":"On Halloween, 2020, Jesse and Jacob Warner disappeared while live streaming on social media. This is that live stream.","genre_ids":[27],"media_type":"movie","popularity":0.1467,"vote_count":37,"poster_path":"/tw8o7cJEybMbaqu8kCeTcxBi5EZ.jpg","release_date":"2023-09-03","vote_average":6.8,"backdrop_path":"/mCfrawMCdVBtl6FHortnN9TAoKz.jpg","original_title":"Project Eerie","original_language":"en"},{"id":481370,"adult":false,"title":"Bigger","video":false,"overview":"The inspirational tale of the grandfathers of the fitness movement as we now know it, Joe & Ben Weider. Battling anti-Semitism, racism and extreme poverty, the brothers beat all odds to build an empire & inspire future generations.","genre_ids":[18,36],"media_type":"movie","popularity":0.6661,"vote_count":81,"poster_path":"/f6rmiFTfT3Rf9XDrXfLO6XcAgWn.jpg","release_date":"2018-10-13","vote_average":6.9,"backdrop_path":"/1TgnorI5RDzzHhyr5J72BhL7HY8.jpg","original_title":"Bigger","original_language":"en"},{"id":45380,"adult":false,"title":"Crazy Stone","video":false,"overview":"Three thieves try to steal a valuable jade that is tightly guarded by a security chief. But the security guards are not the only obstacle these thieves are facing. An extremely unlucky internationally known master thief is also trying to get a hand on this piece of precious jade. What would be the final destination of this piece of crazy stone?","genre_ids":[28,35],"media_type":"movie","popularity":0.9855,"vote_count":139,"poster_path":"/4NVNv2sQKZKb1HtGExUqp3Ukd7f.jpg","release_date":"2006-06-30","vote_average":7.612,"backdrop_path":"/8xzVdkNPNbqT6kJA6IHaRKFpt0B.jpg","original_title":"疯狂的石头","original_language":"zh"},{"id":1143128,"adult":false,"title":"Omni Loop","video":false,"overview":"Diagnosed with a black hole growing inside her chest and stuck in a loop reliving the last five days of her life, a 55-year-old wife and mother from Miami, Florida decides to solve time travel in order to go back and be the person she always intended to be.","genre_ids":[878,18],"media_type":"movie","popularity":0.5675,"vote_count":90,"poster_path":"/aKrwq3HeyFcl5MXb7tcsileoF9I.jpg","release_date":"2024-09-20","vote_average":5.817,"backdrop_path":"/dSRFLFbykiSndcPzweMcD2ToohT.jpg","original_title":"Omni Loop","original_language":"en"},{"id":1299537,"adult":false,"title":"Successor","video":false,"overview":"Ma Chenggang, a wealthy man in Xihong City, worries that his eldest son is too spoiled to succeed him. Determined to raise a capable successor, he takes an unconventional approach. They conceal their wealth, moving the family to a dilapidated neighborhood, and maintain an illusion of poverty, so that his son could develop qualities such as hard work, knowledge, careful budgeting, physical fitness, and perseverance.","genre_ids":[35],"media_type":"movie","popularity":2.1465,"vote_count":82,"poster_path":"/jqGZEk4sLGGmIXBDQzxTuT1lZx2.jpg","release_date":"2024-07-13","vote_average":6.97,"backdrop_path":"/9ir1UZYWBZBkgCoRUIV0ffk43Xe.jpg","original_title":"抓娃娃","original_language":"zh"},{"id":1137205,"adult":false,"title":"Last Straw","video":false,"overview":"A rural roadside diner becomes the host of a maniacal killing spree – leaving a young waitress to clean up the mess. After hard-headed Nancy fires the staff at her dad’s diner, she decides to cover the last shift of the night by herself. Little does she know, she is far from alone. The day is coming back to haunt her and when things begin to spiral out of control, she must fight for her life over the course of one long night.","genre_ids":[27,18,53],"media_type":"movie","popularity":1.6208,"vote_count":123,"poster_path":"/hgpUvybRQzRK6UagoHNQRrO8sUg.jpg","release_date":"2024-09-20","vote_average":6.13,"backdrop_path":"/A6KaZEXI9NJ1nwjmzTQDkiDTDWN.jpg","original_title":"Last Straw","original_language":"en"},{"id":10540,"adult":false,"title":"Outland","video":false,"overview":"On the sunless moon Io, Marshall William T. O’Niel goes toe-to-toe with the corrupt manager of a mining colony and his gang of roughnecks while investigating a rash of worker suicides.","genre_ids":[878,28,53,80,37],"media_type":"movie","popularity":2.1568,"vote_count":669,"poster_path":"/qmjlDkV8CfCboa8WV06ytZaThqx.jpg","release_date":"1981-05-22","vote_average":6.422,"backdrop_path":"/6m1ol0YFN35kXQ2KNz5LDWwaD56.jpg","original_title":"Outland","original_language":"en"}],"similar_content":[{"id":247193,"adult":false,"title":"Bajo un manto de estrellas","video":false,"overview":"","genre_ids":[18,36],"popularity":0.1177,"vote_count":3,"poster_path":"/8UHtaaZUIr6ZVWHKQpBW9PL92Ak.jpg","release_date":"2014-02-14","vote_average":6.7,"backdrop_path":null,"original_title":"Bajo un manto de estrellas","original_language":"es"},{"id":205,"adult":false,"title":"Hotel Rwanda","video":false,"overview":"Inspired by true events, this film takes place in Rwanda in the 1990s when more than a million Tutsis were killed in a genocide that went mostly unnoticed by the rest of the world. Hotel owner Paul Rusesabagina houses over a thousand refuges in his hotel in attempt to save their lives.","genre_ids":[18,36,10752],"popularity":3.4816,"vote_count":3090,"poster_path":"/p3pHw85UMZPegfMZBA6dZ06yarm.jpg","release_date":"2004-12-22","vote_average":7.7,"backdrop_path":"/jkvvXaN7FPVKGlk8oj9PL0FHNtj.jpg","original_title":"Hotel Rwanda","original_language":"en"},{"id":207,"adult":false,"title":"Dead Poets Society","video":false,"overview":"At an elite, old-fashioned boarding school in New England, a passionate English teacher inspires his students to rebel against convention and seize the potential of every day, courting the disdain of the stern headmaster.","genre_ids":[18],"popularity":11.8108,"vote_count":12309,"poster_path":"/l5NbiHKUmahlAT3Q1ig8Tyl9xrc.jpg","release_date":"1989-06-02","vote_average":8.301,"backdrop_path":"/yYvBNN96Ym3wtPxGCFl7F888WwB.jpg","original_title":"Dead Poets Society","original_language":"en"},{"id":247426,"adult":false,"title":"Attica","video":false,"overview":"Acclaimed dramatization recreating the incidents surrounding the 1971 revolt in New York's Attica State Prison that lasted for 23 days and resulted in the greatest casualty toll between Americans since the Civil War.","genre_ids":[18,36,10770],"popularity":0.4109,"vote_count":14,"poster_path":"/dSxPDsiX9qYjAsdBPimrUzUS7m9.jpg","release_date":"1980-03-02","vote_average":5.7,"backdrop_path":"/hCKVC2e8gzXYXg1XScWcOyxzPkD.jpg","original_title":"Attica","original_language":"en"},{"id":667,"adult":false,"title":"You Only Live Twice","video":false,"overview":"A mysterious spacecraft captures Russian and American space capsules and brings the two superpowers to the brink of war. James Bond investigates the case in Japan and comes face to face with his archenemy Blofeld.","genre_ids":[28,53,12],"popularity":7.1355,"vote_count":2402,"poster_path":"/fdRbvRcEXcf2rC4ghLFZzCWPSmB.jpg","release_date":"1967-06-13","vote_average":6.593,"backdrop_path":"/cpZAXIYA0lkZMpAt7d1MmH8ojNV.jpg","original_title":"You Only Live Twice","original_language":"en"},{"id":668,"adult":false,"title":"On Her Majesty's Secret Service","video":false,"overview":"With the help of Marc-Ange Draco, head of the Unione Corse crime syndicate, and Draco's troubled daughter Tracy, James Bond tracks his archnemesis, Ernst Stravro Blofeld, to a mountaintop retreat in the Swiss Alps, where he is training an army of beautiful, lethal women.","genre_ids":[12,28,53],"popularity":5.3271,"vote_count":2077,"poster_path":"/m3KfbxvqaiAvRJ6MpguA3GuLdDQ.jpg","release_date":"1969-12-18","vote_average":6.562,"backdrop_path":"/58pMrmwwcKamJIdjUlinE6QX1Fs.jpg","original_title":"On Her Majesty's Secret Service","original_language":"en"},{"id":687,"adult":false,"title":"Dead Man Walking","video":false,"overview":"A death row inmate turns for spiritual guidance to a local nun in the days leading up to his scheduled execution for the murders of a young couple.","genre_ids":[18],"popularity":1.7303,"vote_count":1464,"poster_path":"/eShxyjhWoFl3BwsuEmVsr4nLaMZ.jpg","release_date":"1995-12-29","vote_average":7.321,"backdrop_path":"/gwRWQeHfPuA8mg73kydQsM8rdXq.jpg","original_title":"Dead Man Walking","original_language":"en"},{"id":691,"adult":false,"title":"The Spy Who Loved Me","video":false,"overview":"Russian and British submarines with nuclear missiles on board both vanish from sight without a trace. England and Russia both blame each other as James Bond tries to solve the riddle of the disappearing ships. But the KGB also has an agent on the case.","genre_ids":[12,28,53],"popularity":5.5757,"vote_count":2165,"poster_path":"/3ZxHKFxMYvAko680DsRgAZKWcLi.jpg","release_date":"1977-07-07","vote_average":6.8,"backdrop_path":"/8lRdfsmJjUXQU3DMOOB3vVIhJxP.jpg","original_title":"The Spy Who Loved Me","original_language":"en"},{"id":696,"adult":false,"title":"Manhattan","video":false,"overview":"Manhattan explores how the life of a middle-aged television writer dating a teenage girl is further complicated when he falls in love with his best friend's mistress.","genre_ids":[35,18,10749],"popularity":3.8199,"vote_count":2566,"poster_path":"/k4eT3EvfxW1L9Wmt04UqJqCvCR6.jpg","release_date":"1979-04-25","vote_average":7.718,"backdrop_path":"/adnSTomHU9YyqV2lx38CgM0UxLS.jpg","original_title":"Manhattan","original_language":"en"},{"id":699,"adult":false,"title":"For Your Eyes Only","video":false,"overview":"A British spy ship has sunk and on board was a hi-tech encryption device. James Bond is sent to find the device that holds British launching instructions before the enemy Soviets get to it first.","genre_ids":[12,28,53],"popularity":5.8858,"vote_count":2016,"poster_path":"/xV4Nnr6DjjERlqNikqDQX8LUgua.jpg","release_date":"1981-06-24","vote_average":6.541,"backdrop_path":"/z7Jp7HAsY7MqXzPYzTjJnmOQk2r.jpg","original_title":"For Your Eyes Only","original_language":"en"},{"id":708,"adult":false,"title":"The Living Daylights","video":false,"overview":"After a defecting Russian general reveals a plot to assassinate foreign spies, James Bond is assigned a secret mission to dispatch the new head of the KGB to prevent an escalation of tensions between the Soviet Union and the West.","genre_ids":[28,12,53],"popularity":5.57,"vote_count":1965,"poster_path":"/1oRlmWX9hewpn2B44wawBjHd7dx.jpg","release_date":"1987-06-29","vote_average":6.542,"backdrop_path":"/ebaq0ecL1Tu39rIExfHwE4ToFl2.jpg","original_title":"The Living Daylights","original_language":"en"},{"id":709,"adult":false,"title":"Licence to Kill","video":false,"overview":"After capturing the notorious drug lord Franz Sanchez, Bond's close friend and former CIA agent Felix Leiter is left for dead and his wife is murdered. Bond goes rogue and seeks vengeance on those responsible, as he infiltrates Sanchez's organization from the inside.","genre_ids":[12,28,53],"popularity":4.7914,"vote_count":2096,"poster_path":"/8nzJve63EXA79HGAyidZwivZrQ2.jpg","release_date":"1989-06-13","vote_average":6.43,"backdrop_path":"/ff0oDdHd8iFkFFfMZLXuGcxPphY.jpg","original_title":"Licence to Kill","original_language":"en"},{"id":746,"adult":false,"title":"The Last Emperor","video":false,"overview":"A dramatic history of Pu Yi, the last of the Emperors of China, from his lofty birth and brief reign in the Forbidden City, the object of worship by half a billion people; through his abdication, his decline and dissolute lifestyle; his exploitation by the invading Japanese, and finally to his obscure existence as just another peasant worker in the People's Republic.","genre_ids":[18,36],"popularity":4.9386,"vote_count":1868,"poster_path":"/7TILJhdeJAaEyDiwvJZMo9SQBoe.jpg","release_date":"1987-10-04","vote_average":7.582,"backdrop_path":"/k29qVmwWwR0i5A1UMIws1Vmv6hV.jpg","original_title":"The Last Emperor","original_language":"en"},{"id":769,"adult":false,"title":"GoodFellas","video":false,"overview":"The true story of Henry Hill, a half-Irish, half-Sicilian Brooklyn kid who is adopted by neighbourhood gangsters at an early age and climbs the ranks of a Mafia family under the guidance of Jimmy Conway.","genre_ids":[18,80],"popularity":20.4002,"vote_count":14030,"poster_path":"/9OkCLM73MIU2CrKZbqiT8Ln1wY2.jpg","release_date":"1990-09-12","vote_average":8.452,"backdrop_path":"/gILte6Zd7m1YneIr6MVhh30S9pr.jpg","original_title":"GoodFellas","original_language":"en"},{"id":1955,"adult":false,"title":"The Elephant Man","video":false,"overview":"A Victorian surgeon rescues a heavily disfigured man being mistreated by his \"owner\" as a side-show freak. Behind his monstrous façade, there is revealed a person of great intelligence and sensitivity. Based on the true story of Joseph Merrick (called John Merrick in the film), a severely deformed man in 19th century London.","genre_ids":[18,36],"popularity":4.8847,"vote_count":3832,"poster_path":"/u0wpPYjuSt8DIe1Y3Vapnh8jcKE.jpg","release_date":"1980-10-09","vote_average":8.048,"backdrop_path":"/6huSptAsqYg3wbsi1jbMognSgmp.jpg","original_title":"The Elephant Man","original_language":"en"},{"id":1965,"adult":false,"title":"A Perfect Murder","video":false,"overview":"Millionaire industrialist Steven Taylor is a man who has everything but what he craves most: the love and fidelity of his wife. A hugely successful player in the New York financial world, he considers her to be his most treasured acquisition. But she needs more than simply the role of dazzling accessory.","genre_ids":[80,53,18],"popularity":2.5596,"vote_count":1515,"poster_path":"/wC0ax12N9GQ8vMXPEs4nES5AAiB.jpg","release_date":"1998-06-05","vote_average":6.546,"backdrop_path":"/dNW7ftcqEAvKmDkuRPaLC4gnhwJ.jpg","original_title":"A Perfect Murder","original_language":"en"},{"id":2007,"adult":false,"title":"Lorenzo's Oil","video":false,"overview":"Augusto and Michaela Odone are dealt a cruel blow by fate when their five-year-old son Lorenzo is diagnosed with a rare and incurable disease. But the Odones' persistence and faith leads to an unorthodox cure which saves their boy and re-writes medical history.","genre_ids":[18],"popularity":1.4133,"vote_count":555,"poster_path":"/suRf59zRu1h8Zq4Gxekn6UiLGaM.jpg","release_date":"1992-12-30","vote_average":7.1,"backdrop_path":"/gYapxyWZXFYcCHtf5dVB2Ub9RTy.jpg","original_title":"Lorenzo's Oil","original_language":"en"},{"id":2017,"adult":false,"title":"No Good Deed","video":false,"overview":"While doing a friend a favor and searching for a runaway teenager, a police detective stumbles upon a bizarre band of criminals about to pull off a bank robbery.","genre_ids":[28,80,18,9648,53],"popularity":1.2831,"vote_count":209,"poster_path":"/lrQU72BcSfzJx71X1ko2K4LTtlE.jpg","release_date":"2002-06-28","vote_average":5.368,"backdrop_path":"/29t7THr2KxAHcCrtd1yxaaNW3g9.jpg","original_title":"No Good Deed","original_language":"en"},{"id":2024,"adult":false,"title":"The Patriot","video":false,"overview":"After proving himself on the field of battle in the French and Indian War, Benjamin Martin wants nothing more to do with such things, preferring the simple life of a farmer. But when his son Gabriel enlists in the army to defend their new nation, America, against the British, Benjamin reluctantly returns to his old life to protect his son.","genre_ids":[18,36,10752,28],"popularity":5.8339,"vote_count":4214,"poster_path":"/fWZd815QxUCUcrWQZwUkAp9ljG.jpg","release_date":"2000-06-28","vote_average":7.183,"backdrop_path":"/jSHHUHRcShP6DJbg0H2lO4A8m9x.jpg","original_title":"The Patriot","original_language":"en"},{"id":2031,"adult":false,"title":"Resurrection","video":false,"overview":"Young Prince Nechljudov is summoned as a judge in a murder trial. A rich merchant was found dead in the room of the inn where he was staying and the prostitute Maslova was accused of the crime. Nechljudov recognizes in the woman the maid of the aunts he had seduced and abandoned years before and tries to convince the authorities of her of his innocence but to no avail. Convinced that he is responsible for her moral fall, he follows her to Siberia where she must serve her sentence.","genre_ids":[18],"popularity":0.3581,"vote_count":1,"poster_path":"/u07uWW6dxPc29fx5liIWrA5EZmw.jpg","release_date":"1958-10-21","vote_average":6,"backdrop_path":"/8gM79OmCssrg88XsxKVg6fMKFuM.jpg","original_title":"Auferstehung","original_language":"de"}],"external_ids":{"imdb_id":"tt30024043","twitter_id":null,"facebook_id":null,"wikidata_id":"Q130272144","instagram_id":null,"metacritic_id":"movie/the-prosecutor","rotten_tomatoes_id":"m/the_prosecutor"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":102937,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AU","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-01-16T00:00:00.000Z","certification":"MA 15+"}]},{"iso_3166_1":"BR","release_dates":[{"note":"","type":4,"iso_639_1":"","descriptors":[],"release_date":"2025-11-28T00:00:00.000Z","certification":""}]},{"iso_3166_1":"CA","release_dates":[{"note":"","t