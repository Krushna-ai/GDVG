9:{"metadata":[["$","title","0",{"children":"The Prosecutor | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"A poor young man is wrongly charged with drug trafficking after being deceived. An ex-prosecutor investigates the case, uncovers a corrupt lawyer team's scheme, and restores justice despite obstruction from evil forces."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/102937/the-prosecutor"}],["$","meta","5",{"property":"og:title","content":"The Prosecutor"}],["$","meta","6",{"property":"og:description","content":"A poor young man is wrongly charged with drug trafficking after being deceived. An ex-prosecutor investigates the case, uncovers a corrupt lawyer team's scheme, and restores justice despite obstruction from evil forces."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/102937/the-prosecutor"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/n3ZnFqp988MWfIkT8OHofEJfjlt.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"The Prosecutor"}],["$","meta","12",{"name":"twitter:description","content":"A poor young man is wrongly charged with drug trafficking after being deceived. An ex-prosecutor investigates the case, uncovers a corrupt lawyer team's scheme, and restores justice despite obstruction from evil forces."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/n3ZnFqp988MWfIkT8OHofEJfjlt.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L12","15",{}]],"error":null,"digest":"$undefined"}
