o_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":2.278},{"width":1920,"height":1080,"file_path":"/6WMeEmwXWKwrWBd6uDXjtWPigzM.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":7,"aspect_ratio":1.778,"vote_average":1.714},{"width":1920,"height":1080,"file_path":"/prCigWMtfA30kyq7nkSJzQGqJUr.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":1.434},{"width":1600,"height":900,"file_path":"/cqymonAfUuwdMipMWhdxZqKTbaQ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":5,"aspect_ratio":1.778,"vote_average":1.434},{"width":3840,"height":2160,"file_path":"/bSN9FlCj3dTMjFl06iSWApvPkpJ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":1.222},{"width":1400,"height":788,"file_path":"/h5DKYSXoEGAEZYNE0aeJCi31y6.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":4,"aspect_ratio":1.777,"vote_average":0.958},{"width":1436,"height":808,"file_path":"/ctA83AEOo0XGZRvibkCpXVkZy5.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.777,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/pVZ9HzD2NFxXV46sa68elrZKn75.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/8zKNryybejRB84XdC0gTjWe02za.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/bUcOCgPkzRR1O2J5dM0LzhgbTX9.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2624,"height":1476,"file_path":"/kO2nOycxztWI3Jt9KUrEZMjHfrM.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/bBBBIFSZyQ2jo0LhtRFSt0XhlBe.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2123,"height":1194,"file_path":"/iX3kDTnIf744hQloj3V4wqrcMsS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2129,"height":1198,"file_path":"/unLlQofTRk0pMQ1YVmabDNCOqLB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2127,"height":1196,"file_path":"/cIoRsfAfC4Jd1Hz8K9w5W5CbZUt.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2121,"height":1193,"file_path":"/oVh1PiKd2xxjGBmzb2zEPs3QOu6.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2105,"height":1184,"file_path":"/dzRMAAdrjgz1WFlXj7YgPCvSP7V.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2116,"height":1190,"file_path":"/tPeRsq5BvpoxNTo70WKXfL9m0no.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2127,"height":1196,"file_path":"/bbghX9Mae2dulX7DnlTy2UqPCOb.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2110,"height":1187,"file_path":"/gwpl831qZiHPbsNz0yf6KlShCI3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2122,"height":1194,"file_path":"/9rbfnXfFZKwAfF6TWJXA6TJ9Zs2.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.777,"vote_average":0},{"width":2118,"height":1191,"file_path":"/7SLdNcklqk58ciELx4jmJdKmWDM.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/wHHEU1lysXDt4Z8YgCVX8KKRaQY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/fKUOswTU1RclX6hqmkhhPvO8I0t.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/ibOANglYKJm0l3mf2a3sozlxiqH.jpg","iso_639_1":"zh","iso_3166_1":"HK","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T03:42:03.178+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Sympathy for Mr. Vengeance","runtime":129,"tagline":"Revenge was never this sweet.","homepage":"","overview":"A deaf man and his girlfriend resort to desperate measures in order to fund a kidney transplant for his sister. Things go horribly wrong, and the situation spirals rapidly into a cycle of violence and revenge."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Sympathy for Mr. Vengeance","runtime":121,"tagline":"","homepage":"","overview":"Der taubstumme Ryu hat nur ein Ziel vor Augen: er will seiner schwerkranken Schwester eine Nierentransplantation ermöglichen. Doch er muss einsehen, dass er dies auf legale Weise nicht erreichen wird. Ein Deal mit einer kriminellen Bande von Organhändlern soll das Leben seiner Schwester retten, aber die Gangster haben nur ihre eigenen Interessen im Sinn und stehlen ihm sein Geld. Als letzten verzweifelten Schritt plant er eine Kindesentführung. Doch dies erweist sich für ihn als ein weiterer, äußerst fataler Fehler."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Mr. Vendetta","runtime":129,"tagline":"La vendetta non è mai stata cosí dolce.","homepage":"","overview":"Ryu è un ragazzo sordomuto che, per pagare le cure della sorella malata, cerca di vendere un rene: truffato dai trafficanti di organi, su consiglio della sua ragazza Yeong-mi organizza il rapimento della figlia dell'uomo che l'ha licenziato. Per un incidente, la bambina muore affogata, ed il padre, Park Dong-jin, dà la caccia a Ryu e Yeong-mi per vendicarsi."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Sympathy for Mister Vengeance","runtime":121,"tagline":"","homepage":"","overview":"Ryu est un ouvrier sourd et muet, dont la sœur est en attente d'une opération chirurgicale. Son patron, Dongjin, est divorcé et père d'une petite fille. Young-Mi, la fiancée de Ryu, est une activiste gauchiste. Lorsque Ryu perd son emploi et voit diminuer les chances d'opération de sa sœur, elle lui propose de kidnapper la fille de Dongjin. La rançon obtenue servirait à pouvoir soigner la sœur de Ryu. Mais le plan parfait tourne à la catastrophe…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Haklı İntikam","runtime":0,"tagline":"","homepage":"","overview":"Böbrek nakli yapılması gereken kız kardeşine yardım etmek için çocuk kaçıran sağır Ryu’nun başına gelmeyen kalmaz. İşler sarpa sarar ve Güney Kore’nin kenar mahallerinde işkenceden, cinayete, karaborsadan intihara, terörizmden organ mafyasına kadar uzanan uzun ve kanlı bir yolculuk başlar. Şaşırtıcı gelişmelerle dolu haklı intikamın, sürpriz finaliyle unutulmazlar arasına gireceğine şüphe yok."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Сочувствие господину Месть","runtime":0,"tagline":"","homepage":"","overview":"История глухонемого Рю и его сестры, которой нужно пересадить почку. Начальник Рю, Пак, только что уволил его, и Рю со своей подружкой решают похитить дочь Пака, чтобы на полученный выкуп сделать трансплантацию. Но все идет катастрофически не так, и ситуация очень скоро перерастает в лавину насилия и мести…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Sympathy for Mr. Vengeance","runtime":129,"tagline":"Sé que eres una buena persona, pero tengo que matarte","homepage":"","overview":"Un hombre sordo y su novia recurren a medidas desesperadas para financiar un trasplante de riñón para su hermana. Las cosas salen terriblemente mal y la situación se convierte rápidamente en un ciclo de violencia y venganza."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Em Nome da Vingança","runtime":121,"tagline":"A vingança nunca foi tão doce.","homepage":"","overview":"Ryu (Ha-kyun Shin) é surdo-mudo. Sua adorada irmã precisa com urgência de um transplante de rim. Na ausência de doadores compatíveis, Ryu recorre ao mercado negro, mas é trapaceado e perde todas suas economias, bem como o próprio rim. Ryu então é convencido por sua namorada a seqüestrar a filha de 4 anos do empresário Dong-Jin (Kang-ho Song) para custear a cirurgia de transplante. Mas o seqüestro não funciona como esperado: a irmã de Ryu se suicida e a menina raptada morre afogada. Sem outros motivos para viver, Dong-Jin e Ryu vão preparar implacáveis planos de vingança um contra o outro."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"我要复仇","runtime":121,"tagline":"复仇从未如此甜蜜","homepage":"","overview":"Ryu（申河均饰）是名聋哑青年，自父母去世一直和姐姐相依为命。在特殊学校里，他遇上了装作失聪的女友（裴斗娜饰），二人感情发展不错。可是姐姐却患上了绝症，需要移植肾脏以维持生命..."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Boksuneun Naui Geot","runtime":129,"tagline":"","homepage":"","overview":"Ryu wil een van zijn nieren te doneren aan zijn zieke zus. Maar deze blijkt niet geschikt te zijn voor haar. Bovendien wordt hij ontslagen door de fabriek waar hij werkt, vanwege verzuim om voor zijn zus te zorgen. Hij komt in contact met een orgaanhandelaar in de zwarte markt die zijn nier steelt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Mr. Vengeance – A bosszú ura","runtime":0,"tagline":"","homepage":"","overview":"Chan-wook Park bosszú-trilógiájának első darabja, mely egyben a legnyersebb is a három film (a másik kettő az Oldboy és A bosszú asszonya) közül. A főszereplő egy fiatal, süketnéma fiú, aki vesebeteg nővére számára próbál pénzt gyűjteni az új szervre, de mivel a szervkereskedők csúnyán átverik őt, így kétségbeesett lépésként elrabolja volt főnöke lányát, ám ezzel az akcióval bosszúállások megállíthatatlan láncolatát indítja el. A bosszú ura a pár éve virágzó dél-koreai filmgyártás egyik legjobb darabja, ami a megtekintése közben komoly erőfeszítéseket igényel a néző részéről, de ha egyszer rászántuk magunkat, akkor páratlanul megrázó élményben lesz részünk. A bosszú ura nem akciófilm, így itt minden késlendítésnek vagy ütésnek irtózatos ereje van. Park nyersen, realistán mindent megmutat, és nem fordítja el a kamerát még a legkegyetlenebb pillanatokban sem."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"복수는 나의 것","runtime":120,"tagline":"우연히 시작된 비극, 상상보다 거대한 파국","homepage":"","overview":"선천성 청각 장애인 류에게 누나는 유일한 가족이다. 신부전증을 앓고 있는 누나는 병이 악화되어 신장을 이식하지 않으면 얼마 살 수 없다는 진단을 받는다. 누나와 혈액형이 달라 이식 수술이 좌절된 류는 장기밀매단과 접촉해 자신의 신장과 전재산 천 만원을 넘겨주고 누나를 위한 신장을 받기로 하지만 모든 것이 사기로 드러난다. 누나에게 맞는 신장을 찾기 위해 돈이 필요한 류는 애인이자 운동권 학생인 영미의 말에 아이를 유괴한다. 착한 유괴라고 류를 설득해 동진의 딸을 유괴하지만 이 사실을 알게 된 류의 누이는 스스로 목숨을 끊고 우연한 사건으로 아이마저 죽게 되는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Hämnarens resa","runtime":0,"tagline":"","homepage":"","overview":"En dövstum man som förlorat sitt jobb behöver pengar för att kunna hjälpa sin syster att få en ny njure. Då han själv inte är kompatibel som donator försöker han sälja en av sina egna njurar för att få ihop pengar till en transplantation. Han blir dock lurad och dras in i en desperat jakt på pengar till en ny njure."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"שלום לנוקם","runtime":0,"tagline":"","homepage":"","overview":"סרטו השני של פארק צ'אן ווק, מי שאחראי לסרט המפתיע \"שבעה צעדים\" (שמהווה חלק שני בטרילוגיה, שזהו חלקה הראשון). מעשה באח ואחות - האח חירש-אילם שזה עתה פוטר מעבודתו והאחות חולה הזקוקה להשתלת כליה. האח מחליט למכור את כלייתו בשוק השחור בתמורה לכליה שתתאים לאחותו. מנקודת מוצא זו הכל הולך ומסתבך. הסרט המרגש הזה זכה בפרסים רבים ותרם למעמדו של הבמאי כאחד החשובים ביותר שיצאו אי פעם מהמזרח הרחוק."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"復讐者に憐れみを","runtime":0,"tagline":"","homepage":"","overview":"先天性の聴覚障害を持つリュウは、重い病に倒れた姉を献身的に看病していた。両親亡きあと自分の面倒を見てくれた姉を救うため、自ら片方の腎臓を提供しようとするリュウだったが、検査の結果は不適合。おまけに、看病のため欠勤が続き職場を解雇されてしまう。仕方なく臓器売買の闇取引に望みを託すが、反対に自分の腎臓と虎の子の退職金を騙し取られてしまう。そんな時、病院から移植ドナーが現われたと知らされたリュウ。途方に暮れる彼に、恋人ユンミは金持ちの子供を誘拐すればいいと強引に説得する。やむなく言われた通り行動するリュウだったが...。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Mr. Vingança","runtime":129,"tagline":"A vingança nunca foi tão doce.","homepage":"","overview":"O jovem Ryu é surdo-mudo e cuida da irmã, que precisa de um transplante urgente de um rim; tenta juntar dinheiro trabalhando, mas quando é demitido se desespera e negocia um de seus órgãos no mercado negro, em troca de um outro saudável e compatível para a irmã, sendo enganado pelos criminosos. Sem saída, sua namorada o ajuda a planejar o sequestro de uma criança rica, mas um acidente levará a situação à um nível que Ryu jamais poderia imaginar."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Má je pomsta","runtime":121,"tagline":"","homepage":"","overview":"Zoufalí lidé konají zoufalé věci. Tak lze shrnout premisu dnes již klasického snímku náležícího mezi stěžejní díla „korejské vlny\". Nedávno z práce propuštěný hluchoněmý mladík se marně pokouší sehnat peníze, aby své nemocné sestře zaplatil transplantaci ledvin. Na radu své přítelkyně se nakonec uchýlí k únosu dcerky svého bývalého zaměstnavatele. Zdánlivě prostý a bezproblémový plán se ale zvrtne a roztočí spirálu zvratů a zoufalstvím zaslepeného násilí."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Pan Zemsta","runtime":121,"tagline":"","homepage":"","overview":"Mroczny thriller będący pierwszym elementem \"trylogii zemsty\", w skład której wchodzą również \"Oldboy\" oraz \"Pani Zemsta\". Dong-jin, bogaty właściciel fabryki, w której pracuje Ryu, dowiaduje się, że jego córeczka została uprowadzona. Kiedy porywacze domagają się okupu, Dong-jin bez chwili wahania spełnia ich żądanie. Wkrótce dowiaduje się, że mimo to jego dziecko zostało zabite. Wtedy planuje krwawą zemstę."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Співчуття панові Помсті","runtime":0,"tagline":"Помста ніколи не була настільки солодкою","homepage":"","overview":"Це історія глухонімого Рю та його сестри, якій необхідна пересадка нирки. Начальник Рю, Пак, щойно звільнив його, і Рю зі своєю подружкою вирішують викрасти доньку Пака, аби на отриманий викуп зробити трансплантацію. Але все йде катастрофічно не так і ситуація дуже скоро переростає в лавину насилля та помсти…"},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Съчувствие за г-н Мъст","runtime":121,"tagline":"","homepage":"","overview":"Първа част от трилогията \"Мъст\" е за глух служител, който събира пари за операция на сестра си, но неочаквано е уволнен и заедно с приятелката си решава да отвлече дъщерята на бившия си шеф."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"我要復仇","runtime":122,"tagline":"失去所愛的兩個男人陷入了瘋狂復仇漩渦之中！","homepage":"","overview":"柳（申河均 飾）先天失聰，聽不見使他難以與外界溝通，也沒有朋友，父母去世後，他與姊姊（林志恩 飾）相依為命，姊姊是生命中的唯一摯愛。姊姊卻罹患絕症，需要移植腎臟，但自己的腎臟卻因血型不合也無法捐給姊姊。柳為了照顧姊姊而曠工，又被工廠開除。他決定到黑市賣腎，被上當被騙，一顆腎白白被割走。柳在面對一連串的厄運後，女友英美（裴斗娜 飾）勸誘下，他們決定去綁架工廠老闆東鎮（宋康昊 飾）的女兒佑善，沒想到老闆女兒卻意外淹死。東鎮白手起家，忙於事業而與妻子離婚，但女兒是他生命中最重要的唯一，這筆喪女之痛東鎮，決定一定要討回來，而走上復仇之路。另一方面，柳的姊姊得知弟弟的所作所為後自殺，崩潰的柳打算殺光欺騙自己腎臟的黑幫流氓。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"復仇","runtime":0,"tagline":"","homepage":"","overview":"柳（申河均 飾）先天失聰，聽不見使他難以與外界溝通，也沒有朋友，父母去世後，他與姊姊（林志恩 飾）相依為命，姊姊是生命中的唯一摯愛。姊姊卻罹患絕症，需要移植腎臟，但自己的腎臟卻因血型不合也無法捐給姊姊。柳為了照顧姊姊而曠工，又被工廠開除。他決定到黑市賣腎，被上當被騙，一顆腎白白被割走。柳在面對一聯串的厄運後，女友英美（裴鬥娜 飾）勸誘下，他們決定去綁架工廠老闆東鎮（宋康昊 飾）的女兒佑善，沒想到老闆女兒卻意外淹死。東鎮白手起家，忙於事業而與妻子離婚，但女兒是他生命中最重要的唯一，這筆喪女之痛東鎮，決定一定要討回來，而走上復仇之路。另一方面，柳的姊姊得知弟弟的所作所為後自殺，崩潰的柳打算殺光欺騙自己腎臟的黑幫流氓。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Η Τελευταία Εκδίκηση","runtime":0,"tagline":"","homepage":"","overview":"Η ταινία ξεκινά με τον κωφάλαλο Ryu που προσπαθεί να μαζέψει λεφτά για την εγχείρηση που θα κάνει η αδελφή του, περιμένοντας παράλληλα μόσχευμα. Απεγνωσμένος απευθύνεται σε μια σε μία οργάνωση που όμως τον εξαπατά."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"El nombre de la venganza","runtime":0,"tagline":"La venganza nunca fue tan dulce.","homepage":"","overview":"Esta es la historia de Ryu, un hombre sordo, y su hermana, que requiere un trasplante de riñón. El jefe de Ryu, Park, acaba de despedirlo, y para poder pagar el trasplante, Ryu y su novia desarrollan un plan para secuestrar a la hija de Park. Las cosas van terriblemente mal y la situación se convierte rápidamente en un ciclo de violencia y venganza."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"เขา! ฆ่าแบบชาติหน้าไม่ต้องเกิด","runtime":0,"tagline":"","homepage":"","overview":"รยูยอมขายไตเพื่อให้พี่สาวได้ผ่าตัด แต่ดันไปเจอคนซื้อหน้าเลือด แล้วแฟนสาวของเขาก็คิดแผนหาเงินขึ้นมาได้"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Sympathy for Mr. Vengeance","runtime":122,"tagline":"Når hævn er den sidste udvej.","homepage":"","overview":"Ryu er desperat. Han er netop blevet fyret for at tage fri for at passe sin syge søster. Hvis hun skal overleve, skal hun have en ny nyre. Ryu forsøger at købe en nyre til sin søster på det sorte marked, men han bliver snydt og mister sine sidste penge. Alt håb synes at være ude indtil hans veninde siger at \"det ikke er en forbrydelse at kidnappe i en god sags tjeneste\". En lille pige bliver bortført, og hendes rige far, Dongin, får et krav om løsepenge. Men noget går helt galt og pigen findes druknet næste dag. Dongin går på jagt efter kidnapperne, helt ude af sig selv. Nu starter en skæbnesvanger ond spiral, som trækker alle ned i en kulsort afgrund af dødelig desperation."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Quý Ông Báo Thù","runtime":0,"tagline":"","homepage":"","overview":"Đây là câu chuyện về Ryu, một người đàn ông bị điếc và em gái của anh ta, người cần ghép thận. Để có tiền cấy ghép, Ryu và bạn gái lên kế hoạch bắt cóc con gái của Park. Mọi thứ trở nên tồi tệ một cách khủng khiếp, và tình hình nhanh chóng trở thành một vòng xoáy bạo lực và trả thù."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"პატივისცემა ბატონი შურისძიების მიმართ","runtime":0,"tagline":"","homepage":"","overview":"რიუ ყრუა, მისი და კი მძიმედ ავადაა და მხოლოდ ტრანსპლანტაცია თუ გადაარენს, რისი ფულიც ოჯახს არ აქვს. ერთხელაც, რიუ მეგობარ გოგონასათან ერთად გადაწყვეტს მოიტაცოს ყოფილი უფროსის ქალიშვილი, გამოსასყიდის მიღების მიზნით."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"ဒီကားရဲ့ ဒါရိုက်တာ Chan-wook Park  ကိုမသိရင်တောင်မှ Oldboy ဆိုတဲ့ ကွီးယားကားကို တော့သိကြမှာပါ..အဲ့ဒီကားဟာ လက်ရာမြောက်လွန်းတဲ့ Hollywood ကတောင် ပြန်လည်ရိုက်ကူးဖြစ်ခဲ့ပါတယ်.Chan-wook Park ဆိုတာ Oldboy ဖန်တီးရှင်ဒါရိုက်တာပေါ့ ယခုSympathy for Mr.Vengeance ဆိုတဲ့ကားကိုလည်း သူရိုက်ကူးခဲ့ပါတယ်...ဒီကားနဲ့ အကောင်းဆုံးရုပ်ရှင်ဆု ၊အကောင်းဆုံး ဒါရိုက်တာဆုတွေအပြင် အခြားဆု(၅)ဆုတောင်ရရှိခဲ့ပါတယ် မင်းသားကလည်း  Kang-ho Song နဲ့  Ha-kyun Shinတို့ပါပဲ Oldboy ကြည့်ဖူးတဲ့သူတွေဆိုရင် ဒီဒါရိုက်တာကြီးရဲ့လက်ရာကိုခန့်မှန်းမိမယ်ထင်ပါတယ်..ဒီကားထဲမှာလည်း သတ်ဖြတ်ခန်းတွေက တကယ့်ကိုသွေးပျက်လောက်စရာကြီးတွေ ဇာတ်ဝင်ခန်းတိုင်းကို အပီပြင်ဆုံးရိုက်ကူးထားတယ်မောင်နှမ(၂)ယောက်ရှိတယ် အစ်မဖြစ်သူက ကျောက်ကပ်မလဲရင်သေရတော့မယ့်ရောဂါအခြေအနေဖြစ်နေတယ်..မောင်ဖြစ်တဲ့သူအနေနဲ့လည်း လှူလို့မရတဲ့အခြေအနေ..ဒါကြောင့် သူ့ကျောက်ကပ်ကိုကလီဇာတွေဝယ်တဲ့ဂိုဏ်းကိုသွားရောင်းလိုက်တယ် ဒီနောက်ပိုင်းတော့ အခြေအနေတွေဟာ အကုန်ရှုတ်ထွေးကုန်တယ် Spoiler မလုပ်သင့်တဲ့ကားဖို့ ကျန်တာတွေမပြောတော့ဘူး"},"name":"","iso_639_1":"my","iso_3166_1":"MY","english_name":"Burmese"},{"data":{"title":"Moja je pomsta","runtime":0,"tagline":"Pomsta nikdy nebola taká sladká.","homepage":"","overview":"Hluchonemý Ryu sa zo všetkých síl snaží zarobiť dosť peňazí, aby mohol svoju umierajúcu sestru poslať na transplantáciu obličiek (čo nie je práve ľahké, keď ste práve prišli o prácu a ešte ku všetkému vám v nemocnici povedali, že potrebný orgán nie je k dispozícii). Po menšej epizóde s priekupníkmi s ľudskými orgánmi dá Ryu na radu svojej priateľky a rozhodne sa získať peniaze na sestrinu operáciu únosom malého dievčatka. Spočiatku sľubne rozbehnutá akcia sa ale veľmi skoro príšerným spôsobom zvrtne a únos uvedie do chodu kolotoč udalostí, ktoré všetkým poriadne zacloumajú životy. Úvodný diel Parkovej trilógie o pomste (nasledovaný snímkami OLDBOY a SYMPATHY FOR LADY VENGEANCE) získal v roku 2003 na filmovom festivale vo Philadelphii prvú cenu za najlepší film."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Răzbunarea este a mea","runtime":0,"tagline":"Răzbunarea nu a fost niciodată așa de dulce.","homepage":"","overview":"Un bărbat surd și iubita lui recurg la măsuri disperate pentru a strânge bani pentru un transplant de rinichi pentru sora lui. Lucrurile iau o întorsătură groaznică, iar situația degenerează rapid într-un ciclu de violență și răzbunare."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"}],"reviews_tmdb":[],"recommendations":[{"id":4550,"adult":false,"title":"Lady Vengeance","video":false,"overview":"Released after being wrongfully convicted and imprisoned for 13 years, a woman begins executing her elaborate plan of retribution.","genre_ids":[18,53],"media_type":"movie","popularity":3.2731,"vote_count":1874,"poster_path":"/3Oy3iLMqD79us2iAUD6fKqWebYU.jpg","release_date":"2005-07-29","vote_average":7.5,"backdrop_path":"/wP1nu98mgiSOyuPmMWdZ8109S9j.jpg","original_title":"친절한 금자씨","original_language":"ko"},{"id":22536,"adult":false,"title":"Thirst","video":false,"overview":"A respected priest volunteers for an experimental procedure that may lead to a cure for a deadly virus. He gets infected and dies, but a blood transfusion of unknown origin brings him back to life. Now, he’s torn between faith and bloodlust, and has a newfound desire for the wife of a childhood friend.","genre_ids":[18,27,53],"media_type":"movie","popularity":2.447,"vote_count":1053,"poster_path":"/sFgvkGpXLTydvHqBCXw54OB8R0h.jpg","release_date":"2009-04-30","vote_average":7.113,"backdrop_path":"/oNdO2VSonWIZFZNC7O4bkuFTNOh.jpg","original_title":"박쥐","original_language":"ko"},{"id":5488,"adult":false,"title":"I'm a Cyborg, But That's OK","video":false,"overview":"Young-goon, mentally deranged and frequently electro-charging herself with a transistor radio, has been admitted into a mental institution. Firmly believing herself to be a cyborg, she refuses to consume like a human being. Il-soon is another patient, who catches the eye of Young-goon and soon becomes a close friend. Il-soon is now confronted with the biggest task: to cure Young-goon's mental problem and have her eat real food.","genre_ids":[18,35,10749],"media_type":"movie","popularity":1.7958,"vote_count":582,"poster_path":"/x48ecVD1HbfQh3KZeK6LwRgVrOl.jpg","release_date":"2006-12-07","vote_average":7.034,"backdrop_path":"/eLgZPEG4994T2gjB1YtgQJrp8b3.jpg","original_title":"싸이보그지만 괜찮아","original_language":"ko"},{"id":33908,"adult":false,"title":"Three... Extremes","video":false,"overview":"Features an anthology centred on the experiences of a witch doctor, a film-maker and a disgruntled extra determined to take revenge on him, and a novelist as well as her twin sister.","genre_ids":[27],"media_type":"movie","popularity":0.9908,"vote_count":402,"poster_path":"/r0UzUF15suxLatzvNK3TQKxp10h.jpg","release_date":"2004-08-20","vote_average":6.779,"backdrop_path":"/lJ5lUT0yccP3ejklErN0HqlGMwv.jpg","original_title":"쓰리, 몬스터","original_language":"ko"},{"id":670,"adult":false,"title":"Oldboy","video":false,"overview":"With no clue how he came to be imprisoned, drugged and tortured for 15 years, a desperate man seeks revenge on his captors.","genre_ids":[18,53,9648,28],"media_type":"movie","popularity":13.8085,"vote_count":9601,"poster_path":"/pWDtjs568ZfOTMbURQBYuT4Qxka.jpg","release_date":"2003-11-21","vote_average":8.241,"backdrop_path":"/sdwjQEM869JFwMytTmvr6ggvaUl.jpg","original_title":"올드보이","original_language":"ko"},{"id":27936,"adult":false,"title":"Micmacs","video":false,"overview":"While standing in the doorway of the video shop where he works, Bazil is inadvertently shot in the head. Now homeless and jobless, he is taken in by a troupe of misfits who live in a giant mound of trash. There Bazil begins his quest for revenge against the people who produced the gun that shot him.","genre_ids":[28,35,80],"media_type":"movie","popularity":0.9869,"vote_count":646,"poster_path":"/yiqooJWNDEVsp8lbdTrTBvLAk0m.jpg","release_date":"2009-10-28","vote_average":6.625,"backdrop_path":"/awhWLCEmA4Suxf3po9xXAGDwzZY.jpg","original_title":"Micmacs à tire-larigot","original_language":"fr"},{"id":2440,"adult":false,"title":"Joint Security Area","video":false,"overview":"Two North Korean soldiers are killed in the border area between North and South Korea, prompting an investigation by a neutral body. The sergeant is the shooter, but the lead investigator, a Swiss-Korean woman, receives differing accounts from the two sides.","genre_ids":[18,53,28],"media_type":"movie","popularity":4.3349,"vote_count":800,"poster_path":"/etoPOj0bXzfw0LBNslCxqO7MHuv.jpg","release_date":"2000-09-09","vote_average":7.8,"backdrop_path":"/z7w6ACQJTeGYASr1plSwfRe6Ytk.jpg","original_title":"공동경비구역 JSA","original_language":"ko"},{"id":73827,"adult":false,"title":"Why","video":false,"overview":"Giuseppe Di Noi, an Italian surveyor living in Swiden, gets arrested at the border while going back to Italy with his family for a vacation. But can someone tell the man why?","genre_ids":[18,35],"media_type":"movie","popularity":0.3662,"vote_count":91,"poster_path":"/kFGvi77y4sHMOTopRXJGTTzqEU5.jpg","release_date":"1971-10-27","vote_average":7.258,"backdrop_path":"/mZ9Y8JSLnZZoxmWlzvTjZ1cvmJ2.jpg","original_title":"Detenuto in attesa di giudizio","original_language":"it"},{"id":20043,"adult":false,"title":"Royal Space Force - The Wings of Honneamise","video":false,"overview":"On a future Earth, war between the Kingdom of Honneamise and its rival, The Republic, is inevitable. As evolving technology creates new ways to wage war, a small group seeks to propel mankind into space in their world’s first spaceflight program. For astronaut candidate Shirotsugh Lhadatt, it’s a personal odyssey as he grows from an aimless young man into a leader willing to put everything on the line in order to move the human race forward and away from the brink of Armageddon.","genre_ids":[16,878],"media_type":"movie","popularity":1.8574,"vote_count":148,"poster_path":"/h5naABij9ghj6CLcpBYBkxMGYGX.jpg","release_date":"1987-03-14","vote_average":6.831,"backdrop_path":"/sCPRp4j5YzLTCIG72PRZM8LLgHh.jpg","original_title":"王立宇宙軍 オネアミスの翼","original_language":"ja"},{"id":11297,"adult":false,"title":"Save the Green Planet!","video":false,"overview":"A young man believes that his country's leaders are actually toxic reptilian aliens sent down to launch a takeover of his beloved Earth. So he decides to abduct them and force the truth out on camera in his basement that doubles as a film studio and torture chamber.","genre_ids":[35,878,80],"media_type":"movie","popularity":2.4073,"vote_count":224,"poster_path":"/kou9TDjveVwBhWnxCRUT88RUVCs.jpg","release_date":"2003-04-04","vote_average":6.982,"backdrop_path":"/1yRIjUeLTyy4A1PLWhg1genlhuY.jpg","original_title":"지구를 지켜라!","original_language":"ko"},{"id":35813,"adult":false,"title":"The Bat","video":false,"overview":"Mystery writer Cornelia Van Gorder has rented a country house called \"The Oaks\", which not long ago was the scene of some murders committed by a strange and violent criminal known as \"The Bat\". Meanwhile, the house's owner, bank president John Fleming, has recently embezzled one million dollars in securities and has hidden the proceeds in the house, but is killed before he can retrieve it.","genre_ids":[27,9648,53,80],"media_type":"movie","popularity":0.8114,"vote_count":135,"poster_path":"/78PVHYnadZ0e2BkBBSNonMZvViB.jpg","release_date":"1959-08-09","vote_average":5.919,"backdrop_path":"/8ydivJF1pFmfHRzrvq1DU1esGpx.jpg","original_title":"The Bat","original_language":"en"},{"id":20531,"adult":false,"title":"Early Spring","video":false,"overview":"A young Tokyo salary man and his wife struggle within the confines of their passionless relationship while he has an extramarital affair.","genre_ids":[18,10749],"media_type":"movie","popularity":0.8329,"vote_count":92,"poster_path":"/aEZuNAL70fVDiAoSG2sAEVHa3xO.jpg","release_date":"1956-01-29","vote_average":7.5,"backdrop_path":"/l0WJpDWrRGqZabwVlNEl42VKMVz.jpg","original_title":"早春","original_language":"ja"},{"id":10247,"adult":false,"title":"He Was a Quiet Man","video":false,"overview":"An unhinged office worker who planned to go on a shooting spree at his workplace struggles with his newfound status as a hero after he ends up stopping a shooting spree instead.","genre_ids":[35,18,10749],"media_type":"movie","popularity":0.8341,"vote_count":355,"poster_path":"/dZiQLBDum5SjlNmLlkHd61RKVLV.jpg","release_date":"2007-11-23","vote_average":6.38,"backdrop_path":"/dl6fWX816xuKYw7vZRcFaKotBaw.jpg","original_title":"He Was a Quiet Man","original_language":"en"},{"id":10410,"adult":false,"title":"Hoffa","video":false,"overview":"A portrait of union leader James R. Hoffa, as seen through the eyes of his friend, Bobby Ciaro. The film follows Hoffa through his countless battles with the RTA and President Roosevelt.","genre_ids":[80,36,18],"media_type":"movie","popularity":3.6208,"vote_count":348,"poster_path":"/aMGhaSkhkFwz33hKEsBrJ3ptx3g.jpg","release_date":"1992-12-25","vote_average":6.25,"backdrop_path":"/dineJzDZLuEXNNy261vFcJgqhxr.jpg","original_title":"Hoffa","original_language":"en"},{"id":54890,"adult":false,"title":"Dhobi Ghat","video":false,"overview":"Arun is a reclusive and lonely modern art painter. Shai is an American banker who is on a visit to Mumbai. Munna is a washerboy also living near Arun and Yasmin. The movie is about these four characters from different class of society and how the lives of four characters are intertwined.","genre_ids":[18],"media_type":"movie","popularity":0.5435,"vote_count":90,"poster_path":"/hSNbvyrRbfAxz29yJSz7bJ1Ujuu.jpg","release_date":"2010-01-21","vote_average":6.428,"backdrop_path":"/vs4kj5fFi2UaOAglZZstvbyETvp.jpg","original_title":"धोबी घाट","original_language":"hi"},{"id":155217,"adult":false,"title":"Ranma ½","video":false,"overview":"Akane is the youngest of three daughters for Soun Tendo. Her father Soun Tendo runs a dojo for martial arts. Akane hopes to carry on her father's dojo into the distant future. Meanwhile, Akane has been selected to marry Ranma, the son of her father's long time friend Genma. Akane and Ranma's relationship has developed into a love and hate relationship. Also, Ranma isn't your typical boy. While on a training journey Ranma fell into the Spring of the Drowned Girl and now changes into a women whenever cold water is splashed on him. Warm water will allow him to revert back to a male. Problems arise when Akane's father declares that the successor to their dojo must be a male. Now, Akane and Ranma (being a man only half of the time) must find a secret spring that can cure him of his curse.","genre_ids":[28,35,14,10770],"media_type":"movie","popularity":0.7567,"vote_count":61,"poster_path":"/qU59RKzCu15sBodid5Sb3lfgxHp.jpg","release_date":"2011-12-09","vote_average":6.8,"backdrop_path":"/5nd7Z1pVMLoPvrO4EF9fL25S3p9.jpg","original_title":"らんま1/2","original_language":"ja"},{"id":8435,"adult":false,"title":"A Cock and Bull Story","video":false,"overview":"Steve Coogan, an arrogant actor with low self-esteem and a complicated love life, is playing the eponymous role in an adaptation of \"The Life and Opinions of Tristram Shandy, Gentleman\" being filmed at a stately home. He constantly spars with actor Rob Brydon, who is playing Uncle Toby and believes his role to be of equal importance to Coogan's.","genre_ids":[35,36],"media_type":"movie","popularity":0.5418,"vote_count":148,"poster_path":"/g14QNhGkWLviBr18nCGDB1U8w8f.jpg","release_date":"2005-07-17","vote_average":6.149,"backdrop_path":"/8MWKVstOmGUlCsS80iPTHDH7N22.jpg","original_title":"A Cock and Bull Story","original_language":"en"},{"id":253020,"adult":false,"title":"Road 47","video":false,"overview":"During World War II, looking up the Mountain, in Italy, a Brazilian Expeditionary Force - FEB - mines weeping platoon is hit by a panic-attack that sets them running aimlessly right in the middle of 'no man's land'. Desperate cold and hungry, the ill-prepared soldiers have to choose between facing military court or delve deeper into enemy lines. After a tense discussion, they decide to save their faces with the Brazilian Army by tackling a daring military objective: to disarm the most feared minefield in Italy. On their way there, they end meeting two others deserters; a remorseful Italian soldier trying to join the Partigianos and German officer who is just simply tired of war. with unexpected help of their ex-enemy, the soldiers are set to accomplish a mission that so far had been deemed impossible.","genre_ids":[10752,36,18],"media_type":"movie","popularity":0.7246,"vote_count":51,"poster_path":"/xQCtUSUOiNIRuj0gaGR6Rku7rD6.jpg","release_date":"2014-08-01","vote_average":6.2,"backdrop_path":"/xrg3t1y8oMq4CzvoOaPqFeCH41L.jpg","original_title":"A Estrada 47","original_language":"pt"},{"id":62382,"adult":false,"title":"The Mattei Affair","video":false,"overview":"Enrico Mattei helped change Italy’s future, first as freedom-fighter against the Nazis, then as an investor in methane gas through a public company, A.G.I.P., and ultimately as the head of ENI, a state body formed for the development of oil resources. On October 27, 1962, he died when his private airplane crashed during a flight to Milan. Officially, it is declared an accident, but many journalists explore other plausible reasons for Mattei's untimely death.","genre_ids":[18,36],"media_type":"movie","popularity":0.4048,"vote_count":112,"poster_path":"/p4EHDfdbgjNXmQb7WB9fYmom0s1.jpg","release_date":"1972-01-26","vote_average":7.455,"backdrop_path":"/wl6kXCMdmFIHYyzTgAoB8LsaduB.jpg","original_title":"Il caso Mattei","original_language":"it"},{"id":53380,"adult":false,"title":"Divine Trash","video":false,"overview":"The life and times of Baltimore film maker and midnight movie pioneer, John Waters.","genre_ids":[99],"media_type":"movie","popularity":0.3031,"vote_count":36,"poster_path":"/uaPcuUP9QxyKRtdGtE6IlG4JLqp.jpg","release_date":"2000-03-31","vote_average":7.194,"backdrop_path":"/hVv9yoyYCPt3f6D1U3GbJqqP9iN.jpg","original_title":"Divine Trash","original_language":"en"}],"similar_content":[{"id":8046,"adult":false,"title":"Gigli","video":false,"overview":"Gigli is ordered to kidnap the psychologically challenged younger brother of a powerful federal prosecutor. When plans go awry, Gigli's boss sends in Ricki, a gorgeous free-spirited female gangster who has her own set of orders to assist with the kidnapping. But Gigli begins falling for the decidedly unavailable Ricki, which could be a hazard to his occupation.","genre_ids":[35,80,18,10749],"popularity":2.2604,"vote_count":488,"poster_path":"/qOhAK3WDqdeVTIE59loXvEGU7Lu.jpg","release_date":"2003-08-01","vote_average":4.019,"backdrop_path":"/ciIVYsDU4F4nCfrE6j6d1kCfStU.jpg","original_title":"Gigli","original_language":"en"},{"id":8068,"adult":false,"title":"Desperado","video":false,"overview":"El Mariachi plunges headfirst into the dark border underworld when he follows a trail of blood to the last of the infamous Mexican drug lords, Bucho, for an action-packed, bullet-riddled showdown. With the help of his friend and a beautiful bookstore owner, El Mariachi tracks Bucho, takes on his army of desperados, and leaves his own trail of blood.","genre_ids":[53,28,80],"popularity":3.683,"vote_count":3072,"poster_path":"/e3gwpBeXpvGZsxUya9zNym5QXrw.jpg","release_date":"1995-08-25","vote_average":6.928,"backdrop_path":"/rWFLgIRGXzECIbczgo7dmnwq55q.jpg","original_title":"Desperado","original_language":"en"},{"id":8090,"adult":false,"title":"Untraceable","video":false,"overview":"Special Agent Jennifer Marsh works in an elite division of the FBI dedicated to fighting cybercrime. She thinks she has seen it all, until a particularly sadistic criminal arises on the Internet. This tech-savvy killer posts live feeds of his crimes on his website; the more hits the site gets, the faster the victim dies. Marsh and her team must find the elusive killer before time runs out.","genre_ids":[53,80,9648,18,27],"popularity":1.6294,"vote_count":969,"poster_path":"/ySUwDRDEn01lKIMPQorpFCMLWqE.jpg","release_date":"2008-01-22","vote_average":6.229,"backdrop_path":"/pPTNyx5xjYQ7WX05n3eRjmhGzdC.jpg","original_title":"Untraceable","original_language":"en"},{"id":8208,"adult":false,"title":"The Man Who Knew Too Much","video":false,"overview":"While vacationing in St. Moritz, a British couple receive a clue to an imminent assassination attempt, only to learn that their daughter has been kidnapped to keep them quiet.","genre_ids":[53,9648],"popularity":0.823,"vote_count":438,"poster_path":"/qghwbSfQblFYRFq675uK5qDGr3w.jpg","release_date":"1934-12-09","vote_average":6.489,"backdrop_path":"/o9QuotgupLq34zYyzFrfd4TrimC.jpg","original_title":"The Man Who Knew Too Much","original_language":"en"},{"id":277496,"adult":false,"title":"Seoul","video":false,"overview":"Japanese detective Hayase is caught in the midst of a truck robbery on the way to the Seoul airport. Being forced to extend his stay and help identify the robbers, Hayase gets thrown into another situation -- as Japan's Foreign Minister is kidnapped before the upcoming Asian Summit. Is 72 hours enough?","genre_ids":[53,28,12],"popularity":0.3397,"vote_count":1,"poster_path":"/e68W255xHxLBfQG73x8X5vmOp7G.jpg","release_date":"2002-02-09","vote_average":5,"backdrop_path":"/qqsz34AfEAyaq3XWsfpxbY0gKak.jpg","original_title":"ソウル","original_language":"ja"},{"id":470918,"adult":false,"title":"Beast","video":false,"overview":"A troubled woman living in an isolated community finds herself pulled between the control of her oppressive family and the allure of a secretive outsider suspected of a series of brutal murders.","genre_ids":[9648,80,18],"popularity":0.7893,"vote_count":326,"poster_path":"/kZdncyp1IKhEqwv5zdmUpK5Dc7S.jpg","release_date":"2018-04-18","vote_average":6.5,"backdrop_path":"/t3W767pq9rUdMXxVGzWVt2hs1Hs.jpg","original_title":"Beast","original_language":"en"},{"id":8456,"adult":false,"title":"Never Back Down","video":false,"overview":"Jake, full of anger after his father's death, is just starting to find a place for himself at his new Orlando high school - until Ryan, head of an underground MMA fight club, picks Jake out as a prime opponent. After being trounced by Ryan in front of the entire school, Jake begins training under the firm, moral guidance of a MMA master, where he learns how to fight... and how to avoid a fight. But it becomes obvious that a rematch will be inevitable if Jake wants to stop Ryan and his bullying, once and for all.","genre_ids":[18,28],"popularity":4.4077,"vote_count":2442,"poster_path":"/8oRUTyP1QAtGDMvRpKZyuyFPG0U.jpg","release_date":"2008-03-04","vote_average":6.8,"backdrop_path":"/h71xyiurUscD6uIPbECyso1Lwb9.jpg","original_title":"Never Back Down","original_language":"en"},{"id":8470,"adult":false,"title":"John Q","video":false,"overview":"John Quincy Archibald is a father and husband whose son is diagnosed with an enlarged heart and then finds out he cannot receive a transplant because HMO insurance will not cover it. Therefore, he decides to take a hospital full of patients hostage until the hospital puts his son's name on the donor's list.","genre_ids":[18,53,80],"popularity":2.864,"vote_count":2555,"poster_path":"/xEE91LvXiqgs7Hmdl44LCzHtFf6.jpg","release_date":"2002-02-15","vote_average":7.125,"backdrop_path":"/sBB39VMtByFltGGGW2c5N6LOAvj.jpg","original_title":"John Q","original_language":"en"},{"id":8292,"adult":false,"title":"Four Brothers","video":false,"overview":"Four adopted brothers return to their Detroit hometown when their mother is murdered and vow to exact revenge on the killers.","genre_ids":[28,80],"popularity":4.497,"vote_count":2328,"poster_path":"/8cO39cnWSZQi2ncPG5TxL3YRzKc.jpg","release_date":"2005-08-11","vote_average":6.805,"backdrop_path":"/2pITFeesu6aikrEknoH6bNXOdhk.jpg","original_title":"Four Brothers","original_language":"en"},{"id":8681,"adult":false,"title":"Taken","video":false,"overview":"Bryan Mills, a former government operative, is trying to reconnect with his teenage daughter Kim. After reluctantly agreeing with his ex-wife to let Kim go to Paris on vacation with a friend, his worst nightmare comes true. While on the phone with his daughter shortly after she arrives in Paris, she and her friend are abducted by a gang of human traffickers. Working against the clock, Bryan relies on his extensive training and skills to track down the ruthless gang that abducted her and launch a one-man war to rescue his daughter.","genre_ids":[28,53],"popularity":12.7718,"vote_count":11898,"poster_path":"/ognkaUSNgJe1a2pjB4UNdzEo5jT.jpg","release_date":"2008-02-18","vote_average":7.4,"backdrop_path":"/lMRMjd9yJsZLyaT97eiURu2zVb4.jpg","original_title":"Taken","original_language":"en"},{"id":8373,"adult":false,"title":"Transformers: Revenge of the Fallen","video":false,"overview":"Sam Witwicky leaves the Autobots behind for a normal life. But when his mind is filled with cryptic symbols, the Decepticons target him and he is dragged back into the Transformers' war.","genre_ids":[878,28,12],"popularity":2.9923,"vote_count":9020,"poster_path":"/pLBb0whOzVDtJvyD4DPeQyQNOqp.jpg","release_date":"2009-06-19","vote_average":6.21,"backdrop_path":"/bH1bhjn37uA1zOPvyHbzJSvza7v.jpg","original_title":"Transformers: Revenge of the Fallen","original_language":"en"},{"id":8382,"adult":false,"title":"Today You Die","video":false,"overview":"A former thief who is trying to go straight seeks vengeance on those who framed him.","genre_ids":[28,80,12,53],"popularity":0.8781,"vote_count":121,"poster_path":"/fSL56vXRp4Qh23vXPiAhJMFKZgB.jpg","release_date":"2005-09-13","vote_average":4.3,"backdrop_path":"/9XpbzvX38LUi21QYvBlVyp3yBMv.jpg","original_title":"Today You Die","original_language":"en"},{"id":8427,"adult":false,"title":"I Spy","video":false,"overview":"When the Switchblade, the most sophisticated prototype stealth fighter created yet, is stolen from the U.S. government, one of the United States' top spies, Alex Scott, is called to action. What he doesn't expect is to get teamed up with a cocky civilian, World Class Boxing Champion Kelly Robinson, on a dangerous top secret espionage mission. Their assignment: using equal parts skill and humor, catch Arnold Gundars, one of the world's most successful arms dealers.","genre_ids":[28,12,35,53],"popularity":5.0509,"vote_count":1008,"poster_path":"/hmjCMtkeqxruMVocq7iwMx899xi.jpg","release_date":"2002-10-31","vote_average":5.4,"backdrop_path":"/qwGkQpQbDXuHDOq909RQmJPENwN.jpg","original_title":"I Spy","original_language":"en"},{"id":8436,"adult":false,"title":"The Page Turner","video":false,"overview":"Mélanie Prouvost, a ten-year-old butcher's daughter, is a gifted pianist. That is why she and her parents decide that she sit for the Conservatory entrance exam. Although Mélanie is very likely to be admitted, she unfortunately gets distracted by the president of the jury's offhand attitude and she fails. Ten years later, Mélanie becomes her page turner, waiting patiently for her revenge.","genre_ids":[18,10402,53],"popularity":0.4351,"vote_count":145,"poster_path":"/lBomGoLZKklJWb5hMvcy44WbUsd.jpg","release_date":"2006-08-09","vote_average":6.521,"backdrop_path":"/uyZMq9VTihrWBVXzIQUkB8P8Nnq.jpg","original_title":"La Tourneuse de pages","original_language":"fr"},{"id":8333,"adult":false,"title":"The Taking of Pelham One Two Three","video":false,"overview":"In New York, armed men hijack a subway car and demand a ransom for the passengers. Even if it's paid, how could they get away?","genre_ids":[80,53,28],"popularity":1.421,"vote_count":605,"poster_path":"/vNhywp9w1DVG6BytxKp4kjtaaGC.jpg","release_date":"1974-10-02","vote_average":7.4,"backdrop_path":"/wDLUp63wIE6NeWHAcJkCijhI3M8.jpg","original_title":"The Taking of Pelham One Two Three","original_language":"en"},{"id":277633,"adult":false,"title":"Blind Vengeance","video":false,"overview":"A man seeks revenge on the white supremacists acquitted in the murder of his son","genre_ids":[18,80,10770],"popularity":0.2312,"vote_count":1,"poster_path":"/8nb3VoDMIf9xwR04DeSlqxwMiHF.jpg","release_date":"1990-08-22","vote_average":1,"backdrop_path":null,"original_title":"Blind Vengeance","original_language":"en"},{"id":8840,"adult":false,"title":"DragonHeart","video":false,"overview":"In an ancient time when majestic fire-breathers soared through the skies, a knight named Bowen comes face to face and heart to heart with the last dragon on Earth, Draco. Taking up arms to suppress a tyrant king, Bowen soon realizes his task will be harder than he'd imagined: If he kills the king, Draco will die as well.","genre_ids":[14,28,12,18],"popularity":3.9928,"vote_count":2107,"poster_path":"/1J2FvxEoEKMFT9TjUdfhm0MJhZD.jpg","release_date":"1996-05-31","vote_average":6.54