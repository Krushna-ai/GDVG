:0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/iyr9VnThgqjw58vkuhwhUyOheJQ.jpg","iso_639_1":"zh","iso_3166_1":"HK","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/xSWWAktCZeN0BXjyvLX108fEgnw.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/mYZZF9d96hACTDGeSyrBNPUCgsb.jpg","iso_639_1":"eu","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/20Yga08DhdRFw7sLMGqjZSRLKch.jpg","iso_639_1":"ja","iso_3166_1":"JP","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/lIPn4z162KmIoESp0G4AeKWDor7.jpg","iso_639_1":"kn","iso_3166_1":"IN","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/sZPLhcW54u4MA95ePADhvTLZWck.jpg","iso_639_1":"hu","iso_3166_1":"HU","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/pE9iG9xz7DmArYF6Cy0SaU0fwmF.jpg","iso_639_1":"ml","iso_3166_1":"IN","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/r7KlKuBmcMzPrkt2yR9HYpPDFlV.jpg","iso_639_1":"zh","iso_3166_1":"SG","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/h4NcN3v6ksZISfZFy5K3UQXfvkS.jpg","iso_639_1":"ka","iso_3166_1":"GE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/8HwBftUHH3aWTl3yB5yjqBcCxuA.jpg","iso_639_1":"ka","iso_3166_1":"GE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/pI696qRdMfPdVal0BBfe4mcXnwZ.jpg","iso_639_1":"ka","iso_3166_1":"GE","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T06:38:45.417+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Tell Me Softly","runtime":119,"tagline":"","homepage":"https://www.amazon.com/dp/B0FY3V1MWB","overview":"Kamila has everything under control: studies, social life, her image... Everything except the unexpected return of her neighbors, the Di Bianco brothers, after seven years of absence. Thiago stole her first kiss, and Taylor was her best friend, but now their return will turn Kami's world upside down. Can the three overcome the past that binds them? Or will everything explode into pieces once again?"},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Kami cree que lo tiene todo controlado… Todo excepto el inesperado regreso de sus vecinos, los hermanos Di Bianco, después de 7 años. Thiago le robó su primer beso y Taylor fue su mejor amigo, pero ahora su vuelta pondrá el mundo de Kami del revés. ¿Podrán superar el pasado que les une? ¿O explotará todo en mil pedazos una vez más?"},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Diga-me Baixinho","runtime":0,"tagline":"","homepage":"https://www.primevideo.com/detail/0PEEDYZH0AJ24QZ0JKD110XD2X","overview":"Kamila tem tudo sob controle: estudos, vida social, sua imagem... Tudo exceto o retorno inesperado de seus vizinhos, os irmãos Di Bianco, depois de sete anos de ausência. Thiago foi seu primeiro beijo, e Taylor era seu melhor amigo, mas agora a volta deles vai bagunçar a vida dela. Será que os três vão conseguir superar o passado que os prende? Ou tudo vai desabar mais uma vez?"},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Dis-le-moi tout bas","runtime":0,"tagline":"","homepage":"https://press.amazonmgmstudios.com/us/en/original-movies/dimelo-bajito","overview":"Tout est sous contrôle dans la vie de Kamila : études, vie sociale, son image... Mais le retour inattendu de ses voisins, les frères Di Bianco, après 7 ans d'absence, change tout. Thiago lui avait volé son premier baiser, Taylor était son meilleur ami, mais leur retour va chambouler l'univers de Kami. Arriveront-ils à surmonter le passé qui les lie ? Ou les choses vont-elles encore s'envenimer ?"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Dimmelo sottovoce","runtime":0,"tagline":"","homepage":"","overview":"Kamila ha tutto sotto controllo: gli studi, la vita sociale, la sua immagine... Tutto, tranne l'inaspettato ritorno dei suoi vicini di casa, i fratelli Di Bianco, dopo sette anni. Thiago le rubò il suo primo bacio, e Taylor era il suo migliore amico, ma il loro ritorno stravolge il mondo di Kami. Riusciranno i tre a superare il passato che li lega? O andrà tutto in frantumi, ancora una volta?"},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"轻声告诉我","runtime":0,"tagline":"","homepage":"","overview":"一切都在卡米拉的掌控之中：学习、社交生活、她的形象……唯独没想到她的邻居迪比安科兄弟会在离开七年后意外归来。蒂亚戈曾经偷走她的初吻，泰勒曾是她的挚友，但他们的归来将把卡米的世界搅得天翻地覆。他们三人能否走出将他们捆绑在一起的过往？还是说一切将再次分崩离析？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"อดีตรักไม่เคยเลือน","runtime":0,"tagline":"","homepage":"","overview":"คามิล่าควบคุมชีวิตของเธอได้เป็นอย่างดี ทั้งการเรียน ชีวิตสังคม ภาพลักษณ์ของเธอ ทุกอย่างนอกจากการกลับมาที่ไม่คาดคิดของเพื่อนบ้าน พี่น้องดิ บิอังโก้ หลังจากที่จากไปถึงเจ็ดปี ติอาโก้ขโมยจูบแรกของเธอไป และเตย์เลอร์ก็เคยเป็นเพื่อนสนิทของเธอ แต่ตอนนี้การกลับมาของพวกเขาจะทำให้โลกของคามี่ต้องกลับตาลปัตร ทั้งสามคนจะเอาชนะอดีตที่ผูกมัดพวกเขาไว้ด้วยกันได้หรือไม่ หรือทุกอย่างจะแตกสลายลงอีกครั้ง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"상냥하게 말해줘","runtime":0,"tagline":"","homepage":"","overview":"카밀라의 인생은 완벽하다. 공부, 친구 관계, 평판까지... 하지만 7년 동안 사라졌던 이웃 디 비앙코 형제가 갑자기 돌아왔다. 첫 키스 상대 티아고와 절친이었던 테일러. 둘의 귀환으로 카미의 세계는 완전히 흔들린다. 세 사람은 과거의 상처를 극복할 수 있을까? 아니면 또다시 모든 게 엉망이 돼 버릴까?"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"柔語情話","runtime":0,"tagline":"","homepage":"","overview":"卡蜜拉的人生看似全盤皆順：學業、社交、形象，樣樣完美，直到消失七年的鄰居迪比安可兄弟突然回來。提亞哥奪走她的初吻，泰勒則是她最好的朋友，如今兄弟倆歸來，卻將卡蜜拉的世界攪得天翻地覆。三人能否跨越過去的糾葛？還是一切又將分崩離析？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Powiedz mi po cichu","runtime":119,"tagline":"","homepage":"","overview":"Kamila ma wszystko pod kontrolą: naukę, życie towarzyskie, wizerunek. Oprócz niespodziewanego powrotu sąsiadów, enigmatycznych braci Di Bianco, po 7 latach nieobecności. Thiago skradł jej pierwszy pocałunek, Taylor był jej najlepszym przyjacielem, ale ich powrót wywraca jej świat do góry nogami. Uda im się uporać z przeszłością, która ich łączy? Czy wszystko znów rozpadnie się na tysiąc kawałków?"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Kamila Hamilton lo tenía todo bajo control... o eso pensaba: no estaba en sus planes que los hermanos Di Bianco volvieran de nuevo a darle la vuelta a su mundo. Hace 7 años Thiago fue el que le dio su primer beso. Y Taylor, el que siempre la protegió. El inesperado regreso de los hermanos sume la aparentemente perfecta vida de Kami en el caos. Ya no es la niña inocente que ellos conocían: desde que se fueron, parece que nadie puede realmente acceder a ella. Nadie excepto ellos. ¿Podrá Kami resistirse a la simple presencia de Thiago? ¿Qué pasará cuando Taylor empiece a mirarla de manera diferente? ¿Explotará todo en mil pedazos una vez más?"},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"أخبرني برقة","runtime":0,"tagline":"","homepage":"","overview":"تسيطر \"كاميلا\" على كلّ جوانب حياتها: دراستها وعلاقاتها الاجتماعية وصورتها أمام الآخرين، إلى أن يعود جاراها السابقان، الأخوان \"دي بيانكو\"، بعد غياب دام 7 أعوام. كان \"تياغو\" صاحب أول قبلة خطفت قلبها، وكان \"تايلور\" صديقها المقرّب، لكن عودتهما الآن تربك عالم \"كامي\" مرة أخرى، فهل يستطيع الـ3 تجاوز الماضي الذي يربطهم؟ أم سينهار كلّ شيء من جديد؟"},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"أخبرني برقة","runtime":0,"tagline":"","homepage":"","overview":"تسيطر \"كاميلا\" على كلّ جوانب حياتها: دراستها وعلاقاتها الاجتماعية وصورتها أمام الآخرين، إلى أن يعود جاراها السابقان، الأخوان \"دي بيانكو\"، بعد غياب دام 7 أعوام. كان \"تياغو\" صاحب أول قبلة خطفت قلبها، وكان \"تايلور\" صديقها المقرّب، لكن عودتهما الآن تربك عالم \"كامي\" مرة أخرى، فهل يستطيع الـ3 تجاوز الماضي الذي يربطهم؟ أم سينهار كلّ شيء من جديد؟"},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Tell Me Softly","runtime":0,"tagline":"","homepage":"","overview":"Kamila hat alles unter Kontrolle: ihr Studium, ihr Sozialleben, ihr Image... Doch dann kehren ihre Nachbarn, die Brüder Di Bianco, nach sieben Jahren Abwesenheit zurück. Thiago gab ihr ihren ersten Kuss und Taylor war ihr bester Freund, aber jetzt stellt ihre Rückkehr Kamis Welt auf den Kopf. Können die drei die Vergangenheit überwinden, die sie verbindet? Oder wird alles wieder zerbrechen?"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"轻声告诉我","runtime":0,"tagline":"","homepage":"","overview":"一切都在卡米拉的掌控之中：学习、社交生活、她的形象......唯独没想到她的邻居迪比安科兄弟会在离开七年后意外归来。蒂亚戈曾经偷走她的初吻，泰勒曾是她的挚友，但他们的归来将把卡米的世界搅得天翻地覆。他们三人能否走出将他们捆绑在一起的过往？还是说一切将再次分崩离析？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"Esadazu goxo","runtime":0,"tagline":"","homepage":"","overview":"Kamilak dena du kontrolpean: ikasketak, lagunak, bere itxura... Dena bere auzoko Di Bianco anaien bat-bateko itzulera izan ezik, zazpi urte kanpoan eman dituztenak. Thiagok lehen musua lapurtu zion, eta Taylor bere lagunik onena zen, baina haien itzulerak hankaz gora jarriko du Kamilaren mundua. Izango dira hirurak iragana atzean uzteko gai? Edo dena joango da berriro pikutara?"},"name":"euskera","iso_639_1":"eu","iso_3166_1":"ES","english_name":"Basque"},{"data":{"title":"Digue-m'ho fluixet","runtime":0,"tagline":"","homepage":"","overview":"La Kamila ho té tot sota control: els estudis, la vida social, la seva imatge... Tot excepte l'inesperat retorn dels seus veïns, els enigmàtics germans Di Bianco, després de set anys. En Thiago li va robar el primer petó i en Taylor era el seu millor amic, però el seu retorn farà trontollar el món de la Kami. Podran tots tres superar el passat que els uneix? O tornarà a esclatar tot en mil bocins?"},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"柔語情話","runtime":0,"tagline":"","homepage":"","overview":"卡蜜拉的人生看似全盤皆順：學業、社交、形象，樣樣完美，直到消失七年的鄰居迪比安可兄弟突然回來。提亞哥奪走她的初吻，泰勒則是她最好的朋友，如今兄弟倆歸來，卻將卡蜜拉的世界攪得天翻地覆。三人能否跨越過去的糾葛？還是一切又將分崩離析？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Řekni mi to tiše","runtime":0,"tagline":"","homepage":"","overview":"Kamila má všechno pod kontrolou: studium, společenský život i svou image. Všechno až na to, že se po sedmi letech nečekaně vrátili její sousedi, bratři Di Biancové. Thiago ji poprvé políbil a Taylor byl její nejlepší kamarád, ale jejich návrat nyní převrátil Kamilin svět vzhůru nohama. Dokáží ti tři překonat minulost, která je poutá? Nebo se vše zase rozpadne na tisíc kusů?"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Dímelo Bajito","runtime":0,"tagline":"","homepage":"","overview":"Kamilalla on kaikki kunnossa: opinnot, sosiaalinen elämä ja imago... Sitten hänen naapurinsa, salaperäiset Di Biancon veljekset, palaavat seitsemän vuoden jälkeen. Kamilan ensisuudelma tapahtui Thiagon kanssa, ja Taylor oli hänen paras ystävänsä. Poikien paluu saa Kamilan maailman ylösalaisin. Voiko kolmikko selättää menneisyyden kahleet, vai hajoaako kaikki uudelleen palasiksi?"},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Dis-le-moi tout bas","runtime":0,"tagline":"","homepage":"","overview":"Kamila maîtrise tous les aspects de sa vie : études, vie mondaine, image... Tout sauf le retour inattendu de ses voisins, les énigmatiques frères Di Bianco, après sept ans d'absence. Thiago lui a donné son premier baiser, et Taylor était son meilleur ami, mais leur retour trouble Kamila. Les trois jeunes pourront-ils surmonter le passé qui les hante, ou la crise éclatera-t-elle une fois de plus ?"},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Dímelo Bajito","runtime":0,"tagline":"","homepage":"","overview":"Kamila heeft alles onder controle: haar studie, sociale leven en imago... Alles behalve de onverwachte terugkeer van haar buren, de Di Bianco-broers, na zeven jaar afwezigheid. Met Thiago had ze haar eerste kus en Taylor was haar beste vriend, maar nu zet hun terugkeer Kami's wereld op z'n kop. Kunnen de drie het verleden dat hen bindt achter zich laten? Of stort alles weer in?"},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Dimo baixiño","runtime":0,"tagline":"","homepage":"","overview":"Kamila teno todo baixo control: os estudos, a vida social, a súa imaxe... Todo agás a inesperada volta dos seus veciños, os irmáns Di Bianco, tras sete anos de ausencia. Thiago rouboulle o seu primeiro bico e Taylor era o seu mellor amigo, pero agora o seu regreso poñerá o mundo de Kami do revés. Poderán os tres superar o pasado que os une? Ou volverá estalar todo en mil pedazos?"},"name":"Galego","iso_639_1":"gl","iso_3166_1":"ES","english_name":"Galician"},{"data":{"title":"Dímelo Bajito","runtime":0,"tagline":"","homepage":"","overview":"Kamila har alt under kontrol: studierne, det sociale, sit image ... Men det hører brat op, da hendes barndomsvenner, Di Bianco-brødrene, vender tilbage efter syv års fravær. Thiago stjal hendes første kys, og Taylor var hendes bedste ven, men nu vender deres tilbagevenden op og ned på Kamis verden. Kan de tre overvinde den fortid, der binder dem sammen? Eller vil alting eksplodere igen?"},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Tell Me Softly","runtime":0,"tagline":"","homepage":"","overview":"Kamila mengira semua baik-baik saja: studi, kehidupan sosial, citranya... Sampai suatu ketika, setelah tujuh tahun tidak ada, tetangganya, Di Bianco bersaudara, kembali. Thiago mencuri ciuman pertamanya, dan Taylor adalah sahabatnya, tetapi kepulangan mereka akan mengubah dunia Kami. Mampukah ketiganya mengatasi masa lalu yang mengikat mereka? Atau akankah semuanya kembali hancur?"},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"Πες μου Σιγανά","runtime":0,"tagline":"","homepage":"","overview":"Η Καμίλα τα έχει όλα υπό έλεγχο: το σχολείο, την κοινωνική ζωή, την εικόνα της... Όλα εκτός από την ξαφνική επιστροφή των γειτόνων της, των αδερφών Ντι Μπιάνκο, μετά από επτά χρόνια απουσίας. Ο Τιάγο έκλεψε το πρώτο της φιλί και ο Τέιλορ ήταν ο καλύτερός της φίλος, αλλά τώρα η επιστροφή τους αναστατώνει την Καμίλα. Μπορούν να ξεπεράσουν κι οι τρεις το παρελθόν ή θα γίνουν όλα ξανά κομμάτια;"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"टेल मी सॉफ़्टली","runtime":0,"tagline":"","homepage":"","overview":"कमिला की ज़िंदगी पूरी तरह उसकी पकड़ में है: पढ़ाई, सामाजिक जीवन, उसकी छवि... सब कुछ, सिवाय उसके पड़ोसियों, दी बिआन्को भाइयों की सात साल बाद हुई अप्रत्याशित वापसी के। थियागो ने उसका पहला चुंबन चुराया था, और टेलर उसका सबसे अच्छा दोस्त था। लेकिन अब उनकी वापसी कामि की दुनिया को पूरी तरह उलट-पुलट कर देगी। क्या ये तीनों उस अतीत से आगे बढ़ पाएंगे जो उन्हें बांधे हुए है? या फिर सब कुछ एक बार फिर बिखर जाएगा?"},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"תגיד לי ברוך","runtime":0,"tagline":"","homepage":"","overview":"הכול אצל קמילה בשליטה: לימודים, חיי חברה, התדמית שלה... הכול מלבד חזרתם הבלתי צפויה של השכנים שלה, האחים די ביאנקו, אחרי שבע שנות היעדרות. טיאגו גנב את הנשיקה הראשונה שלה, וטיילור היה החבר הכי טוב שלה, אך עתה חזרתם תערער את עולמה של קאמי לחלוטין. האם השלושה יצליחו להתגבר על העבר שקושר ביניהם? או שהכול יתפוצץ לרסיסים פעם נוספת?"},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Mondd el halkan!","runtime":0,"tagline":"","homepage":"","overview":"Kamilának sínen van az élete: a suli, a társasági élete, a hírneve... Egészen addig, míg hét év távollét után vissza nem térnek a szomszédai, a Di Bianco fivérek. Thiagótól kapta élete első csókját, Taylor pedig a legjobb barátja volt, de a visszatérésük teljesen felforgatja Kami életét. Vajon túl tudnak lépni a múlton, ami összeköti őket? Vagy megint minden atomjaira hullik szét?"},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Tell me Softly","runtime":0,"tagline":"","homepage":"","overview":"Segalanya terkawal untuk Kamila: pelajaran, kehidupan sosial, imej dirinya. Semuanya sempurna, kecuali kepulangan tak dijangka jiran lamanya, adik-beradik Di Bianco, selepas tujuh tahun menghilang. Thiago orang pertama menciumnya, dan Taylor sahabat baiknya. Kepulangan mereka bakal menggoncang dunia Kamila. Mampukah mereka bertiga mengatasi kisah lalu mereka? Adakah segalanya akan hancur lagi?"},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"テル・ミー・ソフトリー","runtime":0,"tagline":"","homepage":"","overview":"カミラはすべてを完璧にコントロールしていた。勉強も、友達との付き合いも、自分のイメージも...。しかし7年ぶりに突然戻ってきた隣人、ディビアンコ兄弟だけは別だった。ティアゴは彼女のファーストキスを奪い、テイラーは親友だった。彼らが戻ってきたことで、カミの世界はひっくり返る。３人は、わだかまりとなっている過去を乗り越えられるのか？それとも再びすべてが粉々に砕け散ってしまうのか？"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"ടെൽ മീ സോഫ്റ്റ്ലി","runtime":0,"tagline":"","homepage":"","overview":"എല്ലാം കമീല വിചാരിച്ചപോലായിരുന്നു: പഠനം, സോഷ്യൽ ലെെഫ്, പ്രതിച്ഛായ... എല്ലാം, അയൽക്കാരായിരുന്ന ദി ബിയാങ്കോ സഹോദരന്മാർ ഏഴ് വർഷങ്ങൾക്ക് ശേഷം അപ്രതീക്ഷിതമായി തിരിച്ചുവരുന്നവരെ. തിയാഗോ അവളുടെ ആദ്യ ചുംബനം കവർന്നു, തെയ്‌ലർ ഉറ്റ ചങ്ങാതിയും, എന്നാൽ ഇപ്പോൾ അവരുടെ തിരിച്ചുവരവ് കാമിയുടെ ലോകത്തെ കീഴ്മേൽ മറിക്കും. മൂവർക്കും അവരെ ബന്ധിച്ച ഭൂതകാലത്തെ മറികടക്കാനാകുമോ? അതോ വീണ്ടും എല്ലാം പൊട്ടിച്ചിതറുമോ?"},"name":"","iso_639_1":"ml","iso_3166_1":"IN","english_name":"Malayalam"},{"data":{"title":"ದೀಮೆಲೊ ಬಹೀತೊ","runtime":0,"tagline":"","homepage":"","overview":"ಕಮೀಲಾಗೆ ಎಲ್ಲವೂ ತನ್ನ ಹಿಡಿತದಲ್ಲಿದೆ: ಅಧ್ಯಯನ, ಸಾಮಾಜಿಕ ಜೀವನ, ಅವಳ ವ್ಯಕ್ತಿತ್ವ... ಏಳು ವರ್ಷಗಳ ಅನುಪಸ್ಥಿತಿಯ ನಂತರ, ಅವಳ ನೆರೆಹೊರೆಯವರಾದ ಡಿ ಬಿಯಾಂಕೋ ಸೋದರರ ಅನಿರೀಕ್ಷಿತ ಮರಳುವಿಕೆ ಹೊರತುಪಡಿಸಿ. ಥಿಯಾಗೊ ಅವಳ ಪ್ರಥಮ ಚುಂಬನ ಪಡೆದಿದ್ದ, ಮತ್ತು ಟೇಲರ್ ಅವಳ ಆತ್ಮೀಯ ಗೆಳೆಯನಾಗಿದ್ದ, ಆದರೆ ಈಗ ಅವರ ಪುನರಾಗಮನವು ಕಮೀಳ ಪ್ರಪಂಚವನ್ನೇ ತಲೆಕೆಳಗೆ ಮಾಡಲಿದೆ. ಈ ಮೂವರು ಅವರನ್ನು ಹಿಡಿದಿರುವ ಹಿಂದಿನ ಘಟನೆಗಳಿಂದ ಮುಕ್ತರಾಗಬಲ್ಲರೇ? ಇಲ್ಲವೇ ಎಲ್ಲವೂ ಇನ್ನೊಮ್ಮೆ ಛಿದ್ರವಾಗುವುದೇ?"},"name":"?????","iso_639_1":"kn","iso_3166_1":"IN","english_name":"Kannada"},{"data":{"title":"Dímelo Bajito","runtime":0,"tagline":"","homepage":"","overview":"Kamila har alt under kontroll: studiene, sosialt liv, image... Alt unntatt den uventede tilbakekomsten av naboene hennes, de gåtefulle Di Bianco-brødrene, etter 7 års fravær. Thiago stjal hennes første kyss og Taylor var hennes beste venn, men nå vil deres tilbakekomst vende Kamis verden på hodet. Kan de tre overvinne fortiden som binder dem sammen? Eller vil alt eksplodere i tusen biter igjen?"},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Diz-me ao Ouvido","runtime":0,"tagline":"","homepage":"","overview":"Kamila tem tudo sob controlo: os estudos, a vida social, a imagem... Tudo, menos o inesperado regresso dos vizinhos, os enigmáticos irmãos Di Bianco, após sete anos de ausência. Thiago roubou-lhe o primeiro beijo e Taylor foi o melhor amigo dela, mas, agora, o regresso deles vai virar o mundo de Kami do avesso. Conseguirão os três superar o passado que os une? Ou irá tudo desmoronar mais uma vez?"},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"టెల్ మీ సాఫ్ట్‌లీ","runtime":0,"tagline":"","homepage":"","overview":"కమీలా అంతా తన నియంత్రణలోనే ఉంచుకుంటుంది: చదువులు, సామాజిక జీవితం, తన ఇమేజ్... ఏడు ఏళ్ళ తర్వాత ఆమె పొరుగువారైన డి బియాంకో సోదరులు ఊహించని విధంగా తిరిగి రావడం తప్ప మిగతావన్నీ. తియాగో ఆమె మొదటి ముద్దును దొంగిలించాడు, ఇంకా టేలర్ ఆమె ప్రాణ స్నేహితుడు, కానీ వారి ఆకస్మిక రాక కామి ప్రపంచాన్ని తలక్రిందులు చేస్తుంది. ఆ ముగ్గురూ తమ మధ్వ ఉన్న గతాన్ని మరిచి ముందుకు సాగగలరా? లేక అంతా మరలా గందరగోళం అవుతుందా?"},"name":"తెలుగు","iso_639_1":"te","iso_3166_1":"IN","english_name":"Telugu"},{"data":{"title":"Dímelo Bajito","runtime":0,"tagline":"","homepage":"","overview":"Kamila har allt under kontroll: sina studier, sitt sociala liv, sin image... Allt utom den oväntade återkomsten av hennes grannar, de gåtfulla bröderna Di Bianco, efter sju års frånvaro. Thiago stal hennes första kyss och Taylor var hennes bästa vän, men hur ska det nu bli? Kan de tre övervinna det förflutna som binder dem samman? Eller kommer allt att explodera i tusen bitar igen?"},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Spune-mi în șoaptă","runtime":0,"tagline":"","homepage":"","overview":"Kamila are totul sub control: studiile, viața socială, imaginea... Totul, cu excepția întoarcerii neașteptate a vecinilor ei, frații Di Bianco, după șapte ani de absență. Thiago i-a furat primul sărut, iar Taylor era cel mai bun prieten al ei, dar acum întoarcerea lor va da lumea lui Kami peste cap. Vor putea cei trei să depășească trecutul care îi leagă? Sau se va face totul țăndări din nou?"},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"டெல் மீ சாஃப்ட்லி","runtime":0,"tagline":"","homepage":"","overview":"கமிலாவுக்கு அனைத்தும் கட்டுக்குள் உள்ளது: படிப்பு, சமூக வாழ்க்கை, தன் இமேஜ்... ஏழு ஆண்டுக்குப் பின், அண்டை வீட்டாரான டி பியாங்கோ சகோதரர்களின் எதிர்பாரா வருகையைத் தவிர. அவள் முதல் முத்தத்தைத் திருடியவன் தியாகோ, டெய்லர் அவளது உற்ற தோழன். அவர்களின் மறுவருகை, கமியின் உலகைத் தலைகீழாக மாற்றும். மூவரையும் பிணைக்கும் கடந்த காலத்தை அவர்களால் வெல்ல முடியுமா? அல்லது மீண்டும் வெடித்து சுக்கு நூறாகுமா?"},"name":"தமிழ்","iso_639_1":"ta","iso_3166_1":"IN","english_name":"Tamil"},{"data":{"title":"Yavaşça Söyle","runtime":0,"tagline":"","homepage":"","overview":"Kamila her şeyi kontrol altında tutar: dersleri, sosyal hayatı, imajı... Yedi yıl aradan sonra komşuları Di Bianco kardeşlerin beklenmedik dönüşü hariç her şeyi. Thiago ilk öpüştüğü kişiydi ve Taylor en iyi arkadaşıydı, ama şimdi onların dönüşü Kami'nin dünyasını alt üst edecektir. Üçü, onları birbirine bağlayan geçmişi aşabilecek mi? Yoksa her şey bir kez daha paramparça mı olacak?"},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Скажи тихонько","runtime":0,"tagline":"","homepage":"","overview":"Жизнь Камилы переворачивается с ног на голову, когда братья Ди Бьянко возвращаются спустя 7 лет. Тьяго подарил ей первый поцелуй, Тейлор был её защитником. Теперь она изменилась, но они по-прежнему могут достучаться до неё так, как никто другой."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Thì Thầm Với Em","runtime":0,"tagline":"","homepage":"","overview":"Cuộc sống tưởng như hoàn hảo của Kamila bị xáo trộn khi hai anh em Di Bianco trở về sau bảy năm. Quá khứ tình cảm chưa khép lại giữa ba người trỗi dậy, buộc họ phải đối diện với những tổn thương cũ."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Šnabždėk tyliai","runtime":0,"tagline":"","homepage":"","overview":"Kamila manė, kad viską kontroliuoja... bent jau taip jai atrodė, kol į jos gyvenimą vėl neįsiveržė du broliai, sujaukę visą jos pasaulį. Prieš septynerius metus vienas iš jų padovanojo jai pirmąjį bučinį, o kitas visada ją saugojo. Dabar praeities jausmai ir paslaptys grįžta, versdami ją iš naujo permąstyti savo širdies pasirinkimus. Ši istorija alsuoja aistra, neišsakytomis tiesomis ir sudėtingais santykiais, kurie privers širdį plakti greičiau."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[{"id":8055,"adult":false,"title":"The Reader","video":false,"overview":"The story of Michael Berg, a German lawyer who, as a teenager in the late 1950s, had an affair with an older woman, Hanna, who then disappeared only to resurface years later as one of the defendants in a war crimes trial stemming from her actions as a concentration camp guard late in the war. He alone realizes that Hanna is illiterate and may be concealing that fact at the expense of her freedom.","genre_ids":[18,10749],"popularity":3.1528,"vote_count":3329,"poster_path":"/r0WURbmnhgKeBpHcpDULBgRedQM.jpg","release_date":"2008-12-10","vote_average":7.466,"backdrop_path":"/waMGsUEoHfYj3A1uRMUUgpBa71d.jpg","original_title":"The Reader","original_language":"en"},{"id":8067,"adult":false,"title":"A Life Less Ordinary","video":false,"overview":"A couple of angels, O'Reilly and Jackson, are sent to Earth to make sure that their next supervised love-connection succeeds. They follow Celine, a spoiled rich girl who has just accidentally shot a suitor and, due to a misunderstanding, is kidnapped by janitor Robert. Although Celine quickly frees herself, she stays with Robert for thrills. O'Reilly and Jackson pursue, hoping to unite the prospective lovers.","genre_ids":[14,35,10749],"popularity":1.015,"vote_count":483,"poster_path":"/tk7WNEwLZepFU2yPIIkRuQOO0Q9.jpg","release_date":"1997-10-24","vote_average":6.127,"backdrop_path":"/78fqm4OGHe4a1Sl1WhX12pV8Ocr.jpg","original_title":"A Life Less Ordinary","original_language":"en"},{"id":470691,"adult":false,"title":"Esmeralda","video":false,"overview":"It was the first film version of the Hunchback of Notre Dame.","genre_ids":[18],"popularity":1.8091,"vote_count":1,"poster_path":"/yPohMvllKNZoDNd7ODCsBsXkWZM.jpg","release_date":"1905-12-01","vote_average":3,"backdrop_path":null,"original_title":"Esmeralda","original_language":"fr"},{"id":277296,"adult":false,"title":"Vice and Virtue","video":false,"overview":"1944 : Occupied France. Juliette (Vice) is Wehrmacht General Bamberg's mistress and enjoys a privileged life. Her younger sister  Justine (Virtue) is about to marry Jean who is in the Resistance and come to Juliette for help. Both sisters end up at \"la Commanderie\", where Juliette becomes SS Colonel Schonberg's mistress and Justine is detained with other pretty girls who must satisfy the sexual needs of high-ranking nazi officials. Inspired by \"Justine ou les infortunes de la vertu\" by the marquis de Sade","genre_ids":[18,35],"popularity":0.1858,"vote_count":14,"poster_path":"/4s6aUGjsjP3FkiC98HzWmXvA0FR.jpg","release_date":"1963-03-01","vote_average":5.4,"backdrop_path":"/zK30zKTI5QqXK43GGO73NH3d72m.jpg","original_title":"Le Vice et la Vertu","original_language":"fr"},{"id":8073,"adult":false,"title":"Band of Outsiders","video":false,"overview":"Cinephile slackers Franz and Arthur spend their days mimicking the antiheroes of Hollywood noirs and Westerns while pursuing the lovely Odile. The misfit trio upends convention at every turn, be it through choreographed dances in cafés or frolicsome romps through the Louvre. Eventually, their romantic view of outlaws pushes them to plan their own heist, but their inexperience may send them out in a blaze of glory -- which could be just what they want.","genre_ids":[80,18,35],"popularity":2.1895,"vote_count":597,"poster_path":"/9oqyj79xmcypxLajJdefOtrYx64.jpg","release_date":"1964-08-05","vote_average":7.487,"backdrop_path":"/kKsy8sCjfOtfHPBT2i8z13bIRij.jpg","original_title":"Bande à part","original_language":"fr"},{"id":8092,"adult":false,"title":"This Boy's Life","video":false,"overview":"When a son and mother move to Seattle in hopes for a better life, the mother meets a seemingly polite man. Things go south when the man turns out to be abusive, endangering their lives. As the mother struggles to maintain hope in an impossible situation, the son has plans to escape.","genre_ids":[18],"popularity":1.8552,"vote_count":1056,"poster_path":"/pRMSZfen1Cv1eqwDbtxCBpBqxnU.jpg","release_date":"1993-04-09","vote_average":7.125,"backdrop_path":"/6N6VUUR1gzbCkiGpQzvRREv3Od1.jpg","original_title":"This Boy's Life","original_language":"en"},{"id":661539,"adult":false,"title":"A Complete Unknown","video":false,"overview":"New York, early 1960s. Against the backdrop of a vibrant music scene and tumultuous cultural upheaval, an enigmatic 19-year-old from Minnesota arrives in the West Village with his guitar and revolutionary talent, destined to change the course of American music.","genre_ids":[18,10402],"popularity":5.1723,"vote_count":1369,"poster_path":"/llWl3GtNoXosbvYboelmoT459NM.jpg","release_date":"2024-12-25","vote_average":7.081,"backdrop_path":"/kcCy5tKTe6WepVQ6SQaSewpmoCj.jpg","original_title":"A Complete Unknown","original_language":"en"},{"id":277509,"adult":false,"title":"Miracle in Four Days","video":false,"overview":"Dvorak's Symphony No. 9, \"From the New World\" wafts through a hospice recreation room. Sitting at the grand piano is a young girl, Chiori, with a prodigious ability to play any piece of music after one hearing. Keisuke Kisaragi whose career was abruptly cut short when he jumped in front of a bullet fired by a crazed gunman. The nerves in one hand were severed but he saved the life of Chiori. The tragic incident takes the lives of Chiori's parents, however, and Keisuke becomes her guardian. Not long after their return to Japan, Keisuke discovers Chiori's musical gift.","genre_ids":[10749],"popularity":0.4078,"vote_count":0,"poster_path":"/isw3Fi8hG6U7D53KidUT1apM9VV.jpg","release_date":"2005-06-04","vote_average":0,"backdrop_path":"/hy9JsbY4skGKK5Ofs6GhgbprjMM.jpg","original_title":"四日間の奇跡","original_language":"ja"},{"id":277547,"adult":false,"title":"Playing It Cool","video":false,"overview":"A young man meets and instantly falls in love with an engaged woman.","genre_ids":[35,10749],"popularity":2.7686,"vote_count":800,"poster_path":"/96htqghZlKctNJqDLo2DuC9PEap.jpg","release_date":"2014-09-26","vote_average":5.843,"backdrop_path":"/xiv9qW6hv5VMhxkPOEGnXKuowTo.jpg","original_title":"Playing It Cool","original_language":"en"},{"id":8289,"adult":false,"title":"Gorky Park","video":false,"overview":"Police Inspector Renko tries to solve the case of three bodies found in Moscow's Gorky Park but finds his attempts to solve the crime impeded by his superiors. Working on his own, Renko seeks out more information and stumbles across a conspiracy involving the highest levels of the government.","genre_ids":[53,80,18,9648],"popularity":1.315,"vote_count":334,"poster_path":"/xQFH7XlMk8pLPDzK5XVEj5McsRm.jpg","release_date":"1983-12-15","vote_average":6.323,"backdrop_path":"/dO8qUkabhQwBy8lPGawtvWQkdKd.jpg","original_title":"Gorky Park","original_language":"en"},{"id":8326,"adult":false,"title":"Holes","video":false,"overview":"After being wrongfully convicted for stealing a pair of shoes, Stanley Yelnats is sent away to Camp Green Lake, a boys detention facility where inmates are forced to dig holes all day in the hot desert sun as a form of character building. But Stanley and the other boys start to unravel a mystery, linked with the camps tough-as-nails warden —and possibly Stanley’s family itself.","genre_ids":[12,10751,18,35],"popularity":3.73,"vote_count":1509,"poster_path":"/o2Dm2mcE1qW8vT0bpsJO5OMBbqa.jpg","release_date":"2003-04-18","vote_average":6.895,"backdrop_path":"/cVMK2k0Wbs8DV3IK5sS4ziVenrI.jpg","original_title":"Holes","original_language":"en"},{"id":8619,"adult":false,"title":"Master and Commander: The Far Side of the World","video":false,"overview":"After an abrupt and violent encounter with a French warship inflicts severe damage upon his ship, a captain of the British Royal Navy begins a chase over two oceans to capture or destroy the enemy, though he must weigh his commitment to duty and ferocious pursuit of glory against the safety of his devoted crew, including the ship's thoughtful surgeon, his best friend.","genre_ids":[12,18,10752],"popularity":4.3795,"vote_count":3438,"poster_path":"/s1cVTQEZYn4nSjZLnFbzLP0j8y2.jpg","release_date":"2003-11-14","vote_average":7.181,"backdrop_path":"/zMHyNxNt4zhL939XX8QLBW3gWfu.jpg","original_title":"Master and Commander: The Far Side of the World","original_language":"en"},{"id":8649,"adult":false,"title":"Bringing Out the Dead","video":false,"overview":"Once called \"Father Frank\" for his efforts to rescue lives, Frank Pierce sees the ghosts of those he failed to save around every turn. He has tried everything he can to get fired, calling in sick, delaying taking calls where he might have to face one more victim he couldn't help, yet cannot quit the job on his own.","genre_ids":[18],"popularity":3.0113,"vote_count":1191,"poster_path":"/gE2Q8mL0m0EA6HakRyc92uzSPJn.jpg","release_date":"1999-10-22","vote_average":6.607,"backdrop_path":"/A1V1suhllQJ1CTrKpCulcM7mjyj.jpg","original_title":"Bringing Out the Dead","original_language":"en"},{"id":8668,"adult":false,"title":"So long, my heart!","video":false,"overview":"\"It's great that we now have a man on the ward... I always say that having a man like that on the staff works wonders!\" says nursing manager Petra Opels during her welcome meeting with her new employee Holger. The charming commitment-phobe has actually come to southern Germany from Berlin to escape his unresolved relationship issues. Instead, however, he once again brings a lot of turmoil to the fragile emotional lives of two women: Barbara, who works as a kitchen assistant in the same nursing home, has chosen Holger as a remedy for her loneliness. However, the tender love story is immediately thrown into turmoil when Holger soon finds himself attracted to his boss, Petra Opels.","genre_ids":[35,18],"popularity":0.1428,"vote_count":0,"poster_path":"/11Dy0G9tHEIRorkygKoJxPCUKrR.jpg","release_date":"2007-03-22","vote_average":0,"backdrop_path":null,"original_title":"Wir werden uns wiederseh'n","original_language":"en"},{"id":8680,"adult":false,"title":"The Shell Seekers","video":false,"overview":"Penelope Keeling, a sixty-four-year-old daughter of a famous artist, reflects on her life, and the fate and choices that defined it, when she arrives in the Mediterranean to stay with her headstrong daughter. Shifting through time, and falling into place like the pieces of a jigsaw, the truth of Penelope's rich, heartbreaking and surprising life unfolds.","genre_ids":[18,10749],"popularity":0.384,"vote_count":7,"poster_path":"/y7oxk0TY47vpJ1v2kcnYak0GKkX.jpg","release_date":"2007-10-18","vote_average":6.9,"backdrop_path":"/3OqHYx2QlUQxbXx6TsCAenICQd7.jpg","original_title":"The Shell Seekers","original_language":"en"},{"id":661475,"adult":false,"title":"Apinan vuosi","video":false,"overview":"A young student seeks direction in his life to counterbalance the studies through female adventures.","genre_ids":[18,35],"popularity":0.3868,"vote_count":2,"poster_path":"/2OnmxCt66lXG1MuSky901gwGruq.jpg","release_date":"1983-11-11","vote_average":7,"backdrop_path":"/7XvomNV2M9UqZEa87IRk69F441R.jpg","original_title":"Apinan vuosi","original_language":"fi"},{"id":8417,"adult":false,"title":"Süss, the Jew","video":false,"overview":"Nazi historical drama about Duke Karl Alexander of Württemberg and his treasurer Süß Oppenheimer.","genre_ids":[18,36],"popularity":0.3165,"vote_count":45,"poster_path":"/3fN1p4OY7Mi0zXQqMJvCdhRwEYs.jpg","release_date":"1940-09-24","vote_average":4.3,"backdrop_path":"/4msV23h4lRFXQoOUUL8Oc0XTcxt.jpg","original_title":"Jud Süß","original_language":"de"},{"id":8434,"adult":false,"title":"Summer Things","video":false,"overview":"Two couple of friends, one very rich, the other almost homeless, decide to go on Holiday. Julie, a single mother, joins them too. Once at seaside, it starts a complicate love cross among them that will involve also a transsexual, a jealous brother, a Latin Lover and another nervous stressed couple. Not to mention about the daughter of one of them that is secretly in Chicago with one of her father's employees... At the end of the summer, all of them will join the same party...","genre_ids":[35,18,10749],"popularity":0.5336,"vote_count":102,"poster_path":"/laV4Xo5O1COZefAFPJLFZ28pkYS.jpg","release_date":"2002-03-04","vote_average":5.809,"backdrop_path":"/azkp4brPsmzJiyKw5ExkPDrVpWA.jpg","original_title":"Embrassez qui vous voudrez","original_language":"fr"},{"id":277352,"adult":false,"title":"The Passionate Adventure","video":false,"overview":"A rich man leaves his wife, poses as a coster, and saves a factory girl from a crook.","genre_ids":[18],"popularity":0.133,"vote_count":1,"poster_path":"/h1PZ9Wk4336u4vYcJup6CJtERt7.jpg","release_date":"1924-07-01","vote_average":6,"backdrop_path":"/e5C3lPya6prhtbXzMw1N0jgakc2.jpg","original_title":"The Passionate Adventure","original_language":"en"},{"id":277364,"adult":false,"title":"Promise at Dawn","video":false,"overview":"A single mother raises her son in impossible circumstances first in Leningrad, then Krakow, and then France, and is over-ambitious about him but never gives in.","genre_ids":[18],"popularity":0.1868,"vote_count":9,"poster_path":"/olkNCkEhhUiRuwMt6hcwxuchGf8.jpg","release_date":"1970-11-25","vote_average":5.3,"backdrop_path":"/symqYH29cghJJ9QlV4uHtUi5W51.jpg","original_title":"Promise at Dawn","original_language":"en"}],"external_ids":{"imdb_id":"tt34434461","twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148446,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,