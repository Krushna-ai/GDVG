5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Cute But Ordinary\",\"description\":\"The youngest daughter of a rich man has been raped by five black men in the slums of Rio de Janeiro, and her father arranges her marriage to one of his employees in order to save the family’s honor.\",\"image\":\"https://image.tmdb.org/t/p/w500/4YXVxQHv4XSp1hE3Dsx2wIiuwTy.jpg\",\"datePublished\":\"1981-03-12\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"BR\",\"inLanguage\":\"pt\",\"genre\":[\"Drama\",\"Thriller\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.4,\"bestRating\":10,\"ratingCount\":24}}"}}],["$","$L10",null,{"initialDrama":{"id":"f8ab40cc-973f-4f02-a577-9c93fc89dc5f","tmdb_id":187826,"imdb_id":"tt0132891","content_type":"movie","title":"Cute But Ordinary","original_title":"Bonitinha mas Ordinária ou Otto Lara Rezende","overview":"The youngest daughter of a rich man has been raped by five black men in the slums of Rio de Janeiro, and her father arranges her marriage to one of his employees in order to save the family’s honor.","poster_path":"/4YXVxQHv4XSp1hE3Dsx2wIiuwTy.jpg","backdrop_path":"/xESushLqXM6gat9e0nWmhWXvqWP.jpg","release_date":"1981-03-12","first_air_date":null,"status":"published","original_language":"pt","origin_country":["BR"],"genres":[{"id":18,"name":"Drama"},{"id":53,"name":"Thriller"},"drama film"],"popularity":4.7706,"vote_average":4.4,"vote_count":24,"runtime":105,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-26T01:35:22.394718+00:00","updated_at":"2026-02-26T01:35:22.232+00:00","tagline":"She's only 17 and she only knows how to love in a weird way","homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":81446,"name":"Sincrocine Produções Cinematográficas","logo_path":"/7uxwAYxTrPSy1pKlmklK73qde65.png","origin_country":"BR"}],"production_countries":[{"name":"Brazil","iso_3166_1":"BR"}],"spoken_languages":[{"name":"Português","iso_639_1":"pt","english_name":"Portuguese"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[],"alternative_titles":[{"type":"","title":"Cute, But Ordinary","iso_3166_1":"US"}],"videos":[],"watch_providers":{"results":{}},"wikidata_id":"Q9661482","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-26T01:35:22.394718+00:00","region":null,"main_poster":null,"images":{"logos":[{"width":1575,"height":184,"file_path":"/5LitMWicAkkktwLmtphY0VClRi3.png","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":8.56,"vote_average":0}],"posters":[{"width":600,"height":900,"file_path":"/4YXVxQHv4XSp1hE3Dsx2wIiuwTy.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":2,"aspect_ratio":0.667,"vote_average":3.334},{"width":500,"height":750,"file_path":"/l0BUnhlQSrrpnhYXOwLtKYM4Oh8.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":1,"aspect_ratio":0.667,"vote_average":0.166},{"width":504,"height":750,"file_path":"/iLXbWBkUA9XhJzTQOEGFUDtr87a.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":1,"aspect_ratio":0.672,"vote_average":0.166}],"backdrops":[{"width":1280,"height":720,"file_path":"/xESushLqXM6gat9e0nWmhWXvqWP.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/d8LuaZ3SPmP5FBYJdxoxDUzKcCh.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1600,"height":900,"file_path":"/jGKBrmdy4qiuuCL7AqksSgqopx.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/3LgG1ABhIlV8mjxzf3giaqb9d1S.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/owIQHoQysQjxYstl8zelIZoqEMR.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:36:54.784+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":85,"tagline":"\"O mineiro só é solidário no câncer\"","homepage":"","overview":"Edgard é um rapaz de Minas Gerais de origem bastante humilde, fato esse que o constrange. Procurado por Peixoto, genro do milionário Werneck, dono da firma onde Edgard é contínuo, ele recebe a proposta de se casar com Maria Cecília, filha de Werneck, de 17 anos que fora currada por cinco negros. Pelo dinheiro, Edgard aceita, mas tem dúvidas por gostar de Ritinha, sua vizinha. Já com o casamento acertado, Edgard e Ritinha vão despedir-se num cemitério, onde ela conta o que faz para conseguir sustentar a mãe louca e as três irmãs. Toda a trama gira em torno das hesitações de Edgard, até sua escolha final."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Cute But Ordinary","runtime":105,"tagline":"She's only 17 and she only knows how to love in a weird way","homepage":"","overview":"The youngest daughter of a rich man has been raped by five black men in the slums of Rio de Janeiro, and her father arranges her marriage to one of his employees in order to save the family’s honor."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":106,"tagline":"","homepage":"","overview":"Edgard é um rapaz de Minas Gerais de origem bastante humilde, fato esse que o constrange. Procurado por Peixoto, genro do milionário Werneck, dono da firma onde Edgard é contínuo, ele recebe a proposta de se casar com Maria Cecília, filha de Werneck, de 17 anos que fora currada por cinco negros. Pelo dinheiro, Edgard aceita, mas tem dúvidas por gostar de Ritinha, sua vizinha. Já com o casamento acertado, Edgard e Ritinha vão despedir-se num cemitério, onde ela conta o que faz para conseguir sustentar a mãe louca e as três irmãs. Toda a trama gira em torno das hesitações de Edgard, até sua escolha final."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"可爱但很普通","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"De jongste dochter van een rijke man is verkracht door vijf zwarte mannen in de sloppenwijken van Rio de Janeiro, en haar vader regelt haar huwelijk met een van zijn werknemers om de eer van de familie te redden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Красивая, но обыкновенная","runtime":85,"tagline":"","homepage":"","overview":"Марию Сесилию, 17-летнюю девственницу, дочь богатого и могущественного доктора Вернека, изнасиловали пятеро чернокожих. Ее семья решает, что Мария Сесилия должна выйти замуж, и Вернек приказывает своему подчиненному Пейшоту найти жениха среди сотрудников его компании. Пейшоту выбирает Эдгарда, и делает ему необычное предложение: если он женится на Марии Сесилии, в качестве приданого он получит огромную сумму..."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"可愛但很普通","runtime":0,"tagline":"","homepage":"","overview":""},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":1361622,"adult":false,"title":"Honeymoon Crasher","video":false,"overview":"When his fiancée dumps him at the altar for her ex, a young man is left with no alternative but to go on his romantic honeymoon with his mother.","genre_ids":[35],"media_type":"movie","popularity":1.5371,"vote_count":156,"poster_path":"/7mrmqaoFKx61MzyYzaI4sO6VLuc.jpg","release_date":"2025-02-11","vote_average":5.615,"backdrop_path":"/pz0wQh69Fc88xJgEBGCnr8RHmQj.jpg","original_title":"Lune de miel avec ma mère","original_language":"fr"},{"id":25736,"adult":false,"title":"The Postman Always Rings Twice","video":false,"overview":"A married woman and a drifter fall in love, then plot to murder her husband.","genre_ids":[18,10749,80,53],"media_type":"movie","popularity":0.937,"vote_count":368,"poster_path":"/3qdX948vUXi4q8raUUOHHlbP9q8.jpg","release_date":"1946-05-02","vote_average":7.038,"backdrop_path":"/cXkA9CqkZyWufwPE0GSVj1SFwUW.jpg","original_title":"The Postman Always Rings Twice","original_language":"en"},{"id":52941,"adult":false,"title":"I, Monster","video":false,"overview":"Christopher Lee stars in this Amicus production of “Dr. Jekyll & Mr. Hyde” where the names have been changed to Dr. Marlowe and Mr. Blake. Lee as Dr. Marlowe experiments with intravenous drugs that are suppose to release inner inhibitions. So comes forth Mr. Blake (also Lee) who gets more monstrous with each transformation. Peter Cushing plays his friend and colleague, Dr. Utterson.","genre_ids":[27,878],"media_type":"movie","popularity":3.3178,"vote_count":54,"poster_path":"/7MMjLTD68UiRbSM9bVy8HhYY3uB.jpg","release_date":"1971-11-01","vote_average":5.387,"backdrop_path":"/a8X2CsKyiZabDbmcEtrQn5x9Av6.jpg","original_title":"I, Monster","original_language":"en"},{"id":726200,"adult":false,"title":"Guerra da Tapioca","video":true,"overview":"Solange is heartbroken to discover that Manuel, her fiancé and work partner, no longer wants to marry her. Not knowing how to go on with her life, she ends up opening a tapioca stand, which competes with Manuel's. The two develop a rivalry that gets worse when Manuel feels jealous when he sees Solange involved with another man.","genre_ids":[35,10770],"media_type":"movie","popularity":0.0858,"vote_count":4,"poster_path":"/oOWif0MEhzP8ktzbyuuYOzaBcul.jpg","release_date":"2017-12-23","vote_average":7.2,"backdrop_path":"/25Z7gQhdieLy3sRb2btANFqtSgX.jpg","original_title":"Guerra da Tapioca","original_language":"pt"},{"id":273481,"adult":false,"title":"Sicario","video":false,"overview":"An idealistic FBI agent is enlisted by a government task force to aid in the escalating war against drugs at the border area between the U.S. and Mexico.","genre_ids":[28,80,53],"media_type":"movie","popularity":12.4523,"vote_count":9350,"poster_path":"/lz8vNyXeidqqOdJW9ZjnDAMb5Vr.jpg","release_date":"2015-09-17","vote_average":7.416,"backdrop_path":"/meeileDF37uB8ykIs4iFb713ABO.jpg","original_title":"Sicario","original_language":"en"},{"id":276907,"adult":false,"title":"Legend","video":false,"overview":"Suave, charming and volatile, Reggie Kray and his unstable twin brother Ronnie start to leave their mark on the London underworld in the 1960s. Using violence to get what they want, the siblings orchestrate robberies and murders while running nightclubs and protection rackets. With police Detective Leonard \"Nipper\" Read hot on their heels, the brothers continue their rapid rise to power and achieve tabloid notoriety.","genre_ids":[80,53],"media_type":"movie","popularity":5.8415,"vote_count":4186,"poster_path":"/4shf5Alq4KWCKqrAAQe0JGJHYp5.jpg","release_date":"2015-09-09","vote_average":7.058,"backdrop_path":"/v8zOcynvSd6IW3FzZrvst2HJ53s.jpg","original_title":"Legend","original_language":"en"},{"id":245700,"adult":false,"title":"Mr. Turner","video":false,"overview":"Eccentric British painter J.M.W. Turner  lives his last 25 years with gusto and secretly becomes involved with a seaside landlady, while his faithful housekeeper bears an unrequited love for him.","genre_ids":[36,18],"media_type":"movie","popularity":1.7585,"vote_count":575,"poster_path":"/rnVhl1PFSOoW5c6UhZJZt5TV98p.jpg","release_date":"2014-10-31","vote_average":6.538,"backdrop_path":"/74IaLYwgko2nTLj8Gz9ukQ4RIvC.jpg","original_title":"Mr. Turner","original_language":"en"},{"id":666277,"adult":false,"title":"Past Lives","video":false,"overview":"After decades apart, childhood friends Nora and Hae Sung are reunited in New York for one fateful weekend as they confront notions of destiny, love, and the choices that make a life.","genre_ids":[18,10749],"media_type":"movie","popularity":8.1491,"vote_count":2206,"poster_path":"/k3waqVXSnvCZWfJYNtdamTgTtTA.jpg","release_date":"2023-06-02","vote_average":7.718,"backdrop_path":"/7HR38hMBl23lf38MAN63y4pKsHz.jpg","original_title":"Past Lives","original_language":"en"},{"id":217316,"adult":false,"title":"1","video":false,"overview":"Set in the golden era of Grand Prix Racing '1' tells the story of a generation of charismatic drivers who raced on the edge, risking their lives during Formula 1's deadliest period, and the men who stood up and changed the sport forever.","genre_ids":[99],"media_type":"movie","popularity":1.1088,"vote_count":363,"poster_path":"/nIHvkb3M1B9TnaiaABsfTzmFMYP.jpg","release_date":"2013-09-30","vote_average":6.613,"backdrop_path":"/nPqDbXYaMhR2XKQ9IU8bkX7YgO7.jpg","original_title":"1","original_language":"en"},{"id":680,"adult":false,"title":"Pulp Fiction","video":false,"overview":"A burger-loving hit man, his philosophical partner, a drug-addled gangster's moll and a washed-up boxer converge in this sprawling, comedic crime caper. Their adventures unfurl in three stories that ingeniously trip back and forth in time.","genre_ids":[53,80,35],"media_type":"movie","popularity":22.9382,"vote_count":29739,"poster_path":"/vQWk5YBFWF4bZaofAbv0tShwBvQ.jpg","release_date":"1994-09-10","vote_average":8.486,"backdrop_path":"/96hiUXEuYsu4tcnvlaY8tEMFM0m.jpg","original_title":"Pulp Fiction","original_language":"en"},{"id":376867,"adult":false,"title":"Moonlight","video":false,"overview":"The tender, heartbreaking story of a young man’s struggle to find himself, told across three defining chapters in his life as he experiences the ecstasy, pain, and beauty of falling in love, while grappling with his own sexuality.","genre_ids":[18],"media_type":"movie","popularity":6.9546,"vote_count":7424,"poster_path":"/qLnfEmPrDjJfPyyddLJPkXmshkp.jpg","release_date":"2016-10-21","vote_average":7.359,"backdrop_path":"/jm1oD3eB08LImSwL1LrzF9AJQ5b.jpg","original_title":"Moonlight","original_language":"en"},{"id":265228,"adult":false,"title":"Timbuktu","video":false,"overview":"Just outside of the Malian city of Timbuktu, now occupied by militant Islamic rebels who impose the Sharia on civilians and inconvenience their daily life, a cattleman kills a fisherman.","genre_ids":[18,10752],"media_type":"movie","popularity":0.8677,"vote_count":507,"poster_path":"/tCpHpn8msgonS9HVDMkrcSZh4an.jpg","release_date":"2014-12-10","vote_average":6.965,"backdrop_path":"/3cQO2X0vRpMYwNhoZURSCxUpCPh.jpg","original_title":"Timbuktu","original_language":"fr"},{"id":345920,"adult":false,"title":"Collateral Beauty","video":false,"overview":"Retreating from life after a tragedy, a man questions the universe by writing to Love, Time and Death. Receiving unexpected answers, he begins to see how these things interlock and how even loss can reveal moments of meaning and beauty.","genre_ids":[18,10749],"media_type":"movie","popularity":3.8844,"vote_count":5510,"poster_path":"/4vfqosgik5pLb32RpskYifp8PWJ.jpg","release_date":"2016-12-15","vote_average":7.218,"backdrop_path":"/iovi35nPfjbYTw2gRo7uImWblRU.jpg","original_title":"Collateral Beauty","original_language":"en"},{"id":293660,"adult":false,"title":"Deadpool","video":false,"overview":"The origin story of former Special Forces operative turned mercenary Wade Wilson, who, after being subjected to a rogue experiment that leaves him with accelerated healing powers, adopts the alter ego Deadpool. Armed with his new abilities and a dark, twisted sense of humor, Deadpool hunts down the man who nearly destroyed his life.","genre_ids":[28,12,35],"media_type":"movie","popularity":13.263,"vote_count":32391,"poster_path":"/3E53WEZJqP6aM84D8CckXx4pIHw.jpg","release_date":"2016-02-09","vote_average":7.622,"backdrop_path":"/en971MEXui9diirXlogOrPKmsEn.jpg","original_title":"Deadpool","original_language":"en"},{"id":551332,"adult":false,"title":"The Two Popes","video":false,"overview":"Frustrated with the direction of the church, Cardinal Bergoglio requests permission to retire in 2012 from Pope Benedict. Instead, facing scandal and self-doubt, the introspective Pope Benedict summons his harshest critic and future successor to Rome to reveal a secret that would shake the foundations of the Catholic Church.","genre_ids":[18,36],"media_type":"movie","popularity":3.043,"vote_count":3098,"poster_path":"/4d4mTSfDIFIbUbMLUfaKodvxYXA.jpg","release_date":"2019-11-27","vote_average":7.491,"backdrop_path":"/bOPessdyd0dChHy70FM8Om7CgDg.jpg","original_title":"The Two Popes","original_language":"en"},{"id":1106739,"adult":false,"title":"Juror #2","video":false,"overview":"While serving as a juror in a high profile murder trial, family man Justin Kemp finds himself struggling with a serious moral dilemma…one he could use to sway the jury verdict and potentially convict—or free—the accused killer.","genre_ids":[18,53],"media_type":"movie","popularity":5.3459,"vote_count":2361,"poster_path":"/ugQkpGajKFQ8eyOEhGheR0HfWQ.jpg","release_date":"2024-10-30","vote_average":6.878,"backdrop_path":"/9Qq8InnodUYs8zdam8Zj967i6RO.jpg","original_title":"Juror #2","original_language":"en"},{"id":157336,"adult":false,"title":"Interstellar","video":false,"overview":"The adventures of a group of explorers who make use of a newly discovered wormhole to surpass the limitations on human space travel and conquer the vast distances involved in an interstellar voyage.","genre_ids":[12,18,878],"media_type":"movie","popularity":44.594,"vote_count":38962,"poster_path":"/gEU2QniE6E77NI6lCU6MxlNBvIx.jpg","release_date":"2014-11-05","vote_average":8.467,"backdrop_path":"/2ssWTSVklAEc98frZUQhgtGHx7s.jpg","original_title":"Interstellar","original_language":"en"},{"id":261023,"adult":false,"title":"Black Mass","video":false,"overview":"The true story of Whitey Bulger, the brother of a state senator and the most infamous violent criminal in the history of South Boston, who became an FBI informant to take down a Mafia family invading his turf.","genre_ids":[18,80,36],"media_type":"movie","popularity":4.9465,"vote_count":3535,"poster_path":"/zfwciv4LIJkNQsfuhYGv0Nkiweg.jpg","release_date":"2015-09-17","vote_average":6.528,"backdrop_path":"/mK4J2Qk4S4UQGOeMqsgei9DyPwW.jpg","original_title":"Black Mass","original_language":"en"},{"id":440021,"adult":false,"title":"Happy Death Day","video":false,"overview":"Caught in a bizarre and terrifying time warp, college student Tree finds herself repeatedly reliving the day of her murder, ultimately realizing that she must identify the killer and the reason for her death before her chances of survival run out.","genre_ids":[35,27,9648],"media_type":"movie","popularity":4.3862,"vote_count":6485,"poster_path":"/cTaEIUYTt52ooq9quVbAQ7NpGwo.jpg","release_date":"2017-10-12","vote_average":6.7,"backdrop_path":"/9XSEL3EMC2D8k4UcYBn8etgRxPg.jpg","original_title":"Happy Death Day","original_language":"en"},{"id":348350,"adult":false,"title":"Solo: A Star Wars Story","video":false,"overview":"Through a series of daring escapades deep within a dark and dangerous criminal underworld, Han Solo meets his mighty future copilot Chewbacca and encounters the notorious gambler Lando Calrissian.","genre_ids":[878,12,28],"media_type":"movie","popularity":5.7051,"vote_count":9119,"poster_path":"/4oD6VEccFkorEBTEDXtpLAaz0Rl.jpg","release_date":"2018-05-15","vote_average":6.557,"backdrop_path":"/7LZ0K4FsALrt7OeNIGOVLNuKQRU.jpg","original_title":"Solo: A Star Wars Story","original_language":"en"}],"similar_content":[],"external_ids":{"imdb_id":"tt0132891","twitter_id":null,"facebook_id":null,"wikidata_id":"Q9661482","instagram_id":null,"mydramalist_id":"265958"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148730,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"