9:{"metadata":[["$","title","0",{"children":"Aces Go Places III: Our Man from Bond Street | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"While vacationing in Paris, King Kong is kidnapped by a British agent called James, who seeks to recover one of the stolen crown jewels, the Star of Fortune, supposedly at the request of the Queen of England. The jewel is hidden at the Hong Kong Police Headquarters and Kong will have to steal the jewel without his partner-in-crime, Detective Albert 'Baldy' Au, finding out. When James' devious intentions are revealed and Baldy and his wife, Supt. Nancy Ho, discover Kong's heist, Kong finds himself at a crossroad."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/103710/aces-go-places-iii-our-man-from-bond-street"}],["$","meta","5",{"property":"og:title","content":"Aces Go Places III: Our Man from Bond Street"}],["$","meta","6",{"property":"og:description","content":"While vacationing in Paris, King Kong is kidnapped by a British agent called James, who seeks to recover one of the stolen crown jewels, the Star of Fortune, supposedly at the request of the Queen of England. The jewel is hidden at the Hong Kong Police Headquarters and Kong will have to steal the jewel without his partner-in-crime, Detective Albert 'Baldy' Au, finding out. When James' devious intentions are revealed and Baldy and his wife, Supt. Nancy Ho, discover Kong's heist, Kong finds himself at a crossroad."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/103710/aces-go-places-iii-our-man-from-bond-street"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/suYE32h1GsqmZhCPVhJuFxUgy7Q.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","m