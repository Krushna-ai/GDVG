5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Aces Go Places III: Our Man from Bond Street\",\"description\":\"While vacationing in Paris, King Kong is kidnapped by a British agent called James, who seeks to recover one of the stolen crown jewels, the Star of Fortune, supposedly at the request of the Queen of England. The jewel is hidden at the Hong Kong Police Headquarters and Kong will have to steal the jewel without his partner-in-crime, Detective Albert 'Baldy' Au, finding out. When James' devious intentions are revealed and Baldy and his wife, Supt. Nancy Ho, discover Kong's heist, Kong finds himself at a crossroad.\",\"image\":\"https://image.tmdb.org/t/p/w500/suYE32h1GsqmZhCPVhJuFxUgy7Q.jpg\",\"datePublished\":\"1984-01-25\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"HK\",\"inLanguage\":\"cn\",\"genre\":[\"Action\",\"Comedy\",null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5.7,\"bestRating\":10,\"ratingCount\":44}}"}}],["$","$L10",null,{"initialDrama":{"id":"d617d84c-59f8-44c5-b77e-0ddc82511fe4","tmdb_id":2646,"imdb_id":"tt0088457","content_type":"movie","title":"Aces Go Places III: Our Man from Bond Street","original_title":"最佳拍檔III之女皇密令","overview":"While vacationing in Paris, King Kong is kidnapped by a British agent called James, who seeks to recover one of the stolen crown jewels, the Star of Fortune, supposedly at the request of the Queen of England. The jewel is hidden at the Hong Kong Police Headquarters and Kong will have to steal the jewel without his partner-in-crime, Detective Albert 'Baldy' Au, finding out. When James' devious intentions are revealed and Baldy and his wife, Supt. Nancy Ho, discover Kong's heist, Kong finds himself at a crossroad.","poster_path":"/suYE32h1GsqmZhCPVhJuFxUgy7Q.jpg","backdrop_path":"/jJYasNGPK2dPwk1iSOV4yiddfXH.jpg","release_date":"1984-01-25","first_air_date":null,"status"