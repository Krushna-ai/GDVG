cllRNY9v9e.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":832,"height":1248,"file_path":"/cGK8JlZYwoP7enoICiawXJ5vDz.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":832,"height":1248,"file_path":"/oFyRjz8OiVo9NteVNih2Tbibk4o.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/xzP2m0PqEsmBiNbRC6qW5zkrnRo.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1365,"height":2048,"file_path":"/h0zJFHsXlWrJ7Q3XYqovmLvQeEV.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1365,"height":2048,"file_path":"/qXDoFWZJBQFKbDYMSAPQBCQhdVu.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1365,"height":2048,"file_path":"/e80k8a9ZmuGynknXFBvUMLKyIQx.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":2048,"height":1152,"file_path":"/3RaVf9MWpB74kK8AtPJ7DJmfZNA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/41ep9kAEosmHFVxF9ik0HD4ff91.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:10:34.576+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"A Letter to My Youth","runtime":135,"tagline":"","homepage":"https://www.netflix.com/title/81737845","overview":"A rebellious teen and a reserved caretaker form an unlikely bond in an orphanage as they come to terms with their painful pasts."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Uma Carta à Minha Juventude","runtime":135,"tagline":"","homepage":"https://www.netflix.com/pt/title/81737845","overview":"Conta a história de um jovem rebelde que vive em um orfanato e de um monitor reservado que trabalham para superar traumas do passado. Após um primeiro encontro difícil, os dois desenvolvem uma amizade sincera e um vínculo profundo, onde as experiências da juventude se tornam o combustível para a cura na fase adulta. A narrativa, contada na perspectiva de Kefas (o jovem), explora memórias inesquecíveis durante sua visita à instituição anos depois."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Una carta a mi juventud","runtime":135,"tagline":"","homepage":"https://www.netflix.com/mx/title/81737845","overview":"Un adolescente rebelde y un reservado educador forjan un vínculo inesperado en un orfanato, mientras intentan pasar página y lidiar con su doloroso pasado."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Una carta a mi juventud","runtime":135,"tagline":"","homepage":"https://www.netflix.com/es/title/81737845","overview":"Un adolescente rebelde y un reservado educador forjan un vínculo inesperado en un orfanato, mientras intentan pasar página y lidiar con su doloroso pasado."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.netflix.com/it/title/81737845","overview":"Un adolescente ribelle e un educatore riservato instaurano un legame inaspettato in un orfanotrofio, cercando di fare i conti con il loro doloroso passato."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"若き日々への手紙","runtime":0,"tagline":"","homepage":"https://www.netflix.com/jp/title/81737845","overview":"孤児院で暮らす反抗的なティーンエイジャーと物静かな世話係。二人はそれぞれのつらい過去に向き合いながら、思いがけないきずなを育んでいく。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Lettre à ma jeunesse","runtime":135,"tagline":"","homepage":"https://www.netflix.com/fr/title/81737845","overview":"Dans un orphelinat, un adolescent rebelle et un responsable discret nouent un lien improbable tout en essayant d'accepter leurs passés douloureux."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.netflix.com/de/title/81737845","overview":"In einem Waisenhaus freunden sich ein rebellischer Teenager und ein zurückhaltender Hausmeister an, während sie mit ihrer schmerzlichen Vergangenheit ins Reine kommen."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.netflix.com/nl/title/81737845","overview":"Een rebelse tiener en een afstandelijke verzorger in een weeshuis krijgen een onverwachte band terwijl ze proberen hun leven weer op te pakken na pijnlijke ervaringen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.netflix.com/se/title/81737845","overview":"En rebellisk tonåring och den tystlåtna chefen på barnhemmet där han bor knyter oväntade vänskapsband medan de försöker hantera sina smärtsamma livshistorier."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"List do mojej młodości","runtime":0,"tagline":"","homepage":"https://www.netflix.com/pl/title/81737845","overview":"Zbuntowany nastolatek i powściągliwy opiekun w sierocińcu przywiązują się do siebie, próbując pogodzić się ze swoją bolesną przeszłością."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.netflix.com/id/title/81737845","overview":"Di sebuah panti asuhan, seorang remaja pemberontak dan pengurus pendiam tanpa diduga menjadi sahabat, saat mereka berusaha untuk berdamai dengan masa lalu penuh luka."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"Scrisoare tinereții mele","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ro/title/81737845","overview":"Un adolescent rebel și un îngrijitor rezervat leagă o prietenie neașteptată într-un orfelinat, încercând să-și vindece rănile trecutului."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Carta ao Meu Jovem Eu","runtime":0,"tagline":"","homepage":"https://www.netflix.com/pt/title/81737845","overview":"Num orfanato, um adolescente rebelde e o seu discreto cuidador criam uma amizade inesperada enquanto tentam superar velhas mágoas do passado."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"내 젊은 날에 보내는 편지","runtime":0,"tagline":"","homepage":"https://www.netflix.com/kr/title/81737845","overview":"어느 보육원. 관리인이 된 나이 지긋하고 과묵한 선생이 사고뭉치 반항아를 상대하다가 둘 사이에 우정이 생겨난다. 그러던 어느 날 관리인의 비극적인 과거를 알게 되는 소년. 닥쳐오는 파멸적 운명에서 관리인을 구하고자, 친구들과 함께 시간과의 싸움에 나선다. 그들은 각자의 고통스러운 과거를 받아들이는 과정에서 뜻밖의 유대를 맺게 된다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.netflix.com/no/title/81737845","overview":"En rebelsk tenåring og en reservert ansatt på et barnehjem knytter overraskende bånd mens de prøver å forsone seg med vanskelige fortider."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"致我的青春","runtime":135,"tagline":"有些话，只有未来的自己能听懂。","homepage":"","overview":"这是一个关于和解与疗愈的故事。主人公（由 Fedi Nuril 饰演）偶然发现了一封自己在多年前写给未来的信。这封信唤醒了他对青春时代的记忆，迫使他重新审视那些曾经被遗忘的梦想、错过的爱情以及至今未解的心结。在现在的他与过去的自己进行跨时空“对话”的过程中，他试图原谅当年的错误，并从回忆中汲取力量，去拥抱当下的生活。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Thư Gửi Tuổi Trẻ Của Tôi","runtime":0,"tagline":"","homepage":"","overview":"Một thiếu niên nổi loạn và một người quản lý trầm lặng tạo nên sợi dây gắn kết lạ thường tại mái ấm nọ khi cả hai thỏa hiệp với quá khứ đau thương."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"จดหมายถึงฉันในวัยเยาว์","runtime":0,"tagline":"","homepage":"","overview":"วัยรุ่นหัวขบถและผู้ดูแลที่เงียบขรึมสานความผูกพันโดยไม่คาดคิดในสถานเลี้ยงเด็กกำพร้า ขณะที่ทั้งคู่พยายามเดินหน้าต่อและทำใจยอมรับอดีตอันเจ็บปวดของตัวเอง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Çocukluğuma Bir Mektup","runtime":0,"tagline":"","homepage":"","overview":"Yeni gelen yetimhane müdürüyle hiç anlaşamayan asi genç, zamanla müdürle beklenmedik bir bağ kurar."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Писмо до младостта ми","runtime":0,"tagline":"","homepage":"","overview":"Бунтарски тийнейджър и сдържан настойник създават неочаквана връзка в сиропиталище, докато се примиряват с болезненото си минало."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"euskera","iso_639_1":"eu","iso_3166_1":"ES","english_name":"Basque"},{"data":{"title":"致我的青春","runtime":0,"tagline":"","homepage":"","overview":"叛逆的少年與拘謹的照顧者在孤兒院意外建立情誼，同時正視各自痛苦的過去。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"איגרת לנעורים","runtime":0,"tagline":"","homepage":"","overview":"נער מרדן ומטפל שקט, שכל אחד מהם מנסה להתמודד עם עברו הכואב, נפגשים בבית יתומים ורוקמים קשר מפתיע."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Писмо мојој младости","runtime":0,"tagline":"","homepage":"","overview":"Бунтовни тинејџер и резервисана неговатељица стварају необичну везу у сиротишту док се суочавају са својом болном прошлошћу."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"","runtime":135,"tagline":"","homepage":"","overview":"Vypráví příběh vzpurného mladého muže žijícího v sirotčinci a rezervovaného poradce, kteří se snaží překonat traumata z minulosti. Po těžkém prvním setkání mezi nimi vznikne upřímné přátelství a hluboké pouto, kde se zážitky z mládí stávají palivem pro uzdravení v dospělosti. Příběh, vyprávěný z pohledu mladého muže, zkoumá nezapomenutelné vzpomínky během jeho návštěvy ústavu o několik let později."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Moje pismo mladosti","runtime":135,"tagline":"","homepage":"","overview":"Priča o buntovnom mladiću koji živi u sirotištu i rezerviranom savjetniku koji rade na prevladavanju prošlih trauma. Nakon teškog prvog susreta, njih dvoje razvijaju iskreno prijateljstvo i duboku vezu, gdje iskustva njihove mladosti postaju gorivo za iscjeljenje u odrasloj dobi. Priča, ispričana iz Kefasove (mladićeve) perspektive, istražuje nezaboravne uspomene tijekom njegovog posjeta ustanovi godinama kasnije."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"ЛИСТ ДО МОЄЇ ЮНОСТІ","runtime":135,"tagline":"","homepage":"","overview":"Фільм розповідає історію бунтівного юнака, який живе в дитячому будинку, та стриманого психолога, які намагаються подолати минулі травми. Після складної першої зустрічі між ними зав'язується щира дружба та глибокий зв'язок, де досвід їхньої юності стає паливом для зцілення в дорослому віці. Оповідь, розказана з точки зору Кефаса (юнака), досліджує незабутні спогади під час його візиту до закладу через роки."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[{"id":14,"adult":false,"title":"American Beauty","video":false,"overview":"Lester Burnham, a depressed suburban father in a mid-life crisis, decides to turn his hectic life around after developing an infatuation with his daughter's attractive friend.","genre_ids":[18],"popularity":10.4774,"vote_count":12827,"poster_path":"/wby9315QzVKdW9BonAefg8jGTTb.jpg","release_date":"1999-09-15","vote_average":8.002,"backdrop_path":"/2ndw55F40IkALzWyjCCza3M6nqM.jpg","original_title":"American Beauty","original_language":"en"},{"id":858017,"adult":false,"title":"I Saw the TV Glow","video":false,"overview":"Teenager Owen is just trying to make it through life in the suburbs when his classmate Maddy introduces him to a mysterious TV show — a vision of a supernatural world beneath their own. In the pale glow of the television, Owen’s view of reality begins to crack.","genre_ids":[18,27],"popularity":3.8609,"vote_count":625,"poster_path":"/hS4GYkYpN1rfl4GIxyc02sCyfAj.jpg","release_date":"2024-05-03","vote_average":6.1,"backdrop_path":"/jKulL2hdp5S7dVbpoItAtdCyzXI.jpg","original_title":"I Saw the TV Glow","original_language":"en"},{"id":3036,"adult":false,"title":"Mary Shelley's Frankenstein","video":false,"overview":"Victor Frankenstein is a promising young doctor who, devastated by the death of his mother during childbirth, becomes obsessed with bringing the dead back to life. His experiments lead to the creation of a monster, which Frankenstein has put together with the remains of corpses. It's not long before Frankenstein regrets his actions.","genre_ids":[18,27,878,10749],"popularity":2.2574,"vote_count":1340,"poster_path":"/bOwCAQsZlEKrwhPi1ejY6BS8jpL.jpg","release_date":"1994-11-04","vote_average":6.445,"backdrop_path":"/qhZgRQB6ExVcbFXXGL3ISvshfJm.jpg","original_title":"Mary Shelley's Frankenstein","original_language":"en"},{"id":3176,"adult":false,"title":"Battle Royale","video":false,"overview":"In the future, the Japanese government captures a class of ninth-grade students and forces them to kill each other under the revolutionary \"Battle Royale\" act.","genre_ids":[18,53,28],"popularity":4.7403,"vote_count":3730,"poster_path":"/aLGKAQKgzWpJ6egyWzzC11jXBRJ.jpg","release_date":"2000-12-16","vote_average":7.3,"backdrop_path":"/amBvmIshdsSkOtvVIgxl7YSQ9Dg.jpg","original_title":"バトル・ロワイアル","original_language":"ja"},{"id":6404,"adult":false,"title":"Nosferatu the Vampyre","video":false,"overview":"A real estate agent leaves behind his beautiful wife to go to Transylvania to visit the mysterious Count Dracula and formalize the purchase of a property in Wismar.","genre_ids":[18,27],"popularity":2.4443,"vote_count":1055,"poster_path":"/jHKzGYwf7P34vz8MhJBTN6cnaYD.jpg","release_date":"1979-01-17","vote_average":7.3,"backdrop_path":"/uHudMff1vp2GDXqHD8QOA78QpNW.jpg","original_title":"Nosferatu - Phantom der Nacht","original_language":"de"},{"id":660637,"adult":false,"title":"Dance of the Forty One","video":false,"overview":"Mexico City, November 1901. The police raid a private home where a secret party is being held. Among those attending is the son-in-law of President Porfirio Díaz.","genre_ids":[18,36],"popularity":0.6169,"vote_count":220,"poster_path":"/jcSqwsEtT7wKfQ8oKaaulMMGUdS.jpg","release_date":"2020-11-19","vote_average":7.836,"backdrop_path":"/f4r44unFU6uS9bdlhm72htW2l2T.jpg","original_title":"El baile de los 41","original_language":"es"},{"id":276884,"adult":false,"title":"In the Absence of the Sun","video":false,"overview":"A tender, melancholic night is experienced through the eyes of three women as they struggle to find themselves in this ever-changing jungle of Jakarta.","genre_ids":[18,10749],"popularity":0.1825,"vote_count":10,"poster_path":"/lYVeatUtBde6pBCfgpqEsivejFy.jpg","release_date":"2014-06-19","vote_average":7.3,"backdrop_path":"/13znr9PAfHdCGHN6Svu4nObpoJa.jpg","original_title":"Selamat Pagi, Malam","original_language":"id"},{"id":7301,"adult":false,"title":"Lonesome Jim","video":false,"overview":"After failing to find success as a writer in New York City, Jim slinks back to his family's home in the Midwest to lick his wounds. But his visit is quickly complicated when his angst spreads to his brother, Tim, who promptly decides to drive his car straight into a tree. Under the shadow of his sibling's injurious actions, Jim strikes up an unlikely friendship with Anika, whose centered small-town wisdom gradually rubs off on him.","genre_ids":[35,18,10749],"popularity":0.6418,"vote_count":97,"poster_path":"/z5wh9kFxpqC6bKB7TUx7j6X7BOq.jpg","release_date":"2005-11-16","vote_average":6.036,"backdrop_path":"/qzUY5BlilSqg18glC6YzCePuDc0.jpg","original_title":"Lonesome Jim","original_language":"en"},{"id":606,"adult":false,"title":"Out of Africa","video":false,"overview":"Tells the life story of Danish author Karen Blixen, who at the beginning of the 20th century moved to Africa to build a new life for herself. The film is based on her 1937 autobiographical novel.","genre_ids":[36,10749,18],"popularity":2.3567,"vote_count":1504,"poster_path":"/6oMKqh08TfxmvnoFR4mm1wZB67P.jpg","release_date":"1985-12-20","vote_average":7.164,"backdrop_path":"/5hCGJLTuRlD5WoscKhVPHVnD4gz.jpg","original_title":"Out of Africa","original_language":"en"},{"id":618,"adult":false,"title":"The Birth of a Nation","video":false,"overview":"Two families, abolitionist Northerners the Stonemans and Southern landowners the Camerons, intertwine. When Confederate colonel Ben Cameron is captured in battle, nurse Elsie Stoneman petitions for his pardon. In Reconstruction-era South Carolina, Cameron founds the Ku Klux Klan, battling Elsie's congressman father and his African-American protégé, Silas Lynch.","genre_ids":[18,36,10752],"popularity":1.5808,"vote_count":578,"poster_path":"/f9MkgI1ObRVvJwWgJyWtRbgyWng.jpg","release_date":"1915-03-08","vote_average":5.949,"backdrop_path":"/4H4RAeeykpi0ijvu3wYgV346y06.jpg","original_title":"The Birth of a Nation","original_language":"en"},{"id":548,"adult":false,"title":"Rashomon","video":false,"overview":"Four people recount different versions of the story of a man's murder and the rape of his wife.","genre_ids":[80,18,9648],"popularity":3.1065,"vote_count":2458,"poster_path":"/vL7Xw04nFMHwnvXRFCmYYAzMUvY.jpg","release_date":"1950-08-26","vote_average":8.044,"backdrop_path":"/tDn1dA52bQH9B85vilHeU7C83W1.jpg","original_title":"羅生門","original_language":"ja"},{"id":476,"adult":false,"title":"Drugstore Cowboy","video":false,"overview":"Portland, Oregon, 1971. Bob Hughes is the charismatic leader of a peculiar quartet, formed by his wife, Dianne, and another couple, Rick and Nadine, who skillfully steal from drugstores and hospital medicine cabinets in order to appease their insatiable need for drugs. But neither fun nor luck last forever.","genre_ids":[18,80],"popularity":3.4441,"vote_count":602,"poster_path":"/1URuvqnZcwL4wy8hIIwQ9p9AxVq.jpg","release_date":"1989-10-20","vote_average":7.08,"backdrop_path":"/zf52xLEyao2xcVnpThmzW2Xl0aj.jpg","original_title":"Drugstore Cowboy","original_language":"en"},{"id":439,"adult":false,"title":"La Dolce Vita","video":false,"overview":"Episodic journey of journalist Marcello who struggles to find his place in the world, torn between the allure of Rome's elite social scene and the stifling domesticity offered by his girlfriend, all the while searching for a way to become a serious writer.","genre_ids":[35,18],"popularity":3.1723,"vote_count":2003,"poster_path":"/2KU52apQyvyZuPsqEGMcWb4BKu2.jpg","release_date":"1960-02-05","vote_average":8.047,"backdrop_path":"/uaEfEkb2tjl4hN1oaSyzcxt4cEg.jpg","original_title":"La dolce vita","original_language":"it"},{"id":1256557,"adult":false,"title":"I Feel Fine.","video":false,"overview":"Ozzy Taylor, a charismatic high school teen, discovers he can't control his intrusive thoughts of suicide, setting off a life-changing shift in his destiny.","genre_ids":[18],"popularity":0.5693,"vote_count":8,"poster_path":"/6MhttajnWytBDBy9wnSLXZszVc5.jpg","release_date":"2024-11-06","vote_average":6.4,"backdrop_path":"/yRTZcfnu0OZj2gGhqmqds68TWXx.jpg","original_title":"I Feel Fine.","original_language":"en"},{"id":274955,"adult":false,"title":"Tale of the Three Jewels","video":false,"overview":"A Palestinian boy becomes entranced with a beautiful Romani girl and a fairy tale world she weaves amidst conflict in Gaza. The children explore nature, mysticism and what their future holds, while learning to live with the surrounding brutality c. 1990. Yusef's family scrapes by in a seaside camp while his father's in prison and his heavily-armed brother's on the run, parrying with Israeli troops. Salah, Yusef's schoolmate from a well-off Arab family strives faithfully to assist them, while Yusef helps an elderly, blind neighbor escape from his lonely abandonment into the North American dreamworld he's waited so long for.","genre_ids":[18],"popularity":0.2037,"vote_count":8,"poster_path":"/3LwMkLbfyRnmdLehd0ou3lPx1n9.jpg","release_date":"1995-01-02","vote_average":7.5,"backdrop_path":"/dZkk6fzoeDmjeehftBZbj4iM8R1.jpg","original_title":"حكاية الجواهر الثلاثة","original_language":"ar"},{"id":3558,"adult":false,"title":"Girl, Interrupted","video":false,"overview":"Set in the changing world of the late 1960s, Susanna Kaysen's prescribed \"short rest\" from a psychiatrist she had met only once becomes a strange, unknown journey into Alice's Wonderland, where she struggles with the thin line between normal and crazy. Susanna soon realizes how hard it is to get out once she has been committed, and she ultimately has to choose between the world of people who belong inside or the difficult world of reality outside.","genre_ids":[18],"popularity":4.6741,"vote_count":4081,"poster_path":"/dOBdatHIVppvmRFw2z7bf9VKJr9.jpg","release_date":"1999-12-21","vote_average":7.567,"backdrop_path":"/gXwHuUad6Z7tBkGT0j6nGuLkyrx.jpg","original_title":"Girl, Interrupted","original_language":"en"},{"id":468134,"adult":false,"title":"Ward Six","video":false,"overview":"A doctor from provincial town in Tsardom of Russia meets his former student in Ward 6, where the story takes place. Impressed by his rebellious spirit and clever remarks, he tends to spend more time with him while also indulging in meditation, only to be ridiculed by his fellow colleagues. Based on a Chekhov's work of the same title.","genre_ids":[18],"popularity":0.2991,"vote_count":3,"poster_path":"/4FHI8YAbEtk42bZ4lMpPvt7wYDy.jpg","release_date":"1978-01-01","vote_average":4.3,"backdrop_path":"/vwz0wlIbYsIRsQUe15ZS1w4w8kt.jpg","original_title":"Paviljon VI","original_language":"sh"},{"id":663105,"adult":false,"title":"His","video":false,"overview":"Shun and Nagisa first meet and fall in love during their first year of high school. While Shun is graduating from university, Nagisa tells him that he doesn't see a future for them. Despite Shun's strong feelings, they go their separate ways. Years later, Shun is now a store owner, living alone in a rural area. Out of the blue, Nagisa arrives with his six-year-old daughter, Sora. Spending time together, Shun realizes he still harbors feelings for Nagisa. Can Nagisa reconcile with his feelings for Shun, which have been there all along?","genre_ids":[18,10749],"popularity":0.8129,"vote_count":28,"poster_path":"/ePBDOSLQ26voWspjWoDn1GuhiU8.jpg","release_date":"2020-01-24","vote_average":7.071,"backdrop_path":"/unGBAgFxeKUzGEsTReV2ECphMVl.jpg","original_title":"his","original_language":"ja"},{"id":9663,"adult":false,"title":"Starman","video":false,"overview":"When an alien takes the form of a young widow's husband and asks her to drive him from Wisconsin to Arizona, the government tries to stop them.","genre_ids":[878,10749,18],"popularity":3.0283,"vote_count":964,"poster_path":"/cgDeFWkYi6e9FT5RiQPCbQ9HlXZ.jpg","release_date":"1984-12-13","vote_average":6.926,"backdrop_path":"/fny1B9hmVilFtU3RRjkMZffBjUi.jpg","original_title":"Starman","original_language":"en"},{"id":9571,"adult":false,"title":"Dazed and Confused","video":false,"overview":"The adventures of a group of Texas teens on their last day of school in 1976, centering on student Randall Floyd, who moves easily among stoners, jocks and geeks. Floyd is a star athlete, but he also likes smoking weed, which presents a conundrum when his football coach demands he sign a \"no drugs\" pledge.","genre_ids":[35,18],"popularity":3.3769,"vote_count":2211,"poster_path":"/msG9awbLhVZwv1Eh9Ge7SofMexW.jpg","release_date":"1993-09-24","vote_average":7.316,"backdrop_path":"/mhYQOazZVBAPtKDw3TXybDtMJgK.jpg","original_title":"Dazed and Confused","original_language":"en"}],"external_ids":{"imdb_id":"tt39240255","twitter_id":null,"facebook_id":null,"wikidata_id":null,"instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148574,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AR","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-01-29T00:00:00.000Z","certification":"+13"}]},{"iso_3166_1":"ES","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-01-29T00:00:00.000Z","certification":"12"}]},{"iso_3166_1":"ID","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-01-29T00:00:00.000Z","certification":""}]},{"iso_3166_1":"KR","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-01-29T00:00:00.000Z","certification":"15"}]},{"iso_3166_1":"MX","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-01-29T00:00:00.000Z","certification":""}]},{"iso_3166_1":"SG","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-01-29T00:00:00.000Z","certification":"PG13"}]},{"iso_3166_1":"US","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-01-29T00:00:00.000Z","certification":""}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_sc