5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Gangster, the Cop, the Devil\",\"description\":\"After barely surviving a brutal attack by a sadistic serial killer, crime boss Jang Dong-su is left humiliated. Determined to catch the killer known as K, he forms an uneasy alliance with Jung Tae-seok, a relentless and incorruptible detective who often disrupts his illegal business. However, while Jang Dong-su wants K dead, Jung Tae-suk is determined to bring him to justice. With a deal in place—whoever finds K first will decide his fate—the hunt begins, blurring the lines between crime and law.\",\"image\":\"https://image.tmdb.org/t/p/w500/oHlM4abRm6BzrRcz9Nup1uidw9H.jpg\",\"datePublished\":\"2019-05-15\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"crime film\",\"action film\",\"Crime\",\"Action\",\"Thriller\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.842,\"bestRating\":10,\"ratingCount\":1399}}"}}],["$","$L10",null,{"initialDrama":{"id":"631ff4fd-6e76-415e-80b7-effff069bf04","tmdb_id":581528,"imdb_id":"tt10208198","content_type":"movie","title":"The Gangster, the Cop, the Devil","original_title":"악인전","overview":"After barely surviving a brutal attack by a sadistic serial killer, crime boss Jang Dong-su is left humiliated. Determined to catch the killer known as K, he forms an uneasy alliance with Jung Tae-seok, a relentless and incorruptible detective who often disrupts his illegal business. However, while Jang Dong-su wants K dead, Jung Tae-suk is determined to bring him to justice. With a deal in place—whoever finds K first will decide his fate—the hunt begins, blurring the lines between crime and law.","poster_path":"/oHlM4abRm6BzrRcz9Nup1uidw9H.jpg","backdrop_path":"/jJJQ1PPXUEchqyZ9YyWzgSNU39Z.jpg","release_date":"2019-05-15","first_air_date":null,"status":"published","original_la