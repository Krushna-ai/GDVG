,"original_language":"en"},{"id":275,"adult":false,"title":"Fargo","video":false,"overview":"Jerry, a small-town Minnesota car salesman is bursting at the seams with debt... but he's got a plan. He's going to hire two thugs to kidnap his wife in a scheme to collect a hefty ransom from his wealthy father-in-law. It's going to be a snap and nobody's going to get hurt... until people start dying. Enter Police Chief Marge, a coffee-drinking, parka-wearing - and extremely pregnant - investigator who'll stop at nothing to get her man. And if you think her small-time investigative skills will give the crooks a run for their ransom... you betcha!","genre_ids":[80,18,53],"popularity":8.1869,"vote_count":8900,"poster_path":"/rt7cpEr1uP6RTZykBFhBTcRaKvG.jpg","release_date":"1996-03-08","vote_average":7.847,"backdrop_path":"/747dgDfL5d8esobk7h4odaOFhUq.jpg","original_title":"Fargo","original_language":"en"}],"external_ids":{"imdb_id":"tt2820852","twitter_id":"TheFastSaga","facebook_id":"TheFastSaga","wikidata_id":"Q14650496","instagram_id":"thefastsaga"},"social_ids":{"twitter":"TheFastSaga","facebook":"TheFastSaga","instagram":"thefastsaga"},"gdvg_id":148507,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AU","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2015-04-02T00:00:00.000Z","certification":"M"}]},{"iso_3166_1":"BE","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2015-04-01T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"BG","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2015-04-03T00:00:00.000Z","certification":"C"}]},{"iso_3166_1":"BR","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2015-04-02T00:00:00.000Z","certification":"14"}]},{"iso_