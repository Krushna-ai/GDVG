6TOQ.jpg","iso_639_1":"ja","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/xgMCNtqYlgMjZ6HUeANCXCLktW5.jpg","iso_639_1":null,"vote_average":3.334},{"width":1383,"height":2048,"file_path":"/9WrgbeYF9CFUfHems0RvkG1vRTY.jpg","iso_639_1":"pl","vote_average":3.334},{"width":1200,"height":1686,"file_path":"/qiodOI39faRytzKvmq1C8IUjxaX.jpg","iso_639_1":"zh","vote_average":3.334},{"width":2000,"height":2823,"file_path":"/oEB0B0isNBP8c6SJ3EMjrhxtYlz.jpg","iso_639_1":"zh","vote_average":3.334},{"width":736,"height":1025,"file_path":"/ib2GDUvkLS6Ms4UIgNDkf7CciWb.jpg","iso_639_1":null,"vote_average":3.334},{"width":2000,"height":2830,"file_path":"/75LbyH4LJJjpSymXj0JVJiaJRdy.jpg","iso_639_1":null,"vote_average":2.542},{"width":1000,"height":1500,"file_path":"/wN2pOG934Sce17oYwgZS6hvdJ7c.jpg","iso_639_1":"en","vote_average":2.278},{"width":1500,"height":2132,"file_path":"/4avN0UK2cbG3FqKcO0w7fFytcPW.jpg","iso_639_1":null,"vote_average":1.75}],"backdrops":[{"width":2000,"height":1125,"file_path":"/rcEDPOOOUTLFxLLQJggfLffbofe.jpg","iso_639_1":null,"vote_average":4.3},{"width":1920,"height":1080,"file_path":"/qQH6x0tUvFQKTKfb5KB2NbfIz7.jpg","iso_639_1":null,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/fh4H92nhTUJTONXVRUHIpOGsHnK.jpg","iso_639_1":"en","vote_average":3.334},{"width":1920,"height":1080,"file_path":"/921vUyXdfIYpaXqu5Lnf3nVb4IJ.jpg","iso_639_1":null,"vote_average":2.542},{"width":1920,"height":1080,"file_path":"/uBxkwY70q6d7c8dN0qAXRHmHeUQ.jpg","iso_639_1":null,"vote_average":1.75},{"width":1452,"height":816,"file_path":"/t9K8ycUBCplWiICDOKRNRYcEH9e.jpg","iso_639_1":null,"vote_average":1.444},{"width":1707,"height":960,"file_path":"/geYUecpFI2AonDLhjyK9zoVFcMv.jpg","iso_639_1":null,"vote_average":1.444},{"width":1919,"height":1079,"file_path":"/7phcGGiYRrEQDHWB0cBwgtt3dkY.jpg","iso_639_1":null,"vote_average":1.222},{"width":1452,"height":816,"file_path":"/10jVpNPcl9uzVR7W6EXKRyKLTXZ.jpg","iso_639_1":null,"vote_average":1.208},{"width":1920,"height":1080,"file_path":"/7uxQQUnHvPKc2LmvDXRszgfBka8.jpg","iso_639_1":null,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/xGxNUgYCav9jn7QeUTnGg2GoZVt.jpg","iso_639_1":null,"vote_average":0.166},{"width":1428,"height":803,"file_path":"/7Cqu1tJpptsoozc93vPiISgyhBm.jpg","iso_639_1":"en","vote_average":0},{"width":2048,"height":1152,"file_path":"/ljmyjwJO1vpyTa3Gf8NZ525saEt.jpg","iso_639_1":"pl","vote_average":0},{"width":1420,"height":799,"file_path":"/g3LkHFGwPxKwi5PuGrNknFUVJSN.jpg","iso_639_1":null,"vote_average":0},{"width":1422,"height":800,"file_path":"/cxxNNSoPcGRNOzmtcm0CzyVF4MG.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-02-21T12:12:04.954+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Jujutsu Kaisen 0","runtime":105,"tagline":"Love is a twisted curse.","homepage":"","overview":"Yuta Okkotsu is a nervous high school student who is suffering from a serious problem—his childhood friend Rika has turned into a curse and won't leave him alone. Since Rika is no ordinary curse, his plight is noticed by Satoru Gojo, a teacher at Jujutsu High, a school where fledgling exorcists learn how to combat curses. Gojo convinces Yuta to enroll, but can he learn enough in time to confront the curse that haunts him?"},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":105,"tagline":"『呪術廻戦』の原点―愛と呪いの物語","homepage":"https://jujutsukaisen-movie.jp/","overview":"幼少のころ、幼なじみの祈本里香を交通事故により目の前で失った乙骨憂太。「約束だよ 里香と憂太は大人になったら結婚するの」怨霊と化した里香の呪いに苦しみ、自身の死を望む乙骨だったが、最強の呪術師・五条悟によって、呪術高専に迎え入れられた。そして、同級生の禪院真希・狗巻 棘・パンダと出会い、乙骨はある決意をする。「生きてていいって自信が欲しいんだ」「僕は呪術高専で里香ちゃんの呪いを解きます」一方、乙骨たちの前にかつて一般人を大量虐殺し高専を追放された最悪の呪詛師・夏油 傑が現れる。「来たる12月24日 我々は百鬼夜行を行う」呪術師だけの楽園を標榜する夏油は、非術師を殲滅させんと、ついに新宿・京都に千の呪いを放ち――果たして、乙骨は夏油を止められるのか、そして、里香の解呪の行方は‥‥。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"剧场版 咒术回战 0","runtime":104,"tagline":"","homepage":"https://jujutsukaisen-movie.jp/","overview":"乙骨忧太是一个高中生，他正面临着一个严重的问题，青梅竹马理香变成了一个咒灵，不会让他一个人呆着。由于理香不是普通的咒灵，他的困境被咒术高专的老师五条悟注意到了。五条说服忧太入学，但他赶得及吗？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Jujutsu Kaisen 0","runtime":0,"tagline":"","homepage":"","overview":"Yuta Okkotsu es un nervioso estudiante de instituto que sufre un grave problema: su amiga de la infancia Rika se ha convertido en una maldición y no le deja en paz. Como Rika no es una maldición cualquiera, su situación es percibida por Satoru Gojo, un profesor del instituto Jujutsu, una escuela donde los exorcistas noveles aprenden a combatir las maldiciones. Gojo convence a Yuta para que se matricule, pero ¿podrá aprender lo suficiente a tiempo para enfrentarse a la Maldición que le persigue?"},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Jujutsu kaisen 0 - Il film","runtime":105,"tagline":"","homepage":"","overview":"Yuta Okkotsu è uno studente liceale nervoso che soffre di un problema serio: la sua amica d'infanzia Rika si è trasformata in una maledizione e non lo lascerà in pace. Dal momento che Rika non è una maledizione ordinaria, la sua situazione viene notata da Satoru Gojo, un insegnante del liceo Jujutsu, una scuola in cui gli esorcisti alle prime armi imparano a combattere le maledizioni. Gojo convince Yuta ad iscriversi, ma riuscirà a imparare abbastanza in tempo per affrontare la maledizione che lo perseguita?"},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"劇場版 咒術迴戰 0","runtime":104,"tagline":"","homepage":"","overview":"乙骨憂太兒時目睹青梅竹馬祈本里香死於交通事故。\r 「約好囉，里香跟憂太長大之後要結婚」 里香化為怨靈，乙骨因此為詛咒所苦，希望自己死去。之後在最強咒術師五條悟的帶領下，進入咒術高專。於是，乙骨認識了同班同學禪院真希、狗卷棘以及熊貓，並立下了某個決定。\r 「我想要自己可以活下去的自信」 「我要在咒術高專解開里香的詛咒」 另一方面，乙骨等人面前出現某個人物。那是曾經大量虐殺普通人，被高專驅逐的最兇惡咒詛師──夏油傑。\r 夏油提倡建立只屬於咒術師的樂園，全面殲滅非術師，將在新宿、京都放出上千個詛咒…… 乙骨究竟能不能阻止夏油，又是否能成功解開里香的詛咒呢……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"극장판 주술회전 0","runtime":105,"tagline":"","homepage":"","overview":"어린 시절, 소꿉친구인 오리모토 리카를 교통사고로 눈 앞에서 잃은 옷코츠 유타. 옷코츠는 원령으로 변한 리카의 저주에 괴로워한 나머지 자신도 죽기를 바라지만, 최강의 주술사인 고죠 사토루에 의해 주술고전에 들어가게 된다. 그리고 동급생인 젠인 마키, 이누마키 토게, 판다를 만나면서 굳은 결심을 한다. 한편 옷코츠와 친구들 앞에 과거에 일반인을 대량으로 학살해서 고전에서 추방된 최악의 주저사인 게토 스구루가 나타난다. 주술사만의 낙원을 만들려는 게토는 비술사를 섬멸하겠다면서 신주쿠와 교토에 천의 저주를 내리는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":105,"tagline":"","homepage":"","overview":""},"name":"","iso_639_1":"mn","iso_3166_1":"MN","english_name":"Mongolian"},{"data":{"title":"劇場版 咒術迴戰 0","runtime":104,"tagline":"","homepage":"https://jujutsukaisen.jp/movie/","overview":"自幼感情極好的乙骨憂太與祈本里香約好長大後要結婚，卻不料里香因死亡車禍化為強大怨靈依附在憂太身邊，為此所苦的憂太一心求死，之後在五條悟的帶領下進入咒術高專結識了新同學：禪院真希、狗卷棘與熊貓，他決定在這裡找到活下去的自信並解除里香的詛咒。意欲奪取里香強大怨靈力量的夏油傑宣布在12月24日舉行「百鬼夜行」，在新宿與京都釋出上千個詛咒。面臨如此重大浩劫，憂太能否阻止夏油的野心並解開里香的詛咒？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Jujutsu Kaisen 0","runtime":105,"tagline":"","homepage":"","overview":"Als Kind musste Yuta Okkotsu mit ansehen, wie seine Freundin Rika Orimoto tödlich verunglückte. Seitdem sucht sie ihn als Fluch heim. Yuta wünscht sich sogar seinen eigenen Tod, bis ihn der stärkste Jujuzist, Satoru Gojo, an der städtischen Jujutsu-Akademie Tokyo aufnimmt. Mit neuem Lebensmut und seinen Mitschülern Maki Zen'in, Toge Inumaki und Panda will Yuta den Fluch endlich brechen. Sie müssen aber auch versuchen, den üblen Fluchmagier Suguru Geto aufzuhalten, der tausend Flüche auf Shinjuku und Kyoto entfesseln will, um alle einfachen Leute auszumerzen und ein Paradies für Jujuzisten zu kreieren."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Jujutsu Kaisen 0","runtime":0,"tagline":"","homepage":"","overview":"Rika, amiga de la infancia de Yuta Okkotsu, murió en un accidente automovilístico. Su espíritu permanece con él, más ya no es la dulce niña que él conocía. Se manifiesta como una entidad monstruosa y poderosa que lo protege ferozmente."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Jujutsu Kaisen 0","runtime":105,"tagline":"Combattre ce qu'il y a à l'intérieur","homepage":"","overview":"Lorsqu’il était enfant, Yuta Okkotsu a vu son amie Rika Orimoto perdre la vie dans un terrible accident. Depuis, Rika vient hanter Yuta qui a même souhaité sa propre mort après avoir souffert des années de cette malédiction. Jusqu’au jour où le plus puissant des exorcistes, Satoru Gojo, l’accueille dans l’école d’exorcisme de Tokyo. Tandis que Yuta trouve enfin un nouveau sens à sa vie, une menace plane sur le monde. En effet, quelqu’un projette de déchaîner un millier de malédictions sur Shinjuku et Kyoto pour exterminer tous les non-exorcistes…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Jujutsu Kaisen 0: O Filme","runtime":105,"tagline":"Eu prometo. Quando formos grandes, nós vamos nos casar!","homepage":"","overview":"Quando Yuta Okkotsu era pequeno, sua amiga Rika Orimoto morreu num acidente de trânsito, bem na sua frente. Ela se tornou uma aparição, assombrando o jovem e atormentando a sua vida, até o dia em que Satoru Gojo, um feiticeiro Jujutsu, o convida para se matricular no Colégio Jujutsu. Junto com seus novos colegas de sala: Maki Zen'in, Toge Inumaki e Panda, Yuta encontra a coragem para perseverar. Enquanto isso, Suguru Geto, um vil manipulador de maldições que foi expulso do colégio por massacrar inocentes, põe em prática seu plano: lançar mil maldições em Shinjuku e em Kyoto e exterminar todos os não-feiticeiros, criando um paraíso para feiticeiros Jujutsu. Será que Yuta será capaz de impedir Geto? E o que acontecerá quando ele se livrar da maldição da Rika?"},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Jujutsu Kaisen 0: The Movie","runtime":105,"tagline":"","homepage":"","overview":"Yuta Okkotsu on hermostunut lukiolainen, joka kärsii vakavasta ongelmasta – hänen lapsuudenystävänsä Rika on muuttunut kiroukseksi, eikä jätä häntä rauhaan. Koska Rika ei ole tavallinen kirous, hänen ahdinkonsa huomaa Satoru Gojo, opettaja Jujutsu High -koulussa, jossa aloittelevat manaajat oppivat taistelemaan kirouksia vastaan. Gojo vakuuttaa Yutan ilmoittautumaan, mutta voiko hän oppia tarpeeksi ajoissa kohtaamaan häntä ahdistavan kirouksen?"},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Магическая битва 0. Фильм","runtime":0,"tagline":"","homepage":"","overview":"Юту Оккоцу преследует призрак его подруги детства, которая погибла в ДТП. Однако она вовсе не та милая девушка, какой была Рика до смерти, а чудовищное и могущественное существо. Не в силах контролировать агрессивное поведение Рики, Юта бессилен остановить кровопролитие, которое следует за ее жестокой местью. Поэтому, когда его хватают маги, владеющие джиу-джицу, Юта только рад, что больше никто не пострадает. Задержавший его мастер Сатору Годзё заставляет юношу поступить в старшую школу джиу-джицу, чтобы научиться управлять Рикой и помогать людям. Однако вскоре Юта узнает, что злые духи — не самое опасное, что есть в мире."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Jujutsu Kaisen 0: The Movie","runtime":0,"tagline":"","homepage":"","overview":"Som barn bevittnade Yuta Okkutsu sin vän Rika Orimotos dödsolycka, och den förbannelse som då drabbade honom väckte en dödslängtan. Som tonåring blir han antagen till Jujutsu High av den store jujutsu-magikern Satoru Gojo, och där finner han en ny mening med livet. Men skolan är inte enbart en fristad för jujutsu-trollkarlar. Den före detta eleven Suguru Geto, som stängts av efter att ha utfört en massaker, planerar sin återkomst. Med sin demonförbannelse vill han förinta alla vanliga människor som inte utövar magi."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Chú Thuật Hồi Chiến 0","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Jujutsu Kaisen: 0","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"ג'וג'וטסו קאיזן","runtime":0,"tagline":"","homepage":"","overview":"יוטה אוקוטסו, תלמיד תיכון שהשיג שליטה על רוח מקוללת חזקה, נרשם לתיכון ג'וג'וטסו במחוז טוקיו. שם ילמד ממכשפי ג'וג'וטסו איך לשלוט על כוחיו החדשים והחזקים. בעוד שאותם מורים יוכלו לשים עין עליו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"มหาเวทย์ผนึกมาร ซีโร่","runtime":0,"tagline":"คำสาปที่เดิมพันทุกสิ่ง","homepage":"","overview":"Yuta Okkotsu ถูกวิญญาณของเพื่อนสมัยเด็ก(แฟน) Rika หลอกหลอน ซึ่งเสียชีวิตจากอุบัติเหตุทางรถ วิญญาณของเธอกลับไม่ปรากฏเป็นสาวหน้าหวานที่เขาเรียกว่าที่รักอีกต่อไป วิญญาณของเธอกลับถูกสาปแช่งและเธอแสดงออกว่าเป็นตัวตนอย่างชัดเจนว่าจะครอยขัดขวางทุกอย่างของเขา ไม่มีอะไรสามารถควบคุมพลังอันยิ่งใหญ่ของริกะได้ ยูตะไม่สามารถหยุดการนองเลือดที่ต้นเหตุของคำสาปมากจากเขา เป็นผลให้ Yuta ถูกจับโดย Jujutsu Sorcerers ผู้พิทักษ์ลับของโลกคำสาป ที่ได้รับการฝึกฝนเพื่อต่อสู้กับวิญญาณต้องสาปเช่น Rika เพื่อหยุดการนองเลือด ยูตะปรารถนาที่จะจบชีวิตของเขาเพียงคนเดียว เพื่อไม่ให้ใครได้ต้องรับบาดเจ็บ จากวิญญานคำสาปของเขาอีก แต่ซาโตรุ โกโจ ได้เสนอทางเลือกให้เขา เพื่อการเดินทางครั้งใหญ่ในชีวิต"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Jujutsu Kaisen 0","runtime":0,"tagline":"İçindekilerle savaş.","homepage":"","overview":"Jujutsu Kaisen 0, son derece güçlü bir Lanetli Ruh'un kontrolünü ele geçirdikten sonra onun gücünü kontrol etmek ve ona göz kulak olmasına yardımcı olmak için Jujutsu Büyücüleri tarafından Tokyo Prefectural Jujutsu Lisesi'ne gönderilen lise öğrencisi Yuto Okkotso’nun hikayesini konu ediyor."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Jujutsu Kaisen 0","runtime":105,"tagline":"Luptă cu ceea ce este înăuntru.","homepage":"","overview":"În copilărie, Orimoto Rika a murit într-un accident de mașină chiar în fața celui mai bun prieten al ei, Okkotsu Yuta. \"Când vom crește mari, ne vom căsători. E o promisiune!\" Rika a devenit o apariție, iar Okkotsu a început să-și dorească și el să moară după ce a suferit de pe urma blestemului ei.  Însă cel mai mare vrăjitor Jujutsu, Gojo Satoru, l-a primit la liceul la care preda. Acolo Okkotsu își cunoaște colegii de clasă, Zen'in Maki, Inumaki Toge și Panda, și reușește să își găsească în sfârșit determinarea. \"Vreau să am destulă încredere în mine să spun: este OK că trăiesc! Cât timp sunt la Liceul Jujutsu, voi rupe blestemul lui Rika-chan.\""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Gekijouban Jujutsu Kaisen 0","runtime":0,"tagline":"","homepage":"","overview":"Yuta Okkotsut a Jujutsu Boszorkánymesterek a Tokiói Prefektúra Jujutsu Középiskolájába íratják be, hogy segítsenek neki kontrollálni az erejét, és szemmel tartsák őt."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Jujutsu Kaisen 0: The Movie","runtime":0,"tagline":"","homepage":"","overview":"Jako dziecko Rika Orimoto ginie w wypadku drogowym na oczach bliskiego przyjaciela Yuty Okkotsu. „To obietnica. Gdy dorośniemy, pobierzemy się”. Rika staje się zjawą, a Okkotsu, cierpiąc z powodu jej klątwy, pragnie własnej śmierci. Największy czarownik jujutsu, Satoru Gojo, wita go jednak w Liceum Jujutsu. Okkotsu poznaje kolegów z klasy: Maki Zen’in, Togego Inumakiego oraz Pandę, i w końcu odnajduje w sobie determinację: „Chcę móc powiedzieć, że to, że żyję, jest okej”. „Uczęszczając do Liceum Jujutsu, zdejmę klątwę Riki”. W międzyczasie nikczemny użytkownik klątw, Suguru Geto, którego wyrzucono ze szkoły za dokonanie masakry na zwykłych ludziach, ukazuje się przed Okkotsu i resztą. „24 grudnia zorganizujemy Nocną Paradę Stu Demonów”. Geto nawołuje do stworzenia raju wyłącznie dla czarowników jujutsu i rzuca tysiąc klątw na Shinjuku i Kioto, by w ten sposób zlikwidować wszystkich nie-czarowników. Czy Okkotsu uda się ostatecznie powstrzymać Geta? A co ze zdjęciem klątwy Riki…?"},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"جوجوتسو كايسن : ذا موفي","runtime":0,"tagline":"","homepage":"","overview":"يوتا أوكوتسو هو طالب في المدرسة الثانوية يكتسب قوة السيطرة على روح ملعونة قوية للغاية ويتم تسجيله في مدرسة جوجوتسو الثانوية بمحافظة طوكيو لمساعدته على السيطرة على قوته ومراقبته."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Магічна Битва: 0","runtime":0,"tagline":"Любов - це спотворене прокляття.","homepage":"","overview":"Дія аніме, заснованого на однойменній манзі, розгортається навколо Оккоцу Юти, що вступив до престижної школи магії в Токіо. Якось Юта починає переслідувати привид Ріки — подруги дитинства, яка кілька років тому загинула в автомобільній аварії. Могутній чаклун і вчитель Сатору Годжьо, завдяки якому Оккоцу вдалося вступити до школи магічних мистецтв, переконує підлітка пройти навчання у Токійській школі, щоб він навчився керувати привидом Ріки та використати її могутню силу на благо."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Gekijouban Jujutsu Kaisen 0","runtime":0,"tagline":"","homepage":"","overview":"Yuta Okkotsu je nervózní středoškolák, který trpí vážným problémem - jeho kamarádka z dětství Rika se proměnila v kletbu a nechce ho nechat na pokoji. Protože Rika není obyčejná kletba, všimne si jeho osudu Satoru Gojo, učitel na Jujutsu High, škole, kde se začínající exorcisté učí, jak bojovat s kletbami. Gojo přesvědčí Yutu, aby se zapsal, ale dokáže se včas naučit dost na to, aby se postavil kletbě, která ho pronásleduje?"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Jujutsu Kaisen 0","runtime":95,"tagline":"Não há maldição mais distorcida que o amor.","homepage":"","overview":"Yuta Okkotsu é um estudante do ensino médio nervoso que sofre de um problema sério: a sua amiga de infância, Rika, transformou-se num espírito amaldiçoado e não o deixa sozinho. Já que Rika não é um espírito amaldiçoado comum, Satoru Gojo, um professor da Academia Jujutsu, uma escola onde exorcistas novatos aprendem a lutar contra as maldições, apercebe-se da sua situação. Gojo convence Yuta a inscrever-se, mas conseguirá ele aprender o suficiente a tempo de enfrentar o espírito amaldiçoado que o assombra?"},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Jujutsu Kaisen 0: The Movie","runtime":0,"tagline":"","homepage":"","overview":"Όταν ήταν ακόμη παιδιά, η Ρίκα Οτιμότο πέθανε σε ένα τροχαίο δυστύχημα μπροστά στα μάτια του πολύ κοντινού της φίλου, Γιούτα Οκκότσου. Η Ρίκα έγινε ένα καταραμένο πνεύμα, και ο Γιούτα λαχταρούσε το θάνατο του, αφού υπέφερε από την κατάρα της. Αλλά, ο σπουδαιότερος Τζουτζούτσου Μάγος, Σάτορου Γκόζο, τον καλωσόρισε στην σχολή Τζουτζούτσου. Εκεί ο Γιούτα γνώρισε τους συμμαθητές του, Μάκι Ζένιν, Τόγκε Ινουμάκι και Πάντα, και επιτέλους βρήκε τον δικό του σκοπό. “Θέλω να βρω το θάρρος να πω, ότι είναι εντάξει, που είμαι ζωντανός!” “Καθώς βρίσκομαι στην σχολή Τζουτζούτσου, θα σπάσω την κατάρα της Ρίκα.” Εν τω μεταξύ, ο απαίσιος μάγος, Σούγκουρου Γκέτο, ο οποίος αποβλήθηκε από το σχολή Τζουτζούτσου για την σφαγή πολλών απλών ανθρώπων, εμφανίζεται απέναντι στο Γιούτα και τους άλλους. “Στις 24 Δεκεμβρίου, θα πραγματοποιήσουμε την Νυχτερινή Παρέλαση των Εκατό Δαιμόνων”  Θα μπορέσει ο Γιούτα να σταματήσει τον Γκέτο στο τέλος; Και τι θα γίνει με το σπάσιμο της κατάρας της Ρίκας;"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Jujutsu Kaisen 0","runtime":0,"tagline":"","homepage":"","overview":"Yuka Okkotsu, punya teman masa kecil bernama Rika Orimoto. Keduanya berjanji akan menikah bila sudah dewasa. Sayangnya, Rika meninggal dalam kecelakaan,  dan kemudian berubah menjadi roh terkutuk yang menghantui Yuta. Untuk menundukkan kutukan tersebut, Yuta ditawari Satoru Gojo masuk ke Sekolah Jujutsu. Yuta pun setuju dan kemudian bertemu tiga karakter lainnya yaitu, Inumaki Toge, Panda, dan Maki Zenin. Di bawah bimbingan Satoru Gojo, Yuta berusaha mematahkan kutukan Rika. Yuta juga melawan kekuatan Suguru Geto, penyihir sakti yang dikeluarkan dari sekolah Jujutsu karena membantai orang biasa. Dalam semesta Jujutsu Kaisen, kutukan datang dalam bentuk monster yang merupakan wujud dari emosi negatif."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"جوجوتسو کایسن 0","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Yuta Okkotsu is een nerveuze middelbare scholier die aan een ernstig probleem lijdt: zijn jeugdvriendin Rika is in een vloek veranderd en wil hem niet met rust laten. Omdat Rika geen gewone vloek is, wordt zijn benarde situatie opgemerkt door Satoru Gojo, een leraar op Jujutsu High, een school waar beginnende exorcisten leren hoe ze vloeken kunnen bestrijden. Gojo overtuigt Yuta om zich in te schrijven, maar kan hij op tijd genoeg leren om de vloek die hem achtervolgt het hoofd te bieden?"},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Jujutsu kaisen 0","runtime":105,"tagline":"","homepage":"","overview":"Kai buvo vaikai, Orimoto Rika žuvo eismo įvykyje prieš pat savo artimo draugo Okkotsu Yutos akis. Pagrindinis Okkotsu tikslas yra pagerinti savo antgamtinį potencialą ir rasti būdą, kaip išvaryti Riką, kad jis galėtų gyventi normalų gyvenimą. Tačiau jo buvimas burtininkų pasaulyje patraukė Suguru Geto. Ar Okkotsu galų gale sugebės sustabdyti Geto? Ir kas bus sulaužius Rikos prakeiksmą...?"},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Jujutsu Kaisen 0 : Le film","runtime":0,"tagline":"","homepage":"","overview":"Dans cette présuite de la série « Jujutsu Kaisen », un élève découragé s'inscrit à l'école secondaire Jujutsu afin de se débarrasser du violent fléau qui le hante."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Jujutsu Kaisen 0","runtime":0,"tagline":"","homepage":"","overview":"En Yuta Okkotsu és un estudiant de secundària nerviós que pateix un problema greu: la seva amiga de la infància, la Rika, s'ha convertit en una maledicció i no el deixa en pau. Com que la Rika no és una maledicció qualsevol en Satoru Gojo, un professor de l'institut Jujutsu on els exorcistes novells aprenen a combatre les malediccions, s'adona de la seva situació. Gojo convenç al Yuta perquè s'hi matriculi, però tindrà prou temps per aprendre a enfrontar-se a la maledicció que el persegueix?"},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Джуджуцу Кайсен 0","runtime":0,"tagline":"","homepage":"","overview":"Юта Оккотсу е притеснен гимназист с необичаен проблем — неговата приятелка от детството Рика се е превърнала в проклятие, което не го оставя на мира. Тъй като Рика е далеч от обикновено проклятие, съдбата на Юта привлича вниманието на Сатору Годжо, преподавател в Jujutsu High — училище, където млади екзорсисти се учат да се борят с проклятия. Годжо успява да убеди Юта да се запише, но ще успее ли той да научи достатъчно навреме, за да се изправи срещу проклятието, което го следва?"},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"}],"reviews_tmdb":[{"id":"624aff2705822400aa0f1004","url":"https://www.themoviedb.org/review/624aff2705822400aa0f1004","author":"CinemaSerf","content":"$11","created_at":"2022-04-04T14:22:31.930Z","updated_at":"2022-04-04T14:22:31.930Z","author_details":{"name":"CinemaSerf","rating":7,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}}],"recommendations":[{"id":610892,"adult":false,"title":"Violet Evergarden: Eternity and the Auto Memory Doll","video":false,"overview":"Violet Evergarden comes to a private women's academy to tutor Isabella in the ways of being a lady. Heir to the York family, Isabella feels trapped in this new and uncomfortable world. She still grieves for the only person to ever bring her happiness – now lost to her. Violet's lessons do give her a brief respite from the melancholy but with the absence of joy, how long does it take to truly heal?","genre_ids":[18,14,16],"media_type":"movie","popularity":1.9039,"vote_count":442,"poster_path":"/zjaSw6Ok0MhXjrruPrA27VHyUYC.jpg","release_date":"2019-09-06","vote_average":8.1,"backdrop_path":"/ldOF0T4x0YuST0OeJr9ctWMXuTL.jpg","original_title":"ヴァイオレット・エヴァーガーデン 外伝 - 永遠と自動手記人形 -","original_language":"ja"},{"id":912598,"adult":false,"title":"Bubble","video":false,"overview":"In an abandoned Tokyo overrun by bubbles and gravitational abnormalities, one gifted young man has a fateful meeting with a mysterious girl.","genre_ids":[16,12,878,14],"media_type":"movie","popularity":1.71,"vote_count":467,"poster_path":"/wjgwIZyEgtgy9nIdz6C5uJNel2X.jpg","release_date":"2022-02-14","vote_average":7.297,"backdrop_path":"/a8Q2g0g7XzAF6gcB8qgn37ccb9Y.jpg","original_title":"バブル","original_language":"ja"},{"id":1056803,"adult":false,"title":"Rascal Does Not Dream of a Sister Venturing Out","video":false,"overview":"After a draining December, Sakuta is quickly nearing the end of his second year of high school. Since Mai is a third-year student, they don't have much time left together before graduation rolls around. Meanwhile, his sister, Kaede, is slowly but steadily venturing outdoors again. Just as she begins to find her footing, she announces her most ambitious goal yet—attending her brother's high school! Sakuta knows better than anyone how difficult this will be for Kaede, and he's ready to support her however he can. He's just not sure if that's what's best for her...or what she really wants...","genre_ids":[16,18,14],"media_type":"movie","popularity":4.105,"vote_count":50,"poster_path":"/o3Yc0plKnzpck0SM3rQLjWBHel8.jpg","release_date":"2023-06-23","vote_average":7.7,"backdrop_path":"/sdh76YtGseZHPk4WiOJjMzKKFSB.jpg","original_title":"青春ブタ野郎はおでかけシスターの夢を見ない","original_language":"ja"},{"id":1338799,"adult":false,"title":"JUJUTSU KAISEN: Hidden Inventory / Premature Death - The Movie","video":false,"overview":"Pursued by a religious cult and other curse users, former friends Satoru Gojo and Suguru Geto are the only sorcerers capable of carrying the difficult task of protecting Riko Amanai, a student who has been designated to be sacrificed as the Star Plasma Vessel, until she can fulfill her duty.","genre_ids":[16,28,14],"media_type":"movie","popularity":8.2651,"vote_count":57,"poster_path":"/kZkyr1sRzarENrxjtltPvmHRrTk.jpg","release_date":"2025-05-30","vote_average":8.211,"backdrop_path":"/w8j0HVX7xasNVGAva2T3W4ncoN4.jpg","original_title":"劇場版総集編 呪術廻戦 懐玉・玉折","original_language":"ja"},{"id":888195,"adult":false,"title":"Hot Seat","video":false,"overview":"An ex-hacker is forced to break into high-level banking institutions, another man must try to penetrate the booby-trapped building to get the young man off the hot seat.","genre_ids":[53,28],"media_type":"movie","popularity":5.0423,"vote_count":150,"poster_path":"/6zoA2yEfKs8hNFlk4AV28VpoT3I.jpg","release_date":"2022-07-01","vote_average":5.107,"backdrop_path":"/wO46AY2nLQoLdRYD64FS5AsUCbP.jpg","original_title":"Hot Seat","original_language":"en"},{"id":754525,"adult":false,"title":"0","video":false,"overview":"","genre_ids":[],"media_type":"movie","popularity":0.0362,"vote_count":1,"poster_path":null,"release_date":"1977-01-01","vote_average":10,"backdrop_path":null,"original_title":"0","original_language":"fr"},{"id":620249,"adult":false,"title":"The Legend of Hei","video":false,"overview":"When cat spirit Luo Xiaohei's home is deforested by humans, he must find a new one. He runs into a group of other spirit creatures who take him under their wing with dreams of reconquering the land they say is rightfully theirs. However, they run into a human known as Wuxian who separates Luo Xiaohei from the other spirits and the two go on a journey, with the cat spirit learning to control his abilities as well as forming his own thoughts on whether or not he should ally with the spirits or the humans.","genre_ids":[16,14,28],"media_type":"movie","popularity":3.6742,"vote_count":440,"poster_path":"/4jfbKKLpqts3i2h2obkrONcjTg1.jpg","release_date":"2019-08-27","vote_average":8.3,"backdrop_path":"/aVFx1VtlOxR3v0ADEatalXOvwbu.jpg","original_title":"罗小黑战记","original_language":"zh"},{"id":18491,"adult":false,"title":"Neon Genesis Evangelion: The End of Evangelion","video":false,"overview":"SEELE orders an all-out attack on NERV, aiming to destroy the Evas before Gendo can advance his own plans for the Human Instrumentality Project. Shinji is pushed to the limits of his sanity as he is forced to decide the fate of humanity.","genre_ids":[16,878,18,14],"media_type":"movie","popularity":5.738,"vote_count":1792,"poster_path":"/j6G24dqI4WgUtChhWjfnI4lnmiK.jpg","release_date":"1997-07-19","vote_average":8.3,"backdrop_path":"/xLMJCCSatxENpHO9rLW9yD8A12C.jpg","original_title":"新世紀エヴァンゲリオン劇場版 Air／まごころを、君に","original_language":"ja"},{"id":776305,"adult":false,"title":"Belle","video":false,"overview":"Suzu is a 17-year-old high-school student living in a rural town with her father. Wounded by the loss of her mother at a young age, Suzu one day discovers the massive online world \"U\" and dives into this alternate reality as her avatar, Belle. Before long, all of U's eyes are fixed on Belle, when, suddenly, a mysterious, dragon-like figure appears before her.","genre_ids":[16,878,18,10402],"media_type":"movie","popularity":3.4286,"vote_count":838,"poster_path":"/fYHOD4pxZQk4rsP2tQrZI5uBlZV.jpg","release_date":"2021-07-16","vote_average":7.644,"backdrop_path":"/7aiVtavsu145yo6n4ZpazwMDLXL.jpg","original_title":"竜とそばかすの姫","original_language":"ja"},{"id":504253,"adult":false,"title":"I Want to Eat Your Pancreas","video":false,"overview":"After his classmate and crush is diagnosed with a pancreatic disease, an average high schooler sets out to make the most of her final days.","genre_ids":[16,18,10749],"media_type":"movie","popularity":5.2803,"vote_count":1724,"poster_path":"/qDWA7fB4cZ4sBP6YgwlxvraDHi7.jpg","release_date":"2018-09-01","vote_average":8.23,"backdrop_path":"/YLyORLsYIjC0d1TFBSpJKk7piP.jpg","original_title":"君の膵臓をたべたい","original_language":"ja"},{"id":812225,"adult":false,"title":"Black Clover: Sword of the Wizard King","video":false,"overview":"As a lionhearted boy who can't wield magic strives for the title of Wizard King, four banished Wizard Kings of yore return to crush the Clover Kingdom.","genre_ids":[16,14,28,12],"media_type":"movie","popularity":4.0418,"vote_count":358,"poster_path":"/9YEGawvjaRgnyW6QVcUhFJPFDco.jpg","release_date":"2023-06-16","vote_average":8.087,"backdrop_path":"/rogeBJK44LtWynOqzMFmEF30T80.jpg","original_title":"映画 ブラッククローバー 魔法帝の剣","original_language":"ja"},{"id":532067,"adult":false,"title":"KONOSUBA – God's blessing on this wonderful world! Legend of Crimson","video":false,"overview":"It is not strange that the Demon Lord's forces fear the Crimson Demons, the clan from which Megumin and Yunyun originate. Even if the Demon Lord's generals attack their village, the Crimson Demons can just easily brush them off with their supreme mastery of advanced and overpowered magic.  When Yunyun receives a seemingly serious letter regarding a potential disaster coming to her hometown, she immediately informs Kazuma Satou and the rest of his party. After a series of wacky misunderstandings, it turns out to be a mere prank by her fellow demon who wants to be an author. Even so, Megumin becomes worried about her family and sets out toward the Crimson Demons' village with the gang.  There, Kazuma and the others decide to sightsee the wonders of Megumin's birthplace. However, they soon come to realize that the nonsense threat they received might have been more than just a joke.","genre_ids":[16,12,35,14],"media_type":"movie","popularity":3.088,"vote_count":599,"poster_path":"/fv5BgcfkpWh3V6Pb1qVlXESBOdl.jpg","release_date":"2019-08-30","vote_average":8.048,"backdrop_path":"/xTWHFJgP5anqRipDig4LSa4DLqj.jpg","original_title":"映画 この素晴らしい世界に祝福を！紅伝説","original_language":"ja"},{"id":614939,"adult":false,"title":"Bros","video":false,"overview":"Two emotionally unavailable men attempt a relationship.","genre_ids":[35,10749],"media_type":"movie","popularity":1.5331,"vote_count":555,"poster_path":"/6iFBzZ3LjmlE83pHok03Z9QPkAB.jpg","release_date":"2022-09-30","vote_average":6.663,"backdrop_path":"/mezKuuKtAKPENnAVlT3TghkMACv.jpg","original_title":"Bros","original_language":"en"},{"id":635302,"adult":false,"title":"Demon Slayer -Kimetsu no Yaiba- The Movie: Mugen Train","video":false,"overview":"Tanjiro Kamado, joined with Inosuke Hashibira, a boy raised by boars who wears a boar's head, and Zenitsu Agatsuma, a scared boy who reveals his true power when he sleeps, boards the Infinity Train on a new mission with the Fire Hashira, Kyojuro Rengoku, to defeat a demon who has been tormenting the people and killing the demon slayers who oppose it!","genre_ids":[16,28,14],"media_type":"movie","popularity":9.3584,"vote_count":4397,"poster_path":"/h8Rb9gBr48ODIwYUttZNYeMWeUU.jpg","release_date":"2020-10-16","vote_average":8.2,"backdrop_path":"/xPpXYnCWfjkt3zzE0dpCNME1pXF.jpg","original_title":"劇場版「鬼滅の刃」無限列車編","original_language":"ja"},{"id":604605,"adult":false,"title":"Hello 