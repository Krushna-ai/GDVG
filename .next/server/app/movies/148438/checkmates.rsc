ull,"import_batch_name":null,"imported_at":"2026-02-25T22:10:23.941333+00:00","region":null,"main_poster":null,"images":{"logos":[{"width":2983,"height":992,"file_path":"/pugufFQh7h2FQZAC6Sr9jXbXFFH.png","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":3.007,"vote_average":0}],"posters":[{"width":2000,"height":3000,"file_path":"/epxMmvLaQmInLeRNOIMfRaJrhSZ.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":2000,"height":3000,"file_path":"/vbk8aNFGbvdeDzNN4oE4D4quYm6.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":2000,"height":3000,"file_path":"/fQtXWXoh301O6fp9ZsG71w76T4g.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":2,"aspect_ratio":0.667,"vote_average":1.75},{"width":1812,"height":2560,"file_path":"/6hLTp4z2Zh1uR0pFAI0CVf5hBit.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.708,"vote_average":0},{"width":940,"height":1410,"file_path":"/c6GwgfahAIpJT8DnLe2x7R0B0yc.jpg","iso_639_1":"uk","iso_3166_1":"UA","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/2ft9sbj2ZnHzDLSS4ixelCcFdRa.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":2857,"file_path":"/d6tZC8G4qqYW8HtAX0J6yBdYriC.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":2000,"height":2857,"file_path":"/tuxza30GqHZaUh4hKVjfKl1IGkz.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":1000,"height":1500,"file_path":"/nXgtzL4FBSZjuGZhUxgoyUgFS08.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/sQnbIgJzleqPF0XpNGTWXVMyF1h.jpg","iso_639_1":"ru","iso_3166_1":"RU","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1175,"height":1763,"file_path":"/9VP3SHOAe7ooyWHpV7NqiuwRa6z.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.666,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/2UYUojn45G06tk2gTbQc20DQGCm.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1920,"height":1080,"file_path":"/mqTXDQgLbUkf95gzsqUZvkkU6K4.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/lubLa3D7GOtqMEUR9qTNB1jUrDs.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334}]},"enriched_at":"2026-04-21T06:52:51.289+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":99,"tagline":"","homepage":"","overview":"Tras un traumático divorcio, Candela pierde su trabajo en un colegio de élite. Tiene que volver al barrio que abandonó y pedir ayuda a su hermana y a su padre, y dar clases en su antiguo instituto a alumnos con problemas de integración."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Checkmates","runtime":98,"tagline":"","homepage":"https://www.filmfactoryentertainment.com/films/checkmates","overview":"Candela, the headmistress of an elite school, after a traumatic divorce, returns to her old high school to lead a group of rebellious students through chess. There she will learn that in chess, and in life, it doesn't matter if you are a king or a pawn, because everyone ends up in the same box."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Després d'un traumàtic i inesperat divorci, la Candela perd el seu treball en un col·legi d'elit i ha de tornar al barri on va néixer. Intenta començar de zero i aconseguir una segona oportunitat, i comença a fer classes en el seu antic institut a estudiants amb problemes d'integració. El que no s'espera és que les classes d'escacs obren el miracle i aquestes ovelles negres aconsegueixen creure's per primera vegada en la seva vida que no són uns perdedors i que les coses poden canviar."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"Шах і мат","runtime":0,"tagline":"","homepage":"","overview":"Кандела була шановним учителем у престижному коледжі, але тепер життя жінки кардинально змінилося, тому що вона починає працювати у звичайній школі із важкими підлітками. Щоправда, таким чином у безнадійних, на перший погляд, учнів з'являється можливість стати найкращими у шахах у країні."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Шах и мат","runtime":99,"tagline":"","homepage":"","overview":"Жизнь Канделы в одночасье кардинально меняется, и она из успешной преподавательницы элитного колледжа превращается в простую училку в не самой лучшей школе «на районе». Теперь ей придется обучать трудных подростков из неблагополучных семей. Благодаря Канделе у компании школьных аутсайдеров появляется реальный шанс стать чемпионами страны по шахматам.\r Ведь в шахматах — как и в жизни — не имеет значения, король ты или пешка. Главное — сделать верный ход."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Candela was een gerespecteerde lerares aan een prestigieuze universiteit, maar nu is het leven van de vrouw drastisch veranderd, omdat ze op een gewone school begint te werken met moeilijke tieners. Op deze manier hebben studenten op het eerste gezicht echter de kans om de beste schaakspeler van het land te worden."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"","runtime":98,"tagline":"","homepage":"","overview":"Tras un traumático divorcio, Candela pierde su trabajo en un colegio de élite. Tiene que volver al barrio que abandonó y pedir ayuda a su hermana y a su padre, y dar clases en su antiguo instituto a alumnos con problemas de integración."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Šach mat","runtime":0,"tagline":"","homepage":"","overview":"Candela se mylně domnívala, že společenský žebříček jde pouze jedním směrem - nahoru. Nyní, po traumatickém a nečekaném rozvodu, ztratí práci na elitní soukromé škole a nezbývá jí, než se vrátit do svého rodného města a požádat o pomoc svou sestru a otce. Nastal čas postavit své figurky zpět na šachovnici a začít znovu v naději, že najde druhou šanci."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Checkmates - Ziemlich schräge Figuren","runtime":0,"tagline":"","homepage":"","overview":"Nach einer plötzlichen Scheidung verliert eine Frau ihren gut bezahlten Job an einer Privatschule und muss in ihre alte Nachbarschaft zurückkehren. Auf Unterstützung angewiesen, bleibt ihr nur ein Ausweg: ein Neuanfang als Schachlehrerin für rebellische Teenager."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"发飙老师","runtime":0,"tagline":"","homepage":"","overview":"经历了一场痛苦的离婚后，坎德拉失去了在一所精英学校的工作。于是，她不得不回到自己曾经离开的社区，向姐姐和父亲寻求帮助，并在自己的母校高中任教，教那些有融入问题的学生。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":763147,"adult":false,"title":"Across the River and into the Trees","video":false,"overview":"In post WW2 Venice Italy, American Army Col. Richard Cantwell, haunted by the war, faces news of his illness with stoic disregard. Determined to spend a weekend in quiet solitude, he commandeers a military driver to visit his old haunts in Venice. As Cantwell's plans begin to unravel, a chance encounter with a remarkable young woman begins to rekindle hope. Based  on the harrowing novel by Ernest Hemingway.","genre_ids":[18],"media_type":"movie","popularity":0.8573,"vote_count":31,"poster_path":"/ya9Xbrh8rN8EDeFBiI1tEjGY05o.jpg","release_date":"2023-10-11","vote_average":7,"backdrop_path":"/61QNJEtapy1rjprgMRvuHYlL8L9.jpg","original_title":"Across the River and into the Trees","original_language":"en"},{"id":1034387,"adult":false,"title":"Chinas","video":false,"overview":"In Madrid, Spain, Lucía and Xiang, two nine-year-old Chinese girls, meet at the beginning of the school year.","genre_ids":[18],"media_type":"movie","popularity":0.6979,"vote_count":34,"poster_path":"/xXDegCxZZLP66xghr8N5VMnhCga.jpg","release_date":"2023-10-06","vote_average":7.029,"backdrop_path":"/m2B9ijXppTE5oYbXTRckUp7cew8.jpg","original_title":"Chinas","original_language":"es"},{"id":1196366,"adult":false,"title":"Idol Affair","video":false,"overview":"César and Teresa are a happy couple until one night she sleeps with Coque Malla, César's great idol since his adolescence. Teresa confesses it to César, repentant, but he doesn't know how to react. Is being unfaithful with your erotic myth excusable? Teresa has not slept with her idol, but with Caesar's. And there is no current legislation on that. César needs to talk to Coque, even though the singer no longer lives in Spain. So the couple travels to Miami in search of him, while they rethink their 15-year relationship and their own lives.","genre_ids":[35],"media_type":"movie","popularity":0.3443,"vote_count":28,"poster_path":"/fM2fSLStTbws4Eah5Pjo0KKBgpo.jpg","release_date":"2024-02-14","vote_average":4.929,"backdrop_path":"/i2reWgXQ4bPH6APxZNcZXppSmYw.jpg","original_title":"Buscando a Coque","original_language":"es"},{"id":551499,"adult":false,"title":"70 Big Ones","video":false,"overview":"Raquel is desperate: a series of unfortunate events have led to her daughter being taken and she needs a large amount of money to get her back, and fast. After a desperate plea to the bank, she manages to secure the loan she needs. The problem is that precisely at that moment, a peculiar couple of robbers enter the branch: the drug-addicted Jonan and his partner Lola, who is a deadly combination of smart and psychotic. But Raquel’s stakes are too high, and she knows she must think carefully to outsmart them, save herself and get her money.","genre_ids":[80,28],"media_type":"movie","popularity":0.3858,"vote_count":87,"poster_path":"/4gcLReyZd83sPuEPvW6JJwEaaYt.jpg","release_date":"2019-03-08","vote_average":5.73,"backdrop_path":"/zDtoAya6AY8YYBcOMOjbNDwX3WX.jpg","original_title":"70 Binladens","original_language":"es"},{"id":1036497,"adult":false,"title":"I Love You More","video":false,"overview":"After a year of online pillow-talk, Ben, a shy Kosovar teen, is exhilarated to finally meet his first (but secret) love, Leo. Consumed with passion, Ben carefully weaves the plans and cover-story for his much desired romantic tryst with Leo who is arriving from Germany in just one month. Everything must be perfect. Great news, Ben’s mother surprises him and the family with a life changing opportunity, but he just can’t take it yet. He must meet Leo.","genre_ids":[10749,18],"media_type":"movie","popularity":0.5624,"vote_count":6,"poster_path":"/cim8ByKrdLwEr3EabawQJ88Hl0D.jpg","release_date":"2024-05-23","vote_average":4.417,"backdrop_path":"/bGuzxFeQkk0mUvCCI32RVea0CsB.jpg","original_title":"I Love You More","original_language":"en"},{"id":554285,"adult":false,"title":"Butter","video":false,"overview":"A lonely obese boy everyone calls \"Butter\" is about to make history. He is going to eat himself to death-live on the Internet - and everyone is invited to watch.","genre_ids":[18],"media_type":"movie","popularity":0.5168,"vote_count":32,"poster_path":"/9tWnnYR4uWivO5lTHLbKLCYu8wH.jpg","release_date":"2020-02-25","vote_average":5.938,"backdrop_path":"/oXlo2drpXh10cOR2p3mio40siQH.jpg","original_title":"Butter","original_language":"en"},{"id":1064103,"adult":false,"title":"How to Be a Modern Man","video":false,"overview":"Andres Cuadrado is an old-fashioned civil servant. Conservative and somewhat macho, he takes his job at the Ministry of Finance very seriously. He considers himself above all a person \"as God commands\" and, consequently, he takes it for granted that everything responds to a natural, hierarchical and immovable order. After an unfortunate confrontation with a colleague, Andrés is disciplined and transferred to the Ministry of Equality. There everything is totally new to him: there are no assigned places, no schedules, and everyone is a vegan. Andres will have a lot of catching up to do to adapt to this new order of things.","genre_ids":[35],"media_type":"movie","popularity":0.2268,"vote_count":59,"poster_path":"/kI2wF5PNWjAmh6uqpPxTt8PWOcq.jpg","release_date":"2023-06-02","vote_average":5.822,"backdrop_path":"/sBpJc1w45BI8bpJEk6gDbXOfi6P.jpg","original_title":"Como Dios manda","original_language":"es"},{"id":1109146,"adult":false,"title":"Jump!","video":false,"overview":"Oscar and Teo (13 and 11 years old) are two brothers, very different from each other, who will have to face the loss of their mother, a scientist obsessed with wormholes.","genre_ids":[35,10751,878,18],"media_type":"movie","popularity":1.7927,"vote_count":50,"poster_path":"/r0Vi8FA4o5fxVG76WQF3WxKmgjR.jpg","release_date":"2023-09-01","vote_average":7.2,"backdrop_path":"/bvR4HcVVpZBtChDPJeGHOoiHGuR.jpg","original_title":"¡Salta!","original_language":"es"},{"id":634521,"adult":false,"title":"The Promised Neverland","video":false,"overview":"A number of children are being well fed, taken care of, and pampered at a very meticulate and managed orphanage. The facility and grounds are impressive, but the wall acting as a barrier is high. There is a secret to the place and once revealed to several orphans, they're desperate to escape.","genre_ids":[28,14,9648,12,53],"media_type":"movie","popularity":1.1437,"vote_count":65,"poster_path":"/7tMAledkia9p72zON1nLRlyfHO7.jpg","release_date":"2020-12-18","vote_average":7.262,"backdrop_path":"/iy08wTsqcWYT2PFTEWFYcxepLeB.jpg","original_title":"約束のネバーランド","original_language":"ja"},{"id":1148713,"adult":false,"title":"The Courier","video":false,"overview":"After shrewdly seizing his chance to join a money-laundering scheme, a modest valet dives into a world of fast cash, fast cars — and an inevitable crash.","genre_ids":[53,80],"media_type":"movie","popularity":3.4431,"vote_count":170,"poster_path":"/1IRKYqQXXleihbzaFXeDU1TdxKP.jpg","release_date":"2024-01-19","vote_average":6.415,"backdrop_path":"/6SukPXIL4ipy2JptYaTgeYnRD0p.jpg","original_title":"El correo","original_language":"es"},{"id":996154,"adult":false,"title":"Black Lotus","video":false,"overview":"An ex-special forces operative wages a one man war through the streets of Amsterdam to rescue his friend's daughter from the local crime syndicate.","genre_ids":[28,80,9648,53],"media_type":"movie","popularity":2.5828,"vote_count":188,"poster_path":"/y3AeW200hqGLxoPyHMDHpzudylz.jpg","release_date":"2023-04-12","vote_average":6.383,"backdrop_path":"/hvqNAz3cq48sh9GKxu4lPiogfBo.jpg","original_title":"Black Lotus","original_language":"en"},{"id":1047020,"adult":false,"title":"The Last Stop in Yuma County","video":false,"overview":"While awaiting the next fuel truck at a middle-of-nowhere Arizona rest stop, a traveling young knife salesman is thrust into a high-stakes hostage situation by the arrival of two similarly stranded bank robbers with no qualms about using cruelty—or cold, hard steel—to protect their bloodstained, ill-gotten fortune.","genre_ids":[53,80,18],"media_type":"movie","popularity":2.1706,"vote_count":324,"poster_path":"/u6ae2MMh8PpSamO3cIttLM5B18v.jpg","release_date":"2024-05-10","vote_average":6.943,"backdrop_path":"/2s4KvAxS9igmXZkhrxqzztAykGB.jpg","original_title":"The Last Stop in Yuma County","original_language":"en"},{"id":1104844,"adult":false,"title":"BLUE LOCK THE MOVIE -EPISODE NAGI-","video":false,"overview":"When apathetic gamer Nagi agrees to join his rich classmate Mikage in soccer, their partnership leads to the famous Blue Lock program — and to changes.","genre_ids":[16,28,18],"media_type":"movie","popularity":3.387,"vote_count":220,"poster_path":"/yZYZqT1f6rddhiSdjl8NVVCoZKE.jpg","release_date":"2024-04-19","vote_average":7.414,"backdrop_path":"/dJwclPgKPnV7hX3OSlvSBiCmuvB.jpg","original_title":"劇場版ブルーロック -EPISODE 凪-","original_language":"ja"},{"id":1008953,"adult":false,"title":"Incoming","video":false,"overview":"Their first week of high school. The biggest party of the year. Mistakes will be made as four teenage boys navigate a night of mayhem and debauchery.","genre_ids":[35],"media_type":"movie","popularity":4.2875,"vote_count":337,"poster_path":"/k2ySukuAiAarLns0yttKS3jg85Y.jpg","release_date":"2024-08-22","vote_average":6.2,"backdrop_path":"/1XmbgjIpqpdnSBaEzN0YaaaZObd.jpg","original_title":"Incoming","original_language":"en"},{"id":539649,"adult":false,"title":"The Lie","video":false,"overview":"A father and daughter are on their way to dance camp when they spot the girl's best friend on the side of the road. When they stop to offer the friend a ride, their good intentions soon result in terrible consequences.","genre_ids":[27,9648,53],"media_type":"movie","popularity":1.5558,"vote_count":775,"poster_path":"/a3c5zUOIEXAFYFf0vyypBCNJepb.jpg","release_date":"2018-09-13","vote_average":6.369,"backdrop_path":"/yRzsHHUbgsgEQ2ZNxYtvujaTer9.jpg","original_title":"The Lie","original_language":"en"},{"id":1242434,"adult":false,"title":"Highest 2 Lowest","video":false,"overview":"When a titan music mogul, widely known as having the \"best ears in the business\", is targeted with a ransom plot, he is jammed up in a life-or-death moral dilemma.","genre_ids":[53,80,18],"media_type":"movie","popularity":4.0792,"vote_count":434,"poster_path":"/RFQtinuiHhOnbmJaCn3uzegCYF.jpg","release_date":"2025-08-14","vote_average":5.494,"backdrop_path":"/94KROr9xO9u5Tq5gTdCJlVRRfhm.jpg","original_title":"Highest 2 Lowest","original_language":"en"},{"id":456929,"adult":false,"title":"Champions","video":false,"overview":"A disgraced basketball coach is given the chance to coach Los Amigos, a team of players who are intellectually disabled, and soon realizes they just might have what it takes to make it to the national championships.","genre_ids":[35,10751,18],"media_type":"movie","popularity":1.058,"vote_count":763,"poster_path":"/m5z4Ud6Ya5EY3Eg3OBbVBaDKWK.jpg","release_date":"2018-04-06","vote_average":7.506,"backdrop_path":"/8s231Ufkl9jF2JVnoZtQUxPXsSl.jpg","original_title":"Campeones","original_language":"es"},{"id":1357633,"adult":false,"title":"Solo Leveling -ReAwakening-","video":false,"overview":"Over a decade after 'gates' connecting worlds appeared, awakening 'hunters' with superpowers, weakest hunter Sung Jinwoo encounters a double dungeon and accepts a mysterious quest, becoming the only one able to level up, changing his fate. A catch-up recap of the first season coupled with an exclusive sneak peek of the first two episodes of the highly anticipated second season in one momentous theatrical fan experience.","genre_ids":[28,12,14,16],"media_type":"movie","popularity":12.0327,"vote_count":259,"poster_path":"/dblIFen0bNZAq8icJXHwrjfymDW.jpg","release_date":"2024-11-26","vote_average":7.075,"backdrop_path":"/hlfu6g0h0D65SjkVhQBU20zePTl.jpg","original_title":"俺だけレベルアップな件 -ReAwakening-","original_language":"ja"},{"id":704673,"adult":false,"title":"Trigger Warning","video":false,"overview":"A Special Forces commando uncovers a dangerous conspiracy when she returns to her hometown looking for answers into her beloved father's death.","genre_ids":[28],"media_type":"movie","popularity":2.9112,"vote_count":560,"poster_path":"/6XJM3C47iGOK9nFU6yLFCSf4U5c.jpg","release_date":"2024-06-20","vote_average":5.701,"backdrop_path":"/cmgjr2saprHvYw6Ee7MUIqGVQHn.jpg","original_title":"Trigger Warning","original_language":"en"},{"id":440597,"adult":false,"title":"Wish Upon","video":false,"overview":"A teenage girl discovers a box with magical powers, but those powers comes with a deadly price.","genre_ids":[27,53,14],"media_type":"movie","popularity":1.6813,"vote_count":1449,"poster_path":"/u0vnocj57vJt5DHoBEqUOD1G4SU.jpg","release_date":"2017-07-07","vote_average":5.73,"backdrop_path":"/rYpOaLb908aDspCuaa1o7nn5Bf.jpg","original_title":"Wish Upon","original_language":"en"}],"similar_content":[{"id":1254808,"adult":false,"title":"Nouvelle Vague","video":false,"overview":"After writing for Cahiers du cinéma, a young Jean-Luc Godard decides making films is the best film criticism. He convinces producer Georges de Beauregard to fund a low-budget feature, and creates a treatment with fellow New Wave filmmaker François Truffaut about a gangster couple. The result? Breathless, one of the first features of the Nouvelle Vague era of French cinema.","genre_ids":[35,18,36],"popularity":6.2815,"vote_count":115,"poster_path":"/AfE7DZ0DPgme6I58dlYp1Bo9xeN.jpg","release_date":"2025-10-08","vote_average":7.326,"backdrop_path":"/c15Fg4jvclF5VjxCi1mtjUg4a6H.jpg","original_title":"Nouvelle Vague","original_language":"fr"},{"id":859453,"adult":false,"title":"The Getaway King","video":false,"overview":"Comedy about Zdzisław Najmrodzki, most famous polish criminal in the times of Polish People Republic, named \"the getaway king\", known for stealing cars and escaping prison many times, but never hurting anybody.","genre_ids":[35,80,28],"popularity":0.4695,"vote_count":75,"poster_path":"/dfoudpFhAo5Mn8Sqyuu4Y006ITQ.jpg","release_date":"2021-09-17","vote_average":6.24,"backdrop_path":"/tE2vhFinKbyPXmiq5mjnRNLenhM.jpg","original_title":"Najmro","original_language":"pl"},{"id":5121,"adult":false,"title":"The Sugarland Express","video":false,"overview":"Married small-time crooks Lou-Jean and Clovis Poplin lose their baby to the state of Texas and resolve to do whatever it takes to get him back. Lou-Jean gets Clovis out of jail, and the two steal their son from his foster home, in addition to taking a highway patrolman hostage. As a massive dragnet starts to pursue them across Texas, the couple become unlikely folk heroes and even start to bond with the captive policeman.","genre_ids":[80,18,35],"popularity":2.0518,"vote_count":443,"poster_path":"/csahjHhtJ9NzFKcxVcw7S4Pyfj.jpg","release_date":"1974-03-31","vote_average":6.607,"backdrop_path":"/cssKLoKClpgqaaGD2z3cjXgzPSM.jpg","original_title":"The Sugarland Express","original_language":"en"},{"id":5257,"adult":false,"title":"The Dish","video":false,"overview":"A group of maverick scientists on a remote Australian sheep farm are the globe's only hope for obtaining the epic images of man's first steps on the moon.","genre_ids":[35,18,36],"popularity":0.6064,"vote_count":221,"poster_path":"/zG83o1wpU3p7QTd382K4HtctLq0.jpg","release_date":"2000-10-19","vote_average":6.713,"backdrop_path":"/rY1FcmerUUU32VcDJ4ylZrTkH6.jpg","original_title":"The Dish","original_language":"en"},{"id":14820,"adult":false,"title":"Music Within","video":false,"overview":"After a confrontation with one of his idols dashes his dreams of studying public speaking in college, Richard Pimentel joins the Army and ships off to Vietnam. During his service, Richard loses nearly all of his hearing. Joining a new circle of friends, including a man with cerebral palsy and an alcoholic war veteran, Richard discovers his gift for motivational speaking and becomes an advocate for people with disabilities.","genre_ids":[35,18],"popularity":0.5006,"vote_count":71,"poster_path":"/9KwG84rESQbWjnY3nuQ7vVleC6Q.jpg","release_date":"2007-01-05","vote_average":6.408,"backdrop_path":"/sr4b1mf98CKf0FYOcIbOmdJva5m.jpg","original_title":"Music Within","original_language":"en"},{"id":12109,"adult":false,"title":"It's All Gone Pete Tong","video":false,"overview":"A comedy following the tragic life of the legendary Frankie Wilde. The story takes us through Frankie's life from being one of the best DJs alive, through a subsequent battle with a hearing disorder, culminating in his mysterious disappearance from the scene.","genre_ids":[18,35,10402],"popularity":0.6232,"vote_count":199,"poster_path":"/4AvbVwbejmSMKGEdLmVYDLAss1i.jpg","release_date":"2004-09-12","vote_average":6.6,"backdrop_path":"/l5WLJIio1trouTEFGP69d0fr2DF.jpg","original_title":"It's All Gone Pete Tong","original_language":"en"},{"id":281285,"adult":false,"title":"Crossover Dreams","video":false,"overview":"Salsa singer screws over everybody on his way to the top; when his latest record flops, his career starts doing downhill.","genre_ids":[10402,35,18],"popularity":0.2216,"vote_count":4,"poster_path":null,"release_date":"1985-08-23","vote_average":4.75,"backdrop_path":null,"original_title":"Crossover Dreams","original_language":"en"},{"id":11091,"adult":false,"title":"Riding in Cars with Boys","video":false,"overview":"In 1965, a young woman with dreams of becoming a writer has a son at the age of 15 and struggles to make things work with the drug-addicted father.","genre_ids":[18,35],"popularity":1.7663,"vote_count":473,"poster_path":"/lz8FCZAzfr2gzju6YM4s7UCZugL.jpg","release_date":"2001-10-19","vote_average":6.736,"backdrop_path":"/wXax3nRWlZDfRqgrmBIKfE2OnaJ.jpg","original_title":"Riding in Cars with Boys","original_language":"en"},{"id":478376,"adult":false,"title":"Perfect Revolution","video":false,"overview":"Kuma is an author, a sex obsessive and a wheelchair user. Beautiful and volatile Ryoko is unlike anybody he’s ever met before. She barrages into one of his lectures, demanding to know why he only talks of sex, not love, before declaring her own affection. It’s the first of many inappropriate acts by Ryoko and the start of a relationship that is by turns sweet, strange and toxic. Ryoko hopes that she and Kuma’s love can change the world. What she fails to realise is that sometimes it’s the small gestures, not the grand ones, that feel most revolutionary.","genre_ids":[35,10749],"popularity":0.3214,"vote_count":2,"poster_path":"/d49ZaAmLeXM0yODd1wRVIQxb3s7.jpg","release_date":"2017-09-29","vote_average":6,"backdrop_path":null,"original_title":"パーフェクト・レボリューション","original_language":"ja"},{"id":13929,"adult":false,"title":"Geri's Game","video":false,"overview":"An aging codger named Geri plays a daylong game of chess in the park against himself. Somehow, he begins losing to his livelier opponent. But just when the game's nearly over, Geri manages to turn the tables.","genre_ids":[16,35,10751],"popularity":1.1537,"vote_count":1193,"poster_path":"/8PdCk3T9EkcKniUviDogWFCXx28.jpg","release_date":"1997-11-24","vote_average":7.634,"backdrop_path":"/3nqjJeI5XVxWayIgoYzrDUCdBZA.jpg","original_title":"Geri's Game","original_language":"en"},{"id":8696,"adult":false,"title":"Calendar Girls","video":false,"overview":"Members of a Yorkshire branch of the Women's Institute cause controversy when they pose nude for a charity calendar.","genre_ids":[18,35],"popularity":3.2174,"vote_count":397,"poster_path":"/yy2cPwrnUquMCmShrf8TbYu6emd.jpg","release_date":"2003-09-02","vote_average":6.531,"backdrop_path":"/mB23ce4CxfUwSb9Y6YY8NPLyy2E.jpg","original_title":"Calendar Girls","original_language":"en"},{"id":9403,"adult":false,"title":"Private Parts","video":false,"overview":"The life and career of shock-jock superstar Howard Stern is recounted from his humble beginnings to his view from the top. Possessing a desire to be an on-air personality since childhood, Stern meanders through the radio world, always with his supportive wife, Alison, by his side. Landing a gig in Washington, D.C., Stern meets Robin Quivers, who will become his long-time partner in crime. When the two move to New York, they face the wrath of NBC executives.","genre_ids":[35,18],"popularity":3.6707,"vote_count":369,"poster_path":"/8nCc9fhXCVvetlqpxkrCTc9NwOz.jpg","release_date":"1997-03-07","vote_average":6.455,"backdrop_path":"/liPn0q65pOXosCpkr0BTbTHjbRT.jpg","original_title":"Private Parts","original_language":"en"},{"id":471992,"adult":false,"title":"Let's See How Fast This Baby Will Go","video":false,"overview":"Pregnant and in labour, a teenager decides the best way to get to the hospital is to buy a new car. Based on Gloria Harrison's true story.","genre_ids":[18,35],"popularity":0.1663,"vote_count":0,"poster_path":"/3FeLL2nNtR3tnaDfrPOPGJ5atjb.jpg","release_date":"2017-08-13","vote_average":0,"backdrop_path":"/zZTreEnr2dcoJBBhvN4F782KWAW.jpg","original_title":"Let's See How Fast This Baby Will Go","original_language":"en"},{"id":475066,"adult":false,"title":"Vacancy","video":false,"overview":"A group of friends try camping when something lurking outside ruins the fun.","genre_ids":[35,27],"popularity":0.2271,"vote_count":1,"poster_path":"/UqQf5WzED4p3Yru2aClE6maH3a.jpg","release_date":"2017-10-27","vote_average":9,"backdrop_path":"/vQBELEToi0LJeoJi3MT0R3jDjeh.jpg","original_title":"Vacancy","original_language":"en"},{"id":11318,"adult":false,"title":"The Madness of King George","video":false,"overview":"Aging King George III of England is exhibiting signs of madness, a problem little understood in 1788. As the monarch alternates between bouts of confusion and near-violent outbursts of temper, his hapless doctors attempt the ineffectual cures of the day. Meanwhile, Queen Charlotte and Prime Minister William Pitt the Younger attempt to prevent the king's political enemies, led by the Prince of Wales, from usurping the throne.","genre_ids":[35,18,36],"popularity":0.8962,"vote_count":254,"poster_path":"/1dTSY023ZyBbgVSKDRuA6JLGSnZ.jpg","release_date":"1994-12-28","vote_average":6.8,"backdrop_path":"/2Rf6jQMHGDZpzoeoNdBLbCyRCK7.jpg","original_title":"The Madness of King George","original_language":"en"},{"id":1073413,"adult":false,"title":"Phenomena","video":false,"overview":"Madrid, Spain, 1998. The many resources and skills of Gloria, Paz and Sagrario, three middle-aged women investigating paranormal events, are put to the test when their leader, Father Pilón, has an unpleasant encounter.","genre_ids":[35,27,53],"popularity":0.7679,"vote_count":156,"poster_path":"/haez6rp