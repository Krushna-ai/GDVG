9:{"metadata":[["$","title","0",{"children":"Checkmates | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Candela, the headmistress of an elite school, after a traumatic divorce, returns to her old high school to lead a group of rebellious students through chess. There she will learn that in chess, and in life, it doesn't matter if you are a king or a pawn, because everyone ends up in the same box."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148438/checkmates"}],["$","meta","5",{"property":"og:title","content":"Checkmates"}],["$","meta","6",{"property":"og:description","content":"Candela, the headmistress of an elite school, after a traumatic divorce, returns to her old high school to lead a group of rebellious students through chess. There she will learn that in chess, and in life, it doesn't matter if you are a king or a pawn, because everyone ends up in the same box."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148438/checkmates"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/epxMmvLaQmInLeRNOIMfRaJrhSZ.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Checkmates"}],["$","meta","12",{"name":"twitter:description","content":"Candela, the headmistress of an elite school, after a traumatic divorce, returns to her old high school to lead a group of rebellious students through chess. There she will learn that in chess, and in life, it doesn't matter if you are a king or a pawn, because everyone ends up in the same box."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/epxM