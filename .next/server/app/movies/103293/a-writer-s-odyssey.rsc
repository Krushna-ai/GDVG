9:{"metadata":[["$","title","0",{"children":"A Writer's Odyssey | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Kongwen Lu is the author of a fantasy novel series following a heroic teenager, also named Kongwen, on a quest to end the tyrannical rule of Lord Redmane, under the guidance of a Black Armor. But through a strange twist of fate, the fantasy world of the novel begins to impact life in the real world, leading Guan Ning to accept a mission from Tu Ling to kill the author."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/103293/a-writer-s-odyssey"}],["$","meta","5",{"property":"og:title","content":"A Writer's Odyssey"}],["$","meta","6",{"property":"og:description","content":"Kongwen Lu is the author of a fantasy novel series following a heroic teenager, also named Kongwen, on a quest to end the tyrannical rule of Lord Redmane, under the guidance of a Black Armor. But through a strange twist of fate, the fantasy world of the novel begins to impact life in the real world, leading Guan Ning to accept a mission from Tu Ling to kill the author."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/103293/a-writer-s-odyssey"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/7hEhhmAF8Tr7g95fkbuxDpeR27b.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"A Writer's Odyssey"}],["$","meta","12",{"name":"twitter:description","content":"Kongwen Lu is the author of a fantasy novel series following a heroic teenager, also named Kongwen, on a quest to end the tyrannical rule of Lord Redmane, under the guidance of a Black Armor. But through a strange twist of fate, the fantasy world of the novel begins to impact life in the real world, leading Guan Ning to accept a mission from Tu Ling to kill the author."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/7hEhhmAF8Tr7g95fkbuxDpeR27b.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
