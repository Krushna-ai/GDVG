2SsqwX882QhtTE7S5IoujeygWbi.jpg","iso_639_1":null,"vote_average":1.75},{"width":1525,"height":858,"file_path":"/9XtU3HVnYx2esRPlzqrzixrFkcY.jpg","iso_639_1":null,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/rDrc51pmicFppEXUMWvofCVvLn5.jpg","iso_639_1":null,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/64JQwBltthbnn0ceRA8o2Txmhlr.jpg","iso_639_1":null,"vote_average":1.75},{"width":2180,"height":1226,"file_path":"/c2s6KbOm4yOkQgIdUYUpi95R1ww.jpg","iso_639_1":null,"vote_average":0},{"width":2172,"height":1222,"file_path":"/fmx6EggGUV9CEhyiPMUYfOGhIJm.jpg","iso_639_1":null,"vote_average":0},{"width":1525,"height":858,"file_path":"/eEcMh5mkiStV9vUZ12p3p5rQvbd.jpg","iso_639_1":null,"vote_average":0},{"width":1525,"height":858,"file_path":"/t3POPGsvQ4AsnA6KwZ2diyDAUpk.jpg","iso_639_1":null,"vote_average":0},{"width":1525,"height":858,"file_path":"/puEs0a7SYiWBVsSuL6pGI9YYrlR.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/saymQ9wdR4zObhbVPYwzCshKdZV.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-02-21T15:39:32.122+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"White Snake: Afloat","runtime":133,"tagline":"Life is ever-changing, but love remains unchanged.","homepage":"","overview":"Xiaobai finally found Xu Xian, the reincarnation of Axuan, after 500 years, the two met on the Broken Bridge. Xiaobai and sister hid in the streets and alleys, started a lively life in human world with him and his brother-in-law Li Gongfu."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":133,"tagline":"","homepage":"","overview":"南宋临安，小白五百年后终于觅得阿宣的转世——许仙，二人断桥相遇。小白小青隐身街巷，和许仙还有姐夫李公甫一起开始了人间的热闹生活。却不想杭州城中突发怪事，金山寺法海除妖而来，意外揭开了小白和小青的蛇妖身份，许仙惊恐目睹小白化身巨蟒……　浮生中这一场生死情劫，许仙值得吗？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Белая Змея: Жизнь на воде","runtime":133,"tagline":"","homepage":"","overview":"Сяобай спустя 500 лет наконец-то нашла Сюй Сяня, реинкарнацию Асуаня, они встретились на Сломанном мосту. Сяобай  и её сестра скрываясь на улицах и переулках и начали жить в мире людей вместе с Сюй Сянем и его шурином Ли Гунфу."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"White Snake: Afloat","runtime":133,"tagline":"","homepage":"","overview":"Después de 500 años, Xiaobai se reúne con Xu Xian, la reencarnación de Axuan, en el Puente Roto. Se esconden en callejones, comenzando una vida aventurera con la hermana de Xiaobai y su cuñado."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":133,"tagline":"","homepage":"","overview":"南宋杭州，小白和小青尋找到阿宣的轉世——許仙，小白與許仙終成夫妻。二人開辦保安堂治病救人，卻被法海識破小白與小青的妖怪身份，要阻止小白與許仙在一起。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"白蛇 3：浮生","runtime":133,"tagline":"","homepage":"","overview":"南宋杭州，小白和小青尋找到阿宣的轉世——許仙，小白與許仙終成夫妻。二人開辦保安堂治病救人，卻被法海識破小白與小青的妖怪身份，要阻止小白與許仙在一起。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Bạch Xà 3: Phù Sinh","runtime":133,"tagline":"","homepage":"","overview":"Tại Lâm An thời Nam Tống, Tiểu Bạch cuối cùng đã tìm thấy Hứa Tiên, hóa thân của A Tuyên sau năm trăm năm, và hai người gặp nhau qua một cây cầu. Hai người bắt đầu cuộc sống sôi động trên thế giới cùng tại Hàng Châu. Tuy nhiên Pháp Hải từ chùa Kim Sơn đến để diệt trừ ma quỷ và bất ngờ tiết lộ danh tính của Tiểu Bạch và Tiểu Thanh"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"مار سفید: شناور","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"백사: 부생","runtime":0,"tagline":"삶은 끊임없이 변하지만, 사랑은 변하지 않는다.","homepage":"","overview":"샤오바이는 500년 만에 아쉬안의 환생인 쉬셴을 마침내 찾아냈고, 두 사람은 단교(브로큰 브리지)에서 만났다. 샤오바이와 그녀의 언니는 거리와 골목에 몸을 숨긴 채, 쉬셴과 그의 매형 리공푸와 함께 인간 세상에서 활기찬 삶을 시작했다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"A Serpente Branca: À tona","runtime":133,"tagline":"","homepage":"","overview":"Xiaobai finalmente encontrou Xu Xian, a reencarnação de Axuan, depois de 500 anos, os dois conheceram-se na Ponte Quebrada. Xiaobai e a sua irmã esconderam-se nas ruas e becos e começaram uma vida animada no mundo dos humanos com ele e o seu cunhado Li Gongfu."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"נחש לבן: צף","runtime":0,"tagline":"","homepage":"","overview":""},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"White Snake: Afloat","runtime":0,"tagline":"","homepage":"","overview":"เล่าเรื่องราวของ เสี่ยวไป๋ (ไป๋ซู่เจิน) ปีศาจงูขาวที่ต้องต่อสู้กับอิทธิพลจากโลกปีศาจ เพื่อปกป้อง ซูเซียน (ซูเปี่ยว) ชายหนุ่มผู้เป็นที่รักที่กลับชาติมาเกิดจากภาคแรก เรื่องราวเน้นไปที่การเดินทางของเสี่ยวไป๋ในภารกิจลับ ซึ่งทำให้เธอต้องเผชิญหน้ากับความทรงจำที่ถูกผนึกไว้ และความพยายามในการต่อสู้กับอำนาจที่พยายามดึงเธอกลับสู่โลกปีศาจ"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"White Snake - Afloat","runtime":0,"tagline":"","homepage":"","overview":"Blanca (Xiao bai) a finalement trouvé Xu Xian, la réincarnation d’Axuan, après 500 ans, sur le Pont Brisé. Sa sœur Verta (Xiao Qing) et elle, cachées dans les rues de la ville, commencent une vie animée dans le monde des humains avec lui et son beau frère Li Gongfu."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"White Snake: Afloat","runtime":133,"tagline":"","homepage":"","overview":"Después de 500 años, Xiaobai se reúne con Xu Xian, la reencarnación de Axuan, en el Puente Roto. Se esconden en callejones, comenzando una vida aventurera con la hermana de Xiaobai y su cuñado."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"White Snake: Afloat","runtime":0,"tagline":"A vida está em constante mudança, mas o amor permanece o mesmo.","homepage":"","overview":"Após 500 anos, Xiaobai finalmente encontrou Xu Xian, a reencarnação de Axuan. Os dois se encontraram na Ponte Quebrada. Xiaobai e sua irmã se esconderam nas ruas e vielas, e começaram uma vida agitada no mundo humano com ele e seu cunhado, Li Gongfu."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"}],"reviews_tmdb":[],"recommendations":[{"id":995926,"adult":false,"title":"I, the Executioner","video":false,"overview":"The veteran detective Seo Do-cheol and his team at Major Crimes, relentless in their pursuit of criminals, join forces with rookie cop Park Sun-woo to track down a serial killer who has plunged the nation into turmoil.","genre_ids":[28,80,35],"media_type":"movie","popularity":2.965,"vote_count":90,"poster_path":"/gAtP0usArK5gVOBObnsENKLwML8.jpg","release_date":"2024-09-13","vote_average":6.9,"backdrop_path":"/bA4Io3xv46oEyP4O51uU0EKbluF.jpg","original_title":"베테랑 2","original_language":"ko"},{"id":36113,"adult":false,"title":"Getting Home","video":false,"overview":"A black comedy about a farmer who tries to bring home the body of his friend, who died far from their town.","genre_ids":[18,35],"media_type":"movie","popularity":0.4682,"vote_count":61,"poster_path":"/l3ESk3iFDhrLWKeFnzlsPCS7s7j.jpg","release_date":"2007-12-31","vote_average":7.287,"backdrop_path":"/f1EyhhFCXDw1aTlBzrLRrbBcCTb.jpg","original_title":"落叶归根","original_language":"zh"},{"id":347200,"adult":false,"title":"Code Geass: Akito the Exiled 3: The Brightness Falls","video":false,"overview":"After discovering the face of their true enemy, someone who is related to Akito and responsible for the Geass placed upon him, W-0 attempts to return to their base at Castle Weisswolf. However, stranded in Warsaw due to a complication involving their military identification, they are forced to accept the help of local gypsies, allowing the squad to take some time to deepen their bonds. Meanwhile, Britannian advisor Julius Kingsley and his guard Suzaku Kururugi begin working together with the Knights of St. Michael in order to crush the European resistance once and for all, armed with the destructive power of a giant weapon known as the Ark Fleet.","genre_ids":[28,16,878],"media_type":"movie","popularity":1.4636,"vote_count":54,"poster_path":"/n7ajLedWF7AFMwkUVXhowNZG3cA.jpg","release_date":"2015-05-02","vote_average":6.398,"backdrop_path":"/8fGYIoxjKS2IfiniLaTHt1ebLv6.jpg","original_title":"コードギアス 亡国のアキト 第3章「輝くもの天より堕つ」","original_language":"ja"},{"id":1425617,"adult":false,"title":"Another You","video":false,"overview":"Mümtaz and Derya are condemned to live out their last moments each day in someone else's skin.","genre_ids":[35,10749],"media_type":"movie","popularity":1.0165,"vote_count":37,"poster_path":"/vfEbhAzhKavunGOFiOknVtY0NiD.jpg","release_date":"2025-03-07","vote_average":6.622,"backdrop_path":"/j4oYX4LgNnoRYHnkafGYeyVLULi.jpg","original_title":"Başka Bir Sen","original_language":"tr"},{"id":250578,"adult":false,"title":"Leave the World Behind","video":false,"overview":"A music documentary following the breakup of Swedish House Mafia and their subsequent One Last Tour. The largest electronic tour in history, selling over 1 million tickets in one week. Director Christian Larson captures the band in a unique fly on the wall manner as they call it quits and seek closure by going on the tour they had always dreamed of. With breathtaking live moments, huge laughs and dark lows, the band start to unravel why they came to the decision to end the biggest achievement of their lives to date to save their friendship.  The film maps out three of the biggest stars in a scene which has gripped youth the world over and the psychology of the band. A film not to be missed.","genre_ids":[99,10402],"media_type":"movie","popularity":0.1794,"vote_count":46,"poster_