5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"White Snake: Afloat\",\"description\":\"Xiaobai finally found Xu Xian, the reincarnation of Axuan, after 500 years, the two met on the Broken Bridge. Xiaobai and sister hid in the streets and alleys, started a lively life in human world with him and his brother-in-law Li Gongfu.\",\"image\":\"https://image.tmdb.org/t/p/w500/mTszIRmU7zKm4Nl03uEhlcQ5Dkz.jpg\",\"datePublished\":\"2024-07-30\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"CN\",\"inLanguage\":\"zh\",\"genre\":[\"Animation\",\"Romance\",\"Comedy\",\"Fantasy\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.867,\"bestRating\":10,\"ratingCount\":30}}"}}],["$","$L10",null,{"initialDrama":{"id":"339eea6d-8751-48ce-8102-9e0abef54bf5","tmdb_id":1207123,"imdb_id":"tt30836045","content_type":"movie","title":"White Snake: Afloat","original_title":"白蛇：浮生","overview":"Xiaobai finally found Xu Xian, the reincarnation of Axuan, after 500 years, the two met on the Broken Bridge. Xiaobai and sister hid in the streets and alleys, started a lively life in human world with him and his brother-in-law Li Gongfu.","poster_path":"/mTszIRmU7zKm4Nl03uEhlcQ5Dkz.jpg","backdrop_path":"/1d4IhfrOQFltNjwuiajUDmOvfW1.jpg","release_date":"2024-07-30","first_air_date":null,"status":"published","original_language":"zh","origin_country":["CN"],"genres":[{"id":16,"name":"Animation"},{"id":10749,"name":"Romance"},{"id":35,"name":"Comedy"},{"id":14,"name":"Fantasy"}],"popularity":2.8541,"vote_average":7.867,"vote_count":30,"runtime":133,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-29T21:51:04.256611+00:00","updated_at":"2026-02-21T15:39:17.183+00:00","tagline":"Life is ever-changing, but love remains unchanged.","homepage":null,"budget":0,"revenue":59307515,"production_companies":[{"id":67089,"name":"Light Chaser Animation Studios","logo