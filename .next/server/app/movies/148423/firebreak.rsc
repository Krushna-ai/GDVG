count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T06:06:37.768+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.netflix.com/es/title/81744440","overview":"Mientras su familia empaqueta su casa de campo para venderla, la pequeña Lide desaparece y se desata un incendio, empujando a su madre a una carrera contrarreloj para encontrarla."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Corta-fogo","runtime":0,"tagline":"","homepage":"https://www.netflix.com/br/title/81744440","overview":"A pequena Lide desaparece na floresta enquanto a família se prepara para deixar a casa. Agora, sua mãe precisa encontrá-la antes do incêndio que se aproxima."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Firebreak","runtime":107,"tagline":"","homepage":"https://www.netflix.com/title/81744440","overview":"Little Lide disappears in the forest while her family packs up their home. As a fire breaks out, her mother must race to reach her before the flames do."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Coupe-feu","runtime":0,"tagline":"","homepage":"https://www.netflix.com/fr/title/81744440","overview":"Tandis que sa famille fait le vide dans sa maison d'été, la petite Lide disparaît dans la forêt. Quand un incendie se déclare, sa mère se précipite pour la sauver des flammes."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":107,"tagline":"","homepage":"https://www.netflix.com/mx/title/81744440","overview":"Mientras su familia se prepara para mudarse, Lide desaparece en el bosque. Durante su ausencia, se desata un incendio, y su madre debe encontrarla antes de que lo hagan las llamas."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Cortafuego – Umgeben von Feuer","runtime":0,"tagline":"","homepage":"https://www.netflix.com/de/title/81744440","overview":"Die kleine Lide verschwindet im Wald, während ihre Familie alles zusammenpackt. Als ein Feuer im Wald ausbricht, macht sich ihre Mutter auf die Suche."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Brandgata","runtime":0,"tagline":"","homepage":"https://www.netflix.com/se/title/81744440","overview":"Lilla Lide försvinner i skogen medan familjen packar inför flytten, och när en skogsbrand bryter ut försöker hennes mamma nå henne innan lågorna gör det."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.netflix.com/nl/title/81744440","overview":"De kleine Lide verdwijnt in het bos terwijl de rest van het gezin bezig is met inpakken. Wanneer er brand uitbreekt, moet haar moeder haar vinden voordat het vuur haar bereikt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Zatrzymać pożar","runtime":0,"tagline":"","homepage":"https://www.netflix.com/pl/title/81744440","overview":"Mała Lide znika w lesie, gdy jej rodzina przygotowuje się do opuszczenia domu. Gdy wybucha pożar, matka dziewczynki musi ją odnaleźć, zanim dosięgnie ją ogień."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"https://www.netflix.com/it/title/81744440","overview":"La piccola Lide scompare nel bosco mentre la famiglia si prepara a partire. Quando scoppia un incendio, la madre corre contro il tempo per trovarla prima che lo facciano le fiamme."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"ファイヤーブレイク","runtime":0,"tagline":"","homepage":"https://www.netflix.com/jp/title/81744440","overview":"家族が引っ越しの準備をしている最中、幼いリデが森の中でこつ然と姿を消す。そこへ追い打ちをかけるように火災が発生。迫りくる炎の中、母は娘を救い出すことができるのか。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"파이어브레이크","runtime":0,"tagline":"","homepage":"https://www.netflix.com/kr/title/81744440","overview":"가족이 이사 준비를 하던 중, 어린 소녀 리데가 숲속에서 흔적도 없이 사라진다. 바로 그때 숲에서 번지기 시작한 불길. 엄마는 화염이 덮치기 전에 딸을 찾기 위해 시간과의 사투를 벌인다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Corta-Fogo","runtime":0,"tagline":"","homepage":"https://www.netflix.com/pt/title/81744440","overview":"A pequena Lide desaparece na floresta enquanto a família prepara a mudança. Quando deflagra um incêndio florestal, a mãe corre para chegar até ela antes das chamas."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"În calea flăcărilor","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ro/title/81744440","overview":"Micuța Lide dispare în pădure în timp ce familia împachetează lucrurile din casă. Un incendiu izbucnește în pădure și mama sa este disperată să o găsească."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Usred vatre","runtime":0,"tagline":"","homepage":"https://www.netflix.com/hr/title/81744440","overview":"Mala Lide nestane u šumi dok joj se obitelj sprema za selidbu. Kad izbije požar njezina je majka mora pronaći i spasiti od vatrene stihije."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Lángok közt","runtime":0,"tagline":"","homepage":"https://www.netflix.com/hu/title/81744440","overview":"A kis Lide eltűnik az erdőben, miközben a család kirámolja a vidéki házukat. Egy tűz kitörését követően az anyja igyekszik rátalálni, mielőtt utolérik a lángok."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"De kleine Lide verdwijnt in het bos terwijl de rest van het gezin bezig is met inpakken. Wanneer er brand uitbreekt, moet haar moeder haar vinden voordat het vuur haar bereikt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"ดับไฟอารมณ์","runtime":0,"tagline":"","homepage":"https://www.netflix.com/th/title/81744440","overview":"หนูน้อยลีเด้หายตัวไปในป่าขณะที่ครอบครัวกำลังเก็บข้าวของ และเมื่อเกิดไฟไหม้ขึ้น แม่ของหนูน้อยจึงต้องรีบตามหาเธอให้เจอ ก่อนที่เปลวไฟจะลุกลามมาถึง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Проти полумʼя","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ua/title/81744440","overview":"Доки сім’я пакує речі перед переїздом, маленька Ліде йде до лісу й губиться. Починається страшна пожежа й матір намагається дістатися до малечі раніше за полум’я."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"حاجز النار","runtime":0,"tagline":"","homepage":"https://www.netflix.com/sa/title/81744440","overview":"تختفي \"ليدي\" الصغيرة في الغابة وسط انشغال عائلتها بحزم محتويات المنزل. وحين يندلع حريق في الأرجاء، تخوض والدتها سباقًا مع الزمن لإنقاذها قبل فوات الأوان."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Průsek","runtime":0,"tagline":"","homepage":"https://www.netflix.com/cz/title/81744440","overview":"Malá Lide se ztratí, zrovna když se její rodina chystá evakuovat kvůli lesnímu požáru. Máma ji pak musí za každou cenu najít dřív, než plameny pohltí úplně všechno."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"浴火之森","runtime":0,"tagline":"","homepage":"","overview":"丈夫过世后，玛拉带着女儿莉德，与小叔子路易斯及他的妻儿，一起前往家族位于林中的避暑别墅疗伤。没想到女儿与她发生争执后消失在森林中，原本单纯的告别之旅成了一场恶梦。当难以控制的野火开始在附近延烧，情况变得更加危急，搜救行动也因火势迅速蔓延不得不暂停，当局更下令要紧急疏散。心急如焚的玛拉拒绝离开，一家人被迫做出极端决策，决定违背疏散令，前往森林里自行寻人。他们与外界断联，没有政府的协助，加上火势不断逼近，唯一的希望只剩下当地的护林员圣提亚哥。不过当情况越来越危急，玛拉开始怀疑森林大火并不是唯一的威胁，他们之中有人在说谎。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Mala Lide izgine v gozdu, medtem ko se njena družina pripravlja na selitev. Ko izbruhne požar, jo mora mama Mara najti in rešiti pred ognjenimi zublji."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"מול הלהבות","runtime":107,"tagline":"","homepage":"https://www.netflix.com/il/title/81744440","overview":"הילדה לידה נעלמת ביער בזמן שמשפחתה עסוקה באריזות. כשפורצת שריפה, אימה של לידה חייבת להתחרות בלהבות ולהגיע אליה ראשונה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Пожарът","runtime":0,"tagline":"","homepage":"","overview":"Малката Лайд изчезва в гората, докато семейството ѝ опакова дома си. Когато избухва пожар, майка ѝ трябва да се втурне да я достигне преди пламъците."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Alevlerin Ortasında","runtime":0,"tagline":"","homepage":"https://www.netflix.com/tr/title/81744440","overview":"Küçük Lide, ailesi evlerini toplarken ormanda kaybolur. Yangın çıkınca annesi, alevler ona ulaşmadan önce ona yetişmek için zamanla yarışır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Vành đai phòng lửa","runtime":0,"tagline":"","homepage":"https://www.netflix.com/vn/title/81744440","overview":"Cô bé Lide biến mất trong rừng khi cả nhà đang thu dọn để chuyển đi. Khi đám cháy bùng phát, mẹ cô bé phải gấp rút đến chỗ con gái trước khi ngọn lửa lan đến."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"Лесной пожар","runtime":107,"tagline":"","homepage":"https://www.netflix.com/ru/title/81744440","overview":"Маленькая Лиде исчезает в лесу, пока ее семья собирает вещи. Разгорается пожар, и мать должна найти девочку раньше, чем пламя."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"浴火之森","runtime":0,"tagline":"","homepage":"https://www.netflix.com/sg-zh/title/81744440","overview":"小莱德在树林里失踪，而家人正收拾房子。火灾突发，母亲必须争分夺秒，赶在大火烧到女儿之前找到她。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"حاجز النار","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ae/title/81744440","overview":"تختفي \"ليدي\" الصغيرة في الغابة وسط انشغال عائلتها بحزم محتويات المنزل. وحين يندلع حريق في الأرجاء، تخوض والدتها سباقًا مع الزمن لإنقاذها قبل فوات الأوان."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"浴火之森","runtime":0,"tagline":"","homepage":"https://www.netflix.com/hk/title/81744440","overview":"全家在打包搬家時，小莉德居然跑進森林失蹤了。豈料火苗竄起，媽媽必須與時間賽跑，在火勢蔓延前找到她。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"浴火之森","runtime":0,"tagline":"","homepage":"https://www.netflix.com/tw/title/81744440","overview":"全家在打包搬家時，小莉德居然跑進森林失蹤了。豈料火苗竄起，媽媽必須與時間賽跑，在火勢蔓延前找到她。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"फ़ायरब्रेक","runtime":0,"tagline":"","homepage":"https://www.netflix.com/in-hi/title/81744440","overview":"लिटिल लीड जंगल में गायब हो जाती है, जबकि दूसरी ओर उसका पूरा परिवार उनके घर का सामान बांधता है. आग लगने पर उसकी मां को आग की लपटों के लीड तक पहुंचने से पहले खुद पहुंचना होगा."},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"Coupe-feu","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ca-fr/title/81744440","overview":"Une fillette disparaît dans la forêt pendant que sa famille se prépare à déménager. Quand un incendie éclate, sa mère fait tout pour la rejoindre avant les flammes."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Αντιπυρική Ζώνη","runtime":0,"tagline":"","homepage":"https://www.netflix.com/gr/title/81744440","overview":"Η μικρή Λίντε εξαφανίζεται στο δάσος ενώ η οικογένειά της μαζεύει τα πράγματα του σπιτιού. Όταν ξεσπά φωτιά, η μητέρα της τρέχει να τη βρει πριν την προλάβουν οι φλόγες."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Liekkien tiellä","runtime":0,"tagline":"","homepage":"https://www.netflix.com/fi/title/81744440","overview":"Lide-tyttö katoaa metsään, kun hänen perheensä on pakkaamassa muuttoa. Seudulla syttyy metsäpalo, ja Liden äidin on löydettävä tyttärensä ennen liekkejä."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Brandvej","runtime":0,"tagline":"","homepage":"https://www.netflix.com/dk/title/81744440","overview":"Lille Lide forsvinder i skoven, mens hendes familie pakker huset ned. Der udbryder en skovbrand, og hendes mor forsøger desperat at finde hende, inden flammerne gør."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Branngate","runtime":0,"tagline":"","homepage":"https://www.netflix.com/no/title/81744440","overview":"Lille Lide forsvinner i skogen mens familien pakker flyttelasset. Når en brann bryter ut, må moren hennes skynde seg for å finne henne før flammene gjør det."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Firebreak","runtime":0,"tagline":"","homepage":"https://www.netflix.com/my/title/81744440","overview":"Kanak-kanak bernama Lide hilang di dalam hutan ketika keluarganya mengemas rumah. Apabila kebakaran berlaku, ibu Lide harus mencarinya dengan segera sebelum api merebak."},"name":"Bahasa melayu","iso_639_1":"ms","iso_3166_1":"MY","english_name":"Malay"},{"data":{"title":"Firebreak","runtime":0,"tagline":"","homepage":"https://www.netflix.com/ph/title/81744440","overview":"Naglaho sa gubat ang munting si Lide habang nag-eempake ang pamilya niya paalis ng bahay. Nang magsimula ang sunog, kailangang magmadali ng nanay niya para mahanap siya."},"name":"","iso_639_1":"tl","iso_3166_1":"PH","english_name":"Tagalog"},{"data":{"title":"Firebreak","runtime":0,"tagline":"","homepage":"https://www.netflix.com/id/title/81744440","overview":"Lide kecil hilang di hutan saat keluarganya berkemas untuk meninggalkan rumah. Ketika kebakaran terjadi, ibunya harus cepat menemukannya sebelum api membakar semuanya."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"}],"reviews_tmdb":[],"recommendations":[],"similar_content":[{"id":3170,"adult":false,"title":"Bambi","video":false,"overview":"Bambi's tale unfolds from season to season as the young prince of the forest learns about life, love, and friends.","genre_ids":[16,18,10751],"popularity":5.0868,"vote_count":5952,"poster_path":"/wV9e2y4myJ4KMFsyFfWYcUOawyK.jpg","release_date":"1942-08-14","vote_average":7.008,"backdrop_path":"/1ZKHzSGJm0kvlCp4echAOtKnDTm.jpg","original_title":"Bambi","original_language":"en"},{"id":1253347,"adult":false,"title":"Pines","video":false,"overview":"A man returns to the burnt forest where he last saw his brother.","genre_ids":[18],"popularity":0.1628,"vote_count":1,"poster_path":"/aSU950tPxXWw9NTuYGpukU4bw9I.jpg","release_date":"2024-05-09","vote_average":8.5,"backdrop_path":"/3VCvYKr6lfrpe23rU64kfjKk8io.jpg","original_title":"סוקצסיה","original_language":"he"},{"id":11352,"adult":false,"title":"Always","video":false,"overview":"The spirit of a recently deceased expert pilot mentors a newer pilot while watching him fall in love with the girlfriend that he left behind.","genre_ids":[10749,14,18],"popularity":1.3584,"vote_count":649,"poster_path":"/wh0WItAFrw3m66mDMlCCuXQwfMW.jpg","release_date":"1989-12-22","vote_average":6.248,"backdrop_path":"/pIb1CLl08DxciZXJr7AK4qmkArA.jpg","original_title":"Always","original_language":"en"},{"id":1262820,"adult":false,"title":"Wake, Bake & Vibe","video":false,"overview":"","genre_ids":[35,53,18,10751],"popularity":0.1289,"vote_count":0,"poster_path":"/mpQ71Z2B4IKMEu2zJO9iWDsBHRg.jpg","release_date":"2024-08-06","vote_average":0,"backdrop_path":"/5UUrtaVQ8zZgjz2X1oArdoBllgJ.jpg","original_title":"Wake, Bake & Vibe","original_language":"sv"},{"id":900379,"adult":false,"title":"Afire","video":false,"overview":"Self-important author Leon joins his best friend on a summer holiday near the Baltic Sea to complete his novel. When they arrive, they find their house is already occupied by a carefree woman who challenges Leon to open up. Meanwhile, forest wildfires rage around them and impending disaster looms.","genre_ids":[18,10749,35],"popularity":0.9019,"vote_count":233,"poster_path":"/k8NYzD01zAUsdqocjhLXbO9BSS8.jpg","release_date":"2023-04-20","vote_average":6.781,"backdrop_path":"/wbW4w4HvvzDavQCjUKtLMosyNn5.jpg","original_title":"Roter Himmel","original_language":"de"},{"id":41417,"adult":false,"title":"Firestorm","video":false,"overview":"Firefighter Jesse Graves has to save ornithologist Jennifer and other people caught in a forest fire, which was set up by the lawyer of convicted killer Earl Shaye, who escaped from the prison with several of his inmates posing as firefighters to recover $37,000,000 in stashed loot.","genre_ids":[28,12,53],"popularity":0.5274,"vote_count":71,"poster_path":"/joAzHTg4xoz56zQ7AntfTYENuAD.jpg","release_date":"1998-01-08","vote_average":5.162,"backdrop_path":"/gqySr87GFNjNX3sPwRAiPzt1O05.jpg","original_title":"Firestorm","original_language":"en"},{"id":1311484,"adult":false,"title":"Fire on Kelly Mountain","video":false,"overview":"A forest service fire lookout gets his wish when he wants to fight fires, for he is sent to check out a blaze, but the fire he finds almost gets the best of him. He also has problems with an enraged bear that has been spooked by the fire.","genre_ids":[12,10751,18,10770],"popularity":0.1819,"vote_count":0,"poster_path":"/m618jyS3kplWzZdJH3K9F2Tgd75.jpg","release_date":"1973-09-30","vote_average":0,"backdrop_path":null,"original_title":"Fire on Kelly Mountain","original_language":"en"},{"id":113678,"adult":false,"title":"Savage","video":false,"overview":"A blazing fire rips its way through Bear Valley National Park. As the firefighters try to contain it, the animals are being forced out of their habitat including a beast that was better left undiscovered.","genre_ids":[27,878,53],"popularity":0.4046,"vote_count":5,"poster_path":"/fbL6tLUstuELGSSFOFkwRwOjMq9.jpg","release_date":"2011-07-11","vote_average":6.6,"backdrop_path":"/8ScdBDpZYiVZOqxXoMbG9KD3eCJ.jpg","original_title":"Savage","original_language":"en"},{"id":83539,"adult":false,"title":"Letter Never Sent","video":false,"overview":"Four geologists are searching for diamonds in the wilderness of Siberia. After a long and tiresome journey they manage to find their luck and put the diamond mine on the map. The map must be delivered back to Moscow. But on the day of their departure a terrible forest fire wreaks havoc, and the geologists get trapped in the woods.","genre_ids":[18,12],"popularity":1.3103,"vote_count":118,"poster_path":"/eBIEgVI4uMzJGvEtwS31YtgEqTP.jpg","release_date":"1960-06-27","vote_average":7.1,"backdrop_path":"/w5v52YJtol2h0KXCZzSt6Y18loA.jpg","original_title":"Неотправленное письмо","original_language":"ru"},{"id":1176953,"adult":false,"title":"Gepellte Haut","video":false,"overview":"Four young people from Berlin decide to spend their summer in Portugal. They throw away their smart phones, open up their relationships and try to free themselves from any social norms. But just as their utopia comes true, a devastating forest fire breaks out around them.","genre_ids":[18],"popularity":1.6654,"vote_count":0,"poster_path":null,"release_date":"2026-05-14","vote_average":0,"backdrop_path":null,"original_title":"Gepellte Haut","original_language":"de"},{"id":172767,"adult":false,"title":"500 MPH Storm","video":false,"overview":"When an energy experiment goes haywire, a rash of massive hurricanes rips across North America. A high school science teacher must get his family to safety before the hurricanes merge, creating a \"hypercane\" with the power to wipe the US off the map.","genre_ids":[28,878,10770,12,18,53],"popularity":0.6637,"vote_count":99,"poster_path":"/268rvZNZD7DM4D3dbE0pQQB18rT.jpg","release_date":"2013-02-28","vote_average":5.333,"backdrop_path":"/nddudkiXQbmE1cKUDQBSs4XAbME.jpg","original_title":"500 MPH Storm","original_language":"en"},{"id":395991,"adult":false,"title":"Only the Brave","video":false,"overview":"Members of the Granite Mountain Hotshots battle deadly wildfires to save an Arizona town.","genre_ids":[18,28],"popularity":4.027,"vote_count":1802,"poster_path":"/lC7WdUNLOJI3sllaDGNdFy2GT8g.jpg","release_date":"2017-09-22","vote_average":7.46,"backdrop_path":"/zaX6d5GCtb2CmOH9jrHBl58xxBY.jpg","original_title":"Only the Brave","original_language":"en"},{"id":958247,"adult":false,"title":"Dead Girls Dancing","video":false,"overview":"On a road trip across Italy, recent high school graduates Ira, Malin and Ka pick up the intriguing backpacker Zoe. As the four girls stumble across an abandoned village, they start to experiment with the limits of their newly found freedom, away from the expectations of their parents and teachers.","genre_ids":[18],"popularity":0.1937,"vote_count":6,"poster_path":"/z9u5YI684SEDGOUXusdigZnejwE.jpg","release_date":"2023-06-28","vote_average":4.6,"backdrop_path":"/2VZ7fzlyL7bALv9kL1U5YOVnVUz.jpg","original_title":"Dead Girls Dancing","original_language":"de"},{"id":1374380,"adult":false,"title":"A Fire Called Jeremiah","video":false,"overview":"This is the story of the “smoke jumpers,” specially trained by the Forest Service to reach forest fires when they are in the inaccessible areas of US National Forests. A cabin in the woods is set on fire after an over stimulated kitten upsets an oil lantern.","genre_ids":[12,10751,18],"popularity":0.1522,"vote_count":0,"poster_path":"/o29emHExo35efYdMhw5NqI6TEWw.jpg","release_date":"1961-12-03","vote_average":0,"backdrop_path":null,"original_title":"A Fire Called Jeremiah","original_language":"en"},{"id":390236,"adult":false,"title":"Law of the Timber","video":false,"overview":"PRC Pictures' final 1941 release, Law of the Timber was based on a story by North Woods specialist James Oliver Curwood.","genre_ids":[18,37],"popularity":0.1256,"vote_count":1,"poster_path":"/hgJ16KJ2unYHN5Y5Jqf0KgSYEjR.jpg","release_date":"1941-12-19","vote_average":6,"backdrop_path":"/A7VvduUwqlRRIPvWoLB8QYzESJe.jpg","original_title":"Law of the Timber","original_language":"en"},{"id":1248343,"adult":false,"title":"Xondaros - Guarani Resistance","video":false,"overview":"The 6 Guarani villages of Jaraguá, in São Paulo, fight for land rights, for human rights and for the preservation of nature. They suffer from the proximity to the city, which brings lack of resources, pollution of rivers and springs, racism, police violence, fires, lack of infrastructure and sanitation, among others. Unable to live like their ancestors, their millenary culture is lost as it merges with the urban culture.","genre_ids":[99,18],"popularity":0.1537,"vote_count":0,"poster_path":"/6eHAa5mg28KoLbcYyFmnfREpVPW.jpg","release_date":"2023-06-08","vote_average":0,"backdrop_path":null,"original_title":"Xondaros - Guarani Resistance","original_language":"gn"},{"id":376529,"adult":false,"title":"The Comb of Oroku","video":false,"overview":"Once a wealthy local land owner, Toranosuke has long since fallen on hard times. Social ostracism befalls those who neglect communal duties and Toranosuke's life goes down hill by being exiled from the village. The story evolves around brother and sister Umakichi and Oroku left alone by their father.","genre_ids":[18],"popularity":0.1225,"vote_count":0,"poster_path":null,"release_date":"1935-05-09","vote_average":0,"backdrop_path":null,"original_title":"お六櫛","original_language":"ja"},{"id":1504776,"adult":false,"title":"Wounded Edges","video":false,"overview":"In July 2022, a forest fire broke out on Monte Gambarogno in Ticino, Switzerland. Wound Edges is my emotional response to this landscape, filmed on 16mm and hand-developed with the forest’s ashes. Each frame carries physical traces of the land’s memory, blending destruction with resilience. The soundscape—field recordings, burned wood, contact microphones on trees, and the presence of fire—echoes the forest’s wounds. A reflection on human impact, impermanence, and the haunting beauty of transformation.","genre_ids":[99,9648],"popularity":0.1934,"vote_count":0,"poster_path":"/8oU5iaboHl7VBHK4LCbIloJc9GG.jpg","release_date":"2026-02-28","vote_average":0,"backdrop_path":null,"original_title":"Wounded Edges","original_language":"de"},{"id":675252,"adult":false,"title":"Megafires: The Global Threat","video":false,"overview":"For more than a decade, wildfires of unprecedented force have been devouring our lives, homes and forests at a steady pace. Each year, 350 million hectares of forest go up in smoke, the equivalent of six times the size of France. In the US, the fire season now lasts up to two months longer than a generation ago, and the surface burnt annually has multiplied by three. This film sets out on a gripping journey of investigation from Europe to the US, Canada, Brazil and Indonesia to follow the work of a global team of dedicated firefighters, scientists and fire experts as they investigate why our forests are going up in flames, and act on an unexpected discovery: if we want to save our forests, homes, health and our climate, we need to radically change our attitude towards fire and the way we fight wildfires.","genre_ids":[99],"popularity":0.2618,"vote_count":3,"poster_path":"/ge1TwRLSMekZD9jvFXqcdlrYikl.jpg","release_date":"2020-01-21","vote_average":8.333,"backdrop_path":"/tHzbC4OO5PPkHsjNhZxsZwyWAaD.jpg","original_title":"Incendies géants : enquête sur un nouveau fléau","original_language":"fr"},{"id":1477914,"adult":false,"title":"Forevergreen","video":false,"overview":"An orphaned bear cub finds a home with a fatherly evergreen tree, until his hunger for trash leads him to danger.","genre_ids":[16,10751],"popularity":0.7057,"vote_count":12,"poster_path":"/bYmb2SzWZjQvyuBItB3wcO8RAWy.jpg","release_date":"2025-05-08","vote_average":6.75,"backdrop_path":"/sYfyT266IdI86ELeVGpbEOpSIZg.jpg","original_title":"Forevergreen","original_language":"xx"}],"external_ids":{"imdb_id":"tt33474179","twitter_id":null,"facebook_id":null,"wikidata_id":"Q137916153","instagram_id":null,"rotten_tomatoes_id":"m/firebreak_2026"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148423,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AD","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-02-20T00:00:00.000Z","certification":""}]},{"iso_3166_1":"AE","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-02-20T00:00:00.000Z","certification":""}]},{"iso_3166_1":"AF","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-02-20T00:00:00.000Z","certification":""}]},{"iso_3166_1":"AG","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-02-20T00:00:00.000Z","certification":""}]},{"iso_3166_1":"AI","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-02-20T00:00:00.000Z","certification":""}]},{"iso_3166_1":"AL","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-02-20T00:00:00.000Z","certification":""}]},{"iso_3166_1":"AM","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release_date":"2026-02-20T00:00:00.000Z","certification":""}]},{"iso_3166_1":"AO","release_dates":[{"note":"Netflix","type":4,"iso_639_1":"","descriptors":[],"release