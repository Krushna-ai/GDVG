":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1280,"height":720,"file_path":"/348c4GOIeT0RQTT1fCM6PVAk8hS.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/24ACebd1Lr5moss4bVjjxDV08bT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/kLQLqZUKUF6MJ9E1AOBhkYto67O.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/sHWyL1JrEO2zY8RRji0LU3xL32z.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/3hl4tVt2lRbayVRnV4hkSiEojlp.jpg","iso_639_1":"eu","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1600,"height":900,"file_path":"/lEFKXCCcJyljVdo37dYHhWnvadV.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1600,"height":900,"file_path":"/er6hxkAHtplK69CO7sJ8HNT9otO.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/aC5f8OAgAIGyIYaZCFWWdqEHdsd.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/cWjFRt1jgUmXnCuLPDDcbJbKcrJ.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1600,"height":900,"file_path":"/gkuoThxWyLz8ofIUDPpX5JCjWQp.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1600,"height":900,"file_path":"/sJ7rHa8Ol20RQ9vYRgJIF4onz64.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:00:18.102+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Gaua (The Night)","runtime":92,"tagline":"","homepage":"https://www.filmaxinternationalsales.com/film/gaua-the-night","overview":"Spain, Basque Country, 17th century. At night and through the mountains, Kattalin escapes from her farmhouse and, while wandering through the deep forest, she senses a presence that stalks her."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":92,"tagline":"La noche para las de la noche","homepage":"https://www.filmax.com/distribucion/gaua/307","overview":"España, País Vasco, siglo XVII. De noche y a través de las montañas, Kattalin escapa de su caserío y, mientras deambula por el profundo bosque, percibe una presencia que la acecha."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"","runtime":92,"tagline":"Gaua gauekoentzat","homepage":"","overview":"Espainia, Euskal Herria, XVII. mendea. Gauez eta mendietan zehar, Kattalinek bere baserritik ihes egiten du eta, baso sakonean barrena ibiltzen den bitartean, zelatatzen duen presentzia sumatzen du."},"name":"euskera","iso_639_1":"eu","iso_3166_1":"ES","english_name":"Basque"},{"data":{"title":"","runtime":92,"tagline":"","homepage":"","overview":"Hiszpania, Kraj Basków, XVII wiek. Nocą, przez góry, Kattalin ucieka ze swojej farmy i wędrując przez głęboki las, wyczuwa obecność kogoś, kto ją śledzi."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":92,"tagline":"","homepage":"","overview":"Montagnes basques, Espagne, XVIIe siècle. Kattalin fuit son mari, abandonnant sa ferme au milieu de la nuit. Perdue dans l'obscurité de la forêt, elle sent une présence qui la poursuit."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":92,"tagline":"","homepage":"","overview":"España, País Vasco, siglo XVII. De noche y a través de las montañas, Kattalin escapa de su caserío y, mientras deambula por el profundo bosque, percibe una presencia que la acecha."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"恐惧夜话","runtime":92,"tagline":"","homepage":"","overview":"故事发生在17世纪西班牙的巴斯克区，在一天夜晚卡塔琳从自己的农舍逃出，当她穿越山群在茂密的森林中徘徊时，察觉到有个身影正在暗中尾随她。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Ночь","runtime":92,"tagline":"","homepage":"","overview":"Испания, Страна Басков, XVII век. Ночью, через горы, Катталине удается сбежать из своего дома, и, блуждая по густому лесу, она чувствует, что за ней кто-то следит."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"}],"reviews_tmdb":[{"id":"698d8c4da2d8529ba3dcda1f","url":"https://www.themoviedb.org/review/698d8c4da2d8529ba3dcda1f","author":"Enes","content":"You're spending so much budget and effort, why don't you make a proper horror movie? What kind of horror movie is just dialogue? And whoever did the subtitle translation for this movie, they shouldn't do it anymore. I'm going blind! The subtitles end before the character finishes speaking. The acting is passable, the effects are bad, and the script seems to have been written with the mentality of \"the faster I finish it, the better.\" Is it watchable? I don't think so. If you like demons, horror, and goat themes, then give it a try.","created_at":"2026-02-12T08:16:13.342Z","updated_at":"2026-02-12T18:56:21.571Z","author_details":{"name":"Enes","rating":3,"username":"Eness_","avatar_path":"/wASOrU1PJmMuTD1jIdop9yBvYdh.jpg"}}],"recommendations":[],"similar_content":[{"id":7093,"adult":false,"title":"Vatel","video":false,"overview":"In 1671, with war brewing with Holland, a penniless prince invites Louis XIV to three days of festivities at a chateau in Chantilly. The prince wants a commission as a general, so the extravagances are to impress the king. In charge of all is the steward, Vatel, a man of honor, talent, and low birth. The prince is craven in his longing for stature: no task is too menial or dishonorable for him to give Vatel. While Vatel tries to sustain dignity, he finds himself attracted to Anne de Montausier, the king's newest mistress. In Vatel, she finds someone who's authentic, living out his principles within the casual cruelties of court politics. Can the two of them escape unscathed?","genre_ids":[36,18,10749],"popularity":2.4866,"vote_count":176,"poster_path":"/qxtzOlO5FqFgSOGnNr0kFzo2Ho7.jpg","release_date":"2000-05-01","vote_average":6.1,"backdrop_path":"/vRFZivvKQ22JTlxkqVgGLC7Uw0f.jpg","original_title":"Vatel","original_language":"en"},{"id":1253093,"adult":false,"title":"Exergo","video":false,"overview":"Departing from peripheral details of some paintings of the Bilbao Fine Arts Museum, a female narrator unravels several stories related to the economic, social and psychological conditions of past and current artists.","genre_ids":[99,18],"popularity":0.6413,"vote_count":0,"poster_path":"/9kPbuK3NomLS4daVwqzhR7oJBrh.jpg","release_date":"2024-05-04","vote_average":0,"backdrop_path":null,"original_title":"Exergo","original_language":"eu"},{"id":3635,"adult":false,"title":"Girl with a Pearl Earring","video":false,"overview":"This film, adapted from a work of fiction by author Tracy Chevalier, tells a story about the events surrounding the creation of the painting \"Girl With A Pearl Earring\" by 17th century Dutch master Johannes Vermeer. A young peasant maid working in the house of painter Johannes Vermeer becomes his talented assistant and the model for one of his most famous works.","genre_ids":[18,10749],"popularity":1.2493,"vote_count":1457,"poster_path":"/41DkOi1MvTgTQXt5BevVSzo94kk.jpg","release_date":"2003-12-12","vote_average":6.626,"backdrop_path":"/tuiupUeJrNQkmO6LADHOSjbGJ6E.jpg","original_title":"Girl with a Pearl Earring","original_language":"en"},{"id":272805,"adult":false,"title":"Oedipus Rex","video":false,"overview":"The story of Oedipus' gradual discovery of his primal crime, killing his father and marrying his mother, filmed by the famed British theatrical director Sir Tyrone Guthrie. This elegant version of Sophocles' play adds a brilliant stroke: the actors wear masks just as the Greeks did in the playwright's day.","genre_ids":[18],"popularity":0.7456,"vote_count":8,"poster_path":"/cBoXJL0yQv8ReKoFk04uyB4XfsT.jpg","release_date":"1957-01-06","vote_average":6.3,"backdrop_path":"/ghOR1tdLi0w66JEmI5r9KWX0uNW.jpg","original_title":"Oedipus Rex","original_language":"en"},{"id":465111,"adult":false,"title":"Arsena","video":false,"overview":"XIX century peasants' revolt and the life story of bandit Arsena Odzelashvili.","genre_ids":[28,18,14],"popularity":0.1814,"vote_count":2,"poster_path":"/hgxRFRRVtnNhUBez2Nzxz62SVGD.jpg","release_date":"1937-05-19","vote_average":5,"backdrop_path":"/le7JARoq3koh5DyCupEx6QQV09W.jpg","original_title":"არსენა","original_language":"ka"},{"id":474139,"adult":false,"title":"I Am Nezha","video":false,"overview":"","genre_ids":[16,14,10751],"popularity":1.2991,"vote_count":3,"poster_path":"/b0BKVqQ25YenrJQkwGiscrmFQah.jpg","release_date":"2016-10-01","vote_average":7.7,"backdrop_path":"/gS4RrHZpz6yksjubDJLGYIVHapC.jpg","original_title":"我是哪吒","original_language":"zh"},{"id":10728,"adult":false,"title":"Faust","video":false,"overview":"God and Satan wager on the soul of a learned and prayerful alchemist as part of their eternal war over Earth.","genre_ids":[14,18,27],"popularity":1.0171,"vote_count":384,"poster_path":"/rN703hMFxmkZfyEzsXvFtuFhkXE.jpg","release_date":"1926-10-13","vote_average":7.9,"backdrop_path":"/vBOKLF3nhdaKRiCvmdoIUTikG2X.jpg","original_title":"Faust - Eine deutsche Volkssage","original_language":"de"},{"id":10703,"adult":false,"title":"Seven Swords","video":false,"overview":"In the middle of the 17th century, the Manchus conquered China and founded the Ching dynasty. Due to widespread uprisings against the new rulers, the study and practice of traditional martial arts is forbidden and punishable by death. The unscrupulous leader of a 