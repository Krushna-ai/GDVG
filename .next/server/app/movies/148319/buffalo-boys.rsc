9:{"metadata":[["$","title","0",{"children":"Buffalo Boys | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Betrayed by the Dutch colonial forces, Arana manages to escape along with his nephews Jamar and Suwo, the newborn sons of Hamza, one of the last Indonesian sultans fighting against foreign tyranny. In 1860, after wandering for years on the plains of the American Wild West, Arana and the two brothers return to Indonesia to avenge their dead loved ones and punish the evil man who caused their misfortune."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148319/buffalo-boys"}],["$","meta","5",{"property":"og:title","content":"Buffalo Boys"}],["$","meta","6",{"property":"og:description","content":"Betrayed by the Dutch colonial forces, Arana manages to escape along with his nephews Jamar and Suwo, the newborn sons of Hamza, one of the last Indonesian sultans fighting against foreign tyranny. In 1860, after wandering for years on the plains of the American Wild West, Arana and the two brothers return to Indonesia to avenge their dead loved ones and punish the evil man who caused their misfortune."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148319/buffalo-boys"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/o1Bn2zlIDJSnM5aOljbOPTM6Kf9.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Buffalo Boys"}],["$","meta","12",{"name":"twitter:description","content":"Betrayed by the Dutch colonial forces, Arana manages to escape along with his nephews Jamar and Suwo, the newborn sons of Hamza, one of the last Indonesian s