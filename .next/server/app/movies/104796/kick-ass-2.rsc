9:{"metadata":[["$","title","0",{"children":"Kick-Ass 2 | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"After Kick-Ass’ insane bravery inspires a new wave of self-made masked crusaders, he joins a patrol led by the Colonel Stars and Stripes. When these amateur superheroes are hunted down by Red Mist — reborn as The Mother Fucker — only the blade-wielding Hit-Girl can prevent their annihilation."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/104796/kick-ass-2"}],["$","meta","5",{"property":"og:title","content":"Kick-Ass 2"}],["$","meta","6",{"property":"og:description","content":"After Kick-Ass’ insane bravery inspires a new wave of self-made masked crusaders, he joins a patrol led by the Colonel Stars and Stripes. When these amateur superheroes are hunted down by Red Mist — reborn as The Mother Fucker — only the blade-wielding Hit-Girl can prevent their annihilation."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/104796/kick-ass-2"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/1go2A3gdQjaMuHWquybgoJlQRcX.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Kick-Ass 2"}],["$","meta","12",{"name":"twitter:description","content":"After Kick-Ass’ insane bravery inspires a new wave of self-made masked crusaders, he joins a patrol led by the Colonel Stars and Stripes. When these amateur superheroes are hunted down by Red Mist — reborn as The Mother Fucker — only the blade-wielding Hit-Girl can prevent their annihilation."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/1go2A3gdQj