"aspect_ratio":0.667,"vote_average":0.166},{"width":613,"height":900,"file_path":"/6JUgGBoCjfKo28FgfPPFFkVcxJv.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":1,"aspect_ratio":0.681,"vote_average":0.166},{"width":500,"height":750,"file_path":"/lPQ8zKTKSn4I9hAs9aVkbzgJQ2c.jpg","iso_639_1":"pt","iso_3166_1":"BR","vote_count":1,"aspect_ratio":0.667,"vote_average":0.166},{"width":1754,"height":2631,"file_path":"/zczdNPusprH5ybHGP8p07HbovOV.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1200,"height":1600,"file_path":"/lEslZ9owjciPrEbZchGan1X8Wzl.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.75,"vote_average":0},{"width":2000,"height":2857,"file_path":"/dzp2Fulq4BMxZ9jzmufyHOZolBT.jpg","iso_639_1":"el","iso_3166_1":"GR","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":1433,"height":2048,"file_path":"/isfrC3xaNb2r1cf3gqqHIQb6MMi.jpg","iso_639_1":"lt","iso_3166_1":"LT","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":2000,"height":2857,"file_path":"/udc83ufi3zytIs5GDoz9irwevLV.jpg","iso_639_1":"uk","iso_3166_1":"UA","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":1754,"height":2631,"file_path":"/8fGSf9XCIWB20nht5eyDngxgwxa.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/t13xCAvVBlEOuw3WjgAVxgeWzcp.jpg","iso_639_1":"nl","iso_3166_1":"NL","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1920,"height":2560,"file_path":"/1CmrueLuJqoDCqo8l1BMrYwUg7p.jpg","iso_639_1":"es","iso_3166_1":"MX","vote_count":0,"aspect_ratio":0.75,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/kC1IdzVibYoLrAVrtky7sWI4kPx.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/zXL6qKagHhE7SXlvY4gRfcX7kaU.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/qKs2ZcWnvuVGrjQkLntgmiy528B.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/tuMnwtZWhdQThZCIvGsIP8KIpOG.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/esELjfyAwUOpF6DVANUJ6IoTNDA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/vYx2cFOXNorqAwJQNxAjpllGMfG.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/fkDaTg1jZYkMizCsyKO0pInA06R.jpg","iso_639_1":"es","iso_3166_1":"MX","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/l4CrkW4SGDVkALQ5euKX7MWagB7.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/hXR4Sd8IuhuiZrhM1605bSoGjFz.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/kO1ROEfOMx8VqMOA3tOiHSmikjL.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T03:27:31.535+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Two to One","runtime":116,"tagline":"The best things in life are free.","homepage":"https://www.x-verleih.de/filme/zwei-zu-eins/","overview":"After the fall of the Berlin Wall, a communist family discovers a bunker full of money soon to be worthless. With the help of their neighbors, they embark on a race against time to enter the capitalist world in style."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"O Grande Golpe do Leste","runtime":116,"tagline":"Quem converte se diverte.","homepage":"https://exibidor.synapse.com.br/lancamentos/o-grande-golpe-do-leste/","overview":"Após a queda do Muro de Berlim, uma família comunista encontra um bunker cheio de dinheiro prestes a perder o valor. Com a ajuda dos vizinhos, eles embarcam em uma corrida contra o tempo para entrar em grande estilo no mundo capitalista."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"","runtime":116,"tagline":"Geld ist gedruckte Freiheit","homepage":"","overview":"Halberstadt im Sommer 1990. Maren, Robert und Volker kennen und lieben sich seit ihrer Kindheit. Eher zufällig finden sie in einem alten Schacht die Millionen der DDR, die dort eingelagert wurden, um zu verrotten. Die Drei schmuggeln Rucksäcke voll Geld heraus. Gemeinsam mit ihren Freunden und Nachbarn entwickeln sie ein ausgeklügeltes System, um das inzwischen wertlose Geld in Waren zu tauschen und den anrauschenden Westlern und ihrem Kapitalismus ein Schnippchen zu schlagen. Denn wenn man jetzt ein bisschen schlau ist, kann dieser Sommer nicht nur ein großes Abenteuer, sondern auch der endgültige Wendepunkt in ihrem Leben sein."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"La Belle affaire","runtime":116,"tagline":"","homepage":"","overview":"1990, en pleine réunification complexe des deux Allemagne, les ouvriers d’un même quartier d’ex-RDA se retrouvent sans emploi. Ils découvrent un jour l’emplacement de milliers de billets est-allemands voués à être détruits. Ils ont trois jours pour s’en emparer et convertir l’argent en Deutsche Mark, en montant l’affaire qui changera leur vie."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Δύο προς Ένα","runtime":0,"tagline":"","homepage":"","overview":"Ανατολική Γερμανία, καλοκαίρι του 1990: Μια οικογένεια ανακαλύπτει σε σήραγγα έναν σωρό από χαρτονομίσματα, τα οποία σε λίγες μέρες δεν θα έχουν αξία. Με τη βοήθεια της κοινότητάς της, θα βάλει σε εφαρμογή ένα παράτολμο σχέδιο."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Zwei zu eins","runtime":116,"tagline":"","homepage":"","overview":"W 1990 r., w trakcie skomplikowanego zjednoczenia obu Niemiec, pracownicy z tego samego okręgu byłej NRD zostali bezrobotni. Pewnego dnia odkrywają lokalizację tysięcy wschodnioniemieckich banknotów przeznaczonych do zniszczenia. Mają trzy dni na przejęcie ich i wymianę pieniędzy na markę niemiecką, zawierając umowę, która odmieni ich życie. Każdy ich zabiera tyle, ile jest w stanie unieść."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"A változás valutája","runtime":0,"tagline":"","homepage":"","overview":"Egy furfangos keletnémet csapat az újraegyesítés időszakának káoszát kihasználva megszerez egy föld alatti raktárba rejtett hatalmas összeget. Szorít az idő, túl kell járniuk ellenfeleik eszén, ráadásul tudják, hogy a keletnémet márka hamarosan értéktelenné válik. Maren, Robert, Volker és Käte megpróbálják a lehető legtöbbet kihozni a helyzetből...  A fordulatos, váratlan csavarokkal teli vígjáték valós eseményeket dolgoz fel."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"2:1","runtime":0,"tagline":"","homepage":"","overview":"1990 年夏天： 马伦（Maren）、罗伯特（Robert）和沃尔克（Volker）在一条旧隧道里发现了数百万东德马克。 虽然从技术上讲，这些钱一文不值，但这三个朋友还是用背包把钱偷运了出来，并让邻居们参与了一个巧妙的计划，用这些钱换取商品，从而欺骗资本主义。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Du už vieno kainą","runtime":113,"tagline":"Geriausi dalykai gyvenime yra nemokami","homepage":"","overview":"1990-ųjų vasara, Halberštatas. Vokietijai susivienijant, Rytų Vokietijos piliečiai gauna vos šešias dienas seną ostmarkių valiutą pakeisti į Vokietijos markes. Chaoso įkarštyje vaikystės draugai Maren, Robertas ir Folkeris aptinka milijonus ostmarkių, paslėptų požeminiame šachtos tunelyje. Supratę, kad pinigai greitai taps beverčiais, jie kartu su savo namo bendruomene sukuria išradingą planą, kaip panaudoti pavogtus pinigus."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"富貴逼東人","runtime":0,"tagline":"","homepage":"","overview":"1990 年東西德統一前夕,東德夫婦 Maren 及 Robert,與家人準備迎接資本主義新生活,並打算將快被全面取締的東德貨幣兌換成西德馬克。此時青梅竹馬好友 Volker 突然到訪,並帶來一單大茶飯—原來政府將大量未及焚化的東德銀紙棄置於地底倉庫內!兩男一女即時化身雌雄大盜,將大批舊銀紙運回家中,並結集左鄰右里發揮東德共產精神,實行有錢齊齊「洗」!根據真實事件改編,憑《墮下的對證》提名奧斯卡最佳女主角的柏林影后姍迪許娜,喜獲天降橫財,今次仲唔富貴逼人!"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Sommaren 1990 är en historisk tid i gamla Östtyskland. Sammanslagningen med väst var precis runt hörnet och förändringens vindar vinade. Maren och hennes familj smider en till synes genial plan hur de kan komma över miljoner med bortglömda östtyska mark, frågan är bara hur de ska lyckas växla in dem utan att väcka misstankar. Two to One är en komedi baserad på en verklig historia, med Sandra Hüller i huvudrollen."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Two to One","runtime":116,"tagline":"","homepage":"","overview":"Verano de 1990, en plena reunificación alemana tras la caída del muro de Berlín. Una familia encuentra en un almacén subterráneo millones de marcos de Alemania del Este, una moneda que está a punto de perder todo su valor frente a los marcos alemanes occidentales. Aprovechando diferentes vacíos legales, la familia dispondrá de unos pocos días para obtener beneficio del dinero, aplicando el mayor ingenio posible."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Два до одного","runtime":0,"tagline":"","homepage":"","overview":"Літо, 1990 рік. Троє друзів знаходять у покинутій шахті мільйони знецінених марок НДР. Марен, Роберт і Фолькер розробляють хитрий план обміну «мертвих» грошей, кидаючи виклик новому капіталістичному ладу. Їхня авантюра, балансуючи між дружбою та спокусою багатства, перетворює тихе містечко на епіцентр найбільшої фінансової витівки возз’єднаної Німеччини."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"","runtime":116,"tagline":"","homepage":"","overview":"In de zomer van 1990, wanneer Oost-Duitse burgers slechts zes dagen krijgen om hun Ostmarken om te wisselen voor West-Duitse marken, besluiten jeugdvrienden en geliefden Maren, Robert en Volker een fortuin aan bijna waardeloos geld te stelen uit een ondergrondse bunker. Samen met familie, vrienden en buren bedenken ze een creatief plan om het geld zo snel mogelijk om te zetten in waardevolle spullen en zo de kapitalisten te slim af te zijn."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"İkiye Bir","runtime":0,"tagline":"","homepage":"","overview":"Berlin Duvarı yıkıldıktan sonra komünist bir aile, para dolu bir sığınak keşfeder. Kapitalist dünyaya şık bir giriş yapabilmek için zamana karşı yarışa girişirler."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"Два к одному","runtime":0,"tagline":"","homepage":"","overview":"Лето 1990 года. Марен, Роберт и Фолькер случайно находят большое количество банкнот ГДР, которые вот-вот обесценятся. Они выносят купюры из старой шахты и вместе с соседями создают сложную систему обмена денег на товары."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Dvě ku jedné","runtime":0,"tagline":"","homepage":"","overview":"Film podle skutečné události, která se odehrála v létě roku 1990 v Halberstadtu. Maren, Robert a Volker se znají od dětství. Náhodou najdou ve staré šachtě miliony východních marek, které tam byly uloženy, aby tam shnily. Trojice se rozhodne batohy plné peněz propašovat ven. Společně se svými přáteli a sousedy vymyslí důmyslný systém, jak vyměnit již bezcenné peníze za zboží a přelstít přicházející “zápaďáky” a jejich kapitalismus. Když je člověk aspoň trochu prozíravý, může se toto léto stát nejen velkým dobrodružstvím, ale i zásadním zlomem v životě. Velká komedie o lásce a přátelství, penězích a spravedlnosti. A hold velmi zvláštní době, kdy se zdálo, že je možné všechno."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"El gran golpe del este","runtime":0,"tagline":"","homepage":"","overview":"Verano de 1990, en plena reunificación alemana tras la caída del muro de Berlín. Una familia encuentra en un almacén subterráneo millones de marcos de Alemania del Este, una moneda que está a punto de perder todo su valor frente a los marcos alemanes occidentales. Aprovechando diferentes vacíos legales, la familia dispondrá de unos pocos días para obtener beneficio del dinero, aplicando el mayor ingenio posible."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"}],"reviews_tmdb":[{"id":"6715fd1f9943637ce5829fec","url":"https://www.themoviedb.org/review/6715fd1f9943637ce5829fec","author":"Brent Marchant","content":"$11","created_at":"2024-10-21T07:05:03.150Z","updated_at":"2024-10-21T07:05:03.419Z","author_details":{"name":"Brent Marchant","rating":8,"username":"Brent_Marchant","avatar_path":null}}],"recommendations":[{"id":1001736,"adult":false,"title":"Meet the Barbarians","video":false,"overview":"The municipality of a small Breton village has decided to welcome a family of Ukrainian refugees. To their surprise, they receive Fayad family – coming from Syria. They thwart all the clichés that the French expected: they are friendly, refined, educated… So much so that, in this small, humming village, it is no longer clear which side the barbarians are on…","genre_ids":[35,18],"media_type":"movie","popularity":0.8022,"vote_count":69,"poster_path":"/xGacUz5IkYrRtp6MEiiy3hKOte.jpg","release_date":"2024-09-18","vote_average":6.094,"backdrop_path":"/pfslsIEGkNNkm88N4O0z8cNUH8a.jpg","original_title":"Les Barbares","original_language":"fr"},{"id":1231035,"adult":false,"title":"Gloria!","video":false,"overview":"In late 18th century Venice, in a convent school for girls, Teresa, a student with prophetic gifts, joins forces with some amazing music-makers. They create a new kind of pop, bright and bold, and challenge the ancient and rigid system.","genre_ids":[18,10402],"media_type":"movie","popularity":0.7888,"vote_count":109,"poster_path":"/Nm0umpaFx2FthwtdTqGdegohu6.jpg","release_date":"2024-04-11","vote_average":6.936,"backdrop_path":"/mohiVnDYwd9SWG8yIk4nOkiwO5l.jpg","original_title":"Gloria!","original_language":"it"},{"id":941019,"adult":false,"title":"LOLA","video":false,"overview":"Sussex, England, 1938. Shortly before the outbreak of World War II, Thomasina and Martha Hanbury, two ingenious sisters, create LOLA, a miraculous machine.","genre_ids":[18,878,10752],"media_type":"movie","popularity":3.7163,"vote_count":108,"poster_path":"/6IQEDnHKMvzforhtQW9mwW5kSHB.jpg","release_date":"2023-04-07","vote_average":6.403,"backdrop_path":"/6Mrf1ABhhXnzkRs7JxWNrOZH6Kf.jpg","original_title":"LOLA","original_language":"en"},{"id":846964,"adult":false,"title":"And Tomorrow You Will Be Dead","video":false,"overview":"In 2011 the young married Swiss couple Daniela Widmer and David Och got kidnapped while being on a long trip along the old Silk Road in Pakistan. They were hand over to the Taliban and were held as hostages for 8 months under the most precarious conditions.","genre_ids":[18,53],"media_type":"movie","popularity":0.235,"vote_count":31,"poster_path":"/dIgBQkGaWj8eANdbiy8zwdaqPgA.jpg","release_date":"2021-10-28","vote_average":6.7,"backdrop_path":"/dwc3VqrtMVJ8POtA8B9O00nVNIC.jpg","original_title":"Und morgen seid ihr tot","original_language":"de"},{"id":1175932,"adult":false,"title":"Fly On","video":false,"overview":"Watako has just lost her lover, Kimura, in a traffic accident in Tokyo. She decides to bury the trauma of this tragedy and carries on with her life with her husband. Although she puts on a facade for a while, the loss of Kimura has left deep marks, and she can't escape his memory any longer. She must now confront her grief.","genre_ids":[10749,18],"media_type":"movie","popularity":0.4204,"vote_count":11,"poster_path":"/qTbodQx3O4ic2LDlgaJdgAmjKaP.jpg","release_date":"2023-09-08","vote_average":7,"backdrop_path":"/rTTxCG3btsxfSMhgAUbwuSxy9OW.jpg","original_title":"ほつれる","original_language":"ja"},{"id":768106,"adult":false,"title":"Madam President","video":false,"overview":"President Kateřina Čechová, exhausted by the pressures of her first year in office, secretly dons a disguise to slip out of the castle at night and mingle among ordinary citizens. She meets and falls for sculptor Petr, unaware of her true identity, but when her nightly escapades are exposed, she must navigate the fallout and fight for her right to a personal life and love despite her public role.","genre_ids":[35],"media_type":"movie","popularity":0.194,"vote_count":8,"poster_path":"/8ZqZdGhuCMFXKaP5YQpWQWIoL4w.jpg","release_date":"2022-06-23","vote_average":5.5,"backdrop_path":"/yIvcEXKq7ZenLCoTMlVQwYA6mSs.jpg","original_title":"Prezidentka","original_language":"cs"},{"id":1214502,"adult":false,"title":"Eternal You","video":false,"overview":"Startups are using AI to create avatars that allow relatives to talk with their loved ones after they have died. An exploration of a profound human desire and the consequences of turning the dream of immortality into a product.","genre_ids":[99],"media_type":"movie","popularity":0.3731,"vote_count":8,"poster_path":"/dBMgyoKTUIaPwGPuhQCqRhhghxO.jpg","release_date":"2024-06-20","vote_average":6.2,"backdrop_path":"/tHKnsTPGU34qmXh5Ba1Ko8ukUrV.jpg","original_title":"Eternal You","original_language":"en"},{"id":1234591,"adult":false,"title":"My Favourite Cake","video":false,"overview":"Mahin lives alone in Tehran since her husband’s death and her daughter’s departure for Europe, until an afternoon tea with friends leads her to break her solitary routine and revitalize her love life.","genre_ids":[18,35,10749],"media_type":"movie","popularity":0.9152,"vote_count":134,"poster_path":"/gs6XHzRPZWBMUbFkZUwMDgNz0li.jpg","release_date":"2024-07-11","vote_average":7.347,"backdrop_path":"/3p1bD9QYA41lb5MBijhYee70Fxz.jpg","original_title":"کیک محبوب من","original_language":"fa"},{"id":11069,"adult":false,"title":"Tremors 2: Aftershocks","video":false,"overview":"Earl Bassett's celebrity after defeating the Graboid attack against the town of Perfection has proved short-lived, until he's recruited by a Mexican oil company whose workers have found more than they bargained for under the soil.","genre_ids":[28,27,35],"media_type":"movie","popularity":3.0002,"vote_count":1029,"poster_path":"/hvBYCgG62Fk8cYIsUtrfP5iw3K8.jpg","release_date":"1996-04-09","vote_average":6.306,"backdrop_path":"/dh6BVPe2v5ftSRol4dS09uMw51I.jpg","original_title":"Tremors 2: Aftershocks","original_language":"en"},{"id":1212142,"adult":false,"title":"Kinda Pregnant","video":false,"overview":"When Lainy's plan to settle down and start a family falls apart, she puts on a fake baby bump, tells a lie — and accidentally falls for her dream guy.","genre_ids":[35,10749],"media_type":"movie","popularity":3.3165,"vote_count":305,"poster_path":"/k2Lq3rCJ7P9gk5Df9of9kqr9IJM.jpg","release_date":"2025-02-04","vote_average":5.575,"backdrop_path":"/8qSsnSbgosaCROnvcOzeXyWsxIp.jpg","original_title":"Kinda Pregnant","original_language":"en"},{"id":13812,"adult":false,"title":"Quarantine","video":false,"overview":"A television reporter and her cameraman are trapped inside a building quarantined by the CDC after the outbreak of a mysterious virus which turns humans into bloodthirsty killers.","genre_ids":[27,878,53],"media_type":"movie","popularity":2.3766,"vote_count":1335,"poster_path":"/rGfOD8IC1x4PqmnqRuA8KyCckia.jpg","release_date":"2008-10-10","vote_average":5.781,"backdrop_path":"/v3yQYRScLl8WIqS1DnPub3hPuiE.jpg","original_title":"Quarantine","original_language":"en"},{"id":1098006,"adult":false,"title":"Fountain of Youth","video":false,"overview":"A treasure-hunting mastermind assembles a team for a life-changing adventure. But to outwit and outrun threats at every turn, he'll need someone even smarter than he is: his estranged sister.","genre_ids":[12,14,9648],"media_type":"movie","popularity":5.7216,"vote_count":854,"poster_path":"/4iWjGghUj2uyHo2Hyw8NFBvsNGm.jpg","release_date":"2025-05-19","vote_average":6.259,"backdrop_path":"/arGs8D4RfUfsk7vMiMjDi6Mtabv.jpg","original_title":"Fountain of Youth","original_language":"en"},{"id":870028,"adult":false,"title":"The Accountant²","video":false,"overview":"When an old acquaintance is murdered, Wolff is compelled to solve the case. Realizing more extreme measures are necessary, Wolff recruits his estranged and highly lethal brother, Brax, to help. In partnership with Marybeth Medina, they uncover a deadly conspiracy, becoming targets of a ruthless network of killers who will stop at nothing to keep their secrets buried.","genre_ids":[9648,80,53],"media_type":"movie","popularity":8.2368,"vote_count":1623,"poster_path":"/lUvfTcOZiK0sdcX0WNLPbMyKjGm.jpg","release_date":"2025-04-23","vote_average":7.082,"backdrop_path":"/yBDvgpyynDsbMyK21FoQu1c2wYR.jpg","original_title":"The Accountant²","original_language":"en"},{"id":376570,"adult":false,"title":"Hush","video":false,"overview":"A deaf woman is stalked by a psychotic killer in her secluded home.","genre_ids":[27,53],"media_type":"movie","popularity":3.1662,"vote_count":4774,"poster_path":"/zHzBTd502IZf60x8n2g0TB01vPF.jpg","release_date":"2016-03-12","vote_average":6.734,"backdrop_path":"/1r7AVAxdG97mgjR47Zm5YOSnnMW.jpg","original_title":"Hush","original_language":"en"},{"id":1226578,"adult":false,"title":"Longlegs","video":false,"overview":"FBI Agent Lee Harker is a gifted new recruit assigned to the unsolved case of an elusive serial killer. As the case takes complex turns, unearthing evidence of the occult, Harker discovers a personal connection to the merciless killer and must race against time to stop him before he claims the lives of another innocent family.","genre_ids":[80,27,9648],"media_type":"movie","popularity":6.3396,"vote_count":2486,"poster_path":"/1EwNyiiNFd863H4e8nWEzutnZD7.jpg","release_date":"2024-07-10","vote_average":6.534,"backdrop_path":"/6ToGkmqn0KG0UGGGUAC1Ww0e5CM.jpg","original_title":"Longlegs","original_language":"en"},{"id":884605,"adult":false,"title":"No Hard Feelings","video":false,"overview":"On the brink of losing her childhood home, Maddie discovers an intriguing job listing: wealthy helicopter parents looking for someone to “date” their introverted 19-year-old son, Percy, before he leaves for college. To her surprise, Maddie soon discovers the awkward Percy is no sure thing.","genre_ids":[35,10749],"media_type":"movie","popularity":4.8743,"vote_count":3690,"poster_path":"/gD72DhJ7NbfxvtxGiAzLaa0xaoj.jpg","release_date":"2023-06-15","vote_average":6.684,"backdrop_path":"/rRcNmiH55Tz0ugUsDUGmj8Bsa4V.jpg","original_title":"No Hard Feelings","original_language":"en"},{"id":346698,"adult":false,"title":"Barbie","video":false,"overview":"Barbie and Ken are having the time of their lives in the colorful and seemingly perfect world of Barbie Land. However, when they get a chance to go to the real world, they soon discover the joys and perils of living among humans.","genre_ids":[35,12],"media_type":"movie","popularity":19.205,"vote_count":10797,"poster_path":"/iuFNMS8U5cb6xfzi51Dbkovj7vM.jpg","release_date":"2023-07-19","vote_average":6.929,"backdrop_path":"/ctMserH8g2SeOAnCw5gFjdQF8mo.jpg","original_title":"Barbie","original_language":"en"},{"id":693134,"adult":false,"title":"Dune: Part Two","video":false,"overview":"Follow the mythic journey of Paul Atreides as he unites with Chani and the Fremen while on a path of revenge against the conspirators who destroyed his family. Facing a choice between the love of his life and the fate of the known universe, Paul endeavors to prevent a terrible future only he can foresee.","genre_ids":[878,12],"media_type":"movie","popularity":22.2359,"vote_count":7552,"poster_path":"/1pdfLvkbY9ohJlCjQH2CZjjYVvJ.jpg","release_date":"2024-02-27","vote_average":8.13,"backdrop_path":"/ylkdrn23p3gQcHx7ukIfuy2CkTE.jpg","original_title":"Dune: Part Two","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":19.7563,"vote_count":11389,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":533535,"adult":false,"title":"Deadpool & Wolverine","video":false,"overview":"A listless Wade Wilson toils away in civilian life with his days as the morally flexible mercenary, Deadpool, behind him. But when his homeworld faces an existential threat, Wade must reluctantly suit-up again with an even more reluctant Wolverine.","genre_ids":[28,35,878],"media_type":"movie","popularity":22.6059,"vote_count":8293,"poster_path":"/8cdWjvZQUExUUTzyp4t6EDMubfO.jpg","release_date":"2024-07-24","vote_average":7.557,"backdrop_path":"/ufpeVEM64uZHPpzzeiDNIAdaeOD.jpg","original_title":"Deadpool & Wolverine","original_language":"en"}],"similar_content":[{"id":8055,"adult":false,"title":"The Reader","video":false,"overview":"The story of Michael Berg, a German lawyer who, as a teenager in the late 1950s, had an affair with an older woman, Hanna, who then disappeared only to resurface years later as one of the defendants in a war crimes trial stemming from her actions as a concentration camp guard late in the war. He alone realizes that Hanna is illiterate and may be concealing that fact at the expense of her freedom.","genre_ids":[18,10749],"popularity":3.1528,"vote_count":3328,"poster_path":"/r0WURbmnhgKeBpHcpDULBgRedQM.jpg","release_date":"2008-12-10","vote_average":7.466,"backdrop_path":"/waMGsUEoHfYj3A1uRMUUgpBa71d.jpg","original_title":"The Reader","original_language":"en"},{"id":8426,"adult":false,"title":"Swallowtail Butterfly","video":false,"overview":"The struggles of a group of outcasts living in \"Yentown\", in an alternate-future Japan.","genre_ids":[18,80,10402,878],"popularity":1.544,"vote_count":96,"poster_path":"/wbHrboUJnLFvAG5eiB9LJaErjPn.jpg","release_date":"1996-09-14","vote_average":7.422,"backdrop_path":"/1u0ivjKCXZULqQTUZiVjZOjkEiO.jpg","original_title":"スワロウテイル","original_language":"ja"},{"id":8831,"adult":false,"title":"Timecop","video":false,"overview":"In 2004, an officer for a security agency that regulates time travel must fend for his life against a shady politician who has a tie to his past.","genre_ids":[53,878,28,80],"popularity":2.6426,"vote_count":1275,"poster_path":"/bgxP6ws8ErBiarnb4S93vv0lkf4.jpg","release_date":"1994-09-15","vote_average":6.005,"backdrop_path":"/iNfDwioDBzqodomLbMfV8ZXj0yL.jpg","original_title":"Timecop","original_language":"en"},{"id":8832,"adult":false,"title":"Il Divo","video":false,"overview":"Italy, early '90s. Calm, clever and inscrutable, politician Giulio Andreotti has been synonymous with power for decades. He has survived everything: electoral battles, terrorist massacres, loss of friends, slanderous accusations; but now certain repentant mobsters implicate him in the crimes of Cosa Nostra.","genre_ids":[18],"popularity":0.8698,"vote_count":1173,"poster_path":"/g1bgM34ZGldqcGkucmaGZe4pMBu.jpg","release_date":"2008-05-28","vote_average":7.624,"backdrop_path":"/f0QGUAdHs2eDMuUXO9GhViYe1bj.jpg","original_title":"Il Divo","original_language":"it"},{"id":8952,"adult":false,"title":"I Love You Phillip Morris","video":false,"overview":"Steven Russell leads a seemingly average life – an organ player in the local church, happily married to Debbie, and a member of the local police force. That is until he has a severe car accident that leads him to the ultimate epiphany: he’s gay and he’s going to live life to the fullest – even if he has to break the law to do it. Taking on an extravagant lifestyle, Steven turns to cons and fraud to make ends meet and is eventually sent to the State Penitentiary where he meets the love of his life, a sensitive, soft-spoken man named Phillip Morris. His devotion to freeing Phillip from jail and building the perfect life together prompts him to attempt (and often succeed at) one impossible con after another.","genre_ids":[35,80,18,10749],"popularity":2.1673,"vote_count":1780,"poster_path":"/qtAuWLGQ7N4PNQ6boZeqqoUY2l9.jpg","release_date":"2010-02-04","vote_average":6.4,"backdrop_path":"/sGelj98GTvGgx9yq2vNdvRoyXH4.jpg","original_title":"I Love You Phillip Morris","original_language":"en"},{"id":8961,"adult":false,"title":"Bad Boys II","video":false,"overview":"Detectives Marcus Burnett and Mike Lowrey of the Miami Narcotics Task Force are tasked with stopping the flow of the drug Ecstasy into Miami. They track the drugs to the whacked-out Cuban drug lord Johnny Tapia, who is also involved in a bloody war with Russian and Haitian mobsters. If that isn't bad enough, there's tension between the two detectives when Marcus discovers that playboy Mike is secretly romancing Marcus’ sister, Syd.","genre_ids":[28,80,35],"popularity":6.4976,"vote_count":5825,"poster_path":"/yCvB5fG5aEPqa1St7ihY6KEAsHD.jpg","release_date":"2003-07-18","vote_average":6.656,"backdrop_path":"/gxSVZCUlDd8upT1G2wdrUdz2hxG.jpg","original_title":"Bad Boys II","original_language":"en"},{"id":9303,"adult":false,"title":"Bound","video":false,"overview":"Corky, a tough female ex-convict working on an apartment renovation in a Chicago building, meets a couple living next door, Caesar, a paranoid mobster, and Violet, his seductive girlfriend, who is immediately attracted to her.","genre_ids":[18,53,80],"popularity":4.3521,"vote_count":1052,"poster_path":"/9qAy6UWVw44dGrsyKrdEMt5qIUM.jpg","release_date":"1996-09-13","vote_average":7.2,"backdrop_path":"/k1HwxcuoCrKzfZ4UbU1fnNKgXGV.jpg","original_title":"Bound","original_language":"en"},{"id":9071,"adult":false,"title":"Living in Oblivion","video":false,"overview":"Low-budget independent filmmaker Nick Reve tries to keep everything together as his production is plagued with an insecure actress, a megalomaniac star, a pretentious beret-wearing director of photography, and lousy catering.","genre_ids":[35],"popularity":1.0416,"vote_count":312,"poster_path":"/b54xDk98oWtEtAso9sj1wjaZDDH.jpg","release_date":"1995-07-21","vote_average":7.175,"backdrop_path":"/6CwIvZzTtsHX9LQAySH03Vby5UV.jpg","original_title":"Living in Oblivion","original_language":"en"},{"id":9327,"adult":false,"title":"The Nutty Professor","video":false,"overview":"When beautiful Carla Purty joins the university faculty, genetic professor Dr. Sherman Klump grows desperate to whittle his 400-pound frame down to size and win her heart. So, with one swig of his experimental fat-reducing serum, Sherman becomes 'Buddy Love', a fast-talking, pumped-up, plumped down Don Juan.","genre_ids":[14,35,10749,878],"popularity":3.3911,"vote_count":3062,"poster_path":"/fMtb5aZoLRNbMnCkatFsTmPRfl5.jpg","release_date":"1996-06-28","vote_average":5.6,"backdrop_path":"/gHFuLHxruielBcMEZx1WowxbRWS.jpg","original_title":"The Nutty Professor","original_language":"en"},{"id":1067950,"adult":false,"title":"Girl You Know It's True","video":false,"overview":"The rise and fall of Milli Vanilli, a studio group assembled by German producer Frank Farian and fronted by nightclub dancers Robert Pilatus and Fabrice Morvan. After a string of worldwide hit singles, awards and performances, it was revealed that the duo never sang a note of their songs, leading to one of the biggest scandals in music history.","genre_ids":[18,36,10402],"popularity":0.6836,"vote_count":120,"poster_path":"/yKYSHULhVfFzibLmWyJfUiwsFkR.jpg","release_date":"2023-12-06","vote_average":7.333,"backdrop_path":"/muG1Inh2Eawg8MoAElROpwHGtur.jpg","original_title":"Girl You Know It's True","original_language":"de"},{"id":65,"adult":false,"title":"8 Mile","video":false,"overview":"For Jimmy Smith, Jr., life is a daily fight just to keep hope alive. Feeding his dreams in Detroit's vibrant music scene, Jimmy wages an extraordinary personal struggle to find his own voice - and earn a place in a world where rhymes rule, legends are born and every moment… is another chance.","genre_ids":[18,10402],"popularity":5.7383,"vote_count":7690,"poster_path":"/7BmQj8qE1FLuLTf7Xjf9sdIHzoa.jpg","release_date":"2002-11-08","vote_average":7.14,"backdrop_path":"/jNG7pl0DkN1nzxnbZj4MCGf2VEG.jpg","original_title":"8 Mile","original_language":"en"},{"id":1906,"adult":false,"title":"Solo Sunny","video":false,"overview":"Sunny is the singer of band trying to establish itself in the music-scene of East-Berlin. They play regular gigs in small towns, but Sunny feels out of touch with the audience and her life as a whole. She begins a relationship with the amateur saxophonist and studied philosopher Ralph who writes her a very personal song - but his obsession with death and unfaithful lifestyle is not for her. After getting into a quarrel with a band member who harasses her and telling off a show-host she is thrown out of the band. Abandoned, she struggles to regain control over her life.","genre_ids":[18,10402],"popularity":0.2574,"vote_count":32,"poster_path":"/iULQFKitbtYb3T7IbGjGi49hZPZ.jpg","release_date":"1980-01-18","vote_average":6.1,"backdrop_path":"/2qdZSWyiJlMRsIn5kppiumz0fFy.jpg","original_title":"Solo Sunny","original_language":"de"},{"id":1923,"adult":false,"title":"Twin Peaks: Fire Walk with Me","video":false,"overview":"In the questionable town of Deer Meadow, Washington, FBI Agent Desmond inexplicably disappears while hunting for the man who murdered a teen girl. The killer is never apprehended, and, after experiencing dark visions and supernatural encounters, Agent Dale Cooper chillingly predicts that the culprit will claim another life. Meanwhile, in the more cozy town of Twin Peaks, hedonistic beauty Laura Palmer hangs with lowlifes and seems destined for a grisly fate.","genre_ids":[18,9648,27],"popularity":6.3879,"vote_count":2203,"poster_path":"/mxsGXqetGnirf99qapYd5MMY1VL.jpg","release_date":"1992-06-03","vote_average":7.407,"backdrop_path":"/amGU1FpELmenVvNmPShW58Orepy.jpg","original_title":"Twin Peaks: Fire Walk with Me","original_language":"en"},{"id":1254743,"adult":false,"title":"Whispers of Freedom","video":false,"overview":"Described by Deadline Hollywood as the \"tragic true story\" of Chris Gueffroy, it follows one of the last daring attempts to escape across the infamous Berlin Wall.","genre_ids":[36,18,53],"popularity":0.173,"vote_count":0,"poster_path":"/kwNutKI7rWVqYAkwtJKlmeCaZSS.jpg","release_date":"2024-11-01","vote_average":0,"backdrop_path":null,"original_title":"Whispers of Freedom","original_language":"en"},{"id":2054,"adult":false,"title":"Mr. Holland's Opus","video":false,"overview":"In 1965, passionate musician Glenn Holland takes a day job as a high school music teacher, convinced it's just a small obstacle on the road to his true calling: writing a historic opus. As the decades roll by with the composition unwritten but generations of students inspired through his teaching, Holland must redefine his life's purpose.","genre_ids":[18,10402],"popularity":0.9919,"vote_count":441,"poster_path":"/kBmwWeSN3ajnYHZ3dSybEobxEPI.jpg","release_date":"1995-12-29","vote_average":6.954,"backdrop_path":"/oUptKQLatCgywVDx0ETVhq7knHt.jpg","original_title":"Mr. Holland's Opus","original_language":"en"},{"id":2076,"adult":false,"title":"Swindle","video":false,"overview":"Four thieves attempt to make the richest score in history.","genre_ids":[28,80,18,53],"popularity":0.9638,"vote_count":17,"poster_path":"/h5LSYgE5y4firthL82t1s84nny9.jpg","release_date":"2002-04-01","vote_average":4.471,"backdrop_path":"/49hriJp9Oop5Gu3pxeKzy3v2hgi.jpg","original_title":"Swindle","original_language":"en"},{"id":2133,"adult":false,"title":"The Perfect Storm","video":false,"overview":"In October 1991, a confluence of weather conditions combined to form a killer storm in the North Atlantic. Caught in the storm was the sword-fishing boat Andrea Gail.","genre_ids":[18,12,28],"popularity":3.5018,"vote_count":2500,"poster_path":"/vJPoxqgpfFNbGi0HyoNsjFeLCio.jpg","release_date":"2000-06-29","vote_average":6.477,"backdrop_path":"/tO1wEUOSmZLyttwkhOMzUxTiR7k.jpg","original_title":"The Perfect Storm","original_language":"en"},{"id":278790,"adult":false,"title":"Just Don't Think I'll Cry","video":false,"overview":"High-school senior Peter considers the adults around him to be hypocritical, self-congratulatory, and immersed in the past. He gets suspended for writing an essay that his teachers consider to be a challenge to the state. Just Don't Think I'll Cry became one of twelve films and film projects-almost an entire year's production-that were banned in 1965-1966 due to their alleged anti-socialist aspects. Although scenes and dialogs were altered and the end was reshot twice, officials condemned this title as \"particularly harmful.\" In 1989, cinematographer Ost restored the original version, and this and most of the other banned films were finally screened in January 1990. Belatedly, they were acclaimed as masterpieces of critical realism.","genre_ids":[18],"popularity":0.1992,"vote_count":8,"poster_path":"/aE8El2BM8OHjAWXeY216bFPjkwj.jpg","release_date":"1965-10-25","vote_average":7.2,"backdrop_path":"/51lPH8WUikW45CE7VFZfHgFxxnw.jpg","original_title":"Denk bloß nicht, ich heule","original_language":"de"},{"id":9750,"adult":false,"title":"Balls of Fury","video":false,"overview":"Randy Daytona was a child ping pong prodigy who lost his chance at Olympic gold when his father is murdered by the mysterious Feng over a gambling debt. 15yrs later he's down on his luck and scraping a living doing seedy back room shows in Vegas; when the FBI turn up and ask for his help to take down Feng... who just happens to love Ping Pong.","genre_ids":[35,80],"popularity":0.9147,"vote_count":584,"poster_path":"/1Uc6lFCcNlaKP5uLJdQAhdDfihy.jpg","release_date":"2007-08-29","vote_average":5.283,"backdrop_path":"/cUDzGeQ5d4LVDu8ma1z9U02fo3k.jpg","original_title":"Balls of Fury","original_language":"en"},{"id":9876,"adult":false,"title":"Stop! Or My Mom Will Shoot","video":false,"overview":"A tough police sergeant's mother comes to visit him, and promptly starts trying to fix up his life, much to his embarrassment. For his birthday she buys him a machine gun out of the back of a van, and begins to further interfere with his job and love life, eventually helping him with a case he's on.","genre_ids":[28,35],"popularity":2.7494,"vote_count":1088,"poster_path":"/yCw4U5FK7C9hVWF2qcLO4EVvkCc.jpg","release_date":"1992-02-21","vote_average":5.312,"backdrop_path":"/nKJz9OZNZYk8JcUx6oDEgxcDfos.jpg","original_title":"Stop! Or My Mom Will Shoot","original_language":"en"}],"external_ids":{"imdb_id":"tt28833698","twitter_id":null,"facebook_id":null,"wikidata_id":"Q124169125","instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148472,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AU","release_dates":[{"note":"German Film Festival","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-05-04T00:00:00.000Z","certification":""}]},{"iso_3166_1":"BR","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":["Crimin