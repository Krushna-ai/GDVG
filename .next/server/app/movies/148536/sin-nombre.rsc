y_priority":4}],"link":"https://www.themoviedb.org/movie/21191-sin-nombre/watch?locale=VE","rent":[{"logo_path":"/SPnB1qiCkYfirS2it3hZORwGVn.jpg","provider_id":2,"provider_name":"Apple TV Store","display_priority":4}]}}},"wikidata_id":"Q1667482","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-25T23:30:10.17567+00:00","region":null,"main_poster":null,"images":{"logos":[{"width":1280,"height":544,"file_path":"/yT4aGVqlD1igxZQT6iQgdzSa60M.png","iso_639_1":"th","iso_3166_1":"TH","vote_count":0,"aspect_ratio":2.353,"vote_average":0},{"width":788,"height":144,"file_path":"/klG7wIu9UmCoNBbO1lhIs7C0k5y.png","iso_639_1":"es","iso_3166_1":"MX","vote_count":0,"aspect_ratio":5.472,"vote_average":0},{"width":788,"height":144,"file_path":"/5n3sg9z4P4SqcvmLD5tgq9IFyEt.png","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":5.472,"vote_average":0}],"posters":[{"width":1184,"height":1775,"file_path":"/dubZwiGWp6TwYNGYtyGEUC7XAin.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":5.238},{"width":1000,"height":1500,"file_path":"/wncX4fshBUDvB2CaW3AYG7i3nUd.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":800,"height":1200,"file_path":"/kIw4rjSQ3LIcmD2hcTRMzksEZ3Y.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":1,"aspect_ratio":0.667,"vote_average":3.334},{"width":1012,"height":1440,"file_path":"/6nLU4sZktn8HyN2HUmAsb52nb9I.jpg","iso_639_1":"pl","iso_3166_1":"PL","vote_count":0,"aspect_ratio":0.703,"vote_average":0},{"width":800,"height":1200,"file_path":"/A5lRirUrwBWYK9R8hHDQpGaS60G.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1382,"height":2048,"file_path":"/3nGfmyESTG543wlcUMRCk4uTjQC.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.675,"vote_average":0},{"width":2000,"height":3000,"file_path":"/yLlMtMu0VI7wFdpL3GjOpw3Uchv.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":667,"height":1000,"file_path":"/3eA00ZYa3Wnp88ktNS3ZpXd74XU.jpg","iso_639_1":"uk","iso_3166_1":"UA","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/dPJ6Phs6crwoVXiLHntQk2lHz2T.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2560,"height":1440,"file_path":"/oihEEHZv0HpzBVNkhAtTV6AJyqw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/8REdVBBpFeCg9lKngoZXL5V4cCA.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-26T03:45:37.054+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Sin Nombre","runtime":96,"tagline":"The greatest sin of all is risking nothing.","homepage":"","overview":"Sayra, a Honduran teen, hungers for a better life. Her chance for one comes when she is reunited with her long-estranged father, who intends to emigrate to Mexico and then enter the United States. Sayra's life collides with a pair of Mexican gangmembers who have boarded the same American-bound train."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":96,"tagline":"","homepage":"","overview":"Während sich Sayra mit ihrem Vater auf den beschwerlichen Weg von Honduras in die USA macht, wo dessen neue Familie lebt, hat El Caspar in Mexiko andere Probleme. Sein Gang - Boss hat herausgekriegt, dass er sich mit einem Mädchen trifft, das in einem Stadtteil lebt, in der eine gegnerische Gang das Sagen hat. Während er dafür von den anderen Gang - Mitgliedern bestraft wird, kümmert sich sein Boss um Martha Marlene. Als sie sich gegen die versuchte Vergewaltigung wehrt, stirbt sie unglücklich. Um El Caspars Loyalität zu überprüfen, nimmt sein Boss ihn und den 12jährigen El Smiley mit zu einem Raubzug auf die Menschen, die auf den Dächern von Güterzügen mitfahren, um so das gelobte Land USA zu erreichen. Dabei treffen sie zufällig auf Sayra und ihre Begleiter. Als sein Boss diese ebenfalls zu belästigen beginnt, schlägt El Caspar spontan mit seiner Machete zu, worauf dieser tödlich getroffen vom Zug fällt. Jetzt beginnt für El Caspar ein Wettlauf mit dem Tod ..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Sin Nombre","runtime":96,"tagline":"","homepage":"","overview":"Sedmnáctiletý Casper patří k mexickému pouličnímu gangu Mara Salvatrucha, pro jehož členy je nejvyšší hodnotou smrt příslušníka gangu soupeřícího. Osudová náhoda jej svede dohromady se stejně starou Sayrou, která se spolu s otcem a strýcem snaží přejet na střeše vlaku z rodného Hondurasu přes Mexiko do vysněných USA. Debutující Fukunaga umně mísí různé žánry, od thrilleru přes sociální drama na téma ilegální imigrace až po love story a western, aniž by v kterémkoli z nich působil nevěrohodně. Podmanivá vizuální stránka filmu využívá fotogeničnosti mexické krajiny viděné ze střechy vlaku, ani na okamžik však nesklouzne k efektnosti. Silnému důrazu na realističnost výpovědi podřídil režisér výběr málo známých herců či neherců. Strhující autenticita jejich výkonů spolu s Fukunagovou suverénní kontrolou nad obrazem i příběhem činí ze Sin nombre jeden z nejpozoruhodnějších debutů posledních let."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"","runtime":96,"tagline":"","homepage":"","overview":"Au Honduras, la jeune Sayra retrouve son père après une longue séparation. Elle va enfin réaliser son rêve, émigrer avec lui et son oncle aux États-Unis. Au Mexique, Casper est membre de la \"Mara\", l'un des terribles gangs d'Amérique Centrale. Pour venger la mort de sa fiancée, il tue un chef de bande et prend la fuite. Sur le toit du train qui file vers le Nord, entourés de centaines de candidats à l'émigration, Sayra et Casper se rencontrent. Il fuit son passé criminel, elle espère un avenir meilleur: parviendront-ils à échapper ensemble à leur destin et à franchir la frontière ?"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Em busca do sonho americano, Sayra (Paulina Gaytan), uma jovem das Honduras, junta-se ao seu pai e ao seu tio numa odisseia desafiante da travessia da paisagem latino-americana para os Estados Unidos. Ao longo do caminho, cruza-se com um jovem membro de um gangue mexicano, El Casper (Edgar M. Flores), que tenta escapar ao seu passado violento e aos pouco compreensivos antigos associados. Juntos têm que contar com a fé, confiança e esperteza de rua a fim de sobreviver à cada vez mais arriscada viagem em direção à esperança de uma nova vida."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"Без имени","runtime":0,"tagline":"","homepage":"","overview":"Уроженка Гондураса Сайра воссоединяется со своим отцом, чтобы осуществить свою мечту о жизни в США. Переезд же в Мексику является первым шагом в важном путешествии, полном неожиданных событий…"},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":96,"tagline":"","homepage":"","overview":"Sayra is een tiener, woont in Honduras en verlangt naar een goede toekomst. Een reünie met haar vader, die ze al een lange poos niet gezien heeft, geeft haar een kans haar droom waar te maken."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Sin nombre","runtime":96,"tagline":"","homepage":"http://www.sinnombre-lapelicula.es","overview":"Sayra (Paulina Gaitan), una adolescente hondureña, se reúne con su padre para viajar con él a los Estados Unidos; a partir de Chiapas, viajan en el techo de un vagón de carga, donde están expuestos tanto a las inclemencias del tiempo como a la violencia."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Sin Nombre","runtime":0,"tagline":"","homepage":"http://www.sinnombre-lapelicula.es","overview":"Sayra, un'adolescente nata in Honduras, sogna un futuro migliore. La sua speranza è tutta riposta nel sogno americano. La ragazza decide infatti di cercare una via che le permetta di iniziare una nuova vita negli Stati Uniti. La prima cosa da fare è un lungo viaggio attraverso il Messico, insieme a Smiley, Casper e gli altri membri della sua gang. La strada però si rivela irta di pericoli e di incontri inaspettati."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Ucieczka z piekła","runtime":96,"tagline":"","homepage":"","overview":"Nastoletnia Sayra za namową ojca wyrusza w niezwykłą podróż. Punkt startowy to Honduras, a celem ma być ziemia obiecana, kraj wielkich możliwości – USA. Dziewczyny nie stać na korzystanie z normalnych środków lokomocji, podróżuje więc na dachach pociągów. El Casper to członek najgroźniejszego w Ameryce Południowej gangu Mara Salvatrucha. Chłopak pozwala sobie na nieposłuszeństwo, co jest przez przywódców grupy traktowane jako grzech śmiertelny. Musi więc uciekać, aby uratować życie. Drogi tych dwojga młodych ludzi splatają się. Oboje nie mają nic oprócz wielkiej determinacji, aby ochronić to, co w ich świecie okrucieństwa i beznadziei jest jedyną wartością: miłość do bliskich, wiarę i nadzieję na lepszą przyszłość."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Χωρίς Όνομα","runtime":0,"tagline":"","homepage":"","overview":"Ο Κάσπερ βρίσκεται στην εφηβεία και είναι ήδη μέλος της αμείλικτης συμμορίας Μάρα. Η Σάιρα ταξιδεύει με τον πατέρα και τον θείο της από την εξοχή του Μεξικό προς τον Βορρά, στην οροφή ενός τρένου, με την ελπίδα πως θα μπορέσουν να περάσουν στις Ηνωμένες Πολιτείες. Έτσι, οι δρόμοι του Κάσπερ και της Σάιρα διασταυρώνονται και μια ξεχωριστή φιλία γεννιέται, ενώ οι κίνδυνοι συνεχώς παραμονεύουν. Θα καταφέρουν οι δύο αυτές περιπλανώμενες ψυχές να επιβιώσουν και να περάσουν τα σύνορα;"},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"ללא שם","runtime":0,"tagline":"","homepage":"","overview":"במציאות היומיומית בכפר מקסיקני קטן, נאמנות בכל מחיר לחברי הכנופיה שלך היא דבר מובן מאליו. במיוחד אם אתה בחור צעיר המחפש משהו שיגרום לך לרצות לחיות למענו ושתרגיש אליו שייכות. קספר הוא בחור מסוגר שלא מגלה ל\"אחיו\" על הרומן שלו עם חברתו, ונענש על כך ברציחתהע\"י מנהיג הכנופיה. סיירה, היא נערה יפיפייה מהונדורס שמנסה לחצות את הגבול לארץ האפשרויות הבלתי מוגבלות. במהלך מסעה המסוכן על גג רכבת נוסעת, היא נתקלת באותו מנהיג כנופיה אלים. קספר, מחליט לעזור לה ועושה מעשה שיציל את חייה אך במקביל יסמן אותו כמטרה לנקמה מצד אחיו לכנופיה. וכך בזמן שבין סיירה וקספר מתפתחים קשר עז וחברות מיוחדת, הולך ומתהדק \"חבל התלייה\" סביב צווארם.האם אהבתם העמוקה והאמון שלהם זה בזו יספיקו כדי להציל את חייהם והשניים יצליחו לעבור בשלום את הגבול?"},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Sem Identidade","runtime":96,"tagline":"","homepage":"","overview":"O jovem Casper é integrante da gang chamada \"La Mara Salvatrucha\" e tenta fugir de sua realidade violenta.  Sayra uma garota de periferia de Honduras tenta entrar ilegalmente nos EUA. Estas duas vidas se encontram na perigosa odisseia dos imigrantes ilegais em direção aos EUA.  Um retrato verdadeiro sobre a realidade das violentas gangues e sobre o desespero da imigração ilegal em direção aos EUA."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"İsimsiz","runtime":0,"tagline":"","homepage":"","overview":"Honduraslı genç kız Sayra, uzun zaman sonra babasıyla tekrar kavuşurlar. Bu, onun için Amerika'ya gitme hayallerindeki bir adımlardan birisidir. Öncelikle Meksika'ya, daha sonra da Amerika'ya ulaşarak orada yaşama hayallerine kavuşmak için çok uzun bir yolculuğa çıkar. Bu yolculuğu sırasında Sayra, hiç beklemediği dram dolu anlar yaşayacaktır.\r Hayattaki En Büyük Suç, Hiç Bir Risk Alamamaktır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"","runtime":96,"tagline":"","homepage":"","overview":"Силен, въздействащ, на места откровено брутален, но истински. Филм за бандите от подземния свят, в които ако следваш правилата им, живееш добре, но кривнеш ли, те чака смърт. Сигурна смърт. Колкото и да бягаш, където и да се криеш, рано или късно, смъртта ще те застигне. Филм за неограничените човешки възможности, когато става въпрос за бягство от мизерията. За това как пътуваш дни наред върху тавана на едва движещ се влак, с надеждата, че когато стигнеш крайната дестинация, животът ти ще започне наново. Но после осъзнаваш, че това са били едни от хубавите мигове в живота ти, защото поне си имал някаква надежда, преди да се сблъскаш с поредната мизерия. И филм за любовта, но тази, която е невъзможна. Колкото и да я искаш, знаеш че не може да я имаш."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Sökande efter nya möjligheter i USA åker Sayra, en ung kvinna från Honduras, med sin far och farbror på väg mot gränsen. På vägen möter hon en ung mexikansk gängmedlem, El Casper, som försöker fly undan sitt våldsamma förflutna och undkomma sitt gamla gäng. Tillsammans måste de förlita sig på tro, hopp och vara gatusmarta om de ska överleva sin allt farligare resa mot sina nya liv."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"无名","runtime":0,"tagline":"","homepage":"","overview":"　　墨西哥青年人帮派“拉马拉”手段凶残，占据着每天运送大量偷渡客的火车站。作为帮派份子，卡斯帕在执行任务期间却外出约会，并冒着被视为叛徒的危险隐瞒自己恋爱的事实，但女友仍在卡斯帕受处罚的聚会上出现，并被首领里马尔戈误杀。洪都拉斯少女塞拉长年在美国的父亲终于出现，为了能和亲人团聚，父女登上了偷渡的火车，火车路经拉马拉势力范围时，里马尔戈同帕斯卡攀车打劫，为救塞拉，帕斯卡将里马尔戈砍落车下。塞拉与帕斯卡萌生了情意，但他们前方是未知的旅途，而背后是帮派的追杀……  　　本片获2009年爱丁堡国际电影节最佳新导演奖，2009年圣丹斯电影节导演奖、摄影奖。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"罪惡代碼","runtime":96,"tagline":"","homepage":"","overview":"為了追尋美國夢，美少女塞雅（鮑琳娜蓋坦）與父親一起展開了一段長征之行，冒險橫跨拉丁美洲。途中，她認識了一位少年墨西哥黑手黨奧爾卡斯伯（艾格弗洛瑞斯），對方有意金盆洗手。在這個險象環生的旅途上，三人必須憑靠對彼此信心、信任和小聰明生存下來，才能重獲新生。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"罪惡程式碼","runtime":0,"tagline":"","homepage":"","overview":"這個貧民窟小子逃離暴力的中美洲街頭黑幫，躲到行駛火車的車頂，希望在另一個國家重新開始。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Sin nombre","runtime":0,"tagline":"","homepage":"","overview":"Sayra, una adolescente hondureña, se reúne con su padre para viajar con él a los Estados Unidos; a partir de Chiapas, viajan en el techo de un vagón de carga, donde están expuestos tanto a las inclemencias del tiempo como a la violencia."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"신 놈브레","runtime":96,"tagline":"","homepage":"","overview":"멕시코 갱조직과 미국으로 불법 이민을 가려는 사람들에 관한 영화."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Không Tên","runtime":0,"tagline":"","homepage":"","overview":"Chạy trốn khỏi một băng đảng đường phố đầy bạo lực ở Trung Mỹ, một thiếu niên ẩn náu bên trên đoàn tàu đang di chuyển và hy vọng có khởi đầu mới ở một đất nước mới."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"闇の列車、光の旅","runtime":0,"tagline":"","homepage":"","overview":"主人公カスペルは殺し屋ギャンググループmara salvatruchaのメンバーの一人。このグループは貧困で家族も居ない、仕事もない、食べ物もない、そんな地域の若者達から生まれた“１つの家族\"である。しかしこのグループのメンバーになる為には13秒間のメンバー全員からの暴行に耐えて生き残れるもののみ。さらに必ず1人誰かを殺さないとメンバーにしてもらえないという恐ろしいグループである。刺青が多ければ多いほど位が高い。  他にもたくさんの掟があるなか、カスペルはグループに秘密でメンバー以外の女の子に恋をする。しかし、リーダーに嘘をついて会っていた事がバレ、罰として移民が移動に使う列車に強盗に一緒に行くことを命ぜられる。  ホンジュラスの少女サイラは、故郷を捨て、父親らと共にメキシコ経由でアメリカへ移民しようとしていたが、チアパス州でアメリカ行きの列車の屋根に乗り込んだところ、メキシカン・ギャング団のカスペル・スマイリー・リルマゴに遭遇し、リーダーのリルマゴに暴行されそうになる。耐えきれなくなったギャング団の少年カスペルは、リルマゴ殺してしまう。  サイラとその家族と共にギャングから逃げ、アメリカへ移民しようと必死に逃げる。  実際に世界中に存在する恐ろしいギャング、実際に今でも起きている不法移民問題やその厳しさなどをリアルに描いた映画。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Безіменний","runtime":0,"tagline":"","homepage":"","overview":"Каспар, який є членом найжорстокішої і вкрай небезпечної міжнародної банди «Мара Сальватруча», робить хід проти своїх заради зовсім невідомої йому дівчини Сайри. На нього починається полювання…"},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"คนไม่มีชื่อ","runtime":0,"tagline":"","homepage":"","overview":"นักเลงหนุ่มที่ต้องหาทางหนีอิทธิพลแก๊งโฉดในถิ่นอเมริกากลางกระโดดขึ้นขบวนรถไฟที่มุ่งไปสู่ปลายทางข้างหน้า พร้อมความหวังจะเริ่มต้นชีวิตใหม่ในต่างแดน"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Un adolescent din Honduras se întâlnește cu un criminal Mexican în timp ce călătoresc spre un viitor mai luminos, pe acoperișul unui tren care se îndreaptă spre America."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"På jagt efter nye muligheder i USA tager Sayra, en smuk ung kvinde fra Honduras, sammen med sin far og onkel på en rejse gennem landområder på vej mod grænsen. På vejen møder hun et ungt, mexicansk bandemedlem, El Casper, som forsøger at flygte fra sin voldelige fortid og slippe væk fra sin utilgivende, tidligere bande. For at overleve må de satse på tro, håb og tilpasningsevne."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"}],"reviews_tmdb":[],"recommendations":[{"id":62077,"adult":false,"title":"Neon Flesh","video":false,"overview":"Hoping to earn his mother's respect, a young hustler-turned-businessman tries to open a brothel with his two useless buddies.","genre_ids":[53,28,35],"media_type":"movie","popularity":0.7294,"vote_count":63,"poster_path":"/v9rktdg6PkkpL25cKO7DXblarXz.jpg","release_date":"2010-10-09","vote_average":5.944,"backdrop_path":"/aDgIQaO3n8lmSX5LAmHUvwygimA.jpg","original_title":"Carne de neón","original_language":"es"},{"id":20764,"adult":false,"title":"Sleep Dealer","video":false,"overview":"Set in a near-future, militarized world marked by closed borders, virtual labor and a global digital network that joins minds and experiences, three strangers risk their lives to connect with each other and break the barriers of technology.","genre_ids":[18,878,53],"media_type":"movie","popularity":0.8132,"vote_count":129,"poster_path":"/kFXQ4oMJkXAWjyo7Tr5GrLjmk61.jpg","release_date":"2008-12-10","vote_average":5.884,"backdrop_path":"/kfBhgDnMzo050dJJq1NqDwWmAzf.jpg","original_title":"Sleep Dealer","original_language":"en"},{"id":17003,"adult":false,"title":"Sugar","video":false,"overview":"Like many young men in the Dominican Republic, 19-year-old Miguel \"Sugar\" Santos dreams of winning a slot on an American baseball team. Indeed, his talents as a pitcher eventually land him a slot on a single-A team in Iowa, but culture shock, racism and other curveballs threaten to turn Sugar's dream sour.","genre_ids":[18],"media_type":"movie","popularity":0.5152,"vote_count":71,"poster_path":"/ldiKnTAt8pBB3rY6HQI4QZt6r7n.jpg","release_date":"2008-04-03","vote_average":6.6,"backdrop_path":"/DsG28k7nsej7PQirbdWLbIPoXZ.jpg","original_title":"Sugar","original_language":"en"},{"id":43956,"adult":false,"title":"Tom and Jerry Meet Sherlock Holmes","video":false,"overview":"Tom and Jerry need to learn to work together in order to help Sherlock Holmes with an investigation of a jewel theft. But still, they are cat and mouse!","genre_ids":[16,35,9648,10751],"media_type":"movie","popularity":0.7075,"vote_count":95,"poster_path":"/8YLgPSsiDrZMO4y