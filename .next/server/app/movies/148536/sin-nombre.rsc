9:{"metadata":[["$","title","0",{"children":"Sin Nombre | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Sayra, a Honduran teen, hungers for a better life. Her chance for one comes when she is reunited with her long-estranged father, who intends to emigrate to Mexico and then enter the United States. Sayra's life collides with a pair of Mexican gangmembers who have boarded the same American-bound train."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/148536/sin-nombre"}],["$","meta","5",{"property":"og:title","content":"Sin Nombre"}],["$","meta","6",{"property":"og:description","content":"Sayra, a Honduran teen, hungers for a better life. Her chance for one comes when she is reunited with her long-estranged father, who intends to emigrate to Mexico and then enter the United States. Sayra's life collides with a pair of Mexican gangmembers who have boarded the same American-bound train."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/148536/sin-nombre"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/dubZwiGWp6TwYNGYtyGEUC7XAin.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Sin Nombre"}],["$","meta","12",{"name":"twitter:description","content":"Sayra, a Honduran teen, hungers for a better life. Her chance for one comes when she is reunited with her long-estranged father, who intends to emigrate to Mexico and then enter the United States. Sayra's life collides with a pair of Mexican gangmembers who have boarded the same American-bound train."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb