":8.034},{"width":1265,"height":540,"file_path":"/2XZ3UvbJlWLhpjKXhn685E3d2mI.png","iso_639_1":"pt","vote_average":6.722},{"width":1121,"height":539,"file_path":"/kc35JMTjXIv6KVVbFdOfDLdsyF4.png","iso_639_1":"zh","vote_average":5.786},{"width":3097,"height":1057,"file_path":"/r5XwacwwJ0bvr604as4TXIBxZBY.png","iso_639_1":"zh","vote_average":5.25},{"width":730,"height":290,"file_path":"/f79rol2Sf9xPhhTbgNeH6mhRNfL.png","iso_639_1":"es","vote_average":3.334}],"posters":[{"width":1001,"height":1426,"file_path":"/27DNJjNTLpKDsuhqjSjklyPnos4.jpg","iso_639_1":"pt","vote_average":10},{"width":2000,"height":3000,"file_path":"/aLoK7Fxgw8Rgn15iP9hIxtFoZYZ.jpg","iso_639_1":"pt","vote_average":10},{"width":2000,"height":3000,"file_path":"/bzKQHuKvkuD4Mm0k3TPup5hv9DL.jpg","iso_639_1":"zh","vote_average":8.77},{"width":1000,"height":1500,"file_path":"/8KpHRokGpiaqEGpjYe0rpywtvUx.jpg","iso_639_1":"fr","vote_average":8.362},{"width":1000,"height":1500,"file_path":"/rmsP4F5tjuOpnHsQAPba6YjHDFq.jpg","iso_639_1":"pt","vote_average":8.034},{"width":2000,"height":3000,"file_path":"/5aWiwybkgcSrDnSLTqPfr7mD7Xw.jpg","iso_639_1":"pt","vote_average":8.034},{"width":550,"height":825,"file_path":"/p6e7HSfWcrPCerEF23lin8bKuQ0.jpg","iso_639_1":"zh","vote_average":8.034},{"width":2000,"height":3000,"file_path":"/30qhPllwGUbrZLi5n8jDV7oN5Nl.jpg","iso_639_1":"zh","vote_average":7.19},{"width":754,"height":1130,"file_path":"/eZy8E8F85DXZX3yFk2bYzMNYJKG.jpg","iso_639_1":"de","vote_average":6.648},{"width":2000,"height":3000,"file_path":"/33Wj3LSyoAqtqkeh7YXcVMvTQzc.jpg","iso_639_1":"ru","vote_average":5.786},{"width":2000,"height":3000,"file_path":"/n6zpzAOoGx3kYrEzgAMHQZyF5cE.jpg","iso_639_1":"en","vote_average":5.778},{"width":2000,"height":3000,"file_path":"/bhCfAzeMMg7GyLDT11yVM2i1NPh.jpg","iso_639_1":"es","vote_average":5.682},{"width":1000,"height":1500,"file_path":"/31z69FoBRNoQ27k546IXJizFrUI.jpg","iso_639_1":"en","vote_average":5.616},{"width":630,"height":945,"file_path":"/3nvGqfZE3yrsqehpF