9:{"metadata":[["$","title","0",{"children":"Sakra | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Qiao Feng is the respected leader of a roving band of martial artists. After he is wrongfully accused of murder and subsequently exiled, Qiao Feng goes on the run in search of answers about his own mysterious origin story—and the unknown enemies working to destroy him from the shadows."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/110265/sakra"}],["$","meta","5",{"property":"og:title","content":"Sakra"}],["$","meta","6",{"property":"og:description","content":"Qiao Feng is the respected leader of a roving band of martial artists. After he is wrongfully accused of murder and subsequently exiled, Qiao Feng goes on the run in search of answers about his own mysterious origin story—and the unknown enemies working to destroy him from the shadows."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/110265/sakra"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/jGKCpt3zzbGZbgoza6HCvecqElM.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Sakra"}],["$","meta","12",{"name":"twitter:description","content":"Qiao Feng is the respected leader of a roving band of martial artists. After he is wrongfully accused of murder and subsequently exiled, Qiao Feng goes on the run in search of answers about his own mysterious origin story—and the unknown enemies working to destroy him from the shadows."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/jGKCpt3zzbGZbgoza6HCvecqElM.jpg"}],["$","link","14",{"re