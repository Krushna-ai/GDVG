5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Cold Feet\",\"description\":\"Although he actually just wanted to steal money, the crook Denis finds himself in the position of caretaking for the stroke patient Raimund. When Raimund's granddaughter Charlotte turns up, Denis has enough of it and wants to skip. But because of an huge blizzard, escape is unimaginable.\",\"image\":\"https://image.tmdb.org/t/p/w500/9v8dhdYwTeXzzw2fDb05TrvhWH1.jpg\",\"datePublished\":\"2018-11-21\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"AT\",\"inLanguage\":\"de\",\"genre\":[\"Comedy\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.615,\"bestRating\":10,\"ratingCount\":96}}"}}],["$","$L10",null,{"initialDrama":{"id":"58072498-4d71-4383-a72d-614bece3eb44","tmdb_id":564140,"imdb_id":"tt7883774","content_type":"movie","title":"Cold Feet","original_title":"Kalte Füße","overview":"Although he actually just wanted to steal money, the crook Denis finds himself in the position of caretaking for the stroke patient Raimund. When Raimund's granddaughter Charlotte turns up, Denis has enough of it and wants to skip. But because of an huge blizzard, escape is unimaginable.","poster_path":"/9v8dhdYwTeXzzw2fDb05TrvhWH1.jpg","backdrop_path":"/nSuZJXgn01roVKt0NaQ4s1rKG9Z.jpg","release_date":"2018-11-21","first_air_date":null,"status":"published","original_language":"de","origin_country":["AT","DE"],"genres":[{"id":35,"name":"Comedy"},"comedy film"],"popularity":5.7861,"vote_average":6.615,"vote_count":96,"runtime":94,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-26T01:15:56.288077+00:00","updated_at":"2026-02-26T01:15:56.132+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":55163,"name":"Claussen+Putz Filmproduktion","logo_path":"/sv06pHi3d93dE4zUq1RUs4vkFqW.png","origin_country":"DE"},{"id":26976,