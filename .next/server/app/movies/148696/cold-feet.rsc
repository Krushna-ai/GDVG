ile_path":"/qzzxPv8hQwTRnmXoWCbma9ZmPUq.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.706,"vote_average":0},{"width":992,"height":1418,"file_path":"/hlzGjy0KfuQQfnKSVOdlcpJvETz.jpg","iso_639_1":"zh","iso_3166_1":"CN","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":2000,"height":3000,"file_path":"/9v8dhdYwTeXzzw2fDb05TrvhWH1.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/gbMM05Yn2he1HC4xw4lMYfnSAId.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1519,"height":2170,"file_path":"/eJLIxCaLgbQhmAGJpLtS5sewFe2.jpg","iso_639_1":"hu","iso_3166_1":"HU","vote_count":0,"aspect_ratio":0.7,"vote_average":0},{"width":1080,"height":1620,"file_path":"/s7b43BOco3vt9GJlCykdBhDxb2y.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":0.667,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/nSuZJXgn01roVKt0NaQ4s1rKG9Z.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/nb7LGBlH2xzHnM4tnqzXCSgbKr8.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/fCMLizw7grajvhKGRYu275Q0LkB.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/iA07Ac7hey0xFMcbFJ1gu0WRSTv.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/qBSHn5mDwOY129gQeeAIPuZR83E.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/fMMvGVN1NmNoNTUHH6973l5aiRw.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/bgX7EqGj91YAKEN4E2w5Fr0K8Pm.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/oWZY9BWXRLMvhSnT1KOTXonivn3.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/cKqHgdMJBghuroIPBxexUCfSc5i.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T07:29:56.74+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":94,"tagline":"","homepage":"","overview":"Durch eine Verwechslung findet sich der Kleinkriminelle Denis plötzlich in der Position des Krankenpflegers für den Schlaganfallpatienten Raimund wieder. Dabei wollte er nur in dessen Villa einbrechen, um endlich seine Schulden bei einigen Ganoven zu begleichen. Stattdessen sitzt er nun im herrschaftlichen Anwesen des reichen Unternehmers fest, der seit dem Anfall nicht mehr sprechen kann und an den Rollstuhl gefesselt ist. Als dann auch noch Raimunds Enkeltochter Charlotte auftaucht, wird es Denis endgültig zu viel. Doch an Flucht ist nicht zu denken, ein gewaltiger Schneesturm tobt in der Region. Und so muss er wohl oder übel die Rolle des Krankenpflegers spielen – sehr zu Raimunds Unmut, der sich mit allen Mitteln gegen den Eindringling wehrt. Denn im Gegensatz zu Charlotte hat Raimund den Ganoven Denis sofort durchschaut. Ein Katz-und-Maus-Spiel beginnt, in dem der kernige Senior und der gewiefte Junior ihre Mittel grandios zum Einsatz bringen..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Cold Feet","runtime":94,"tagline":"","homepage":"","overview":"Although he actually just wanted to steal money, the crook Denis finds himself in the position of caretaking for the stroke patient Raimund. When Raimund's granddaughter Charlotte turns up, Denis has enough of it and wants to skip. But because of an huge blizzard, escape is unimaginable."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Нянька на рождество","runtime":97,"tagline":"","homepage":"","overview":"По нелепой случайности воришка Денис оказывается в роли сиделки у прикованного к инвалидному креслу. Он вынужден ухаживать за богатым бизнесменом и его внучкой, которая приехала навестить деда. Рэймонд с радостью избавился бы от непрошенного гостя, но снежная буря вынуждает их оставаться в одном доме."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"临阵脱逃","runtime":97,"tagline":"","homepage":"","overview":"在一场混乱后，小混混丹尼斯突然成了中风患者雷蒙德的看护。他原本只想闯入雷蒙德的房子，盗取财物以偿还债务。而现在的他，却被“囚禁”在富商雷蒙德的房子里。与此同时，雷蒙德的孙女夏洛特前往照看他，“巧遇”宅子里的丹尼斯，这无疑打乱了丹尼斯的计划。然而，逃离绝不是一种好的选择，因为该地区正遭受暴风雪的肆虐。因此，丹尼斯必须继续扮演看护者的角色。与夏洛特相反，雷蒙德却是早已看透丹尼斯。就此，一场“就地取材”的猫捉老鼠游戏，在行动不便的年长者和聪明的年轻人之间展开了……"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"凸槌大臨演","runtime":0,"tagline":"難搞阿公尬上冒牌看護 最精彩的「照護」生活即將展開！","homepage":"","overview":"丹尼斯是位一事無成的年輕人，不僅毫無責任感更事沒有工作而欠下債務。為了還債，他受債主指使要去一間深山豪宅中行竊。豪宅的主人雷蒙，是一位脾氣暴躁又頑固的老人家，而他就在聖誕節前夕他突然中風，遠在外地念警察預備學校的孫女夏洛特敵不過母親的請託，只好不甘心地連夜趕來照顧爺爺。心中另有所想的丹尼斯與夏洛特在中風又難相處的雷蒙家相遇，丹尼斯為了隱藏真實身分，謊稱是雷蒙的看護。眼看丹尼斯計畫要成功之際，突如其來的暴風雪打亂了一切計畫，雷蒙能阻止丹尼斯的搶劫計畫並且守護孫女夏洛特的安危嗎？化身為假看護的丹尼斯，能逃過「難搞阿公」雷蒙的糾纏嗎？而一心只想離開大宅的夏洛特，能識破假看護的真目的嗎？困於暴風雪中的三人各懷鬼胎，爆笑有趣的諜對諜即將展開！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Alávaló ápoló","runtime":0,"tagline":"","homepage":"","overview":"Raimund évekkel ezelőtt összeveszett a lányával, ezért egyedül él egy hatalmas birtokon, míg egy nap agyvérzést nem kap. Így érkezik meg hozzá Denis, a betörő, akit elsodornak az események, ezért kénytelen ápolónak kiadni magát és az öregember mellett maradni. Raimund unokája, Charlotte is megjelenik, hogy ideiglenesen ápolja beteg nagyapját. A két fiatal hamar közel kerül egymáshoz, ám a bonyodalmak csak később kezdődnek..."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Studené nohy","runtime":0,"tagline":"","homepage":"","overview":"Denis je mladík s pozitivním vztahem k všemu, co se dá zpeněžit nebo získat zdarma. Charlotte je nadějná policistka, s vervou cílevědomé studentky překonávající vlastní profesionální nedostatky. Absence finančních zdrojů přivede Denise do vily starého může po mozkové mrtvici. Vše vidí, ale nemluví a nemůže se hýbat. Když se s Charlotte, jeho vnučkou, střetne ve dveřích, netuší, že právě rozehrál dramatickou šachovou partii, na konci které bude někým úplně jiným."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Нянька на Різдво","runtime":0,"tagline":"","homepage":"","overview":"За безглуздою випадковістю злодюжка Деніс опиняється у ролі доглядальниці прикутого до інвалідного крісла. Він змушений доглядати за багатим бізнесменом та його онукою, яка приїхала відвідати діда. Реймонд з радістю позбувся б непроханого гостя, але снігова буря змушує їх залишатися в одному будинку. Починається гра, в якій старий і молодий чоловік застосовують свої здібності з жахливою винахідливістю."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Bláznivá vianočná kalamita","runtime":93,"tagline":"","homepage":"https://voyo.markiza.sk/filmy/3096-blazniva-vianocna-kalamita","overview":"Denis je mladý muž s pozitívnym prístupom ku všetkému, čo sa dá speňažiť alebo získať zadarmo. Charlotte je nádejná policajtka s elánom odhodlanej študentky, ktorá prekonáva vlastné profesionálne nedostatky. Nedostatok finančných prostriedkov privedie Denisa do vily starej konzervy po mŕtvici. Všetko vidí, ale nemôže hovoriť a nemôže sa hýbať. Keď vo dverách stretne Charlottu, svoju vnučku, netuší, že práve rozohrala dramatickú šachovú partiu, na konci ktorej bude niekým úplne iným."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Door een verwisseling bevindt de kleine crimineel Denis zich plotseling in de positie van verpleegkundige voor de beroertepatiënt Raimund. Hij wilde alleen maar inbreken in zijn villa om eindelijk zijn schulden aan een paar boeven af te betalen. In plaats daarvan zit hij nu vast in het statige landgoed van de rijke ondernemer, die sinds de aanval niet meer kan spreken en aan een rolstoel gekluisterd is. Wanneer Raimunds kleindochter Charlotte verschijnt, wordt het Denis uiteindelijk te veel. Maar ontsnappen is uitgesloten, er woedt een enorme sneeuwstorm in de regio. En dus, in voor- en tegenspoed, moet hij de rol van verpleger spelen – tot groot ongenoegen van Raimund, die zich met alle middelen verdedigt tegen de indringer. Want in tegenstelling tot Charlotte heeft Raimund de boef Denis meteen doorzien. Er ontstaat een kat-en-muisspel, waarin de robuuste senior en de sluwe junior hun middelen grandioos gebruiken..."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Suando Frio","runtime":0,"tagline":"","homepage":"","overview":"Quando Denis invade a casa de inverno austríaca do rico homem de negócios Raimund, ele é confundido com a nova enfermeira pela neta de Raimund, Charlotte. Para não ser pego, Denis decide entrar na brincadeira."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"凸槌大臨演","runtime":0,"tagline":"","homepage":"","overview":"丹尼斯是位一事無成的年輕人，不僅毫無責任感更事沒有工作而缺下債務。為了還債，他受債主指使要去一間深山豪宅中行竊。豪宅的主人雷蒙，是一位脾氣暴躁又頑固的老人家，而他就在聖誕節前夕他突然中風，遠在外地念警察預備學校的孫女夏洛特敵不過母親的請託，只好不甘心地聯夜趕來照顧爺爺。心中另有所想的丹尼斯與夏洛特在中風又難相處的雷蒙家相遇，丹尼斯為了隱藏真實身分，謊稱是雷蒙的看護。眼看丹尼斯計畫要成功之際，突如其來的暴風雪打亂了一切計畫，雷蒙能阻止丹尼斯的搶劫計畫並且守護孫女夏洛特的安危嗎？化身為假看護的丹尼斯，能逃過「難搞阿公」雷蒙的糾纏嗎？而一心只想離開大宅的夏洛特，能識破假看護的真目的嗎？困於暴風雪中的三人各懷鬼胎，爆笑有趣的諜對諜即將展開！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"}],"reviews_tmdb":[],"recommendations":[{"id":535092,"adult":false,"title":"The Goldfish","video":false,"overview":"Oliver is a banker and portfolio manager and leads a life in the fast lane, which one day comes to an abrupt end, as he builds a self-inflicted accident on highway with 230 km / h and raced through a guardrail. When he wakes up in the hospital again, he faces a devastating diagnosis: paraplegia. Actually, a rehabilitation stay of several months is planned in the hospital, but Oliver soon falls on his head and ends up in a disabled shared flat with the name \"Die Goldfische\"","genre_ids":[35],"media_type":"movie","popularity":0.2684,"vote_count":102,"poster_path":"/arqU72w8tkCGCIKEul476of8qZE.jpg","release_date":"2019-02-28","vote_average":6.4,"backdrop_path":"/mfvJQLVu7g3cYMOLmSVpSs3vIdL.jpg","original_title":"Die Goldfische","original_language":"de"},{"id":587668,"adult":false,"title":"The Gravedigger's Wife","video":false,"overview":"Guled and Nasra are a loving couple, living in the outskirts of Djibouti city with their teenage son, Mahad. However, they are facing difficult times: Nasra urgently needs an expensive surgery to treat a chronic kidney disease. Guled is already working hard as a gravedigger to make ends meet.","genre_ids":[18],"media_type":"movie","popularity":1.7367,"vote_count":30,"poster_path":"/c4COWFUlnTBb1w9RZQsBJHk2Axx.jpg","release_date":"2021-11-12","vote_average":6.7,"backdrop_path":"/yfmHkflWbDMuz0kkHcr5zx2GK79.jpg","original_title":"Guled & Nasra","original_language":"fi"},{"id":271433,"adult":false,"title":"Wir sind die Neuen","video":false,"overview":"Three old friends from college move back in together in an apartment in Munich for financial reasons.","genre_ids":[35],"media_type":"movie","popularity":0.1769,"vote_count":70,"poster_path":"/pIC9lDrT75JrvhhHfwH0GFdW5m.jpg","release_date":"2014-07-17","vote_average":6.536,"backdrop_path":"/yBEhk3IE0PhwRB14AwReyGadT8O.jpg","original_title":"Wir sind die Neuen","original_language":"de"},{"id":336660,"adult":false,"title":"Mediterranea","video":false,"overview":"Ayiva recently left his home in Burkina Faso in search of a way to provide for his sister and his daughter. He takes advantage of his position in an illegal smuggling operation to get himself and his best friend Abas off of the continent. Ayiva adapts to life in Italy, but when tensions with the local community rise, things become increasingly dangerous. Determined to make his new situation work he attempts to weather the storm, but it has its costs.","genre_ids":[18],"media_type":"movie","popularity":2.3024,"vote_count":56,"poster_path":"/84L8Qak3UAQ4qgY3xeXU4Siejem.jpg","release_date":"2015-09-02","vote_average":6.679,"backdrop_path":"/77g6JyhZgRyv6UWOxnXP9kBgMb8.jpg","original_title":"Mediterranea","original_language":"it"},{"id":555877,"adult":false,"title":"Immenhof - The Adventure of a Summer","video":false,"overview":"After the death of their father three sisters, sixteen year old Lou, Charly who is in her early twenties and Emmie who is a mere child, have to try and run the family's horse farm between them. They have to overcome all manner of adversity in order to keep their beloved farm.","genre_ids":[10751,18],"media_type":"movie","popularity":0.331,"vote_count":31,"poster_path":"/jykLFW6uTrhKrGdoSYhwehMbIpN.jpg","release_date":"2019-01-17","vote_average":6.7,"backdrop_path":"/whijTDa2CcqgiO7jYTqCenVxzpK.jpg","original_title":"Immenhof - Das Abenteuer eines Sommers","original_language":"de"},{"id":656704,"adult":false,"title":"Needle Park Baby","video":false,"overview":"Spring 1995 - after the closure of the Needle Park and the public drug scene in Zurich, eleven-year-old Mia and her heroin addicted mother Sandrine are relocated to the countryside. While caring for her mother, Mia spends time with her imaginary friend and a gang of local teenage misfits. These friendships finally give her the strength to rebel and break free from her abusive mother.","genre_ids":[18],"media_type":"movie","popularity":1.6387,"vote_count":28,"poster_path":"/CQ55klM6jjoJ3Po8Xb3YCejyla.jpg","release_date":"2020-01-16","vote_average":6.929,"backdrop_path":"/jBEsGJUAgbrsi8DO5Rae8A7ZWfT.jpg","original_title":"Platzspitzbaby","original_language":"de"},{"id":382498,"adult":false,"title":"Heart of Stone","video":false,"overview":"Peter and Lisbeth are two young but unfortunate lovers living in a rigid rural community in the Black Forest. She comes from a wealthy family of glassblowers; he is a poor coal worker on the lower end of society. To become rich and respected, Peter makes a pact with a devil named Dutch Michael, who rips out his heart and replaces it with a stone. Robbed of all warmth and feeling, Peter becomes a cold-hearted go-getter who rapidly achieves his goals. Ruthlessly he strives for money and power.","genre_ids":[18,14,10749],"media_type":"movie","popularity":0.6789,"vote_count":38,"poster_path":"/WVQSVmXGtY3tJukP67zz9tgBgl.jpg","release_date":"2016-10-20","vote_average":6.3,"backdrop_path":"/rXQeqSUitemsgYoO0W4GvyC1lss.jpg","original_title":"Das kalte Herz","original_language":"de"},{"id":916507,"adult":false,"title":"Krass Klassenfahrt - Der Kinofilm","video":false,"overview":"Croatia is calling! The 12th grade of a Berlin high school is going on a graduation trip. Together with the stressed teacher Mrs. Gruber and the over-committed teacher Georg, the trip doesn't start as planned: In the so-called Eco-Hostel the dream of an Insta-worthy beach vacation with endless parties seems to burst before it has even begun. Yet McLarry in particular had high hopes of distraction: he's the only one who didn't pass his A-levels and who can't actually afford the class trip. He is also not yet over his breakup with Bella. But then the ray of hope - his favorite rapper and idol Zeno is also in Croatia! The perfect opportunity for McLarry to present him his own songs. Together with his best buddy Cornelius and Best Friends Bella and Alena, they break away from the class field trip and head to Zeno's villa. With the hopelessly overtaxed chaperone Georg in tow, they embark on the gnarliest adventure of their lives...","genre_ids":[35],"media_type":"movie","popularity":0.7077,"vote_count":15,"poster_path":"/9eycS8Yl87iVcU0te57KNAVqKrK.jpg","release_date":"2021-11-11","vote_average":5.733,"backdrop_path":"/tXvRmm2e3PZ0Q7sD0a4E8rHDKT9.jpg","original_title":"Krass Klassenfahrt - Der Kinofilm","original_language":"de"},{"id":1061117,"adult":false,"title":"The Hatchet Wielding Hitchhiker","video":false,"overview":"After Kai saves a woman's life, he turns into an overnight hero and viral sensation — until disturbing truths about his erratic behavior come to light. This shocking documentary chronicles a happy-go-lucky nomad's ascent to viral stardom and the resulting steep downward spiral.","genre_ids":[80,99],"media_type":"movie","popularity":0.4395,"vote_count":155,"poster_path":"/kb9ow17gQv2196VTgLnbRoA3amZ.jpg","release_date":"2023-01-10","vote_average":6.229,"backdrop_path":"/ySqZmxCcbwkrtH5j6KVH6BVv4mM.jpg","original_title":"The Hatchet Wielding Hitchhiker","original_language":"en"},{"id":1002315,"adult":false,"title":"Please Don't Destroy: The Treasure of Foggy Mountain","video":false,"overview":"When three friends who live together realize that they don't like their life trajectory, they set off to find a gold treasure that is rumored to be buried in the nearby mountain.","genre_ids":[35,12,28],"media_type":"movie","popularity":0.9543,"vote_count":146,"poster_path":"/2WSTjQNamyMoy3kFDemd1os8TNz.jpg","release_date":"2023-11-17","vote_average":6.14,"backdrop_path":"/pIbsQ4Cu8rGWkj8QjD6Sqy9NzAS.jpg","original_title":"Please Don't Destroy: The Treasure of Foggy Mountain","original_language":"en"},{"id":428081,"adult":false,"title":"High Society","video":false,"overview":"Two girls from very different social backgrounds discover, at the age of 25, that they had been switched at birth.","genre_ids":[35],"media_type":"movie","popularity":0.6025,"vote_count":160,"poster_path":"/y1jkYgGExy1MsAEgvdnxEu0yQsR.jpg","release_date":"2017-09-14","vote_average":6.213,"backdrop_path":"/6qrFAxLmgP1wAhCXSryMEjIsD4m.jpg","original_title":"High Society","original_language":"de"},{"id":489763,"adult":false,"title":"The Keeper","video":false,"overview":"The story of a man whose love for football, for England and for the love of his life, Margaret, saw him rise from Nazi 'villain' to British hero. Bert Trautmann, the German goalkeeper won over even his harshest opponents by winning the FA Cup Final for Manchester City in 1956 - playing on with a broken neck to secure victory.","genre_ids":[18,10752,36],"media_type":"movie","popularity":1.8807,"vote_count":234,"poster_path":"/nNPsc5USXEr90FoFaXXljaC1O3r.jpg","release_date":"2018-12-05","vote_average":7.4,"backdrop_path":"/8n4aiFihHkFLsezZIY4Rp34jH9r.jpg","original_title":"Trautmann","original_language":"de"},{"id":8092,"adult":false,"title":"This Boy's Life","video":false,"overview":"When a son and mother move to Seattle in hopes for a better life, the mother meets a seemingly polite man. Things go south when the man turns out to be abusive, endangering their lives. As the mother struggles to maintain hope in an impossible situation, the son has plans to escape.","genre_ids":[18],"media_type":"movie","popularity":1.8552,"vote_count":1056,"poster_path":"/pRMSZfen1Cv1eqwDbtxCBpBqxnU.jpg","release_date":"1993-04-09","vote_average":7.125,"backdrop_path":"/6N6VUUR1gzbCkiGpQzvRREv3Od1.jpg","original_title":"This Boy's Life","original_language":"en"},{"id":614939,"adult":false,"title":"Bros","video":false,"overview":"Two emotionally unavailable men attempt a relationship.","genre_ids":[35,10749],"media_type":"movie","popularity":2.4095,"vote_count":555,"poster_path":"/6iFBzZ3LjmlE83pHok03Z9QPkAB.jpg","release_date":"2022-09-30","vote_average":6.663,"backdrop_path":"/mezKuuKtAKPENnAVlT3TghkMACv.jpg","original_title":"Bros","original_language":"en"},{"id":207933,"adult":false,"title":"Stonehearst Asylum","video":false,"overview":"An Oxford Medical School graduate takes a position at a mental institution and soon becomes obsessed with a female mental patient, but he has no idea of a recent and horrifying staffing change.","genre_ids":[53,9648,27],"media_type":"movie","popularity":18.5876,"vote_count":1544,"poster_path":"/fZxGCCQ0NAtraevqULJ84wSSjo0.jpg","release_date":"2014-10-23","vote_average":6.851,"backdrop_path":"/988AG01BZZe62P33jemkFIacxF9.jpg","original_title":"Stonehearst Asylum","original_language":"en"},{"id":940139,"adult":false,"title":"Here","video":false,"overview":"An odyssey through time and memory, centered on a place in New Jersey where—from wilderness, and then, later, from a home—love, loss, struggle, hope and legacy play out between couples and families over generations.","genre_ids":[18],"media_type":"movie","popularity":3.2856,"vote_count":630,"poster_path":"/79euHUJJtfgeGU63ef38KtNjXEn.jpg","release_date":"2024-10-30","vote_average":6.529,"backdrop_path":"/z7JEMQuxHWZtGb1DxZ2egjOlPcb.jpg","original_title":"Here","original_language":"en"},{"id":483104,"adult":false,"title":"A Christmas Prince","video":false,"overview":"When a reporter goes undercover as a nanny to get the inside scoop on a playboy prince, she gets tangled in some royal intrigue and ends up finding love - but will she be able to keep up her lie?","genre_ids":[10749,10770],"media_type":"movie","popularity":0.8419,"vote_count":1471,"poster_path":"/x0IGQsMzVbsF7noj5cCfEk1GU7s.jpg","release_date":"2017-11-17","vote_average":6.604,"backdrop_path":"/mNjoA9jDNbxPJqeYmeETLStpYZF.jpg","original_title":"A Christmas Prince","original_language":"en"},{"id":748167,"adult":false,"title":"Uglies","video":false,"overview":"In a futuristic dystopia with enforced beauty standards, a teen awaiting mandatory cosmetic surgery embarks on a journey to find her missing friend.","genre_ids":[878,12,28],"media_type":"movie","popularity":4.168,"vote_count":897,"poster_path":"/jaUu9zHtbcFwrB5Y1DNYE09HMex.jpg","release_date":"2024-09-12","vote_average":5.768,"backdrop_path":"/y4NzXdvpJdwRmsnOT7HdkmHh6Yn.jpg","original_title":"Uglies","original_language":"en"},{"id":8456,"adult":false,"title":"Never Back Down","video":false,"overview":"Jake, full of anger after his father's death, is just starting to find a place for himself at his new Orlando high school - until Ryan, head of an underground MMA fight club, picks Jake out as a prime opponent. After being trounced by Ryan in front of the entire school, Jake begins training under the firm, moral guidance of a MMA master, where he learns how to fight... and how to avoid a fight. But it becomes obvious that a rematch will be inevitable if Jake wants to stop Ryan and his bullying, once and for all.","genre_ids":[18,28],"media_type":"movie","popularity":4.4077,"vote_count":2442,"poster_path":"/8oRUTyP1QAtGDMvRpKZyuyFPG0U.jpg","release_date":"2008-03-04","vote_average":6.8,"backdrop_path":"/h71xyiurUscD6uIPbECyso1Lwb9.jpg","original_title":"Never Back Down","original_language":"en"},{"id":470044,"adult":false,"title":"The Hate U Give","video":false,"overview":"Raised in a poverty-stricken slum, a 16-year-old girl named Starr now attends a suburban prep school. After she witnesses a police officer shoot her unarmed best friend, she's torn between her two very different worlds as she tries to speak her truth.","genre_ids":[80,18],"media_type":"movie","popularity":1.7551,"vote_count":2201,"poster_path":"/2icwBom0t5nmOuZI9FVXF3gkMK0.jpg","release_date":"2018-10-19","vote_average":8.084,"backdrop_path":"/kH8xW7K2Gp1KOXoeewcLPkfqZ8K.jpg","original_title":"The Hate U Give","original_language":"en"}],"similar_content":[],"external_ids":{"imdb_id":"tt7883774","twitter_id":null,"facebook_id":null,"wikidata_id":"Q55773928","instagram_id":null,"rotten_tomatoes_id":"m/cold_feet_2010"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148696,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_