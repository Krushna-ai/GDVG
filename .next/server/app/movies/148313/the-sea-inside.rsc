1400,"file_path":"/954DBPqjzCs15BjWdhv6eGaVXRa.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.666,"vote_average":0},{"width":600,"height":900,"file_path":"/d3EdEtpCXKgRkehHxQCK06oLNkD.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/e2LQ4adVHEak47lbCIVMgOoiwJA.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":2000,"height":3000,"file_path":"/eJEobGJp0zQoNbrtOaybQqt9p6O.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/9BMV9gg3CEXH8n6z2mrHLMbW6WS.jpg","iso_639_1":"fr","iso_3166_1":"FR","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":510,"height":755,"file_path":"/9Aec9xcVBQBbUxsfrztGKtbcrSy.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":0.675,"vote_average":0},{"width":1545,"height":2180,"file_path":"/x6LJRnRRSw982lXQ1nupJPH6b2g.jpg","iso_639_1":"hu","iso_3166_1":"HU","vote_count":0,"aspect_ratio":0.709,"vote_average":0},{"width":2000,"height":2857,"file_path":"/ai7rmcWQDKnfvCdScB9xlpLLZdx.jpg","iso_639_1":"el","iso_3166_1":"GR","vote_count":0,"aspect_ratio":0.7,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/7XmDhCTkce5GH8KCdbMoTZdxn1p.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/uogzGsu5cVUYAl9Xf9JAVvElNLK.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/t2xneprllDUVXkCwudH5V3OczxB.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":1,"aspect_ratio":1.778,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/8MAmTGRjYMPrPa3cUgXIYT4Dbcg.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2000,"height":1124,"file_path":"/tcizsdRLbBe0cyoKYGHg1dpn17G.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.779,"vote_average":0},{"width":1920,"height":1080,"file_path":"/qy5kcmCMDtQ80pWjp1gltK8nTmd.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/c2NYp3aHa0ZCxF6pX9LZ9Z2XCyT.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-02-25T03:51:39.363+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"The Sea Inside","runtime":126,"tagline":"","homepage":"","overview":"Ramón Sampedro is a ship mechanic and part-time poet left a quadriplegic following a diving accident. Ramón fought for 30 years for the legal right to end his own life. He develops close relationships with his long-term lawyer Julia and his friend Rosa, who tries to convince him that his life is worth living. Despite his situation, Ramón manages to inspire those around him to live life to the fullest."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Das Meer in mir","runtime":126,"tagline":"","homepage":"","overview":"In seinen Gedanken ist Ramón immer noch jung, agil und bei den Frauen beliebt. Doch die Realität ist bitter, ist der hochintelligente Mann doch seit einem Badeunfall vor 27 Jahren vom Hals abwärts gelähmt. Schon lange will er sich freiwillig aus diesem Dasein verabschieden. Doch dazu würde er Hilfe brauchen - und die versagen ihm Staat und Kirche; und sogar der eigene Bruder, in dessen Haus er lebt, aufopferungsvoll gepflegt von seiner Schwägerin. Erst das Auftauchen der lebenslustigen Rosa lässt seinen Wunsch in greifbare Nähe rücken."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Mare dentro","runtime":125,"tagline":"","homepage":"","overview":"E' la storia di Ramón Sampedro, un ex marinaio reso tetraplegico da un tuffo in mare. Nonostante l'affetto e la dedizione dei suoi familiari, dopo un trentennio di totale immobilità inizia, con l'aiuto di un'associazione per i diritti umani, una inutile lotta con i tribunali spagnoli per ottenere il diritto a una morte dignitosa. Due donne, Julia un'avvocatessa colpita a sua volta da una malattia degenerativa, e Rosa, un'operaia con due figli piccoli, impegnate ciascuna a suo modo nella causa di Ramón, dovranno fare i conti con i loro sentimenti e con i principi che hanno regolato fino a quel momento le loro vite."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"","runtime":125,"tagline":"Drama sensible sobre un tema polémico","homepage":"","overview":"Ramón lleva casi treinta años postrado en una cama al cuidado de su familia. Su única ventana al mundo es la de su habitación, junto al mar por el que tanto viajó y donde sufrió el accidente que interrumpió su juventud. Desde entonces, su único deseo es terminar con su vida dignamente. La llegada de dos mujeres alterará su mundo: Julia, la abogada que quiere apoyar su lucha y Rosa, una vecina del pueblo que intentará convencerle de que vivir merece la pena. La luminosa personalidad de Ramón termina por cautivar a ambas, que tendrán que cuestionar como nunca antes los principios que rigen sus vidas. Él sabe que sólo la persona que de verdad le ame será la que le ayude a realizar ese último viaje."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"İçimdeki Deniz","runtime":0,"tagline":"","homepage":"","overview":"Ramon Sampedro’nun yaşamı, 30 yıldır bir yatakta geçmektedir. Gençliğinde geçirdiği bir kazadan sonra hayatla tek ilişkisi deniz manzaralı penceresidir. Hayatına iki kadın girer: avukat Julia ve köylü kızı Rosa. Bu iki kadından biri, boynundan aşağısı felçli adama hayatın anlamını tattırır ve onun kurtuluşunu sağlar. Alejandro Amenabar’ın bu çalışması Venedik’te ikinciliği, başrol oyuncusu Javier Bardem’e de En İyi Erkek Oyuncu ödülünü aldı."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Море внутри","runtime":0,"tagline":"","homepage":"","overview":"Реальная история испанца Рамона Сампедро, который, будучи полностью парализованным около тридцати лет, 2 года боролся за право на добровольный уход из жизни. Фильм рассказывает о его отношениях с двумя женщинами: Джулией, его адвокатом, и подругой Розой, которая пытается убедить Рамона, что жизнь стоит того, чтобы жить. Сила любви Рамона вдохновляет женщин на поступки, которые казались им невозможными. Рамон, несмотря на желание смерти, раскрывает своим друзьям и близким ценность и смысл жизни. Он не может двигаться сам, но может заставить любого изменить течение его жизни."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Mar Adentro","runtime":125,"tagline":"Condenado a viver, ele só quer morrer.","homepage":"","overview":"Baseado na história real de Ramón Sampedro, nascido numa pequena vila de pescadores na Galícia, o filme retrata a luta de um homem para por fim a sua própria vida. Na juventude, Ramón sofreu um acidente que o deixou tetraplégico e preso a uma cama por 27 anos. Com uma lucidez e inteligência cativante, Ramón lutou na justiça pelo direito de decidir sobre a sua vida, o que gerou vários conflitos com os seus familiares, a igreja e a sociedade."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"A belső tenger","runtime":125,"tagline":"Érzéki dráma egy érzékeny témáról","homepage":"","overview":"Ramón Sampedro egy fiatalkori balesete következményeként már csaknem harminc éve él ágyhoz kötötten. Azóta az egyetlen kapocs, ami a külvilághoz köti, a tengerre néző szobájának ablaka és egyetlen vágya, hogy méltósággal fejezhesse be életét. Napjait azonban megváltoztatja két nő érkezése. Julia, az ügyvédnő azért jön, hogy segítsen az eutanáziára irányuló kérelem megszerzésében. Rosa, egy nő a faluból, aki megpróbálja meggyőzni őt arról, hogy mégis érdemes életben maradnia. Ramón rendkívüli személyisége mindkét nőt rabul ejti és arra készteti őket, hogy most először végiggondolják azokat az elveket, amelyek szerint saját életüket irányítják. Ramón tisztában van vele, hogy csak az képes segíteni neki az utolsó úton, aki igazából szereti őt."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"深海长眠","runtime":125,"tagline":"","homepage":"","overview":"　　雷蒙（贾维尔•巴尔登 Javier Bardem 饰）在一次跳海运动中出了意外，全身瘫痪。原本英俊壮健的他要在煎熬中度过余生。他忍受着常人无法理解的痛苦中过活了26年，已经无法领会到活着的意义。他一再申请安乐死，却无法获准。他请来律师朱莉娅（贝兰•鲁达 Belén Rueda 饰），这个女人在与雷蒙的相处中慢慢认同了他的观点，她不幸也身患绝症，二人更加惺惺相惜。朱莉娅承诺帮雷蒙出版诗集后，就和他一同赴死。\r 　　有一个少妇知道了雷蒙的经历，力劝他不要放弃生命，并深深爱上这个不幸的人。然而，这一切都无法把雷蒙从瘫痪的煎熬中重生过来。然而他还等着朱莉娅一起告别这个世界。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Mar adentro","runtime":125,"tagline":"","homepage":"","overview":"À la suite d'un accident dont il a été victime dans sa jeunesse, Ramón ne peut plus bouger que la tête. « Enfermé dans son corps », il vit depuis presque trente ans prostré dans un lit. Sa seule ouverture sur le monde est la fenêtre de sa chambre à travers laquelle il « voyage » jusqu'à la mer toute proche ; cette mer qui lui a tant donné et tout repris. Pourtant très entouré par sa famille, Ramón n'a plus qu'un seul désir : pouvoir décider de sa propre mort et terminer sa vie dans la dignité…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"海を飛ぶ夢","runtime":0,"tagline":"","homepage":"","overview":"25歳の夏にラモン・サンペドロは、事故により首を骨折、寝たきりの生活を送る身体になってしまう。それから26年後、ラモンは自ら人生にピリオドを打つことを決意するが、弁護士フリアと村の女ローザと出会う。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Η Θάλασσα Μέσα μου","runtime":0,"tagline":"","homepage":"","overview":"Συγκλονιστική ταινία, βασισμένη σε μια αληθινή ιστορία: εκείνη του Ραμόν Σαμπένδρο, Ισπανού ποιητή που μένει τετραπληγικός στα 25 του χρόνια (βουτώντας στο νερό από έναν βράχο), και αγωνίζεται να πείσει το κράτος να περάσει νόμο για την ευθανασία, ώστε να καταφέρει τελικά να δώσει τέρμα στη ζωή του. «Μια ζωή σ' αυτήν την κατάσταση δεν έχει αξιοπρέπεια», λέει σε κάποια στιγμή ο ήρωας θυμούμενος την όλο ζωντάνια και σφρίγος προηγούμενη ζωή του. Παρά τις προσπάθειες συγγενών, φίλων ακόμα και ενός υπερόπτη, παραπληγικού ιερέα να τον πείσουν να ζήσει, θα καταφέρει τελικά να δώσει τέρμα στη ζωή του, πίνοντας υδροκυάνιο, οργανώνοντας το θάνατό του μ' έναν έξυπνο τρόπο ώστε νομικά να μη μπορεί να κατηγορηθεί κανείς."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"הים שבפנים","runtime":0,"tagline":"","homepage":"","overview":"סיפורו האמיתי והנוגע ללב של ראמון סמפדרו שנלחם במשך שלושים שנה על זכותו למות. במרכז העלילה עומדות שתי מערכות יחסים: בינו לבין עורכת הדין שתומכת במאבקו, ובינו לבין אשה מקומית שעושה הכל כדי לעזור לבחור דווקא בחיים."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Gråta med ett leende","runtime":125,"tagline":"","homepage":"","overview":"Ramon är totalförlamad sedan närmare 30 år och vill inget hellre än att få dö en värdig död. Advokaten Julia hjälper Ramon i kampen mot myndighteterna, medan den fattiga Rosa försöker få honom att återfinna sin livslust."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Mar Adentro","runtime":125,"tagline":"A vida é um direito, não uma obrigação.","homepage":"","overview":"Ramón Sampedro (Javier Bardem) é um homem que luta para ter o direito de pôr fim à sua própria vida. Na juventude ele sofreu um acidente, que o deixou tetraplégico e preso a uma cama por 28 anos. Lúcido e extremamente inteligente, Ramón decide lutar na justiça pelo direito de decidir sobre sua própria vida, o que lhe gera problemas com a igreja, a sociedade e até mesmo seus familiares."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"씨 인사이드","runtime":0,"tagline":"세상에서 가장 아름다운 이별","homepage":"","overview":"26년 전, 수심을 알 수 없는 바다에서 다이빙을 하다 전신마비자가 된 남자가 있다. 라몬 삼페드로, 무기력한 전신마비자이기 보단 의욕적이고 이성적인 모습으로 죽을 수 있는 권리를 찾고자 했던 그에게 바다는 단 1미터도 움직일 수 없는 인생을 안겨준 공간이자, 영원한 자유를 소망하는 꿈의 공간이다. 가족들의 헌신적인 뒷바라지 속에 침대에 누워서 오로지 입으로 펜을 잡고 글을 써왔던 그의 소망은 단 하나, 안락사로 세상을 떠나는 것이다.  한편, 라몬을 찾아온 두 명의 여자가 있다. 통조림 공장에서 일하는 수다스럽지만 순수한 여인 로사. 라몬이 스스로 생을 끊으려고 한다는 소식을 듣고 무턱대고 그를 찾아와 친구가 된 그녀는 라몬을 사랑하게 되고, 급기야 자신을 위해 삶을 포기하지 말라고 설득한다. 또한 퇴행성 질환을 앓고 있는 변호사 줄리아. 라몬의 자유로운 삶을 위해 안락사 소송을 도와주는 동안 그녀는 그에게 점점 사랑을 느끼지만, 그 감정조차도 그들에겐 너무나 버거울 뿐인데.."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"","runtime":125,"tagline":"","homepage":"","overview":"Ramón ligt al bijna 30 jaar krachteloos in zijn bed, onder de hoede van zijn familie. Zijn enige uitzicht op het leven is het raam van zijn kamer, vlakbij de zee die hij ooit zo graag bereisde en waar hij het ongeluk kreeg dat een einde maakte aan zijn jeugd."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Hlas moře","runtime":0,"tagline":"","homepage":"","overview":"Ramón je již 30 let upoután na lůžko a jeho rodina se o něj stará. Jediný pohled na svět mu umožňuje pouze okno v jeho ložnici. Dívá se na moře, na které se často plavil a na kterém utrpěl úraz, který zkrátil jeho mládí. Od té doby má jediné přání - důstojně ukončit svůj život. Jeho svět je však převrácen naruby příchodem dvou žen: Julie, právničky, která mu pomáhá v jeho úsilí legálně ukončit svůj život; a Rose, žena z vesnice, která se ho snaží přesvědčit, že život za to stojí žít až do konce. Obě ženy jsou zaujaty Ramónovou poutavou osobností a jsou nuceny se samy sebe ptát po důvodech, které ovládaly jejich životy až potud. Ramón ví, že pouze jedna z nich, která ho skutečně miluje, mu pomůže podstoupit tu poslední cestu. Pravdivý životní příběh Španěla Ramona Sampedra, který 30 let vedl kampaň za právo na euthanasii a za právo na svou vlastní smrt. (oficiální text distributora)"},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"W stronę morza","runtime":0,"tagline":"","homepage":"","overview":"Jeden z najbardziej kontrowersyjnych obrazów roku poruszający temat eutanazji. Film jest opowieścią o życiu Ramona Sampedro (Javier Bardem), człowieka który przez prawie 30 lat swojego życia toczył walkę o... śmierć, która w jego rozumieniu była ucieczką od cierpień. Po ciężkim wypadku został sparaliżowany. Mimo, ze otoczony był miłością rodziny i przyjaciół od tamtej pory cały czas starał się o skrócenie cierpień. W końcu, rozgoryczony postawą sądu, postanawia popełnić samobójstwo."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Морето в мен","runtime":125,"tagline":"","homepage":"","overview":"Филмът разказва за испанеца Рамон Санпедро и неговата 30-годишна битка да спечели правото на достоен край на живота си. \"Морето в мен\" е история за отношенията на рамон с две жени – хулия – адвокатка, която подкрепя каузата му, и роса – местна жена, която иска да го убеди, че животът си струва да се живее. Дарената от него любов вдъхновява тези две жени да извършват неща, които никога преди не са смятали за възможни."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Volanie mora","runtime":0,"tagline":"","homepage":"","overview":"Ramón je už 30 rokov pripútaný na lôžko a jeho rodina sa o neho stará. Jediný pohľad na svet mu umožňuje iba okno v jeho spálni. Pozerá sa na more, na ktoré sa často plavil a na ktorom utrpel úraz, ktorý skrátil jeho mladosť. Odvtedy má jediné prianie - dôstojne ukončiť svoj život. Jeho svet je však prevrátený naruby príchodom dvoch žien: Julie, právničky, ktorá mu pomáha v jeho úsilí legálne ukončiť svoj život; a Rose, ženy z dediny, ktorá sa ho snaží presvedčiť, že život za to stojí žiť až do konca. Obe ženy sú zaujaté Ramonovou pútavou osobnosťou a sú nútené sa samy seba pýtať na dôvody, ktoré ovládali ich životy až dosiaľ. Ramón vie, že iba jedna z nich, ktorá ho skutočne miluje, mu pomôže podstúpiť tú poslednú cestu. Pravdivý životný príbeh Španiela Ramona Sampedra, ktorý 30 rokov viedol kampaň za právo na eutanáziu a za právo na svoju vlastnú smrť."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Jūros gelmėse","runtime":0,"tagline":"","homepage":"","overview":"„Jūros gelmėse\" remiasi autentiška istorija. Filme atskleidžiama ispanų žvejo ir laivo mechaniko Ramono Sampedro gyvenimo istorija. 1969-siais jis patyrė sunkią stuburo traumą ir buvo paralyžuotas nuo kaklo iki kojų. Prie lovos prikaustytas vyras net 29 metus mėgino įteisinti eutanaziją, o 1988-siais meistriškai suplanavo savo savižudybę ir išgėrė lemtingą gurkšnį vandens su cianidu."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Море всередині","runtime":0,"tagline":"","homepage":"","overview":"Реальна історія іспанця Рамона Сампедро, який, будучи повністю паралізованим, тридцять років боровся за право на добровільне позбавлення життя. Дві жінки супроводжували його всі ці роки — Джулія, його адвокат в судових тяжбах, і Роза, що відчайдушно намагалася переконати Сампедро, що життя варте того, щоб жити…"},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Život je more","runtime":0,"tagline":"","homepage":"","overview":"Ramon je već skoro trideset godina ležao u krevetu u brizi o svojoj obitelji. Njegov je jedini prozor u svijet onaj u njegovoj sobi, pored mora gdje je toliko putovao i gdje je pretrpio nesreću koja je prekinula njegovu mladost. Od tada jedina mu je želja dostojanstveno okončati život. Dolazak dviju žena promijenit će njegov svijet: Julia, odvjetnica koja želi podržati njegovu borbu i Rosa, susjeda grada koja će ga pokušati uvjeriti da život vrijedi živjeti. Ramonova blistava ličnost na kraju obožava očaravajući njih, koji će se morati pitati kao nikad prije o načelima koja upravljaju njihovim životima. Zna da će samo ona osoba koja ga istinski voli biti ta koja će mu pomoći da krene na posljednje putovanje."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Mit indre hav","runtime":0,"tagline":"","homepage":"","overview":"Ramon har været sengeliggende i næsten tredive år i plejen af sin familie. Hans eneste vindue mod verden er det i hans værelse ved siden af havet, hvor han rejste så meget, og hvor han led ulykken, der afbrød hans ungdom. Siden da er hans eneste ønske at afslutte sit liv med værdighed. To kvinders ankomst vil ændre hans verden: Julia, den advokat, der ønsker at støtte hans kamp, og Rosa, en nabo i byen, der vil prøve at overbevise ham om, at livet er værd at leve. Ramons lysende personlighed ender med at fange begge to, som bliver nødt til at stille spørgsmål som aldrig før de principper, der styrer deres liv. Han ved, at kun den, der virkelig elsker ham, er den, der hjælper ham med at tage den sidste rejse."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Sisemeri","runtime":0,"tagline":"","homepage":"","overview":"Ramon on oma pere hoole all magatud peaaegu kolmkümmend aastat. Tema ainus aken maailma on see, mis asub tema toas, mere kõrval, kus ta nii palju reisis ja kus ta kannatas õnnetuse, mis segas tema nooruse. Sellest ajast peale on tema ainus soov lõpetada elu väärikalt. Kahe naise saabumine muudab tema maailma: advokaat Julia, kes soovib oma võitlust toetada, ja Rosa, linna naaber, kes püüab teda veenda, et elu on elamist väärt. Ramóni helendav isiksus paelub mõlemat, kes peavad nagu kunagi varem küsitlema nende elu valitsevate põhimõtete üle. Ta teab, et ainult see, kes teda tõeliselt armastab, aitab teda sellel viimasel teekonnal."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"Meri sisälläni","runtime":0,"tagline":"","homepage":"","overview":"Ramon on ollut sängyssä lähes kolmekymmentä vuotta perheensä hoidossa. Hänen ainoa ikkuna maailmaan on huoneessaan, meren vieressä, missä hän matkusti niin paljon ja missä hän kärsi onnettomuuden, joka keskeytti hänen nuoruutensa. Sittemmin hänen ainoa toiveensa on lopettaa elämänsä arvokkaasti. Kahden naisen saapuminen muuttaa hänen maailmaa: Julia, lakimies, joka haluaa tukea kamppailuaan, ja Rosa, kaupungin naapuri, joka yrittää vakuuttaa hänelle, että elämä on elämisen arvoinen. Ramónin valoisa persoonallisuus päätyy kiehtovaksi molemmista, joiden on kysyttävä kuin koskaan ennen heidän elämäänsä hallitsevia periaatteita. Hän tietää, että vain henkilö, joka todella rakastaa häntä, auttaa häntä tekemään viimeisen matkan."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Havet innenfor","runtime":0,"tagline":"","homepage":"","overview":"Ramon har vært sengeliggende i nesten tretti år i omsorgen for familien. Hans eneste vindu mot verden er det på rommet hans, ved siden av havet der han reiste så mye og hvor han led ulykken som avbrøt ungdommen hans. Siden den gang er hans eneste ønske å avslutte livet med verdighet. To kvinners ankomst vil forandre hans verden: Julia, advokaten som ønsker å støtte sin kamp, og Rosa, en nabo av byen som vil prøve å overbevise ham om at livet er verdt å leve. Ramons lysende personlighet ender med å fange opp begge, som vil måtte stille spørsmål som aldri før prinsippene som styrer deres liv. Han vet at bare personen som virkelig elsker ham, vil være den som hjelper ham med å ta den siste reisen."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Marea dinauntru","runtime":0,"tagline":"","homepage":"","overview":"Ramon a fost culcat de aproape treizeci de ani în grija familiei sale. Singura lui fereastră către lume este cea din camera lui, lângă marea în care a călătorit atât de mult și unde a suferit accidentul care i-a întrerupt tinerețea. De atunci, singura sa dorință este să-și încheie viața cu demnitate. Sosirea a două femei îi va schimba lumea: Julia, avocata care vrea să-și susțină lupta și Rosa, o vecină a orașului care va încerca să-l convingă că viața merită trăită. Personalitatea luminoasă a lui Ramón sfârșește prin a-i captiva pe amândoi, care vor trebui să se pună la îndoială ca niciodată înainte de principiile care le guvernează viața. Știe că numai persoana care îl iubește cu adevărat va fi cea care îl va ajuta să facă acea călătorie finală."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Море у нама","runtime":0,"tagline":"","homepage":"","overview":"Стварна прича о Шпанцу Рамону Сампедру, који је водио 28-годишњу кампању у корист еутаназије и сопственог права на смрт."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"Biển Sóng Trong Lòng","runtime":0,"tagline":"","homepage":"","overview":"The Sea Inside kể về câu chuyện có thật đầy thổn thức của một người đàn ông bị bại liệt Ramon Sampedro và cuộc đấu tranh của ông với cơ quan y tế Tây Ban Nha và các giáo lý tôn giáo nước này để đòi quyền được chết không đau đớn (An tử) sau khi chống chọi với bệnh tật suốt 30 năm trời. Bên cạnh đó, mối quan hệ tình cảm giữa Ramon với hai người phụ nữ là Julia, nữ luật sư giúp anh trong vụ kiện và Rosa, người phụ nữ hàng ngày chăm sóc và thuyết phục anh rằng cuộc đời này rất đáng sống, cũng đã được tái hiện một cách chân thực nhất."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"點燃生命之海","runtime":0,"tagline":"","homepage":"","overview":"雷蒙（賈維爾‧巴爾登 Javier Bardem 飾）在一次跳海運動中出了意外，全身癱瘓。原本英俊壯健的他要在煎熬中度過餘生。他忍受著常人無法理解的痛苦中過活了26年，已經無法領會到活著的意義。他一再申請安樂死，卻無法獲准。他請來律師朱莉婭（貝蘭‧魯達 Belen Rueda 飾），這個女人在與雷蒙的相處中慢慢認同了他的觀點，她不幸也身患絕症，二人更加惺惺相惜。朱莉婭承諾幫雷蒙出版詩集後，就和他一同赴死。\r 　　有一個少婦知道了雷蒙的經歷，力勸他不要放棄生命，並深深愛上這個不幸的人。然而，這一切都無法把雷蒙從癱瘓的煎熬中重生過來。然而他還等著朱莉婭一起告別這個世界。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"情流心海","runtime":0,"tagline":"","homepage":"","overview":"西班牙機械師拉蒙在一次跳水意外後全身癱瘓。在之後的 28 年裏, 拉蒙為能夠合法地給自己實施安樂死而鬥爭。影片設計了兩位立場迥異的女性，朱莉亞－一位受到腦病折磨並且支持拉蒙決定的律師；蘿薩－一位始終勸阻拉蒙並告訴他生命自有其意義的本地女性。在於拉蒙相處的日子裏，兩位女性逐漸改變了看法並發現了在生命中從未觸及的想法。雖然拉蒙一心求死，但他帶給身邊的人他對於生命、尊嚴和愛的價值。儘管到最後法律也沒有允許拉蒙結束自己的生命，但拉蒙還是自己服下了氰化物，帶著尊嚴離開了世界。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Rodado en Galicia, baséase na historia real de Ramón Sampedro, un escritor e ex-mariñeiro que quedou tetrapléxico logo dun accidente ocorrido durante a súa xuventude. Permanece prostrado nunha cama durante case 30 anos, situación pola que desexa morrer mediante a aplicación da eutanasia. O filme relata a loita de Sampedro para lograr que a lei recoñeza o seu dereito a morrer."},"name":"Galego","iso_639_1":"gl","iso_3166_1":"ES","english_name":"Galician"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Ramón (Javier Bardem) lleva casi treinta años postrado en una cama al cuidado de su familia. Su única ventana al mundo es la de su habitación, que da al mar, donde sufrió el accidente que interrumpió su juventud. Desde entonces, su único deseo es morir dignamente. En su vida ejercen una gran influencia dos mujeres: Julia (Belén Rueda), una abogada que apoya su causa, y Rosa (Lola Dueñas), una vecina que intenta convencerlo de que vivir merece la pena. Pero también ellas, cautivadas por la luminosa personalidad de Ramón, se replantearán los principios que rigen sus vidas. Él sabe que sólo quien de verdad le ame le ayudará a emprender el último viaje."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"}],"reviews_tmdb":[],"recommendations":[{"id":214761,"adult":false,"title":"7th Floor","video":false,"overview":"Buenos Aires, Argentina. Sebastián, a successful lawyer, leaves his ex-wife's condo, located on the seventh floor of an apartment building, to take his two children to school. While they run down the stairs, he uses the elevator. Once on the ground floor, Sebastián awaits the arrival of the children.","genre_ids":[18,53],"media_type":"movie","popularity":0.6169,"vote_count":249,"poster_path":"/dTSJHOcV8adoDYEx7IYdRwlV3D3.jpg","release_date":"2013-09-05","vote_average":5.823,"backdrop_path":"/nFgQU011NrKHPKDxjow24lncMck.jpg","original_title":"Séptimo","original_language":"es"},{"id":661728,"adult":false,"title":"Tom Papa: You're Doing Great!","video":false,"overview":"Comedian Tom Papa takes on body image issues, social media, pets, Staten Island, the \"old days\" and more in a special from his home state of New Jersey.","genre_ids":[35],"media_type":"movie","popularity":0.2064,"vote_count":25,"poster_path":"/8ba7sfo3MU2DuvxJg6DmlThSYmg.jpg","release_date":"2020-02-04","vote_average":6.4,"backdrop_path":"/cBArGMNeBmd3SyHDaYCMT9D4qw8.jpg","original_title":"Tom Papa: You're Doing Great!","original_language":"en"},{"id":36505,"adult":false,"title":"On Earth as It Is in Heaven","video":false,"overview":"Matacanes dies and goes to heaven just to discover that it was not as he expected, and everyone there is revolutionized lately. Peter explains that God was concerned about the progress of the world, and decided to send a second son to Earth. However, Jesus hears and does not agree, as they would have to rewrite history.","genre_ids":[35],"media_type":"movie","popularity":0.2704,"vote_count":31,"poster_path":"/oAwllE6TZePksJyC5mwiz3Eqa7J.jpg","release_date":"1995-11-03","vote_average":5.581,"backdrop_path":"/hfi3IEqtTQhk6bgGIXAyDbNplml.jpg","original_title":"Así en el Cielo como en la Tierra","original_language":"es"},{"id":52258,"adult":false,"title":"The Emperor's New Clothes","video":false,"overview":"Napoleon, exiled, devises a plan to retake the throne. He'll swap places with commoner Eugene Lenormand, sneak into Paris, then Lenormand will reveal himself and Napoleon will regain his throne. Things don't go at all well; first, the journey proves more difficult than expected, but more disastrously, Lenormand enjoys himself too much to reveal the deception. Napoleon adjusts somewhat uneasily to the life of a commoner while waiting, while Lenormand gorges on rich food.","genre_ids":[35,18],"media_type":"movie","popularity":0.5796,"vote_count":42,"poster_path":"/iTonTn91U4X1px7KXAHTFnIA4ud.jpg","release_date":"2001-08-11","vote_average":6.7,"backdrop_path":"/2XVEjzisS34cJy14OsR8d980gYj.jpg","original_title":"The Emperor's New Clothes","original_language":"en"},{"id":21041,"adult":false,"title":"The Third Wave","video":false,"overview":"Johan Falk hasn't been working for over a year since he resigned from the police. Most of all he wants to move out to the countryside, but fate has a different thought.","genre_ids":[28,53],"media_type":"movie","popularity":0.3089,"vote_count":65,"poster_path":"/qANSnHCJPYfc5lsAybMFlTw36Tn.jpg","release_date":"2003-10-15","vote_average":6.1,"backdrop_path":"/tOFV6eQ92pb8LiH8w7J4BodDR6C.jpg","original_title":"Den tredje vågen","original_language":"sv"},{"id":76297,"adult":false,"title":"All's Faire in Love","video":false,"overview":"Two rival medieval families compete for power and love in the fairytale world of the Renaissance. Will is a student who was sent by his professor to work in the fairgrounds after missing a few classes. Here he meets the kind and charming Kate, who quit her job at the bank to work at the fair. This is where this modern-day love story begins, in Renaissance garb!","genre_ids":[35,10749],"media_type":"movie","popularity":0.3666,"vote_count":28,"poster_path":"/1awVuRX4iJ1kSRy9mfynZppZMFg.jpg","release_date":"2009-05-15","vote_average":5.9,"backdrop_path":"/hc8k5P5k0Akyvn1LGUtNbSv4Za.jpg","original_title":"All's Faire in Love","original_language":"en"},{"id":1917,"adult":false,"title":"Who Killed Bambi?","video":false,"overview":"Isabelle, a beautiful nursing student, is starting her internship at a prestigious hospital. She meets Dr. Philip there, feels atracted to him from the beggining and starts suffering from strange fainting; so he calls her Bambi: her legs don't support her. Patients mysteriously start to dissappear from their rooms; so Bambi and Dr. Philip start a cat vs. mouse paranoid game, in order to catch the probable killer.","genre_ids":[53],"media_type":"movie","popularity":0.2895,"vote_count":37,"poster_path":"/nKhmdbwcMXWM21AqSBKLvV3kdog.jpg","release_date":"2003-12-24","vote_average":5.973,"backdrop_path":"/6zGsyQLBS5uS7ZLZRdd55CsohUO.jpg","original_title":"Qui a tué Bambi ?","original_language":"fr"},{"id":50387,"adult":false,"title":"Grimm","video":false,"overview":"One cold winter's day, Jacob and his sister Marie are abandoned in a wood by their out of work father. In his jacket Jacob finds a letter from their mother urging them to go to her brother in Spain. Once in Spain, it turns out that their uncle is dead. Marie meets Diego, a wealthy charming Spanish surgeon, and falls in love with him. Diego lives with his sick, domineering sister, Teresa. To Jacob's astonishment, Marie wants to marry Diego. Even after the wedding has taken place, jealous Jacob tries to get his sister away from Diego. When this doesn't succeed, Jacob starts to provoke his brother-in-law. It soon transpires that no one will go unpunished for this.","genre_ids":[18,35,12],"media_type":"movie","popularity":0.7725,"vote_count":40,"poster_path":"/sQqsGLGjQFMR9lHlQDJyjPMih6Y.jpg","release_date":"2003-10-08","vote_average":5.663,"backdrop_path":"/327ezUILPLcQ2tuaDyWaEG09GJf.jpg","original_title":"Grimm","original_language":"nl"},{"id":631737,"adult":false,"title":"The First Forgotten","video":false,"overview":"For years, Axel has cut off ties with his family, devastated by a tragedy for which he was made to bear responsibility. When the freighter on which he was cook stopped in his hometown, he decided to visit his mother, Françoise. It's a shock: she no longer recognizes him. Having Alzheimer's disease, Françoise now forgets whole sections of her life. Axel is the first of the siblings to disappear from his memory. Why him? What is he hiding behind this oversight? And while Ivan and Lucie have agreed to have her admitted in the center, Axel opposes it frontally and delays her departure to take care of her, despite the tensions. Between the mother and the son opens the face-to-face so long feared and yet necessary.","genre_ids":[18,10770],"media_type":"movie","popularity":0.3518,"vote_count":28,"poster_path":"/nZzHjSA1vhI37tYE5VemxbsHz9M.jpg","release_date":"2019-09-22","vote_average":7.3,"backdrop_path":"/2t0Pfb7UtT5mTAOY7p9qtq5sabw.jpg","original_title":"Le Premier Oublié","original_language":"fr"},{"id":54155,"adult":false,"title":"Hands in the Air","video":false,"overview":"March 22, 2067. At dawn of life, Milana remembers her life, when she was a young Chechen immigrant in Paris, struggling for a better life along with her school friends.","genre_ids":[18,35,10749],"media_type":"movie","popularity":0.1127,"vote_count":10,"poster_path":"/hhdLJG1bgoci12ycOmIOOvcmaCK.jpg","release_date":"2010-07-06","vote_average":5.85,"backdrop_path":"/qlLO7HdNyi0jGaIoy1QvCxikTsD.jpg","original_title":"Les mains en l'air","original_language":"fr"},{"id":891129,"adult":false,"title":"Dolores guapa!","video":false,"overview":"Religious-based images and traditions permeate the lives of all the people who inhabit Seville.  Historically, the city's mariquitas (\"sissies\") have also assimilated them in their childhood and,  through them, have been creating their own encounter spaces and their own codes.  Nowadays, new dissident identities continue to respond to them: they participate or distance  themselves, they continue what exists or transform it. This film looks at these traditions from a  perspective always relegated to the margins.","genre_ids":[99],"media_type":"movie","popularity":0.3676,"vote_count":3,"poster_path":"/Af2fHOszDJy2hWfknbQGRWUPKDe.jpg","release_date":"2022-05-20","vote_average":4.7,"backdrop_path":"/wu6cgVhAXvdlNlSVttBkGlUwAYb.jpg","original_title":"¡Dolores guapa!","original_language":"es"},{"id":671812,"adult":false,"title":"The Match","video":false,"overview":"One football match on a dirt pitch near Rome becomes a day of reckoning as a young player, his coach and their team's owner wrestle internal demons.","genre_ids":[18],"media_type":"movie","popularity":0.2098,"vote_count":88,"poster_path":"/pPOoMzOC7GX5aFbdbQCczSqywMQ.jpg","release_date":"2020-02-27","vote_average":5.7,"backdrop_path":"/m4F3eazOANbWu2ICzA7vAMNgqzU.jpg","original_title":"La partita","original_language":"it"},{"id":55368,"adult":false,"title":"Lacombe, Lucien","video":false,"overview":"In Louis Malle's lauded drama, Lucien Lacombe is a young man living in rural France during World War II who seeks to join the French Resistance. When he is rejected due to his youth, the resentful Lucien allies himself with the Nazis and joins the Gallic arm of their Gestapo. Lucien grows to enjoy the power that comes with his position, but his life is complicated when he falls for France Horn, a beautiful young Jewish woman.","genre_ids":[18,10752],"media_type":"movie","popularity":0.485,"vote_count":158,"poster_path":"/gHlorDyJrigxzcuZaQ5p4mseAPC.jpg","release_date":"1974-01-30","vote_average":7.009,"backdrop_path":"/ikO0koqdi0V7Z9CJXwwKf5tiTrs.jpg","original_title":"Lacombe Lucien","original_language":"fr"},{"id":18264,"adult":false,"title":"The Man from Laramie","video":false,"overview":"Will Lockhart arrives in Coronado, an isolated town in New Mexico, in search of someone who sells rifles to the Apache tribe, finding himself unwillingly drawn into the convoluted life of a local ranching family whose members seem to have a lot to hide.","genre_ids":[18,37],"media_type":"movie","popularity":0.7891,"vote_count":250,"poster_path":"/aKMZoZpN0FobSIDAlj5Ixv0kDeT.jpg","release_date":"1955-08-19","vote_average":7.2,"backdrop_path":"/vN604vmU4V3fps7lRFJe2y94M5g.jpg","original_title":"The Man from Laramie","original_language":"en"},{"id":17899,"adult":false,"title":"Sex, Party and Lies","video":false,"overview":"A youth group is preparing for what will be the summer of their life, including secrets, lies, sex, confusion, evenings and holidays.","genre_ids":[35,18],"media_type":"movie","popularity":4.1557,"vote_count":152,"poster_path":"/8D16rdCmTYCg66EMwK1ZZDWiK3x.jpg","release_date":"2009-03-27","vote_average":4.6,"backdrop_path":"/pv82OBJIF3v5inCkpxfb2XZFYta.jpg","original_title":"Mentiras y gordas","original_language":"es"},{"id":27103,"adult":false,"title":"My Life in Pink","video":false,"overview":"Ludovic is waiting for a miracle. With six-year-old certainty, she believes she was meant to be a little girl -- and that the mistake will soon be corrected. But where she expects the miraculous, Ludo finds only rejection, isolation, and guilt -- as the intense reactions of family, friends, and neighbors strip away every innocent lace and bauble.","genre_ids":[18,35],"media_type":"movie","popularity":0.4457,"vote_count":106,"poster_path":"/4SwZaSDy1DR80QXKdvp6iSTawK2.jpg","release_date":"1997-05-28","vote_average":6.9,"backdrop_path":"/nfj0CWrBw6lRjPb1yUSqxGjgudt.jpg","original_title":"Ma vie en rose","original_language":"fr"},{"id":13495,"adult":false,"title":"Captain Alatriste: The Spanish Musketeer","video":false,"overview":"In 17th century Spain Diego Alatriste, a brave and heroic soldier, is fighting in his King's army in the Flandes region. His best mate, Balboa, falls in a trap and, near to death, asks Diego to look after his son and teach him to be a soldier.","genre_ids":[28],"media_type":"movie","popularity":3.3141,"vote_count":246,"poster_path":"/hQ4b8dXp0uCqslHm0jOvjw4BNUe.jpg","release_date":"2006-09-01","vote_average":5.9,"backdrop_path":"/eqpkycxmFt6ETn9XuE6dT1ldCdi.jpg","original_title":"Alatriste","original_language":"es"},{"id":411638,"adult":false,"title":"The Fury of a Patient Man","video":false,"overview":"Quiet Jose woos cafe worker Ana, but she is unaware he has intentions other than the purely romantic.","genre_ids":[53],"media_type":"movie","popularity":0.4645,"vote_count":453,"poster_path":"/qwNAEiNrCcOnVNXJCVHxCGEJjsc.jpg","release_date":"2016-09-09","vote_average":6.588,"backdrop_path":"/eVgEBhfjzlWZXbZQLhdxLbWlez.jpg","original_title":"Tarde para la ira","original_language":"es"},{"id":5001,"adult":false,"title":"Before Night Falls","video":false,"overview":"Spanning several decades, this powerful biopic offers a glimpse into the life of famed Cuban poet and novelist Reinaldo Arenas, an artist who was vilified for his homosexuality in Fidel Castro's Cuba.","genre_ids":[18],"media_type":"movie","popularity":0.9805,"vote_count":296,"poster_path":"/kb2dqj73cfmt6qHAh1ySIlVm6v0.jpg","release_date":"2000-09-03","vote_average":6.63,"backdrop_path":"/euDDsCiURZDuhJccrkM1bAJbb8r.jpg","original_title":"Before Night Falls","original_language":"en"},{"id":35640,"adult":false,"title":"Spanish Movie","video":false,"overview":"Large doses of humor, ingenious nods to Spain's most recent national cinema, an artistic cast highly linked to comedy and a high reserve of surprises constitute the ingredients of this crazy comedy: Spanish Movie.","genre_ids":[35],"media_type":"movie","popularity":0.8252,"vote_count":188,"poster_path":"/uUW7KgUKBi83kU0tlBJLYwdY4ZR.jpg","release_date":"2009-12-03","vote_average":4.995,"backdrop_path":"/cmz40N9zZWsmCJ2vSlDaCKWeqlt.jpg","original_title":"Spanish Movie","original_language":"es"}],"similar_content":[{"id":1108988,"adult":false,"title":"Meeting Ms. Leigh","video":false,"overview":"A young writer in desperate need of inspiration begins an affair with an enchanting, enigmatic older woman during a weekend in Santa Monica. True feelings emerge, and 