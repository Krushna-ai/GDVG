5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"The Sea Inside\",\"description\":\"Ramón Sampedro is a ship mechanic and part-time poet left a quadriplegic following a diving accident. Ramón fought for 30 years for the legal right to end his own life. He develops close relationships with his long-term lawyer Julia and his friend Rosa, who tries to convince him that his life is worth living. Despite his situation, Ramón manages to inspire those around him to live life to the fullest.\",\"image\":\"https://image.tmdb.org/t/p/w500/mQW1JJKCUg02cmWBzr9JFu9vM1V.jpg\",\"datePublished\":\"2004-09-03\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"ES\",\"inLanguage\":\"es\",\"genre\":[\"Drama\",null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.57,\"bestRating\":10,\"ratingCount\":990}}"}}],["$","$L10",null,{"initialDrama":{"id":"3bb3549e-7fa0-4113-b0e3-5b0e166b7e1d","tmdb_id":1913,"imdb_id":"tt0369702","content_type":"movie","title":"The Sea Inside","original_title":"Mar adentro","overview":"Ramón Sampedro is a ship mechanic and part-time poet left a quadriplegic following a diving accident. Ramón fought for 30 years for the legal right to end his own life. He develops close relationships with his long-term lawyer Julia and his friend Rosa, who tries to convince him that his life is worth living. Despite his situation, Ramón manages to inspire those around him to live life to the fullest.","poster_path":"/mQW1JJKCUg02cmWBzr9JFu9vM1V.jpg","backdrop_path":"/7XmDhCTkce5GH8KCdbMoTZdxn1p.jpg","release_date":"2004-09-03","first_air_date":null,"status":"published","original_language":"es","origin_country":["ES"],"genres":[{"id":18,"name":"Drama"},"drama film","biographical film"],"popularity":3.1583,"vote_average":7.57,"vote_count":990,"runtime":126,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-25T00:41:51.965569+00: