","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/mRUgdPskLIdyYOFkRiA8gVOOBuL.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/wZjfXLJLjjS2TlPAuVfdfj90bcE.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/tqfQLo8zyn5UGZyWir4ZrGkRlzw.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1920,"height":1080,"file_path":"/KjbQ35cX6dfILn9gz9lFhEgrpg.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3200,"height":1800,"file_path":"/qGvfQQeEaehArsNwnh4AXMt5kPY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T06:17:39.252+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Raid 2","runtime":139,"tagline":"Amay Patnaik is Back!","homepage":"","overview":"Set seven years after the events of the first film, it follows the return of IRS officer Amay Patnaik, who is attempting to take down a seemingly benevolent politician."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Raid 2","runtime":145,"tagline":"","homepage":"","overview":"Der Steuereintreiber Amay Patnaik hat bereits unter Beweis gestellt, dass er auch vor den mächtigsten Männern des Landes nicht klein beigibt und sie zur Rechenschaft zieht. Nun ist der einflussreiche Politiker Dada Bhai  in sein Visier gerückt. Mit einer Razzia auf dessen Anwesen soll die Sache nun zu den Akten gelegt werden."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Рейд 2","runtime":0,"tagline":"","homepage":"","overview":"Сотрудник налоговой службы Индии Амай Патнаик за время своей работы изъял более 4200 кроров во время своих рейдов, и теперь расследует очередное преступление, совершённое «белым воротничком»."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"Colarinho Branco 2","runtime":0,"tagline":"","homepage":"","overview":"Um auditor fiscal honesto é transferido para uma pequena cidade do Rajastão e descobre um esquema de corrupção liderado por um famoso político."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"袭击2","runtime":0,"tagline":"","homepage":"","overview":"故事背景设定在第一部电影的七年后，讲述了国税局官员阿迈·帕特奈克 (Amay Patnaik) 的回归，她试图打倒一位看似仁慈的政治家。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"RAID 2","runtime":0,"tagline":"","homepage":"","overview":"Muté dans une petite ville du Rajasthan, un inspecteur des impôts intègre mène l'enquête sur un politicien adulé dont les bonnes actions cachent une corruption endémique."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"เจ้าหน้าที่ระห่ำท้าทรชน 2","runtime":0,"tagline":"","homepage":"","overview":"เจ้าหน้าที่สรรพากรผู้ซื่อสัตย์ที่ถูกย้ายไปยังเมืองเล็กๆ ในราชสถาน พยายามเปิดโปงนักการเมืองท้องถิ่นขวัญใจประชาชน ที่แสร้งทำดีบังหน้า เพื่อปกปิดการทุจริตครั้งใหญ่"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"突襲行動2","runtime":0,"tagline":"","homepage":"","overview":"忠厚老實的稅務官被調到拉賈斯坦邦偏鄉後，查起一位深受愛戴的政治人物，發現親民形象的背後竟是貪污成性的真面目"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"레이드 2","runtime":0,"tagline":"","homepage":"","overview":"1편의 사건으로부터 7년 후를 배경으로, 겉보기에는 선량해 보이는 정치인을 무너뜨리려는 국세청 요원 아메이 팻나익의 귀환을 다룹니다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Raid 2","runtime":0,"tagline":"","homepage":"","overview":"Luego de ser transferido a un pequeño pueblo en Rajastán, un honesto oficial de impuestos persigue a un político popular cuyas buenas acciones esconden actos corruptos."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"突襲行動 2","runtime":139,"tagline":"","homepage":"","overview":"忠厚老實的税務官被調到拉賈斯坦邦偏鄉後，查起一位深受愛戴的政治人物，發現親民形象的背後竟是貪汙成性的真面目"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Redada 2","runtime":0,"tagline":"","homepage":"","overview":"En el Rajastán de 1989, el oficial Patnaik efectúa una redada sin éxito. Tras solicitar un soborno, le trasladan a Bhoj, donde investiga a Dada Bhai, figura respetada. Suspendido tras otra redada, descubre secretos."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"غارة 2","runtime":0,"tagline":"","homepage":"","overview":"تدور الاحداث الفيلم حين يتبع العمل قصة ضابط مصلحة الضرائب الهندية (أماي باتنايك)، والذي تزداد شعبيته بعد إيقاعه باللصوص والمجرمين واحدًا تلو الآخر، ولكن تقوده مداهمة جديدة مع رجل يدعى (دادا مانوهار بهاي) إلى سلسلة من الأحداث العنيفة."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"}],"reviews_tmdb":[],"recommendations":[{"id":1060046,"adult":false,"title":"HIT: The Third Case","video":false,"overview":"The Homicide Intervention Team (HIT) sends ruthless police officer Arjun Sarkaar to find a group of killers and stop their grisly murder spree.","genre_ids":[80,53,28],"media_type":"movie","popularity":1.0892,"vote_count":48,"poster_path":"/wT9tGyFol4RBwkjESXUWeBdnLJn.jpg","release_date":"2025-04-30","vote_average":6.906,"backdrop_path":"/xzpXvyetmrdR3NSRN9uy0xO3lR1.jpg","original_title":"హిట్: ది థర్డ్ కేస్","original_language":"te"},{"id":1288998,"adult":false,"title":"1978","video":false,"overview":"During the World Cup final between Argentina and Holland, in times of military dictatorship, a group of torturers kidnap a