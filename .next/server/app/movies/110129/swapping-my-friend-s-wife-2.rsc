5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Swapping: My Friend's Wife 2\",\"description\":\"A man's business fails and he's chased by loan sharks. He moves in with his best friend. His best friend's wife can't conceive, so the man sleeps with his wife to help her conceive.\",\"image\":\"https://image.tmdb.org/t/p/w500/8NGBIQbpQaSzc2OWIN1BdOMAv7M.jpg\",\"datePublished\":\"2018-07-19\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"KR\",\"inLanguage\":\"ko\",\"genre\":[\"erotic film\",\"Romance\",null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5,\"bestRating\":10,\"ratingCount\":1}}"}}],["$","$L10",null,{"initialDrama":{"id":"7dfd2810-19ae-475a-ae50-19f30f360a13","tmdb_id":702454,"imdb_id":null,"content_type":"movie","title":"Swapping: My Friend's Wife 2","original_title":"스와핑 : 친구의 아내2","overview":"A man's business fails and he's chased by loan sharks. He moves in with his best friend. His best friend's wife can't conceive, so the man sleeps with his wife to help her conceive.","poster_path":"/8NGBIQbpQaSzc2OWIN1BdOMAv7M.jpg","backdrop_path":"/5hQSm7FEGWnd0JnwjpMYyuP4p3m.jpg","release_date":"2018-07-19","first_air_date":null,"status":"published","original_language":"ko","origin_country":["KR"],"genres":[{"name":"erotic film"},{"id":10749,"name":"Romance"},"erotic film"],"popularity":4.3999,"vote_average":5,"vote_count":1,"runtime":70,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-01-31T22:03:35.396256+00:00","updated_at":"2026-02-23T11:33:24.865+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[],"production_countries":[{"name":"South Korea","iso_3166_1":"KR"}],"spoken_languages":[{"name":"한국어/조선말","iso_639_1":"ko","english_name":"Korean"}],"networks":[],"last_air_date":null,"in_production":null,"tmdb_status":"Released","content_rating":null,"keywords":[{"id":155477,"name":"softcore"}],"alternative_titles":[{"type":"","title":"我们的换妻时光","iso_3166_1":"CN"},{"type":"","title":"Swapping: My Friend's Wife 2","iso_3166_1":"US"}],"videos":[{"id":"5eb7ced20cb3350021ccd199","key":"1rIAlqJEOw0","name":"스와핑: 친구의 아내 2 - Trailer","site":"YouTube","size":1080,"type":"Trailer","official":false,"iso_639_1":"en","iso_3166_1":"US","published_at":"2018-07-25T16:40:47.000Z"}],"watch_providers":{"results":{}},"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"KR","main_poster":"/8NGBIQbpQaSzc2OWIN1BdOMAv7M.jpg","images":{"logos":[],"posters":[{"width":2000,"height":3000,"file_path":"/8NGBIQbpQaSzc2OWIN1BdOMAv7M.jpg","iso_639_1":null,"vote_average":3.334},{"width":2000,"height":2829,"file_path":"/oamuIPSLH2zPHkLK677xsp3Lx5A.jpg","iso_639_1":null,"vote_average":0.166},{"width":1200,"height":1800,"file_path":"/p1Mq6FqYoFPm0wkk6crDaSnJSfe.jpg","iso_639_1":null,"vote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/5hQSm7FEGWnd0JnwjpMYyuP4p3m.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T03:50:19.066+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Swapping: My Friend's Wife 2","runtime":70,"tagline":"","homepage":"","overview":"A man's business fails and he's chased by loan sharks. He moves in with his best friend. His best friend's wife can't conceive, so the man sleeps with his wife to help her conceive."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"交換：朋友的妻子 2","runtime":0,"tagline":"","homepage":"","overview":"男主家庭富裕，偶遇曾經的好哥們，卻混的不盡人意，好心的男主邀請好哥們免費住進了自己的豪宅，還給他提供高薪的工作，好哥們非常感動，而男主也有一個難言之隱，就是自己的妻子無法受孕，家裏長輩一直催促，萬般無奈之下，想求助好哥們，讓好哥們的妻子幫忙代孕，好哥們夫妻倆商議了一下，決定幫助男主完成這一心願，於是孤男寡女共居一室，開始了造人計劃. . . ."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"거부할 수 없는 제안, 욕망에 눈을 뜨다!\r 민호와 정식은 둘도 없는 친구 사이다. 그런데 정식이 사업 실패로 빚쟁이들한테 시달려 괴로워하자 민호는 자신의 집까지 빌려주면서 근처로 이사 오길 권한다. 어느 날, 두 부부는 술자리를 하던 중, 민호의 아내 소연이 불임으로 아이를 가질 수 없다는 고민을 털어놓는다. 그리고 정식의 아내 주희에게 자신을 대신해 남편의 아이를 낳아 주면 빚을 전부 갚아주겠다는 파격적인 제안을 한다. 제안을 승락한 날, 친구 정식과 아내가 섹스하는 걸 지켜 본 민호는 너무 괴로워하고, 그런 민호를 위해 소연도 옷을 벗는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"交换：朋友的妻子2","runtime":0,"tagline":"","homepage":"","overview":"男主家庭富裕，偶遇曾经的好哥们，却混的不尽人意，好心的男主邀请好哥们免费住进了自己的豪宅，还给他提供高薪的工作，好哥们非常感动，而男主也有一个难言之隐，就是自己的妻子无法受孕，家里长辈一直催促，万般无奈之下，想求助好哥们，让好哥们的妻子帮忙代孕，好哥们夫妻俩商议了一下，决定帮助男主完成这一心愿，于是孤男寡女共居一室，开始了造人计划...."},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"","runtime":70,"tagline":"","homepage":"","overview":"De zaak van een man mislukt en hij wordt achtervolgd door woekeraars. Hij trekt in bij zijn beste vriend. De vrouw van zijn beste vriend kan niet zwanger worden, dus helpt hij hun een beetje...."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"}],"reviews_tmdb":[],"recommendations":[{"id":79582,"adult":false,"title":"Aliens vs Avatars","video":false,"overview":"Six college friends blowing off steam on a camping trip, find themselves caught up in a cat and mouse hunt with an Alien monster. Not knowing what to do or who to trust, they struggle to protect themselves. Reluctantly, they join forces with another, seemingly friendly, alien, Ava, who orbits the Earth and appears to them in the form of an avatar. Having only one chance at stopping the monster, they must race to locate and repair the Ava’s earth sent robot, before it slaughters them one by one.","genre_ids":[878,27,53],"media_type":"movie","popularity":0.648,"vote_count":34,"poster_path":"/bgwYgUeAMvy6PZXLSDrWy9dlUEQ.jpg","release_date":"2011-09-20","vote_average":3.1,"backdrop_path":null,"original_title":"Aliens vs Avatars","original_language":"en"},{"id":11947,"adult":false,"title":"Emil and the Piglet","video":false,"overview":"Nursing a piglet back to life because it's the runt of the litter earns Emil a friend for life.","genre_ids":[35,10751],"media_type":"movie","popularity":0.2675,"vote_count":77,"poster_path":"/8cMK2tiBrfV0TqCZPJA1O2t0Xko.jpg","release_date":"1973-10-06","vote_average":6.753,"backdrop_path":"/5u5BXfMuGLOkerR1qJPDBdg1fI9.jpg","original_title":"Emil och griseknoen","original_language":"sv"},{"id":238,"adult":false,"title":"The Godfather","video":false,"overview":"Spanning the years 1945 to 1955, a chronicle of the fictional Italian-American Corleone crime family. When organized crime family patriarch, Vito Corleone barely survives an attempt on his life, his youngest son, Michael steps in to take care of the would-be killers, launching a campaign of bloody revenge.","genre_ids":[18,80],"media_type":"movie","popularity":41.4528,"vote_count":22494,"poster_path":"/3bhkrj58Vtu7enYsRolD1fZdja1.jpg","release_date":"1972-03-14","vote_average":8.688,"backdrop_path":"/tSPT36ZKlP2WVHJLM4cQPLSzv3b.jpg","original_title":"The Godfather","original_language":"en"},{"id":105077,"adult":false,"title":"Battlestar Galactica: The Plan","video":false,"overview":"When the initial Cylon attack against the Twelve Colonies fails to achieve complete extermination of human life as planned, twin Number Ones (Cavils) embedded on Galactica and Caprica must improvise to destroy the human survivors.","genre_ids":[878,28,18],"media_type":"movie","popularity":1.2464,"vote_count":468,"poster_path":"/vwtHIRwwASCiX0Ku487DY7YZrag.jpg","release_date":"2009-10-27","vote_average":6.762,"backdrop_path":"/snSFUEA5ftPfrXVb0xphitD2VrP.jpg","original_title":"Battlestar Galactica: The Plan","original_language":"en"},{"id":709,"adult":false,"title":"Licence to Kill","video":false,"overview":"After capturing the notorious drug lord Franz Sanchez, Bond's close friend and former CIA agent Felix Leiter is left for dead and his wife is murdered. Bond goes rogue and seeks vengeance on those responsible, as he infiltrates Sanchez's organization from the inside.","genre_ids":[12,28,53],"media_type":"movie","popularity":5.4467,"vote_count":2096,"poster_path":"/8nzJve63EXA79HGAyidZwivZrQ2.jpg","release_date":"1989-06-13","vote_average":6.43,"backdrop_path":"/ff0oDdHd8iFkFFfMZLXuGcxPphY.jpg","original_title":"Licence to Kill","original_language":"en"},{"id":1025756,"adult":false,"title":"Brother or Marriage 2","video":false,"overview":"Gaukhar is pregnant, and Aidar seems to have finally found a common language with his wife's brothers. But everything changes when the main character is faced with an unusual illness. Kuvad's syndrome - an imaginary pregnancy in men - can completely destroy Aidar's plans and even his marriage.","genre_ids":[35],"media_type":"movie","popularity":0.1458,"vote_count":4,"poster_path":"/svz1EX5jrMH5uHH0CQJ8aiv7A59.jpg","release_date":"2019-01-31","vote_average":7,"backdrop_path":"/uEJDnJnNOmMJ17E5OQj73EM1cKR.jpg","original_title":"Брат или брак 2","original_language":"ru"},{"id":320997,"adult":false,"title":"Goodbye My Friend","video":false,"overview":"Two friends Marzouk and Barakat, work with street vendor Batta on her cart in the melon trade. Al-Gayiar who works in the trade of stolen cars admires them, they work with him till they become his competitors. He decides to get rid of them after they've become a treat.","genre_ids":[28,35,80],"media_type":"movie","popularity":0.4764,"vote_count":20,"poster_path":"/qf9IAfUVnksSVLLIzsvPPuXWTH3.jpg","release_date":"1987-05-28","vote_average":7.1,"backdrop_path":"/AdZjNz7jFhQt4BtaN8X1oo7jFBd.jpg","original_title":"سلام يا صاحبي","original_language":"ar"},{"id":548762,"adult":false,"title":"7 Emotions","video":false,"overview":"Fear, anger, sadness, joy, disgust, envy, shame. Adaś Miauczyński goes back to his childhood days when, like most of us, he used to find it problematic to name the emotions that accompanied him. To improve the quality of his adult life, he decides to return to that time – which proves not so carefree after all – to learn how to experience the seven basic emotions. This extremely unpredictable journey into the past features an abundance of hilarious, even comical, situations but is also filled with lots of touching moments and food for thought.","genre_ids":[18,35],"media_type":"movie","popularity":0.1737,"vote_count":60,"poster_path":"/ac1DIjgHV8ogmuXvDqO2wsG2XLq.jpg","release_date":"2018-10-12","vote_average":6.6,"backdrop_path":"/56EPAmrflwjPA3LnoSlmeVs9Eff.jpg","original_title":"7 uczuć","original_language":"pl"},{"id":584549,"adult":false,"title":"Sherlock Holmes and Dr. Watson: Acquaintance","video":true,"overview":"Dr. Watson, who served in the English armed forces and was in the Afghan war, retires and returns to his homeland, in England. Since the financial situation of the doctor is very precarious, his long-time friend Mr. Stamford offers him to rent a room in the house at 221-B Baker Street, which is rented by an elderly lady - Mrs. Hudson. The second rented room is already occupied by another gentleman - the mysterious Mr. Sherlock Holmes. Holmes makes an ambiguous impression on Watson. He conducts complex chemical experiments with blood, plays the violin, has the deepest knowledge about cigar ash, London dirt and criminal law, but at the same time demonstrates complete ignorance of well-known truths (for example, the fact that the Earth revolves around the Sun), does not read fiction, as well as books on history and philosophy. At the same time, very strange visitors constantly come to Holmes, and on the table he has portraits of personalities of a disgusting appearance.","genre_ids":[9648,10770,80,12],"media_type":"movie","popularity":0.4479,"vote_count":61,"poster_path":"/u2JhH3S3HFuM6bBEaWSyY6qAEdI.jpg","release_date":"1980-03-22","vote_average":7.762,"backdrop_path":"/gGt1bOGuZZxneEPciQpVGHDQiVx.jpg","original_title":"Шерлок Холмс и доктор Ватсон: Знакомство","original_language":"ru"},{"id":11917,"adult":false,"title":"Saw V","video":false,"overview":"Following Jigsaw's grisly demise, Detective Mark Hoffman is commended as a hero, but Agent Strahm is suspicious, and delves into Hoffman's past. Meanwhile, another group of people are put through a series of gruesome tests.","genre_ids":[27,53,80],"media_type":"movie","popularity":2.4403,"vote_count":3742,"poster_path":"/rKl79KqLXg60KFyKsLe4wSSjQ08.jpg","release_date":"2008-10-23","vote_average":6.174,"backdrop_path":"/jIjVPKDow5ai8dbs4PgWmtqg9Ol.jpg","original_title":"Saw V","original_language":"en"},{"id":657,"adult":false,"title":"From Russia with Love","video":false,"overview":"Agent 007 is back in the second installment of the James Bond series, this time battling a secret crime organization known as SPECTRE. Russians Rosa Klebb and Kronsteen are out to snatch a decoding device known as the Lektor, using the ravishing Tatiana to lure Bond into helping them. Bond willingly travels to meet Tatiana in Istanbul, where he must rely on his wits to escape with his life in a series of deadly encounters with the enemy.","genre_ids":[28,53,12],"media_type":"movie","popularity":5.8833,"vote_count":3282,"poster_path":"/zx4V17FP8oclNvOpTgs2iCCtiYk.jpg","release_date":"1963-10-10","vote_average":7.066,"backdrop_path":"/8JMiQa0OqsCYvbNUrQIrMzwV7g2.jpg","original_title":"From Russia with Love","original_language":"en"},{"id":400874,"adult":false,"title":"Ever After High: Spring Unsprung","video":false,"overview":"When the Storybook of Legends is found by Alistair Wonderland and Bunny Blanc, the two friends decide to bring the book back to Ever After High, but the Cheshire Cat has other plans for the book and swaps it with a book of cursed riddles instead, that turn all who read it topsy-turvy with their wild magic, one of whom is Apple, who thus threatens to destroy the fairytale world. Now, with only Maddie, Alistair, Lizzie, Bunny and Kitty left, they must solve the malicious riddle of the Cheshire Cat, and save their friend