000,"file_path":"/4aH0akVk9MqycCEd0bRlReFvAjc.jpg","iso_639_1":"de","vote_average":3.334},{"width":1978,"height":2835,"file_path":"/fQ8Q3VAybCt6fHFJQD0kwd5azNL.jpg","iso_639_1":"ko","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/A62cueRErsygbxm95wQvcMplwk8.jpg","iso_639_1":"th","vote_average":3.334},{"width":1440,"height":2132,"file_path":"/wimky75xdeozY8zo6jpPyJ1YU6B.jpg","iso_639_1":"th","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/pT6sSrUsylpAkxue7Gvr4b8woeu.jpg","iso_639_1":"en","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/mgqAZeEI5hnAgeVZ0kAdYiPy1Rs.jpg","iso_639_1":"es","vote_average":3.334}],"backdrops":[{"width":3840,"height":2160,"file_path":"/7HKpc11uQfxnw0Y8tRUYn1fsKqE.jpg","iso_639_1":null,"vote_average":10},{"width":3840,"height":2160,"file_path":"/gIClklFGYBe0uiOoiP2vtocJbss.jpg","iso_639_1":null,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/bVVbz4nODTWOxdP3gUs1TTBhBNo.jpg","iso_639_1":"pt","vote_average":3.334},{"width":3840,"height":2160,"file_path":"/po1niVuud0tX86xOFegO5omQ2wX.jpg","iso_639_1":null,"vote_average":2.278},{"width":3480,"height":1957,"file_path":"/l0rY0RH64CXne5vW2Y3yHZpjmDy.jpg","iso_639_1":null,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/mHC8tSRYfAKGh2jaSNQMSzGdbOW.jpg","iso_639_1":null,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/vbI706C9s6QBgmJ9QQ0nA70Wi9W.jpg","iso_639_1":null,"vote_average":1.434},{"width":1280,"height":720,"file_path":"/16mDdz1ORTTHdO5nQylxFAEXa1G.jpg","iso_639_1":null,"vote_average":0.166},{"width":1550,"height":871,"file_path":"/g75DiGaSg2bypTrUgJMXQssA82x.jpg","iso_639_1":null,"vote_average":0.166},{"width":1550,"height":871,"file_path":"/iUWewxLYiIz0xeuUos6fzrmaVke.jpg","iso_639_1":null,"vote_average":0.166},{"width":2000,"height":1125,"file_path":"/6eiPNevgFdbVVShQF8eWhBNx5T8.jpg","iso_639_1":null,"vote_average":0.166},{"width":1328,"height":747,"file_path":"/d675LpJvS4n6xPTTbrIXvuHngUc.jpg","iso_639_1":null,"vote_average":0.166},{"width":1731,"height":973,"file_path":"/9j8tHymrgfANwPh7iH1nbIH2ZZI.jpg","iso_639_1":null,"vote_average":0.166},{"width":1550,"height":871,"file_path":"/uIAxXKQzE6vn4oosCDhZKQl75LI.jpg","iso_639_1":null,"vote_average":0},{"width":1550,"height":871,"file_path":"/y6oGGBAKYAxApj3E5DQ75YN7kzt.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-02-21T17:53:47.702+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":100,"tagline":"Prove your innocence to an AI judge or face execution.","homepage":"https://www.amazon.com/salp/mercy?hhf=","overview":"In the near future, a detective stands on trial accused of murdering his wife. He has ninety minutes to prove his innocence to the advanced AI Judge he once championed, before it determines his fate."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"노 머시: 90분","runtime":100,"tagline":"사형까지 단 90분, 무죄를 증명하고 판결을 뒤집어라","homepage":"","overview":"모든 진실을 데이터로만 판단하는 냉혹한 AI 재판 시스템 ‘MERCY’에 맞서 사형을 피하기 위해 90분 안에 자신의 무죄를 증명해야 하는 형사(크리스 프랫)의 숨 막히는 반격을 그린 타임리미트 스릴러"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Sin piedad","runtime":0,"tagline":"","homepage":"","overview":"En un futuro próximo, un detective (Chris Pratt) es acusado de asesinar a su esposa. Tiene 90 minutos para demostrar su inocencia ante la Jueza de la I.A. avanzada (Rebecca Ferguson), a la que él mismo defendió en su día, antes de que esta decida su destino."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Reconnu coupable","runtime":100,"tagline":"Prouvez votre innoncence à un juge IA ou vous serez exécuté.","homepage":"","overview":"Dans un futur proche, la ville de Los Angeles est en proie à une montée de la violence. Le détective privé Chris Raven est accusé du meurtre de sa femme. Il est jugé par la juge Maddox, une intelligence artificielle avancée du tribunal expéditif de Mercy Capital, auquel Chris a grandement contribué. Il a 90 minutes pour prouver lui-même son innocence. Après ce délai, l'IA déterminera son sort et le condamnera à mort."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Merhamet Yok","runtime":0,"tagline":"Masum olduğunu kanıtlamak ya da idam edilmek için 90 dakikan var.","homepage":"","overview":"Yakın gelecekte, LAPD cinayet masası dedektifi Chris Raven, kendini bir anda yüksek güvenlikli bir mahkeme salonunda, eşinin cinayetinden yargılanırken bulur. Bu kez karar, \"Mercy\" adı verilen devrim niteliğindeki yeni yargı sistemine aittir. Yargıç Maddox liderliğindeki bu sistem, olay yeri verilerinden dijital kayıtlara kadar her detayı analiz ederek hüküm verir. Chris'in, Mercy mahkemesinin yüksek teknolojili imkanlarını kullanarak masumiyetini kanıtlaması için yalnızca doksan dakikası vardır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Bằng Chứng Sinh Tử","runtime":0,"tagline":"Khi tương lai công lý là trí tuệ nhân tạo.","homepage":"","overview":"Trong một thế giới mới, bạn có 90 phút để chứng minh vô tội, hoặc không sẽ bị hành quyết ngay lập tức."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"","runtime":101,"tagline":"","homepage":"","overview":"LAPD-Detective Raymond steht, wie immer mehr in dieser dystopischen Zukunft, wegen des Mordes an seiner Frau vor Gericht. Die hochmoderne KI-Richterin Maddox, deren Einführung er einst selbst unterstützte, leitet schließlich das Verfahren gegen ihn. Binnen lediglich 90 Minuten muss der Gesetzeshüter nun seine eigene Unschuld hieb- und stichfest beweisen, bevor die künstliche Rechtsprechung über sein weiteres Leben – oder dessen Ende – entscheidet."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Милосердя","runtime":0,"tagline":"","homepage":"","overview":"У недалекому майбутньому детектив постає перед судом за звинуваченням у вбивстві своєї дружини. У нього є 90 хвилин, щоб довести свою невинуватість перед передовим ШІ-суддею, якого він колись підтримував, перш ніж той винесе вирок."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Казнить нельзя помиловать","runtime":0,"tagline":"«Докажите свою невиновность искусственному интеллекту»","homepage":"","overview":"Ближайшее будущее, Лос-Анджелес. Полицейский Крис Рейвен задержан по обвинению в убийстве своей жены. В течение 90 минут Крис должен доказать свою невиновность продвинутому искусственному интеллекту, который выступает в роли судьи и палача."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Etsivä Raven havahtuu lukittuna tuoliin uuden Mercy-tekoälyn pyörittämässä tuomioistuimessa, jonka tarkoitus on palauttaa järjestys rikollisuuden piinaamaan lähitulevaisuuden Yhdysvaltoihin. Ironista on, että Raven on itse aktiivisesti ajanut Mercy-järjestelmän asiaa, mutta se ei auta. Mercyn kautta jo 18 rikollista on tuomittu kuolemaan kaikkialla läsnä olevan valvontainfrastruktuurin keräämän todistusaineiston perusteella.\r Raven on nyt tapaus numero 19, ja hänellä on kenen tahansa rikollisen tapaan puolitoista tuntia aikaa käyttää hyväkseen samaa kuva- ja infomassaa vakuttaakseen tekoäly siitä, ettei hän ole humalapäissään tappanut vaimoaan - tai ainakin luomaan perusteltua epäilyä. Jos se ei onnistu, tuoli tappaa hänet."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Justiça Artificial","runtime":100,"tagline":"90 minutos para provar sua inocência ou enfrentar a execução.","homepage":"","overview":"Em um futuro próximo, um detetive é acusado de assassinar a própria esposa. Ele tem 90 minutos para provar sua inocência à avançada justiça de Inteligência Artificial que ele mesmo ajudou a implementar."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"法無赦","runtime":0,"tagline":"","homepage":"","overview":"「你仲有90分鐘。」一名警探（基斯柏特 飾）被控殺妻，受審於AI法官（莉碧嘉費格遜 飾）。生死關頭，佢要喺90分鐘內證明自己清白⋯⋯限時之內自證清白，否則殺無赦！然而真相之下，又隱藏著多少秘密？"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"關鍵公敵","runtime":100,"tagline":"如果AI法庭判定有罪，你該如何證明自己清白？","homepage":"","overview":"在不遠的未來，一個高階警探(克里斯 普瑞特飾演)因被指控謀殺妻子接受AI法庭審判。在定罪行刑之前，他只有90分鐘向曾經極度推崇的AI法官(蕾貝卡弗格森飾演)證明自己的清白。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Sin piedad","runtime":99,"tagline":"Demuestre su inocencia ante un juez de IA o enfréntate a la ejecución.","homepage":"","overview":"En un futuro cercano, un detective es juzgado por el asesinato de su esposa. Tiene noventa minutos para demostrar su inocencia ante el Juez de Inteligencia Artificial que una vez defendió, antes de que este determine su destino."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"极限审判","runtime":0,"tagline":"","homepage":"","overview":"背景设定在不久的将来，死罪不断增加，一名侦探（克里斯·帕拉特 Chris Pratt 饰）被指控犯有暴力罪，他被迫证明自己无罪。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Mercy - Sotto accusa","runtime":0,"tagline":"90 minuti per dimostrare la tua innocenza o affrontare l'esecuzione.","homepage":"","overview":"Ambientato in un futuro prossimo in cui i crimini capitali sono in aumento, un detective viene accusato di un crimine violento ed è costretto a dimostrare la sua innocenza."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Důkaz viny","runtime":100,"tagline":"","homepage":"","overview":"V blízké budoucnosti se detektiv ocitne před soudem, kde je obviněn z vraždy své manželky. Má 90 minut na to, aby dokázal svou nevinu soudkyni vytvořenou umělou inteligencí v programu trestního soudnictví MERCY, který kdysi pomáhal vytvořit, než rozhodne o jeho konečném osudu."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"90 минути до присъда","runtime":0,"tagline":"","homepage":"","overview":"Сюжетът се развива в близко бъдеще, когато смъртните престъпления са нараснали, а детектив е несправедливо обвинен в тежко престъпление и трябва да докаже своята невинност."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"MERCY／マーシー　AI裁判","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"הנאשם","runtime":0,"tagline":"העתיד של המשפט הפלילי הוא בינה מלאכותית.","homepage":"","overview":"בעתיד הקרוב, בלש עומד לדין באשמת רצח אשתו.  לרשותו עומדות 90 דקות בלבד להוכיח את חפותו בפני שופטת הבינה המלאכותית המתקדמת, שהוא עצמו קידם בעבר, לפני שהיא תקבע את גורלו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"90 นาทีสั่งตาย","runtime":0,"tagline":"","homepage":"","overview":"ในโลกอนาคตอันใกล้ที่อาชญากรรมร้ายแรงพุ่งสูงขึ้น นักสืบคนหนึ่งได้ถูกกล่าวหาว่าได้กระทำอาชญากรรมความรุนแรง และถูกบีบให้ต้องพิสูจน์ความบริสุทธิ์ของตัวเอง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Bez Milosti","runtime":0,"tagline":"","homepage":"","overview":"U bliskoj budućnosti sudi se detektivu optuženom za ubojstvo svoje supruge. Ima 90 minuta da dokaže svoju nevinost naprednom sucu umjetne inteligencije kojeg je nekoć zagovarao, prije nego što to odluči o njegovoj sudbini."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Mesterséges kegyelem","runtime":0,"tagline":"Bizonyítsd be ártatlanságodat egy mesterséges intelligencia által felügyelt bíró előtt, vagy nézz szembe a kivégzéssel.","homepage":"","overview":"A jövőben is lesznek gyilkosok. És lesznek zsaruk. De az utóbbiak egyre kevesebben. Mert a munkájukat átveszi a Mercy Bíróság, ami egyszerre rendőr, bíró és ítéletvégrehajtó: aki a gépi bíró (Rebecca Ferguson) elé kerül, 90 percet kap, hogy bizonyítsa az ártatlanságát. És ha a gép végül úgy látja, hogy legalább 92%-os valószínűséggel elkövette a tettét, akkor azonnal kivégzik.  Raven nyomozó (Chris Pratt) közreműködött a rendszer beindításában. És most ott ül a székbe szíjazva, rendelkezésére áll a város összes kamerájának a felvétele, és be kell bizonyítania, hogy nem ő ölte meg a feleségét. Két ellensége van. Az idő és a kérlelhetetlen digitális bíró."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"","runtime":0,"tagline":"Bevisa din oskuld inför en AI-domare eller riskera avrättning.","homepage":"","overview":"I en nära framtid anklagas en kriminalpolis för mordet på sin fru. Nu har han bara 90 minuter på sig att bevisa sin oskuld inför en obeveklig AI-domare – samma system han själv en gång dedikerade sitt liv åt att försvara."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Mercy: Prova de Culpa","runtime":0,"tagline":"O futuro da justiça criminal é a inteligência artificial.","homepage":"","overview":"Num futuro próximo, um detective é levado a tribunal, acusado de assassinar a sua mulher. Tem 90 minutos para provar a sua inocência à Juíza de I.A. avançada, antes que ela determine o seu destino."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"შეწყალება","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"90 minut do wolności","runtime":100,"tagline":"Ma 90 minut na udowodnienie swojej niewinności albo czeka go egzekucja.","homepage":"","overview":"W świecie bliskiej przyszłości wymiar sprawiedliwości przechodzi rewolucję. Mercy - sąd oparty na zaawansowanej sztucznej inteligencji - ma dostęp do wszystkich kamer, telefonów i baz danych. Jego werdyk-ty są szybkie, niepodważalne i... ostateczne.  Gdy detektyw John Kross zostaje oskarżony o zamordowa-nie żony, trafia przed trybunał, który sam kiedyś popierał. Przed sędzią Al ma zaledwie 90 minut, by udowodnić swoją niewinność. Jeśli mu się nie uda, zostanie stracony.  W Mercy obowiązuje zasada: to oskarżony musi udowodnić, że jest niewinny. W świecie, gdzie tradycyjne sądy zawodzą, ten system obiecuje koniec bezkarności. Ale w rękach niewłaściwych ludzi może stać się narzędziem doskonałej niesprawiedliwości.  Pełen napięcia thriller, który trzyma za gardło od pierwszej do ostatniej minuty."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Dôkaz viny","runtime":0,"tagline":"Dokáž nevinu AI sudkyni, inak ťa čaká poprava","homepage":"","overview":"Detektív Raven, ktorý stál pri jeho zrode, sa zrazu ocitne na druhej strane spravodlivosti - ako obžalovaný z vraždy svojej manželky. Raven dostane 90 minút na to, aby neúprosnú AI sudkyňu presvedčil o svojej nevine. Ak zlyhá, čaká ho okamžitá poprava. Čas sa neúprosne kráti a Raven postupne odhaľuje, že v celom prípade ide o niečo oveľa väčšie, než je dôkaz jeho neviny"},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"","runtime":100,"tagline":"","homepage":"","overview":"In de nabije toekomst staat een rechercheur terecht voor de moord op zijn vrouw. Hij heeft slechts 90 minuten de tijd om zijn onschuld te bewijzen voordat zijn lot zal worden bepaald door de geavanceerde AI-rechter waarvan hij zelf een pleitbezorger was."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Žēlastība (Mercy)","runtime":100,"tagline":"","homepage":"","overview":"Tuvā nākotnē detektīvs (Kriss Prets) stājas tiesas priekšā, apsūdzēts par sievas slepkavību. Viņam ir 90 minūtes, lai pierādītu savu nevainīgumu uzlabotajam mākslīgajam intelektam (Rebeka Fērgusone), kuru viņš reiz atbalstīja, pirms tā lemj par viņa likteni."},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Brez milosti","runtime":0,"tagline":"Imaš 90 minut, da dokažeš svojo nedolžnost ali se soočiš z usmrtitvijo.","homepage":"","overview":"Losangeleški detektiv Chris Raven se znajde na sojenju za umor svoje ženein ima na voljo le 90 minut časa, da dokaže svojo nedolžnost - preden umetna inteligenca, ki združuje vlogo sodnika, porote in izvršitelja odloči o njegovi usodi."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"Η Εσχάτη των Ποινών","runtime":0,"tagline":"","homepage":"","overview":"Στο εγγύς μέλλον, ένας ντετέκτιβ δικάζεται με την κατηγορία της δολοφονίας της συζύγου του. Έχει 90 λεπτά για να αποδείξει την αθωότητά του στην προηγμένη τεχνητή νοημοσύνη που ο ίδιος στήριζε ένθερμα, πριν αυτή αποφασίσει για την τύχη του."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"ميرسي","runtime":0,"tagline":"","homepage":"","overview":"في المستقبل القريب، يمثل محقق أمام المحكمة بتهمة قتل زوجته. أمامه 90 دقيقة لإثبات براءته أمام قاضي الذكاء الاصطناعي المتطور الذي كان يدافع عنه بشدة، قبل أن يحدد مصيره."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Nuteisti negalima pasigailėti","runtime":100,"tagline":"","homepage":"","overview":"2029-ieji, Los Andželas. Nusikaltimų skaičiui augant, o policijos finansavimui mažėjant, miesto vadovai nusprendžia į pagalbą pasitelkti dirbtinį intelektą. Jo pagrindu sukuriama sistema MERCY: nešališka, niekada nepavargstanti ir viską pastebinti teisėja.\r Kuomet detektyvas Reivenas nubunda pririštas prie kėdės nepažįstamame kambaryje, jis ne iš karto supranta, kur pateko. Paslaptis greitai atskleidžiama: prieš vyrą esančiame ekrane pasirodo skaitmeninės teisėjos veidas, informuojantis detektyvą, kad jis yra pagrindinis įtariamasis savo žmonos nužudymo byloje.\r Reivenui duodama pusantros valandos, kad, įrodytų savo nekaltumą - prasideda kvapą gniaužiančias lenktynes su laiku."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"Mərhəmət","runtime":115,"tagline":"","homepage":"","overview":"Yaxın gələcək, Los-Anceles. Polis əməkdaşı Kris Reyven həyat yoldaşını qətlə yetirməkdə ittiham olunaraq saxlanılır. 90 dəqiqə ərzində Kris öz günahsızlığını hakim və cəllad rolunda çıxış edən inkişaf etmiş süni intellektə sübut etməlidir."},"name":"Azərbaycan","iso_639_1":"az","iso_3166_1":"AZ","english_name":"Azerbaijani"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Vi befinder os i en nær fremtid, hvor en kriminalbetjent kommer for retten anklaget for at have myrdet sin kone. Beviserne mod ham er stærke og han har nu 90 minutter til at bevise sin uskyld over for den avancerede AI-dommer, han selv har været varm fortaler for. Dommeren er den eneste, der kan afgøre hans skæbne…"},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":0,"tagline":"Ai 90 de minute să-ți dovedești nevinovăția sau vei fi executat.","homepage":"","overview":"Într-un viitor apropiat, un detectiv este acuzat de uciderea soției sale și judecat. Are la dispoziție 90 de minute pentru a-și dovedi nevinovăția în fața unei judecătoare AI, pe care o susținuse cândva, înainte ca aceasta să-i decidă soarta."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Viimane kohtuotsus","runtime":0,"tagline":"90 minutit, et tõestada oma süütust või seista silmitsi hukkamisega","homepage":"","overview":"Uurija (Chris Pratt) seisab lähitulevikus oma naise mõrvas süüdistatuna kohtu ees. Tal on 90 minutit aega, et tõestada oma süütust arenenud tehisintellektist kohtunikule (Rebecca Ferguson), enne kui too ta saatuse üle otsustab."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"},{"data":{"title":"Reconnu coupable","runtime":99,"tagline":"Prouvez votre innocence à un juge IA ou vous serez exécuté.","homepage":"","overview":"Dans un futur proche, la ville de Los Angeles est en proie à une montée de la violence. Le détective privé Chris Raven est accusé du meurtre de sa femme. Il est jugé par la juge Maddox, une intelligence artificielle avancée du tribunal expéditif de Mercy Capital, auquel Chris a grandement contribué. Il a 90 minutes pour prouver lui-même son innocence. Après ce délai, l'IA déterminera son sort et le condamnera à mort."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"}],"reviews_tmdb":[{"id":"697361a1c29174e95baee0e8","url":"https://www.themoviedb.org/review/697361a1c29174e95baee0e8","author":"Brent Marchant","content":"$11","created_at":"2026-01-23T11:55:13.939Z","updated_at":"2026-01-23T11:55:13.969Z","author_details":{"name":"Brent Marchant","rating":6,"username":"Brent_Marchant","avatar_path":null}},{"id":"6975f1620f150cbbc8088896","url":"https://www.themoviedb.org/review/6975f1620f150cbbc8088896","author":"CinemaSerf","content":"$12","created_at":"2026-01-25T10:33:06.224Z","updated_at":"2026-01-25T10:33:06.283Z","author_details":{"name":"CinemaSerf","rating":6,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}},{"id":"6981013e571c12d0b4382ad7","url":"https://www.themoviedb.org/review/6981013e571c12d0b4382ad7","author":"Manuel São Bento","content":"Full review: https://movieswetextedabout.com/mercy-movie-review-chris-pratt-and-rebecca-fergusons-talent-cant-save-a-careless-execution-of-a-fascinating-premise/\r\n\r\nRating: C-\r\n\r\n\"Mercy is an experience that sits between a fascinating premise and a careless execution, presenting a scenario of algorithmic justice that gets lost in narrative contradictions and plot conveniences. Although the performances of Chris Pratt and Rebecca Ferguson offer some stability, and the tension levels are maintained by an effective score and competent visual effects, the movie fails to deepen the ethical implications of total surveillance and technological inequality. It leaves behind a somewhat confusing reminder that no matter how much we try to automate the truth, justice without the context of human fragility is just a line of code devoid of a soul.\"","created_at":"2026-02-02T19:55:42.081Z","updated_at":"2026-02-02T19:55:42.115Z","author_details":{"name":"Manuel São Bento","rating":4,"username":"msbreviews","avatar_path":null}},{"id":"6997c3cf15ddabfd77c99426","url":"https://www.themoviedb.org/review/6997c3cf15ddabfd77c99426","author":"Enes","content":"The cast is good, but the AI ​​thing is a bit annoying. Overall, it's a film that takes place in a single location. The guy uses all the AI's capabilities to avoid being judged, and he's the one who created the AI. Still, I got bored after a while. I like science fiction. This film is neither bad nor very good; I'd give it a 5 out of 10. To be honest, I didn't like it very much.","created_at":"2026-02-20T02:15:43.617Z","updated_at":"2026-02-20T02:15:43.626Z","author_details":{"name":"Enes","rating":5,"username":"Eness_","avatar_path":"/wASOrU1PJmMuTD1jIdop9yBvYdh.jpg"}}],"recommendations":[],"similar_content":[{"id":169,"adult":false,"title":"Predator 2","video":false,"overview":"A police chief in the war-torn streets of Los Angeles discovers that an extraterrestrial creature is hunting down residents - and that he is the next target.","genre_ids":[878,28,53],"popularity":9.4138,"vote_count":3712,"poster_path":"/83X4VwY9sdSJykskmsplIVG0a4h.jpg","release_date":"1990-11-21","vote_average":6.293,"backdrop_path":"/8GGAXEXaTPMDGa0sCPyFcitvlD9.jpg","original_title":"Predator 2","original_language":"en"},{"id":180,"adult":false,"title":"Minority Report","video":false,"overview":"John Anderton is a top 'Precrime' cop in the late-21st century, when technology can predict crimes before they're committed. But Anderton becomes the quarry when another investigator targets him for a murder charge.","genre_ids":[878,28,53],"popularity":6.7464,"vote_count":9404,"poster_path":"/ccqpHq5tk5W4ymbSbuoy4uYOxFI.jpg","release_date":"2002-06-20","vote_average":7.349,"backdrop_path":"/PrMb3oeEluauy0q9ZO5xL33A6C.jpg","original_title":"Minority Report","original_language":"en"},{"id":184,"adult":false,"title":"Jackie Brown","video":false,"overview":"Jackie Brown is a flight attendant who gets caught in the middle of smuggling cash into the country for her gunrunner boss. When the cops try to use Jackie to get to her boss, she hatches a plan — with help from a bail bondsman — to keep the money for herself.","genre_ids":[80,18,53],"popularity":4.7148,"vote_count":6809,"poster_path":"/rOUx7qg4KmEh1juEDwqzbDSL1Nr.jpg","release_date":"1997-12-25","vote_average":7.36,"backdrop_path":"/gvaeY5kz3wHrMU6xLdnybziwYXw.jpg","original_title":"Jackie Brown","original_language":"en"},{"id":196,"adult":false,"title":"Back to the Future Part III","video":false,"overview":"The final installment finds Marty digging the trusty DeLorean out of a mineshaft and looking for Doc in the Wild West of 1885. But when their time machine breaks down, the travelers are stranded in a land of spurs. More problems arise when Doc falls for pretty schoolteacher Clara Clayton, and Marty tangles with Buford Tannen.","genre_ids":[12,35,878],"popularity":6.747,"vote_count":11312,"poster_path":"/crzoVQnMzIrRfHtQw0tLBirNfVg.jpg","release_date":"1990-05-25","vote_average":7.489,"backdrop_path":"/AtF7TESJEMmImBRUj9Z7HmW2ZH0.jpg","original_title":"Back to the Future Part III","original_language":"en"},{"id":590003,"adult":false,"title":"A Living Dog","video":false,"overview":"The war between mankind and intelligent machines has begun - and the machines are winning. Tomasz is a deserter who tries to hide as far away from the battle as possible.  In the vast emptiness of northern Scandinavia he meets Lilja, the last survivor of a resistance group, who is determined to fight the superior machines. With every minute that passes the machines get closer, searching for the last remains of the human race. And the enemy doesn't just shoot on sight - their perfect sensors are programmed to recognize human voice patterns.  So if you speak or even whisper - you die.","genre_ids":[878,28,53],"popularity":0.1779,"vote_count":3,"poster_path":"/kkpeYDMS0LPLPtQveJGvkLMk4V8.jpg","release_date":"2019-09-07","vote_average":5.3,"backdrop_path":"/eECrrbuwrf4Xjc6i5rLv3yijMjV.jpg","original_title":"A Living Dog","original_language":"en"},{"id":419272,"adult":false,"title":"Pony Girl","video":false,"overview":"Under the direction of a wealthy pervert, young women are being kidnapped, shipped off to a remote ranch and forced to submit and behave like horses by a whip-wielding dominatrix. This shot-on-video thriller with just R-rated nudity is noteworthy as one of the only non-porn films Traci Lords appeared in prior to the discovery of true age. She co-stars along with future Scream Queen Michelle Bauer.","genre_ids":[53],"popularity":1.9115,"vote_count":2,"poster_path":"/yFxJeOzr8TfDSfgVZtxOfcfyh0l.jpg","release_date":"1985-01-01","vote_average":6.5,"backdrop_path":null,"original_title":"Pony Girl","original_language":"en"},{"id":419276,"adult":false,"title":"Pony Girl: At the Ranch","video":false,"overview":"Young women are being kidnapped by a rich sleazebag and his goons and are taken to a farm. At night they are forced to sleep on a barn floor. During the day, they are at the mercy of a sadistic dominatrix who dresses in leather outfits and forces them to behave like horses. This video uses footage from Pony Girl (1985) and Pony Girl Number Two (1985), with Traci Lords edited out of the proceedings despite the fact there's no X-rated material in the original tapes.","genre_ids":[53],"popularity":0.5908,"vote_count":3,"poster_path":"/q7AQ0VSd85S9fi8lkDW65yxcKBk.jpg","release_date":"1986-01-01","vote_average":7.7,"backdrop_path":null,"original_title":"Pony Girl: At the Ranch","original_language":"en"},{"id":644,"adult":false,"title":"A.I. Artificial Intelligence","video":false,"overview":"David, a robotic boy—the first of his kind programmed to love—is adopted as a test case by a Cybertronics employee and his wife. Though he gradually becomes their child, a series of unexpected circumstances make this life impossible for David.","genre_ids":[18,878,12],"popularity":6.9967,"vote_count":6532,"poster_path":"/8MZSGX5JORoO72EfuAEcejH5yHn.jpg","release_date":"2001-06-29","vote_average":7.053,"backdrop_path":"/2tQ0Uhav10ay7jOX6QoqvbtGljB.jpg","original_title":"A.I. Artificial Intelligence","original_language":"en"},{"id":658,"adult":false,"title":"Goldfinger","video":false,"overview":"Special agent 007 comes face to face with one of the most notorious villains of all time, and now he must outwit and outgun the powerful tycoon to prevent him from cashing in on a devious scheme to raid Fort Knox -- and obliterate the world's economy.","genre_ids":[12,28,53],"popularity":6.2145,"vote_count":3872,"poster_path":"/aKNFzaqQgPzsGXnsMc4kJH5hFIV.jpg","release_date":"1964-09-20","vote_average":7.355,"backdrop_path":"/f1Is9VLQZSRpeLMU7mIcj5aXclt.jpg","original_title":"Goldfinger","original_language":"en"},{"id":670,"adult":false,"title":"Oldboy","video":false,"overview":"With no clue how he came to be imprisoned, drugged and tortured for 15 years, a desperate man seeks revenge on his captors.","genre_ids":[18,53,9648,28],"popularity":13.138,"vote_count":9583,"poster_path":"/pWDtjs568ZfOTMbURQBYuT4Qxka.jpg","release_date":"2003-11-21","vote_average":8.241,"backdrop_path":"/sdwjQEM869JFwMytTmvr6ggvaUl.jpg","original_title":"올드보이","original_language":"ko"},{"id":680,"adult":false,"title":"Pulp Fiction","video":false,"overview":"A burger-loving hit man, his philosophical partner, a drug-addled gangster's moll and a washed-up boxer converge in this sprawling, comedic crime caper. Th