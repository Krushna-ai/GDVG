ote_average":0}],"backdrops":[{"width":1920,"height":1080,"file_path":"/inEy3A5OPgeYW4rjRiGycfEeQzA.jpg","iso_639_1":null,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/ogyUszy5ZjQyXpKd6f5aT4lHVaq.jpg","iso_639_1":null,"vote_average":3.334},{"width":1280,"height":720,"file_path":"/4YbHir4Ka4kG7WOdh0anXv1iT8s.jpg","iso_639_1":null,"vote_average":1.75},{"width":1280,"height":720,"file_path":"/dmcrKTKT6KsKXCKTVshITiusag.jpg","iso_639_1":"en","vote_average":0.166},{"width":2999,"height":1687,"file_path":"/mKKLgF2nbCy5Ia28RI01PH786pV.jpg","iso_639_1":null,"vote_average":0},{"width":1280,"height":720,"file_path":"/wWZXyo6t22ZwaEsGc8Y3EbPjkbs.jpg","iso_639_1":null,"vote_average":0},{"width":1920,"height":1080,"file_path":"/tcJsL74S9WOB8dWuyyxEiJG86yX.jpg","iso_639_1":"pt","vote_average":0},{"width":1280,"height":720,"file_path":"/cHRVbkolVYRDTeenZRYGa9G8A0P.jpg","iso_639_1":"tr","vote_average":0},{"width":1280,"height":720,"file_path":"/nP3BFBeYBWF4SbYrccwnv1m85yH.jpg","iso_639_1":"en","vote_average":0},{"width":1280,"height":720,"file_path":"/5hGdXEJKsZRFZZUZZ4WzV9gdtC1.jpg","iso_639_1":"en","vote_average":0},{"width":3840,"height":2160,"file_path":"/7Gd51JtB0M6AMkxBLNO0WaonLip.jpg","iso_639_1":"tr","vote_average":0},{"width":1920,"height":1080,"file_path":"/yD7EVtzJBCtYTbW151kGQhsPWwq.jpg","iso_639_1":null,"vote_average":0},{"width":1679,"height":945,"file_path":"/g592yl3UkLqFHD4zxdJZPeMVgso.jpg","iso_639_1":null,"vote_average":0},{"width":2998,"height":1687,"file_path":"/2p8smCanGjcUOCPPTztf8u2Bkb0.jpg","iso_639_1":null,"vote_average":0},{"width":2998,"height":1687,"file_path":"/3rUmjihVn0yqr7L4Ov6mbnFUwBB.jpg","iso_639_1":null,"vote_average":0}]},"enriched_at":"2026-04-21T06:34:45.228+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Miracle in Cell No. 7","runtime":132,"tagline":"","homepage":"","overview":"Separated from his daughter, a father with an intellectual disability must prove his innocence when he is jailed for the death of a commander's child."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":132,"tagline":"Senin baban kimselere benzemez...","homepage":"https://www.netflix.com/tr/title/81239779","overview":"Darbe döneminde bir Ege kasabasında, canından çok sevdiği küçük kızı ve babaannesiyle birlikte yaşayan Memo, mental yetersizliği olan ama küçük dünyasında mutlu yaşayan bir çobandır. 1983 yılında bir gün, sıkıyönetim komutanının kızının ölümü üzerine kalan ve sıradan hayatı birden altüst olan Memo, idam cezasına çarptırılır ve böylece ‘Yedinci Koğuş’a gelir. Burada hayatta kalması pek mümkün görünmemektedir. Fakat başta onu nefretle karşılayan tüm koğuş, onun iyilik dolu kalbini görür, yavaş yavaş Memo’nun cinayet işleyebilecek bir kişiliği olmadığına ikna olmaya başlar ve zamanla hayatına dokunduğu herkes Memo’nun hayatını kurtarmak için seferber olur. Herkes adalet peşindeyken Memo ve kızı Ova’nın tek isteği birbirlerine kavuşmaktır. Memo suçsuzdur ve şimdi yaşamına geri dönebilmesi için bir mucizeye ihtiyacı vardır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"7번방의 기적","runtime":132,"tagline":"","homepage":"","overview":"교도소 7번 방. 지능이 예닐곱 살 수준인 남자가 이곳에 들어왔다. 아동 살해 누명을 쓰고 사형을 기다리지만 그에겐 아끼는 딸이 있다. 감방 동료들이 준비한 특별 선물로 딸과 재회한 남자. 하지만 계속 함께하려면 무죄를 밝혀야 한다."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Miracle in Cell No. 7","runtime":127,"tagline":"","homepage":"https://www.netflix.com/title/81239779","overview":"Separato dalla sua bambina, un padre con disabilità intellettiva viene incarcerato per la morte della figlia di un comandante. Dovrà dimostrare la propria innocenza."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Cud w celi nr 7","runtime":132,"tagline":"","homepage":"","overview":"Niepełnosprawny intelektualnie mężczyzna, któremu odebrano córkę, trafia do więzienia i musi udowodnić, że został niesłusznie oskarżony o zabicie dziecka dowódcy."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"Dárek do cely č.7","runtime":132,"tagline":"","homepage":"","overview":"Mentálně postižený otec, kterému odebrali dceru, musí prokázat svoji nevinu. Sedí totiž ve vězení za smrt velitelova dítěte."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"נס בתא מספר 7","runtime":132,"tagline":"","homepage":"","overview":"סרט פשע טורקי. אב רפה-שכל הופרד מבתו לאחר שהואשם ברצח בתו של מפקד צבאי, ונאבק כדי להוכיח את חפותו."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Milagro en la Celda 7","runtime":132,"tagline":"","homepage":"","overview":"Separado de su hija, un padre con una discapacidad intelectual debe probar su inocencia al ser arrestado por la muerte de la niña de un comandante."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":132,"tagline":"Le véritable amour ne connaît pas de prison.","homepage":"","overview":"Séparé de sa fille, un père avec un handicap mental doit prouver son innocence lorsqu'il est arrêté pour le meurtre d'une enfant."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Milagro en la celda 7","runtime":132,"tagline":"","homepage":"","overview":"Un hombre con discapacidad intelectual es injustamente encarcelado por la muerte de una niña, y debe demostrar su inocencia para poder estar de nuevo con su hija."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Milagre na Cela 7","runtime":130,"tagline":"O verdadeiro amor não conhece prisões.","homepage":"","overview":"Na Turquia dos anos 80, um pastor mentalmente atrasado é acusado injustamente de matar uma criança. Preso, é espancado e condenado à forca, mas a sua bondade inata contagia todos e convence toda a gente da sua inocência. Ao mesmo tempo que uns tentam ajudá-lo a sair da prisão vivo, outros tentarão ajudá-lo a não perder contacto com Ova, a sua filha de seis anos, a quem ele ama mais do que tudo na vida."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"七号房的礼物","runtime":132,"tagline":"","homepage":"","overview":"梅莫（阿拉斯·布鲁特·伊涅姆利 Aras Bulut Iynemli 饰）虽然生得人高马大，但却只有相当于6岁孩童一般的智慧，他带着女儿奥瓦（妮莎·索菲亚·阿克松古尔 Nisa Sofiya Aksongur 饰），同奶奶法蒂玛（塞利尔·托扬·乌伊萨尔 Celile Toyon Uysal 饰）生活在一起，日子虽然过得紧巴巴的，但一家人能够团聚就是最大的快乐。  哪知道某日祸从天降，连一只蚂蚁都不愿意踩死的梅莫，竟然背负上了莫须有的杀人罪名，被关进了七号牢房中，单纯的梅莫并不知道自己即将面临怎样悲惨的命运。在监狱里，梅莫很快就和他的狱友们成为了朋友，梅莫开朗乐观的性格感染了周围的每一个人，给他们带来了快乐和希望，为了回报梅莫，这些曾经“穷凶极恶”的罪人们决定用他们的性命为筹码，来实现梅莫一个希冀已久的愿望。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Milagre na Cela 7","runtime":132,"tagline":"Unidos pela Justiça: Transformando Tragédia em Triunfo!","homepage":"","overview":"Separado de sua filha, um homem com deficiência intelectual precisa provar sua inocência ao ser preso pela morte da filha de um comandante."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Чудо в камері №7","runtime":132,"tagline":"","homepage":"","overview":"Мемо - дорослий чоловік з інтелектом семирічної дитини. Однак він зумів побудувати сім'ю, у нього з'явилася дочка Ова. Одного разу проходячи повз парк, Мемо бачить в озері дівчинку і намагається її врятувати, але безуспішно - дівчинка гине. Виявляється, вона була дочкою поліцейського начальника, і той заарештовує чоловіка і садить у в'язницю."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Чудо в камере № 7","runtime":132,"tagline":"«Потому что твой отец одного с тобой возраста»","homepage":"","overview":"Мемо - взрослый мужчина с интеллектом семилетнего ребенка. Однако он сумел построить семью, у него появилась дочь Ова. Однажды проходя мимо парка, Мемо видит в озере девочку и пытается её спасти, но безуспешно - девочка погибает. Оказывается, она была дочерью полицейского начальника, и тот арестовывает мужчину и сажает в тюрьму."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"七號房的祝福","runtime":132,"tagline":"","homepage":"","overview":"梅莫（阿拉斯·布卢特·伊尼姆利 Aras Bulut Iynemli 飾）雖然生得人高馬大，但卻只有相當於6歲孩童一般的智慧，他帶著女兒奧瓦（妮莎·蘇菲亞·阿克松古爾 Nisa Sofiya Aksongur 飾），同奶奶法蒂瑪（傑莉莉·托揚·烏伊薩爾 Celile Toyon Uysal 飾）生活在一起，日子雖然過得緊巴巴的，但一家人能够團聚就是最大的快樂。\r 哪知道某日禍從天降，連一隻螞蟻都不願意踩死的梅莫，竟然背負上了莫須有的殺人罪名，被關進了七號牢房中，單純的梅莫並不知道自己即將面臨怎樣悲慘的命運。在監獄裏，梅莫很快就和他的獄友們成為了朋友，梅莫開朗樂觀的性格感染了周圍的每一個人，給他們帶來了快樂和希望。為了回報梅莫，這些曾經“窮凶極惡”的罪人們决定用他們的性命為籌碼，來實現梅莫一個希冀已久的願望。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Чудото в килия 7","runtime":132,"tagline":"","homepage":"","overview":"Отделен от дъщеря си, баща с интелектуална нетрудоспособност трябва да докаже невинността си, докато е в затвора за смъртта на детето на командира."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"ปาฏิหาริย์ห้องขังหมายเลข 7 (เวอร์ชันตุรกี)","runtime":132,"tagline":"","homepage":"","overview":"พ่อผู้มีความบกพร่องทางปัญญาถูกพรากจากลูกสาวและต้องหาทางพิสูจน์ความบริสุทธิ์ของตัวเองเมื่อถูกจับขังในข้อหาฆ่าลูกนายพล"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"Csoda a 7-es cellában","runtime":132,"tagline":"","homepage":"","overview":"Egy értelmi fogyatékos apát bebörtönöznek egy fontos személy gyermekének halála miatt, és a saját kislányától távol kell bebizonyítania ártatlanságát."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Điều Kì Diệu Ở Phòng Giam Số 7","runtime":132,"tagline":"","homepage":"","overview":"Một người cha bị thiểu năng bị buộc phải xa con gái và phải chứng minh mình vô tội khi anh bị tống vào tù vì cái chết của con gái một vị chỉ huy quân sự."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"სასწაული მეშვიდე საკანი","runtime":132,"tagline":"","homepage":"","overview":"ფილმი მოგვითხრობს მენტალურად დაავადებულ მამაზე, რომელსაც თავისი 7 წლის მკვლელობაში ტყუილ უბრალოდ დებენ ბრალს და აპატიმრებენ..."},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"معجزة في الزنزانة 7","runtime":132,"tagline":"","homepage":"","overview":"بعد انفصاله عن ابنته ، يجب على الأب الذي يعاني من إعاقة ذهنية إثبات براءته عندما يُسجن لوفاة طفل قائد عسكري."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Το Θαύμα στο Κελί 7","runtime":132,"tagline":"","homepage":"","overview":"Αποχωρισμένος από την κόρη του, ένας πατέρας με νοητική υστέρηση πρέπει να αποδείξει ότι είναι αθώος έχοντας καταδικαστεί για τον φόνο του παιδιού ενός διοικητή."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"7番房の奇跡","runtime":132,"tagline":"","homepage":"","overview":"軍司令官の子供を殺害した罪で投獄され、愛する娘と離ればなれになった知的障害を持つ男。死刑判決を受けながらも、ひたすら無実を訴え続けるが...。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Darček do cely č.7","runtime":132,"tagline":"","homepage":"","overview":"Mentálne postihnutý otec, ktorému odobrali dcéru, musí preukázať svoju nevinu. Sedí totiž vo väzení za smrť veliteľovho dieťaťa."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Miracle in Cell No. 7","runtime":132,"tagline":"","homepage":"","overview":"Een vader met een verstandelijke beperking wordt gevangengezet voor de dood van het kind van een commandant. Gescheiden van zijn dochter moet hij zijn onschuld bewijzen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"BE","english_name":"Dutch"},{"data":{"title":"Miracle in Cell No. 7","runtime":132,"tagline":"","homepage":"","overview":"Als Hirte führt Memo Anfang der 1980er-Jahre ein bescheidenes aber glückliches Leben zusammen mit seiner Mutter und seiner sechsjährigen Tochter Ova in einem kleinen Dorf der Agäis-Region. Von den Unruhen des Staatsstreichs bekommen sie in der Einöde nichts mit. Das unbescholtene Leben nimmt ein jähes Ende, als dem Familienvater eines Tages der Tod der Tochter eines Militärangehörigen zu Last gelegt wird. Ihm wird der Prozess gemacht, er wird zum Tode verurteilt und in Zelle Sieben des Gefängnisses gesteckt. Die Aussichten, dass der geistig behinderte Mann das Leben in dieser Zelle überleben wird, stehen schlecht. Obwohl ihn die anderen Insassen anfangs nicht gut behandeln, stellen sie bald fest, dass Memo kein schlechter Mensch ist, und sind immer mehr davon überzeugt, dass so jemand wie er, keinen Mord begehen kann."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Miracol în celula 7","runtime":132,"tagline":"","homepage":"","overview":"Un tată cu dizabilități intelectuale trebuie să-și dovedească nevinovăția după ce este despărțit de fiica lui și încarcerat pentru uciderea copilei unui comandant."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"معجزة في الزنزانة 7","runtime":132,"tagline":"","homepage":"","overview":"ينبغي على والد يعاني من إعاقة ذهنية إثبات براءته بعد الزجّ به في السجن لاتهامه في حادث وفاة ابنة حاكم البلدة، فهل يلتئم شمله بابنته ثانية؟"},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"Miracle in Cell No. 7","runtime":132,"tagline":"","homepage":"","overview":"Séparé de sa fille, un père ayant une déficience intellectuelle doit prouver son innocence quand il est emprisonné pour le meurtre de la fille d'un commandant."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Miracle in Cell No. 7","runtime":132,"tagline":"","homepage":"","overview":"Der geistig zurückgebliebene, liebende Vater einer Tochter wird für den Mord an der Tochter des Polizeipräsidenten verurteilt. Wird er seine Unschuld beweisen können?"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"AT","english_name":"German"},{"data":{"title":"Miracle in Cell No. 7","runtime":132,"tagline":"","homepage":"","overview":"Der geistig zurückgebliebene, liebende Vater einer Tochter wird für den Mord an der Tochter des Polizeipräsidenten verurteilt. Wird er seine Unschuld beweisen können?"},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"CH","english_name":"German"},{"data":{"title":"戇爸的禮物","runtime":132,"tagline":"","homepage":"","overview":"一名智障父親遭控殺害廳長的孩子，因此被迫與女兒分開。身陷囹圄的他必須證明自己的清白。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"7 号房的礼物","runtime":132,"tagline":"","homepage":"","overview":"一名具有智力障碍的父亲因谋杀警察局长的女儿而入狱，与女儿分离的他必须证明自己的清白。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"SG","english_name":"Mandarin"},{"data":{"title":"Miracle in Cell No. 7","runtime":132,"tagline":"","homepage":"","overview":"Terpisah dari putrinya, seorang ayah yang menderita keterbelakangan mental harus membuktikan dirinya tak bersalah saat ia dipenjara karena kematian anak seorang komandan."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"Čudo u ćeliji br. 7","runtime":132,"tagline":"","homepage":"","overview":"Odvojen od svoje kćeri, otac s intelektualnim teškoćama mora dokazati svoju nevinost nakon što je optužen za ubojstvo zapovjednikova djeteta."},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"Miracle in Cell No. 7","runtime":132,"tagline":"","homepage":"","overview":"En psykisk handicappet far, der er adskilt fra sin datter, må bevise sin uskyld, da han fængsles for mordet på en kommandørs datter."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Miracle in Cell No. 7","runtime":132,"tagline":"","homepage":"","overview":"En pappa med en intellektuell funktionsnedsättning har separerats från sin dotter och måste bevisa sin oskuld när han döms för mordet på dottern till en högt uppsatt man."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Miracle in Cell No. 7","runtime":132,"tagline":"","homepage":"","overview":"Aivovamman kanssa elävä isä joutuu vankilaan murhasta mutta yrittää todistaa syyttömyytensä voidakseen olla yhdessä tyttärensä kanssa."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Miracle in Cell No. 7","runtime":132,"tagline":"","homepage":"","overview":"Een vader met een verstandelijke beperking wordt gevangengezet voor de dood van het kind van een commandant. Gescheiden van zijn dochter moet hij zijn onschuld bewijzen."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Miracle in Cell No. 7","runtime":132,"tagline":"","homepage":"","overview":"En psykisk utviklingshemmet far skilles fra datteren sin og må bevise sin uskyld når han blir mistenkt for drapet på lederens barn."},"name":"Bokmål","iso_639_1":"nb","iso_3166_1":"NO","english_name":"Norwegian Bokmål"},{"data":{"title":"Miracle in Cell No. 7","runtime":132,"tagline":"","homepage":"","overview":"En psykisk utviklingshemmet far skilles fra datteren sin og må bevise sin uskyld når han blir mistenkt for drapet på lederens barn."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Miracle in Cell No. 7","runtime":132,"tagline":"","homepage":"","overview":"En psykisk utviklingshemmet far skilles fra datteren sin og må bevise sin uskyld når han blir mistenkt for drapet på lederens barn."},"name":"","iso_639_1":"nn","iso_3166_1":"NN","english_name":"Norwegian Nynorsk"}],"reviews_tmdb":[],"recommendations":[{"id":387805,"adult":false,"title":"7:19","video":false,"overview":"At 7:19 a.m., on September 19th of 1985, the most destructive earthquake hit Mexico City. Inside what's left of a building, a group of survivors fight for their lives waiting for rescue.","genre_ids":[53,18,36],"media_type":"movie","popularity":0.2413,"vote_count":54,"poster_path":"/7vhjD2FmBUrnEWyKRb1LI0XCRz.jpg","release_date":"2016-09-16","vote_average":6.5,"backdrop_path":"/cSXUVWBczlS9K036UcIGLlKos4R.jpg","original_title":"7:19","original_language":"es"},{"id":619264,"adult":false,"title":"The Platform","video":false,"overview":"A slab of food descends down a vertical facility. The residents above eat heartily, leaving those below starving and desperate. A rebellion is imminent.","genre_ids":[18,878,53],"media_type":"movie","popularity":4.0907,"vote_count":7684,"poster_path":"/iXvQnzy6JCAx1PiQEKXuTY04ZHl.jpg","release_date":"2019-11-08","vote_average":6.969,"backdrop_path":"/3tkDMNfM2YuIAJlvGO6rfIzAnfG.jpg","original_title":"El hoyo","original_language":"es"},{"id":597219,"adult":false,"title":"The Half of It","video":false,"overview":"Shy, straight-A student Ellie is hired by sweet but inarticulate jock Paul, who needs help wooing the most popular girl in school. But their new and unlikely friendship gets tricky when Ellie discovers she has feelings for the same girl.","genre_ids":[35,10749,18],"media_type":"movie","popularity":1.2114,"vote_count":1569,"poster_path":"/jC1PNXGET1ZZQyrJvdFhPfXdPP1.jpg","release_date":"2020-05-01","vote_average":7.09,"backdrop_path":"/8YSpQBdGvuvSj9pLsY2yoUb9fZn.jpg","original_title":"The Half of It","original_language":"en"},{"id":323372,"adult":false,"title":"The Corpse of Anna Fritz","video":false,"overview":"Anna Fritz is a beautiful and famous actress. Suddenly her body is found in a hotel and the news of her death goes around the planet. The young, shy caretaker Pau works at the hospital where they carried the body of Anna Fritz. He and his friends  decide to take pictures of the body of Anna Fritz.  They decide they could make love to her and nobody would know. They are in front of Anna Fritz ... and can do with it what  they want.","genre_ids":[18,53],"media_type":"movie","popularity":2.172,"vote_count":571,"poster_path":"/wbGlMrymGFhYE8CTDVc7xwPUD6j.jpg","release_date":"2015-03-15","vote_average":6.87,"backdrop_path":"/fMt4fwqy0C908DwHDHpn65z1ku0.jpg","original_title":"El cadáver de Anna Fritz","original_language":"es"},{"id":545609,"adult":false,"title":"Extraction","video":false,"overview":"A hardened gun-for-hire's latest mission becomes a soul-searching race to survive when he's sent into Bangladesh to rescue a drug lord's kidnapped son.","genre_ids":[28,53],"media_type":"movie","popularity":6.9038,"vote_count":6490,"poster_path":"/nygOUcBKPHFTbxsYRFZVePqgPK6.jpg","release_date":"2020-04-23","vote_average":7.297,"backdrop_path":"/1R6cvRtZgsYCkh8UFuWFN33xBP4.jpg","original_title":"Extraction","original_language":"en"},{"id":342470,"adult":false,"title":"All the Bright Places","video":false,"overview":"Two teens facing personal struggles form a powerful bond as they embark on a cathartic journey chronicling the wonders of Indiana.","genre_ids":[10749,18],"media_type":"movie","popularity":2.3743,"vote_count":2990,"poster_path":"/4SafxuMKQiw4reBiWKVZJpJn80I.jpg","release_date":"2020-02-28","vote_average":7.63,"backdrop_path":"/tcrNJfyNEIqaBR8Ogkgnq5xQJnf.jpg","original_title":"All the Bright Places","original_language":"en"},{"id":658760,"adult":false,"title":"Isi & Ossi","video":false,"overview":"Isi and Ossi couldn't be any more different: She's a billionaire's daughter from Heidelberg, he's a struggling boxer from the nearby town of Mannheim. But when Isi meets Ossi, the two quickly realize that they can take advantage of one another: She dates the broke boxer to provoke her parents and get them to fund a long-desired chef training in New York. He tries to rip off the rich daughter to finance his first professional boxing match. Their plans soon develop into emotional chaos that challenges everything the two believe to know about money, career and love.","genre_ids":[10749,35],"media_type":"movie","popularity":1.2647,"vote_count":949,"poster_path":"/bZ7H0kCwEM6CQ0dyCs2H4RkU130.jpg","release_date":"2020-02-14","vote_average":6.916,"backdrop_path":"/2EOy2YSJbzKvlzKpEEKULVYZGlN.jpg","original_title":"Isi & Ossi","original_language":"de"},{"id":10950,"adult":false,"title":"I Am Sam","video":false,"overview":"Sam, a neurodivergent man, has a daughter with a homeless woman who abandons them when they leave the hospital, leaving Sam to raise Lucy on his own. But as Lucy grows up, Sam's limitations as a parent start to become a problem and the authorities take her away. Sam convinces high-priced lawyer Rita to take his case pro bono and in turn teaches her the value of love and family.","genre_ids":[18],"media_type":"movie","popularity":3.5612,"vote_count":2446,"poster_path":"/8n8BTMIRPKT0KZKSa0nACG9cQ8O.jpg","release_date":"2001-12-28","vote_average":7.561,"backdrop_path":"/mOsg2l9zq315ouw55rbNATSwgU1.jpg","original_title":"I Am Sam","original_language":"en"},{"id":555974,"adult":false,"title":"Brahms: The Boy II","video":false,"overview":"After a family moves into the Heelshire Mansion, their young son soon makes friends with a life-like doll called Brahms.","genre_ids":[27,9648,53],"media_type":"movie","popularity":1.7703,"vote_count":1287,"poster_path":"/swTC1DSZcvdxTOzmAKrtoUUPiDW.jpg","release_date":"2020-02-20","vote_average":5.876,"backdrop_path":"/jeiVmutYPZyQRSYk7OvyWENGIrA.jpg","original_title":"Brahms: The Boy II","original_language":"en"},{"id":2251,"adult":false,"title":"Unfaithful","video":false,"overview":"Connie is a wife and mother whose 11-year marriage to Edward has lost its sexual spark. When Connie literally runs into handsome book collector Paul, he sweeps her into an all-consuming affair. But Edward soon becomes suspicious and decides to confront the other man.","genre_ids":[53,18,10749],"media_type":"movie","popularity":8.7113,"vote_count":1668,"poster_path":"/bjiHEhuiwhIygz