9:{"metadata":[["$","title","0",{"children":"Wuthering Heights | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Young orphan Heathcliff is adopted by the wealthy Earnshaw family and moves into their estate, Wuthering Heights. Soon, the new resident falls for his compassionate foster sister, Cathy. The two share a remarkable bond that seems unbreakable until Cathy, feeling the pressure of social convention, suppresses her feelings and marries Edgar Linton, a man of means who befits her stature. Heathcliff vows to win her back."}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/movies/102169/wuthering-heights"}],["$","meta","5",{"property":"og:title","content":"Wuthering Heights"}],["$","meta","6",{"property":"og:description","content":"Young orphan Heathcliff is adopted by the wealthy Earnshaw family and moves into their estate, Wuthering Heights. Soon, the new resident falls for his compassionate foster sister, Cathy. The two share a remarkable bond that seems unbreakable until Cathy, feeling the pressure of social convention, suppresses her feelings and marries Edgar Linton, a man of means who befits her stature. Heathcliff vows to win her back."}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/movies/102169/wuthering-heights"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500/pZBQ6KfITjufDMCp6FFkqjCoIMN.jpg"}],["$","meta","9",{"property":"og:type","content":"video.movie"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Wuthering Heights"}],["$","meta","12",{"name":"twitter:description","content":"Young orphan Heathcliff is adopted by the wealthy Earnshaw family and moves into their estate, Wuthering Heights. Soon, the new resident falls for his compassionate foster sister, Cathy. The two share a remarkable bond that seems unbreakable until Cathy, feeling the pressure of social convention, suppresses her feelings and marries Edgar Linton, a man of means who befits her stature. Heathcliff vows to win her back."}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500/pZBQ6KfITjufDMCp6FFkqjCoIMN.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
