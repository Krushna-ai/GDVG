0204ESnADtXDqnb9PpVo.jpg","release_date":"1996-03-08","vote_average":0,"backdrop_path":null,"original_title":"Angaara","original_language":"hi"},{"id":764928,"adult":false,"title":"Rashtra Kavach Om","video":false,"overview":"Om, a special forces para commando officer, loses his memory while fighting enemies. After recovering from amnesia, Om is on a mission to save the nation from terrorists. As he fights the challenges the mission presents, he learns a shocking truth about his life.","genre_ids":[28,12,53],"popularity":0.3714,"vote_count":12,"poster_path":"/kBZEDW004FLzPTdBpko6Qf4lACJ.jpg","release_date":"2022-07-01","vote_average":5.2,"backdrop_path":"/8tgkff0NnMO0qzBjjiis1gbonQX.jpg","original_title":"राष्ट्र कवच ओम","original_language":"hi"},{"id":249514,"adult":false,"title":"Heeralaal Pannalaal","video":false,"overview":"The movie starts with two innocent and kind hearted guys named Heeralal and Pannalal. They are famous among criminals as they have helped police in capturing them several times. Heeralal is in search of his parent’s killer but has no idea of him at all. Pannalal is in search of his father. Heeralal meets with a girl named Ruby and falls in love with her. Pannalal falls in love with Ruby’s friend, Neelam.\r Kalicharan, who is a renowned criminal has decided to teach a lesson to Heeralal and Pannalal for interfering in their business. But instead Kalicharan is forced to run from the police. Police commissioner, Premlal is very happy with the guys and wants to protect them from Kalicharan and his friend, Panther’s anger.","genre_ids":[28,35],"popularity":0.2367,"vote_count":2,"poster_path":null,"release_date":"1978-10-09","vote_average":5.5,"backdrop_path":null,"original_title":"Heeralaal Pannalaal","original_language":"hi"},{"id":16928,"adult":false,"title":"Black & White","video":false,"overview":"Rajan Mathur (Anil Kapoor) is a Professor in Urdu literature in Dr. Zakir Hussain's College. He resides in Chandni Chowk with his activist wife, Roma Mathur (Shefali Shah). Professor Mathur comes across a young boy called Numair Qazi (Anurag Sinha) who introduces himself as a victim of communal riots in Gujarat.","genre_ids":[28,18],"popularity":0.4391,"vote_count":1,"poster_path":"/l0uoXiG4foEMozkg69E4upoPxwK.jpg","release_date":"2008-02-01","vote_average":4.5,"backdrop_path":"/cE7szM5vqZEn9Kq6VvIcBpHaBua.jpg","original_title":"Black & White","original_language":"hi"},{"id":15761,"adult":false,"title":"Company","video":false,"overview":"Mallik is a henchman of Aslam Bhai, a Mumbai underworld kingpin. He inducts local hothead Chandu into the gang, and the two of them soon form a formidable faction within the gang, eventually displacing Aslam. As the empire grows, however, the two of them start drifting apart.","genre_ids":[28,80,18],"popularity":0.4672,"vote_count":71,"poster_path":"/1A2J7bYryOmBVBU8qpTs3fta0hv.jpg","release_date":"2002-04-15","vote_average":6.887,"backdrop_path":"/iFd0f324IzQgZkCEq5uTc4LUJ1G.jpg","original_title":"Company","original_language":"hi"},{"id":16383,"adult":false,"title":"Maharathi","video":false,"overview":"After his boss, Jai Singh, commits suicide, Subhash, a chauffeur, hatches a plan to win his insurance money. He teams up with Jai's wife, Mallika, to make the suicide look like a well-planned murder.","genre_ids":[53],"popularity":3.3962,"vote_count":6,"poster_path":"/uaJhmaUQFzQgQ7zoKDB4PUsHGur.jpg","release_date":"2008-12-04","vote_average":6.7,"backdrop_path":null,"original_title":"Maharathi","original_language":"hi"},{"id":606003,"adult":false,"title":"Ab Insaf Hoga","video":false,"overview":"Janki lives a poor lifestyle in a small village consisting of her dad, Bhervi Prasad and her mom. She meets and falls in love with her school-teacher, Ramcharan, and both want to get married. Ramcharan's brother is opposed to this marriage as Bhervi is unable to pay any dowry, nevertheless the marriage does take place, but the couple are turned out of Kalicharan's house, and instead go to live with Ramcharan's friend, Ashok Mishra.","genre_ids":[28,18],"popularity":0.1828,"vote_count":1,"poster_path":"/bCrFAz4SioKAquc97QYldqwJaX9.jpg","release_date":"1995-01-05","vote_average":3,"backdrop_path":"/8ITLhfxsBKzWPxe2sCmj5oC3Clt.jpg","original_title":"Ab Insaf Hoga","original_language":"hi"},{"id":606015,"adult":false,"title":"Janta Ki Adalat","video":false,"overview":"fight from honest police officer against rural thugs..","genre_ids":[28,18,10749],"popularity":0.1611,"vote_count":3,"poster_path":"/vtPjiJ9GtZV5XL7FV4dCUXkA5CJ.jpg","release_date":"1994-07-29","vote_average":5.2,"backdrop_path":null,"original_title":"Janta Ki Adalat","original_language":"hi"},{"id":606599,"adult":false,"title":"Commando 3","video":false,"overview":"A mysterious man is on an impending mission to attack the country from his base in London. Karan Singh Dogra sets out to hunt down the antagonist aided by the British Intelligence.","genre_ids":[28,53],"popularity":0.439,"vote_count":39,"poster_path":"/ukxAjRADLYxUhCzg4KNhXux5BMH.jpg","release_date":"2019-11-28","vote_average":7,"backdrop_path":"/elTsYTJtxgtcPkXOi4pUDIcGLxK.jpg","original_title":"कमांडो 3","original_language":"hi"},{"id":782000,"adult":false,"title":"Tell Me","video":false,"overview":"Monali musters up the courage to end her life, but before the final leap, she gets interrupted by a stone-cold voice. Will she acknowledge this angelic voice?","genre_ids":[18,53],"popularity":0.1591,"vote_count":0,"poster_path":"/5DjjSWJa5de8KrA8rw3jrjxC0IQ.jpg","release_date":"2018-05-25","vote_average":0,"backdrop_path":"/pOVQnLTitbTmcAEVqwAvSkciAOg.jpg","original_title":"Tell Me","original_language":"hi"},{"id":267500,"adult":false,"title":"Pyar Ka Karz","video":false,"overview":"The Story of Ravi Shankar (Mithun) and his troubled life where he has to deal with love, infidelity and death which leads him to a life of crime..will he succumb to evil or can he drag himself out in time?","genre_ids":[28,35,18],"popularity":0.1884,"vote_count":3,"poster_path":"/99eWpBkJYRquOnLo7YhtvxeUEHj.jpg","release_date":"1990-03-02","vote_average":5.8,"backdrop_path":"/8TD77afMWBF9JuKtCMuKKcCIerv.jpg","original_title":"Pyar Ka Karz","original_language":"hi"},{"id":267504,"adult":false,"title":"Aakhree Raasta","video":false,"overview":"David is an old prisoner, released after twenty-four years in a penitentiary for a crime he hasn't committed. The three men who framed him and sent him away, are now prominent citizens of his town. David walks out of the prison straight into a confessional booth at his church. He tells the priest that he is about to kill three prominent men, for which he seeks God's pardon in advance. He must find his old friend, bootlegger and the custodian of David's only son. David had believed in his friend to bring up his son as the worst criminal and seek revenge from the men who put him away. On meeting him, David finds that his son is a Cop instead. Devastated, David continues on his own. When he is about to kill the three men, his son has vowed to protect the citizens under any circumstances. David and his son are at war..who will prevail?","genre_ids":[80,28,18],"popularity":0.4853,"vote_count":14,"poster_path":"/zeOByJ06LPHctubIWZzOfpdPzYQ.jpg","release_date":"1986-06-02","vote_average":6.867,"backdrop_path":"/10ZasIEIS66gfucorBsbOWLiyxU.jpg","original_title":"आखिरी रास्ता","original_language":"hi"},{"id":783442,"adult":false,"title":"Dombivli Return","video":false,"overview":"Anant Velankar is an honest government officer working in Mantralaya who has never taken bribe.He has a respectful life with is family wife Ujwala and daughter Antra.He commutes daily for work from Dombivali to CST a route more then a hour and admires his boss Dadasaheb but suddenly comes across a photograph of him killing someone which is the only proof the murder.Now the ball is in Anant's court how to deal with the situation weather to revel the truth in front of everyone or blackmail Dadasaheb.","genre_ids":[18,53],"popularity":0.9274,"vote_count":11,"poster_path":"/iowMD8PiqWSdfJNpDof9PBhnfIq.jpg","release_date":"2019-02-22","vote_average":6.1,"backdrop_path":"/d1ZhS3VH1XPLPdZSiYRA9zbhCM0.jpg","original_title":"Dombivli Return","original_language":"hi"},{"id":783461,"adult":false,"title":"Looop Lapeta","video":false,"overview":"When her boyfriend loses a mobster's cash, Savi races against the clock to save the day — if only she can break out of a curious cycle of dead ends.","genre_ids":[28,35,80],"popularity":0.7324,"vote_count":67,"poster_path":"/onGdT8sYi89drvSJyEJnft97rOq.jpg","release_date":"2022-02-04","vote_average":6.134,"backdrop_path":"/pOEwPqwK4rfKaM1UJKU3eyWUtVF.jpg","original_title":"लूप लपेटा","original_language":"hi"},{"id":19616,"adult":false,"title":"New York","video":false,"overview":"New York is a contemporary story of friendship set against the larger than life backdrop of a city often described as the centre of the world. Omar has gone abroad for the first time in his life and soon enough he begins to see and love America through the eyes of his American friends - Sam and Maya. It is the story of these three friends discovering a new world together.","genre_ids":[80,18,53],"popularity":0.4496,"vote_count":77,"poster_path":"/yFp4MiFPNGPiLOnl5zZGnS13jAL.jpg","release_date":"2009-06-26","vote_average":6.227,"backdrop_path":"/66AfZA6GaRrGjgjL9lmZN2aqgxl.jpg","original_title":"New York","original_language":"hi"},{"id":19623,"adult":false,"title":"Drona","video":false,"overview":"Aditya is an orphaned and lonely young man. He soon learns that he belongs to a family of ancestral warriors who guard a mystic source of cosmic energy, and he must now take up his responsibilities.","genre_ids":[28,53],"popularity":1.9674,"vote_count":18,"poster_path":"/7l5lejRwvkEnQ3s1dOLQ1qUXGRf.jpg","release_date":"2008-10-02","vote_average":3.3,"backdrop_path":"/j7Dk5Zc5eR06DtCXhAg56TxsBY8.jpg","original_title":"Drona","original_language":"hi"}],"external_ids":{"imdb