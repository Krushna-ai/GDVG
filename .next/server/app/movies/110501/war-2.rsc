t":1941,"file_path":"/t4MgTHAWtV5FGG9OnoCjdCguiaF.jpg","iso_639_1":"en","vote_average":0.5},{"width":1366,"height":2050,"file_path":"/eALYxwo5Og3S4BJy7vlsuDgsh9k.jpg","iso_639_1":"en","vote_average":0.5}],"backdrops":[{"width":1920,"height":1080,"file_path":"/pKIRUTnwY3YYU9urSdsuobdcliP.jpg","iso_639_1":null,"vote_average":8.034},{"width":1920,"height":1080,"file_path":"/eBalwiE9sRWNaZQ3Bwjx2jNaChv.jpg","iso_639_1":"en","vote_average":3.334},{"width":2175,"height":1224,"file_path":"/bNwxRkm97oLUhSYXpSvQNyWJFmg.jpg","iso_639_1":null,"vote_average":3.334},{"width":2176,"height":1224,"file_path":"/1hJLR7K03XVn6vaqnt2VDlfXtXb.jpg","iso_639_1":null,"vote_average":3.334},{"width":2048,"height":1152,"file_path":"/6DlhH0P52p14yXr7ua8vqAjWXwt.jpg","iso_639_1":null,"vote_average":3.334},{"width":2048,"height":1152,"file_path":"/zEuAwH4Uc96a4HCEUmIagW0qZQC.jpg","iso_639_1":null,"vote_average":3.334},{"width":2176,"height":1224,"file_path":"/raF0eC9R4rLukbSKKBalCqiIauD.jpg","iso_639_1":null,"vote_average":2.278},{"width":2804,"height":1577,"file_path":"/qQH65hIB4qmc4aP40DxaoEGC2Ea.jpg","iso_639_1":null,"vote_average":2.066},{"width":2797,"height":1573,"file_path":"/4dzh6RT7EQXpETwASd29JRqd7R5.jpg","iso_639_1":null,"vote_average":2.066},{"width":2856,"height":1606,"file_path":"/p1ztwiHxfRqB37eLAMglGF7Z4yD.jpg","iso_639_1":null,"vote_average":2.066},{"width":2830,"height":1592,"file_path":"/i7qArgoTogtdW690F3QGYtfNM1J.jpg","iso_639_1":null,"vote_average":2.066},{"width":2832,"height":1593,"file_path":"/lVWU99Zsta4qDtYvqpLiLXyLnI.jpg","iso_639_1":null,"vote_average":2.066},{"width":2177,"height":1225,"file_path":"/pEyGHf9JduAglrmW0kgmdbZdDiK.jpg","iso_639_1":null,"vote_average":1.75},{"width":2169,"height":1220,"file_path":"/yibkU0G2yYoAIGvfbVxuTfRH6OJ.jpg","iso_639_1":null,"vote_average":1.75},{"width":2193,"height":1234,"file_path":"/nmhOhx2p0r8GPi9hEuK2uTSV57w.jpg","iso_639_1":null,"vote_average":1.75}]},"enriched_at":"2026-04-21T07:21:16.477+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"War 2","runtime":173,"tagline":"","homepage":"https://www.yashrajfilms.com/movies/war-2","overview":"Years ago Agent Kabir went rogue, became India’s greatest villain ever.  As he descends further into the deepest shadows... India sends its deadliest, most lethal agent after him, Agent Vikram  A Special Units Officer who is more than Kabir’s equal and a relentless Terminator driven by his own demons, determined to put a bullet into Kabir’s skull."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"Războiul 2","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"宝莱坞双雄之战2","runtime":0,"tagline":"","homepage":"","overview":"佣兵卡毕尔接下风险奇高的任务，替犯罪组织卖命，却随即发现自己和无所畏惧的过往盟友反目为敌。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"جنگ 2","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"War 2","runtime":146,"tagline":"","homepage":"","overview":"Elite-Agent Major Kabir Dhaliwal kehrt zurück und bekommt es auch diesmal wieder mit einem mächtigen Gegner zu tun."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"War 2","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"מלחמה 2","runtime":0,"tagline":"","homepage":"","overview":"בעולם שבו איומים לא מזוהים אורבים מכל עבר, סוכן העל קאביר (כוכב העל ריטיק רושאן) הפך לאיש שהמערכת עצמה מבקשת להפיל. לא עוד גיבור – אלא האויב מספר 1 של הודו.\r כדי לעצור אותו, נשלח ויקראם (בגילומו של כוכב RRR זוכה האוסקר) לוחם עילית חסר רחמים, שמאמין שהצדק שווה הכול… גם אם יעלה בדם.\r מה שמתחיל כמשימת לכידה פשוטה, הופך לקרב פסיכולוגי עוצר נשימה בין שני ענקים, כשמאחוריהם סודות, בגידות, ואיום שמרחף על ביטחון המדינה כולה."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"War 2","runtime":170,"tagline":"","homepage":"","overview":"Lata temu agent Kabir zbuntował się i stał się największym złoczyńcą w historii Indii. W miarę jak pogrąża się w złych czynach Indie wysyłają za nim swojego najgroźniejszego agenta Vikrama, oficera jednostek specjalnych, który jest kimś więcej niż równym Kabirowi i nieustępliwym Terminatorem, zdeterminowanym, by wpakować Kabirowi kulę w łeb."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"حرب ٢","runtime":170,"tagline":"","homepage":"","overview":"منذ سنوات، تمرّد العميل كبير وتحول إلى أعظم شرير عرفته الهند على الإطلاق. ومع انغماسه أكثر فأكثر في أعماق الظلال القاتمة... ترسل الهند أخطر عملائها وأكثرهم فتكًا لملاحقته، وهو العميل فيكرام، ضابط الوحدات الخاصة الذي لا يقل عن كبير قوةً وبأسًا، و\"مُفترس لا يرحم\" تطارده شياطينه الخاصة، عاقد العزم على أن يطلق رصاصة تخترق جمجمة كبير."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"寶萊塢雙雄之戰 2","runtime":0,"tagline":"","homepage":"","overview":"傭兵卡畢爾接下風險奇高的任務，替犯罪組織賣命，卻隨即發現自己和無所畏懼的過往盟友反目為敵。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"War 2","runtime":0,"tagline":"","homepage":"","overview":"คาบีร์รับหน้าที่ทหารรับจ้างปฏิบัติภารกิจเสี่ยงตายให้กับเครือข่ายอาชญากร แต่งานนี้กลับทำให้เขาเผชิญหน้ากับอดีตพันธมิตรผู้กล้าแกร่ง"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"الحرب 2","runtime":0,"tagline":"","homepage":"","overview":"تنقلب الأمور رأسًا على عقب عندما يُتهم العميل السري (كابير دهاليوال) بخيانة بلده، فيُكلّف زميله السابق بمهمة العثور عليه."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Война 2","runtime":173,"tagline":"","homepage":"","overview":"Нещата се усложняват, когато тайният агент Кабир Дхаливал е обвинен в предателство към родината си, а неговият бивш колега Викрам получава задачата да го намери"},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"War 2","runtime":0,"tagline":"","homepage":"","overview":"Desde las sombras más densas, la India desata a su arma más letal: el superagente Vikram. Un oficial de las Unidades Especiales, imparable, indestructible, implacable. Cuando entra en escena, el peligro es inevitable. Un Terminator atormentado por sus propios demonios, con un único propósito: volarle la cabeza a Kabir. Dos titanes. Un destino. Una persecución sin límites. El mundo entero se convierte en su sangriento y despiadado campo de batalla. En su camino, decisiones imposibles, donde cada elección tiene un precio muy alto. Esta no es solo una guerra. Es una explosión de acción brutal y emociones que desgarran el alma"},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"寶萊塢雙雄之戰2","runtime":0,"tagline":"","homepage":"","overview":"傭兵卡畢爾接下風險奇高的任務，替犯罪組織賣命，卻隨即發現自己和無所畏懼的過往盟友反目為敵。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Бой 2","runtime":0,"tagline":"","homepage":"","overview":"Тайный агент Кабир, предавший свою страну и службу несколько лет назад, теперь представляет ещё большую угрозу. Индия направляет против него офицера специального подразделения Викрама, своего самого опасного оперативника. Движимый внутренними демонами, он намерен ликвидировать Кабира."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"War 2","runtime":173,"tagline":"","homepage":"","overview":"Desde las sombras más densas, la India desata a su arma más letal: el superagente Vikram. Un oficial de las Unidades Especiales, imparable, indestructible, implacable. Cuando entra en escena, el peligro es inevitable. Un Terminator atormentado por sus propios demonios, con un único propósito: volarle la cabeza a Kabir. Dos titanes. Un destino. Una persecución sin límites. El mundo entero se convierte en su sangriento y despiadado campo de batalla. En su camino, decisiones imposibles, donde cada elección tiene un precio muy alto. Esta no es solo una guerra. Es una explosión de acción brutal y emociones que desgarran el alma."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"Truy Lùng Trùm Khủng Bố 2","runtime":0,"tagline":"","homepage":"","overview":"Kabir, từng là biểu tượng của lực lượng đặc nhiệm Ấn Độ, nay trở thành kẻ phản bội nguy hiểm nhất. Để ngăn chặn anh ta, quốc gia cử Vikram – một đặc vụ tinh nhuệ, lạnh lùng và đầy ám ảnh – người duy nhất có thể đối đầu Kabir trong trận chiến không khoan nhượng."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"War 2","runtime":0,"tagline":"","homepage":"","overview":"En tant que mercenaire, Kabir accepte une mission à haut risque pour un réseau criminel. Cependant, sa mission le confronte rapidement à un ancien allié intransigeant."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"워 2","runtime":0,"tagline":"","homepage":"","overview":"\"스파이 유니버스의 판을 흔드는 초대형 대결이 시작된다\"\r 전설적 요원 카비르가 비밀 임무 속에서 보이지 않는 적과 맞서며 국가와 개인의 경계, 동료와 적의 선을 끊임없이 의심하게 된다. 각 대륙을 가로지르는 작전과 예측 불가한 추적전 속에서 그 앞을 막아서는 가장 강력한 라이벌과의 일대일 승부가 불붙고, 새로운 파트너의 등장으로 판은 더욱 복잡해진다. 폭발적 액션과 속도감 속에서 진짜 ‘전쟁’의 목적이 드러나기 시작하는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Guerra 2","runtime":0,"tagline":"","homepage":"","overview":"Um agente indiano renegado que virou vilão confronta o agente Vikram, o melhor agente da Índia, em uma perseguição mundial com decisões cruciais."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"}],"reviews_tmdb":[],"recommendations":[{"id":986097,"adult":false,"title":"HIM","video":false,"overview":"After suffering a potentially career-ending brain trauma, Cameron Cade receives a lifeline when his hero, legendary eight-time Championship quarterback and cultural megastar Isaiah White, offers to train Cam at Isaiah's isolated compound that he shares with his celebrity influencer wife. But as Cam's training accelerates, Isaiah's charisma begins to curdle into something darker.","genre_ids":[27,9648],"media_type":"movie","popularity":8.4919,"vote_count":318,"poster_path":"/qPJzcYR2f1O1uynYBCVPPJuOiAH.jpg","release_date":"2025-09-18","vote_average":5.786,"backdrop_path":"/jzzpCJWkVZZwAxzzLmtYN0MBWFd.jpg","original_title":"HIM","original_language":"en"},{"id":315465,"adult":false,"title":"The Boy and the Beast","video":false,"overview":"Kyuta, a boy living in Shibuya, and Kumatetsu, a lonesome beast from Jutengai, an imaginary world. One day, Kyuta forays into the imaginary world and, as he's looking for his way back, meets Kumatetsu who becomes his spirit guide. That encounter leads them to many adventures.","genre_ids":[28,12,16,18,10751,14],"media_type":"movie","popularity":2.4143,"vote_count":1567,"poster_path":"/kzKJxfIdZ70nsPfKyq7hlYlJwSx.jpg","release_date":"2015-07-11","vote_average":7.929,"backdrop_path":"/8yniaG7C4iCm0VVTSShAPUZYM3Y.jpg","original_title":"バケモノの子","original_language":"ja"},{"id":1153399,"adult":false,"title":"Coolie","video":false,"overview":"Deva, once living a quiet life, is shaken when his close friend dies under suspicious circumstances. Determined to uncover the truth, he infiltrates a powerful gang operating in the shadows. As he investigates, Deva becomes entangled in a dangerous web of crime, betrayal, and secrets from his own past, forcing him to confront powerful enemies while protecting the ones he loves.","genre_ids":[28,53,80],"media_type":"movie","popularity":2.1814,"vote_count":72,"poster_path":"/kr36awqmziEI5mfUElsHB0pj9zP.jpg","release_date":"2025-08-13","vote_average":6.295,"backdrop_path":"/bLn0CPzrrqFLicjNTgrzaIyE0gZ.jpg","original_title":"கூலி","original_language":"ta"},{"id":1314784,"adult":false,"title":"Hridayapoorvam","video":false,"overview":"Sandeep, a middle-aged bachelor who recently got a heart transplant, travels to Pune to attend the engagement of his heart-donor’s daughter, Haritha. Her engagement gets broken and Sandeep injures his back on the same day, forcing him to stay back in Pune for a few weeks, in his heart-donor’s house – who was an adventurous Colonel.","genre_ids":[10749,35,18,10751],"media_type":"movie","popularity":0.7064,"vote_count":11,"poster_path":"/j6M2odS1RqGEUPKirIvB1VZ9i6Y.jpg","release_date":"2025-08-28","vote_average":7.455,"backdrop_path":"/7HATFCB88pCbTyFytbUM48aZtpy.jpg","original_title":"ഹൃദയപൂര്‍വ്വം","original_language":"ml"},{"id":1007734,"adult":false,"title":"Nobody 2","video":false,"overview":"Former assassin Hutch Mansell takes his family on a nostalgic vacation to a small-town theme park, only to be pulled back into violence when they clash with a corrupt operator, a crooked sheriff, and a ruthless crime boss.","genre_ids":[28,53],"media_type":"movie","popularity":17.543,"vote_count":1262,"poster_path":"/iyxwxDZCpIm0vIORaHpmgJv2BGF.jpg","release_date":"2025-08-13","vote_average":6.987,"backdrop_path":"/82C04rTiXYZ7c8XZv91Nu53w82Y.jpg","original_title":"Nobody 2","original_language":"en"},{"id":597,"adult":false,"title":"Titanic","video":false,"overview":"101-year-old Rose DeWitt Bukater tells the story of her life aboard the Titanic, 84 years later. A young Rose boards the ship with her mother and fiancé. Meanwhile, Jack Dawson and Fabrizio De Rossi win third-class tickets aboard the ship. Rose tells the whole story from Titanic's departure through to its death—on its first and last voyage—on April 15, 1912.","genre_ids":[18,10749],"media_type":"movie","popularity":29.5562,"vote_count":26800,"poster_path":"/9xjZS2rlVxm8SFx8kPC3aIGCOYQ.jpg","release_date":"1997-12-18","vote_average":7.9,"backdrop_path":"/xnHVX37XZEp33hhCbYlQFq7ux1J.jpg","original_title":"Titanic","original_language":"en"},{"id":76600,"adult":false,"title":"Avatar: The Way of Water","video":false,"overview":"Set more than a decade after the events of the first film, learn the story of the Sully family (Jake, Neytiri, and their kids), the trouble that follows them, the lengths they go to keep each other safe, the battles they fight to stay alive, and the tragedies they endure.","genre_ids":[28,12,878],"media_type":"movie","popularity":40.1195,"vote_count":13723,"poster_path":"/t6HIqrRAclMCA60NsSmeqe9RmNV.jpg","release_date":"2022-12-14","vote_average":7.598,"backdrop_path":"/cd8YDn7M0lfaHhZdU6MvCDxPalP.jpg","original_title":"Avatar: The Way of Water","original_language":"en"},{"id":1234821,"adult":false,"title":"Jurassic World Rebirth","video":false,"overview":"Five years after the events of Jurassic World Dominion, covert operations expert Zora Bennett is contracted to lead a skilled team on a top-secret mission to secure genetic material from the world's three most massive dinosaurs. When Zora's operation intersects with a civilian family whose boating expedition was capsized, they all find themselves stranded on an island where they come face-to-face with a sinister, shocking discovery that's been hidden from the world for decades.","genre_ids":[878,12,28],"media_type":"movie","popularity":34.4455,"vote_count":2997,"poster_path":"/1RICxzeoNCAO5NpcRMIgg1XT6fm.jpg","release_date":"2025-07-01","vote_average":6.307,"backdrop_path":"/zNriRTr0kWwyaXPzdg1EIxf0BWk.jpg","original_title":"Jurassic World Rebirth","original_language":"en"},{"id":400928,"adult":false,"title":"Gifted","video":false,"overview":"Frank, a single man raising his child prodigy niece Mary, is drawn into a custody battle with his mother.","genre_ids":[18,35],"media_type":"movie","popularity":5.9818,"vote_count":5851,"poster_path":"/9Ts7Vc4wLlpI9oox9mkVUE1tBHy.jpg","release_date":"2017-04-07","vote_average":8,"backdrop_path":"/aH63TQfTFgAT8tYZs0CjDsqfMo2.jpg","original_title":"Gifted","original_language":"en"},{"id":1061474,"adult":false,"title":"Superman","video":false,"overview":"Superman, a journalist in Metropolis, embarks on a journey to reconcile his Kryptonian heritage with his human upbringing as Clark Kent.","genre_ids":[878,12,28],"media_type":"movie","popularity":30.5535,"vote_count":4344,"poster_path":"/oe5TVF6GQDESLsGiFrN6GyJEekh.jpg","release_date":"2025-07-09","vote_average":7.368,"backdrop_path":"/aJDLz1748CIMZkCkyISYe5Hl6I7.jpg","original_title":"Superman","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":21.4528,"vote_count":11363,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.036,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":297222,"adult":false,"title":"PK","video":false,"overview":"A stranger in the city asks questions no one has asked before. Known only by his initials, the man's innocent questions and childlike curiosity take him on a journey of love, laughter and letting go.","genre_ids":[35,18,878],"media_type":"movie","popularity":5.6684,"vote_count":1118,"poster_path":"/z2x2Y4tncefsIU7h82gmUM5vnBJ.jpg","release_date":"2014-12-18","vote_average":7.707,"backdrop_path":"/gxfvtq5eYiClS2X7hxAAPBNrbWA.jpg","original_title":"पीके","original_language":"hi"},{"id":1071585,"adult":false,"title":"M3GAN 2.0","video":false,"overview":"After the underlying tech for M3GAN is stolen and misused by a powerful defense contractor to cre