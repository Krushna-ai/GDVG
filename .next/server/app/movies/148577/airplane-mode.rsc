_average":0},{"width":872,"height":212,"file_path":"/vIG67SSURRsIFuCxceZdnTO3wdt.png","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":4.113,"vote_average":0}],"posters":[{"width":1482,"height":2222,"file_path":"/hDZBhyl83F07syVhQ0q21NBZSCC.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":2,"aspect_ratio":0.667,"vote_average":3.334},{"width":1482,"height":2222,"file_path":"/mTTn0Sycnawhqoog4m7caE7A2zZ.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":2,"aspect_ratio":0.667,"vote_average":1.75},{"width":500,"height":750,"file_path":"/fLXisj0j39zaktmoU72tVtOXx6W.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":0.667,"vote_average":0.166},{"width":769,"height":1152,"file_path":"/olbxe4g3PWmWtadoIYF1HTUNT8z.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":0.668,"vote_average":0},{"width":500,"height":750,"file_path":"/iIgfvPsPWDssqH59KFiNw7FRtme.jpg","iso_639_1":"de","iso_3166_1":"DE","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":500,"height":750,"file_path":"/yuu1qw97SU0Vjf1Csk1yY0QSLLM.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1500,"file_path":"/9tqVaqOdBBxq9Lae9TzVboUjCM7.jpg","iso_639_1":"it","iso_3166_1":"IT","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":1482,"height":2222,"file_path":"/fYxWZlGhZvSXbgmu5dL2E9Xx1OF.jpg","iso_639_1":"pt","iso_3166_1":"PT","vote_count":0,"aspect_ratio":0.667,"vote_average":0},{"width":718,"height":1024,"file_path":"/beaOSQk4m8nhOWuJlO2JXRbpl1v.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.701,"vote_average":0}],"backdrops":[{"width":1280,"height":720,"file_path":"/rNRjYQSorwbzPrlQrfwd1PCwclT.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":1,"aspect_ratio":1.778,"vote_average":3.334},{"width":2048,"height":1152,"file_path":"/9OaIWmWI7Ph3jqj235zQIrh5yVd.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":2.278},{"width":1280,"height":720,"file_path":"/kRgdajhZlw3eciyt8WWQTuikWXw.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/N4CfPya7VqppmSE5Tx7MGrrpTm.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":2048,"height":1152,"file_path":"/9kzLgfHXfkqAPG4EHfFBu277K7A.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":1280,"height":720,"file_path":"/eC3Onem8ta7ogTmTaxnrEKpCC3P.jpg","iso_639_1":"tr","iso_3166_1":"TR","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T08:25:09.702+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":95,"tagline":"","homepage":"","overview":"Uma jovem influenciadora digital bate o Mustang de colecionador do avô ao tirar uma selfie e é enviada para a fazenda dele para tentar consertar o carro, mas com um detalhe crucial: ela não pode usar o celular…"},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"Airplane Mode","runtime":96,"tagline":"","homepage":"https://www.netflix.com/title/81056195","overview":"When Ana, an influencer, crashes her car while talking on the phone, she's shipped to her grumpy grandfather's farm -- and forced into a digital detox."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Offline","runtime":95,"tagline":"Offline","homepage":"https://www.netflix.com/title/81056195","overview":"Quando Ana, una influencer, distrugge l'auto mentre parla al cellulare, viene spedita in campagna dal nonno e obbligata a sottoporsi a una disintossicazione digitale."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Λειτουργία Πτήσης","runtime":96,"tagline":"","homepage":"","overview":"Όταν η influencer Άννα τρακάρει το αυτοκίνητό της ενώ μιλάει στο τηλέφωνο, αναγκάζεται να πάει στη φάρμα του στριμμένου παππού της για \"ψηφιακή απεξάρτηση\"."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Tryb samolotowy","runtime":0,"tagline":"","homepage":"","overview":"Influencerka Ana rozbija samochód podczas rozmowy telefonicznej. Za karę trafia do domu swojego zrzędliwego dziadka na wsi, gdzie przejdzie detoks od komórki i internetu."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"오늘부터 로그아웃","runtime":0,"tagline":"","homepage":"","overview":"스마트폰은 나의 분신! SNS 인플루언서 그녀, 일상부터 연애사까지 빼곡히 공유하기에 24시간이 모자랄 지경. 그런데 갑자기 스마트폰 금지령과 함께, 첩첩산중에서 할아버지와 지내라는 명이 떨어졌다! 로그아웃된 삶, 뭘 하고 지내지?"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Flugmodus","runtime":0,"tagline":"Flugmodus","homepage":"","overview":"Die Influencerin Ana telefoniert beim Autofahren und hat einen Unfall. Nun muss sie auf der Farm ihres mürrischen Großvaters helfen – ganz ohne Netz und Selfies.\r Der/die Film Flugmodus ist ein Netflix Original und erschien 2020 und dauert 96 Minuten. Geeignet ab 6 Jahren. Der/die Flugmodus steht auf Netflix in Ultra HD/4K-Qualität zur Verfügung, wenn Sie das entsprechende Netflix-Abonnement haben. Dieser Film ist Feelgood, Bewegend, Romantisch."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"Uçak Modu","runtime":0,"tagline":"","homepage":"","overview":"Sosyal medya fenomeni Ana, telefonda konuşurken arabasını çarpınca huysuz büyükbabasının çiftliğine gönderilir ve dijital detoks yapmaya zorlanır."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"Mode Avion","runtime":96,"tagline":"","homepage":"","overview":"Ana devient une influenceuse pour une marque renommée sur les médias sociaux. Rapidement, elle quitte l'université et investit tout son temps sur sa plateforme. Cependant, ce qui semblait être une opportunité incroyable devient progressivement un mode de vie toxique. Enfin, lorsqu'elle plante sa voiture en étant au téléphone, elle est envoyée à la ferme de son grand-père grognon et y subit malgré elle une désintox numérique."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Repülőgép üzemmódban","runtime":96,"tagline":"","homepage":"","overview":"Ana, az influencer balesetet okoz, mert vezetés közben a telefonján beszél, ezért morgós nagyapja farmjára száműzik – digitális elvonókúrára."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Modo avión","runtime":0,"tagline":"","homepage":"","overview":"Ana, una exitosa influencer de redes sociales, destroza su auto por ir utilizando su celular. Entonces sus padres toman una decisión drástica: enviarla a la lejana granja de su gruñón abuelo para dejar su adicción al celular de una vez por todas."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Letový režim","runtime":0,"tagline":"","homepage":"","overview":"Influencerka Ana telefonuje za jízdy a nabourá. Pošlou ji proto na statek jejího mrzoutského dědečka, kde ji čeká nucený digitální detox."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Modo avión","runtime":95,"tagline":"Modo avión","homepage":"","overview":"Como castigo por chocar su auto mientras hablaba por su teléfono celular, una influencer digital debe ir a vivir a la granja de su abuelo para someterse a una \"desintoxicación digital\" sin señal de teléfono celular y sin selfies..."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"מצב טיסה","runtime":0,"tagline":"","homepage":"","overview":"אנה אושיית רשת מדברת בנייד תוך כדי נהיגה ועושה תאונה. כעונש היא נשלחת לחווה של סבא הנרגן ונאלצת לעבור גמילה ממסכים."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"飞行模式","runtime":0,"tagline":"","homepage":"","overview":"网红安娜因开车时打电话而遭遇车祸，于是被送至她脾气暴躁的祖父的农场，被迫进行“数码排毒”。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"飛行模式","runtime":0,"tagline":"","homepage":"","overview":"網紅安娜開車講電話出了車禍後，被送到暴躁爺爺的農場，還被迫戒除手機成癮症。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Режим полета","runtime":0,"tagline":"","homepage":"","overview":"Ана - молодая женщина, которая с раннего детства имела безупречный вкус в одежде. Она постоянно следила за модой и мечтала связать с ней свое будущее. С годами ее интерес к моде только усиливался, и она делал все возможное, чтобы стать известным на весь мир стилистом. Героиня несмотря ни на что следовала навстречу мечте, но однажды ей пришлось забыть о ней. Она стала очень важным человеком для одного известного бренда. Данное событие кардинально поменяло жизнь героини, и у нее появились новые планы на ближайшее будущее. Сможет ли она достичь своей цели?.."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Самолетен режим","runtime":0,"tagline":"","homepage":"","overview":"Ана е младо момиче и е силно пристрастена към Интернет и социалните мрежи. Един ден ,докато шофира и говори по телефона си тя катастрофира. За наказание е изпратена при вечно мърморещия си дядо ,където е принудена да се раздели с вредните си навици."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Chế Độ Máy Bay","runtime":0,"tagline":"","homepage":"","overview":"Gây ra vụ đâm xe vì mải nói chuyện điện thoại, cô nàng nổi tiếng Ana bị đưa đến trang trại của người đàn ông cục cằn - nơi cô buộc phải \"kiêng\" mạng và \"kiêng\" điện thoại."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"機内モードな私","runtime":0,"tagline":"","homepage":"","overview":""},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Wanneer Ana, een influencer, haar auto crasht terwijl ze aan de telefoon is, wordt ze naar de boerderij van haar knorrige grootvader gestuurd en gedwongen tot een digitale detox."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"เปิดโหมดรัก พักสัญญาณ","runtime":0,"tagline":"","homepage":"","overview":"เมื่ออนาสาวคนดังบนโลกอินเทอร์เน็ตประสบอุบัติเหตุเพราะคุยโทรศัพท์ขณะขับรถ เธอจึงถูกส่งตัวไปอยู่ที่บ้านไร่ของคุณปู่ขี้หงุดหงิดแถมยังโดนตัดขาดจากโลกออนไลน์ด้วย"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"飛行模式","runtime":0,"tagline":"","homepage":"","overview":"網紅安娜開車講電話出了車禍後，被送到暴躁爺爺的農場，還被迫戒除手機成癮症。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"När influencern Ana krockar med bilen medan hon pratar i telefon skickas hon till sin vresige farfar på landet, där hon tvingas genomgå en digital avgiftning."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"}],"reviews_tmdb":[],"recommendations":[{"id":620683,"adult":false,"title":"My Mom Is a Character 3","video":false,"overview":"Dona Hermínia will have to rediscover and reinvent herself because her children are forming new families. This supermom will have to deal with a new life scenario: Marcelina is pregnant and Juliano is getting married.","genre_ids":[35],"media_type":"movie","popularity":0.5092,"vote_count":492,"poster_path":"/zw77BFPGJ73Lig8GwRzYj1XHq53.jpg","release_date":"2019-12-26","vote_average":8.18,"backdrop_path":"/19vTfircuojU00I6xtRdy3DrF1e.jpg","original_title":"Minha Mãe é uma Peça 3: O Filme","original_language":"pt"},{"id":613183,"adult":false,"title":"All the Freckles in the World","video":false,"overview":"Teen comedy set in the school-year of 1994. José i