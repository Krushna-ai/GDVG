0.667,"vote_average":0.166},{"width":1365,"height":2048,"file_path":"/eBw5Vso0K3r8Dzycxz0E0lgC40z.jpg","iso_639_1":"en","iso_3166_1":"US","vote_count":1,"aspect_ratio":0.667,"vote_average":0.166},{"width":2000,"height":3000,"file_path":"/g6nPxucwOXDonlu1KHN7egVr8KS.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":1,"aspect_ratio":0.667,"vote_average":0},{"width":1000,"height":1423,"file_path":"/p9mPi01GuHZXn2NxXc7d6m1xxpa.jpg","iso_639_1":"es","iso_3166_1":"ES","vote_count":0,"aspect_ratio":0.703,"vote_average":0}],"backdrops":[{"width":3840,"height":2160,"file_path":"/nJLp4dBD29fwWopoaranezJ26bo.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":3,"aspect_ratio":1.778,"vote_average":2.278},{"width":3840,"height":2160,"file_path":"/bwP4UJZjjfAVOuTAWT8W8J2AKtG.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":2,"aspect_ratio":1.778,"vote_average":1.75},{"width":1280,"height":721,"file_path":"/pOrDi2q5RmecIpArN2HvlPEqkbe.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.775,"vote_average":0},{"width":3840,"height":2160,"file_path":"/2NAgOx1H8Or7A0AlPI5byCHkGm7.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/rF3vZzGALcTT49VKFwzYcA5jgAh.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/e7Q19Vwcmf4yRaLt3ist4gHhKEY.jpg","iso_639_1":null,"iso_3166_1":null,"vote_count":0,"aspect_ratio":1.778,"vote_average":0},{"width":3840,"height":2160,"file_path":"/uIOqX3PdmdieqtpAlC6REgKbij3.jpg","iso_639_1":"es","iso_3166_1":"MX","vote_count":0,"aspect_ratio":1.778,"vote_average":0}]},"enriched_at":"2026-04-21T04:45:55.463+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Gatillero","runtime":80,"tagline":"","homepage":"","overview":"Una cruda historia de tragedia y redención, contada a través de un único plano continuo. Rodada en la verdadera Isla Maciel, en las afueras de Buenos Aires, Argentina."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Gunman","runtime":80,"tagline":"","homepage":"","overview":"A former hitman accepts a minor job for his former boss. However, in a corrupt neighborhood, nothing is what it seems, and he quickly gets caught in a web of unexpected events. A race against time and his own destiny."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Una cruda historia de tragedia y redención, contada a través de un único plano continuo. Rodada en la verdadera Isla Maciel, en las afueras de Buenos Aires, Argentina."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Pablo „El Galgo”, fost asasin recent eliberat din închisoare, acceptă un job aparent simplu: să tragă într-un magazin pentru a intimida proprietarul. Însă, în loc să fie o misiune ușoară, se trezește prins într-o capcană mortală, fiind urmărit de foștii săi colegi din lumea interlopă."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Gatilheiro","runtime":0,"tagline":"","homepage":"","overview":"Este thriller acompanha uma noite vertiginosa na vida de \"El Galgo\" (Sergio Podeley), um ex-assassino de aluguel que aceita um pequeno trabalho para seu antigo chefe. No entanto, em um bairro corrupto, nada é o que parece, e ele rapidamente se vê envolvido em uma teia de eventos inesperados. Uma corrida contra o tempo e seu próprio destino, filmado sem cortes visíveis."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"الرّجُل المسلّح","runtime":80,"tagline":"","homepage":"","overview":"قاتلٌ مأجور سابق يقبل بتنفيذ مهمةٍ صغيرة لصالح رئيسه السابق. غير أنّه في حيٍّ غارقٍ في الفساد، لا شيء يبدو على حقيقته، وسرعان ما يجد نفسه عالقًا في شبكةٍ من الأحداث غير المتوقَّعة. إنّه سباقٌ مع الزمن ومع قدره المحتوم."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"AE","english_name":"Arabic"},{"data":{"title":"Стрелецът","runtime":0,"tagline":"","homepage":"","overview":"Трилър в реално време, заснет в един непрекъснат кадър. Сурова история за трагедия и изкупление се разгръща по улиците на Исла Масиел, Буенос Айрес, държейки зрителите напрегнати."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"槍手","runtime":0,"tagline":"","homepage":"","overview":"《槍手》（Gatillero）是一部緊張刺激的即時驚悚片。影片以一鏡到底的鏡頭，講述了一個關於悲劇與救贖的真實故事。拍攝地點位於阿根廷布宜諾斯艾利斯郊外的真實島嶼馬西埃爾島。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"厄运扳机","runtime":0,"tagline":"","homepage":"","overview":"一名前杀手接受了他前老板的一份小工作。然而，在一个腐败的街区，一切都并非表面看上去那样，他很快就陷入了一张由意外事件编织的网中。这是一场与时间和自身命运的赛跑。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"Стрелок","runtime":0,"tagline":"","homepage":"","overview":"История о бывшем киллере, который выходит из тюрьмы и берётся за простое задание от своей бывшей босcессы — сделать «предупредительную стрельбу» для запугивания. Но всё идёт не по плану: вместо лёгкой работы он оказывается втянут в смертельно опасную ловушку, где улицы превращаются в поле боя. История разворачивается в реальном времени и снята одним кадром, показывая, как прошлое и ошибки героя приводят к цепи предательств, насилия и борьбе за выживание."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"}],"reviews_tmdb":[],"recommendations":[{"id":1202479,"adult":false,"title":"Opus","video":false,"overview":"A young writer is invited to the remote compound of a legendary pop star who mysteriously disappeared thirty years ago. Surrounded by the star's cult of sycophants and intoxicated journalists, she finds herself in the middle of his twisted plan.","genre_ids":[27,9648,53],"media_type":"movie","popularity":2.171,"vote_count":202,"poster_path":"/m0du9dsiOVeb0SgfqR8ZAEPRxww.jpg","release_date":"2025-03-13","vote_average":5.698,"backdrop_path":"/3kzw6Rw7TBujqtchJS2TSP3O2US.jpg","original_title":"Opus","original_language":"en"},{"id":1161617,"adult":false,"title":"Code 3","video":false,"overview":"A burned-out paramedic tries to survive his last 24 hours on the job while training a new recruit.","genre_ids":[35,28],"media_type":"movie","popularity":9.8543,"vote_count":222,"poster_path":"/gIAYMDb5mIAeCAj76q1sRsKjkzo.jpg","release_date":"2025-09-12","vote_average":7.043,"backdrop_path":"/vZK3f5N8Fv2LcyFYLwt6dz0HE1H.jpg","original_title":"Code 3","original_language":"en"},{"id":919355,"adult":false,"title":"Dragon Knight","video":false,"overview":"Many years after the war has been lost, and all the dragons slain, a lone knight travels the lands of Agonos seeking to raise an army against the demon lord Abaddon. When a healer's vision reveals that one dragon still lives, and together with an eager young squire, the knight sets off in search of the fabled creature. As the armies of Abaddon descend on the human kingdoms, the dragon is their last hope of fending off the horde, before it lays waste to the lands of men. But does the creature even exist? And if it does, will it fight for them once more?","genre_ids":[14,12,28],"media_type":"movie","popularity":3.749,"vote_count":61,"poster_path":"/zkGFADykBtfPfTv7YJooxTH52ph.jpg","release_date":"2022-03-21","vote_average":6.3,"backdrop_path":"/l99dylTOAMkwKSr54X5ytiEtnLA.jpg","original_title":"Dragon Knight","original_language":"en"},{"id":1379520,"adult":false,"title":"Rule Breakers","video":false,"overview":"In a nation where educating girls is seen as rebellion, a visionary woman dares to teach young minds to dream. When their innovation draws global attention, their success sparks hope—and opposition. As threats loom and sacrifices are made, their courage and unity ignite a movement that could forever transform the world.","genre_ids":[18],"media_type":"movie","popularity":1.0707,"vote_count":21,"poster_path":"/zJ6yH7e7XFsVTbF1gZnERCVeQJn.jpg","release_date":"2025-03-06","vote_average":7.5,"backdrop_path":"/oaliethcvyREtDbNBp94hi5IXeP.jpg","original_title":"Rule Breakers","original_language":"en"},{"id":423204,"adult":false,"title":"Angel Has Fallen","video":false,"overview":"After a treacherous attack, Secret Service agent Mike Banning is charged with attempting to assassinate President Trumbull. Chased by his own colleagues and the FBI, Banning begins a race against the clock to clear his name.","genre_ids":[28,53],"media_type":"movie","popularity":6.1617,"vote_count":3801,"poster_path":"/fapXd3v9qTcNBTm39ZC4KUVQDNf.jpg","release_date":"2019-08-21","vote_average":6.594,"backdrop_path":"/sGqqnvOqJg2HDHrjtCPIlCwF4Mu.jpg","original_title":"Angel Has Fallen","original_language":"en"},{"id":872585,"adult":false,"title":"Oppenheimer","video":false,"overview":"The story of J. Robert Oppenheimer's role in the development of the atomic bomb during World War II.","genre_ids":[18,36],"media_type":"movie","popularity":23.0611,"vote_count":11386,"poster_path":"/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg","release_date":"2023-07-19","vote_average":8.034,"backdrop_path":"/ycnO0cjsAROSGJKuMODgRtWsHQw.jpg","original_title":"Oppenheimer","original_language":"en"},{"id":693134,"adult":false,"title":"Dune: Part Two","video":false,"overview":"Follow the mythic journey of Paul Atreides as he unites with Chani and the Fremen while on a path of revenge against the conspirators who destroyed his family. Facing a choice between the love of his life and the fate of the known universe, Paul endeavors to prevent a terrible future only he can foresee.","genre_ids":[878,12],"media_type":"movie","popularity":24.0699,"vote_count":7549,"poster_path":"/1pdfLvkbY9ohJlCjQH2CZjjYVvJ.jpg","release_date":"2024-02-27","vote_average":8.13,"backdrop_path":"/ylkdrn23p3gQcHx7ukIfuy2CkTE.jpg","original_title":"Dune: Part Two","original_language":"en"},{"id":533535,"adult":false,"title":"Deadpool & Wolverine","video":false,"overview":"A listless Wade Wilson toils away in civilian life with his days as the morally flexible mercenary, Deadpool, behind him. But when his homeworld faces an existential threat, Wade must reluctantly suit-up again with an even more reluctant Wolverine.","genre_ids":[28,35,878],"media_type":"movie","popularity":24.3599,"vote_count":8293,"poster_path":"/8cdWjvZQUExUUTzyp4t6EDMubfO.jpg","release_date":"2024-07-24","vote_average":7.558,"backdrop_path":"/ufpeVEM64uZHPpzzeiDNIAdaeOD.jpg","original_title":"Deadpool & Wolverine","original_language":"en"},{"id":361743,"adult":false,"title":"Top Gun: Maverick","video":false,"overview":"After more than thirty years of service as one of the Navy’s top aviators, and dodging the advancement in rank that would ground him, Pete “Maverick” Mitchell finds himself training a detachment of TOP GUN graduates for a specialized mission the likes of which no living pilot has ever seen.","genre_ids":[28,18],"media_type":"movie","popularity":20.7841,"vote_count":10612,"poster_path":"/62HCnUTziyWcpDaBO2i1DX17ljH.jpg","release_date":"2022-05-21","vote_average":8.156,"backdrop_path":"/AaV1YIdWKnjAIAOe8UUKBFm327v.jpg","original_title":"Top Gun: Maverick","original_language":"en"},{"id":823219,"adult":false,"title":"Flow","video":false,"overview":"A solitary cat, displaced by a great flood, finds refuge on a boat with various species and must navigate the challenges of adapting to a transformed world together.","genre_ids":[16,12,14,10751],"media_type":"movie","popularity":14.5003,"vote_count":2646,"poster_path":"/zME0Ul0w48MKkYBnFRn40M5qgLh.jpg","release_date":"2024-08-29","vote_average":8.095,"backdrop_path":"/4XPNNt0zfZKBqxxVWaQALd57UHl.jpg","original_title":"Straume","original_language":"lv"},{"id":1233413,"adult":false,"title":"Sinners","video":false,"overview":"Trying to leave their troubled lives behind, twin brothers return to their hometown to start again, only to discover that an even greater evil is waiting to welcome them back.","genre_ids":[27,28,53],"media_type":"movie","popularity":37.799,"vote_count":3773,"poster_path":"/qTvFWCGeGXgBRaINLY1zqgTPSpn.jpg","release_date":"2025-04-16","vote_average":7.489,"backdrop_path":"/nAxGnGHOsfzufThz20zgmRwKur3.jpg","original_title":"Sinners","original_language":"en"},{"id":264660,"adult":false,"title":"Ex Machina","video":false,"overview":"Caleb, a coder at the world's largest internet company, wins a competition to spend a week at a private mountain retreat belonging to Nathan, the reclusive CEO of the company. But when Caleb arrives at the remote location he finds that he will have to participate in a strange and fascinating experiment in which he must interact with the world's first true artificial intelligence, housed in the body of a beautiful robot girl.","genre_ids":[18,878],"media_type":"movie","popularity":7.9469,"vote_count":14040,"poster_path":"/dmJW8IAKHKxFNiUnoDR7JfsK7Rp.jpg","release_date":"2015-01-21","vote_average":7.573,"backdrop_path":"/uqOuJ50EtTj7kkDIXP8LCg7G45D.jpg","original_title":"Ex Machina","original_language":"en"},{"id":545611,"adult":false,"title":"Everything Everywhere All at Once","video":false,"overview":"An aging Chinese immigrant is swept up in an insane adventure, where she alone can save what's important to her by connecting with the lives she could have led in other universes.","genre_ids":[28,12,878],"media_type":"movie","popularity":11.7985,"vote_count":7694,"poster_path":"/u68AjlvlutfEIcpmbYpKcdi09ut.jpg","release_date":"2022-03-24","vote_average":7.721,"backdrop_path":"/ss0Os3uWJfQAENILHZUdX8Tt1OC.jpg","original_title":"Everything Everywhere All at Once","original_language":"en"},{"id":530385,"adult":false,"title":"Midsommar","video":false,"overview":"Several friends travel to Sweden to study as anthropologists a summer festival that is held every ninety years in the remote hometown of one of them. What begins as a dream vacation in a place where the sun never sets, gradually turns into a dark nightmare as the mysterious inhabitants invite them to participate in their disturbing festive activities.","genre_ids":[27,18,9648],"media_type":"movie","popularity":9.8903,"vote_count":7887,"poster_path":"/7LEI8ulZzO5gy9Ww2NVCrKmHeDZ.jpg","release_date":"2019-07-03","vote_average":7.153,"backdrop_path":"/pYgj8e2Y6RufnSyOA6OnzmxFXxZ.jpg","original_title":"Midsommar","original_language":"en"},{"id":912649,"adult":false,"title":"Venom: The Last Dance","video":false,"overview":"Eddie and Venom are on the run. Hunted by both of their worlds and with the net closing in, the duo are forced into a devastating decision that will bring the curtains down on Venom and Eddie's last dance.","genre_ids":[28,878,12],"media_type":"movie","popularity":17.6767,"vote_count":4022,"poster_path":"/1RaSkWakWBxxYOWRrqmwo2my5zg.jpg","release_date":"2024-10-22","vote_average":6.663,"backdrop_path":"/3V4kLQg0kSqPLctI5ziYWabAZYF.jpg","original_title":"Venom: The Last Dance","original_language":"en"},{"id":1022789,"adult":false,"title":"Inside Out 2","video":false,"overview":"Teenager Riley's mind headquarters is undergoing a sudden demolition to make room for something entirely unexpected: new Emotions! Joy, Sadness, Anger, Fear and Disgust, who’ve long been running a successful operation by all accounts, aren’t sure how to feel when Anxiety shows up. And it looks like she’s not alone.","genre_ids":[16,12,35,10751],"media_type":"movie","popularity":20.8197,"vote_count":6475,"poster_path":"/vpnVM9B6NMmQpWeZvzLvDESb2QY.jpg","release_date":"2024-06-11","vote_average":7.547,"backdrop_path":"/p5ozvmdgsmbWe0H8Xk7Rc8SCwAB.jpg","original_title":"Inside Out 2","original_language":"en"},{"id":575264,"adult":false,"title":"Mission: Impossible - Dead Reckoning Part One","video":false,"overview":"Ethan Hunt and his IMF team embark on their most dangerous mission yet: To track down a terrifying new weapon that threatens all of humanity before it falls into the wrong hands. With control of the future and the world's fate at stake and dark forces from Ethan's past closing in, a deadly race around the globe begins. Confronted by a mysterious, all-powerful enemy, Ethan must consider that nothing can matter more than his mission—not even the lives of those he cares about most.","genre_ids":[28,53,12],"media_type":"movie","popularity":11.2386,"vote_count":4935,"poster_path":"/NNxYkU70HPurnNCSiCjYAmacwm.jpg","release_date":"2023-07-08","vote_average":7.506,"backdrop_path":"/628Dep6AxEtDxjZoGP78TsOxYbK.jpg","original_title":"Mission: Impossible - Dead Reckoning Part One","original_language":"en"},{"id":823464,"adult":false,"title":"Godzilla x Kong: The New Empire","video":false,"overview":"Following their explosive showdown, Godzilla and Kong must reunite against a colossal undiscovered threat hidden within our world, challenging their very existence – and our own.","genre_ids":[28,12,878],"media_type":"movie","popularity":13.49,"vote_count":4515,"poster_path":"/z1p34vh7dEOnLDmyCrlUVLuoDzd.jpg","release_date":"2024-03-27","vote_average":7.052,"backdrop_path":"/gvLG3Fnznkxl4SmYfcK8gUuqxM8.jpg","original_title":"Godzilla x Kong: The New Empire","original_language":"en"},{"id":565770,"adult":false,"title":"Blue Beetle","video":false,"overview":"Recent college grad Jaime Reyes returns home full of aspirations for his future, only to find that home is not quite as he left it. As he searches to find his purpose in the world, fate intervenes when Jaime unexpectedly finds himself in possession of an ancient relic of alien biotechnology: the Scarab.","genre_ids":[28,878,12],"media_type":"movie","popularity":6.3322,"vote_count":3024,"poster_path":"/mXLOHHc1Zeuwsl4xYKjKh2280oL.jpg","release_date":"2023-08-16","vote_average":6.646,"backdrop_path":"/3H9NA1KWEQN0ItL3Wl3SFZYP6yV.jpg","original_title":"Blue Beetle","original_language":"en"},{"id":238,"adult":false,"title":"The Godfather","video":false,"overview":"Spanning the years 1945 to 1955, a chronicle of the fictional Italian-American Corleone crime family. When organized crime family patriarch, Vito Corleone barely survives an attempt on his life, his youngest son, Michael steps in to take care of the would-be killers, launching a campaign of bloody revenge.","genre_ids":[18,80],"media_type":"movie","popularity":40.3175,"vote_count":22500,"poster_path":"/3bhkrj58Vtu7enYsRolD1fZdja1.jpg","release_date":"1972-03-14","vote_average":8.688,"backdrop_path":"/tSPT36ZKlP2WVHJLM4cQPLSzv3b.jpg","original_title":"The Godfather","original_language":"en"}],"similar_content":[],"external_ids":{"imdb_id":"tt35974872","twitter_id":null,"facebook_id":null,"wikidata_id":"Q135963230","instagram_id":null},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":148193,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AR","release_dates":[{"note":"BAFICI","type":1,"iso_639_1":"es","descriptors":[],"release_date":"2025-04-05T00:00:00.000Z","certification":""},{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2025-06-12T00:00:00.000Z","certification":"+16"}]},{"iso_3166_1":"ES","release_dates":[{"note":"30 Ourense Film Festival","type":2,"iso_639_1":"es","descriptors":[],"release_date":"2025-09-27T00:00:00.000Z","certification":""}]},{"iso_3166_1":"US","release_dates":[{"note":"Cinequest","type":1,"iso_639_1":"","descriptors":[],"release_date":"2025-03-21T00:00:00.000Z","certification":""}]}],"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc":null,"box_office":null,"belongs_to_collection":null,"collection_id":null,"wikidata_metadata":{},"mood_tags":null,"trope_tags":null,"vibe_description":null,"ai_enrich