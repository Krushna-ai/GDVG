5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Movie\",\"name\":\"Gunman\",\"description\":\"A former hitman accepts a minor job for his former boss. However, in a corrupt neighborhood, nothing is what it seems, and he quickly gets caught in a web of unexpected events. A race against time and his own destiny.\",\"image\":\"https://image.tmdb.org/t/p/w500/eRd5ifLty4vn1vkWG5oozTlE1iX.jpg\",\"datePublished\":\"2025-06-12\",\"numberOfEpisodes\":null,\"countryOfOrigin\":\"AR\",\"inLanguage\":\"es\",\"genre\":[\"Thriller\",\"Action\",null,null,null],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.6,\"bestRating\":10,\"ratingCount\":20}}"}}],["$","$L10",null,{"initialDrama":{"id":"d2343f2c-36c4-4982-b04e-1d01839f401f","tmdb_id":1450529,"imdb_id":"tt35974872","content_type":"movie","title":"Gunman","original_title":"Gatillero","overview":"A former hitman accepts a minor job for his former boss. However, in a corrupt neighborhood, nothing is what it seems, and he quickly gets caught in a web of unexpected events. A race against time and his own destiny.","poster_path":"/eRd5ifLty4vn1vkWG5oozTlE1iX.jpg","backdrop_path":"/nJLp4dBD29fwWopoaranezJ26bo.jpg","release_date":"2025-06-12","first_air_date":null,"status":"published","original_language":"es","origin_country":["AR"],"genres":[{"id":53,"name":"Thriller"},{"id":28,"name":"Action"},"action film","thriller film","drama film"],"popularity":4.1168,"vote_average":6.6,"vote_count":20,"runtime":80,"number_of_seasons":null,"number_of_episodes":null,"created_at":"2026-02-24T22:53:51.418993+00:00","updated_at":"2026-02-24T22:53:51.271+00:00","tagline":null,"homepage":null,"budget":0,"revenue":0,"production_companies":[{"id":212004,"name":"Dukkah Producciones","logo_path":"/ysl4FSU0c96OZFGlwIIxy1Ph68o.png","origin_country":"AR"},{"id":141986,"name":"Perspectiva Audiovisual","logo_path":null,"origin_country":"AR"},{"id":6458