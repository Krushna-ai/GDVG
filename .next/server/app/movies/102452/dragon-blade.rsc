on Prime Video","display_priority":5},{"logo_path":"/8aBqoNeGGr0oSA85iopgNZUOTOc.jpg","provider_id":2100,"provider_name":"Amazon Prime Video with Ads","display_priority":204},{"logo_path":"/bEI5UgVjthdjiBXGiKRy7uSCRvF.jpg","provider_id":2445,"provider_name":"MovieSphere+ Amazon Channel","display_priority":297}]},"UY":{"ads":[{"logo_path":"/dB8G41Q6tSL5NBisrIeqByfepBc.jpg","provider_id":300,"provider_name":"Pluto TV","display_priority":21},{"logo_path":"/xm8xr6LDdY5j2gjYf1S3yqaeRbE.jpg","provider_id":1875,"provider_name":"Runtime","display_priority":28},{"logo_path":"/60iyHW9xKBKVBf0kxiQixuLqG1f.jpg","provider_id":2302,"provider_name":"Mercado Play","display_priority":34}],"link":"https://www.themoviedb.org/movie/300168/watch?locale=UY","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":1}]},"VE":{"ads":[{"logo_path":"/dB8G41Q6tSL5NBisrIeqByfepBc.jpg","provider_id":300,"provider_name":"Pluto TV","display_priority":18},{"logo_path":"/xm8xr6LDdY5j2gjYf1S3yqaeRbE.jpg","provider_id":1875,"provider_name":"Runtime","display_priority":24}],"link":"https://www.themoviedb.org/movie/300168/watch?locale=VE","flatrate":[{"logo_path":"/pvske1MyAoymrs5bguRfVqYiM9a.jpg","provider_id":119,"provider_name":"Amazon Prime Video","display_priority":2}]}}},"wikidata_id":"Q17002139","tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-02-07T14:49:53.785279+00:00","region":"CN","main_poster":"/m5yyMErIDbdzVLIDXVBG6EzM1oF.jpg","images":{"logos":[{"width":379,"height":196,"file_path":"/oxYvTqZkQEs4nTbphPJ2yDG6Rd3.png","iso_639_1":"zh","vote_average":3.334},{"width":1413,"height":386,"file_path":"/9fDYY85PXweZcLQZNqcIINpvIR1.png","iso_639_1":"es","vote_average":0}],"posters":[{"width":2000,"height":3000,"file_path":"/m5yyMErIDbdzVLIDXVBG6EzM1oF.jpg","iso_639_1":"en","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/suTAWYLIHAnkH2V4nC8t3AG7HjR.jpg","iso_639_1":"en","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/iSOztbhxa8N3Q44kDA5An0Mb1Dm.jpg","iso_639_1":"en","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/4kmqhCX7YftuXv7l600CvSpbgdj.jpg","iso_639_1":"ru","vote_average":3.334},{"width":1537,"height":2161,"file_path":"/1SfEUJBx2TTxvsOhtdB8pv56VIh.jpg","iso_639_1":"hu","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/pwLsWggWr0gW3ndOcQRkVqDhW8C.jpg","iso_639_1":"sk","vote_average":3.334},{"width":1000,"height":1500,"file_path":"/8eBBZXWoCgIcRGgszm0cirzLtz8.jpg","iso_639_1":"sk","vote_average":3.334},{"width":1200,"height":1600,"file_path":"/h7eFL7CZh0ejPNic6QPxxpVbOfv.jpg","iso_639_1":"pt","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/pK93lj4JSQ6JZH3AwhldXbXlcbJ.jpg","iso_639_1":"tr","vote_average":3.334},{"width":1175,"height":1763,"file_path":"/q5RpRsw58Bp3mi51TQgOZr6x3Ka.jpg","iso_639_1":"ja","vote_average":3.334},{"width":2000,"height":3000,"file_path":"/kAMpDcY8dPuuBajNNzr7GFwWuhp.jpg","iso_639_1":"zh","vote_average":3.334},{"width":1537,"height":2161,"file_path":"/c5wdMmbg5KlhIEVKZEFC6Fev5nu.jpg","iso_639_1":"hu","vote_average":0.166},{"width":621,"height":886,"file_path":"/mcIjJnMQeMsxGrp7dZmL04xVCyw.jpg","iso_639_1":"ko","vote_average":0.166},{"width":1000,"height":1500,"file_path":"/AjXnoBlGEyeu09C2RJ3enNuug4Q.jpg","iso_639_1":"ja","vote_average":0.166},{"width":960,"height":1440,"file_path":"/jehJ5TlgBqfP6DkWqOjcCkMYxgd.jpg","iso_639_1":"pt","vote_average":0.166}],"backdrops":[{"width":1920,"height":1080,"file_path":"/rnNkUJlo03a8D0utxiOrADstaMT.jpg","iso_639_1":null,"vote_average":3.334},{"width":3504,"height":1971,"file_path":"/acdYwiW84yyXaCDhLijzIj3meOs.jpg","iso_639_1":null,"vote_average":1.75},{"width":3840,"height":2160,"file_path":"/lV2i39yorOWgjYfIGyPl7aU4lZA.jpg","iso_639_1":null,"vote_average":0.166},{"width":1920,"height":1080,"file_path":"/csOhEitootuM399qtrQcaK6gyQ0.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/en9eWVU8pl2Zjw0fMq1aW8O3iw4.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/dCT2qpYnunObUpKpHSqaZiMmCrE.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/wea4ZS9dmL8i2RSsaoZH6UtKWmf.jpg","iso_639_1":null,"vote_average":0},{"width":3840,"height":2160,"file_path":"/eQ8YKkJksgUw8TWzIL5FfcR7KZm.jpg","iso_639_1":null,"vote_average":0},{"width":1500,"height":843,"file_path":"/mnIUAu291tzPDIgRMvbG3aKnuiN.jpg","iso_639_1":"en","vote_average":0},{"width":1920,"height":1080,"file_path":"/eUGU9ruVt8fqe3hpbWTT86pgIq1.jpg","iso_639_1":"en","vote_average":0}]},"enriched_at":"2026-02-21T15:03:24.232+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"Dragon Blade","runtime":127,"tagline":"When the Eagle meets the Dragon","homepage":"","overview":"Huo An, the commander of the Protection Squad of the Western Regions, was framed by evil forces and becomes enslaved. On the other hand, a Roman general escapes to China after rescuing the Prince. The heroic duo meet in the Western Desert and a thrilling story unfolds."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"Dragon Blade","runtime":127,"tagline":"Adler trifft Drache","homepage":"","overview":"Während der Han Dynastie befindet sich das chinesische Reich mitten im Krieg zwischen mehreren verfeindeten Clans und Familienbanden. Dabei fällt es einem Kommandeur zu, eine Schutzeinheit aufzustellen, um die westlichen Regionen seines Königreiches gegen anrückende Eindringlinge zu verteidigen. Dabei muss er sich mit einem ungewöhnlichen Partner zusammentun, um die Gefahr abwehren zu können..."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"天将雄师","runtime":127,"tagline":"","homepage":"","overview":"西汉汉元帝年间，西域都护府大都护霍安（成龙 饰）遭奸人陷害，沦为奴役，被刺配至雁门关修城。恰在此时，罗马将军卢魁斯（约翰·库萨克 John Cusack 饰）护卫遭到哥哥迫害的罗马小王子（西蒙子 饰）逃命至雁门关。双雄在西域戈壁相遇，从开始的兵戎相见到惺惺相惜，最终化敌为友。一日，霍安为洗清自己冤屈四处追查时，无意间撞破了好兄弟殷破（崔始源 饰）与罗马大王子提比斯（艾德里安·布洛迪 Adrien Brody 饰）不可告人的秘密。与此同时，提比斯为追杀卢魁斯与小王子一行人也亲自带兵赶来西域。为保护小王子和西域诸国的安危，霍安与卢魁斯联手与提比斯在戈壁大漠展开了一场生死之战"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"La battaglia degli imperi - Dragon Blade","runtime":127,"tagline":"Quando l'impero romano si scontrò con l'oriente","homepage":"","overview":"Durante la dinastia Han, Huo An, comandante della squadra di protezione delle regioni occidentali, è caduto vittima delle forze del male ed è diventato schiavo. Il suo destino però si incontrerà presto con quello del generale romano Lucius, con cui proteggerà la sovranità della Cina dalle mire del folle Tiberius."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"Το Ξίφος του Δράκου","runtime":0,"tagline":"","homepage":"","overview":"Συνοδευόμενος από έναν πελώριο στρατό, ο αδίστακτος Ρωμαίος αυτοκράτορας Τιβέριος διεκδικεί το Δρόμο του Μεταξιού. Μια ομάδα πολεμιστών θα αναλάβει δράση, προκειμένου να διατηρήσει την ευαίσθητη ισορροπία δυνάμεων στην περιοχή."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"Меч дракона","runtime":0,"tagline":"","homepage":"","overview":"Действие фильма разворачивается в Древнем Китае во времена правления династии Хань. Римский полководец Луция с легионом своих солдат оказывается на территории Китая. В это же время командир отряда охраны Западного региона Хо Ань в результате действий своих врагов становится рабом. И этим двум воинам было суждено встретиться в Западной пустыне, где развернётся эпическое сражение. Однако биться они будут не друг против друга, как можно было бы подумать, а против алчного императора Тиберия за суверенитет Китая."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"Dragon Blade","runtime":127,"tagline":"Cuando el águila se encuentra con el dragón","homepage":"","overview":"Un decurión de una Legión romana se verá solo y abandonado en medio de China tras una expedición fallida. Será allí donde se cruce con un heroico soldado chino con el que unirá sus fuerzas para combatir a un enemigo aún mayor que amenaza no sólo a China, sino a todo el mundo conocido."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Dragon Blade","runtime":127,"tagline":"","homepage":"","overview":"Den korrupte romerske leder Tiberius ankommer med sin massive hær for at tage kontrollen over den vigtige handelsrute, Silkevejen. En lille gruppe soldater, anført af Huo An, må slå sig sammen med en gruppe af afhoppede romerske soldater, anført af General Lucius, for at nedkæmpe denne styrke og opretholde balancen i regionen."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"Wojna Imperiów","runtime":127,"tagline":"Bitwa o jedwabny szlak.","homepage":"","overview":"Huo An jest komandorem Protektoratu Regionów Zachodnich pod panowaniem Dynastii Han, odpowiedzialnym za obronę granic. Wkrótce zostaje niesłusznie oskarżony, w rezultacie czego traci wolność. W tym samym czasie do Chin przedostaje się zaginiony rzymski legion, dowodzony przez Luciusa . Spotkanie obu bohaterów daje początek legendarnej obronie przed armią generała Tiberiusa , który pragnie przejąć kontrolę na \"jedwabnym szlaku\"."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"Dragon Blade","runtime":127,"tagline":"","homepage":"","overview":"Dragon Blade kertoo karussa olevasta roomalaiskenraali Luciuksesta, joka kohtaa orjaksi joutuneen kiinalaisvartijan Kiinan aavikoilla. Epätavallinen kaksikko yhdistää voimansa kukistaakseen vallanhimoisen Tiberiuksen aikeet ottaa haltuunsa arvokas Silkkitie."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"Dragon Blade","runtime":127,"tagline":"","homepage":"","overview":"La paix et l'égalité entre les peuples : telles sont les valeurs auxquelles croit le charismatique capitaine chinois Huo An. Arrêté pour un crime qu'il n'a pas commis, le père de famille est envoyé à la frontière occidentale où il a 15 jours pour reconstruire une ville détruite. Après une première rencontre qui s'est soldée par un affrontement, il reçoit l'aide du soldat romain Lucius et de ses hommes de main qui semblent être sur la route de la soie. En échange de son aide précieuse, son nouvel ami lui demande des conseils afin de se venger du tyran Tiberius."},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"Драконово острие","runtime":127,"tagline":"","homepage":"","overview":"Хуо Ан (Джаки Чан), командващ отряд, който охранява Западните региони на Китайската империя, крепи мира между войнствените племена по Пътя на коприната и често се бие с тях или разрешава споровете помежду им. Но до вътрешността на Китай достига керван със злато, с чужди знамена и заради това Хуо Ан е обвинен в предателство и е пратен да работи като роб на границата. С малък отряд от най-верните си войници, той се бори да оцелее в затворнически лагер. Същевременно римският генерал Луций (Кюсак) достига с малката си армия граничната порта и побеждава китайските пазачи на границата, но Хуо Ан се намесва в битката и съвсем сам успява да обърне развоя й като печели възхищението на Луций. В римския легион има едно сляпо момче, Публий, най-малък син на римския консул Крас. Крас е бил убит от амбициозния му най-голям син Тиберий (Броуди), който тръгва със 100 000 войници към Китай под предлог да отвлече Луций. Хуо Ан уговаря местните племена да помогнат на отряда на Луций."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"Dragon Blade","runtime":127,"tagline":"Quando a Águia encontra o Dragão","homepage":"","overview":"No ano 48 a.C. o general romano Lucius (John Cusak) foge com o seu pelotão e o herdeiro do Consul Romano, Publius (Jozef Waite), para escapar do imperador Tiberius (Adrien Brody) que deseja tomar o trono e matar Publius. Num forte na fronteira da Rota da Seda, o grupo conhece o huno Huo An (Jackie Chan) que é responsável por proteger o local. Quando descobre que o imperador está a caminho, Huo An recruta um exército e une-se aos romanos numa épica batalha."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"ดาบมังกรฟัด","runtime":125,"tagline":"ดาบมังกรฟัด","homepage":"","overview":"สองพันปีก่อน กองพลทหารลึกลับ ที่มีนัยน์ตาโตและจมูกโด่ง ร่อนเร่ไปตามเส้นทางสายไหม แต่งตัวด้วยเกราะและมีพู่แดงบนหมวก ทหารโรมันทัพนี้นำโดย แม่ทัพลูเชียส เขาพาคนของเขาไปยังตะวันออกเพื่อปกป้องพูบลิอุส บุตรชายคนเล็กสุดของกงสุลแครสซัส จากพี่ชายที่ชั่วร้ายของเขาอย่างทีเบเรียส ทีเบเรียสได้สังหารพ่อของเขาและทำให้พูบลิอุสตาบอด ลูเชียสหนีมาพร้อมกับพูบลิอุสและมุ่งหน้าไปทางตะวันออก กองทัพนี้มีอาวุธและกลยุทธในการรบที่คนบนแผ่นดินจีนไม่เคยเห็นมาก่อน หลังจากหลงทางในทะเลทราย พวกเขาก็มาถึงยังประตูห่านป่า ที่ที่ลูเชียสต้องต่อสู้กับฮัวอัน ผู้บัญชาการของกองกำลังคุ้มกันเส้นทางสายไหมทางด้านตะวันตก ชายสองคน ซึ่งต่างคนต่างเคยถูกกล่าวหาว่าเป็นกบฎ ต่างเคารพซึ่งกันและกันในเวลาต่อมา เมื่อทีเบเรียสยกทัพใหญ่มาถึง เขาได้ยื่นคำขาดให้ฮัวอันส่งตัวลูเชียสและพูบลิอุสมา ไม่เช่นนั้น ทัพของเขาจะเข้าบุกยึดจีน เพื่อเป็นการปกป้องประเทศชาติและกอบกู้ชื่อเสียงจากที่เคยถูกกล่าวหาว่ากบฏ ฮัวอันรวบรวมนักรบ 36 ชนชาติ ให้รวมตัวกันสู้กับทีเบเรียสในศึกครั้งมหากาพย์…"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"드래곤 블레이드: 천장웅사","runtime":127,"tagline":"피할 수 없는 운명의 서막! 운명에 맞선 전사들의 가장 위대한 전투가 시작된다!","homepage":"","overview":"2000년 전, 거대한 모래폭풍이 휘몰아치는 혼란의 땅 실크로드. 평화 유지를 위해 그곳을 지키는 부대의 총사령관 후오 안(성룡)은 어느 날 정교하게 짜인 갑옷과 붉은 갈기가 장식된 투구를 쓴 지금껏 볼 수 없었던 무기와 전투 편대를 구축하고 있는 로마 군대와 맞닥뜨리게 된다. 후오 안(성룡)은 로마 군대를 이끄는 루시우스 장군(존 쿠삭)과 피할 수 없는 결투를 하게 되지만 각각 자국에서 반역죄의 누명을 쓰게 된 사연을 알게 되면서 서로에게 존경심과 우정을 느낀다. 한편, 이들을 둘러싸고 닥쳐오는 위협은 점점 더 커져만 가고 결국 그들은 조국과 명예를 위해 목숨을 건 마지막 전투를 준비하게 되는데…"},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Boj o Hedvábnou stezku","runtime":127,"tagline":"Když se setká orel a drak","homepage":"","overview":"Příběh začíná před 2 000 lety na Hedvábné stezce. Spravuje jí obranná jednotka pod vedením kapitána Chuo Ana. Tato jednotka má nastolit mír mezi všemi národy. Jenže jednoho dne je obranná jednotka obviněna z pašování zlata a poslána do vyhnanství k Bráně divokých hus, kde se musí podílet na obnově města. K bráně ale přichází Lucius se svými římskými legiemi a chce město dobýt, aby si mohl vzít zásoby. Lucius je ale vyhnanec, který zachránil konzulova syna před smrtí. K samotnému boji nedojde a Římané jsou vpuštěni za brány, aby se ukryli před písečnou bouří. Jako vděk za pomoc, pomohou s obnovou města. Z římských jednotek a čínských trestanců se stanou přátelé. O pár dní později k Bráně přichází Tiberius, který chce zabít Publiuse, malého prince, syna konzulova. Lucius vysílá ke královně do Parthské říše posla, aby dokázal Tiberiovy zlé úmysly."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Tian Jiang Xiong Shi","runtime":126,"tagline":"","homepage":"","overview":"De Romeinse generaal Lucius leidt een legioen China binnen. Hij wordt achterna gezeten door een leger van 10.000 soldaten, onder aanvoering van de machtswellusteling Tiberius, die de Romeinse consul Crassus heeft vermoord. Lucius wordt te hulp geschoten door een Chinese commandant die de westerse regionen bewaakt."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Ejder Kılıcı","runtime":0,"tagline":"Kartal ve Ejder Karşılaşıyor","homepage":"","overview":"General Lucius'un önderlik ettiği Romalı bir lejyon İpek Yolu üzerinde ilerlemektedir. Amaçları Consul Crassus'un oğlu Publius'u, hain kardeşi Tiberius'tan korumaktır. General Lucius, Publius'u yanına alıp doğuya kaçırır. Lucius ve lejyonu yol üzerinde Batı Bölgesi İpek Yolu Koruma Ordusu'nun kumandanı Huo An ile savaşır. İki taraf da ihanete uğramıştır ve birbirlerine saygı duyarlar. Huo An sonunda Romalı lejyona kum fırtınasından korunmaları için sığınak verir. Lucius'un askerleri ise bunun karşılığında Huo An'ın askerlerine Vahşi Kazlar Kapısı'nı tamir etmesi için yardım edecektir. Kötücül Tiberius kalabalık ordusuyla Huo An'ın topraklarına gelir ve ondan Lucius ve Publius'u iade etmesini ister. Diğer türlü Çin topraklarını işgal edeceğini belirtir. Huo An topraklarını korumak ve üzerindeki hain damgasını temizlemek için Tiberius ile savaşacak ve bunun için de 36 farklı milletten savaşçıyı bir araya getirecektir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"A sas és a sárkány","runtime":127,"tagline":"Amikor birodalmak csapnak össze... Legendák születnek.","homepage":"","overview":"Kínában a Han dinasztia idején a tisztségviselőt, Huo Ant átverik, és hamis vádakkal rabszolgává teszik. Nem sokkal később megismerkedik egy római katonával, Lucius-szal, akivel szövetséget kötve indul harcba az igazságért."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"Dragon Blade","runtime":127,"tagline":"Når Ørnet møter Dragen.","homepage":"","overview":"Huo An, sjefen for beskyttelse squad av den vestlige regioner, ble rammet av onde krefter og blir slaver. På den annen side unnslipper en romersk generalen til Kina etter å ha reddet prinsen. Den heltemodige duoen møtes i den vestlige ørken og en spennende historien utfolder seg."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"Batalha dos Impérios","runtime":0,"tagline":"Quando a Águia encontra o Dragão","homepage":"","overview":"No ano 48 a.C., o general romano Lucius foge com seu pelotão e o herdeiro do Cônsul Romano, Publius, para escapar do imperador Tiberius que deseja tomar o trono e matar Publius. Em um forte na fronteira da Rota da Seda, o grupo conhece o huno Huo An que é responsável por proteger o local. Quando descobre que o imperador está à caminho, Huo An recruta um exército e se une aos romanos em uma épica batalha."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"להב הדרקון","runtime":127,"tagline":"","homepage":"","overview":"כאשר טבריוס, מנהיג רומאי מושחת, מגיע עם צבא עצום בכדי לתבוע בעלות על דרך המשי, יו אן וקבוצתו בעלת צוותי לוחמים מאומנים וכן חבורה מובחרת של חיילים רומאים שערקו בפיקודו של הגנרל לוציוס בכדי לשמור על האיזון העדין של כוחות באזור. יו, בכדי להגן על ארצו ועל חבריו החדשים, קורא ואוסף לוחמים מ-36 מדינות אתניות בכדי להילחם יחדיו כנגד טיבריוס בקרב עצום שכולו קרב של גבורה..."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"Boj o Hodvábnu cestu","runtime":0,"tagline":"","homepage":"","overview":"Skorumpovaný rímsky vodca Tiberius prichádza s obrovskou armádou dobyť a ovládnuť Hodvábnu cestu - výnosnú obchodnú tepnu, ktorá spája Čínu s Rímskou ríšou. Veliteľ čínskych obranných jednotiek Huo An so skupinou skúsených bojovníkov sa spoja s elitnou légiou zbehnutých rímskych vojakov vedených generálom Luciom, aby sa ubránili spoločnému nepriateľovi a zaistili krehkú rovnováhu síl. V túžbe ochrániť svoju vlasť, Hodvábnu cestu a nových priateľov získa Huo An vojenské posily z 36 rôznych národov a etník, žijúcich v regióne. Napokon sa všetci spoločne postavia na odpor voči Tiberiovi v poslednom a rozhodujúcom veľkolepom súboji."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"Меч дракона","runtime":0,"tagline":"","homepage":"","overview":"Події розгортаються в Стародавньому Китаї за часів правління династії Хань. Римський полководець Луція з легіоном своїх солдатів опиняється на території Китаю. В цей же час командир загону охорони Західного регіону Хо Ань в результаті дій своїх ворогів стає рабом. І цим двом воїнам судилося зустрітися в Західній пустелі, де розгорнеться епічний бій. Однак битися вони будуть не один проти одного, як можна було б подумати, а проти жадібного імператора Тіберія за суверенітет Китаю."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"Le sabre du dragon","runtime":127,"tagline":"Quand l'aigle rencontre le dragon","homepage":"","overview":"Alors que le corrompu leader romain Tiberius, accompagnée d'une gigantesque armée, se prépare à envahir la Chine afin de prendre le contrôle de la Route de la soie, Huo An joindra son armée aux forces d'un légion de Romains ayant déserté l'armée et menés par le Général Lucius afin de protéger son pays et ses nouveaux alliés."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"ドラゴン・ブレイド","runtime":104,"tagline":"","homepage":"","overview":"多くの部族が争っていた紀元前のシルクロード。前漢の西域警備隊長フォは、陰謀によって西域辺境の関所・雁門関へ送られてしまう。一方、ローマ帝国の将軍ルシウスは、権力争いの中で暗殺された執政官のまだ幼い末息子を守り、自らの軍を引き連れて雁門関へ逃れてくる。当初は対立するフォとルシウスだが、やがて互いの似た立場から深い友情で結ばれていく。そんな中、関所のとりでにルシウスたちを追うローマ帝国の大軍勢が迫る。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"Dragon Blade","runtime":128,"tagline":"","homepage":"","overview":"När den korrupte romerske ledaren Tiberius anländer med sin gigantiska armé för att göra anspråk på Sidenvägen möts han av kraftfullt motstånd. Huo An och hans grupp av specialtränade krigare går ihop med en elitlegion av avhoppade romerska soldater under ledning av general Lucius för att upprätthålla den känsliga maktbalansen i regionen. För att skydda sitt land och sina allierade, samlar Huo An krigare från trettiosex etniska nationer för att besegra Tiberius i en enorm storslagen slutstrid."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"Dragon Blade: Încleștarea imperiilor","runtime":127,"tagline":"","homepage":"","overview":"Când liderul corupt roman, Tiberius, sosește cu o armată imensă pentru a revendica Drumul Mătăsii, Huo An își unește armata cu o Legiune de soldați romani dezertați, conduși de generalul Lucius, pentru a-și proteja țara și noii săi prieteni."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"Drakono kardas","runtime":0,"tagline":"","homepage":"","overview":"Šilko kelio apsaugos būrio bei jų vado Huo Ano (akt. Jackie Chanas) tikslas – taika saugomoje teritorijoje. Tačiau Romos imperatorius Tiberijus (akt. Adrienas Brody) siekia tapti vieninteliu šios svarbios prekybos teritorijos valdytoju.  Huo Anas, padedamas dezertyravusių Romos karių ir jų generolo Liucijaus (akt. Johnas Cusackas), pradeda kovą su klastingu imperatoriumi, kartu suburdamas ir trisdešimt šešias tautas, gyvenančias prie Šilko kelio."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"天將雄師","runtime":0,"tagline":"","homepage":"","overview":"西漢漢元帝年間，西域都護府大都護霍安（成龍飾）遭奸人陷害，淪為奴役，被刺配至雁門關修城。恰在此時，羅馬將軍盧魁斯（約翰·庫薩克John Cusack 飾）護衛遭到哥哥迫害的羅馬小王子（西蒙子飾）逃命至雁門關。雙雄在西域戈壁相遇，從開始的兵戎相見到惺惺相惜，最終化敵為友。一日，霍安為洗清自己冤屈四處追查時，無意間撞破了好兄弟殷破（崔始源飾）與羅馬大王子提比斯（艾德里安·布洛迪Adrien Brody 飾）不可告人的秘密。與此同時，提比斯為追殺盧魁斯與小王子一行人也親自帶兵趕來西域。為保護小王子和西域諸國的安危，霍安與盧魁斯聯手與提比斯在戈壁大漠展開了一場生死之戰"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"Dragon Blade","runtime":103,"tagline":"","homepage":"","overview":"Un decurión de una Legión romana se verá solo y abandonado en medio de China tras una expedición fallida. Será allí donde se cruce con un heroico soldado chino con el que unirá sus fuerzas para combatir a un enemigo aún mayor que amenaza no sólo a China, sino a todo el mundo conocido."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"سيف التنين","runtime":0,"tagline":"","homepage":"","overview":"في سياق من الفانتازيا التاريخية، تدور أحداث الفيلم حول (هو-آن)، قائد تشكيل عسكري في المنطقة الغربية الصينية، الذي تطارده قوى الشر وتتمكن من هزيمته وإخضاعه للعبودية، على جانب آخر الجنرال الروماني (تيبيريوس) ينجح في الهروب إلى الصين بعدما يستطيع إنقاذ أميره، ويلتقي البطلان ضمن أحداث الفيلم في الصحراء الغربية للصين وتتواصل الأحداث الخيالية."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"Kiếm Rồng","runtime":0,"tagline":"","homepage":"","overview":"Phim Kiếm Rồng lấy bối cảnh diễn ra dưới thời Tây Hán, phim xoay quanh câu chuyện của đại tướng quân Hoắc An (Thành Long) với sứ mệnh bảo vệ sự bình yên cho các nước chư hầu ở Tây Vực. Với tài năng, sự kiên trung và tình yêu hòa bình, Hoắc An đã liên kết với các huynh đệ từng vào sinh ra tử với mình lập nên liên minh “Quyết tử cho hòa bình”.  Thế nhưng, ông lại bị gian thần hãm hại, bị đày tới biên cương và chịu cảnh nô dịch hà khắc. May mắn thay, Hoắc An đã được đại tướng quân Tiberius (John Cusack) trên đường hộ tống hoàng tử tới phương Đông giải thoát. Từ đây, hai vị tướng quân anh hùng gắn kết thành tâm giao tri kỷ cùng chung lý tưởng bảo vệ chính nghĩa, xây dựng hòa bình. Hai người sát cánh bên nhau trải qua hàng loạt những trận đấu ly kỳ và những sự kiện đầy chấn động."},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"天將雄師","runtime":0,"tagline":"","homepage":"","overview":"西漢漢元帝年間，西域都護府大都護霍安（成龍飾）遭奸人陷害，淪為奴役，被刺配至雁門關修城。恰在此時，羅馬將軍盧魁斯（約翰·庫薩克 John Cusack 飾）護衞遭到哥哥迫害的羅馬小王子（西蒙子飾）逃命至雁門關。雙雄在西域戈壁相遇，從開始的兵戎相見到惺惺相惜，最終化敵為友。一日，霍安為洗清自己冤屈四處追查時，無意間撞破了好兄弟殷破（崔始源飾）與羅馬大王子提比斯（艾德裏安·布洛迪 Adrien Brody 飾）不可告人的秘密。與此同時，提比斯為追殺盧魁斯與小王子一行人也親自帶兵趕來西域。為保護小王子和西域諸國的安危，霍安與盧魁斯聯手與提比斯在戈壁大漠展開了一場生死之戰"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"شمشیر اژدها","runtime":0,"tagline":"","homepage":"","overview":""},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Dragon Blade","runtime":0,"tagline":"","homepage":"","overview":"Un decurió d'una Legió romana es veurà sol i abandonat al mig de la Xina després d'una expedició fallida. Serà allà on s'encreui amb un heroic soldat xinès amb què unirà les seves forces per combatre un enemic encara més gran que amenaça no només la Xina, sinó tothom conegut."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"}],"reviews_tmdb":[{"id":"5cc49f330e0a2678a0ebd575","url":"https://www.themoviedb.org/review/5cc49f330e0a2678a0ebd575","author":"Wuchak","content":"$11","created_at":"2019-04-27T18:28:03.351Z","updated_at":"2021-06-23T15:58:20.655Z","author_details":{"name":"","rating":5,"username":"Wuchak","avatar_path":"/4KVM1VkqmXLOuwj1jjaSdxbvBDk.jpg"}}],"recommendations":[{"id":334973,"adult":false,"title":"The Left Ear","video":false,"overview":"Li Er, a 17 year old girl who has great difficulty hearing out of her left ear, is rejected after confessing her love to a boy, Xu yi. Instead the boy is in love with Li Bala, a girl who is in fact in love with Zhang Yang. Li Er befriends Li Bala, who dies due to an accident. As the movie progresses, Li Er overcomes her hatred of Zhang Yang, whom she blamed for Li Bala's death.","genre_ids":[18,10749],"media_type":"movie","popularity":0.7547,"vote_count":36,"poster_path":"/mb5HkB37ux425QntqjeWBcdth2d.jpg","release_date":"2015-04-24","vote_average":6.361,"backdrop_path":"/bPXZKYqlQWHl2jCyeXmfFpXRFwY.jpg","original_title":"左耳","original_language":"zh"},{"id":224233,"adult":false,"title":"Mato Sem Cachorro","video":false,"overview":"The day a man almost runs-over a puppy, he meets the love of his life. The couple and their dog live the dream, until she wants out.","genre_ids":[35],"media_type":"movie","popularity":0.2457,"vote_count":60,"poster_path":"/n3smHWlrTpGSZKPj5BiAu11tZ1h.jpg","release_date":"2013-10-04","vote_average":5.3,"backdrop_path":"/3L4u4mkbDvflAhvgPmsYy4zdGz9.jpg","original_title":"Mato Sem Cachorro","original_language":"pt"},{"id":260339,"adult":false,"title":"Salting the Battlefield","video":false,"overview":"David Hare concludes his trilogy of films about MI5 renegade Johnny Worricker with another fugue on power, secrets and the British establishment. Johnny Worricker goes on the run with Margot Tyrell across Europe, and with the net closing in, the former MI5 man knows his only chance of resolving his problems is to return home and confront prime minister Alec Beasley.","genre_ids":[28,18,80],"media_type":"movie","popularity":0.6468,"vote_count":124,"poster_path":"/2K38pRnuSWEW4VnEDCk65GZin5h.jpg","release_date":"2014-03-27","vote_average":6.2,"backdrop_path":"/gUp091KVfT6rVXzcQ3QSSQ4eysf.jpg","original_title":"Salting the Battlefield","original_language":"en"},{"id":339562,"adult":false,"title":"To The Fore","video":false,"overview":"In the world of professional cycling, where teamwork demands individual sacrifice, the three leading sprinters of Team Radiant must confront their own egos and aspirations as the competition becomes increasingly tough. Arrogant cyclist Ming cares more about personal glory than the good of the team. His shy teammate Tian is unlucky in both love and sports. Finally, the third teammate, Korean Ji-won, is forced to confront the ethics of his manager.","genre_ids":[10749,28,18],"media_type":"movie","popularity":0.5108,"vote_count":43,"poster_path":"/MLHiA66O6IZHOz2z9sge6fSna3.jpg","release_date":"2015-08-06","vote_average":6.6,"backdrop_path":"/kgVqSueLqS8yYyzHyv9mPTV1Oj4.jpg","original_title":"破風","original_language":"zh"},{"id":243919,"adult":false,"title":"Personal Tailor","video":false,"overview":"A story centered on a company that grants wishes to people looking for a day away from their ordinary lives.","genre_ids":[35,18],"media_type":"movie","popularity":1.0372,"vote_count":50,"poster_path":"/ruaZ7fM9jddXdO3g5AQCt8aAxSg.jpg","release_date":"2013-12-19","vote_average":4.83,"backdrop_path":"/e9a1K28iz69acLMwXyJ5QO0VBk.jpg","original_title":"私人订制","original_language":"zh"},{"id":393668,"adult":false,"title":"Mickey Mouse Clubhouse: Mickey's Storybook Surprises","video":true,"overview":"The only thing more fun than listening to a story is actually being part of it. So just say the magic words Meeska, Mooska, Mickey Mouse and let the enchantment begin! When Donald Duck turns into a frog after drinking Professor Von Drake s new potion, only a kiss from Princess Daisy can change him back. But she s locked away in the Tallest Tower! Will you help Mickey choose the right Mouseketools to rescue Daisy and de-frog Donald? There s nonstop fun, excitement and new challenges around every corner as you help solve a Goldilocks-style mystery, wake Sleeping Minnie from a hundred-year nap, outsmart pesky Pete on a race through the woods, and more! Let your imagination soar as you join Mickey, Minnie, Donald, Goofy and the whole Clubhouse gang of classic characters as they set off on amazing, music-filled storybook adventures inspired by your favorite fairy tales.","genre_ids":[],"media_type":"movie","popularity":0.0218,"vote_count":2,"poster_path":"/2j1veNh6I4qkW2xAVfKtpzxCdY2.jpg","release_date":"2008-03-17","vote_average":8,"backdrop_path":null,"original_title":"Mickey Mouse Clubhouse: Mickey's Storybook Surprises","original_language":"en"},{"id":336398,"adult":false,"title":"6:30","video":false,"overview":"This film dwells with Alit's last day in San Francisco. After five years of study, he is finally returning home to Indonesia, to the arm of his beloved mother. At the same time, Alit realizes that this is his last chance to woo Tasya, his housemate, Bima, ex-girlfriend. However, destiny has something else in mind. On this day, starting from 6:30 a.m. until 6:30 a.m. the next morning, they (Alit, Tasya, and Bima) will find out the true meaning of friendship and the choices that they will have to make along the way.","genre_ids":[18],"media_type":"movie","popularity":0.077,"vote_count":1,"poster_path":"/arYEsSNXbJQGjwRF15kKS5cSfyF.jpg","release_date":"2006-10-09","vote_average":6,"backdrop_path":null,"original_title":"6:30","original_language":"en"},{"id":326203,"adult":false,"title":"Suamiku, Encik Perfect 10!","video":false,"overview":"Aleeya Azmeen willingly went to London with her boyfriend five years ago only to get dumped by him in the end. Things became worse when she was thrown out of London's college. Left with nothing, she had no choice but to return to Malaysia. But how will she explain what has happened to her family and friends? A fated meeting at Heaththrow airport with Zariel Daniel, who is willing to become Aleeya's fake husband for a week, leads to many dramatic and hilarious situations.","genre_ids":[18,10749],"media_type":"movie","popularity":0.1622,"vote_count":2,"poster_path":"/yp7Lm4MyJslJUYyy3EQf6lQPsMn.jpg","release_date":"2015-01-22","vote_average":5.5,"backdrop_path":"/srCn2vLYbo9YMpfxnuGaLEg6iV.jpg","original_title":"Suamiku, Encik Perfect 10!","original_language":"ms"},{"id":33319,"adult":false,"title":"The Burmese Harp","video":false,"overview":"In Burma during the closing days of WWII, a Japanese soldier separated from his unit disguises himself as a Buddhist monk to escape imprisonment as a POW.","genre_ids":[18,10752],"media_type":"movie","popularity":1.0535,"vote_count":167,"poster_path":"/zTKpylld64pjRYgRMK9GN6Jo2bA.jpg","release_date":"1956-01-21","vote_average":7.901,"backdrop_path":"/oUX2SiqoXorKUjd82Ax7mMjKI2R.jpg","original_title":"ビルマの竪琴","original_language":"ja"},{"id":455043,"adult":false,"title":"God of War","video":false,"overview":"During the 16th century, pirates rule the Chinese coastline, pillaging the small villages and terrorizing the citizens. When maverick leader Commander Yu enlists the help of a sharp young general, they devise a plan to defeat the pirates. A violent clash of wit and weapons will decide who will rule the land.","genre_ids":[28,36],"media_type":"movie","popularity":1.5428,"vote_count":99,"poster_path":"/4rWq9Vwb1gVhQIqkhUKE0hPVwnz.jpg","release_date":"2017-05-27","vote_average":6.359,"backdrop_path":"/XrpxJywc12kjV5PQPFgpmJTRpY.jpg","original_title":"荡寇风云","original_language":"zh"},{"id":219572,"adult":false,"title":"Police Story: Lockdown","video":false,"overview":"A man looking for the release of a long-time prisoner takes a police officer, his daughter, and a group of strangers hostage.","genre_ids":[28,80,18],"media_type":"movie","popularity":2.0824,"vote_count":403,"poster_path":"/iYukEgKMbbWr05s4nIvGqYGt84z.jpg","release_date":"2013-12-24","vote_average":6.2,"backdrop_path":"/7hJxwdm2OSE4Umsta7rYIxDaymU.jpg","original_title":"警察故事2013","original_language":"zh"},{"id":19267,"adult":false,"title":"The Big Brawl","video":false,"overview":"A young Asian American martial artist is forced to participate in a brutal formal street-fight competition.","genre_ids":[28,35],"media_type":"movie","popularity":1.5934,"vote_count":193,"poster_path":"/jFl2hmGWFX9mw0NvOOn08Zr8bn5.jpg","release_date":"1980-08-18","vote_average":5.902,"backdrop_path":"/qAXtKR6CaLrMSCYIDjRkmJFRIbj.jpg","original_title":"The Big Brawl","original_language":"en"},{"id":588108,"adult":false,"title":"Hansan: Rising Dragon","video":false,"overview":"In 1592, admiral Yi Sun-sin and his fleet face off against the might of the invading Japanese navy and its formidable warships. As the Korean forces fall into crisis, the admiral resorts to using his secret weapon, the dragon head ships known as geobukseon, in order to change the tide of this epic battle at sea.","genre_ids":[10752,28,18,36],"media_type":"movie","popularity":2.9086,"vote_count":84,"poster_path":"/vH76IrIrZLHmO0WOD4U7nxBHgkR.jpg","release_date":"2022-07-27","vote_average":6.548,"backdrop_path":"/gqqfN3XeWZcZZ2uQQEEFp3fHfSp.jpg","original_title":"한산: 용의 출현","original_language":"ko"},{"id":240483,"adult":false,"title":"Robot Overlords","video":false,"overview":"Earth has been conquered by robots from another galaxy and the human survivors must stay in their homes, or risk incineration.","genre_ids":[878,12,28],"media_type":"movie","popularity":0.9769,"vote_count":271,"poster_path":"/n9zyjUoTkcxWPC2osR2AdblPza1.jpg","release_date":"2015-01-29","vote_average":4.843,"backdrop_path":"/t0eapHW6Be3oH5uXVVDMfJ5aeqf.jpg","original_title":"Robot Overlords","original_language":"en"},{"id":30125,"adult":false,"title":"Valentin","video":false,"overview":"Valentin, an 8-year-old boy living with his grandmother in late-1960s Buenos Aires, is surrounded by problems in his family he finds only himself capable of solving.","genre_ids":[10749,18,35],"media_type":"movie","popularity":1.4131,"vote_count":113,"poster_path":"/qBLSZ8lXDBzXrkxKyGlCZ42WOU6.jpg","release_date":"2002-09-29","vote_average":7.372,"backdrop_path":"/9bukKLKSjANhL1mHkHbmPisWKfA.jpg","original_title":"Valentín","original_language":"es"},{"id":300803,"adult":false,"title":"Dragonheart 3: The Sorcerer's Curse","video":false,"overview":"When aspiring knight Gareth goes in search of a fallen comet rumored to contain gold, he is shocked to instead find the dragon Drago. After Drago saves Gareth's life the two become intricately bonded, and must work together to defeat an evil sorcerer and stop his reign of terror. Along the way, Gareth learns the true meaning of being a knight in this fantasy action-adventure for the ages.","genre_ids":[14],"media_type":"movie","popularity":2.3507,"vote_count":265,"poster_path":"/qPiyMWZHlRGgQ54roaraS3iJR12.jpg","release_date":"2015-02-24","vote_average":5.4,"backdrop_path":"/rbA4CkeT2ag0RksiIbHSlQnqZRv.jpg","original_title":"Dragonheart 3: The Sorcerer's Curse","original_language":"en"},{"id":9959,"adult":false,"title":"Freedomland","video":false,"overview":"A black police detective must solve a strange case of a kidnapped boy and deal with a big racial protest.","genre_ids":[53,80,9648],"media_type":"movie","popularity":3.8495,"vote_count":355,"poster_path":"/fM9MYcI7BHJ2YqEtcr8JKPE8nDB.jpg","release_date":"2006-02-17","vote_average":5.234,"backdrop_path":"/asi4QVM9QSdSAZUo5mpMZVxNaxl.jpg","original_title":"Freedomland","original_language":"en"},{"id":48844,"adult":false,"title":"The Search for Santa Paws","video":false,"overview":"When Santa and his new best friend, Paws, discover that the boys and girls of the world have lost the spirit of the season, they take a trip to New York City. But after Santa loses his memory, it's up to Paws, a faithful orphan named Quinn, her new friend Will, and a wonderful group of magical talking dogs to save St. Nick and show the world what Christmas is really all about.","genre_ids":[10751,12],"media_type":"movie","popularity":1.0628,"vote_count":226,"poster_path":"/z4tJ1AhJKWUUWoDsXvnGS6fQdiR.jpg","release_date":"2010-10-12","vote_average":6.3,"backdrop_path":"/A7JLOMnim2y26Vt06vwvz7HmORM.jpg","original_title":"The Search for Santa Paws","original_language":"en"},{"id":250066,"adult":false,"title":"American Heist","video":false,"overview":"Two brothers, both with troubled paths, find themselves in the middle of one last bank job.","genre_ids":[28],"media_type":"movie","popularity":0.9378,"vote_count":368,"poster_path":"/526uxanwv4mMK0YTxjVrsmMXXo2.jpg","release_date":"2014-09-11","vote_average":4.776,"backdrop_path":"/vIrQp74LyBd7ktEIgMdd0Nfyb3U.jpg","original_title":"American Heist","original_language":"en"},{"id":38140,"adult":false,"title":"To Rob a Thief","video":false,"overview":"Emilio, a Colombian con man, arrives in LA with two weeks to complete his plan to rob a former colleague, Claudio Silvestrini, who's made a fortune using infomercials to peddle snake oil to Latin immigrants. Emilio's friend Alejandro, who sells pirated DVDs, has assembled a team of amateurs, who, as Alejandro says, will go unnoticed because they're immigrants. The team must gain entry to Silvestrini's well-guarded mansion, steal two keys to access a vault, and then get the money off the property. A father and his tomboy daughter, a nervous Cuban actor, a techie, and a muscle man make up the team, plus Alejandro has been courting Silvestrini's nanny. Will they be enough?","genre_ids":[28,12,35],"media_type":"movie","popularity":0.4157,"vote_count":102,"poster_path":"/px4hQ1HvJBDSzRuY3zNIkrFTlrd.jpg","release_date":"2007-08-31","vote_average":7.5,"backdrop_path":"/wCkamXqCv6GuJRAl3yHEH06nala.jpg","original_title":"Ladrón que roba a ladrón","original_language":"es"}],"similar_content":[],"external_ids":{"imdb_id":"tt3672840","twitter_id":null,"facebook_id":null,"wikidata_id":"Q17002139","instagram_id":null,"metacritic_id":"movie/dragon-blade","mydramalist_id":"275134","rotten_tomatoes_id":"m/dragon_blade"},"social_ids":{"twitter":null,"facebook":null,"instagram":null},"gdvg_id":102452,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":[{"iso_3166_1":"AU","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2015-12-26T00:00:00.000Z","certification":"R18+"}]},{"iso_3166_1":"CN","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2015-02-19T00:00:00.000Z","certification":""}]},{"iso_3166_1":"CZ","release_dates":[{"note":"","type":5,"iso_639_1":"cs","descriptors":[],"release_date":"2016-04-13T00:00:00.000Z","certification":"15+"}]},{"iso_3166_1":"DE","release_dates":[{"note":"","type":3,"iso_639_1":"de","descriptors":[],"release_date":"2015-12-04T00:00:00.000Z","certification":"16"}]},{"iso_3166_1":"DK","release_dates":[{"note":"","type":5,"iso_639_1":"","descriptors":[],"release_date":"2015-12-22T00:00:00.000Z","certification":"15"}]},{"iso_3166_1":"FR","release_dates":[{"note":"","type":3,"iso_639_1":"","descriptors":[],"release_date":"2015-12-04T00:00:00.000Z","certification":"16"},{"note":"Ciné+ Frisson","type":6,"iso_639_1":"fr","descriptors":[],"release_date":"20