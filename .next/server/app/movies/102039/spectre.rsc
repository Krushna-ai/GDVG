34},{"width":286,"height":100,"file_path":"/OTSWlEelqj4cyJ8QWzb2ZzaJ1Z.svg","iso_639_1":"en","vote_average":3.334}],"posters":[{"width":1400,"height":2100,"file_path":"/8KcTySYevFZNinrFadCZoKpF9jN.jpg","iso_639_1":"zh","vote_average":10},{"width":640,"height":914,"file_path":"/6YSbetJjAYdH3EfYbI0w3dOjBKj.jpg","iso_639_1":"zh","vote_average":8.362},{"width":2000,"height":3000,"file_path":"/zj8ongFhtWNsVlfjOGo8pSr7PQg.jpg","iso_639_1":"en","vote_average":6.5},{"width":2000,"height":3000,"file_path":"/xfrnnrKuoS1v6x2u2Y50RU50qry.jpg","iso_639_1":"en","vote_average":5.682},{"width":2000,"height":3000,"file_path":"/672kUEMtTHcaVYSVY4eiHEliHFa.jpg","iso_639_1":"en","vote_average":5.59},{"width":2000,"height":3000,"file_path":"/AwCpcShhgRqoVPWhOzs4JiI4dlK.jpg","iso_639_1":"fr","vote_average":5.25},{"width":1000,"height":1500,"file_path":"/aD8fQF2WFAvMMxmMHHj2RXz2hwP.jpg","iso_639_1":"en","vote_average":5.25},{"width":950,"height":1426,"file_path":"/4Fsjzy1D5QPO4w7Sv5rHzsXNvJu.jpg","iso_639_1":"en","vote_average":5.25},{"width":500,"height":750,"file_path":"/qUz6QPWfcPscPgAdvrto3cvGV9I.jpg","iso_639_1":"it","vote_average":5.238},{"width":912,"height":1368,"file_path":"/zmSO6LBHJdVAnlgRHlBmIyVfm6L.jpg","iso_639_1":"de","vote_average":5.238},{"width":933,"height":1400,"file_path":"/1UYDfTmcVd2fA0wLeW1huqNB5As.jpg","iso_639_1":"de","vote_average":5.238},{"width":1000,"height":1500,"file_path":"/1Yc6p9PpwPUizAodS0zsWcRkx6r.jpg","iso_639_1":"en","vote_average":4.458},{"width":2000,"height":3000,"file_path":"/kbLGA8bLxJIbKuiEM5v1WidesMH.jpg","iso_639_1":"en","vote_average":4.3},{"width":2000,"height":3000,"file_path":"/A24yPLfm6TOihPTPbWws0tOjJFH.jpg","iso_639_1":"zh","vote_average":3.954},{"width":1524,"height":2220,"file_path":"/6a0US3rHr2rQC5zwlsxjOpLDKQ0.jpg","iso_639_1":"bg","vote_average":3.334}],"backdrops":[{"width":1920,"height":1080,"file_path":"/8lBViysvNJBPkl6zG1LVAaW3qhj.jpg","iso_639_1":null,"vote_average":5.786},{"width":1920,"height":1080,"file_path":"/n1VZsWIi4missUgUXRfCG9HXFKe.jpg","iso_639_1":null,"vote_average":4.722},{"width":3200,"height":1800,"file_path":"/weILk5IKXsknNAFeIzWt5NSJTbG.jpg","iso_639_1":null,"vote_average":3.334},{"width":3840,"height":2160,"file_path":"/8VLQ8HX8YXg3SoGvjC4oHZAy0mi.jpg","iso_639_1":"en","vote_average":2.278},{"width":3840,"height":2160,"file_path":"/aP6Hzwi2hqPGvX9sF4GliCy55yA.jpg","iso_639_1":null,"vote_average":2.278},{"width":1920,"height":1080,"file_path":"/tXhi8m3SsWc5R93n5S4POSNQGDq.jpg","iso_639_1":"en","vote_average":2.066},{"width":1920,"height":1080,"file_path":"/cCKU3EuiSKt6xsOI6gg5kiFgZYm.jpg","iso_639_1":null,"vote_average":2.066},{"width":3840,"height":2160,"file_path":"/11OF1why8srqNHPZFlKogON94f4.jpg","iso_639_1":"en","vote_average":1.75},{"width":3840,"height":2160,"file_path":"/daZ7Z8IvbbeHQVQNK8RXr32OHtk.jpg","iso_639_1":null,"vote_average":1.75},{"width":1920,"height":1080,"file_path":"/tcf8WL3Lf1nWkOOT7SdhbS2kU6E.jpg","iso_639_1":null,"vote_average":1.714},{"width":3840,"height":2160,"file_path":"/8EVm1SXjG82VJSs0IMbwdXisbSY.jpg","iso_639_1":null,"vote_average":1.31},{"width":1280,"height":720,"file_path":"/8gaS9YFtarOdDrOSdZkNvgBplCg.jpg","iso_639_1":null,"vote_average":1.222},{"width":1920,"height":1080,"file_path":"/913Bfb2YHWGDi9Bi6EwGp8MAGzQ.jpg","iso_639_1":"en","vote_average":1.222},{"width":1920,"height":1080,"file_path":"/2MHguLY6RoCduvRADUBJzQWPhDO.jpg","iso_639_1":null,"vote_average":1.066},{"width":1920,"height":1080,"file_path":"/ikVcVRjzBJHzvjhkwdiFMLVGYM1.jpg","iso_639_1":null,"vote_average":0.958}]},"enriched_at":"2026-02-25T13:53:15.093+00:00","enrichment_cycle":1,"translations":[{"data":{"title":"","runtime":148,"tagline":"","homepage":"https://mgm.com/movies/spectre","overview":"A cryptic message from Bond’s past sends him on a trail to uncover a sinister organization. While M battles political forces to keep the secret service alive, Bond peels back the layers of deceit to reveal the terrible truth behind SPECTRE."},"name":"English","iso_639_1":"en","iso_3166_1":"US","english_name":"English"},{"data":{"title":"","runtime":148,"tagline":"Cette fois c’est personnel !","homepage":"","overview":"Un message cryptique surgi du passé entraîne James Bond dans une mission très personnelle à Mexico puis à Rome, où il rencontre Lucia Sciarra, la très belle veuve d’un célèbre criminel. Bond réussit à infiltrer une réunion secrète révélant une redoutable organisation baptisée Spectre. Pendant ce temps, à Londres, Max Denbigh, le nouveau directeur du Centre pour la Sécurité Nationale, remet en cause les actions de Bond et l’existence même du MI6, dirigé par M. Bond persuade Moneypenny et Q de l’aider secrètement à localiser Madeleine Swann, la fille de son vieil ennemi, Mr White, qui pourrait détenir le moyen de détruire Spectre. Fille de tueur, Madeleine comprend Bond mieux que personne… En s’approchant du cœur de Spectre, Bond va découvrir qu’il existe peut-être un terrible lien entre lui et le mystérieux ennemi qu’il traque…"},"name":"Français","iso_639_1":"fr","iso_3166_1":"FR","english_name":"French"},{"data":{"title":"James Bond 007 - Spectre","runtime":150,"tagline":"","homepage":"","overview":"James Bond erhält eine kryptische Nachricht aus seiner Vergangenheit, die ihn auf die Spur einer finsteren Organisation bringt. Bond muss immer mehr entdecken, dass es viele Täuschungen und Lügen gibt, die er entschlüsseln muss. Während sein Boss M mit anderen Problemen kämpft, mit politischen Kräften konfrontiert ist, die den ganzen Geheimdienst gefährden, erkennt Bond erst nach und nach die schreckliche Wahrheit hinter Spectre."},"name":"Deutsch","iso_639_1":"de","iso_3166_1":"DE","english_name":"German"},{"data":{"title":"","runtime":148,"tagline":"Un plan del que nadie escapa.","homepage":"","overview":"Un críptico mensaje del pasado envía a James Bond a una misión secreta a México D.F. y luego a Roma, donde conoce a Lucía Sciarra, la hermosa viuda de un infame criminal. Bond se infiltra en una reunión secreta y descubre la existencia de una siniestra organización conocida como SPECTRE. Mientras tanto, en Londres, el nuevo director del Centro para la Seguridad Nacional cuestiona las acciones de Bond y pone en duda la importancia del MI6, encabezado por M. De modo encubierto Bond recluta a Moneypenny y Q para que le ayuden a buscar a Madeleine Swann, la hija de su antiguo archienemigo, el Sr. White, que quizá tenga la clave para desentrañar el misterio de SPECTRE. A medida que Bond avanza en su misión, descubre una estremecedora conexión entre él mismo y el enemigo que busca."},"name":"Español","iso_639_1":"es","iso_3166_1":"ES","english_name":"Spanish"},{"data":{"title":"Spectre","runtime":148,"tagline":"Agente 007 - Spectre","homepage":"","overview":"La morte sfila per le strade di Città del Messico e dietro la maschera di un teschio. In missione per conto di M, la defunta M che gli ha lasciato un video e un incarico spinoso da risolvere, James Bond sventa un attentato e uccide Marco Sciarra, terrorista legato a SPECTRE, una misteriosa organizzazione criminale e tentacolare. Il suo colpo di testa gli aliena Gareth Mallory, il nuovo M alle prese con pressioni politiche e Max Denbigh, membro del governo britannico che non vede l'ora di mandare in pensione i vecchi agenti dell'MI6 e di controllare con tanti occhi le agenzie del mondo. Congedato a tempo (in)determinato, Bond prosegue la sua indagine contro il parere di Mallory e con l'aiuto dei fedeli Q e Moneypenny."},"name":"Italiano","iso_639_1":"it","iso_3166_1":"IT","english_name":"Italian"},{"data":{"title":"007 Spectre","runtime":148,"tagline":"Ninguém escapa.","homepage":"","overview":"Uma enigmática mensagem do passado de James Bond desencadeia uma investigação sobre uma misteriosa organização criminosa, chamada Spectre. Enquanto M enfrenta duras batalhas políticas para manter o serviço de inteligência em pleno funcionamento, Bond procura acabar com a ameaça que é Spectre."},"name":"Português","iso_639_1":"pt","iso_3166_1":"PT","english_name":"Portuguese"},{"data":{"title":"","runtime":148,"tagline":"","homepage":"https://www.mgm.com/movies/spectre","overview":"Een cryptische boodschap uit James Bond's verleden brengt hem op het pad van een sinistere organisatie die hij moet zien bloot te leggen. Terwijl M een politieke strijd voert over het voortbestaan van zijn inlichtingendienst, speurt 007 tussen al het bedrog door naar de verschrikkelijke waarheid achter 'SPECTRE'."},"name":"Nederlands","iso_639_1":"nl","iso_3166_1":"NL","english_name":"Dutch"},{"data":{"title":"Τζέιμς Μποντ, Πράκτωρ 007: Spectre","runtime":148,"tagline":"","homepage":"http://www.007.com/","overview":"Ένα κρυπτογραφημένο μήνυμα από το παρελθόν οδηγεί τον Τζέιμς Μποντ σε μια εγκληματική αποστολή στην Πόλη του Μεξικού, και τελικά στη Ρώμη όπου συναντά την Λουτσία Σκιάρα, την όμορφη και απαγορευμένη χήρα ενός κακόφημου εγκληματία. Ο Μποντ διεισδύει σε μια μυστική συνάντηση και ανακαλύπτει την ύπαρξη μιας εγκληματικής οργάνωσης γνωστή ως SPECTRE. Εν τω μεταξύ, πίσω στο Λονδίνο, o Μαξ Ντένμπιχ, ο νέος επικεφαλής του Κέντρου για την Εθνική Ασφάλεια, αμφισβητεί τις ενέργειες του Μποντ και τις ικανότητες της MI6, με επικεφαλής τον Μ. Ο Μποντ στρατολογεί συγκαλυμμένα την Μανιπένη και τον Q για να τον βοηθήσουν να αναζητήσει την Μάντελειν Σγουάν, την κόρη του παλιού εχθρού του K. Γουάιτ, ο οποίος μπορεί να κρατά το κλειδί για να ξετυλίξει τον ιστό της SPECTRE. Ως κόρη δολοφόνου η Μάντελειν καταλαβαίνει τον Μποντ με έναν τρόπο που οι άλλοι δεν μπορούν. Όσο ο Bond επιχειρεί στην καρδιά της Spectre, μαθαίνει για μια ανατριχιαστική σύνδεση μεταξύ του ιδίου και του εχθρού που αναζητά..."},"name":"ελληνικά","iso_639_1":"el","iso_3166_1":"GR","english_name":"Greek"},{"data":{"title":"007：幽灵党","runtime":0,"tagline":"起死回生","homepage":"","overview":"一个来自过去的加密信息让詹姆斯·邦德开始了一个神秘任务，从墨西哥城到最终的罗马，在那儿他邂逅了美艳的露琪亚·斯琪拉（莫妮卡·贝鲁奇 Monica Bellucci 饰），而她则是一名臭名昭著的意大利黑手党寡妇。邦德潜入到了一个密会中，揭开了一个名叫“幽灵党”的邪恶组织背后的秘密。然而，远在伦敦的国家安全中心的新任负责人马克思·登彼（安德鲁·斯科特 Andrew Scott 饰）怀疑邦德这次行动的目的，并挑战M（拉尔夫·费恩斯 Ralph Fiennes 饰）掌权的军情六处的地位。邦德暗中召集了钱班霓（奈奥米·哈里斯 Naomi Harris 饰）和Q博士（本·威肖 Ben Whishaw 饰），协助他寻找他宿敌的女儿——玛德琳·斯旺（蕾雅·赛杜 Léa Seydoux 饰）的下落，玛德琳·斯旺手里握有解开幽灵党秘密的线索。作为一名杀手的女儿，斯旺比绝大多数人更了解邦德。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"CN","english_name":"Mandarin"},{"data":{"title":"007: Спектр","runtime":148,"tagline":"«Мёртвые живы»","homepage":"","overview":"Таинственное послание из прошлого Бонда выведет его к зловещей террористической организации «Спектр». Пока М участвует в политических баталиях, отстаивая интересы MI6, Бонд приоткрывает завесу лжи, чтобы раскрыть ужасную правду, скрываемую «Спектром»."},"name":"Pусский","iso_639_1":"ru","iso_3166_1":"RU","english_name":"Russian"},{"data":{"title":"","runtime":148,"tagline":"Plán, kterému nikdo neunikne.","homepage":"","overview":"Po útoku Raoula Silvy na MI6 uvede mystická zpráva do pohybu události, které přinutí Jamese Bonda opět čelit tváří v tvář zlověstné organizaci známé jako Spectre. Zatímco Gareth Mallory, nově jmenovaný M, pokračuje v boji proti politickým tlakům, které ohrožují budoucnost MI6, Bond zjistí, že jediný způsob, jak odhalit síť spiknutí, je ochránit nevinnou dceru mocného nepřítele. Během sledování horké stopy z Mexika do Itálie, Rakouska a Maroka je nucen pracovat mimo své kompetence a je vtažen do konfrontace s nepřítelem ze své minulosti. Postupně tak rozplétá složitou pavučinu lží, aby nakonec odhalil děsivou pravdu o Spectre."},"name":"Český","iso_639_1":"cs","iso_3166_1":"CZ","english_name":"Czech"},{"data":{"title":"Spectre – A Fantom visszatér","runtime":148,"tagline":"Az engedély, hogy öljön, arra is engedély, hogy ne öljön","homepage":"","overview":"Egy múltból származó titkosított üzenet Bond-ot egy ördögi szervezet nyomára vezeti. Mialatt M politikai csatákra kényszerül, hogy életben tartsa a titkosszolgálatot, Bond egymás után hántja le a megtévesztő rétegeket egy SPECTRE nevű titkos hálózatról, amely mögött egy szörnyű igazság lakozik."},"name":"Magyar","iso_639_1":"hu","iso_3166_1":"HU","english_name":"Hungarian"},{"data":{"title":"007 Spectre","runtime":148,"tagline":"Tällä kertaa se on henkilökohtaista.","homepage":"http://www.007.com/spectre/?lang=fi","overview":"Arvoituksellinen viesti menneisyydestä saa James Bondin lähtemään yksin Mexico Cityyn ja sieltä Roomaan, missä hän tapaa pahamaineisen rikollisen kauniin ja kielletyn lesken, Lucia Sciarran. Bond soluttautuu salaiseen kokoukseen ja paljastaa SPECTRE:nä tunnetun  uhkaavan järjestön olemassaolon."},"name":"suomi","iso_639_1":"fi","iso_3166_1":"FI","english_name":"Finnish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Ett kryptiskt meddelande från Bonds förflutna skickar iväg honom på ett uppdrag för att avslöja en olycksbådande organisation. Medan M bekämpar politiska krafter för att hålla underrättelsetjänsten vid liv skalar Bond bort lagren av svek för att avslöja den fruktansvärda sanningen bakom SPECTRE."},"name":"svenska","iso_639_1":"sv","iso_3166_1":"SE","english_name":"Swedish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Spectre merupakan film ke-24 dari seri film James Bond yang diproduksi oleh Eon Productions. Film ini disutradarai oleh Sam Mendes dan diproduseri oleh Michael G. Wilson dan Barbara Broccoli."},"name":"Bahasa indonesia","iso_639_1":"id","iso_3166_1":"ID","english_name":"Indonesian"},{"data":{"title":"ספקטר","runtime":0,"tagline":"","homepage":"","overview":"פרק נוסף במעלליו של 007, הסוכן הסודי המפורסם ביותר בממלכה הבריטית, שבעקבות מודעה מסתורית יוצא למקסיקו לחשוף ארגון מרושע בשם ספקטר. בעוד M נאבק במאבקים פוליטיים כדי לשמור על הארגון הסודי, בונד מוצא עצמו מקלף את שכבות ההונאה כדי לחשוף את האמת האיומה שמסתתרת מתחת לפני השטח אודות ספקטר. לחובבי האקשן, הקונספירציות, ונעימות-נושא."},"name":"עִבְרִית","iso_639_1":"he","iso_3166_1":"IL","english_name":"Hebrew"},{"data":{"title":"","runtime":148,"tagline":"Kimsenin kaçamayacağı bir plan.","homepage":"","overview":"Geçmişten gelen şifreli bir mesaj James Bond’u Mexico City’ye ve sonunda, kötü şöhretli bir suçlunun, yasaklı dulu, güzel Lucia Sciarra ile tanışacağı Roma’ya sürükler. Bond, sızdığı gizli bir toplantı sonucunda Spectre olarak bilinen tekinsiz bir örgütün varlığını ortaya çıkartır. Bond, Spectre’nin ağını ortaya dökebilecek ipuçlarına ulaşmak için eski düşmanı Mr White’ın kızı, Madeleine Swann’ı aramaktadır. Moneypenny ve Q’dan kıza ulaşmak için gizlice kendisine yardım etmelerini ister. Bond, Spectre'ye yaklaştıkça ulaşmaya çalıştığı Christoph Waltz tarafından canlandırılan düşmanı ile kendisi arasında, kan dondurucu bir bağ olduğunu öğrenecektir."},"name":"Türkçe","iso_639_1":"tr","iso_3166_1":"TR","english_name":"Turkish"},{"data":{"title":"007 스펙터","runtime":148,"tagline":"최악의 적 스펙터와 연관된 제임스 본드의 과거, 그리고 그 속에 숨겨진 거대한 비밀","homepage":"","overview":"멕시코에서 일어난 폭발 테러 이후 MI6는 영국 정부에 의해 해체 위기에 놓인다. 자신의 과거와 연관된 암호를 추적하던 제임스 본드는 사상 최악의 조직 스펙터와 자신이 연관되어 있다는 사실을 알게 되고, 궁지에 몰린 MI6조차 그를 포기하면서 절체절명의 위기에 직면하는데..."},"name":"한국어/조선말","iso_639_1":"ko","iso_3166_1":"KR","english_name":"Korean"},{"data":{"title":"Agent 007 - Spectre","runtime":148,"tagline":"","homepage":"","overview":"En kryptisk besked sender den britiske agent James Bond på en hemmelig mission til Mexico City og videre til Rom, hvor han møder den smukke og dragende enke Lucia Sciarra. Her infiltrerer Bond et hemmeligt møde, der bringer ham på sporet af den lyssky organisation Spectre. Samtidig kæmper hans chef M mod politiske kræfter i London, der er kritiske over for Bond – og som vil nedlægge MI6. For at komme videre med sagen opsporer Bond sin gamle ærkefjende Mr. White's datter, der kan være nøglen til at afsløre Spectre. Efterhånden som Bond opklarer mere og mere af den grusomme sandhed, opdager han, at den mudrede sag trækker tråde til hans egen fortid."},"name":"Dansk","iso_639_1":"da","iso_3166_1":"DK","english_name":"Danish"},{"data":{"title":"","runtime":148,"tagline":"Plan przed którym nikt nie ucieknie.","homepage":"","overview":"Za sprawą zaszyfrowanej wiadomości z przeszłości James Bond wyrusza z samotną misją do Mexico City, a następnie do Rzymu, gdzie poznaje Lucię Sciarrę, piękną wdowę po słynnym przestępcy. Bond przenika na tajne spotkanie i odkrywa istnienie potężnej i złowrogiej organizacji Spectre. Tymczasem w Londynie, Max Denbigh, nowy szef Centrum Bezpieczeństwa Narodowego, kwestionuje działania Bonda i zasadność istnienia kierowanego przez M MI6. Bond potajemnie werbuje Moneypenny i Q, by pomogli mu w odszukaniu niejakiej Madeleine Swann, córki swego starego wroga, znanego, jako Mr. White, która może posiadać wskazówki, jak zniszczyć Spectre. Gdy Bond zbliża się do samego serca organizacji, odkrywa szokujący, przerażający związek między sobą, a ściganym wrogiem, w którego brawurowo wcielił się Christoph Waltz."},"name":"Polski","iso_639_1":"pl","iso_3166_1":"PL","english_name":"Polish"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"http://www.007.com/","overview":"James Bond dostane záhadný odkaz z minulosti, ktorý ho privedie na stopu neslávne známej zločineckej organizácii. Postupne rozplieta zložitú pavučinu klamstiev, aby napokon odhalil desivú pravdu o SPECTRE."},"name":"Slovenčina","iso_639_1":"sk","iso_3166_1":"SK","english_name":"Slovak"},{"data":{"title":"007: Спектр","runtime":0,"tagline":"План від якого ніхто не втече","homepage":"","overview":"Джеймс Бонд вирушає у місію в Мехіко, а потім у Рим, де вдається проникнути на таємну зустріч і виявити, що існує глобальна організація \"Спектр\", яка займається темними справами. В цей же час у Лондоні новий директор Центру національної безпеки намагається зрозуміти дії Бонда і ставить під сумнів актуальність існування МІ6. Шпигуну Її Величності вдається заручитися підтримкою Меніпенні і К'ю, щоб разом знайти дочку його старого ворога. Саме вона може стати ключем до розгадки \"Спектру\"."},"name":"Український","iso_639_1":"uk","iso_3166_1":"UA","english_name":"Ukrainian"},{"data":{"title":"الشبح","runtime":0,"tagline":"","homepage":"","overview":"في إطار مشوق ومثير، يستقبل (جيمس بوند) رسالة غامضة ومشفرة لها علاقة بماضيه، والتي يذهب على إثرها ليحاول اكتشاف أسرار منظمة شريرة تتوارى عن الأنظار، بينما يحارب رئيسه (إم) القوى السياسية ليُبقِي على وجود (مكتب الخدمة السرية)، خلال مهمته يواجه (بوند) كل الطبقات الخادعة الواحدة تلو الأخرى ليكشف الحقيقة المروعة عن (الشبح)."},"name":"العربية","iso_639_1":"ar","iso_3166_1":"SA","english_name":"Arabic"},{"data":{"title":"اسپکتر","runtime":0,"tagline":"","homepage":"","overview":"یک پیغام رمزنگاری شده برای مامور ۰۰۷ ارسال می شود که مربوط به گذشته این مامور می باشد و همچنین حکایت از وجود و سازمانی مخوف دارد. باند تصمیم می گیرد تا هویت سازمان ملقب به اسپکتر را برملا کند اما …"},"name":"فارسی","iso_639_1":"fa","iso_3166_1":"IR","english_name":"Persian"},{"data":{"title":"Спектра","runtime":0,"tagline":"","homepage":"","overview":"Тајанствена порука из његове прошлости послаће тајног агента 007 у мисију у Мексико, а потом и у Рим где ће упознати Луцију Скиару, прелепу и мистериозну удовицу познатог криминалца. Бонд ће се инфилтрирати на тајни састанак и открити постојање злокобне организације познате под именом Спектра. У међувремену у Лондону, Макс Денбих – нови директор сектора за националну безбедност, истражује Бондове раније задатке и тражи разлоге због чега је МИ6, ког води М уопште потребан. Агент 007 тајно затражи помоћ, како би пронашао Медлин Сван, ћерку његовог непријатеља код којег се налази траг који води до откривања СПЕКТРЕ. Као ћерка убице, Медлин разуме Бонда више од било кога другог. Како се он приближава срцу Спектре ускоро сазнаје за застрашујућу повезаност између себе и непријатеља ког све време покушава да пронађе."},"name":"Srpski","iso_639_1":"sr","iso_3166_1":"RS","english_name":"Serbian"},{"data":{"title":"007 スペクター","runtime":148,"tagline":"絶対最強の宿敵“スペクター”。ジェームズ・ボンドが最後の死闘に挑む──","homepage":"","overview":"ボンドは、少年時代の思い出が詰まった生家“スカイフォール”で焼け残った写真を受け取る。彼はMが止めるのも無視して、その写真の謎を解き明かすため単身メキシコとローマを訪れる。死んだ犯罪者の妻ルチアと滞在先で巡り合ったボンドは、悪の組織スペクターの存在を確信する。"},"name":"日本語","iso_639_1":"ja","iso_3166_1":"JP","english_name":"Japanese"},{"data":{"title":"เจมส์ บอนด์ 007 ภาค 24: องค์กรลับดับพยัคฆ์ร้าย","runtime":0,"tagline":"007 : องค์กรลับดับพยัคฆ์ร้าย","homepage":"http://www.007.com/spectre","overview":"เรื่องราวว่าด้วยการได้รับข้อความเข้ารหัสปริศนาจากเมื่อในอดีต ชักนำให้บอนด์ต้องออกตามล่าหาความจริง จนเข้าไปพัวพันกับสเปกเตอร์ (SPECTRE) องค์กรลับที่เชื่อว่าอันตรายที่สุดในโลก ขณะที่ M ก็ต้องต่อสู้กับอำนาจและปัญหาทางการเมือง เพื่อให้ MI6 องค์กรสายลับของบอนด์อยู่รอดต่อไป"},"name":"ภาษาไทย","iso_639_1":"th","iso_3166_1":"TH","english_name":"Thai"},{"data":{"title":"007: Спектър","runtime":0,"tagline":"План, от който никой няма да се измъкне","homepage":"","overview":"Кодирано съобщение от неизвестен източник води Джеймс Бонд към всемогъщата престъпна организация „СПЕКТЪР“. „М“ се бори срещу политическия натиск, заплашващ бъдещето на МИ-6. Сред всички лъжи Бонд трябва да научи ужасната истина, за да разкрие „СПЕКТЪР“ и да защити всичко, което е скъпо на агент 007."},"name":"български език","iso_639_1":"bg","iso_3166_1":"BG","english_name":"Bulgarian"},{"data":{"title":"","runtime":0,"tagline":"Mrtvi su živi.","homepage":"","overview":"Tajanstvena poruka iz njegove prošlosti poslat će tajnog agenta Jamesa Bonda u avanturu tijekom koje će pokušati razotkriti zlokobnu organizaciju. Dok se istovremeno M bori s političkim snagama kako bi na životu održao tajnu službu, Bond se polako probija kroz mnogobrojne slojeve obmane kako bi otkrio zastrašujuću istinu koja se krije iza imena „Spectre“!"},"name":"Hrvatski","iso_639_1":"hr","iso_3166_1":"HR","english_name":"Croatian"},{"data":{"title":"","runtime":0,"tagline":"Prevod AlejaFilmova, AlejaSerija, Webmasterdub","homepage":"","overview":"Tajanstvena poruka iz njegove prošlosti poslat će tajnog agenta Jamesa Bonda u avanturu tijekom koje će pokušati razotkriti zlokobnu organizaciju. Dok se istovremeno M bori s političkim snagama kako bi na životu održao tajnu službu, Bond se polako probija kroz mnogobrojne slojeve obmane kako bi otkrio zastrašujuću istinu koja se krije iza imena Spectre!"},"name":"Bosanski","iso_639_1":"bs","iso_3166_1":"BS","english_name":"Bosnian"},{"data":{"title":"Spectre","runtime":148,"tagline":"Un plan de care nimeni nu scapă.","homepage":"","overview":"Un mesaj criptic din trecut îl trimite pe James Bond într-o misiune pe cont propriu, să se infiltreze într-o organizație sinistră numită SPECTRE. Între timp, înapoi în Londra, Max Denbigh, noul director al Centrului pentru Siguranța Națională, pune la îndoială acțiunile lui Bond și are dubii în legătură cu importanța organizației MI6, condusă de M. Pe măsură ce Bond se aventurează spre centrul lui SPECTRE, agentul află de legătura înfricoșătoare dintre el și dușmanul pe care-l caută."},"name":"Română","iso_639_1":"ro","iso_3166_1":"RO","english_name":"Romanian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"Í Spectre heldur atburðarásin áfram þar sem frá var horfið í Skyfall. Hinn nýi M, sem Ralph Fiennes leikur, glímir við að halda M16 á floti eftir árásir Raouls Silva í Skyfall, sem opinberuðu veikleika stofnunarinnar og kostuðu hana traust stjórnvalda. Á sama tíma berast James Bond dularfull skilaboð sem koma honum á spor glæpasamtakanna Spectre þar sem gamall óvinur, Franz Oberhauser, ræður ríkjum og á harma að hefna ..."},"name":"Íslenska","iso_639_1":"is","iso_3166_1":"IS","english_name":"Icelandic"},{"data":{"title":"","runtime":148,"tagline":"","homepage":"","overview":"En kryptisk melding fra Bond's fortid sender ham på et oppdrag som tar han til Mexico City og til slutt Roma hvor han infiltrerer et hemmelig møte for å avdekke den lyssky organisasjon kjent som SPECTRE. Mens M sloss mot politiske krefter for å holde secret service i live beveger Bond seg nærmere sannheten om SPECTRE. Og når han nærmer seg hjertet av organisasjonen får han kjennskap til et skremmende bånd mellom seg selv og fienden han jakter på."},"name":"Norsk","iso_639_1":"no","iso_3166_1":"NO","english_name":"Norwegian"},{"data":{"title":"007 Contra Spectre","runtime":148,"tagline":"Bem-vindo, James. Porque demorou tanto?","homepage":"","overview":"James Bond chega à Cidade do México e está pronto para eliminar Marco Sciarra sem que o chef M saiba da missão. O caso leva à suspensão temporária do agente, que passa a ser constantemente vigiado pelo governo britânico graças a uma tecnologia implantada em seu corpo por Q. Na tentativa de despistar os inimigos e até mesmo alguns de seus parceiros de trabalho, ele se responsabiliza por ajudar a filha de um desafeto. Toda a situação o leva ao centro de uma temida organização denominada Spectre."},"name":"Português","iso_639_1":"pt","iso_3166_1":"BR","english_name":"Portuguese"},{"data":{"title":"007: Spectre","runtime":149,"tagline":"Un plan del que nadie escapa...","homepage":"http://007spectrelapelicula.com","overview":"Un mensaje críptico del pasado de James Bond lo envía a descubrir la existencia de una organización siniestra llamada SPECTRE. Con el amanecer de una nueva amenaza, Bond aprende la terrible verdad sobre el autor de todo su dolor en sus más recientes misiones."},"name":"Español","iso_639_1":"es","iso_3166_1":"MX","english_name":"Spanish"},{"data":{"title":"007：惡魔四伏","runtime":0,"tagline":"","homepage":"","overview":"一則由前任M遺留下的神祕訊息，促使龐德開始追查一個名叫「魔鬼黨」的國際犯罪組織，在新任M努力保全MI6時，龐德已抽絲剝繭，發現惡魔黨隱藏在層層謊言下的恐怖真相。"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"TW","english_name":"Mandarin"},{"data":{"title":"007 Spectre","runtime":148,"tagline":"Cette fois c’est personnel !","homepage":"","overview":"Un message crypté provenant du passé de James Bond le lance à la poursuite d'un homme à Mexico. Suite au décès de ce dernier, il se rend à ses funérailles en Italie où il rencontre sa défunte femme, Lucia. Des informations qu'elle lui procure lui permettent de s'infiltrer dans la réunion d'une assemblée secrète, connue sous le nom de SPECTRE. Il y découvre que ce groupe représente un grave danger pour le sort de l'humanité. Il s'alliera donc avec la fille d'un ancien membre qui avait quitté la confrérie en raison de ses pratiques abominables et tentera de la démanteler avant que leur plan pervers soit mis à exécution."},"name":"Français","iso_639_1":"fr","iso_3166_1":"CA","english_name":"French"},{"data":{"title":"Spektras","runtime":0,"tagline":"","homepage":"","overview":"Agentas 007 stoja prieš didžiausią pavojų savo karjeroje: paslaptingą organizaciją „Spektras“. Prieš trejus metus Džeimsas Bondas (aktorius Daniel‘is Craig‘as) fime „Skyfall“ turėjo išspręsti sudėtingą šaradą, kurios centre buvo jo vadovė M, bėganti nuo savo praeities paslapčių. Per suimtą, tačiau sugebėjusį pasprukti poną Vaitą Bondas beveik prisikasė iki itin slaptos organizacijos, žinomos „Quantum“ pavadinimu. Deja, akistata su nusikaltėliais pareikalavo didžiulės aukos: M buvo nužudyta ir mirė ant Bondo rankų. Ją pakeitęs Garetas Meloris (akt. Ralph‘as Fiennes‘as), kaip naujasis MI6 vadovas, turi iki paskutiniųjų kovoti politinį karą su savo šalies valdžia, norinčia labai susilpninti slaptosios organizacijos galias ir galimybes. Tuo tarpu panelė Monipenė Bondui slapta perduoda velionei M priklausiusią dėžutę, kurioje agentas 007 aptinka užuominų apie didžiulę paslaptį ir iš savo paties praeities."},"name":"Lietuvių","iso_639_1":"lt","iso_3166_1":"LT","english_name":"Lithuanian"},{"data":{"title":"007: Spektrs","runtime":0,"tagline":"","homepage":"","overview":""},"name":"Latviešu","iso_639_1":"lv","iso_3166_1":"LV","english_name":"Latvian"},{"data":{"title":"Điệp Viên 007: Bóng Ma","runtime":0,"tagline":"Một kế hoạch không ai có thể thoát khỏi.","homepage":"","overview":"James Bond 24: Spectre (Điệp Viên 007: Bóng Ma): Trong Spectre, Daniel Craig lần thứ tư vào vai siêu điệp viên 007. Trong khi “sếp” M phải đấu tranh ở mặt trận chính trị để giữ tổ chức điệp viên tồn tại, Bond nhận được một thông điệp từ quá khứ dẫn anh đến hành trình lột trần sự thật khủng khiếp đằng sau Spectre"},"name":"Tiếng Việt","iso_639_1":"vi","iso_3166_1":"VN","english_name":"Vietnamese"},{"data":{"title":"007：鬼影帝國","runtime":148,"tagline":"狙擊鐵金剛","homepage":"","overview":"一則神秘訊息讓佔士邦 (丹尼爾基克 飾) 從墨西哥一路追緝到羅馬，遇上美麗但聲名狼藉的寡婦罪犯 Lucia Sciarra (蒙妮卡貝露琪 飾)。邦透過她滲入一個秘密會議，發現了邪惡組織 — 魔鬼黨 (SPECTRE) 的存在。同時國家安全局新領導者 Max Denbigh，質疑邦的行動並挑戰 M (賴夫費恩斯 飾) 所帶領的軍情六處。邦秘密請求 Moneypenny\r (娜奧美夏莉絲 飾) 和 Q (賓韋沙 飾) 幫他找到前勁敵 Mr.White 的女兒 Madeleine Swann (蕾雅絲端 飾)，她掌握著瓦解魔鬼黨網絡的線索。作為一名殺手的女兒，她比任何人都更明白邦，她知道邦打算用自己的方式終結魔鬼黨。可是當邦越深入魔鬼黨的核心，他發現所追緝的敵人和自己竟有著叫人不寒而栗的關係……萬夫莫敵的佔士邦將承受一次身心交戰的危險任務！"},"name":"普通话","iso_639_1":"zh","iso_3166_1":"HK","english_name":"Mandarin"},{"data":{"title":"Spectre","runtime":148,"tagline":"","homepage":"","overview":"Po uničenju poveljstva MI6 James Bond prestreže kodirano sporočilo, ki ga po poteh lastne preteklosti vodi v osrčje skrivne organizacije Spectre. Da bi razpletel mrežo spletk in prevar, mora najboljši agent njenega veličanstva zaščititi nedolžno hčerko večnega sovražnika. Med tem, ko se novi šef M ukvarja s političnimi silami, ki ogrožajo prihodnost MI6, se Bond na lastno pest poda na misijo od Mehike, preko Avstrije, do Maroka, v številnih obračunih in vrtoglavih pregonih pa se sooči tako s starimi, kot tudi novimi nevarnimi sovražniki."},"name":"Slovenščina","iso_639_1":"sl","iso_3166_1":"SI","english_name":"Slovenian"},{"data":{"title":"სპექტრი","runtime":0,"tagline":"","homepage":"","overview":""},"name":"ქართული","iso_639_1":"ka","iso_3166_1":"GE","english_name":"Georgian"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"El James Bond visita Ciutat de Mèxic i Roma decidit a destapar una sinistra organització criminal anomenada Spectre, tota una amenaça per al govern britànic. Amb l'ajuda de dos col·laboradors, la Moneypenny i el Q, el 007 intenta trobar la Madeleine Swann, filla del seu gran enemic, el senyor White, que podria tenir la clau per desxifrar el misteri. A mesura que el Bond progressa en la seva investigació descobreix una esgarrifosa relació entre ell i el cap de l'organització Spectre."},"name":"Català","iso_639_1":"ca","iso_3166_1":"ES","english_name":"Catalan"},{"data":{"title":"","runtime":0,"tagline":"","homepage":"","overview":"၂၀၁၅ ခုနှစ်က ထွက်ရှိခဲ့တဲ့ Spectre ဇာတ်ကားဟာ ၂၄ ကားမြောက် James Bond ဇာတ်ကားဖြစ်ပါတယ်။ Spectreဆိုတဲ့ နာမည်ဟာ James Bond ရုပ်ရှင်တွေမှာ ပါလေ့ရှိတဲ့ ကမ္ဘာ့အကြမ်းဖက် အဖွဲ့အစည်းဖြစ်မှန်း James Bond ပရိသတ်တွေ သိကြမှာပါ။ ဒီနာမည်ရဲ့ အရှည်က မကောင်းဆိုးဝါးတစ်ကောင်လိုဖြစ်ပြီး Special Executive for Counterintelligence, Terrorism, Revenge, and Extortion ဖြစ်ပါတယ်။ ဒီဂိုဏ်းကို Skyfall မှာတုန်းက သေသွားခဲ့တဲ့ M ရဲ့မသေခင် ပေးပို့သွားတဲ့ Message ကနေခြေရာခံလိုက်ခဲ့တာပါ။ ယခင်ဂျိမ်းဘွန်းကားတွေနဲ့ မနှိုင်းယှဉ်တော့ပါဘူး ဒီဖက်ခေတ်အထာတွေအများကြီးပါဝင်လာတာမို့လို့ပါ။ ယခင်ဇာတ်ကားတွေလို ဂျိမ်းစ်ဘွန်းကို Team တစ်ခုလုံးက မထောက်ပံ့နိုင်အောင် C ဆိုသူမှ ဝင်ရှုပ်နေပါတယ်။ ဒါကြောင့် Q တို့ မန်နီပန်နီတို့ M တို့က တရားဝင်ကူညီခွင့်မရဘဲ ဘေးကနေ အသာလေးကူညီနေရပြီး ဂျိမ်းစ်ဘွန်းတစ်ယောက်ထဲ ကြိုးစားရုန်းကန်တဲ့ ပုံစံမျိုးနဲ့ ဖန်တီးထားတာကြောင့် ရှေးခေတ်တုန်းကလို ဘော်ကြော့ ဟီးရိုး မဟုတ်တော့ဘဲ ယခုခေတ် ခပ်မိုက်မိုက် ထီမထင် ဟီးရိုးပုံစံဖြစ်လာပါတယ်။ ဝင်ငွေတွေလဲ စံချိန်ချိုးခဲ့တယ်လို့ သိရပါတယ်။ခံစားအားပေးကြပါဦး။"},"name":"","iso_639_1":"my","iso_3166_1":"MY","english_name":"Burmese"},{"data":{"title":"स्पेक्टर","runtime":0,"tagline":"","homepage":"","overview":""},"name":"हिन्दी","iso_639_1":"hi","iso_3166_1":"IN","english_name":"Hindi"},{"data":{"title":"007: Spectre","runtime":0,"tagline":"","homepage":"","overview":"Salapärane sõnum minevikust ajendab James Bondi alustama omavolilist missiooni, mis viib ta Méxicosse ja lõpuks Rooma. Seal kohtub Bond Lucia Sciarraga (Monica Bellucci), kurikuulsa roimari imeilusa ja kättesaamatu lesega. Bondil õnnestub pääseda salajasele kohtumisele ja veenduda SPECTRE-i-nimelise kuritegeliku organisatsiooni olemasolus. Samal ajal seab Londonis asuva riikliku julgeolekuteenistuse uus juht Max Denbigh (Andrew Scott) kahtluse alla Bondi tegevuse tagamaad ja uurib sedagi, kui vajalik on tegelikult MI6, mida juhib M (Ralph Fiennes). Bond palub endale salaja appi Moneypenny (Naomie Harris) ja Q (Ben Whishaw) ning asub otsima Madeleine Swanni (Léa Seydoux), oma ammuse verivaenlase Mr White’i (Jesper Christensen) tütart, kes võib aidata tal kergitada SPECTRE-it ümbritsevat saladusloori."},"name":"Eesti","iso_639_1":"et","iso_3166_1":"EE","english_name":"Estonian"}],"reviews_tmdb":[{"id":"563e06159251413b1300c821","url":"https://www.themoviedb.org/review/563e06159251413b1300c821","author":"cutprintchris","content":"$11","created_at":"2015-11-07T14:09:25.776Z","updated_at":"2021-06-23T15:57:38.376Z","author_details":{"name":"","rating":null,"username":"cutprintchris","avatar_path":null}},{"id":"563ed3f9c3a3681b4d034302","url":"https://www.themoviedb.org/review/563ed3f9c3a3681b4d034302","author":"Frank Ochieng","content":"$12","created_at":"2015-11-08T04:47:53.765Z","updated_at":"2024-05-16T15:19:29.327Z","author_details":{"name":"Frank Ochieng","rating":null,"username":"Frank Ochieng","avatar_path":null}},{"id":"5649fed29251413ad500b5ac","url":"https://www.themoviedb.org/review/5649fed29251413ad500b5ac","author":"Andres Gomez","content":"A \"correct\" Bond movie. All the expected stereotypes are included, Waltz is an OK bad guy and the intro scene is something really impressive.\r\n\r\nNothing else really new ...","created_at":"2015-11-16T16:05:38.566Z","updated_at":"2021-06-23T15:57:39.103Z","author_details":{"name":"Andres Gomez","rating":6,"username":"tanty","avatar_path":null}},{"id":"56c093a59251412be0000529","url":"https://www.themoviedb.org/review/56c093a59251412be0000529","author":"Reno","content":"$13","created_at":"2016-02-14T14:48:05.502Z","updated_at":"2024-05-16T15:18:28.380Z","author_details":{"name":"Reno","rating":7,"username":"Rangan","avatar_path":"/6ZpVUJzqXMzH35VprEtnX0sNI3.jpg"}},{"id":"6154920881c7be008e08b3f8","url":"https://www.themoviedb.org/review/6154920881c7be008e08b3f8","author":"Manuel São Bento","content":"$14","created_at":"2021-09-29T16:19:20.125Z","updated_at":"2021-09-29T16:19:20.125Z","author_details":{"name":"Manuel São Bento","rating":7,"username":"msbreviews","avatar_path":null}},{"id":"6353bf6643250f0082593fa9","url":"https://www.themoviedb.org/review/6353bf6643250f0082593fa9","author":"CinemaSerf","content":"$15","created_at":"2022-10-22T10:01:10.885Z","updated_at":"2022-10-22T10:01:10.985Z","author_details":{"name":"CinemaSerf","rating":6,"username":"Geronimo1967","avatar_path":"/9HcQx0Yfbxy8eqr3ft66X9uWMf0.jpg"}},{"id":"63be6ebffc31d317148de397","url":"https://www.themoviedb.org/review/63be6ebffc31d317148de397","author":"GenerationofSwine","content":"$16","created_at":"2023-01-11T08:09:35.555Z","updated_at":"2023-01-11T08:09:35.658Z","author_details":{"name":"","rating":1,"username":"GenerationofSwine","avatar_path":"/xYhvrFNntgAowjRsf6mRg9JgITr.jpg"}},{"id":"63e70886a2e60200b5ed5835","url":"https://www.themoviedb.org/review/63e70886a2e60200b5ed5835","author":"The Movie Mob","content":"$17","created_at":"2023-02-11T03:16:22.287Z","updated_at":"2023-02-11T03:16:22.390Z","author_details":{"name":"The Movie Mob","rating":7,"username":"mooney240","avatar_path":"/blEC280vq31MVaDcsWBXuGOsYnB.jpg"}},{"id":"643eb092d7a70a04ddab446d","url":"https://www.themoviedb.org/review/643eb092d7a70a04ddab446d","author":"drystyx","content":"$18","created_at":"2023-04-18T15:00:34.427Z","updated_at":"2023-04-18T15:00:34.510Z","author_details":{"name":"","rating":3,"username":"drystyx","avatar_path":"/hLLsAvAnVT0cFU7JuuaaItTWXv8.jpg"}},{"id":"6741c8c9ac27f516d9f34341","url":"https://www.themoviedb.org/review/6741c8c9ac27f516d9f34341","author":"tmdb93836550","content":"Words can't describe how boring this is.","created_at":"2024-11-23T12:21:29.206Z","updated_at":"2024-11-23T12:21:29.256Z","author_details":{"name":"","rating":4,"username":"tmdb93836550","avatar_path":null}}],"recommendations":[{"id":37724,"adult":false,"title":"Skyfall","video":false,"overview":"When Bond's latest assignment goes gravely wrong, agents around the world are exposed and MI6 headquarters is attacked. While M faces challenges to her authority and position from Gareth Mallory, the new Chairman of the Intelligence and Security Committee, it's up to Bond, aided only by field agent Eve, to locate the mastermind behind the attack.","genre_ids":[28,12,53],"media_type":"movie","popularity":10.7512,"vote_count":15913,"poster_path":"/d0IVecFQvsGdSbnMAHqiYsNYaJT.jpg","release_date":"2012-10-24","vote_average":7.257,"backdrop_path":"/qB2eFmGEh5YCzhXUpz7As2PaDCh.jpg","original_title":"Skyfall","original_language":"en"},{"id":36557,"adult":false,"title":"Casino Royale","video":false,"overview":"Le Chiffre, a banker to the world's terrorists, is scheduled to participate in a high-stakes poker game in Montenegro, where he intends to use his winnings to establish his financial grip on the terrorist market. M sends Bond—on his maiden mission as a 00 Agent—to attend this game and prevent Le Chiffre from winning. With the help of Vesper Lynd and Felix Leiter, Bond enters the most important poker game in his already dangerous career.","genre_ids":[12,28,53],"media_type":"movie","popularity":12.023,"vote_count":11450,"poster_path":"/lMrxYKKhd4lqRzwUHAy5gcx9PSO.jpg","release_date":"2006-11-14","vote_average":7.569,"backdrop_path":"/mXFmGlMCgTIOyHaGmQG1Hb6Rv2m.jpg","original_title":"Casino Royale","original_language":"en"},{"id":370172,"adult":false,"title":"No Time to Die","video":false,"overview":"Bond has left active service and is enjoying a tranquil life in Jamaica. His peace is short-lived when his old friend Felix Leiter from the CIA turns up asking for help. The mission to rescue a kidnapped scientist turns out to be far more treacherous than expected, leading Bond onto the trail of a mysterious villain armed with dangerous new technology.","genre_ids":[28,53,12],"media_type":"movie","popularity":10.1757,"vote_count":6921,"poster_path":"/iUgygt3fscRoKWCV1d0C7FbM9TP.jpg","release_date":"2021-09-29","vote_average":7.3,"backdrop_path":"/x9td0NQha0t44K2qgcMipLOGjVi.jpg","original_title":"No Time to Die","original_language":"en"},{"id":140607,"adult":false,"title":"Star Wars: The Force Awakens","video":false,"overview":"Thirty years after defeating the Galactic Empire, Han Solo and his allies face a new threat from the evil Kylo Ren and his army of Stormtroopers.","genre_ids":[12,28,878],"media_type":"movie","popularity":12.1339,"vote_count":20296,"poster_path":"/wqnLdwVXoBjKibFRR5U3y0aDUhs.jpg","release_date":"2015-12-15","vote_average":7.25,"backdrop_path":"/8BTsTfln4jlQrLXUBquXJ0ASQy9.jpg","original_title":"Star Wars: The Force Awakens","original_language":"en"},{"id":131634,"adult":false,"title":"The Hunger Games: Mockingjay - Part 2","video":false,"overview":"As the war between the Capitol and the districts reaches its peak, Katniss Everdeen embarks on a perilous mission to liberate Panem and confront President Snow. Joined by a team of trusted allies, she navigates deadly traps, shifting loyalties, and the heavy cost of rebellion, determined to bring freedom to her people and end the Hunger Games once and for all.","genre_ids":[28,12,878],"media_type":"movie","popularity":5.9327,"vote_count":13156,"poster_path":"/lImKHDfExAulp16grYm8zD5eONE.jpg","release_date":"2015-11-18","vote_average":6.901,"backdrop_path":"/qVgLMRVNB5bHU0inmRa0ueShacN.jpg","original_title":"The Hunger Games: Mockingjay - Part 2","original_language":"en"},{"id":286217,"adult":false,"title":"The Martian","video":false,"overview":"During a manned mission to Mars, Astronaut Mark Watney is presumed dead after a fierce storm and left behind by his crew. But Watney has survived and finds himself stranded and alone on the hostile planet. With only meager supplies, he must draw upon his ingenuity, wit and spirit to subsist and find a way to signal to Earth that he is alive.","genre_ids":[18,12,878],"media_type":"movie","popularity":15.9137,"vote_count":20851,"poster_path":"/3ndAx3weG6KDkJIRMCi5vXX6Dyb.jpg","release_date":"2015-09-30","vote_average":7.692,"backdrop_path":"/sq8oUjbBvKkqv9h0Ns5rQbbquhZ.jpg","original_title":"The Martian","original_language":"en"},{"id":296098,"adult":false,"title":"Bridge of Spies","video":false,"overview":"During the Cold War, the Soviet Union captures U.S. pilot Francis Gary Powers after shooting down his U-2 spy plane. Sentenced to 10 years in prison, Powers' only hope is New York lawyer James Donovan, recruited by a CIA operative to negotiate his release. Donovan boards a plane to Berlin, hoping to win the young man's freedom through a prisoner exchange. If all goes well, the Russians would get Rudolf Abel, the convicted spy who Donovan defended in court.","genre_ids":[53,18],"media_type":"movie","popularity":5.788,"vote_count":7174,"poster_path":"/fmOOjHAQzxr0c1sfcY4qkiSRBH6.jpg","release_date":"2015-10-15","vote_average":7.237,"backdrop_path":"/12M3SvYO4WMdlXCajWklz1zUAly.jpg","original_title":"Bridge of Spies","original_language":"en"},{"id":10764,"adult":false,"title":"Quantum of Solace","video":false,"overview":"Betrayed by Vesper, the woman he loved, 007 fights the urge to make his latest mission personal. Pursuing his determination to uncover the truth, Bond and M interrogate Mr. White, who reveals that the organization that blackmailed Vesper is far more complex and dangerous than anyone had imagined.","genre_ids":[12,28,53,80],"media_type":"movie","popularity":8.1029,"vote_count":8373,"poster_path":"/e3DXXLJHGqMx9yYpXsql1XNljmM.jpg","release_date":"2008-10-29","vote_average":6.3,"backdrop_path":"/3CqMIX3ZlrD0pU3fpBL6DM0Cneb.jpg","original_title":"Quantum of Solace","original_language":"en"},{"id":274854,"adult":false,"title":"The Last Witch Hunter","video":false,"overview":"The modern world holds many secrets, but by far the most astounding is that witches still live among us; vicious supernatural creatures intent on unleashing the Black Death upon the world and putting an end to the human race once and for all. Armies of witch hunters have battled this unnatural enemy for centuries, including Kaulder, a valiant warrior who many years ago slayed the all-powerful Witch Queen, decimating her followers in the process. In the moments right before her death, the Queen cursed Kaulder with immortality, forever separating him from his beloved wife and daughter. Today, Kaulder is the last living hunter who has spent his immortal life tracking down rogue witches, all the while yearning for his long-lost family.","genre_ids":[28,12,14],"media_type":"movie","popularity":3.6658,"vote_count":3791,"poster_path":"/dS9YdnJkxtKE2PKCSsxTaO7Jpf5.jpg","release_date":"2015-10-21","vote_average":6,"backdrop_path":"/mXmvN6drkdU1PWFF92AGklEVIa3.jpg","original_title":"The Last Witch Hunter","original_language":"en"},{"id":321697,"adult":false,"title":"Steve Jobs","video":false,"overview":"Set backstage at three iconic product launches and ending in 1998 with the unveiling of the iMac, Steve Jobs takes us behind the scenes of the digital revolution to paint an intimate portrait of the brilliant man at its epicenter.","genre_ids":[18,36],"media_type":"movie","popularity":3.1585,"vote_count":4307,"poster_path":"/ljiRO29Y9khEERRqMluptUYunJ9.jpg","release_date":"2015-10-09","vote_average":6.775,"backdrop_path":"/mCbB9wUe9KHjGCcYGCzMLYyMjjE.jpg","original_title":"Steve Jobs","original_language":"en"},{"id":273481,"adult":false,"title":"Sicario","video":false,"overview":"An idealistic FBI agent is enlisted by a government task force to aid in the escalating war against drugs at the border area between the U.S. and Mexico.","genre_ids":[28,80,53],"media_type":"movie","popularity":9.779,"vote_count":9338,"poster_path":"/lz8vNyXeidqqOdJW9ZjnDAMb5Vr.jpg","release_date":"2015-09-17","vote_average":7.416,"backdrop_path":"/meeileDF37uB8ykIs4iFb713ABO.jpg","original_title":"Sicario","original_language":"en"},{"id":177677,"adult":false,"title":"Mission: Impossible - Rogue Nation","video":false,"overview":"Ethan and team take on their most impossible mission yet—eradicating 'The Syndicate', an International and highly-skilled rogue organization committed to destroying the IMF.","genre_ids":[28,12],"media_type":"movie","popularity":8.243,"vote_count":9541,"poster_path":"/fRJLXQBHK2wyznK5yZbO7vmsuVK.jpg","release_date":"2015-07-28","vote_average":7.221,"backdrop_path":"/vYIUN5rrCncHFY8WvcuXQlM4hk5.jpg","original_title":"Mission: Impossible - Rogue Nation","original_language":"en"},{"id":238713,"adult":false,"title":"Spy","video":false,"overview":"A desk-bound CIA analyst volunteers to go undercover to infiltrate the world of a deadly arms dealer, and prevent diabolical global disaster.","genre_ids":[28,35,80],"media_type":"movie","popularity":5.3321,"vote_count":6310,"poster_path":"/vPBmfMHxQvRRNGYD5S5ko2KnX56.jpg","release_date":"2015-05-06","vote_average":6.834,"backdrop_path":"/eHEGPHKHTVhWdXzBQcrTATz9M0I.jpg","original_title":"Spy","original_language":"en"},{"id":261023,"adult":false,"title":"Black Mass","video":false,"overview":"The true story of Whitey Bulger, the brother of a state senator and the most infamous violent criminal in the history of South Boston, who became an FBI informant to take down a Mafia family invading his turf.","genre_ids":[18,80,36],"media_type":"movie","popularity":3.7448,"vote_count":3531,"poster_path":"/zfwciv4LIJkNQsfuhYGv0Nkiweg.jpg","release_date":"2015-09-17","vote_average":6.526,"backdrop_path":"/mK4J2Qk4S4UQGOeMqsgei9DyPwW.jpg","original_title":"Black Mass","original_language":"en"},{"id":710,"adult":false,"title":"GoldenEye","video":false,"overview":"When a powerful satellite system falls into the hands of Alec Trevelyan, AKA Agent 006, a former ally-turned-enemy, only James Bond can save the world from a dangerous space weapon that -- in one short pulse -- could destroy the earth! As Bond squares off against his former compatriot, he also battles Xenia Onatopp, an assassin who uses pleasure as her ultimate weapon.","genre_ids":[12,28,53],"media_type":"movie","popularity":7.2432,"vote_count":4224,"poster_path":"/z0ljRnNxIO7CRBhLEO0DvLgAFPR.jpg","release_date":"1995-11-16","vote_average":6.899,"backdrop_path":"/fIWsCpYR9iGDMSbMTSAzy8L7Kg5.jpg","original_title":"GoldenEye","original_language":"en"},{"id":203801,"adult":false,"title":"The Man from U.N.C.L.E.","video":false,"overview":"At the height of the Cold War, a mysterious criminal organization plans to use nuclear weapons and technology to upset the fragile balance of power between the United States and Soviet Union. CIA agent Napoleon Solo and KGB agent Illya Kuryakin are forced to put aside their hostilities and work together to stop the evildoers in their tracks. The duo's only lead is the daughter of a missing German scientist, whom they must find soon to prevent a global catastrophe.","genre_ids":[35,28,12],"media_type":"movie","popularity":4.3697,"vote_count":6726,"poster_path":"/y5yZaForGSJbPD66Cvq9AT5WMAD.jpg","release_date":"2015-08-13","vote_average":7.1,"backdrop_path":"/bu0LiPEWKHWViRoaFwlTAzZ8wyS.jpg","original_title":"The Man from U.N.C.L.E.","original_language":"en"},{"id":294254,"adult":false,"title":"Maze Runner: The Scorch Trials","video":false,"overview":"Thomas and his fellow Gladers face their greatest challenge yet: searching for clues about the mysterious and powerful organization known as WCKD. Their journey takes them to the Scorch, a desolate landscape filled with unimaginable obstacles. Teaming up with resistance fighters, the Gladers take on WCKD’s vastly superior forces and uncover its shocking plans for them all.","genre_ids":[878,28,53,12],"media_type":"movie","popularity":6.0908,"vote_count":10879,"poster_path":"/mYw7ZyejqSCPFlrT2jHZOESZDU3.jpg","release_date":"2015-09-09","vote_average":6.73,"backdrop_path":"/4mcOCiR06dqQ5eoEJcG3zvonjOa.jpg","original_title":"Maze Runner: The Scorch Trials","original_language":"en"},{"id":253412,"adult":false,"title":"Everest","video":false,"overview":"Inspired by 