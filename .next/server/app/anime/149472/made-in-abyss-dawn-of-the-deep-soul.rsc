5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Made in Abyss: Dawn of the Deep Soul\",\"description\":\"<i>Dawn of the Deep Soul</i> continues the epic adventure of plucky Riko and Reg who are joined by their new friend Nanachi. Together they descend into the Abyss’ treacherous fifth layer, the Sea of Corpses, and encounter the mysterious Bondrewd, a legendary White Whistle whose shadow looms over Nanachi’s troubled past. Bondrewd is ingratiatingly hospitable, but the brave adventurers know things are not always as they seem in the enigmatic Abyss...<br>\\n<br>\\n(Source: Sentai Filmworks)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx100643-fPH9OgEKKvcI.jpg\",\"datePublished\":\"2020-01-17\",\"numberOfEpisodes\":1,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Adventure\",\"Drama\",\"Fantasy\",\"Horror\",\"Mystery\",\"Psychological\",\"Sci-Fi\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.5,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"f0f33fc5-75c4-4bc8-b595-c50547db3544","tmdb_id":100643,"imdb_id":null,"content_type":"anime","title":"Made in Abyss: Dawn of the Deep Soul","original_title":"メイドインアビス 深き魂の黎明","overview":"<i>Dawn of the Deep Soul</i> continues the epic adventure of plucky Riko and Reg who are joined by their new friend Nanachi. Together they descend into the Abyss’ treacherous fifth layer, the Sea of Corpses, and encounter the mysterious Bondrewd, a legendary White Whistle whose shadow looms over Nanachi’s troubled past. Bondrewd is ingratiatingly hospitable, but the brave adventurers know things are not always as they seem in the enigmatic Abyss...<br>\n<br>\n(Source: Sentai Filmworks)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx100643-fPH9OgEKKvcI.jpg","ba