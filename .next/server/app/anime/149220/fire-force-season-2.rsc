5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Fire Force Season 2\",\"description\":\"Shinra and Company 8 have figured out the Evangelist’s goal: to gather Adolla Bursts from Shinra and Shou. After learning more about his past from Captain Burns, Shinra becomes more motivated to discover the truth about his mother and save Shou again.<br>\\n<br>\\nBut a mysterious girl known as the “First Pillar” reveals the Evangelist’s master plan to start another Great Cataclysm!<br>\\n<br>\\n(Source: Funimation)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx114236-wfQOWF0Ii3h2.png\",\"datePublished\":\"2020-07-04\",\"numberOfEpisodes\":24,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Drama\",\"Sci-Fi\",\"Supernatural\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.8,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"dc43e05e-0964-4dce-9d55-058207e64d02","tmdb_id":114236,"imdb_id":null,"content_type":"anime","title":"Fire Force Season 2","original_title":"炎炎ノ消防隊 弐ノ章","overview":"Shinra and Company 8 have figured out the Evangelist’s goal: to gather Adolla Bursts from Shinra and Shou. After learning more about his past from Captain Burns, Shinra becomes more motivated to discover the truth about his mother and save Shou again.<br>\n<br>\nBut a mysterious girl known as the “First Pillar” reveals the Evangelist’s master plan to start another Great Cataclysm!<br>\n<br>\n(Source: Funimation)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx114236-wfQOWF0Ii3h2.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/114236-6nbw38bHeXYQ.jpg","release_date":null,"first_air_date":"2020-07-04","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"n