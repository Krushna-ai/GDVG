5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"LAID-BACK CAMP SEASON2\",\"description\":\"Having spent Christmas camping with her new friends, Rin Shima embarks on a solo-camping trip to see the New Year sunrise by the sea. All goes according to plan until unforeseen weather blocks the roads back home, making a return trip impossible. Rin, who is now stranded for a few days, is invited by Nadeshiko Kagamihara to stay at her grandmother's house.<br>\\n<br>\\nWhat is supposed to be a two-day trip becomes an extended period of sightseeing and new experiences for Rin, and she encounters some new and old faces along the way.<br>\\n<br>\\n(Source: MAL Rewrite)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx104459-pywEKGQON613.jpg\",\"datePublished\":\"2021-01-07\",\"numberOfEpisodes\":13,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Comedy\",\"Slice of Life\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.4,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"04502472-3528-4ca2-8179-40a4acb2bf01","tmdb_id":104459,"imdb_id":null,"content_type":"anime","title":"LAID-BACK CAMP SEASON2","original_title":"ゆるキャン△ SEASON２","overview":"Having spent Christmas camping with her new friends, Rin Shima embarks on a solo-camping trip to see the New Year sunrise by the sea. All goes according to plan until unforeseen weather blocks the roads back home, making a return trip impossible. Rin, who is now stranded for a few days, is invited by Nadeshiko Kagamihara to stay at her grandmother's house.<br>\n<br>\nWhat is supposed to be a two-day trip becomes an extended period of sightseeing and new experiences for Rin, and she encounters some new and old faces along the way.<br>\n<br>\n(Source: MAL Rewrite)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx104459-pywEKGQON613.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/104459-5SsUaCzOb3HC.jpg","release_date":null,"first_air_date":"2021-01-07","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Slice of Life"}],"popularity":75851,"vote_average":8.4,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":13,"created_at":"2026-05-02T08:51:12.877059+00:00","updated_at":"2026-05-02T08:51:12.828+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"C-Station"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2021-04-01","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Outdoor Activities"},{"id":2,"name":"Iyashikei"},{"id":3,"name":"Cute Girls Doing Cute Things"},{"id":4,"name":"Primarily Female Cast"},{"id":5,"name":"Camping"},{"id":6,"name":"Female Protagonist"},{"id":7,"name":"Episodic"},{"id":8,"name":"Food"},{"id":9,"name":"Educational"},{"id":10,"name":"Primarily Teen Cast"},{"id":11,"name":"Kuudere"},{"id":12,"name":"Seinen"},{"id":13,"name":"Rural"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:51:12.877059+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":38474,"anilist_id":104459},"social_ids":{"mal":"https://myanimelist.net/anime/38474","anilist":"https://anilist.co/anime/104459"},"gdvg_id":149996,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":