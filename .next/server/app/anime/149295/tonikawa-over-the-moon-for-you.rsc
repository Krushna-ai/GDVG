10:T555,{"@context":"https://schema.org","@type":"TVSeries","name":"TONIKAWA: Over The Moon For You","description":"The story follows a protagonist whose name is written with the characters for \"Hoshizora\" (\"Starry Sky\" in Japanese), but whose name is pronounced as \"Nasa\". On the day of his high school entrance exams, Nasa encounters a beautiful girl named Tsukasa. For Nasa, it feels like destiny is finally calling out to him that he will have a girlfriend, but things take a turn for the worse when Nasa is hit by a car and unable to attend his entrance exams.<br>\n<br>\nAfter Tsukasa helps the injured Nasa, he confesses his feelings to her, and she agrees to go out with him, but only if Nasa agrees to marry her first. A year later Nasa aces the entrance exams, but he decides to work a part time job and live by himself instead of going to school. After Nasa turns 18, Tsukasa re-appears, and their happy, romantic, and mysterious married life together begins.<br>\n<br>\n(Source: Crunchyroll)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx116267-Eo1biPBTlL4i.jpg","datePublished":"2020-10-03","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Comedy","Romance","Slice of Life"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.7,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"ccdafec8-5dd4-47c5-952f-d23274a34ce8","tmdb_id":116267,"imdb_id":null,"content_type":"anime","title":"TONIKAWA: Over The Moon For You","original_title":"トニカクカワイイ","overview":"The story follows a protagonist whose name is written with the characters for \"Hoshizora\" (\"Starry Sky\" in Japanese), but whose name is pronounced as \"Nasa\". On the day of his high school entrance exams, Nasa encounters a beautiful girl named Tsukasa. For Nasa, it feels like destiny is finally calling out to him that he will have a girlfriend, but things take a turn for the worse when Nasa is hit by a car and unable to attend his entrance exams.<br>\n<br>\nAfter Tsukasa helps the injured Nasa, he confesses his feelings to her, and she agrees to go out with him, but only if Nasa agrees to marry her first. A year later Nasa aces the entrance exams, but he decides to work a part time job and live by himself instead of going to school. After Nasa turns 18, Tsukasa re-appears, and their happy, romantic, and mysterious married life together begins.<br>\n<br>\n(Source: Crunchyroll)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx116267-Eo1biPBTlL4i.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/116267-xQRslGT0tMTS.jpg","release_date":null,"first_air_date":"2020-10-03","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Romance"},{"id":3,"name":"Slice of Life"}],"popularity":227753,"vote_average":7.7,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:45:27.603452+00:00","updated_at":"2026-05-02T08:45:27.559+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Seven Arcs"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2020-12-19","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Marriage"},{"id":2,"name":"Family Life"},{"id":3,"name":"Heterosexual"},{"id":4,"name":"Iyashikei"},{"id":5,"name":"Coming of Age"},{"id":6,"name":"Shounen"},{"id":7,"name":"Primarily Adult Cast"},{"id":8,"name":"Meta"},{"id":9,"name":"Male Protagonist"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:45:27.603452+00:00","