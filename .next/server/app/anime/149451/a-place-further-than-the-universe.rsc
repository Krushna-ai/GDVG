5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"A Place Further Than the Universe\",\"description\":\"Mari Tamaki is in her second year of high school and wants to start something. It's then that she meets Shirase, a girl with few friends who's considered weirdo by the rest of the class and nicknamed \\\"Antarctic\\\" since it's all she ever talks about. Unlike her peers, Mari is moved by Shirase's dedication and decides that even though it's unlikely that high school girls will ever go to Antarctica, she's going to try to go with Shirase.<br><br>\\n\\n(Source: Anime News Network)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx99426-ti5BL69Ip3kZ.png\",\"datePublished\":\"2018-01-02\",\"numberOfEpisodes\":13,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Adventure\",\"Comedy\",\"Drama\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.4,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"f850023d-5019-4668-818d-2bc973b79f07","tmdb_id":99426,"imdb_id":null,"content_type":"anime","title":"A Place Further Than the Universe","original_title":"宇宙よりも遠い場所","overview":"Mari Tamaki is in her second year of high school and wants to start something. It's then that she meets Shirase, a girl with few friends who's considered weirdo by the rest of the class and nicknamed \"Antarctic\" since it's all she ever talks about. Unlike her peers, Mari is moved by Shirase's dedication and decides that even though it's unlikely that high school girls will ever go to Antarctica, she's going to try to go with Shirase.<br><br>\n\n(Source: Anime News Network)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx99426-ti5BL69Ip3kZ.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/99426-KsFVCSwVC3x3.jpg","