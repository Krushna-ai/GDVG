9:{"metadata":[["$","title","0",{"children":"A Place Further Than the Universe | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Mari Tamaki is in her second year of high school and wants to start something. It's then that she meets Shirase, a girl with few friends who's considered weirdo by the rest of the class and nicknamed \"Antarctic\" since it's all she ever talks about. Unlike her peers, Mari is moved by Shirase's dedication and decides that even though it's unlikely that high school girls will ever go to Antarctica, she's going to try to go with Shirase.<br><br>\n\n(Source: Anime News Network)"}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/anime/149451/a-place-further-than-the-universe"}],["$","meta","5",{"property":"og:title","content":"A Place Further Than the Universe"}],["$","meta","6",{"property":"og:description","content":"Mari Tamaki is in her second year of high school and wants to start something. It's then that she meets Shirase, a girl with few friends who's considered weirdo by the rest of the class and nicknamed \"Antarctic\" since it's all she ever talks about. Unlike her peers, Mari is moved by Shirase's dedication and decides that even though it's unlikely that high school girls will ever go to Antarctica, she's going to try to go with Shirase.<br><br>\n\n(Source: Anime News Network)"}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/anime/149451/a-place-further-than-the-universe"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx99426-ti5BL69Ip3kZ.png"}],["$","meta","9",{"property":"og:type","content":"video.tv_show"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"