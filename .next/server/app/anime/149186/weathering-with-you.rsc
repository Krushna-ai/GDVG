10:T428,{"@context":"https://schema.org","@type":"TVSeries","name":"Weathering With You","description":"High school student Hodaka leaves his home on an isolated island and moves to Tokyo, but he immediately becomes broke. He lives his days in isolation, but finally finds a job as a writer for a shady occult magazine. After he starts his job, the weather has been rainy day after day. In a corner of the crowded and busy city, Hodaka meets a young woman named Hina. Due to certain circumstances, Hina and her younger brother live together, but have a cheerful and sturdy life. Hina also has a certain power: the power to stop the rain and clear the sky.\n<br><br>\n(Source: Anime News Network)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx106286-5COcpd0J9VbL.png","datePublished":"2019-07-19","numberOfEpisodes":1,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Romance","Slice of Life","Supernatural"],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.1,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"1200e195-9bc0-4fb9-ade3-d4d75137224e","tmdb_id":106286,"imdb_id":null,"content_type":"anime","title":"Weathering With You","original_title":"天気の子","overview":"High school student Hodaka leaves his home on an isolated island and moves to Tokyo, but he immediately becomes broke. He lives his days in isolation, but finally finds a job as a writer for a shady occult magazine. After he starts his job, the weather has been rainy day after day. In a corner of the crowded and busy city, Hodaka meets a young woman named Hina. Due to certain circumstances, Hina and her younger brother live together, but have a cheerful and sturdy life. Hina also has a certain power: the power to stop the rain and clear the sky.\n<br><br>\n(Source: Anime News Network)","poster_path":"https://s4.anilist.co/fi