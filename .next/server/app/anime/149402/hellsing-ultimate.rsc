10:T516,{"@context":"https://schema.org","@type":"TVSeries","name":"Hellsing Ultimate","description":"Hellsing, a secret organization of the British government, has long been battling supernatural threats to keep the people safe from creatures of the night. The current leader, Integra Wingates Hellsing controls her own personal army to eliminate the undead beings, but even her highly trained soldiers pale in comparison to her most trusted vampire exterminator, a man by the name of Alucard, who is actually a powerful vampire himself. Along with Integra's mysterious butler and Alucard's new vampire minion, Seras Victoria, The Hellsing Organization must face not only regular ghouls and vampires, but a rivaling secret organization from the Vatican, and Millennium, an enigmatic group of madmen spawned by a certain war over 50 years ago...<br>\nA bloody battle between monsters is about to begin, the dead are dancing, and all hell is singing...","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx777-F6547pSAR2Zd.jpg","datePublished":"2006-02-10","numberOfEpisodes":10,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Horror","Supernatural"],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.1,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"f8fe23be-84d5-4915-a5fb-b3f29470fe4a","tmdb_id":777,"imdb_id":null,"content_type":"anime","title":"Hellsing Ultimate","original_title":"HELLSING OVA","overview":"Hellsing, a secret organization of the British government, has long been battling supernatural threats to keep the people safe from creatures of the night. The current leader, Integra Wingates Hellsing controls her own personal army to eliminate the undead beings, but even her highly trained soldiers pale in comparison to her most trusted vampire exterminator, a man by the name of Alucard, who is actually a powerful vampire himself. Along with Integra's mysterious butler and Alucard's new vampire minion, Seras Victoria, The Hellsing Organization must face not only regular ghouls and vampires, but a rivaling secret organization from the Vatican, and Millennium, an enigmatic group of madmen spawned by a certain war over 50 years ago...<br>\nA bloody battle between monsters is about to begin, the dead are dancing, and all hell is singing...","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx777-F6547pSAR2Zd.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/777-XzPjBZdSRtDT.jpg","release_date":null,"first_air_date":"2006-02-10","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Horror"},{"id":3,"name":"Supernatural"}],"popularity":173483,"vote_average":8.1,"vote_count":null,"runtime":50,"number_of_seasons":null,"number_of_episodes":10,"created_at":"2026-05-02T08:49:07.604895+00:00","updated_at":"2026-05-02T08:49:07.563+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"MADHOUSE"},{"name":"Satelight"},{"name":"StudioRF Inc."},{"name":"Graphinica"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2012-12-26","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Vampire"},{"id":2,"name":"Gore"},{"id":3,"name":"Seinen"},{"id":4,"name":"War"},{"id":5,"name":"Urban Fantasy"},{"id":6,"name":"Religion"},{"id":7,"name":"Foreign"},{"id":8,"name":"Anti-Hero"},{"id":9,"name":"Primarily Adult Cast"},{"id":10,"name":"Military"},{"id":11,"name":"Urban"},{"id":12,"name":"Guns"},{"id":13,"name":"Monster Girl"},{"id":14,"name":"Body Horror"},{"id":15,"name":"Noir"},{"id":16,"name":"Cannibalism"},{"id":17,"name":"Male Protagonist"},{"id":18,"name":"Monster Boy"},{"id":19,"name":"Butler"}],"alternative_titles":null,"videos":[