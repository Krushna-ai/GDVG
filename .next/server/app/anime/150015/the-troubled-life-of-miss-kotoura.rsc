5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"The Troubled Life of Miss Kotoura\",\"description\":\"A school love comedy. Kotoura Haruka is a 15-year-old girl who can read people's minds. She has been suffering from troubles caused by her mind-reading ability, and her parents got divorced as a result. She moves to a new high school but tries to keep away from her classmates. Manabe Yoshihisa, one of her classmates, accepts and appreciates her ability and she begins to interact with her friends with his help.\\n\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx15379-tSZbUJQzAvRi.png\",\"datePublished\":\"2013-01-11\",\"numberOfEpisodes\":12,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Comedy\",\"Drama\",\"Romance\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":6.8,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"901d4800-8e9c-4d9b-8ff4-ce029800f2ed","tmdb_id":15379,"imdb_id":null,"content_type":"anime","title":"The Troubled Life of Miss Kotoura","original_title":"琴浦さん","overview":"A school love comedy. Kotoura Haruka is a 15-year-old girl who can read people's minds. She has been suffering from troubles caused by her mind-reading ability, and her parents got divorced as a result. She moves to a new high school but tries to keep away from her classmates. Manabe Yoshihisa, one of her classmates, accepts and appreciates her ability and she begins to interact with her friends with his help.\n","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx15379-tSZbUJQzAvRi.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/15379.jpg","release_date":null,"first_air_date":"2013-01-11","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"}