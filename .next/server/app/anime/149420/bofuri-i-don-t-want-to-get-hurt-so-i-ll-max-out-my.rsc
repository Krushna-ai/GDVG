10:T4c1,{"@context":"https://schema.org","@type":"TVSeries","name":"BOFURI: I Don't Want to Get Hurt, so I'll Max Out My Defense.","description":"The story centers on Kaede Honjou, who is invited by her friend Risa Shiramine to play a virtual reality MMO game with her. While Kaede doesn't dislike games, what she really, truly dislikes is being in pain. She creates a character named Maple, and decides to put all her points in VIT to minimize pain. As a result, she moves slowly, can't use magic, and even a rabbit can get the best of her. However, as it turns out, she acquires a skill known as \"Absolute Defense\" as a result of her pumping points into VIT, as well as a \"Counter Skill\" that works against special moves. Now, with her ability to nullify all damage, she goes on adventures.<br><br>(Source: Anime News Network, edited)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx106479-JmPk1F5ubMtm.png","datePublished":"2020-01-08","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Adventure","Comedy","Fantasy","Slice of Life"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.4,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"8186577f-7171-471d-8086-611dfa5e52ba","tmdb_id":106479,"imdb_id":null,"content_type":"anime","title":"BOFURI: I Don't Want to Get Hurt, so I'll Max Out My Defense.","original_title":"痛いのは嫌なので防御力に極振りしたいと思います。","overview":"The story centers on Kaede Honjou, who is invited by her friend Risa Shiramine to play a virtual reality MMO game with her. While Kaede doesn't dislike games, what she really, truly dislikes is being in pain. She creates a character named Maple, and decides to put all her points in VIT to minimize pain. As a result, she moves slowly, can't use magic, and even a rabbit can get the best of her. However, as it turns out, she acquires a skill known as \"Absolute Defense\" as a result of her pumping points into VIT, as well as a \"Counter Skill\" that works against special moves. Now, with her ability to nullify all damage, she goes on adventures.<br><br>(Source: Anime News Network, edited)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx106479-JmPk1F5ubMtm.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/106479-G1rExJ4m8Be3.jpg","release_date":null,"first_air_date":"2020-01-08","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Adventure"},{"id":3,"name":"Comedy"},{"id":4,"name":"Fantasy"},{"id":5,"name":"Slice of Life"}],"popularity":168447,"vote_average":7.4,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:49:10.704504+00:00","updated_at":"2026-05-02T08:49:10.662+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"SILVER LINK."}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2020-03-25","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Video Games"},{"id":2,"name":"Virtual World"},{"id":3,"name":"Female Protagonist"},{"id":4,"name":"Cute Girls Doing Cute Things"},{"id":5,"name":"Isekai"},{"id":6,"name":"Primarily Female Cast"},{"id":7,"name":"Magic"},{"id":8,"name":"Henshin"},{"id":9,"name":"Parody"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:49:10.704504+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":38790,"anilist_id":106479},"social