5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Death Note\",\"description\":\"Light Yagami is a genius high school student who is about to learn about life through a book of death. When a bored shinigami, a God of Death, named Ryuk drops a black notepad called a <i>Death Note</i>, Light receives power over life and death with the stroke of a pen. Determined to use this dark gift for the best, Light sets out to rid the world of evil… namely, the people he believes to be evil. Should anyone hold such power?<br>\\n<br>\\nThe consequences of Light’s actions will set the world ablaze.<br>\\n<br>\\n(Source: VIZ Media)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx1535-kUgkcrfOrkUM.jpg\",\"datePublished\":\"2006-10-04\",\"numberOfEpisodes\":37,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Mystery\",\"Psychological\",\"Supernatural\",\"Thriller\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.4,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"93435032-4e81-4967-85e8-493408865b73","tmdb_id":1535,"imdb_id":null,"content_type":"anime","title":"Death Note","original_title":"DEATH NOTE","overview":"Light Yagami is a genius high school student who is about to learn about life through a book of death. When a bored shinigami, a God of Death, named Ryuk drops a black notepad called a <i>Death Note</i>, Light receives power over life and death with the stroke of a pen. Determined to use this dark gift for the best, Light sets out to rid the world of evil… namely, the people he believes to be evil. Should anyone hold such power?<br>\n<br>\nThe consequences of Light’s actions will set the world ablaze.<br>\n<br>\n(Source: VIZ Media)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx1535-kUgkcrfOrkUM.jpg","backdro