5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Josee, the Tiger and the Fish\",\"description\":\"The story centers on the relationship between Tsuneo and Josee. Tsuneo is a university student, and Josee is a young girl who has rarely gone out of the house by herself due to her being unable to walk. The two meet when Tsuneo finds Josee's grandmother taking her out for a morning walk.\\n<br><br>\\n(Source: Anime News Network)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx113596-LKA0bYJGjLnB.jpg\",\"datePublished\":\"2020-12-25\",\"numberOfEpisodes\":1,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Drama\",\"Romance\",\"Slice of Life\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.2,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"d04e99a8-3a27-472a-8800-f392f70aae69","tmdb_id":113596,"imdb_id":null,"content_type":"anime","title":"Josee, the Tiger and the Fish","original_title":"ジョゼと虎と魚たち","overview":"The story centers on the relationship between Tsuneo and Josee. Tsuneo is a university student, and Josee is a young girl who has rarely gone out of the house by herself due to her being unable to walk. The two meet when Tsuneo finds Josee's grandmother taking her out for a morning walk.\n<br><br>\n(Source: Anime News Network)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx113596-LKA0bYJGjLnB.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/113596-8r3fCSFgQHIY.jpg","release_date":null,"first_air_date":"2020-12-25","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Romance"},{"id":3,"name":"Slice of Life"}],"popularity":169425,"vote_average":8.2,"vote_count":null,"runtime":98,"number_of_seasons":null