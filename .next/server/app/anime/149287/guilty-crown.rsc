10:T526,{"@context":"https://schema.org","@type":"TVSeries","name":"Guilty Crown","description":"Shuu's entire world was shattered after a meteorite crashed into Japan, unleashing the lethal Apocalypse Virus. The chaos and anarchy born of the outbreak cost Shuu his family and reduced him to a timid, fearful shell of the boy he'd once been. His life took another unexpected turn after a chance encounter with the stunning pop star, Inori. This mysterious beauty introduced Shuu to the King's Right Hand: a genetic mutation that allows him to reach into hearts of mortals and turn them into weapons.<br>\n<br>\nShuu finds himself caught in the crossfire between those who desperately seek his newfound strength. On one side lurks a clandestine government agency, and on the other, Inori and the spirited band of rebels known as Funeral Parlor. The choice is Shuu's to make - and the world is his to change.<br>\n<br>\n(Source: Funimation)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx10793-KCysCbrVNqK9.jpg","datePublished":"2011-10-14","numberOfEpisodes":22,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Drama","Mecha","Psychological","Romance","Sci-Fi"],"aggregateRating":{"@type":"AggregateRating","ratingValue":6.9,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"592f318d-48fb-4a28-b5df-41612ccd659e","tmdb_id":10793,"imdb_id":null,"content_type":"anime","title":"Guilty Crown","original_title":"ギルティクラウン","overview":"Shuu's entire world was shattered after a meteorite crashed into Japan, unleashing the lethal Apocalypse Virus. The chaos and anarchy born of the outbreak cost Shuu his family and reduced him to a timid, fearful shell of the boy he'd once been. His life took another unexpected turn after a chance encounter with the stunning pop star, Inori. This mysterious beauty introduced Shuu to the King's Right Hand: a genetic mutation that allows him to reach into hearts of mortals and turn them into weapons.<br>\n<br>\nShuu finds himself caught in the crossfire between those who desperately seek his newfound strength. On one side lurks a clandestine government agency, and on the other, Inori and the spirited band of rebels known as Funeral Parlor. The choice is Shuu's to make - and the world is his to change.<br>\n<br>\n(Source: Funimation)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx10793-KCysCbrVNqK9.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/10793-R1zx9H9kZo1e.jpg","release_date":null,"first_air_date":"2011-10-14","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Drama"},{"id":3,"name":"Mecha"},{"id":4,"name":"Psychological"},{"id":5,"name":"Romance"},{"id":6,"name":"Sci-Fi"}],"popularity":229293,"vote_average":6.9,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":22,"created_at":"2026-05-02T08:45:26.277788+00:00","updated_at":"2026-05-02T08:45:26.233+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Production I.G"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2012-03-23","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Super Power"},{"id":2,"name":"Terrorism"},{"id":3,"name":"Dystopian"},{"id":4,"name":"Pandemic"},{"id":5,"name":"Post-Apocalyptic"},{"id":6,"name":"Anti-Hero"},{"id":7,"name":"Real Robot"},{"id":8,"name":"Female Protagonist"},{"id":9,"name":"Urban"},{"id":10,"name":"Politics"},{"id":11,"name":"Kuudere"},{"id":12,"name":"Male Protagonist"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"importe