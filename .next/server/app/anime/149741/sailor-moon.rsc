10:T54d,{"@context":"https://schema.org","@type":"TVSeries","name":"Sailor Moon","description":"Usagi Tsukino is an average student and crybaby klutz who constantly scores low on her tests. Unexpectedly, her humdrum life is turned upside down when she saves a cat with a crescent moon on its head from danger. The cat, named Luna, later reveals that their meeting was not an accident: Usagi is destined to become Sailor Moon, a planetary guardian with the power to protect the Earth. Given a special brooch that allows her to transform, she must use her new powers to save the city from evil energy-stealing monsters sent by the malevolent Queen Beryl of the Dark Kingdom.<br>\n<br>\nBut getting accustomed to her powers and fighting villains are not the only things she has to worry about. She must find the lost princess of the Moon Kingdom, the other Sailor Guardians, and the Legendary Silver Crystal in order to save the planet from destruction.<br>\n<br>\n(Source: MAL Rewrite)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx530-O8q6KpJ244Qk.jpg","datePublished":"1992-03-07","numberOfEpisodes":46,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Adventure","Fantasy","Mahou Shoujo","Romance"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.6,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"2d5e375c-bd19-4c38-ac96-c9ed366a8e74","tmdb_id":530,"imdb_id":null,"content_type":"anime","title":"Sailor Moon","original_title":"美少女戦士セーラームーン","overview":"Usagi Tsukino is an average student and crybaby klutz who constantly scores low on her tests. Unexpectedly, her humdrum life is turned upside down when she saves a cat with a crescent moon on its head from danger. The cat, named Luna, later reveals that their meeting was not an accident: Usagi is destined to become Sailor Moon, a planetary guardian with the power to protect the Earth. Given a special brooch that allows her to transform, she must use her new powers to save the city from evil energy-stealing monsters sent by the malevolent Queen Beryl of the Dark Kingdom.<br>\n<br>\nBut getting accustomed to her powers and fighting villains are not the only things she has to worry about. She must find the lost princess of the Moon Kingdom, the other Sailor Guardians, and the Legendary Silver Crystal in order to save the planet from destruction.<br>\n<br>\n(Source: MAL Rewrite)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx530-O8q6KpJ244Qk.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/530.jpg","release_date":null,"first_air_date":"1992-03-07","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Adventure"},{"id":3,"name":"Fantasy"},{"id":4,"name":"Mahou Shoujo"},{"id":5,"name":"Romance"}],"popularity":100246,"vote_average":7.6,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":46,"created_at":"2026-05-02T08:50:21.05909+00:00","updated_at":"2026-05-02T08:50:21.016+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Toei Animation"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"1993-02-27","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Magic"},{"id":2,"name":"Shoujo"},{"id":3,"name":"Female Protagonist"},{"id":4,"name":"Henshin"},{"id":5,"name":"Primarily Female Cast"},{"id":6,"name":"Urban Fantasy"},{"id":7,"name":"Super Power"},{"id":8,"name":"Demons"},{"id":9,"name":"Heterosexual"},{"id":10,"name":"Found Family"},{"id":11,"name":"Slapstick"},{"id":12,"name":"Coming of Age"},{"id":13,"name":"Ensemble Cast"},{"id":14,"name":"Primarily Teen Cast"},{"id":15,"name":"Urban"},{"id":16,"name":"Animals"},{"id":17,"name":"Sc