10:T48a,{"@context":"https://schema.org","@type":"TVSeries","name":"Danganronpa: The Animation","description":"A group of 15 elite high school students are gathered at a very special, high class high school. To graduate from this high school essentially means you'll succeed in life, but graduating is very difficult. The school is presided over by a bear called Monokuma, and he explains to them that their graduation hinges around committing a murder. The only way to graduate is to kill one of your classmates and get away with it. If the other classmates discover the identity of the killer, the killer is the only one executed. However, if they fail to catch the killer, only the killer graduates and the others are annihilated. Which of the 15 will survive the bloodbath to come?\n","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx16592-mFn1gfMXlKtw.jpg","datePublished":"2013-06-23","numberOfEpisodes":13,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Horror","Mystery","Psychological","Sci-Fi","Thriller"],"aggregateRating":{"@type":"AggregateRating","ratingValue":6.9,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"cb152373-df07-423a-96e4-142d66ab6d18","tmdb_id":16592,"imdb_id":null,"content_type":"anime","title":"Danganronpa: The Animation","original_title":"ダンガンロンパ 希望の学園と絶望の高校生 The Animation","overview":"A group of 15 elite high school students are gathered at a very special, high class high school. To graduate from this high school essentially means you'll succeed in life, but graduating is very difficult. The school is presided over by a bear called Monokuma, and he explains to them that their graduation hinges around committing a murder. The only way to graduate is to kill one of your classmates and get away with it. If the other classmates discover the identity of the killer, the killer is the only one executed. However, if they fail to catch the killer, only the killer graduates and the others are annihilated. Which of the 15 will survive the bloodbath to come?\n","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx16592-mFn1gfMXlKtw.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/16592-tcRpZFHvgZjb.jpg","release_date":null,"first_air_date":"2013-06-23","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Horror"},{"id":2,"name":"Mystery"},{"id":3,"name":"Psychological"},{"id":4,"name":"Sci-Fi"},{"id":5,"name":"Thriller"}],"popularity":222453,"vote_average":6.9,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":13,"created_at":"2026-05-02T08:45:29.250897+00:00","updated_at":"2026-05-02T08:45:29.206+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Lerche"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2013-09-27","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Death Game"},{"id":2,"name":"Battle Royale"},{"id":3,"name":"Survival"},{"id":4,"name":"Detective"},{"id":5,"name":"Amnesia"},{"id":6,"name":"School"},{"id":7,"name":"Ensemble Cast"},{"id":8,"name":"Gore"},{"id":9,"name":"Primarily Teen Cast"},{"id":10,"name":"Male Protagonist"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:45:29.250897+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":16592,"anilist_id":16592},"social_ids":{"mal":"https://myanimelist.net/anime/16592","anilist":"https://anilist.co/anime/16592"},"gdv