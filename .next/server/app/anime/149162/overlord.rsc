5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Overlord\",\"description\":\"The story takes place in the year 2138 when virtual reality gaming is booming. Yggdrasil, a popular online game is quietly shut down one day. However, the protagonist Momonga decides to not log out. Momonga is then transformed into the image of a skeleton as \\\"the most powerful wizard.\\\" The world continues to change, with non-player characters (NPCs) beginning to feel emotion. Having no parents, friends, or place in society, this ordinary young man Momonga then strives to take over the new world the game has become.<br>\\n<br>\\n(Source: Anime News Network)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20832-vUNm5zrYWifc.jpg\",\"datePublished\":\"2015-07-07\",\"numberOfEpisodes\":13,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Adventure\",\"Fantasy\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.7,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"eade06ad-d3bd-4c27-b215-f8062dd1a8ea","tmdb_id":20832,"imdb_id":null,"content_type":"anime","title":"Overlord","original_title":"オーバーロード","overview":"The story takes place in the year 2138 when virtual reality gaming is booming. Yggdrasil, a popular online game is quietly shut down one day. However, the protagonist Momonga decides to not log out. Momonga is then transformed into the image of a skeleton as \"the most powerful wizard.\" The world continues to change, with non-player characters (NPCs) beginning to feel emotion. Having no parents, friends, or place in society, this ordinary young man Momonga then strives to take over the new world the game has become.<br>\n<br>\n(Source: Anime News Network)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20832-vUNm5zrYWifc.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/20832-NswCiSYMoI2k.jpg","release_date":null,"first_air_date":"2015-07-07","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Adventure"},{"id":3,"name":"Fantasy"}],"popularity":375703,"vote_average":7.7,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":13,"created_at":"2026-05-02T08:44:57.314757+00:00","updated_at":"2026-05-02T08:44:57.27+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"MADHOUSE"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2015-09-29","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Isekai"},{"id":2,"name":"Anti-Hero"},{"id":3,"name":"Skeleton"},{"id":4,"name":"Virtual World"},{"id":5,"name":"Male Protagonist"},{"id":6,"name":"Magic"},{"id":7,"name":"Kingdom Management"},{"id":8,"name":"Ensemble Cast"},{"id":9,"name":"Medieval"},{"id":10,"name":"Demons"},{"id":11,"name":"Succubus"},{"id":12,"name":"Necromancy"},{"id":13,"name":"Yandere"},{"id":14,"name":"Primarily Adult Cast"},{"id":15,"name":"Politics"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:44:57.314757+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":29803,"anilist_id":20832},"social_ids":{"mal":"https://myanimelist.net/anime/29803","anilist":"https://anilist.co/anime/20832"},"gdvg_id":149162,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wi