10:T5c9,{"@context":"https://schema.org","@type":"TVSeries","name":"Penguindrum","description":"Once you make a decision, does the universe conspire to make it happen? Is destiny a matter of chance, a matter of choice or the complex outcome of thousands of warring strands of fate? All twins Kanba and Shoma know is that when their terminally ill sister Himari collapses at the aquarium, her death is somehow temporarily reversed by the penguin hat that she had asked for. It's a provisional resurrection, however, and it comes at a price: to keep Himari alive they need to find the mysterious Penguin Drum. In order to do that, they must first find the links to a complex interlocking chain of riddles that has wrapped around their entire existence, and unravel the knots that tie them to mystifying diary and a baffling string of strangers and semi-acquaintances who all have their own secrets, agendas and \"survival strategies.\" And in order for Himari to live, someone else's chosen destiny will have to change. It's a story of love, fate, life, death... and Penguins! <br><br>\n(Source: Sentai Filmworks) ","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx10721-lNEbDPX24qzn.jpg","datePublished":"2011-07-08","numberOfEpisodes":24,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Mystery","Psychological","Supernatural"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.9,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"29878826-5dfb-49bd-87f0-021b75f090b7","tmdb_id":10721,"imdb_id":null,"content_type":"anime","title":"Penguindrum","original_title":"輪るピングドラム","overview":"Once you make a decision, does the universe conspire to make it happen? Is destiny a matter of chance, a matter of choice or the complex outcome of thousands of warring strands of fate? All twins Kanba and Shoma know is that when their terminally ill sister Himari collapses at the aquarium, her death is somehow temporarily reversed by the penguin hat that she had asked for. It's a provisional resurrection, however, and it comes at a price: to keep Himari alive they need to find the mysterious Penguin Drum. In order to do that, they must first find the links to a complex interlocking chain of riddles that has wrapped around their entire existence, and unravel the knots that tie them to mystifying diary and a baffling string of strangers and semi-acquaintances who all have their own secrets, agendas and \"survival strategies.\" And in order for Himari to live, someone else's chosen destiny will have to change. It's a story of love, fate, life, death... and Penguins! <br><br>\n(Source: Sentai Filmworks) ","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx10721-lNEbDPX24qzn.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/10721-tN8SLwirGDAB.jpg","release_date":null,"first_air_date":"2011-07-08","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Mystery"},{"id":3,"name":"Psychological"},{"id":4,"name":"Supernatural"}],"popularity":81400,"vote_average":7.9,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":24,"created_at":"2026-05-02T08:50:56.856233+00:00","updated_at":"2026-05-02T08:50:56.813+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Brain's Base"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2011-12-23","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Philosophy"},{"id":2,"name":"Family Life"},{"id":3,"name":"Coming of Age"},{"id":4,"name":"Ensemble Cast"},{"id":5,"name":"Meta"},{"id":6,"name":"Denpa"},{"id":7,"name":"Politics"},{"id":8,"name":"Male Protagonist"},{"id":9,"name":"Female Protagoni