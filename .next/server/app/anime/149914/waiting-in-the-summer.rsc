5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Waiting in the Summer\",\"description\":\"When a group of friends decide to make a movie over a long summer holiday, they end up learning a little about filmmaking and a lot more about each other and themselves. What begins as a simple way to avoid the summer doldrums quickly turns into something much more complex, intimate and revealing, as the maturing relationships between the members of the young cast take on new, and sometimes very unexpected, turns. <br><br>\\r\\n(Source: Sentai Filmworks) \",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx11433-KLEzZeK6D46g.jpg\",\"datePublished\":\"2012-01-10\",\"numberOfEpisodes\":12,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Comedy\",\"Drama\",\"Romance\",\"Sci-Fi\",\"Slice of Life\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.1,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"c4664ac8-bacf-445f-9ebf-8c211b31e833","tmdb_id":11433,"imdb_id":null,"content_type":"anime","title":"Waiting in the Summer","original_title":"あの夏で待ってる","overview":"When a group of friends decide to make a movie over a long summer holiday, they end up learning a little about filmmaking and a lot more about each other and themselves. What begins as a simple way to avoid the summer doldrums quickly turns into something much more complex, intimate and revealing, as the maturing relationships between the members of the young cast take on new, and sometimes very unexpected, turns. <br><br>\r\n(Source: Sentai Filmworks) ","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx11433-KLEzZeK6D46g.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/11433-Pce9apZ7W49V.jpg","release_date":null,"first_air_date":"2012-01-1