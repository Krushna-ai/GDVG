10:T4be,{"@context":"https://schema.org","@type":"TVSeries","name":"The Disappearance of Haruhi Suzumiya","description":"It is mid-December, and SOS Brigade chief Haruhi Suzumiya announces that the Brigade is going to hold a Christmas party in their clubroom, with Japanese hotpot for dinner. The brigade members Kyon, Yuki Nagato, Mikuru Asahina and Itsuki Koizumi start preparing everything for the party, such as costumes and decorations. But a couple of days later, Kyon arrives at school only to find that Haruhi is missing. Not only that, but Mikuru claims she has never known Kyon before, Koizumi is also missing, and Yuki has become the sole member of the literature club. The SOS Brigade seems to have never existed, nor has Haruhi Suzumiya. No one in the school has ever heard about her... except for Kyon.<br><br>\n(Source: Anime News Network)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx7311-9Mfc1YRHwCCW.jpg","datePublished":"2010-02-06","numberOfEpisodes":1,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Mystery","Sci-Fi","Supernatural"],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.6,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"7f3939d5-573a-4636-8672-54e14da3f316","tmdb_id":7311,"imdb_id":null,"content_type":"anime","title":"The Disappearance of Haruhi Suzumiya","original_title":"涼宮ハルヒの消失","overview":"It is mid-December, and SOS Brigade chief Haruhi Suzumiya announces that the Brigade is going to hold a Christmas party in their clubroom, with Japanese hotpot for dinner. The brigade members Kyon, Yuki Nagato, Mikuru Asahina and Itsuki Koizumi start preparing everything for the party, such as costumes and decorations. But a couple of days later, Kyon arrives at school only to find that Haruhi is missing. Not only that, but Mikuru claims she has never known Kyon before, Koizumi is also missing, and Yuki has become the sole member of the literature club. The SOS Brigade seems to have never existed, nor has Haruhi Suzumiya. No one in the school has ever heard about her... except for Kyon.<br><br>\n(Source: Anime News Network)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx7311-9Mfc1YRHwCCW.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/7311-LkdBCThgXouS.jpg","release_date":null,"first_air_date":"2010-02-06","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Mystery"},{"id":3,"name":"Sci-Fi"},{"id":4,"name":"Supernatural"}],"popularity":141295,"vote_average":8.6,"vote_count":null,"runtime":162,"number_of_seasons":null,"number_of_episodes":1,"created_at":"2026-05-02T08:49:30.887569+00:00","updated_at":"2026-05-02T08:49:30.845+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Kyoto Animation"},{"name":"Animation Do"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2010-02-06","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Alternate Universe"},{"id":2,"name":"Primarily Teen Cast"},{"id":3,"name":"Memory Manipulation"},{"id":4,"name":"Philosophy"},{"id":5,"name":"Kuudere"},{"id":6,"name":"Male Protagonist"},{"id":7,"name":"Coming of Age"},{"id":8,"name":"Snowscape"},{"id":9,"name":"Urban Fantasy"},{"id":10,"name":"School"},{"id":11,"name":"Aliens"},{"id":12,"name":"School Club"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:49:30.887569+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"sim