5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"ReLIFE\",\"description\":\"The story follows Kaizaki Arata, a 27-year-old jobless man, who fails at every job interview he had after quitting his last company. His life changes after he met Yoake Ryou of the ReLife Research Institute, who offered him a drug that can change his appearance to 17-years-old and to become a subject in an experiment for one year. Thus, he begins his life as a high school student once more.\\n\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21049-4AHSLeiDE9eg.png\",\"datePublished\":\"2016-06-24\",\"numberOfEpisodes\":13,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Comedy\",\"Drama\",\"Romance\",\"Slice of Life\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.8,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"8340930d-243b-491b-b58d-e4e6cb8285fb","tmdb_id":21049,"imdb_id":null,"content_type":"anime","title":"ReLIFE","original_title":"ReLIFE","overview":"The story follows Kaizaki Arata, a 27-year-old jobless man, who fails at every job interview he had after quitting his last company. His life changes after he met Yoake Ryou of the ReLife Research Institute, who offered him a drug that can change his appearance to 17-years-old and to become a subject in an experiment for one year. Thus, he begins his life as a high school student once more.\n","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21049-4AHSLeiDE9eg.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21049-PeKXMMYru3Xl.png","release_date":null,"first_air_date":"2016-06-24","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Drama"},{"id":3,"name":"Romance"},{"id":4,"n