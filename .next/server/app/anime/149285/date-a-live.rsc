10:T511,{"@context":"https://schema.org","@type":"TVSeries","name":"Date A Live","description":"Thirty years before a strange phenomena called a \"spacequake\" devastated the center of Eurasia, claiming the lives of at least 150 million people. Since then, smaller spacequakes plague the world on an irregular basis. Shidou Itsuka, a seemingly ordinary high schooler comes across a mysterious girl at the ground zero of a spacequake and learns from his sister Kotori she is one of the \"Spirits\" who are the real cause of the spacequakes that occur when they manifest themselves in the world. He also learns that Kotori is the captain of the airship Ratatoskr and recruits him to make use of his mysterious ability to seal the Spirits' powers and stop them from being a threat to mankind. However, there is a catch: to seal a Spirit, he must make her fall in love with him.<br>\n<br>\n(Source: Anime News Network)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx15583-Sxd2J4RJdRhj.jpg","datePublished":"2013-04-06","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Comedy","Ecchi","Fantasy","Mecha","Romance","Sci-Fi"],"aggregateRating":{"@type":"AggregateRating","ratingValue":6.8,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"19b2094a-b796-44dd-98bd-fc959a336131","tmdb_id":15583,"imdb_id":null,"content_type":"anime","title":"Date A Live","original_title":"デート・ア・ライブ","overview":"Thirty years before a strange phenomena called a \"spacequake\" devastated the center of Eurasia, claiming the lives of at least 150 million people. Since then, smaller spacequakes plague the world on an irregular basis. Shidou Itsuka, a seemingly ordinary high schooler comes across a mysterious girl at the ground zero of a spacequake and learns from his sister Kotori she is one of the \"Spirits\" who are the real cause of the spacequakes that occur when they manifest themselves in the world. He also learns that Kotori is the captain of the airship Ratatoskr and recruits him to make use of his mysterious ability to seal the Spirits' powers and stop them from being a threat to mankind. However, there is a catch: to seal a Spirit, he must make her fall in love with him.<br>\n<br>\n(Source: Anime News Network)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx15583-Sxd2J4RJdRhj.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/15583.jpg","release_date":null,"first_air_date":"2013-04-06","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Comedy"},{"id":3,"name":"Ecchi"},{"id":4,"name":"Fantasy"},{"id":5,"name":"Mecha"},{"id":6,"name":"Romance"},{"id":7,"name":"Sci-Fi"}],"popularity":230688,"vote_average":6.8,"vote_count":null,"runtime":23,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:45:25.953044+00:00","updated_at":"2026-05-02T08:45:25.907+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"AIC Plus+"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2013-06-22","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Heterosexual"},{"id":2,"name":"Female Harem"},{"id":3,"name":"Henshin"},{"id":4,"name":"Male Protagonist"},{"id":5,"name":"Super Power"},{"id":6,"name":"Urban Fantasy"},{"id":7,"name":"Primarily Teen Cast"},{"id":8,"name":"Urban"},{"id":9,"name":"Primarily Female Cast"},{"id":10,"name":"Slapstick"},{"id":11,"name":"Love Triangle"},{"id":12,"name":"Nudity"},{"id":13,"name":"School"},{"id":14,"name":"Kuudere"},{"id":15,"name":"Parody"},{"id":16,"name":"Tsundere"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null