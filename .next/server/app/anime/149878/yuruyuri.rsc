5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"YuruYuri\",\"description\":\"Right after starting middle school, Akari Akaza joins the Amusement Club which is composed solely by her two childhood friends, Kyouko Toshinou and Yui Funami. Chinatsu Yoshikawa, Akaza's classmate, becomes a member after finding out about the dissolution of the Tea Club. <br><br>\\nThe Amusement Club, situated at the tea room facility since the Tea Club disbanded, has no clear purpose, being free for the girls to do whatever they want.<br><br>\\n(Source: Anime News Network)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx10495-FbK4ybSp2DNG.jpg\",\"datePublished\":\"2011-07-05\",\"numberOfEpisodes\":12,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Comedy\",\"Slice of Life\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.3,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"fe7afeea-5f6c-4fb8-815c-48e16607558c","tmdb_id":10495,"imdb_id":null,"content_type":"anime","title":"YuruYuri","original_title":"ゆるゆり","overview":"Right after starting middle school, Akari Akaza joins the Amusement Club which is composed solely by her two childhood friends, Kyouko Toshinou and Yui Funami. Chinatsu Yoshikawa, Akaza's classmate, becomes a member after finding out about the dissolution of the Tea Club. <br><br>\nThe Amusement Club, situated at the tea room facility since the Tea Club disbanded, has no clear purpose, being free for the girls to do whatever they want.<br><br>\n(Source: Anime News Network)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx10495-FbK4ybSp2DNG.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/10495-rIrvOpIurPXE.jpg","release_date":null,"first_air_date":"2011-07-05","status":"published"