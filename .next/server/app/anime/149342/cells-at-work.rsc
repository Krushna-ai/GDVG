5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Cells at Work!\",\"description\":\"The average human body contains about 60 trillion cells, and each of them has work to do! But when you get injured, viruses or bacteria invade, or when an allergic reaction flares up, everyone from the silent but deadly white blood cells to the brainy neurons has to work together to get through the crisis!<br>\\n<br>\\n(Source: Kodansha US)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx100977-nH1J2dR7GGAk.jpg\",\"datePublished\":\"2018-07-08\",\"numberOfEpisodes\":13,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Comedy\",\"Sci-Fi\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.4,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"a5bd7cb6-1746-457c-8dc0-312f0251a18c","tmdb_id":100977,"imdb_id":null,"content_type":"anime","title":"Cells at Work!","original_title":"はたらく細胞","overview":"The average human body contains about 60 trillion cells, and each of them has work to do! But when you get injured, viruses or bacteria invade, or when an allergic reaction flares up, everyone from the silent but deadly white blood cells to the brainy neurons has to work together to get through the crisis!<br>\n<br>\n(Source: Kodansha US)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx100977-nH1J2dR7GGAk.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/n100977-IztHpiaTckCh.jpg","release_date":null,"first_air_date":"2018-07-08","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Comedy"},{"id":3,"name":"Sci-Fi"}],"popularity":194927,"vote_average":7.4,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes"