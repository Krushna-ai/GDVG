10:T510,{"@context":"https://schema.org","@type":"TVSeries","name":"Is It Wrong to Try to Pick Up Girls in a Dungeon? II","description":"The second season of <i>Dungeon ni Deai wo Motomeru no wa Machigatteiru Darou ka</i>.<br>\n<br>\nThere's rarely a dull moment when you're the champion of a tiny Familia, and things only get rougher for Bell when the God Apollo declares war on Hestia and her followers. With Apollo's Familia able to field a hundred times as many men, Hestia will have to work a lot of favors to keep her Familia from being completely destroyed.<br>\n<br>\nEven if Bell and Hestia manage to pull off the impossible, a major debt that Hestia owes is about to come due and Lili's sordid past comes back to haunt her! Which means that when Bell and his friends come to Lili's aid, it sets into motion yet another impending clash of the titans that may destroy everything!<br>\n<br>\n(Source: Sentai Filmworks)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx101167-Yasvj97UR9ue.png","datePublished":"2019-07-13","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Adventure","Comedy","Fantasy","Romance"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.1,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"53ea8822-41e4-4e34-9dd6-8854fe815a94","tmdb_id":101167,"imdb_id":null,"content_type":"anime","title":"Is It Wrong to Try to Pick Up Girls in a Dungeon? II","original_title":"ダンジョンに出会いを求めるのは間違っているだろうかⅡ","overview":"The second season of <i>Dungeon ni Deai wo Motomeru no wa Machigatteiru Darou ka</i>.<br>\n<br>\nThere's rarely a dull moment when you're the champion of a tiny Familia, and things only get rougher for Bell when the God Apollo declares war on Hestia and her followers. With Apollo's Familia able to field a hundred times as many men, Hestia will have to work a lot of favors to keep her Familia from being completely destroyed.<br>\n<br>\nEven if Bell and Hestia manage to pull off the impossible, a major debt that Hestia owes is about to come due and Lili's sordid past comes back to haunt her! Which means that when Bell and his friends come to Lili's aid, it sets into motion yet another impending clash of the titans that may destroy everything!<br>\n<br>\n(Source: Sentai Filmworks)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx101167-Yasvj97UR9ue.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/101167-VirZ21Z7DGZk.jpg","release_date":null,"first_air_date":"2019-07-13","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Adventure"},{"id":3,"name":"Comedy"},{"id":4,"name":"Fantasy"},{"id":5,"name":"Romance"}],"popularity":229022,"vote_average":7.1,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:45:26.44899+00:00","updated_at":"2026-05-02T08:45:26.404+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"J.C.STAFF"},{"name":"EGG FIRM"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2019-09-28","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Male Protagonist"},{"id":2,"name":"Gods"},{"id":3,"name":"Dungeon"},{"id":4,"name":"Magic"},{"id":5,"name":"Swordplay"},{"id":6,"name":"Female Harem"},{"id":7,"name":"Mythology"},{"id":8,"name":"Ensemble Cast"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:45:26.44899+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_