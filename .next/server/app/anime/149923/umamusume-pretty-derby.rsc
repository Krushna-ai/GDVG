10:T4ac,{"@context":"https://schema.org","@type":"TVSeries","name":"Umamusume: Pretty Derby","description":"In a world very much like our own, great race horses of the past have a chance to be reborn as \"horse girls\"—girls with the ears and tails of horses as well as their speed and endurance. The best of these horse girls go to train at Tokyo's Tracen Academy, hopefully moving on to fame and fortune as both racers and idols.<br><br>\nSpecial Week, a high school horse girl from the countryside, has just transferred to Tracen, and she's determined to fulfill her promise to her mother to become the best horse girl in Japan. On her way to school, she takes a pit stop at the race track and instantly falls in love with Silence Suzuka's style, becoming determined to race on the same team as her.<br><br>\n(Source: Anime News Network) ","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx98514-mEh3Gl58AWgc.jpg","datePublished":"2018-04-02","numberOfEpisodes":13,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Slice of Life","Sports"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.3,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"644ec36a-4795-4609-9ed0-a36d01a52703","tmdb_id":98514,"imdb_id":null,"content_type":"anime","title":"Umamusume: Pretty Derby","original_title":"ウマ娘 プリティーダービー","overview":"In a world very much like our own, great race horses of the past have a chance to be reborn as \"horse girls\"—girls with the ears and tails of horses as well as their speed and endurance. The best of these horse girls go to train at Tokyo's Tracen Academy, hopefully moving on to fame and fortune as both racers and idols.<br><br>\nSpecial Week, a high school horse girl from the countryside, has just transferred to Tracen, and she's determined to fulfill her promise to her mother to become the best horse girl in Japan. On her way to school, she takes a pit stop at the race track and instantly falls in love with Silence Suzuka's style, becoming determined to race on the same team as her.<br><br>\n(Source: Anime News Network) ","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx98514-mEh3Gl58AWgc.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/98514-0uYzay4a1iiL.jpg","release_date":null,"first_air_date":"2018-04-02","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Slice of Life"},{"id":3,"name":"Sports"}],"popularity":81595,"vote_average":7.3,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":13,"created_at":"2026-05-02T08:50:56.420192+00:00","updated_at":"2026-05-02T08:50:56.378+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"P.A.WORKS"},{"name":"CygamesPictures"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2018-06-18","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Athletics"},{"id":2,"name":"Kemonomimi"},{"id":3,"name":"Female Protagonist"},{"id":4,"name":"Primarily Teen Cast"},{"id":5,"name":"Primarily Female Cast"},{"id":6,"name":"Cute Girls Doing Cute Things"},{"id":7,"name":"Gambling"},{"id":8,"name":"Boarding School"},{"id":9,"name":"Ensemble Cast"},{"id":10,"name":"Yuri"},{"id":11,"name":"Kuudere"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:50:56.420192+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":35249,"anilist_id":98514}