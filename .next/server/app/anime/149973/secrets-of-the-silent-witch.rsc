5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Secrets of the Silent Witch\",\"description\":\"Monica Everett, the Silent Witch, is the world’s only practitioner of Voiceless Magic, a veritable heroine who single-handedly fended off the Black Dragon of legend. However, the young prodigy is actually…super-duper shy! Yup, turns out she only learned Voiceless Magic to avoid speaking in public. Ignorant of this, the Seven Sages have placed her on a top-secret mission to guard the Second Prince. Can Monica keep it together as she contends with both social interaction and the evils targeting the young royal?\\n<br><br>(Source: Yen Press, edited)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx179966-g0EU7rVe2Og7.jpg\",\"datePublished\":\"2025-07-05\",\"numberOfEpisodes\":13,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Adventure\",\"Fantasy\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.1,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"a599ac44-67e1-4c63-af29-b1ad23095c8f","tmdb_id":179966,"imdb_id":null,"content_type":"anime","title":"Secrets of the Silent Witch","original_title":"サイレント・ウィッチ 沈黙の魔女の隠しごと","overview":"Monica Everett, the Silent Witch, is the world’s only practitioner of Voiceless Magic, a veritable heroine who single-handedly fended off the Black Dragon of legend. However, the young prodigy is actually…super-duper shy! Yup, turns out she only learned Voiceless Magic to avoid speaking in public. Ignorant of this, the Seven Sages have placed her on a top-secret mission to guard the Second Prince. Can Monica keep it together as she contends with both social interaction and the evils targeting the young royal?\n<br><br>(Source: Yen Press, edited)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx179966-g0EU7rVe2Og7.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/179966-hf71VrF1zhPM.jpg","release_date":null,"first_air_date":"2025-07-05","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Adventure"},{"id":2,"name":"Fantasy"}],"popularity":77590,"vote_average":8.1,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":13,"created_at":"2026-05-02T08:51:06.543202+00:00","updated_at":"2026-05-02T08:51:06.502+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Studio Gokumi"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2025-10-05","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Female Protagonist"},{"id":2,"name":"Magic"},{"id":3,"name":"School"},{"id":4,"name":"Witch"},{"id":5,"name":"Royal Affairs"},{"id":6,"name":"Primarily Teen Cast"},{"id":7,"name":"Hikikomori"},{"id":8,"name":"Coming of Age"},{"id":9,"name":"Politics"},{"id":10,"name":"Ojou-sama"},{"id":11,"name":"Class Struggle"},{"id":12,"name":"Disability"},{"id":13,"name":"Bullying"},{"id":14,"name":"Medieval"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:51:06.543202+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":59459,"anilist_id":179966},"social_ids":{"mal":"https://myanimelist.net/anime/59459","anilist":"https://anilist.co/anime/179966"},"gdvg_id":149973,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accola