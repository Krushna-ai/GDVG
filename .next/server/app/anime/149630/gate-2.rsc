10:T55e,{"@context":"https://schema.org","@type":"TVSeries","name":"Gate 2","description":"The second half of the <i>Gate: Jieitai Kanochi nite, Kaku Tatakaeri</i> anime which will cover the Fire Dragon Arc.\n<br><br>\nSeveral months have passed since the infamous Ginza Incident, with tensions between the Empire and JSDF escalating in the vast and mysterious \"Special Region\" over peace negotiations. The greed and curiosity of the global powers have also begun to grow, as reports about the technological limitations of the magical realm's archaic civilizations come to light.\n<br><br>\nMeanwhile, Lieutenant Youji Itami and his merry band of female admirers struggle to navigate the complex political intrigue that plagues the Empire's court. Despite her best efforts, Princess Piña Co Lada faces difficulties attempting to convince her father that the JSDF has no intention of conquering their kingdom. Pressured from both sides of the Gate, Itami must consider even more drastic measures to fulfill his mission.\n","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21364-6ikYd5J46dt0.jpg","datePublished":"2016-01-09","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Adventure","Fantasy"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.5,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"433f8c24-6787-47f8-bfcd-5193fdb81b81","tmdb_id":21364,"imdb_id":null,"content_type":"anime","title":"Gate 2","original_title":"GATE 自衛隊 彼の地にて、斯く戦えり 第2クール","overview":"The second half of the <i>Gate: Jieitai Kanochi nite, Kaku Tatakaeri</i> anime which will cover the Fire Dragon Arc.\n<br><br>\nSeveral months have passed since the infamous Ginza Incident, with tensions between the Empire and JSDF escalating in the vast and mysterious \"Special Region\" over peace negotiations. The greed and curiosity of the global powers have also begun to grow, as reports about the technological limitations of the magical realm's archaic civilizations come to light.\n<br><br>\nMeanwhile, Lieutenant Youji Itami and his merry band of female admirers struggle to navigate the complex political intrigue that plagues the Empire's court. Despite her best efforts, Princess Piña Co Lada faces difficulties attempting to convince her father that the JSDF has no intention of conquering their kingdom. Pressured from both sides of the Gate, Itami must consider even more drastic measures to fulfill his mission.\n","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21364-6ikYd5J46dt0.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21364-e2myFtThuuVC.jpg","release_date":null,"first_air_date":"2016-01-09","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Adventure"},{"id":3,"name":"Fantasy"}],"popularity":118107,"vote_average":7.5,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:49:57.835492+00:00","updated_at":"2026-05-02T08:49:57.795+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"A-1 Pictures"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2016-03-26","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Military"},{"id":2,"name":"Alternate Universe"},{"id":3,"name":"Isekai"},{"id":4,"name":"Politics"},{"id":5,"name":"Male Protagonist"},{"id":6,"name":"War"},{"id":7,"name":"Primarily Adult Cast"},{"id":8,"name":"Primarily Female Cast"},{"id":9,"name":"Dragons"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported