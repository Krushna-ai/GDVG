10:T51c,{"@context":"https://schema.org","@type":"TVSeries","name":"IRODUKU: The World in Colors","description":"Hitomi Tsukishiro may be the child of a family of witches, but after losing her ability to see color, she also lost her sense of magic. Nothing has been able to help her regain that gift — nothing until Hitomi’s grandmother, that is, sends Hitomi back in time to the year 2018! There Hitomi meets her grandmother’s younger self. She also discovers fascinating drawings of a young man named Yuito Aoi. The moment Hitomi lays eyes on his work, colors flood back into view. But why do his drawings have this effect on Hitomi, and for what purpose has her grandmother sent her so far back in time? As Hitomi’s feelings for Yuito grow, she finds herself poised on the cusp of personal transformation, color and magic returning as she blossoms into the young woman she’s meant to be.<br><br>\n\n(Source: Sentai Filmworks)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx101316-yI1ZvMrsDUn9.png","datePublished":"2018-10-06","numberOfEpisodes":13,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Romance","Slice of Life","Supernatural"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.3,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"9ccc958d-0a77-4b64-822a-feee45237764","tmdb_id":101316,"imdb_id":null,"content_type":"anime","title":"IRODUKU: The World in Colors","original_title":"色づく世界の明日から","overview":"Hitomi Tsukishiro may be the child of a family of witches, but after losing her ability to see color, she also lost her sense of magic. Nothing has been able to help her regain that gift — nothing until Hitomi’s grandmother, that is, sends Hitomi back in time to the year 2018! There Hitomi meets her grandmother’s younger self. She also discovers fascinating drawings of a young man named Yuito Aoi. The moment Hitomi lays eyes on his work, colors flood back into view. But why do his drawings have this effect on Hitomi, and for what purpose has her grandmother sent her so far back in time? As Hitomi’s feelings for Yuito grow, she finds herself poised on the cusp of personal transformation, color and magic returning as she blossoms into the young woman she’s meant to be.<br><br>\n\n(Source: Sentai Filmworks)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx101316-yI1ZvMrsDUn9.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/n101316-UpEVwWWyOx1i.jpg","release_date":null,"first_air_date":"2018-10-06","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Romance"},{"id":3,"name":"Slice of Life"},{"id":4,"name":"Supernatural"}],"popularity":94347,"vote_average":7.3,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":13,"created_at":"2026-05-02T08:50:32.962685+00:00","updated_at":"2026-05-02T08:50:32.922+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"P.A.WORKS"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2018-12-29","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Magic"},{"id":2,"name":"Female Protagonist"},{"id":3,"name":"Time Manipulation"},{"id":4,"name":"Ensemble Cast"},{"id":5,"name":"School Club"},{"id":6,"name":"Photography"},{"id":7,"name":"Drawing"},{"id":8,"name":"Rehabilitation"},{"id":9,"name":"School"},{"id":10,"name":"Coming of Age"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:50:32.962685+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle