5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"TSUKIMICHI -Moonlit Fantasy- Season 2\",\"description\":\"The second season of <i>Tsuki ga Michibiku Isekai Douchuu</i>.<br>\\n<br>\\nAfter Makoto Misumi defeats Mitsurugi and Sofia Bulga, humanity is saved from the attacking demon army—for the time being. The goddess is aware of Makoto’s growing power, and she sees him as less of a nuisance and more of a rival. Makoto continues his journey to further expand his community of outcasts and connect with more hyumans. But will he be strong enough to hold off the coming storm?<br>\\n<br>\\n(Source: Crunchyroll)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx139518-GZWYKM8Kg1S2.png\",\"datePublished\":\"2024-01-08\",\"numberOfEpisodes\":25,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Adventure\",\"Comedy\",\"Fantasy\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.8,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"32bacbf2-ec24-4761-8593-a6109ac4a9dc","tmdb_id":139518,"imdb_id":null,"content_type":"anime","title":"TSUKIMICHI -Moonlit Fantasy- Season 2","original_title":"月が導く異世界道中 第二幕","overview":"The second season of <i>Tsuki ga Michibiku Isekai Douchuu</i>.<br>\n<br>\nAfter Makoto Misumi defeats Mitsurugi and Sofia Bulga, humanity is saved from the attacking demon army—for the time being. The goddess is aware of Makoto’s growing power, and she sees him as less of a nuisance and more of a rival. Makoto continues his journey to further expand his community of outcasts and connect with more hyumans. But will he be strong enough to hold off the coming storm?<br>\n<br>\n(Source: Crunchyroll)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx139518-GZWYKM8Kg1S2.png","backdrop_path":"https://s4.ani