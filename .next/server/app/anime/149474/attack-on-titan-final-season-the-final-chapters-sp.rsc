5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Attack on Titan Final Season THE FINAL CHAPTERS Special 2\",\"description\":\"Eren, as the Founding Titan, advances on Fort Salta with countless other Titans. Appearing before the refugees, who stand on the brink of despair, are Mikasa, Armin, Jean, Conny, Reiner, Pieck, and Levi, who narrowly escaped from the rumbling. The battle between former comrades and childhood friends with Eren concludes here.\\n<br><br>\\n(Source: Crunchyroll)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx162314-qIWdAAFtvY8J.jpg\",\"datePublished\":\"2023-11-05\",\"numberOfEpisodes\":1,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Drama\",\"Fantasy\",\"Psychological\",\"Romance\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.7,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"e45c4f4c-a2b1-4c2e-89d8-a41ff91d930a","tmdb_id":162314,"imdb_id":null,"content_type":"anime","title":"Attack on Titan Final Season THE FINAL CHAPTERS Special 2","original_title":"進撃の巨人 The Final Season完結編 後編","overview":"Eren, as the Founding Titan, advances on Fort Salta with countless other Titans. Appearing before the refugees, who stand on the brink of despair, are Mikasa, Armin, Jean, Conny, Reiner, Pieck, and Levi, who narrowly escaped from the rumbling. The battle between former comrades and childhood friends with Eren concludes here.\n<br><br>\n(Source: Crunchyroll)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx162314-qIWdAAFtvY8J.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/162314-N5M4XMz6O1j4.jpg","release_date":null,"first_air_date":"2023-11-05","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"A