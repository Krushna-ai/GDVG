9:{"metadata":[["$","title","0",{"children":"The Hidden Dungeon Only I Can Enter | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"The Hidden Dungeon is a place of legend where rare treasures and items are hidden. Noir, the third son of an impoverished noble family who's lost the one job offer he had, was lucky enough to hear about this dungeon. He then acquires a skill that allows him to create, bestow, and edit skills... and in order to use it, he needs to accumulate points by carrying out such tasks as eating delicious meals and doing sexual things with alluring members of the opposite sex.<br>\n<br>\n(Source: Crunchyroll)"}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/anime/149637/the-hidden-dungeon-only-i-can-enter"}],["$","meta","5",{"property":"og:title","content":"The Hidden Dungeon Only I Can Enter"}],["$","meta","6",{"property":"og:description","content":"The Hidden Dungeon is a place of legend where rare treasures and items are hidden. Noir, the third son of an impoverished noble family who's lost the one job offer he had, was lucky enough to hear about this dungeon. He then acquires a skill that allows him to create, bestow, and edit skills... and in order to use it, he needs to accumulate points by carrying out such tasks as eating delicious meals and doing sexual things with alluring members of the opposite sex.<br>\n<br>\n(Source: Crunchyroll)"}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/anime/149637/the-hidden-dungeon-only-i-can-enter"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx118375-95ClbAh2EQMD.jpg"}],["$","meta","9",{"property":"og:type","content":"video.tv_show"}],["$","meta","10"