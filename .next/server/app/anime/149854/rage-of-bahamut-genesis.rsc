5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"Rage of Bahamut: Genesis\",\"description\":\"Mistarcia is a magical world where humans, gods, and demons mingle together. In the past, the black-and-silver winged Bahamut has threatened to destroy the land, but humans, gods, and demons overcame their differences to fight together and seal its power. The key to that seal was split in two, one half given to the gods and the other to demons, so that they would never be united and Bahamut never released. Now, two thousand years later, the world is in an era of peace—until the day a human woman steals the gods' half of the key.\\r\\n\\r\\n\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20590-LuMDAd75Kg3C.jpg\",\"datePublished\":\"2014-10-06\",\"numberOfEpisodes\":12,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Adventure\",\"Fantasy\",\"Supernatural\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.4,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"95d7e1d8-4e3d-410a-a6db-c411e23bfb5d","tmdb_id":20590,"imdb_id":null,"content_type":"anime","title":"Rage of Bahamut: Genesis","original_title":"神撃のバハムート GENESIS","overview":"Mistarcia is a magical world where humans, gods, and demons mingle together. In the past, the black-and-silver winged Bahamut has threatened to destroy the land, but humans, gods, and demons overcame their differences to fight together and seal its power. The key to that seal was split in two, one half given to the gods and the other to demons, so that they would never be united and Bahamut never released. Now, two thousand years later, the world is in an era of peace—until the day a human woman steals the gods' half of the key.\r\n\r\n","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20590-LuMDAd75Kg3C.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/20590-UAwdqOHKvENl.jpg","release_date":null,"first_air_date":"2014-10-06","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Adventure"},{"id":3,"name":"Fantasy"},{"id":4,"name":"Supernatural"}],"popularity":87919,"vote_average":7.4,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:50:43.463078+00:00","updated_at":"2026-05-02T08:50:43.421+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"MAPPA"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2014-12-29","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Magic"},{"id":2,"name":"Primarily Adult Cast"},{"id":3,"name":"Demons"},{"id":4,"name":"Angels"},{"id":5,"name":"Gods"},{"id":6,"name":"Medieval"},{"id":7,"name":"Travel"},{"id":8,"name":"Fugitive"},{"id":9,"name":"Male Protagonist"},{"id":10,"name":"Female Protagonist"},{"id":11,"name":"Ensemble Cast"},{"id":12,"name":"Dragons"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:50:43.463078+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":21843,"anilist_id":20590},"social_ids":{"mal":"https://myanimelist.net/anime/21843","anilist":"https://anilist.co/anime/20590"},"gdvg_id":149854,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates"