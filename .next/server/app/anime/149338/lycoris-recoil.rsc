10:T4b6,{"@context":"https://schema.org","@type":"TVSeries","name":"Lycoris Recoil","description":"“LycoReco” is a café with a traditional Japanese twist located in downtown Tokyo. But the delicious coffee and sugary sweets are not the only orders this café takes! From delivering packages short distances, to pick-ups and drop-offs on the lonely streets at night, to zombies and giant monster extermination…?! Whatever your problem, we're here to help! We will solve any kind of \"trouble\" you may have!<br>\n<br>\nWaiting for you are the ever-smiling poster-girl and the cool, serious newcomer. A petite girl who never wants to work and a young woman approaching thirty who wants to get married. And the manager is a nice guy who’s obsessed with Japan!<br>\n<br>\nWhatever your order is, leave it all up to us♪<br><br>\n\n(Source: Official Site)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx143270-rfkyiYXhek5w.jpg","datePublished":"2022-07-02","numberOfEpisodes":13,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Slice of Life"],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.1,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"99dbddda-ed58-45f6-acaf-0212fe3c98b8","tmdb_id":143270,"imdb_id":null,"content_type":"anime","title":"Lycoris Recoil","original_title":"リコリス・リコイル","overview":"“LycoReco” is a café with a traditional Japanese twist located in downtown Tokyo. But the delicious coffee and sugary sweets are not the only orders this café takes! From delivering packages short distances, to pick-ups and drop-offs on the lonely streets at night, to zombies and giant monster extermination…?! Whatever your problem, we're here to help! We will solve any kind of \"trouble\" you may have!<br>\n<br>\nWaiting for you are the ever-smiling poster-girl and the cool, serious newcomer. A petite girl who never wants to work and a young woman approaching thirty who wants to get married. And the manager is a nice guy who’s obsessed with Japan!<br>\n<br>\nWhatever your order is, leave it all up to us♪<br><br>\n\n(Source: Official Site)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx143270-rfkyiYXhek5w.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/143270-Ivjs2nVpARtS.jpg","release_date":null,"first_air_date":"2022-07-02","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Slice of Life"}],"popularity":195809,"vote_average":8.1,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":13,"created_at":"2026-05-02T08:48:54.637183+00:00","updated_at":"2026-05-02T08:48:54.595+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"A-1 Pictures"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2022-09-24","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Female Protagonist"},{"id":2,"name":"Primarily Female Cast"},{"id":3,"name":"Guns"},{"id":4,"name":"Urban"},{"id":5,"name":"Yuri"},{"id":6,"name":"Found Family"},{"id":7,"name":"LGBTQ+ Themes"},{"id":8,"name":"Work"},{"id":9,"name":"Kuudere"},{"id":10,"name":"Orphan"},{"id":11,"name":"Restaurant"},{"id":12,"name":"Cute Girls Doing Cute Things"},{"id":13,"name":"Ensemble Cast"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:48:54.637183+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":50709,"anilist_id":143270},"socia