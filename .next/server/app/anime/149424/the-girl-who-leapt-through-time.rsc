5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"The Girl Who Leapt Through Time\",\"description\":\"The power to travel through time... It can be used for the good of humanity, or just selfishly abused. While many may fantasize about obtaining such a power, it has become nothing less than reality for otherwise-normal schoolgirl Konno Makoto.<br><br>\\nAfter a fated event, her life takes a turn for the extraordinary. Though she initially uses her power to literally \\\"leap\\\" into the past and change little things in order to make her life easier, she soon has to face the fact that changing the past can have drastic consequences.\\n\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx2236-tH5fWFkHyVGg.png\",\"datePublished\":\"2006-07-15\",\"numberOfEpisodes\":1,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Drama\",\"Romance\",\"Sci-Fi\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.8,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"eeff388e-1241-4615-929d-bd16290716f2","tmdb_id":2236,"imdb_id":null,"content_type":"anime","title":"The Girl Who Leapt Through Time","original_title":"時をかける少女","overview":"The power to travel through time... It can be used for the good of humanity, or just selfishly abused. While many may fantasize about obtaining such a power, it has become nothing less than reality for otherwise-normal schoolgirl Konno Makoto.<br><br>\nAfter a fated event, her life takes a turn for the extraordinary. Though she initially uses her power to literally \"leap\" into the past and change little things in order to make her life easier, she soon has to face the fact that changing the past can have drastic consequences.\n","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx2236-tH5fWFkHyVGg.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/2236-rY0fvv53JIOB.jpg","release_date":null,"first_air_date":"2006-07-15","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Romance"},{"id":3,"name":"Sci-Fi"}],"popularity":167136,"vote_average":7.8,"vote_count":null,"runtime":97,"number_of_seasons":null,"number_of_episodes":1,"created_at":"2026-05-02T08:49:11.368188+00:00","updated_at":"2026-05-02T08:49:11.325+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"MADHOUSE"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2006-07-15","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Time Manipulation"},{"id":2,"name":"Coming of Age"},{"id":3,"name":"Female Protagonist"},{"id":4,"name":"Heterosexual"},{"id":5,"name":"School"},{"id":6,"name":"Primarily Teen Cast"},{"id":7,"name":"Tomboy"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:49:11.368188+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":2236,"anilist_id":2236},"social_ids":{"mal":"https://myanimelist.net/anime/2236","anilist":"https://anilist.co/anime/2236"},"gdvg_id":149424,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"release_dates":null,"aggregate_credits":null,"original_network":null,"screenwriters":null,"based_on":null,"filming_location":null,"narrative_location":null,"review_score_rt":null,"review_score_mc":null,"box_