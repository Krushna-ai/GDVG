5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"MUSHI-SHI\",\"description\":\"Neither good nor evil, they are life in its purest form. Vulgar and strange, they have inspired fear in humans since the dawn of time and have, over the ages, come to be known as \\\"mushi.\\\" The stories of the Mushi and the people they affect are all linked together by a traveling Mushi-shi, or \\\"Mushi Master,\\\" who seeks rare Mushi sightings and uses his shaman-like knowledge of Mushi to help the affected people.<br>\\n<br>\\nWhat are the Mushi and what do they want?<br>\\n<br>\\n(Source: Funimation)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx457-l6cTtNgI9Bi6.png\",\"datePublished\":\"2005-10-23\",\"numberOfEpisodes\":26,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Adventure\",\"Fantasy\",\"Mystery\",\"Psychological\",\"Slice of Life\",\"Supernatural\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.5,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"8e16cb37-18c2-402c-b5f6-fd9455fabd5f","tmdb_id":457,"imdb_id":null,"content_type":"anime","title":"MUSHI-SHI","original_title":"蟲師","overview":"Neither good nor evil, they are life in its purest form. Vulgar and strange, they have inspired fear in humans since the dawn of time and have, over the ages, come to be known as \"mushi.\" The stories of the Mushi and the people they affect are all linked together by a traveling Mushi-shi, or \"Mushi Master,\" who seeks rare Mushi sightings and uses his shaman-like knowledge of Mushi to help the affected people.<br>\n<br>\nWhat are the Mushi and what do they want?<br>\n<br>\n(Source: Funimation)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx457-l6cTtNgI9Bi6.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn