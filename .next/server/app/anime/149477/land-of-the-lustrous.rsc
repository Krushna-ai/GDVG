10:T54f,{"@context":"https://schema.org","@type":"TVSeries","name":"Land of the Lustrous","description":"In the mysterious future, crystalline organisms called Gems inhabit a world that has been destroyed by six meteors. Each Gem is assigned a role in order to fight against the Lunarians, a species who attacks them in order to shatter their bodies and use them as decorations.<br>\n<br>\nPhosphophyllite, also known as Phos, is a young and fragile Gem who dreams of helping their friends in the war effort. Instead, they are told to compile an encyclopedia because of their delicate condition. After begrudgingly embarking on this task, Phos meets Cinnabar, an intelligent gem who has been relegated to patrolling the isolated island at night because of the corrosive poison their body creates. After seeing how unhappy Cinnabar is, Phos decides to find a role that both of the rejected Gems can enjoy. Houseki no Kuni follows Phos' efforts to be useful and protect their fellow Gems.","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx98707-25nUKb4XUFgY.png","datePublished":"2017-10-07","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Drama","Fantasy","Mystery","Psychological"],"aggregateRating":{"@type":"AggregateRating","ratingValue":8.3,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"905e029f-f8b0-4f0c-bb38-ba93183c3dd3","tmdb_id":98707,"imdb_id":null,"content_type":"anime","title":"Land of the Lustrous","original_title":"宝石の国","overview":"In the mysterious future, crystalline organisms called Gems inhabit a world that has been destroyed by six meteors. Each Gem is assigned a role in order to fight against the Lunarians, a species who attacks them in order to shatter their bodies and use them as decorations.<br>\n<br>\nPhosphophyllite, also known as Phos, is a young and fragile Gem who dreams of helping their friends in the war effort. Instead, they are told to compile an encyclopedia because of their delicate condition. After begrudgingly embarking on this task, Phos meets Cinnabar, an intelligent gem who has been relegated to patrolling the isolated island at night because of the corrosive poison their body creates. After seeing how unhappy Cinnabar is, Phos decides to find a role that both of the rejected Gems can enjoy. Houseki no Kuni follows Phos' efforts to be useful and protect their fellow Gems.","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx98707-25nUKb4XUFgY.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/98707-ZcFGfUAS4YwK.jpg","release_date":null,"first_air_date":"2017-10-07","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Drama"},{"id":3,"name":"Fantasy"},{"id":4,"name":"Mystery"},{"id":5,"name":"Psychological"}],"popularity":152318,"vote_average":8.3,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:49:25.157715+00:00","updated_at":"2026-05-02T08:49:25.115+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Orange"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2017-12-23","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Coming of Age"},{"id":2,"name":"CGI"},{"id":3,"name":"Full CGI"},{"id":4,"name":"Philosophy"},{"id":5,"name":"Anthropomorphism"},{"id":6,"name":"Agender"},{"id":7,"name":"Seinen"},{"id":8,"name":"Primarily Female Cast"},{"id":9,"name":"Survival"},{"id":10,"name":"Coastal"},{"id":11,"name":"Swordplay"},{"id":12,"name":"War"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id"