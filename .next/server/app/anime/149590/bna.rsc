10:T4b2,{"@context":"https://schema.org","@type":"TVSeries","name":"BNA","description":"In the 21st century, the existence of animal-humans came to light after being hidden in the darkness of history. Michiru lived life as a normal human, until one day she suddenly turns into a tanuki-human. She runs away and takes refuge in a special city area called \"Anima City\" that was set up 10 years ago for animal-humans to be able to live as themselves. There Michiru meets Shirou, a wolf-human who hates humans. Through Shirou, Michiru starts to learn about the worries, lifestyle, and joys of the animal-humans. As Michiru and Shirou try to learn why Michiru suddenly turned into an animal-human, they unexpectedly get wrapped up in a large incident.\n<br><br>\n(Source: Anime News Network)\n<br><br>\n<i>Note: The TV broadcast ended on June 25, 2020.</i>","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx110354-JJKR42frJABe.jpg","datePublished":"2020-03-21","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Comedy","Fantasy"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.2,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"214ba5e1-2574-4753-8fdc-fbdf440aa097","tmdb_id":110354,"imdb_id":null,"content_type":"anime","title":"BNA","original_title":"BNA ビー・エヌ・エー","overview":"In the 21st century, the existence of animal-humans came to light after being hidden in the darkness of history. Michiru lived life as a normal human, until one day she suddenly turns into a tanuki-human. She runs away and takes refuge in a special city area called \"Anima City\" that was set up 10 years ago for animal-humans to be able to live as themselves. There Michiru meets Shirou, a wolf-human who hates humans. Through Shirou, Michiru starts to learn about the worries, lifestyle, and joys of the animal-humans. As Michiru and Shirou try to learn why Michiru suddenly turned into an animal-human, they unexpectedly get wrapped up in a large incident.\n<br><br>\n(Source: Anime News Network)\n<br><br>\n<i>Note: The TV broadcast ended on June 25, 2020.</i>","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx110354-JJKR42frJABe.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/110354-F4KigAURY8zf.jpg","release_date":null,"first_air_date":"2020-03-21","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Comedy"},{"id":3,"name":"Fantasy"}],"popularity":124941,"vote_average":7.2,"vote_count":null,"runtime":23,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:49:48.591315+00:00","updated_at":"2026-05-02T08:49:48.547+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"TRIGGER"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2020-05-06","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Animals"},{"id":2,"name":"Shapeshifting"},{"id":3,"name":"Anthropomorphism"},{"id":4,"name":"Kemonomimi"},{"id":5,"name":"Conspiracy"},{"id":6,"name":"Female Protagonist"},{"id":7,"name":"Urban Fantasy"},{"id":8,"name":"Politics"},{"id":9,"name":"Detective"},{"id":10,"name":"Cult"},{"id":11,"name":"Class Struggle"},{"id":12,"name":"Dystopian"},{"id":13,"name":"Tomboy"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:49:48.591315+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":40060,"anil