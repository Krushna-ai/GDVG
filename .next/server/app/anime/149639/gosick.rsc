10:T5be,{"@context":"https://schema.org","@type":"TVSeries","name":"Gosick","description":"Kazuya Kujou is a foreign student at Saint Marguerite Academy, a luxurious boarding school in the Southern European country of Sauville. Originally from Japan, his jet-black hair and dark brown eyes cause his peers to shun him and give him the nickname \"Black Reaper,\" based on a popular urban legend about the traveler who brings death in the spring.\n<br><br>\nOn a day like any other, Kujou visits the school's extravagant library in search of ghost stories. However, his focus soon changes as he becomes curious about a golden strand of hair on the stairs. The steps lead him to a large garden and a beautiful doll-like girl known as Victorique de Blois, whose complex and imaginative foresight allows her to predict their futures, now intertwined.\n<br><br>\nWith more mysteries quickly developing—including the appearance of a ghost ship and an alchemist with the power of transmutation—Victorique and Kujou, bound by fate and their unique skills, have no choice but to rely on each other.<br><br>\n(Source: MAL Rewrite)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/nx8425-Bn14ayPjnq9o.jpg","datePublished":"2011-01-08","numberOfEpisodes":24,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Mystery","Romance"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.7,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"d4b8a93e-0211-4a73-9eab-169c11139bc3","tmdb_id":8425,"imdb_id":null,"content_type":"anime","title":"Gosick","original_title":"GOSICK","overview":"Kazuya Kujou is a foreign student at Saint Marguerite Academy, a luxurious boarding school in the Southern European country of Sauville. Originally from Japan, his jet-black hair and dark brown eyes cause his peers to shun him and give him the nickname \"Black Reaper,\" based on a popular urban legend about the traveler who brings death in the spring.\n<br><br>\nOn a day like any other, Kujou visits the school's extravagant library in search of ghost stories. However, his focus soon changes as he becomes curious about a golden strand of hair on the stairs. The steps lead him to a large garden and a beautiful doll-like girl known as Victorique de Blois, whose complex and imaginative foresight allows her to predict their futures, now intertwined.\n<br><br>\nWith more mysteries quickly developing—including the appearance of a ghost ship and an alchemist with the power of transmutation—Victorique and Kujou, bound by fate and their unique skills, have no choice but to rely on each other.<br><br>\n(Source: MAL Rewrite)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/nx8425-Bn14ayPjnq9o.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/8425-Lf6WLBHfOdRQ.jpg","release_date":null,"first_air_date":"2011-01-08","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Mystery"},{"id":3,"name":"Romance"}],"popularity":117038,"vote_average":7.7,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":24,"created_at":"2026-05-02T08:49:59.374305+00:00","updated_at":"2026-05-02T08:49:59.328+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"bones"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2011-07-02","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Detective"},{"id":2,"name":"Crime"},{"id":3,"name":"Foreign"},{"id":4,"name":"Historical"},{"id":5,"name":"Female Protagonist"},{"id":6,"name":"Heterosexual"},{"id":7,"name":"Male Protagonist"},{"id":8,"name":"Tsundere"},{"id":9,"name":"Guns"}],"alternative_titles":null,"videos":[],"watch_providers":nul