10:T53b,{"@context":"https://schema.org","@type":"TVSeries","name":"Bubble","description":"In a Tokyo where gravity has broken, a boy and a girl are drawn to each other...<br>\n<br>\nThe story is set in Tokyo, after bubbles that broke the laws of gravity rained down upon the world. Cut off from the outside world, Tokyo has become a playground for a group of young people who have lost their families, acting as a battlefield for parkour team battles as they leap from building to building. Hibiki, a young ace known for his dangerous play style, makes a reckless move one day and plummets into the gravity-bending sea. His life is saved by Uta, a girl with mysterious powers. The pair then hear a unique sound audible only to them. Why did Uta appear before Hibiki? Their encounter leads to a revelation that will change the world.<br>\n<br>\n(Source: Netflix)<br>\n<br>\n<i>Note: The anime released on Netflix on April 28, 2022. It screened in theaters on May 13, 2022.</i>","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx142455-5cBnV4rz5ISf.jpg","datePublished":"2022-04-28","numberOfEpisodes":1,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Romance","Sci-Fi","Sports","Supernatural"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.1,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"547284ae-2436-41a7-9afd-d404e745c17a","tmdb_id":142455,"imdb_id":null,"content_type":"anime","title":"Bubble","original_title":"バブル","overview":"In a Tokyo where gravity has broken, a boy and a girl are drawn to each other...<br>\n<br>\nThe story is set in Tokyo, after bubbles that broke the laws of gravity rained down upon the world. Cut off from the outside world, Tokyo has become a playground for a group of young people who have lost their families, acting as a battlefield for parkour team battles as they leap from building to building. Hibiki, a young ace known for his dangerous play style, makes a reckless move one day and plummets into the gravity-bending sea. His life is saved by Uta, a girl with mysterious powers. The pair then hear a unique sound audible only to them. Why did Uta appear before Hibiki? Their encounter leads to a revelation that will change the world.<br>\n<br>\n(Source: Netflix)<br>\n<br>\n<i>Note: The anime released on Netflix on April 28, 2022. It screened in theaters on May 13, 2022.</i>","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx142455-5cBnV4rz5ISf.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/142455-HCT4izfAzmcw.jpg","release_date":null,"first_air_date":"2022-04-28","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Romance"},{"id":2,"name":"Sci-Fi"},{"id":3,"name":"Sports"},{"id":4,"name":"Supernatural"}],"popularity":85575,"vote_average":7.1,"vote_count":null,"runtime":100,"number_of_seasons":null,"number_of_episodes":1,"created_at":"2026-05-02T08:50:50.186081+00:00","updated_at":"2026-05-02T08:50:50.143+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"WIT STUDIO"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2022-04-28","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Parkour"},{"id":2,"name":"Male Protagonist"},{"id":3,"name":"Post-Apocalyptic"},{"id":4,"name":"Urban Fantasy"},{"id":5,"name":"Female Protagonist"},{"id":6,"name":"Heterosexual"},{"id":7,"name":"Primarily Teen Cast"},{"id":8,"name":"Urban"},{"id":9,"name":"Dystopian"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:50:50.186081+00:00","region":null,"main_poster"