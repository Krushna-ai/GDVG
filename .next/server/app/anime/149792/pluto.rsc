5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"PLUTO\",\"description\":\"A murder occurs in an orderly world where robots are unable to kill humans. The robotic Europol investigator Gesicht takes the case, but the mystery deepens when he finds no trace of a human at the scene of the crime. As he pursues the truth, Gesicht uncovers the most evil manifestation of hate that history has ever seen, one that is bent on bringing destruction to the world ...<br>\\n<br>\\n(Source: Netflix)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx99088-LTJskMD1wbbQ.png\",\"datePublished\":\"2023-10-26\",\"numberOfEpisodes\":8,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Drama\",\"Mecha\",\"Mystery\",\"Psychological\",\"Sci-Fi\",\"Thriller\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":8.4,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"96534ef3-00f1-4016-81f6-4f9c89ca86dd","tmdb_id":99088,"imdb_id":null,"content_type":"anime","title":"PLUTO","original_title":"PLUTO","overview":"A murder occurs in an orderly world where robots are unable to kill humans. The robotic Europol investigator Gesicht takes the case, but the mystery deepens when he finds no trace of a human at the scene of the crime. As he pursues the truth, Gesicht uncovers the most evil manifestation of hate that history has ever seen, one that is bent on bringing destruction to the world ...<br>\n<br>\n(Source: Netflix)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx99088-LTJskMD1wbbQ.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/99088-KFYEoH7jCF0b.jpg","release_date":null,"first_air_date":"2023-10-26","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"}