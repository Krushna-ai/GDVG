10:T566,{"@context":"https://schema.org","@type":"TVSeries","name":"My Happy Marriage","description":"Despite being born into a noble family, Miyo lost her birth mother at a young age and grew up being abused by her stepmother, stepsister, and father.<br>\n<br>\nWhen she finally receives news that she's to be married off, she finds out that her husband-to-be is Kiyoka, a soldier with a reputation for being cruel and heartless. In fact, he's had numerous previous fiancées who have all fled his household; none lasting even a mere three days. <br><br> Resigned to the fact that her family had abandoned her, Miyo knocks on the gate of the Kudou household to find herself greeted by a beautiful man with pale skin. Despite the poor treatment she receives from her husband-to-be during their first meeting, Miyo is unable to return to her old home and spends her time cooking and doing chores. However, as the days pass, Miyo and Kiyoka being to slowly open their hearts to each other... <br>\n<br>\n(Source: KADOKAWA, edited)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx147103-Om2LOXlhHNAe.png","datePublished":"2023-07-05","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Drama","Romance","Supernatural"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.6,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"be5cc6a0-28c0-4353-a34e-0711df895f79","tmdb_id":147103,"imdb_id":null,"content_type":"anime","title":"My Happy Marriage","original_title":"わたしの幸せな結婚","overview":"Despite being born into a noble family, Miyo lost her birth mother at a young age and grew up being abused by her stepmother, stepsister, and father.<br>\n<br>\nWhen she finally receives news that she's to be married off, she finds out that her husband-to-be is Kiyoka, a soldier with a reputation for being cruel and heartless. In fact, he's had numerous previous fiancées who have all fled his household; none lasting even a mere three days. <br><br> Resigned to the fact that her family had abandoned her, Miyo knocks on the gate of the Kudou household to find herself greeted by a beautiful man with pale skin. Despite the poor treatment she receives from her husband-to-be during their first meeting, Miyo is unable to return to her old home and spends her time cooking and doing chores. However, as the days pass, Miyo and Kiyoka being to slowly open their hearts to each other... <br>\n<br>\n(Source: KADOKAWA, edited)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx147103-Om2LOXlhHNAe.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/147103-MwFq1R7jphZT.jpg","release_date":null,"first_air_date":"2023-07-05","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Drama"},{"id":2,"name":"Romance"},{"id":3,"name":"Supernatural"}],"popularity":129500,"vote_average":7.6,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:49:40.886205+00:00","updated_at":"2026-05-02T08:49:40.843+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Kinema Citrus"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2023-09-20","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Marriage"},{"id":2,"name":"Female Protagonist"},{"id":3,"name":"Historical"},{"id":4,"name":"Bullying"},{"id":5,"name":"Heterosexual"},{"id":6,"name":"Arranged Marriage"},{"id":7,"name":"Urban Fantasy"},{"id":8,"name":"Kuudere"},{"id":9,"name":"Shoujo"},{"id":10,"name":"Super Power"},{"id":11,"name":"Politics"},{"id":12,"name":"Rehabilitation"},{"id":13,"name":"Coming of Age"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":nul