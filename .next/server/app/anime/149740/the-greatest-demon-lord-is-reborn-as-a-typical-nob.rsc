10:T47e,{"@context":"https://schema.org","@type":"TVSeries","name":"The Greatest Demon Lord Is Reborn as a Typical Nobody","description":"As the most powerful entity of all time, the Demon Lord Varvatos thinks life is a big fat snore. When he takes matters into his own hands and decides to reincarnate, he calibrates his magical strength to be perfectly average. But there is no way he could have predicted that everyone in the modern world would be weak as hell, which means he is totally overpowered once again! Reborn under the name Ard, he has ladies fawning over him, the royal family begging him to become the next king, and an ex-minion insisting on killing him?! But Ard has a one-track mind, and he won't stop at anything to achieve his ultimate goal!<br>\n<br>\n(Source: Yen Press)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx130586-vzoz4X37RZwc.jpg","datePublished":"2022-04-06","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Ecchi","Fantasy","Romance"],"aggregateRating":{"@type":"AggregateRating","ratingValue":6.2,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"6f524683-758d-4634-a25c-6b9f677cc830","tmdb_id":130586,"imdb_id":null,"content_type":"anime","title":"The Greatest Demon Lord Is Reborn as a Typical Nobody","original_title":"史上最強の大魔王、村人Aに転生する","overview":"As the most powerful entity of all time, the Demon Lord Varvatos thinks life is a big fat snore. When he takes matters into his own hands and decides to reincarnate, he calibrates his magical strength to be perfectly average. But there is no way he could have predicted that everyone in the modern world would be weak as hell, which means he is totally overpowered once again! Reborn under the name Ard, he has ladies fawning over him, the royal family begging him to become the next king, and an ex-minion insisting on killing him?! But Ard has a one-track mind, and he won't stop at anything to achieve his ultimate goal!<br>\n<br>\n(Source: Yen Press)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx130586-vzoz4X37RZwc.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/130586-77NEr6F8Kvcq.jpg","release_date":null,"first_air_date":"2022-04-06","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Ecchi"},{"id":3,"name":"Fantasy"},{"id":4,"name":"Romance"}],"popularity":100379,"vote_average":6.2,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:50:20.905874+00:00","updated_at":"2026-05-02T08:50:20.865+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"SILVER LINK."},{"name":"BLADE"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2022-06-22","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Magic"},{"id":2,"name":"Reincarnation"},{"id":3,"name":"Female Harem"},{"id":4,"name":"Male Protagonist"},{"id":5,"name":"Heterosexual"},{"id":6,"name":"Time Skip"},{"id":7,"name":"School"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:50:20.905874+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":48415,"anilist_id":130586},"social_ids":{"mal":"https://myanimelist.net/anime/48415","anilist":"https://anilist.co/anime/130586"},"gdvg_id":149740,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":nu