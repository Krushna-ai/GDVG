10:T4cd,{"@context":"https://schema.org","@type":"TVSeries","name":"Akame ga Kill!","description":"In a land where corruption rules and a ruthless Prime Minister has turned the puppet Emperor's armies of soldiers, assassins and secret police against the people, only one force dares to stand against them: Night Raid, an elite team of relentless killers, each equipped with an Imperial Arm - legendary weapons with unique and incredible powers created in the distant past.<br>\n<br>\nRescued from a fate worse than death by Night Raid, young Tatsumi is offered the chance to join their lethal ranks… but it's a deadly choice, as few can master an Imperial Arm and even fewer survive when two Arms go against each other in combat. The battle is on, and only the strongest will make it out alive.\n<br><br>\n(Source: Sentai Filmworks)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20613-HXHpec4bemk5.jpg","datePublished":"2014-07-07","numberOfEpisodes":24,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Adventure","Drama","Fantasy","Horror","Psychological","Thriller"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.3,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"5c1381bd-0c5a-4e42-b43b-dd61d4d8acbf","tmdb_id":20613,"imdb_id":null,"content_type":"anime","title":"Akame ga Kill!","original_title":"アカメが斬る！","overview":"In a land where corruption rules and a ruthless Prime Minister has turned the puppet Emperor's armies of soldiers, assassins and secret police against the people, only one force dares to stand against them: Night Raid, an elite team of relentless killers, each equipped with an Imperial Arm - legendary weapons with unique and incredible powers created in the distant past.<br>\n<br>\nRescued from a fate worse than death by Night Raid, young Tatsumi is offered the chance to join their lethal ranks… but it's a deadly choice, as few can master an Imperial Arm and even fewer survive when two Arms go against each other in combat. The battle is on, and only the strongest will make it out alive.\n<br><br>\n(Source: Sentai Filmworks)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20613-HXHpec4bemk5.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/20613-CoEQF4qKiWDX.jpg","release_date":null,"first_air_date":"2014-07-07","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Adventure"},{"id":3,"name":"Drama"},{"id":4,"name":"Fantasy"},{"id":5,"name":"Horror"},{"id":6,"name":"Psychological"},{"id":7,"name":"Thriller"}],"popularity":506633,"vote_average":7.3,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":24,"created_at":"2026-05-02T08:44:47.005779+00:00","updated_at":"2026-05-02T08:44:46.96+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"WHITE FOX"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2014-12-15","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Assassins"},{"id":2,"name":"Shounen"},{"id":3,"name":"Politics"},{"id":4,"name":"Gore"},{"id":5,"name":"Crime"},{"id":6,"name":"Swordplay"},{"id":7,"name":"Henshin"},{"id":8,"name":"Super Power"},{"id":9,"name":"Anti-Hero"},{"id":10,"name":"Male Protagonist"},{"id":11,"name":"Primarily Adult Cast"},{"id":12,"name":"Kuudere"},{"id":13,"name":"Tsundere"},{"id":14,"name":"Heterosexual"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:44:47.005779+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0