5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"PSYCHO-PASS 2\",\"description\":\"Taking place one-and-a-half years after Psycho-Pass, having learned the true nature of the Sibyl System, Akane Tsunemori chose to obey the system, believing in both humanity and the legal order. She's part of a new police section and spends her everyday life facing down criminals. Unbeknownst to Akane, however, a monster who will shake the system to its core is about to appear before her.<br>\\n<br>\\n(Source: Anime News Network)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20513-pVQqYhMwBGoh.jpg\",\"datePublished\":\"2014-10-10\",\"numberOfEpisodes\":11,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Action\",\"Psychological\",\"Sci-Fi\",\"Thriller\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.1,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"b77a26fc-ee21-4b57-8113-e89b0b94dcb4","tmdb_id":20513,"imdb_id":null,"content_type":"anime","title":"PSYCHO-PASS 2","original_title":"PSYCHO-PASS サイコパス2","overview":"Taking place one-and-a-half years after Psycho-Pass, having learned the true nature of the Sibyl System, Akane Tsunemori chose to obey the system, believing in both humanity and the legal order. She's part of a new police section and spends her everyday life facing down criminals. Unbeknownst to Akane, however, a monster who will shake the system to its core is about to appear before her.<br>\n<br>\n(Source: Anime News Network)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20513-pVQqYhMwBGoh.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/20513-dpjLwKrlNnJf.jpg","release_date":null,"first_air_date":"2014-10-10","status":"published","original_language":"ja","origin_country":[