10:T566,{"@context":"https://schema.org","@type":"TVSeries","name":"In/Spectre","description":"At the young age of 11, Kotoko Iwanaga was abducted by youkai for two weeks and asked to become their \"God of Wisdom,\" a mediator between the spirit and human worlds, to which the girl quickly agreed but at the cost of her right eye and left leg. Now, six years later, whenever youkai wish for their problems to be solved, they make their way to Kotoko for consultation.<br>\n<br>\nMeanwhile, Kurou Sakuragawa, a 22-year-old university student, has just broken up with his girlfriend after he fled alone when the two encountered a kappa. Seeing this as her chance to become closer with him, Kotoko immediately makes her move, hoping to get married to Kurou one day. However, she quickly realizes there is something more to Kurou. With this knowledge, she asks for his help in solving the various issues presented by the supernatural, all the while wishing her newfound partner will eventually reciprocate her feelings.\n","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx107201-zQYOPotwmSXO.png","datePublished":"2020-01-12","numberOfEpisodes":12,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Comedy","Mystery","Romance","Supernatural"],"aggregateRating":{"@type":"AggregateRating","ratingValue":6.8,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"dc80b2fe-d8e9-4421-9539-2d48e203d0b6","tmdb_id":107201,"imdb_id":null,"content_type":"anime","title":"In/Spectre","original_title":"虚構推理","overview":"At the young age of 11, Kotoko Iwanaga was abducted by youkai for two weeks and asked to become their \"God of Wisdom,\" a mediator between the spirit and human worlds, to which the girl quickly agreed but at the cost of her right eye and left leg. Now, six years later, whenever youkai wish for their problems to be solved, they make their way to Kotoko for consultation.<br>\n<br>\nMeanwhile, Kurou Sakuragawa, a 22-year-old university student, has just broken up with his girlfriend after he fled alone when the two encountered a kappa. Seeing this as her chance to become closer with him, Kotoko immediately makes her move, hoping to get married to Kurou one day. However, she quickly realizes there is something more to Kurou. With this knowledge, she asks for his help in solving the various issues presented by the supernatural, all the while wishing her newfound partner will eventually reciprocate her feelings.\n","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx107201-zQYOPotwmSXO.png","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/107201-XZHSg0HdC9kR.jpg","release_date":null,"first_air_date":"2020-01-12","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Mystery"},{"id":3,"name":"Romance"},{"id":4,"name":"Supernatural"}],"popularity":152263,"vote_average":6.8,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:49:25.33572+00:00","updated_at":"2026-05-02T08:49:25.289+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Brain's Base"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2020-03-29","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Urban Fantasy"},{"id":2,"name":"Heterosexual"},{"id":3,"name":"Ghost"},{"id":4,"name":"Youkai"},{"id":5,"name":"Female Protagonist"},{"id":6,"name":"Detective"},{"id":7,"name":"Meta"},{"id":8,"name":"Super Power"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:49:25.33572+00: