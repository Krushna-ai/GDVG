10:T4a3,{"@context":"https://schema.org","@type":"TVSeries","name":"The Heroic Legend of Arslan","description":"The manga’s story: In the prosperous kingdom of Pars lies the Royal Capital of Ecbatana, a city of splendor and wonder, ruled by the undefeated and fearsome King Andragoras. Arslan is the young and curious prince of Pars who, despite his best efforts, doesn't seem to have what it takes to be a proper king like his father.<br><br>\nAt the age of 14, Arslan goes to his first battle and loses everything as the blood-soaked mist of war gives way to scorching flames, bringing him to face the demise of his once glorious kingdom. However, it is Arslan's destiny to be a ruler, and despite the trials that face him, he must now embark on a journey to reclaim his fallen kingdom.<br><br>\n(Source: Anime News Network)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20935-jCAXBOuei2T8.jpg","datePublished":"2015-04-05","numberOfEpisodes":25,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Adventure","Drama","Fantasy"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.3,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"704afcf5-5b65-45a3-8795-fbb4d65c3902","tmdb_id":20935,"imdb_id":null,"content_type":"anime","title":"The Heroic Legend of Arslan","original_title":"アルスラーン戦記 (TV)","overview":"The manga’s story: In the prosperous kingdom of Pars lies the Royal Capital of Ecbatana, a city of splendor and wonder, ruled by the undefeated and fearsome King Andragoras. Arslan is the young and curious prince of Pars who, despite his best efforts, doesn't seem to have what it takes to be a proper king like his father.<br><br>\nAt the age of 14, Arslan goes to his first battle and loses everything as the blood-soaked mist of war gives way to scorching flames, bringing him to face the demise of his once glorious kingdom. However, it is Arslan's destiny to be a ruler, and despite the trials that face him, he must now embark on a journey to reclaim his fallen kingdom.<br><br>\n(Source: Anime News Network)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20935-jCAXBOuei2T8.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/n20935-WGAGPNZHbbEy.jpg","release_date":null,"first_air_date":"2015-04-05","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Adventure"},{"id":3,"name":"Drama"},{"id":4,"name":"Fantasy"}],"popularity":71990,"vote_average":7.3,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":25,"created_at":"2026-05-02T08:51:24.042156+00:00","updated_at":"2026-05-02T08:51:23.999+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"LIDENFILMS"},{"name":"SANZIGEN"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2015-09-27","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Military"},{"id":2,"name":"War"},{"id":3,"name":"Politics"},{"id":4,"name":"Royal Affairs"},{"id":5,"name":"Swordplay"},{"id":6,"name":"Historical"},{"id":7,"name":"Shounen"},{"id":8,"name":"Male Protagonist"},{"id":9,"name":"Slavery"},{"id":10,"name":"Foreign"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:51:24.042156+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":28249,"anilist_id":20935},"social_ids":{"mal":"https://myanimelist.net/anime/28249","anilist":"https://anilist.co/an