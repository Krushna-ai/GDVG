9:{"metadata":[["$","title","0",{"children":"NEW GAME! | Global Drama Verse Guide"}],["$","meta","1",{"name":"description","content":"Fresh out of high school, 18-year-old Aoba Suzukaze is bright-eyed, bushy-tailed, and ready for her first day of work at her dream job. She’s joining the character design team at Eagle Jump, the company that makes her favorite video games! But the real world of office culture can be a challenge for a total noob. From her awkward first day to her first game’s debut, she’s got a lot of skills to master. Luckily, her charming determination wins over even her quirkiest of coworkers, and before she knows it, Aoba has joined the party!<br>\n<br>\n(Source: Funimation)"}],["$","meta","2",{"name":"keywords","content":"KDrama,Anime,TV Series,Movies,Global Drama,Drama Guide,Watch Online"}],["$","meta","3",{"name":"robots","content":"index, follow"}],["$","link","4",{"rel":"canonical","href":"https://gdvg-ten.vercel.app/anime/149640/new-game"}],["$","meta","5",{"property":"og:title","content":"NEW GAME!"}],["$","meta","6",{"property":"og:description","content":"Fresh out of high school, 18-year-old Aoba Suzukaze is bright-eyed, bushy-tailed, and ready for her first day of work at her dream job. She’s joining the character design team at Eagle Jump, the company that makes her favorite video games! But the real world of office culture can be a challenge for a total noob. From her awkward first day to her first game’s debut, she’s got a lot of skills to master. Luckily, her charming determination wins over even her quirkiest of coworkers, and before she knows it, Aoba has joined the party!<br>\n<br>\n(Source: Funimation)"}],["$","meta","7",{"property":"og:url","content":"https://gdvg-ten.vercel.app/anime/149640/new-game"}],["$","meta","8",{"property":"og:image","content":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21455-hTd6T0s9fvYj.jpg"}],["$","meta","9",{"property":"og:type","content":"video.tv_show"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"NEW GAME!"}],["$","meta","12",{"name":"twitter:description","content":"Fresh out of high school, 18-year-old Aoba Suzukaze is bright-eyed, bushy-tailed, and ready for her first day of work at her dream job. She’s joining the character design team at Eagle Jump, the company that makes her favorite video games! But the real world of office culture can be a challenge for a total noob. From her awkward first day to her first game’s debut, she’s got a lot of skills to master. Luckily, her charming determination wins over even her quirkiest of coworkers, and before she knows it, Aoba has joined the party!<br>\n<br>\n(Source: Funimation)"}],["$","meta","13",{"name":"twitter:image","content":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21455-hTd6T0s9fvYj.jpg"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","$L11","15",{}]],"error":null,"digest":"$undefined"}
