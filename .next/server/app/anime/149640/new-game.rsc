5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"TVSeries\",\"name\":\"NEW GAME!\",\"description\":\"Fresh out of high school, 18-year-old Aoba Suzukaze is bright-eyed, bushy-tailed, and ready for her first day of work at her dream job. She’s joining the character design team at Eagle Jump, the company that makes her favorite video games! But the real world of office culture can be a challenge for a total noob. From her awkward first day to her first game’s debut, she’s got a lot of skills to master. Luckily, her charming determination wins over even her quirkiest of coworkers, and before she knows it, Aoba has joined the party!<br>\\n<br>\\n(Source: Funimation)\",\"image\":\"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21455-hTd6T0s9fvYj.jpg\",\"datePublished\":\"2016-07-04\",\"numberOfEpisodes\":12,\"countryOfOrigin\":\"JP\",\"inLanguage\":\"ja\",\"genre\":[\"Comedy\",\"Slice of Life\"],\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":7.4,\"bestRating\":10,\"ratingCount\":0}}"}}],["$","$L10",null,{"initialDrama":{"id":"e4b489f9-4394-4cb2-8f9b-b350be5c1f8f","tmdb_id":21455,"imdb_id":null,"content_type":"anime","title":"NEW GAME!","original_title":"NEW GAME!","overview":"Fresh out of high school, 18-year-old Aoba Suzukaze is bright-eyed, bushy-tailed, and ready for her first day of work at her dream job. She’s joining the character design team at Eagle Jump, the company that makes her favorite video games! But the real world of office culture can be a challenge for a total noob. From her awkward first day to her first game’s debut, she’s got a lot of skills to master. Luckily, her charming determination wins over even her quirkiest of coworkers, and before she knows it, Aoba has joined the party!<br>\n<br>\n(Source: Funimation)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21455-hTd6T0s9fvYj.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21455-zxd4BFfVw6SZ.jpg","release_date":null,"first_air_date":"2016-07-04","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Comedy"},{"id":2,"name":"Slice of Life"}],"popularity":116956,"vote_average":7.4,"vote_count":null,"runtime":24,"number_of_seasons":null,"number_of_episodes":12,"created_at":"2026-05-02T08:49:59.544457+00:00","updated_at":"2026-05-02T08:49:59.498+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"Doga Kobo"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2016-09-19","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Cute Girls Doing Cute Things"},{"id":2,"name":"Work"},{"id":3,"name":"Primarily Female Cast"},{"id":4,"name":"Software Development"},{"id":5,"name":"Video Games"},{"id":6,"name":"Office Lady"},{"id":7,"name":"Female Protagonist"},{"id":8,"name":"Seinen"},{"id":9,"name":"Ensemble Cast"},{"id":10,"name":"Office"},{"id":11,"name":"Primarily Adult Cast"},{"id":12,"name":"Urban"},{"id":13,"name":"Drawing"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source":"tmdb","import_batch_id":null,"import_batch_name":null,"imported_at":"2026-05-02T08:49:59.544457+00:00","region":null,"main_poster":null,"images":null,"enriched_at":null,"enrichment_cycle":0,"translations":null,"reviews_tmdb":null,"recommendations":null,"similar_content":null,"external_ids":{"mal_id":31953,"anilist_id":21455},"social_ids":{"mal":"https://myanimelist.net/anime/31953","anilist":"https://anilist.co/anime/21455"},"gdvg_id":149640,"wiki_plot":null,"wiki_synopsis":null,"wiki_episode_guide":null,"wiki_production":null,"wiki_cast_notes":null,"wiki_reception":null,"wiki_soundtrack":null,"wiki_release":null,"wiki_accolades":null,"rel