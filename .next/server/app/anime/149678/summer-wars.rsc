10:T59d,{"@context":"https://schema.org","@type":"TVSeries","name":"Summer Wars","description":"When timid eleventh-grader and math genius Kenji Koiso is asked by older student and secret crush Natsuki to come with her to her family's Nagano home for a summer job, he agrees without hesitation. <br><br>\nNatsuki's family, the Jinnouchi clan, dates back to the Muromachi era (1336 to 1573), and they've all come together to celebrate the 90th birthday of the spunky matriarch of the family, Sakae. That&rsquo;s when Kenji discovers his \"summer job\" is to pretend to be Natsuki's fiance and dance with her at the birthday celebration. <br><br>\nAs Kenji attempts to keep up with Natsuki's act around her family, he receives a strange math problem on his cell phone which, being a math genius, he can't resist solving. As it turns out, the solution to the mysterious equation causes Oz, the program that controls nearly every aspect of life to be hacked into, it's up to Kenji and his new \"family\" to stop the hacker before it's too late.<br><br>\n(Source: twitchfilm.net)","image":"https://image.tmdb.org/t/p/w500https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx5681-3DmxUVn3grD0.jpg","datePublished":"2009-08-01","numberOfEpisodes":1,"countryOfOrigin":"JP","inLanguage":"ja","genre":["Action","Comedy","Drama","Romance","Sci-Fi"],"aggregateRating":{"@type":"AggregateRating","ratingValue":7.7,"bestRating":10,"ratingCount":0}}5:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L11",null,{"initialDrama":{"id":"83ce4094-bfa4-4a3b-b90e-99fe47879ce7","tmdb_id":5681,"imdb_id":null,"content_type":"anime","title":"Summer Wars","original_title":"サマーウォーズ","overview":"When timid eleventh-grader and math genius Kenji Koiso is asked by older student and secret crush Natsuki to come with her to her family's Nagano home for a summer job, he agrees without hesitation. <br><br>\nNatsuki's family, the Jinnouchi clan, dates back to the Muromachi era (1336 to 1573), and they've all come together to celebrate the 90th birthday of the spunky matriarch of the family, Sakae. That&rsquo;s when Kenji discovers his \"summer job\" is to pretend to be Natsuki's fiance and dance with her at the birthday celebration. <br><br>\nAs Kenji attempts to keep up with Natsuki's act around her family, he receives a strange math problem on his cell phone which, being a math genius, he can't resist solving. As it turns out, the solution to the mysterious equation causes Oz, the program that controls nearly every aspect of life to be hacked into, it's up to Kenji and his new \"family\" to stop the hacker before it's too late.<br><br>\n(Source: twitchfilm.net)","poster_path":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx5681-3DmxUVn3grD0.jpg","backdrop_path":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/5681-M15hrscD9QHN.jpg","release_date":null,"first_air_date":"2009-08-01","status":"published","original_language":"ja","origin_country":["JP"],"genres":[{"id":1,"name":"Action"},{"id":2,"name":"Comedy"},{"id":3,"name":"Drama"},{"id":4,"name":"Romance"},{"id":5,"name":"Sci-Fi"}],"popularity":110230,"vote_average":7.7,"vote_count":null,"runtime":114,"number_of_seasons":null,"number_of_episodes":1,"created_at":"2026-05-02T08:50:08.688837+00:00","updated_at":"2026-05-02T08:50:08.648+00:00","tagline":null,"homepage":null,"budget":null,"revenue":null,"production_companies":[{"name":"MADHOUSE"}],"production_countries":null,"spoken_languages":null,"networks":[],"last_air_date":"2009-08-01","in_production":false,"tmdb_status":"Ended","content_rating":null,"keywords":[{"id":1,"name":"Family Life"},{"id":2,"name":"Virtual World"},{"id":3,"name":"Ensemble Cast"},{"id":4,"name":"Rural"},{"id":5,"name":"Male Protagonist"},{"id":6,"name":"CGI"},{"id":7,"name":"Coming of Age"}],"alternative_titles":null,"videos":[],"watch_providers":null,"wikidata_id":null,"tvdb_id":null,"wikipedia_url":null,"overview_source"